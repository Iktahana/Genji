    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今がいい頃だから旅行に行くことにした。",
              "source": "幻辞"
            },
            {
              "text": "その映画は昭和40年代のいい頃の東京を描いている。",
              "source": "幻辞"
            },
            {
              "text": "人生のいい頃を記念に写真をたくさん撮っておくことは大切だ。",
              "source": "幻辞"
            },
            {
              "text": "季節の変わり目でいい頃を見計らって引っ越した。",
              "source": "幻辞"
            },
            {
              "text": "その地域の観光シーズンはいい頃で、多くの観光客が訪れる。",
              "source": "幻辞"
            },
            {
              "text": "ブドウがいい頃になったので収穫を始めることにした。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちが元気で親も若い、人生でいい頃だと両親は話す。",
              "source": "幻辞"
            },
            {
              "text": "企業の売上がいい頃に経営戦略を見直すことが重要である。",
              "source": "幻辞"
            },
            {
              "text": "音楽祭はいい頃に開催されるため、多くのファンが集まる。",
              "source": "幻辞"
            },
            {
              "text": "田中氏のキャリアのいい頃に彼のドキュメンタリー映画が製作された。",
              "source": "幻辞"
            },
            {
              "text": "恋愛関係では付き合い始めのいい頃を大切にすることが長く続く関係の秘訣である。",
              "source": "幻辞"
            },
            {
              "text": "その業界の技術発展のいい頃が今の競争環境を作り出している。",
              "source": "幻辞"
            },
            {
              "text": "祖母は『若い時代のいい頃が懐かしい』と昔の写真を見ながら語った。",
              "source": "幻辞"
            },
            {
              "text": "ワイン造りではぶどうの成熟がいい頃を見極めることが品質を左右する。",
              "source": "幻辞"
            },
            {
              "text": "日本経済はバブル期のいい頃の繁栄から大きく変わった。",
              "source": "幻辞"
            },
            {
              "text": "国家の歴史でいい頃と考えられる時代は学者の間でも見解が分かれる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手のいい頃は意外と短く、ピークの維持が困難である。",
              "source": "幻辞"
            },
            {
              "text": "その地域の発展のいい頃に多くの施設が建設された。",
              "source": "幻辞"
            },
            {
              "text": "人間関係の構築ではお互いを知り始めるいい頃から深い信頼が形成される。",
              "source": "幻辞"
            },
            {
              "text": "文化的なムーブメントのいい頃に多くの傑作が生み出される傾向がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、日本はもう混乱、頽廃から起ち直ってもいい頃じゃないか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、出してもいい頃だ、と思つて、船頭は、棹を岸にあてました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら麓の村といつても、もう帰つて来ていい頃だ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち老人は、そろそろひっこんでいい頃です。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、実にいい頃合いだ、ワトソンくん。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい頃を見計らって善昌が帰って来て、これも弁天様の御罰だと云って何かの御祈祷をすると、与次郎のからだが元の通りになる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい頃を見はからって、喜三郎は他愛のない七蔵を介抱して主人のまえを退がった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで相談の上で、八橋の病気がもう少し納まるまで浮橋だけが茶屋に残っていて、いい頃を見て掛橋自身が迎いに来るか、禿を使いによこすか、それまでもう少し待っていて貰いたいということになった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　後は笑談のように笑いながら、「そんなこと岸野の農場で十年も小作をしていれば、もう分ってもいい頃だろう――なア！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていい頃合にこの冷凍をといて、ふたたび蘇生することができる。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろをこしらえていい頃だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえはいい頃に座敷へ踏ん込め」　打ち合わせをして置いて、半七はそっと表へ出ると、眼のさきに支えている妙義の山は星あかりの下に真っ黒にそそり立って、寝鳥をおどろかす山風がときどきに杉の梢をゆすっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな刺青の講釈まで聞きすまして、半七はもういい頃と衝立のこっちから声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "進は、もう中学校にはいってもいい頃と思う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……時間は丁度いい頃です。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の文学という場合、自身の雄壮を自身の耳に向ってうたう感懐に立ったロマンティシズムのほかに、国民の日々の生活が刻んでいる像を、あらゆる真実の姿でうけいれ、創り出してゆく旺んな創造力の発動にたえるだけに、日本の雄壮な精神も成熟して来ていい頃であろうと思う。",
              "citation": {
                "source": "文学は常に具体的",
                "author": "――「国民文学」に望む――",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜久子姫の御屏風なども、ちょうど季節が私の躯にいい頃だったので先ず先ず押し通せたようなものの、六月七月となるとそうは根気が続きかねます。",
              "citation": {
                "source": "画道と女性",
                "author": "――喜久子姫御用の「春秋屏風」その他――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏萩は白い花をいい頃合に着けて、夕暮れ頃の雨上りの露を含んでおります。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、もうそろそろ悪党を駆りだしてもいい頃だ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、もういい加減に身の程を知つてもいい頃ぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "分別がついてもいい頃です。",
              "citation": {
                "source": "作家的思想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪之丞は、もとより廓内に足ぶみを、公けに出来ぬ役者の身、それを口実に、いい頃合いを見はからって、姿を消したのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういい頃合だと思うよ」「なるほど、それでは何がいいかな。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう撃ってもいい頃じゃないか。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういい加減、日本空軍が鉄に困って木製や泥製の爆弾を落としてもいい頃だと思うんだが、相変らず鉄の爆弾を落としとるですが、敵もさるものですなあ」「いや。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、多少とも文化的意義をもち、教養ある事業家の矜恃を示すに足る劇場の一つや二つは、東京のどこかに、もう生れてゐてもいい頃ではないかと思ふ。",
              "citation": {
                "source": "演劇当面の問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい頃を見計って、表の戸の間に、お多賀さんが半紙をはさみ、端っこを少しのぞかせておいてくれる。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば、双葉山の場合も、もうそろそろさういふ状況にあつてもいい頃だとおもへる。",
              "citation": {
                "source": "双葉山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「観に行きたい戯曲」を書く作家が、もうそろそろ、新劇運動のなかから生れてもいい頃である。",
              "citation": {
                "source": "新劇雑誌",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自室に帰って小さくなっていたが、もういい頃だと思って、様子を見るために、再び引返してきたのだという。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
