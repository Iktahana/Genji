        "examples": {
          "standard": [
            {
              "text": "いすゞは、日本の大手自動車メーカーの一つである。",
              "source": "幻辞"
            },
            {
              "text": "いすゞのトラックは、国内外で高い信頼を得ている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの歴史は、日本の自動車産業の発展を象徴している。",
              "source": "幻辞"
            },
            {
              "text": "いすゞのディーゼルエンジンは、世界的に評価が高い。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの製品は、建設業や運送業で多く使用されている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞは、環境対応車の開発にも力を入れている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの経営は、国際的な競争環境の中で変化を余儀なくされている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの従業員たちは、品質向上に向けて日々努力している。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの販売ネットワークは、全国に広がっている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞは、トラックだけでなくバスも製造している。",
              "source": "幻辞"
            },
            {
              "text": "いすゞのブランド価値は、信頼と耐久性の象徴である。",
              "source": "幻辞"
            },
            {
              "text": "いすゞは、発展途上国でも多くの車両を提供している。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの最新技術は、自動運転やIoTの分野にも活用されている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの経営方針は、サステナビリティを重視する方向へシフトしている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞのサービスネットワークは、ユーザーの信頼を支えている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞは、グローバルな視点で製品開発を進めている。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの労働環境は、自動車業界の中でも比較的良好である。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの技術革新は、業界全体に影響を与えることがある。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの社会貢献活動は、地域社会に根ざしたものである。",
              "source": "幻辞"
            },
            {
              "text": "いすゞの今後の成長戦略には、電気自動車市場での展開が含まれている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ほとたゝら・いすゝぎひめと言はれた名であつたのが、ひめたゝら・いすゞひめ（又は、いすけよりひめ）と呼ばれるやうになつたと言ふ語原説話が行はれてゐた。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新語序で言へば、たゝらいすゞ媛と言ふべきものであつた。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が旧語序では、媛たゝらいすゞ或は媛たゝらいすけと言ふ様な形であつたのであらう。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛たゝらいすゞに対して、尠くとも、「命」は、相当後の附加で、第二次の称呼と言ふべきものである。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、末尾につく媛は、後代風には正当な位置に、接尾語としてあるものゝやうに見えるが、当然ある筈の地位に、敬語語尾として据ゑたゞけで、若し敬語語尾が、古くこゝにないのが、語序として正当ならば、前に言つたやうに、ひめたゝらいすゞでよい訣である。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "後代の習慣で、語感に不安を覚えるなら、仮りにひめたゝら・いすゞの命としてもよい。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、鏡花先生は三十五、六歳ですでに文運隆々たる時代であり、たしか「白鷺」執筆中と思いましたが、二十八、九歳の美しいすゞ子夫人を伴って御出になった時、白面の画工に過ぎなかった私は、この有名な芸術家にお逢い出来たことをどんなに感激したかわかりませんでした。",
              "citation": {
                "source": "泉鏡花先生のこと",
                "author": "小村雪岱",
                "note": "青空文庫"
              }
            }
          ]
        }
