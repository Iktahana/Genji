        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古文書には、特定の魔術師だけがその淫紋を体に刻むことを許されたと記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の背中に浮かび上がる淫紋は、一族の秘めた力を示す証だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝説によれば、その淫紋を持つ者は究極の快楽と苦痛を知るという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は彼女の淫紋に魅せられ、その意味を深く探求しようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
