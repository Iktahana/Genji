        "examples": {
          "standard": [
            {
              "text": "彼は いたいけ盛りの少年時代を過ごした。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りの少女が公園で遊んでいる。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りのころは無邪気な夢を見ていたものだ。",
              "source": "幻辞"
            },
            {
              "text": "親は子どもの いたいけ盛りを大切にしたいと思う。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りで親の言いつけをよく守っていた。",
              "source": "幻辞"
            },
            {
              "text": "あの人も いたいけ盛りを経験したはずだ。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りのこども時代は取り戻せない。",
              "source": "幻辞"
            },
            {
              "text": "両親は息子の いたいけ盛りの時期を見守った。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りなので、まだ大人の責任は果たせない。",
              "source": "幻辞"
            },
            {
              "text": "姉妹がいたいけ盛りで何も知らぬまま育った。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りの兄弟姉妹たちと過ごした日々は貴重だ。",
              "source": "幻辞"
            },
            {
              "text": "その時期は誰もが いたいけ盛りを経験するのだろう。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りの娘に世界の厳しさを教える必要がある。",
              "source": "幻辞"
            },
            {
              "text": "親戚の子どもたちもいたいけ盛りである。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りで何も知らないころのこぼれ話をしよう。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りの思い出は心に刻まれている。",
              "source": "幻辞"
            },
            {
              "text": "人生で いたいけ盛りを過ごすのは一度だけだ。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りのころは親の保護が必要である。",
              "source": "幻辞"
            },
            {
              "text": "子どもがいたいけ盛りで完全に信頼していた。",
              "source": "幻辞"
            },
            {
              "text": "いたいけ盛りでの教育がその後を左右する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "老人の物語るところによれば、この少女の名は雛子、生れて六｜歳のいたいけざかりにこちらの世界に引き移ったものだそうで、その時代は私よりもよほど後れ、帰幽後ざっと八十｜年位にしかならぬとのことでございました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
