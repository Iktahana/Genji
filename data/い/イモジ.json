    "definitions": [
      {
        "index": 1,
        "gloss": "Yi script (used to write the Yi languages)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彝文字について理解することは重要だ。",
              "source": "幻辞"
            },
            {
              "text": "この文脈で彝文字が使用されている。",
              "source": "幻辞"
            },
            {
              "text": "彝文字は様々な場面で見られる。",
              "source": "幻辞"
            },
            {
              "text": "彼は彝文字についての知識が深い。",
              "source": "幻辞"
            },
            {
              "text": "彝文字という概念は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "学習する際に彝文字は重要な要素だ。",
              "source": "幻辞"
            },
            {
              "text": "彝文字の意味を正確に理解する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "実務で彝文字を活用している。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彝文字は価値がある。",
              "source": "幻辞"
            },
            {
              "text": "彝文字に関する理論が発展している。",
              "source": "幻辞"
            },
            {
              "text": "教育で彝文字の扱い方が議論されている。",
              "source": "幻辞"
            },
            {
              "text": "社会において彝文字の役割は大きい。",
              "source": "幻辞"
            },
            {
              "text": "技術的に彝文字の応用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "文化的に彝文字が重要視されている。",
              "source": "幻辞"
            },
            {
              "text": "経済的に彝文字の影響が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "法律的に彝文字の規定がある。",
              "source": "幻辞"
            },
            {
              "text": "医学的に彝文字の研究が続いている。",
              "source": "幻辞"
            },
            {
              "text": "心理学で彝文字の理解が深まっている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彝文字の位置付けが確認されている。",
              "source": "幻辞"
            },
            {
              "text": "環境的に彝文字への対策が必要とされている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すると不意に流れの上の方から、　「ブルルル、ピイ、ピイ、ピイ、ピイ、ブルルル、ピイ、ピイ、ピイ、ピイ」とけたたましい声がして、うす黒いもじゃもじゃした鳥のような形のものが、ばたばたばたばたもがきながら、流れて参りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頑丈な強い男で黒いもじゃもじゃの髭を生やし、真黒く逆だつ眉毛の下の目が山国の男の狂わしい眼つきを持ってはいたが、心はやさしい男であった。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い、にじんだ平仮名ばかりで、ところどころへ涙の汚点を作りながら、「わたくしのしんぱいおすいもじくだされたく候」と繰返し繰返し書いてやったのである。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは全然別な裁判官であって、頬の側にまで達している黒いもじゃもじゃの一面の髯を生やした肥った男だったし、あの絵は油絵だったが、これはパステルでさっとぼかしてあった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しりもちをついて、赤いもじゃもじゃひげは、砂だらけ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下から、あぶらけのないもじゃもじゃ頭があらわれた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いもじ谷というところは、古い鉱滓などがころがっている。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし鋳造所でもあったらしく、地名のいもじは「鋳物師」と書くらしい。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
