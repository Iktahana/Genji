    },
    "definitions": [
      {
        "index": 1,
        "gloss": "squid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "背中がい文字に曲がった老人が杖をついて歩いていた。",
              "source": "幻辞"
            },
            {
              "text": "長時間のデスクワークでい文字になった姿勢を直す必要がある。",
              "source": "幻辞"
            },
            {
              "text": "体操でい文字の姿勢を改善できるという。",
              "source": "幻辞"
            },
            {
              "text": "い文字の姿勢は腰痛や頸椎症の医学的原因となることが知られている。",
              "source": "幻辞"
            },
            {
              "text": "い文字矯正は整形外科的リハビリテーションの一部である。",
              "source": "幻辞"
            },
            {
              "text": "人間工学の研究でい文字の姿勢による脊椎への影響が測定されている。",
              "source": "幻辞"
            },
            {
              "text": "い文字の矯正には脊椎物理学の知見が応用される。",
              "source": "幻辞"
            },
            {
              "text": "人間工学の講座でい文字の姿勢が健康上の問題として説明される。",
              "source": "幻辞"
            },
            {
              "text": "体育学の授業では正しい姿勢とい文字の改善方法が教えられる。",
              "source": "幻辞"
            },
            {
              "text": "絵画の人物表現でい文字の姿勢が悲哀や疲労を象徴することがある。",
              "source": "幻辞"
            },
            {
              "text": "い文字の背中は美術表現の一つの主題である。",
              "source": "幻辞"
            },
            {
              "text": "い文字の従業員には人間工学に基づく椅子が支給された。",
              "source": "幻辞"
            },
            {
              "text": "い文字予防はオフィス環境改善の重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "高齢者のい文字は骨粗しょう症と関連していることが医学的に示されている。",
              "source": "幻辞"
            },
            {
              "text": "い文字による歩行障害は転倒リスクを高める。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーション専門家はい文字の治療を重視している。",
              "source": "幻辞"
            },
            {
              "text": "長時間立ち仕事をするとい文字になりやすいという研究結果がある。",
              "source": "幻辞"
            },
            {
              "text": "職業的に前かがみの姿勢を強いられる労働者はい文字になりやすい。",
              "source": "幻辞"
            },
            {
              "text": "い文字は加齢とともに増加する姿勢的変化である。",
              "source": "幻辞"
            },
            {
              "text": "い文字を予防するための運動習慣が健康寿命に与える影響が研究されている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だから、ちょっと見ると濁るべき所を濁らない文字で書いてあるように見えるけれども、そうではない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "實感を伴はない文字の遊戲と思はれてゐたものが、強い實感を現すための新しい手段と見直せるやうになつた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、たしかに、盗人の三分の理にも似ているが、しかし、私の胸の奥の白絹に、何やらこまかい文字が一ぱいに書かれている。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、十匹の蟻が、墨汁の海から這い上って、そうして白絹の上をかさかさと小さい音をたてて歩き廻り、何やらこまかく、ほそく、墨の足跡をえがき印し散らしたみたいな、そんな工合いの、幽かな、くすぐったい文字。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "却ってそのつやつやした緑色の葉の上に次々せわしくあらわれては又消えて行く紫色のあやしい文字を読みました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記や書信が彼の面前に展げられ、彼のわくわくした心の上に読みおろされたとき、そんな激しい文字を使ひ合つて居た当時の気分が自分で了解し悪い程であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊い文字は、掌に一字ずつ幽に響いた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糊刷毛かなにかでもって書いたものらしく、仰山に肉の太い文字で、そのうえ目茶苦茶ににじんでいた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふにあの美しい「敍情詩人」といふ名稱は私の墓石の銘を飾るためには最も適はしい文字でせう。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "解らない文字は字引を見て覚えた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の障子には、太い文字で「呉服太物」と書いてあつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酢、醤油、上州屋」　何といふ美しい文字だらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の美しい、立派な人でなければ書けない文字だ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは方々旅して来ましたが、こんないい文字を路ばたで見掛けたのは始めてです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼には徒らに判読しがたい文字の羅列であつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、鉛筆の色薄く書かれた文字は老人らしく佶屈な、分りにくい文字だつた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂市君や、源五兵衛君や、照次郎君などが、知らない文字をうのみにして読本を読んでいっても、最初のころのように、え、え、と、優美にとがめるようなことはされなくなった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、初めの表現に不自然な個処があり、的確で無い文字が一つでも挿まつてゐる、それが目につくから、それを真に自然に、真の表現にまで還すが為めに苦しむのである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二三字の怪しい文字を刻みつけたものであった。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一個の棺桶が置いてあったが、その上に紙を貼って太い文字を書いてあった。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一個の棺桶が置いてあったが、その上に紙を貼って太い文字が書いてあった。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川柳に「三たび口説いて聴かれず身｜退く振られ客」とあるごとし、『爾雅』に虎の浅毛なるを山、黒きを、虎に似て真でないを彪、虎に似て角あるを※というと言って、むつかしい文字ばかり列べ居る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "th・rtee・この排列はすぐ‘thirteen’という言葉を思いつかせ、6、＊であらわしてあるｉ、ｎという二つの新しい文字をまた教えてくれる。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャコールグレーの小さなマシンは、白地の画面に黒い文字を浮かび上がらせました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い頁に記された黒い文字はスクロールすることなく、キーの操作によって頁をめくりながら読むスタイルが採用された。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため、普通のパソコンで入力できない文字（以下、「外字」と書く）の処理など、一部に異なった作業方針も選ぶことになった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この反省を踏まえ、新しい規格にもない文字の使用状況に関する調査が先々必要になった場合に備えて、作品中にＪＩＳ X ０２１３外字が使われていた際は、底本の何頁何行目に現れるかの情報を添え、外字情報だけを簡単に切り出せるように、ＸＨＴＭＬファイルの末尾に集約しておくことにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしそのためには、暗号の類としか思えない文字の連なりを、キーボードから綴りを間違えることなく入力することを求められる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると不意に流れの上の方から、　「ブルルル、ピイ、ピイ、ピイ、ピイ、ブルルル、ピイ、ピイ、ピイ、ピイ」とけたたましい声がして、うす黒いもじゃもじゃした鳥のような形のものが、ばたばたばたばたもがきながら、流れて参りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頑丈な強い男で黒いもじゃもじゃの髭を生やし、真黒く逆だつ眉毛の下の目が山国の男の狂わしい眼つきを持ってはいたが、心はやさしい男であった。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
