    "definitions": [
      {
        "index": 1,
        "gloss": "to ease (sewing garments)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生地をいせることで形状を整える。",
              "source": "幻辞"
            },
            {
              "text": "職人は経験を積んで布地をうまくいせる。",
              "source": "幻辞"
            },
            {
              "text": "蒸気を使って生地をいせる方法がある。",
              "source": "幻辞"
            },
            {
              "text": "着物の仕立てではていねいにいせる必要がある。",
              "source": "幻辞"
            },
            {
              "text": "縮みやすい生地は特に気をつけていせる。",
              "source": "幻辞"
            },
            {
              "text": "新しい衣料品をいせて寸法を安定させる。",
              "source": "幻辞"
            },
            {
              "text": "綿麻混紡の生地はいせると品質が向上する。",
              "source": "幻辞"
            },
            {
              "text": "工業用の大型機械でいせることも可能だ。",
              "source": "幻辞"
            },
            {
              "text": "羊毛製品の風合いをいせることで活かす。",
              "source": "幻辞"
            },
            {
              "text": "シルク素材は丁寧にいせることが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "湿度と熱を調整していせるのがコツだ。",
              "source": "幻辞"
            },
            {
              "text": "既製品でも時々いせると長持ちする。",
              "source": "幻辞"
            },
            {
              "text": "均一な圧力でいせるため専門の道具を使う。",
              "source": "幻辞"
            },
            {
              "text": "織り目を崩さないようにいせることが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "防水加工生地もいせることができる。",
              "source": "幻辞"
            },
            {
              "text": "厚手生地をいせるには工夫が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "完成したクッションカバーをいせて仕上げる。",
              "source": "幻辞"
            },
            {
              "text": "ストレッチ素材をいせるときは注意が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "プロの仕上がり加工ではしっかりいせられている。",
              "source": "幻辞"
            },
            {
              "text": "家庭用アイロンでも軽くいせることは可能だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "向うが面白がつて居られなくなれば、殿樣もいくらか腹がいせる譯だ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　（あらわる）お前は何者じゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　では「死ぬるもの」じゃな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　お前はまたごまかしたな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　お前は甘えているな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　それはほんとうじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　わしは死なざるものに仕える臣じゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　お前はたびたびわしの名を呼ぶようじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　わしはモータルには顔を見せぬものじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　モータルを見るとわしは恥ずかしくて死ぬるからじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　死ぬのは罪があるからじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　皆悪人じゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　（あらわる）お前はまたわしを呼んだな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　ゆるされぬ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　その欲望はお前の分に過ぎている。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　あわれなものよ！",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間　（手をのばして顔蔽いをとろうとする）顔蔽いせる者　その手に禍いあれ！",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　見よ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　彼は全列を率いている。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　そして哀れなもののなかの最も哀れなものだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　滅亡へ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　よく見よ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　幸福の破れるのを知りかけているのだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　わしに気がつきかけているのじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　わしをまっすぐに見ないものの陥るあやまちじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　小猿の知識でな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　それはこわれないたしかなものを鍛え出すためじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　見つかったかな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　こわれるものはみなこわすのがわしの役目じゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
