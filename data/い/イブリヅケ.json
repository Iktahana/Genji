        "examples": {
          "standard": [
            {
              "text": "秋田の郷土料理『いぶり漬け』は独特の香りが特徴だ。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けの塩辛さが白いご飯によく合う。",
              "source": "幻辞"
            },
            {
              "text": "友人の実家からいぶり漬けの瓶詰めが届いた。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けはご当地商品として高い売上を記録している。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けのマーケティングで地方の振興に成功した。",
              "source": "幻辞"
            },
            {
              "text": "食品科学でいぶり漬けのスモーク成分が分析されている。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けの保存性は燻製の化学的メカニズムに基づいている。",
              "source": "幻辞"
            },
            {
              "text": "地方の民俗文学ではいぶり漬けが文化的象徴として登場する。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けを題材にした民話が伝わっている。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的見地からいぶり漬けの燻製成分が健康効果を持つ可能性が研究されている。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けの塩分含量は健康食の観点から注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "地方文化研究の中でいぶり漬けの製造技術の継承が重要な課題とされている。",
              "source": "幻辞"
            },
            {
              "text": "食文化学ではいぶり漬けが保存食としての文化的意味を持つことが指摘されている。",
              "source": "幻辞"
            },
            {
              "text": "郷土の食文化を代表する食品としていぶり漬けは観光資源としても価値がある。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けの伝統的製法は無形文化財として保護されるべき対象である。",
              "source": "幻辞"
            },
            {
              "text": "食糧技術の発展の中でも、いぶり漬けのような伝統的製法の価値は失われていない。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けは世代を超えて愛される家庭の味として記憶される。",
              "source": "幻辞"
            },
            {
              "text": "ふるさと納税の返礼品としていぶり漬けは高い人気を誇っている。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けのような地方産品の販売は地域経済の活性化に貢献している。",
              "source": "幻辞"
            },
            {
              "text": "いぶり漬けの製造業者は伝統と革新のバランスを取りながら事業を展開している。",
              "source": "幻辞"
            }
          ],
