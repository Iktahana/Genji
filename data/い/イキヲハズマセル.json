        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マラソンランナーはゴール直前、息を弾ませながら最後の力を振り絞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "テニスの試合、激しいラリーの合間に選手たちは息を弾ませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "重い荷物を運び終え、彼は額の汗を拭いながら息を弾ませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "階段を駆け上がると、急に動悸がして、息を弾ませてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の大きな音に驚き、彼女は息を弾ませて部屋を飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわっ、危なかった！」と、肝を冷やした彼は息を弾ませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは公園で夢中になって遊び、息を弾ませながらも笑顔を絶やさなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "（何んとスバラシイ美の構成であろう）　景岡は夢みるように、手を振って、幻を掴み乍ら、激しい鼓動に、息を弾ませるのでした。",
              "citation": {
                "source": "足の裏",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、息を弾ませるようにして、せかせかと、古風な下着の襟がちぐはぐに出過た胸元に、黒繻子の帯をしめた。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
