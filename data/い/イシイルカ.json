        "examples": {
          "standard": [
            {
              "text": "いし海豚は、イルカ科に属する海の哺乳動物である。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の体長は、通常2メートル程度で、比較的小型である。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚は群れで行動し、集団で狩りを行う習性がある。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚を観察することで、海の生態系の理解が深まる。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚は、高度な知能を持つ哺乳動物として知られている。",
              "source": "幻辞"
            },
            {
              "text": "沿岸部では、いし海豚が定期的に見られる地域がある。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の繁殖期には、独特の行動パターンが観察される。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の音声コミュニケーション能力は、非常に高度である。",
              "source": "幻辞"
            },
            {
              "text": "海洋ツアーで、運が良いといし海豚の群れを見かけることができる。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚は、魚やイカを主な食料としている。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の骨格は、陸生哺乳動物から進化した形態を保持している。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の寿命は、通常20年から30年とされている。",
              "source": "幻辞"
            },
            {
              "text": "水族館では、いし海豚の生態について教育プログラムが提供されている。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の個体差による性格の違いについて、研究者たちが興味を持っている。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚は、環境汚染に敏感であり、個体数が減少している地域もある。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の行動を追跡調査することで、海の流れや水温を推定することができる。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚は、人間とのふれあいを好む個体が多いことで知られている。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚を保護することは、海洋生態系全体の保全につながる。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚の知見は、海洋哺乳動物全般の研究に貴重な情報をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "いし海豚との共存を考えることは、人間と自然の関係を問い直す機会である。",
              "source": "幻辞"
            }
          ],
