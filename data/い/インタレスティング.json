        "examples": {
          "standard": [
            {
              "text": "「この映画、すごくインタレスティングだったよ！」と友人が興奮気味に話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はいつもインタレスティングな話題を提供してくれるので、一緒にいると飽きない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その研究結果は、科学界にとって非常にインタレスティングなものとなるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ふーん、それはインタレスティングですね」と、彼は含みのある笑顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして読後そのインタレスティングを吟味してみよ。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
