[
  {
    "uuid": "94a94f6c-006d-551d-9c6c-37e3db11777c",
    "entry": "いい時間",
    "reading": {
      "primary": "いいじかん",
      "alternatives": [
        "よいじかん"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(getting) late",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人と一緒に過ごす時間はいい時間である。",
              "source": "幻辞"
            },
            {
              "text": "子どもの成長を見守るのはいい時間だと親は感じる。",
              "source": "幻辞"
            },
            {
              "text": "読書に没頭する時間はいい時間として多くの知識人に愛されている。",
              "source": "幻辞"
            },
            {
              "text": "日没の時間帯はいい時間として、多くの写真家に利用される。",
              "source": "幻辞"
            },
            {
              "text": "音楽を聴く時間はいい時間として、ストレス軽減に効果的だと研究で示されている。",
              "source": "幻辞"
            },
            {
              "text": "瞑想の時間をいい時間として位置付ける企業の研修が増えている。",
              "source": "幻辞"
            },
            {
              "text": "家族と食事をする時間がいい時間として価値を見出す文化は多い。",
              "source": "幻辞"
            },
            {
              "text": "執筆活動が進む時間をいい時間として作家は珍重する。",
              "source": "幻辞"
            },
            {
              "text": "朝日を見る時間はいい時間として、散歩愛好家に重宝されている。",
              "source": "幻辞"
            },
            {
              "text": "学習する時間をいい時間として位置付けることが成功の秘訣だと教育者は語った。",
              "source": "幻辞"
            },
            {
              "text": "運動をする時間がいい時間として認識されることで、健康寿命が延びると医学的に示唆されている。",
              "source": "幻辞"
            },
            {
              "text": "思考する時間をいい時間として確保する習慣が、クリエイティビティを高める。",
              "source": "幻辞"
            },
            {
              "text": "自然の中で過ごす時間はいい時間として、都市生活者に求められている。",
              "source": "幻辞"
            },
            {
              "text": "仕事の合間の休憩時間がいい時間として位置付けられると、業務効率が向上することが報告されている。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品を鑑賞する時間がいい時間として心を豊かにすることが一般的に認識されている。",
              "source": "幻辞"
            },
            {
              "text": "人間関係を深める時間がいい時間として価値があることを、心理学は支持している。",
              "source": "幻辞"
            },
            {
              "text": "創造的な活動をする時間をいい時間として保証する企業が増えている。",
              "source": "幻辞"
            },
            {
              "text": "旅行中の移動時間さえもいい時間として楽しむことが充実した人生の秘訣である。",
              "source": "幻辞"
            },
            {
              "text": "瞑想やヨガの時間をいい時間として捉えることで、精神面での改善が期待できる。",
              "source": "幻辞"
            },
            {
              "text": "人生の異なるステージで『いい時間』の定義が変わることは、成長と歩みを共にしている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "きかなくてもいい時間をきいたのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の外塀を乗り越えて、三毛猫、白猫、黒猫、実にいろいろ近所の猫たちが入れかわり立ちかわりやって来ては、そのまま黙って通り過ぎてゆくものもあり、朝や午後からの陽あたりのいい時間には手すり廊下の一個所で、まことに心持ちよげに一刻の睡をむさぼってゆく。",
              "citation": {
                "source": "画室談義",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もう、お目ざのおうたをうたってもいい時間ね。",
              "citation": {
                "source": "金のくびかざり",
                "author": "小野浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからソーホー街へ出掛ければいい時間である。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたは公休日の前日だから、いい時間にいらっしゃらないと何にもありませんよ」七月○日　○ちゃんが愈※明日出発。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "役にも立たぬ手なぐさみや、一つ話題のくどくど話に、一日で一番いい時間と最上の精力をとられて、とどのつまり残るものといったら、何やらこう尻尾も翼も失せたような生活、何やらこう痴けきった代物だが、さりとて出て行きも逃げ出しもできないところは、癲狂院か監獄へぶち込まれたのにそっくりだ！",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚八とても目にアリアリと残っている情景、気色のいい時間ではないらしく、目をとじて、顔をふせたが、フシギや甚八の面色は土色に改まり、額に汗がうき、彼は握りしめた手をひらいて、急いで胸をかきわけるようにしたと思うと、前へのめって、畳をむしり、「ウッ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、戻ってもいい時間だ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、あした、あなたのいい時間によりましょう」　キャルディネ通りの下宿の経営者はふるい軍人あがりらしい老人であった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもいい時間です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えながら歩くこと、すなわち逍遙すること、それは哲学者にとってはいい時間つぶしである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食を食べ終えると、ちょうどいい時間となった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、夕食にちょうどいい時間になる」　海に沿ったハイウエイまで降りていき、再び海沿いを走った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るのにちょうどいい時間だ、と彼は思った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の進行に合わせて、五人はそこでいい時間を過ごすことが出来た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
