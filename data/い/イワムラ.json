        "examples": {
          "standard": [
            {
              "text": "この岩群は、風雨にさらされて独特の形になっているね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "頂上からの眺めは最高だ。この岩群のてっぺんから、雄大な景色が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "クライミングの練習で、この岩群のルートを制覇したんだ。達成感がたまらない！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "其外は、廣い水田と、畠と、存外多い荒蕪地の間に、人の寄りつかぬ塚や岩群が、ちらばつて見えるだけであつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外は、広い水田と、畠と、存外多い荒蕪地の間に、人の寄りつかぬ塚や岩群が、ちらばつて見えるだけであつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外は、広い水田と、畠と、存外多い荒蕪地の間に、人の寄りつかぬ塚や岩群が、ちらばって見えるだけであった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二句）岩群れてひたすら群れて薄暑かな薫風やいと大いなる岩一つその岩をえて弁当をひらく。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岬ゆ　海礁三つ越えて、大き岩群神島のそがひに　晴るゝ志摩の国。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの耶馬渓を構成する岩に似た岩群のたたずまいであった。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
