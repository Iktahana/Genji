        "examples": {
          "standard": [
            {
              "text": "急な発熱で体調が悪くなったので、近くの医療機関を受診した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域には小児科のある医療機関が少なく、子育て世帯には不便だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大規模災害時には、医療機関への負担が集中し、機能不全に陥るリスクがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜間や休日に対応してくれる医療機関のリストを常に携帯している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "国民保健、とくに肺結核の対策については、なるほど厚生省といふやうな役所はできたが、全国の医療機関がそのために実質的に整へられた風もない。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤秀三『社会と医療機関』竹内『公衆衛生』などあり、『海軍衛生』というのも買ってみました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
