        "examples": {
          "standard": [
            {
              "text": "いじめっ子は、自分より弱い者を狙う傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の多くは、家庭での問題を抱えていることがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の行為は、被害者に深刻な心理的ダメージを与える。",
              "source": "幻辞"
            },
            {
              "text": "学校内でいじめっ子として知られている生徒が、実は悩みを抱えていることもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子を更生させるためには、その背景にある問題の解決が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子に対して厳しく対応することも、教育の一環である。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の行為が法律違反に該当することを認識させることが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の中には、自分の行動の重大性に気づいていない者もいる。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子と被害者の関係改善は、簡単ではないが、不可能ではない。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子のグループ心理を理解することが、対策の鍵となる。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の暴力が陰湿さを増すにつれ、被害者の苦痛は深刻になる。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子は、被害者の親から訴えられる可能性もある。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の特徴として、権力への執着や支配欲が挙げられる。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子が大人になった時、その行為を後悔することもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子を周囲が支持しないような文化を作ることが大事だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の多くは、注目と支配を求めているのだと言える。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子に対する学校の対応が問われる時代になった。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子としての行動パターンが固定化される前に、介入が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子であった過去を持つ大人の多くが、自分の行為を反省している。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子の心理を理解することで、より効果的な教育が可能になる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二六　いじめっ子　幼稚園にはいっていた僕はほとんど誰にもいじめられなかった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし小学校へはいるが早いか僕はたちまち世間に多い「いじめっ子」というものにめぐり合った。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いじめっ子」は杉浦誉四郎である。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今漫然と「いじめっ子」の心理を考えている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いじめっ子と、いじめられっ子とである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも、せんだんは双葉より芳しく、強烈な腕ッ節に物をいわせて、いじめっ子の特権を誇示していた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる『いじめっ子』だ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の周囲にもやはりいじめっ子というものがいた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、おれも殺すぞッ」　克彦は、両手に靴を持って、泣きわめきながら、いじめっ子に向かって行く幼児のようになって、めちゃくちゃな力をふりしぼった。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
