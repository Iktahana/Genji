        "examples": {
          "standard": [
            {
              "text": "彼の描いた抽象画は、見る人によって様々なインタープリテーションを許す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事件現場に残された証拠のインタープリテーションが、捜査の行方を左右するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古典文学の新しいインタープリテーションが、学術界で注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "データ分析では、数字の羅列から意味のあるインタープリテーションを導き出すのが腕の見せ所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "インタープリテーションでなく、まづは詩であるためには、苦しいと云へば苦しい、長い道を歩いたことであつた。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
