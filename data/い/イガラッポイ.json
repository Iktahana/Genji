[
  {
    "uuid": "3accfa67-b98a-51ab-82d4-c04864807cd4",
    "entry": "い辛っぽい",
    "reading": {
      "primary": "いがらっぽい",
      "alternatives": [
        "えがらっぽい"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "feeling rough (of the throat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この醤油の味はい辛っぽい香りが特徴だ。",
              "source": "幻辞"
            },
            {
              "text": "この品種の果物はい辛っぽい風味を持っている。",
              "source": "幻辞"
            },
            {
              "text": "古い野菜はい辛っぽい後味になることがある。",
              "source": "幻辞"
            },
            {
              "text": "塩分が多いこのスープはい辛っぽい感じだ。",
              "source": "幻辞"
            },
            {
              "text": "燻製された肉はい辛っぽい香りがする傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "発酵食品はい辛っぽい独特の風味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "このワインはい辛っぽい酸味が目立つ。",
              "source": "幻辞"
            },
            {
              "text": "新鮮でない牛乳はい辛っぽい匂いがする。",
              "source": "幻辞"
            },
            {
              "text": "冬の野菜にはい辛っぽい苦味が増すことがある。",
              "source": "幻辞"
            },
            {
              "text": "この漬物はい辛っぽい味わいが特徴である。",
              "source": "幻辞"
            },
            {
              "text": "年代物のチーズはい辛っぽい香りが強い。",
              "source": "幻辞"
            },
            {
              "text": "腐りかけの果実はい辛っぽい臭いを放つ。",
              "source": "幻辞"
            },
            {
              "text": "珈琲豆を深く焙煎するとい辛っぽい味になる。",
              "source": "幻辞"
            },
            {
              "text": "この種の香草はい辛っぽい香りが利いている。",
              "source": "幻辞"
            },
            {
              "text": "老化した油はい辛っぽい風味が生じる。",
              "source": "幻辞"
            },
            {
              "text": "発酵過程で生じるい辛っぽい香りは自然なものだ。",
              "source": "幻辞"
            },
            {
              "text": "この地方の酒はい辛っぽい独特の味が評判だ。",
              "source": "幻辞"
            },
            {
              "text": "新しいコーヒーと比べると古い豆はい辛っぽい。",
              "source": "幻辞"
            },
            {
              "text": "この調味料はい辛っぽい後味を残す。",
              "source": "幻辞"
            },
            {
              "text": "熟成されたチョコレートはい辛っぽい苦味がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いがらっぽいその煙にあうと、犬もはげしく、くしゃみをした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつは腹這いになって、ふうっと火を吹きましたが、咽喉のいがらっぽい白い煙がむつの吹く息で向うへ押されてゆきます。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは工場へ歩いて行く藁工場ではささり込むような塵埃がもうろうと立ちのぼりいがらっぽい呼吸が出てあなたの呼吸器管は日に日に衰えて行く夜、晩くあなたは家へ帰って休む。",
              "citation": {
                "source": "我等の春",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて熱っぽい、いがらっぽい煙が流れこんできた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が重く、喉はいがらっぽいのだが、彼は、大声を立てて笑うのである。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
