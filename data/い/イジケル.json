    "definitions": [
      {
        "index": 1,
        "gloss": "to grow timid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "兄に馬鹿にされて、弟はいじけている。",
              "source": "幻辞"
            },
            {
              "text": "試験に落ちたからといって、いじけてはいけない。",
              "source": "幻辞"
            },
            {
              "text": "チームから選ばれなかったため、彼はいじけてしまった。",
              "source": "幻辞"
            },
            {
              "text": "親の期待に添えず、子どもがいじけ始めた。",
              "source": "幻辞"
            },
            {
              "text": "失敗を経験すると、自信をなくしていじける人もいる。",
              "source": "幻辞"
            },
            {
              "text": "友人に仲間外れにされたせいで、彼はいじけていた。",
              "source": "幻辞"
            },
            {
              "text": "いじけた態度では、問題は解決しないことを学んだ。",
              "source": "幻辞"
            },
            {
              "text": "点数が低かったことで、学生がいじけてしまった。",
              "source": "幻辞"
            },
            {
              "text": "恋人に振られて、彼女はしばらくいじけていた。",
              "source": "幻辞"
            },
            {
              "text": "親友に裏切られたと感じて、いじける気持ちが生まれた。",
              "source": "幻辞"
            },
            {
              "text": "試練に直面した時、いじけるのではなく立ち上がることが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツで負けて、選手がいじけた表情を見せた。",
              "source": "幻辞"
            },
            {
              "text": "給与が上がらないことで、従業員がいじけ始めた。",
              "source": "幻辞"
            },
            {
              "text": "いじけた人間に誰も近づきたくないという心理がある。",
              "source": "幻辞"
            },
            {
              "text": "人生で何度も失敗すると、いじける気持ちも薄れてくる。",
              "source": "幻辞"
            },
            {
              "text": "いじけた態度は、周囲の人々を遠ざけてしまう。",
              "source": "幻辞"
            },
            {
              "text": "若い時にいじけてばかりいると、その癖が定着する可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "親に褒められない経験が多いと、子どもはいじけやすくなる。",
              "source": "幻辞"
            },
            {
              "text": "いじけずに前に進む勇気を持つことが、人生に必要である。",
              "source": "幻辞"
            },
            {
              "text": "挫折を乗り越えずにいじけたままでは、成長することができない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "給仕は自然いじける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、何を茫然石地蔵を抱いた風で突立ってるんだ、いじけるない。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の心得　石膏の胸像をば画面の中央へいじける事なくまた実物よりも妙に大きくならぬよう、ほぼ実在の大きさを想像させる位いの、のびやかさを以て画面の中央へ行儀よく描くべき事。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女軽業師の親方のお角の前へ出ると、どうも妙に気が引けて、いじけるのはおかしいくらいです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活がいじける訳である。",
              "citation": {
                "source": "ペンクラブと芸術院",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しなぜ、何に遠慮してそんなにいじけるか、又いじけさせるか、と云えばそれは取りも直さず放送協会と放送局に君臨する言論統制の権威のおかげであることは云うまでもない。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、姉の傍へは寄って来ないで遠くから、いじけるように姉の気色を伺って、やはり雨の中に立っているのでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えようとすれば、かえっていじけるもののみでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば、戦々｜兢々と、古い名声にかじりついている大家たちも、気楽に新しいものが書けるかも知れず、新進無名もいじけることなしに全力が発揮できるだろう。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「情愛々々って言っても、お前のは猫可愛がりだから何にもならない」「男親の前へ出ると思うことが碌々言えない子ですから、女親が相談に乗ってやらなければいじけるばかりですわ」「何あに、狡いんだ。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
