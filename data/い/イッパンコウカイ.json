        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ウェブサイトのこのページは、特にセキュリティ上の問題がないため一般公開設定にしてあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "共有サーバー上の機密性の高いファイルは、誤って一般公開されないよう厳重なアクセス制限がかけられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラウドストレージのフォルダ設定を確認したら、いつの間にか個人情報を含むデータが一般公開になっていて焦った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
