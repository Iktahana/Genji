        "examples": {
          "standard": [
            {
              "text": "医者の診察を受けてから初めていぼ痔と診断された。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔の治療は症状に応じて薬や手術を選択する。",
              "source": "幻辞"
            },
            {
              "text": "悪い姿勢がいぼ痔の原因になることもある。",
              "source": "幻辞"
            },
            {
              "text": "医療関連企業は『いぼ痔』の治療薬の開発に投資している。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔関連の市場は毎年拡大している。",
              "source": "幻辞"
            },
            {
              "text": "医学研究でいぼ痔の発症メカニズムが解明されている。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔の治療法は消化器医学の重要な課題である。",
              "source": "幻辞"
            },
            {
              "text": "肛門科医はいぼ痔の治療法として複数の選択肢を患者に提示する。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔の予防には適切な食生活と生活習慣が医学的に推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "江戸時代の文学作品で『いぼ痔』は人物描写の一部として言及されることがある。",
              "source": "幻辞"
            },
            {
              "text": "古典医学書の記録にいぼ痔の言及がある。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔は一般的な健康問題として医学教育の重要なトピックである。",
              "source": "幻辞"
            },
            {
              "text": "生活習慣病の一種として、いぼ痔の予防が啓発活動の対象とされている。",
              "source": "幻辞"
            },
            {
              "text": "医学部の講義でいぼ痔の病態生理が教授される。",
              "source": "幻辞"
            },
            {
              "text": "医学教科書にいぼ痔の診断と治療方針が記載されている。",
              "source": "幻辞"
            },
            {
              "text": "人口高齢化に伴ういぼ痔の患者数は増加する傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "肛門疾患の専門医の需要は、いぼ痔患者の増加に伴い高まっている。",
              "source": "幻辞"
            },
            {
              "text": "いぼ痔のような一般的疾患についての医学的情報提供は患者教育の重要な側面である。",
              "source": "幻辞"
            },
            {
              "text": "健康寿命を延ばすためにはいぼ痔のような慢性疾患の早期発見が重要である。",
              "source": "幻辞"
            },
            {
              "text": "医療費抑制の観点からも、いぼ痔の予防と早期治療が推奨されている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　銀子は梳いた髪をいぼじり捲きにしてもらい、少しはせいせいして、何か胸がむず痒いような感じで膝のうえで雑誌をめくったりしていたが、小谷さんは新聞にたまった雲脂と落ち毛を寄せて、外へ棄てに行った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "前垂掛――そう、髪もいぼじり巻同然で、紺の筒袖で台所を手伝いながら――そう、すなわち前に言った、浜町の鳥料理の頃、鴾氏に誘われて四五｜度出掛けた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はえりあしよりいぼじり巻きに巻き上げて。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎「じゃア浜子さん願いましょう」とかのいぼじり巻きの貴嬢を連れて行く。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "本筋だけれど理詰めで面白くないという「芸」は、人間のお神さんにたとえると、貧乏をものともせず亭主大事と働きまくる世話女房だが、それだけに髪はいぼじり巻、身だしなみもよろしからず。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "首吊の髪は、手拭いをぐるぐる巻きに結い込んでいる、俗にいういぼじり巻きである。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、髪まで同じいぼじり巻きだから、こりゃあ誰でもお美野さんだと――。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の乳白色な、小肥りといってよいくらいな肉附の、三十を越した年増ではありますが、キリリとした身のこなし、真黒な髪をいぼじりといったように無雑作に巻きつけてあるのは、この際だからやむを得ますまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、いぼじり巻に、珊瑚の粒をとめている年増だった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
