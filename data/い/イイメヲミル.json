        "examples": {
          "standard": [
            {
              "text": "初めての事業で失敗し、大変ないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "詐欺師に騙されてしまい、ひどいいい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "投資に失敗して、思わぬいい目を見ることになった。",
              "source": "幻辞"
            },
            {
              "text": "無理な運転で事故に遭い、大変なないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "友人の借金を肩代わりして、辛いいい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "不動産投資で損失を被り、大きなないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "契約書を読まずにサイン上してしまい、いい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "詐欺メールに騙されて、金銭的なないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "職場の陰謀に巻き込まれ、ひどいいい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "病気で長く仕事ができず、経済的ないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "信頼していた人に裏切られ、心理的ないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "自然災害で家を失い、未曾有ののいい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "結婚詐欺に遭い、人生を左右するないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "就職詐欺で無職になり、深刻なないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "交通事故の被害者となり、身体的ないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "医療ミスで後遺症が残り、生涯のないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "投資詐欺に引っかかり、貯蓄を失うないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "職場いじめで精神を病み、深刻なないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "借金地獄に陥り、本当に大変なないい目を見た。",
              "source": "幻辞"
            },
            {
              "text": "恐喝犯の標的になり、恐怖のないい目を見た。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "でもサツに情報を流して、いい目を見るんだろ。",
