        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末の駅前は、まるで芋洗いのような混雑ぶりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ライブ会場は、規制が緩くなったせいか、芋洗い状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「電車が遅れてて、乗ったらもう芋洗いだったよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この店、いつも芋洗いだから、開店と同時に行くのが一番だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
