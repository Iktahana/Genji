        "examples": {
          "standard": [
            {
              "text": "遺伝子操作によって、特定の害虫に対してのみ毒性を持つ成分を合成するジャガイモを開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、遺伝子操作で光るメダカが作れるなんて、まるで魔法みたいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヒトの受精卵に遺伝子操作を施す「デザイナーベビー」の是非が、世界中で問われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その絶命寸前のオレの脳裏には、ミクロン・オーダーであるはずのウイルスが四十人の坊主頭の科学者による遺伝子操作で超巨大化し、東京タワーをはさんで「ウイルス退散」と大書したたすきをかけた正義のモスラと死闘を演じる様が浮かんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴谷さんの断言から当時のオレは、「見逃しているのだから遺伝子操作は恐ろしいぞ」とする危惧のメッセージのみを受け取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
