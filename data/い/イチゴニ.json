        "examples": {
          "standard": [
            {
              "text": "旅館の冬の定番メニューとしていちご煮が出された。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮は紫ウニと鮑を合わせた高級料理だ。",
              "source": "幻辞"
            },
            {
              "text": "北海道の郷土料理いちご煮は、見た目も美しい。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮という名前だが、実は魚介類の煮物である。",
              "source": "幻辞"
            },
            {
              "text": "正月のおもてなし料理にいちご煮を用意した。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮の由来は、紫色と赤色が混ざった見た目からだ。",
              "source": "幻辞"
            },
            {
              "text": "新鮮なウニと鮑を使ったいちご煮の味は格別だ。",
              "source": "幻辞"
            },
            {
              "text": "レストランの特別メニューにいちご煮がランクインしている。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮を作るには、質の良い海産物を選ぶことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "北海道土産としていちご煮の缶詰が人気を集めている。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮は一人当たり数千円する高級料理である。",
              "source": "幻辞"
            },
            {
              "text": "寿司職人がいちご煮をアレンジした創作料理を発表した。",
              "source": "幻辞"
            },
            {
              "text": "冬の会席料理の中心としていちご煮が配置されている。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮という珍しい名前が海外からの観光客の注目を集めた。",
              "source": "幻辞"
            },
            {
              "text": "北海道のいちご煮を食べるために、毎年訪問する客も多い。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮は冷凍状態で保存され、必要に応じて解凍して食べる。",
              "source": "幻辞"
            },
            {
              "text": "味わい深いいちご煮は、日本を代表する食文化の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "調理実習でいちご煮の作り方を学んだ学生たちは驚いた。",
              "source": "幻辞"
            },
            {
              "text": "いちご煮の色合いは、トマトソースを連想させる人も多い。",
              "source": "幻辞"
            },
            {
              "text": "北海道の食文化を知る上で、いちご煮は欠かせない存在である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "春の蚊身近な春しろい一重の木いちごに、朱のレッテルのマッチ函、昼は昼とて、夜は夜とて、身ぢかな春のあかるさよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺の一重の木いちごに、擦るはマッチの燐のかず、煙草ばつかりすひほけて、あそぶこころのけぶたさよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもたちは、つぼいっぱい、いちごにしてしまうと、そのあとのいちごは、わらでつないで、ほっとして、小さいもみの木のそばに、腰をおろしました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ソーンフィールドから一｜哩の、夏は野薔薇に、秋は胡桃やきいちごに名高い、そして今も猶野薔薇と山櫨は少しばかりの珊瑚色の實の殘つてゐる小徑にゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
