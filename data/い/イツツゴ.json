        "examples": {
          "standard": [
            {
              "text": "その病院で五つ子が生まれたというニュースは、またたく間に国中に広まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "五つ子を育てる両親の日常は、想像を絶するほど忙しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女たちは、性格も好みも全く違う、個性豊かな五つ子姉妹だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "テレビ番組で、五つ子の成長を追ったドキュメンタリーが放送された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "八五郎のガラツ八と來ては、向柳原の叔母さんが無盡に當つても、隣の荒物屋の猫が五つ子を生んでも、天下の大事扱ひにしかねないあわて者です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火の呪ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎のガラッ八と来ては、向柳原の叔母さんが無尽に当っても、隣の荒物屋の猫が五つ子を生んでも、天下の大事扱いにしかねないあわて者です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の味噌汁が胸に閊へるぢやないか、――何處の猫の子が一體五つ子を産んだんだ」「そんな話ぢやありませんよ親分。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の味噌汁が胸に閊えるじゃないか、――どこの猫の子がいったい五つ子を産んだんだ」「そんな話じゃありませんよ親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            }
          ]
