          "standard": [
            {
              "text": "いささ川は古い地図に描かれている川だ。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の流域は豊かな自然に恵まれている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川は支流を含め多くの水源を持つ。",
              "source": "幻辞"
            },
            {
              "text": "いささ川沿いの村落は水利を生活の基盤としている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の水は灌漑用水として活用されている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の河口は砂州が形成されている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川は季節性の強い降水の影響を受ける。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の治水対策は地域の重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の名前は古い言語に由来するという。",
              "source": "幻辞"
            },
            {
              "text": "いささ川には複数の橋が架設されている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の生態系は多様な種を育んでいる。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の水温は年間を通じて低い。",
              "source": "幻辞"
            },
            {
              "text": "いささ川での漁業は古くから営まれている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の周辺には遺跡が多く存在する。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の汚濁対策が進められている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の護岸工事は自然景観を保持している。",
              "source": "幻辞"
            },
            {
              "text": "いささ川は地域の象徴的な存在である。",
              "source": "幻辞"
            },
            {
              "text": "いささ川の流量変動は気候変動の指標となる。",
              "source": "幻辞"
            },
            {
              "text": "いささ川での洪水対策が検討されている。",
              "source": "幻辞"
            },
            {
              "text": "いささ川は地域経済の発展に貢献している。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが彼女の人気の源となったところの、甘くて艶っぽい肉声が、管絃楽の伴奏とのつかず離れぬ交錯に、或いは高く、或いは低く、或る時は怒濤と砕け、或る時はいささ川とささやき、曲節の妙を尽して数千の観客を魅了していたとき、突如、実に突如として、「巴里の花売娘」が、舞台から消えうせてしまったのである。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
