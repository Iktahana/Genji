        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親から仕送りをもらい続けている大学生は、本当にいい身分だと周囲から見られている。",
              "source": "幻辞"
            },
            {
              "text": "毎日定時に帰れる職場に勤める彼は、いい身分だと友人から羨まれている。",
              "source": "幻辞"
            },
            {
              "text": "実家が裕福で何不自由なく育った人は、いい身分に生まれたと言えるだろう。",
              "source": "幻辞"
            },
            {
              "text": "給与が高く、やりがいのある仕事に就いている人は、羨ましいいい身分だ。",
              "source": "幻辞"
            },
            {
              "text": "妻の稼ぎで生活できる夫は、一見するといい身分に思えるかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "会社の子会社へ出向となり、責任が軽くなった部長はいい身分になったと周囲から聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "田舎で地主の息子として生まれた彼は、子どもの頃からいい身分だと友人にしばしば言われた。",
              "source": "幻辞"
            },
            {
              "text": "継承が決まっている事業を持つ一族は、事業家としていい身分にあると言える。",
              "source": "幻辞"
            },
            {
              "text": "大手企業で安定した職を得た彼女は、アルバイト生活を送る友人からいい身分だと羨まれた。",
              "source": "幻辞"
            },
            {
              "text": "有給休暇を自由に使える企業文化の中にいる従業員は、いい身分であることに気づいていない。",
              "source": "幻辞"
            },
            {
              "text": "祖父から莫大な遺産を相続した孫は、突然いい身分になってしまった。",
              "source": "幻辞"
            },
            {
              "text": "賃貸を払わずに親の家に住む独身男性は、経済的にいい身分を享受している。",
              "source": "幻辞"
            },
            {
              "text": "フリーランスで自分のペースで仕事をする彼女は、組織人からいい身分だと言われた。",
              "source": "幻辞"
            },
            {
              "text": "田舎の小学校の教員は、給与は低いがいい身分として扱われることもある。",
              "source": "幻辞"
            },
            {
              "text": "親が経営する企業に就職した息子は、同期から『いい身分だな』と指摘されることがある。",
              "source": "幻辞"
            },
            {
              "text": "企業年金が充実している大企業の退職者は、老後がいい身分だと周囲から見なされる。",
              "source": "幻辞"
            },
            {
              "text": "転職で給与が大きく上がった彼は、いい身分になったと家族から喜ばれた。",
              "source": "幻辞"
            },
            {
              "text": "役員の秘書として働く女性は、一般職からいい身分だと見られることもある。",
              "source": "幻辞"
            },
            {
              "text": "親の資産を活かして起業できた起業家は、資金面ではいい身分からスタートした。",
              "source": "幻辞"
            },
            {
              "text": "博士号を取得し研究職に就いた学生は、多くの同級生よりいい身分に進んだと言える。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "クビをくくるにはカモイが高すぎるし、いい身分だなア」「ウーム！",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいたら金をやろうとおまえに言った男がだれだか知っているか」「いい身分のだんなだ」「あれはわしのせがれだ。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘッ、俺たちもとんだいい身分に成り上がって金粉酒がいただけたものと考えよう。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、あなたの姉さんみたいに、どこにいても何かが仕事の役に立つ、というようないい身分じゃないんでね。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御紹介しましょう、佐々伸子さん、こちらは吉見素子さん、お父さんの脛かじりのいい身分の人ですよ」　素子は、「変な紹介だな」と云い、苦笑した。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と弁解したって、いい身分なのですよ」　素子が着物や帯、細々した紐などをある趣味で選び、身につけていることが一目でわかった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人ときたら誰からも密告されないっていういい身分なんですよ。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人達も私に無理をさせていたことが必要がすんでみればはっきりわかってきて今は休むことを頼まれ私はいい身分よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい身分なのね、でもきっと下宿で、さぞおなかのすくことでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はいい身分になったね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ねえ、てめえなんざ、田舎に、じっとしてりゃ、庄屋の小旦那で、炉ばたの地酒でも食らってるか、茶のみ話に、稲の穂の勘定でもしてりゃいい身分。",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が三人とも、いい身分になって、立派に国を治めていました。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人達は俺達よりずっといい身分に生れているし、難かしい議論も出来るし、色々なことを知っている。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "「順さんはいい身分だね。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、露八は、髪結の亭主と同じように、傍目からみればいい身分のような境涯だった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそれとおなじように、のんきの洒アな顔をして、またぞろ、裾野へ舞いもどってきた泣き虫の蛾次郎はばかにいい身分になったような顔をして、あっちこっちを、のこのこと歩いていた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶屋町で駕を降りる――そして二人は二人の湯女を連れて、いい身分でもありそうに、仲店から観音堂の界隈へわたる、羽子板市のすばらしい景気の雰囲気につつまれて行った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんないい身分はないやね」　しかし、禿鳶もまた、悪い身分ではないようだった。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
