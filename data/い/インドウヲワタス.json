[
  {
    "uuid": "cdb9e495-2c42-5af1-8f6e-2f8a29a6829e",
    "entry": "引導を渡す",
    "reading": {
      "primary": "いんどうをわたす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-サ行"
      ],
      "ctype": null,
