        "examples": {
          "standard": [
            {
              "text": "マダガスカルの森で、朝一番に鳴き声で目覚めさせてくれるのは、あの独特なインドリの合唱だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "インドリは、その長い尻尾が特徴的で、他のキツネザルとは一線を画す存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「おーい！」って呼んだら、木の上からインドリがこっちを見てる気がしたよ。まさかな！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "洋食器屋、ハム、ソーセージのうまい家、ユハイムやフロインドリーブの菓子屋、洋家具屋、支那街の焼豚屋、カラー、ネクタイ屋、西洋雑貨屋、バー、チャブ屋など限りがない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの墨汁の研究には膠質学の知識が大いに要るのだといいながら、先生はフロインドリッヒの膠質学の上下二巻千五百頁もある読みづらい本をこくめいに読んでおられた。",
              "citation": {
                "source": "寅彦夏話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼了り、おばあちゃん持参のちらし、フロインドリーブのパンに、ペースト、ポタージュとりて食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
