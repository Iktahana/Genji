        "examples": {
          "standard": [
            {
              "text": "ビジネスメールの冒頭で『お忙しいところ恐れ入りますが、いかがお過ごしですか』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "複数の取引先を回る営業が『いつもお忙しいと思いますが、いかがお過ごしですか』と挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "会合の始まりで『皆様いかがお過ごしですか』と司会者が声をかけた。",
              "source": "幻辞"
            },
            {
              "text": "電話での営業で『お疲れのところ恐れ入りますが、いかがお過ごしですか』と切り出した。",
              "source": "幻辞"
            },
            {
              "text": "医学学会での懇親会で『各地からお越しいただきました。皆様いかがお過ごしですか』とホスト側が挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "オンラインミーティングで『皆様いかがお過ごしですか』と主催者が参加者に呼びかけた。",
              "source": "幻辞"
            },
            {
              "text": "季節が変わり『暖かくなってきましたが、いかがお過ごしですか』と友人に連絡した。",
              "source": "幻辞"
            },
            {
              "text": "会議の始まりに『お集まりいただきありがとうございます。いかがお過ごしですか』と進行役が述べた。",
              "source": "幻辞"
            },
            {
              "text": "セミナーの開始時に『ご参加ありがとうございます。皆様いかがお過ごしですか』とスピーカーが挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "顧客サポートの電話で『本日はご来店ありがとうございます。いかがお過ごしですか』と担当者が述べた。",
              "source": "幻辞"
            },
            {
              "text": "新聞記者がインタビュー対象者に『本日はお時間いただきありがとうございます。いかがお過ごしですか』と話しかけた。",
              "source": "幻辞"
            },
            {
              "text": "研修会の冒頭で『お集まりいただきました。本日はいかがお過ごしですか』と講師が参加者に向かって述べた。",
              "source": "幻辞"
            },
            {
              "text": "業界イベントで『ご来場ありがとうございます。いかがお過ごしですか』と受付スタッフが来訪者に挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "病院の待合室で『長くお待たせしてしまい申し訳ございません。いかがお過ごしですか』と医療者が患者に声をかけた。",
              "source": "幻辞"
            },
            {
              "text": "社員研修で『新しい同期の皆さん、いかがお過ごしですか』と研修講師が新入社員に問いかけた。",
              "source": "幻辞"
            },
            {
              "text": "取引先との打ち合わせ前に『いつもお忙しいところご足労ありがとうございます。いかがお過ごしですか』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "学園祭でのゲストスピーカーが『こんな環境ですが、皆さんいかがお過ごしですか』と語りかけた。",
              "source": "幻辞"
            },
            {
              "text": "企業の新しいパートナーが初めて対面し『新しいお付き合いになります。いかがお過ごしですか』と自己紹介とともに述べた。",
              "source": "幻辞"
            },
            {
              "text": "オンライン講座の終わりに『長時間の受講ありがとうございました。受講生の皆様いかがお過ごしですか』と主催者が労った。",
              "source": "幻辞"
            },
            {
              "text": "国際会議で『遠い国からのご参加ありがとうございます。いかがお過ごしですか』と通訳を通して挨拶した。",
              "source": "幻辞"
            }
          ],
