        "examples": {
          "standard": [
            {
              "text": "古代インドの思想家たちは、印哲の探求を通じて深い洞察を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ヨガや瞑想の根源を理解するには、印哲の知識が役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの哲学者は、印哲と仏教思想を巧みに融合させて語るんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
