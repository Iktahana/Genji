        "examples": {
          "standard": [
            {
              "text": "いいぞという表現は日本語で重要な意味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "日常会話ではいいぞがよく使われる。",
              "source": "幻辞"
            },
            {
              "text": "いいぞの意味を正確に理解することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "学習者にとっていいぞは習得が難しい場合もある。",
              "source": "幻辞"
            },
            {
              "text": "いいぞを使った例文は多く存在する。",
              "source": "幻辞"
            },
            {
              "text": "文化の中でいいぞがどのように機能するかを知ることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "他の言語ではいいぞに該当する表現がないこともある。",
              "source": "幻辞"
            },
            {
              "text": "いいぞの用法を正確に把握するには多くの事例を学ぶ必要がある。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス場面ではいいぞの使い方が微妙に異なることがある。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではいいぞが効果的に使用されることがある。",
              "source": "幻辞"
            },
            {
              "text": "いいぞを含む文章を読むことで、その使用法を学ぶことができる。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では{entry_text}の指導が強調されている。",
              "source": "幻辞"
            },
            {
              "text": "時間とともに{entry_text}の意味や用法が変化することもある。",
              "source": "幻辞"
            },
            {
              "text": "異なる地域では{entry_text}の意味が微妙に異なることもある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}に関連する語彙を習得することも重要である。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}の反対の概念も日本語に存在する。",
              "source": "幻辞"
            },
            {
              "text": "心理学や社会学の観点から{entry_text}を分析することも有興味深い。",
              "source": "幻辞"
            },
            {
              "text": "年代によって{entry_text}の使用頻度が異なることが言語学で示されている。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}は複数の意味を持つため、文脈から判断する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}を習得することで日本語の表現力が格段に向上する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "調子がいいぞ、とにやにやしてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒くさい靴下はポケットへ押し込め、ポケットがふくれて気持ちがいいぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きらずだ、繋ぐ、見得がいいぞ、吉左右！",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むりしないほうがいいぞ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬一匹飼って置くといいぞ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切番はいいぞ、父！",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺つあん、今日は、午めえは草刈っさ行かねってもいいぞ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのすきなときだけ、うたってくれればいいぞ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが今夜話したことは誰にも吹聴しない方がいいぞ」と、Ｋのおじさんは話の終りにこう付け加えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京ちやんは運がいいぞ。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ重大な事件だから、すぐに係りの検事から審問がある筈だが、なまじっか偽を申し立てぬがいいぞ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、最後に忠告しとくが、これからは、これに懲りて、自分の生活の保障もたたんうちに、恋だとか愛だとかいう人並みな考えを起こすのはよしたがいいぞ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれると、ききがいいぞ」　ぎゅっとぞうさもなく押えたやつを伝六に渡しておいて、すばやく手、口、ともにすすぎ清めると、懐紙を口にくわえながら、白布を解きほどきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごしてりゃ、おらがはあんまりじょうずじゃねえが、だんなの草香流はききがいいぞ」　ぱんぱんとかみつくようなすさまじいけんまくに、肝をつぶしたのは子をとられたふたりの新造たちでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラを意識していいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいぞ、かけてくれ、という高志の合図にしたがって、慶一は黙々と湯をかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーベット食うなら、早いとこ片づけたほうがいいぞ」　メロンを矢印にして、高志が南西の空を示した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、帰っていいぞ」　そうしたいのはやまやまだが、どうせなら、令子の組がくるまで待ちたい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、ホコリかぶってる」「聴かねえほうがいいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "起床の時間です」　いいぞ、ワラ、という声と、学校の手先は死ね、てめえの声をきくと発作が起きる、といった罵声が、暗いサロンを飛びかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっ、この部屋は異常に寝起きがいいぞ、とヤジ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつでいけるところなら、どこだっていいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の朝、お前は出ていいぞ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァレンタイン、さっきの話をよーく、心にとめておいた方がいいぞ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一報は、簡潔なのがいいぞ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てしまったら、あとは帰ってもいいぞ」　高木を追払ってしまうと、余は、事務所の入口に、内側から鍵をかけた。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杉田の耳許に口をつけると、「おい杉田、万一お前が捕らえられるようなことがあったら、そのときは官姓名をはっきり名乗ったがいいぞ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく高い所がいいぞ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
