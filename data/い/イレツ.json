  {
    "uuid": "1ab3716a-def1-5218-9824-a584d802f859",
    "entry": "偉烈",
    "reading": {
      "primary": "いれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great achievement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の生涯は、数々の偉烈に彩られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "建国の父の偉烈を称える記念碑が建てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その偉烈は後世まで語り継がれるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "陳は女の往った後でまだ凶とも吉とも定まらない自分の運命を考えて苦しんだが、それよりも苦しいのは、いれつくような空腹のくるしさであった。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋があり夫婦があり親子があった海神の国が、地上的な不完全さを漸次払い落とし、煩悩なき浄光の土の観念を漸次取りいれつつ、ついに海底の国より天上の世界に発展して来たのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
