          "standard": [
            {
              "text": "いじめ防止対策推進法は、2013年に施行された重要な法律である。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法により、学校での防止対策が法的に義務づけられた。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法に基づいて、各学校はいじめ防止方針を策定する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法の制定により、被害者の権利が強化された。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法では、学校と家庭の連携が重視されている。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法に違反した教育機関には、指導が入ることがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法により、教師の研修がより充実することになった。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法の趣旨を理解することが、教育者の責務である。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法に基づく相談体制が、全国的に整備されている。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法が成立した背景には、深刻ないじめ事件がある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法により、学校外でのいじめも対象範囲に含まれた。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法に基づいて、教育委員会は調査権を有することになった。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法は、子どもの人権を守るための重要な枠組みである。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法の実効性については、依然として課題がある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法を基に、各地域で独自の対策が講じられている。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法の制定から10年以上が経過している。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法により、学校の説明責任が強化された。",
              "source": "幻辞"
            },
            {
              "text": "いじめ防止対策推進法の解釈について、関係者の間での議論が続いている。",
