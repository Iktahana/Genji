          "standard": [
            {
              "text": "地震の揺れで、岩石が激しく破砕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この機械は、鉱石を細かく破砕するために使用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "土砂崩れにより、家屋や木々が粉々に破砕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私はさいきん、少しからだの調子を悪くして、神妙にしばらく酒から遠ざかっていたのであるが、ふと、それも馬鹿らしくなって、家の者に言いつけ、お酒をお燗させ、小さい盃でチビチビ二合くらい飲んでみた。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗字はさいきでしょうか。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人はさいきんニスをぬってもらっていましたので、お月さまの光をうけて、キラキラと光っていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はさいきん、芥川の家の燒跡にはじめて行つてみた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
