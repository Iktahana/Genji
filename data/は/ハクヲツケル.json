        "examples": {
          "standard": [
            {
              "text": "海外留学の経験は、彼のキャリアに箔を付けるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このコンテストで優勝すれば、自分の作品に大きな箔が付く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はブランド物の時計を身につけることで、自分のステータスに箔を付けたがっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "杢助にはまるで腑におちなかった、極意だの秘伝だの、しょせんは剣術がずぬけに上手で、うまく人を叩きのめすことのできる人間が、その術に箔を付けるための呪文みたようなものであろう。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各※から渡せといっても、かえって小次郎の武技に箔を付けるようなもので、そういう勇者なればなおさら、渡せぬと出るに違いない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
