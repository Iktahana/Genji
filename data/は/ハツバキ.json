        "examples": {
          "standard": [
            {
              "text": "馬たちが発馬機に収まり、緊張感が高まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "調教不足の馬は、発馬機内で暴れることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発馬機の故障で、レース開始が一時中断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ぱっと発馬機がはね上った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "規律とか規則とかと云うものに、私はつばきを引っかけてけいべつをしてやりたくなった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つはつばの語根であり、唾はつばきである。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正二がものおきから、手すきを取り出してくると、兄はつばきの下に穴を掘りました。",
              "citation": {
                "source": "兄と魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれとすればそれほど気が弱い方ではないつもりなんだが、それにしても二三度はつばきをのみこまないとすぐには返辞ができなかった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
