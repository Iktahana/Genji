        "examples": {
          "standard": [
            {
              "text": "始めは抵抗があったけれど、やってみたら意外と楽しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "始めは単なる好奇心だったが、それがやがて情熱に変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "始めは小さかった株が、今では大企業に成長した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "小屋係りはその渓流のほとりでとっつきの仕事をはじめねばならない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "福井の由緒古い町人の家に生れた彼であることから、考へはじめねばならぬ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、はじめね。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは古代の立派な人々と同じく善くあるべきであるが、ある程度まではまずいかに善くかれらがあったかを知ることからはじめねばならぬ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識を否定するのにはまず常識から踏みはじめねばならぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
