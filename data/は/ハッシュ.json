[
  {
    "uuid": "e5e51987-79c7-5e3e-ad24-32ac1a870469",
    "entry": "ハッシュ",
    "reading": {
      "primary": "ハッシュ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
