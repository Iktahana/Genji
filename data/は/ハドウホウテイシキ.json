        "examples": {
          "standard": [
            {
              "text": "物理学では、波の伝播を記述するために波動方程式が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "波動方程式を解くことで、音波や光波の挙動を予測できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複雑な媒体における波動方程式の解法は、まだ未解明な点が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし引きつづいて、独逸でボルンやシュレーディンガーの論文が出て、波動方程式という名前も皆が知るようになった。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又逆に一定の物理学的原則は或る特定形態の解析的操作だけを選定する必要を生む（例えば量子力学によるマトリックス、波動力学による波動方程式など）。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
