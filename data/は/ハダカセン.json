        "examples": {
          "standard": [
            {
              "text": "古い家電製品は、内部の裸線が露出していることがあるので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "裸線に触れると感電の危険があるため、絶対に近づかないでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電柱から垂れ下がった裸線は、非常に危険に見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、鉄管に絡んでいる裸線は、私のラジオのアンテナですわ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あおむけに寝た私の顔のすぐ上を、黒い電線や裸線が幾本も通り、壕内の乏しい電灯の光を吸うて微かに光った。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
