        "examples": {
          "standard": [
            {
              "text": "ハイジャッカーはコックピットに押し入り、パイロットに隣国への進路変更を要求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画の中で、勇敢な乗客が隙を突いてハイジャッカーから武器を取り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事件から数十年が経過したが、指名手配されているハイジャッカーの行方は依然として不明だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここでは密造酒の輸送を襲おうと「ハイジャッカー」がしばしば浅ましくもトラックを待ち伏せていたのだが、盗賊どもも今回ばかりはより大きなショックを受ける運命にあった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
