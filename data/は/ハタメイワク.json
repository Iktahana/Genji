        "examples": {
          "standard": [
            {
              "text": "大声で騒ぐのは、周りの人にはためいわく（迷惑）だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ゴミのポイ捨ては、街に lotta（迷惑）をかける行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のとった行動は、多くの人にはためいわく（迷惑）をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だいたい、はた迷惑なほどの歌声ではなかったのだ。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しんでいる本人は気の毒だが、はた迷惑なのもたしかだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の思いの恋などは、ご当人の苦しさも格別でしょうが、だいいち、はためいわくです。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
