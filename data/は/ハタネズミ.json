        "examples": {
          "standard": [
            {
              "text": "畑（はた）で、小さくて丸い畑鼠（はたねずみ）が忙しそうに動き回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "畑鼠は、農作物に被害を与えることがあるため、厄介者扱いされることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "田んぼの近くの畑地で、畑鼠の巣を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "次に体外に私有財産を有する動物の例をあげると、まず畑に住んで麦作に大害をおよぼす畑鼠などがもっとも適例であろう。",
              "citation": {
                "source": "動物の私有財産",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
