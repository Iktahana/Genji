        "examples": {
          "standard": [
            {
              "text": "排気量が大きなスポーツカーは、アクセルを踏み込んだ瞬間の加速力が桁違いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "税金や燃費の面から、若者の間では小排気量のコンパクトカーが支持されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジンのボアアップを行い、排気量を増やすことでバイクのパワーを向上させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小さな排気量のバイクで乗りかたを教えようとしたのだが、つづかなかった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきをいく二台の大排気量のエグゾーストがかさなりあい、シャーンというような音になって、うしろへなびいてくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車教習所の貸しコースへ出かけていき、ぼくのカワサキでミーヨを大排気量車の免許試験にそなえさせるためだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険な錯覚なのだが、高速走行中の大排気量オートバイが持つ魔力のひとつであることは、たしかだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
