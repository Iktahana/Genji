        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "太古の昔から、人々は炎の神秘的な力に畏敬の念を抱き、拝火教として信仰した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暗闇を照らし暖をもたらす火を神聖視する拝火教は、多くの文化圏で見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洞窟の奥で燃え続ける炎を囲み、拝火教の儀式が厳かに執り行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし同じ動物の一種であり、同じ生命本能の所有者である人間、そして最も原始的な宗教の起原に、民族共通の拝火教や拝日教を有する我等は、自己の主観から臆測して、殆んど彼等の心理を想像することが出来るのである。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシアの拝火教で、人間の霊魂が火から生まれたことを説いてゐるのは、生物の向火性と対照して、興味の深い哲理を持つてゐる。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教徒や拝火教徒の説にはもう飽きはてた。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "〃　火殿――拝火教の聖火奉安所。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "74　マギイ――拝火教の司祭。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラム教以前のイランの宗教は拝火教であった。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝火教徒が火中に迎えたものは、「すべてを呑噬するもの」の影であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは基督教、仏教、モハメツト教、拝火教なども行はれてゐます。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひに我等の間にも基督教、仏教、モハメツト教、拝火教等の諸宗あることを忘るる勿れ。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは基督教、仏教、モハメット教、拝火教なども行なわれています。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに我らの間にも基督教、仏教、モハメット教、拝火教等の諸宗あることを忘るるなかれ。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仏殿の経蔵には七世紀のはじめに版行した西蔵語訳のカンジュール（一切経）をはじめ、六朝唐代の石摺の経本（唐拓）、※経（拝火教の経典）、摩尼教の教本、景教（ネストリアンというキリスト教の一派）の経本、ザラツシトラ教の経本など、千年も前に消滅してしまった世界宗教の経典が原本のままで残っている。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔拝火教徒が使った呪文のようなものです……」「面白くて？",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゾロアスターの尊敬者（拝火教徒）はミズネズミを嫌いこれを殺すのが神への奉仕と考えた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
