        "examples": {
          "standard": [
            {
              "text": "大航海時代は、ヨーロッパ諸国が世界へと進出した発見時代とも称される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発見時代には、未知の土地や新しい交易路を求めて多くの探検家が旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アメリカ大陸の「発見」は、発見時代における最も大きな出来事の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まず、最初の階段は、微積分学の発見時代に相当する。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、最初の段階は、微積分学の発見時代に相当する。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七世紀の新陸地発見時代のイスパニアの貨幣にはジブラルタルの図案が鋳出されている下に Plus ultra（その向うにまだある）と刻まれていたと、この著者は語っている。",
              "citation": {
                "source": "新島繁著『社会運動思想史』書評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は今日快楽追求時代に住んでゐると云ふが、我々は快楽発見時代には住んでゐないやうである。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ人が、極東についていっそう多く知り始めたのは、実に大発見時代のころである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
