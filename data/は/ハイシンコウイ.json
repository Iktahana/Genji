        "examples": {
          "standard": [
            {
              "text": "会社の機密情報をライバル企業に売却したことは、明らかな背信行為である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "友情を裏切るような背信行為は、どのような理由があっても許されるものではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "背信行為によって失った信頼を取り戻すには、一生をかけても足りないかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしここで手を退いては、全幅の信頼を寄せてくれるホームズに対する、何とよこしまな背信行為であろうか。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            }
          ]
        }
