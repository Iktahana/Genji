        "examples": {
          "standard": [
            {
              "text": "初めての海外旅行は、言葉の壁に戸惑いながらも、刺激的な初体験だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一人でキャンプに挑戦するのは、少し怖かったけれど、素晴らしい初体験になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その日、人生で初めてのスキーに挑戦し、転びながらも楽しさを味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これがヴィラのレース初体験だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
