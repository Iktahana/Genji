        "examples": {
          "standard": [
            {
              "text": "体内で炎症が起きていることを示すサインとして、白血球増加が挙げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "検査の結果、肺炎による著しい白血球増加が確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一時的な白血球増加は、激しい運動やストレスによっても起こりうる現象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "爆心地の残留放射能は時日の経過と共にすみやかに減衰し、二か月以後は人体の健康を損なわぬ程度になることやら、ここに来住して一か月ほどたつと放射線の刺激によって軽い白血球増加症が起こることやら、いろいろの事実がわかりました。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
