        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいお店の開店を祝って、大きな旗を揚げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オリンピック選手団が、誇らしげに自国の旗を揚げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "船乗りたちが、港を出る時に旗を揚げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "漁夫たちの船歌は一段と勇ましくなって、君の父上は船の艫に漁獲を知らせる旗を揚げる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみに他人の不信とか不義とか変心とかを咎めて、万事万端向うがわるいように噪ぎ立てるのは、みんな平面国に籍を置いて、活版に印刷した心を睨んで、旗を揚げる人達である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断は帆柱の先に白い小旗を揚げるが、女が乗ったら赤に易えさせよう。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
