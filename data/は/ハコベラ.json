        "examples": {
          "standard": [
            {
              "text": "彼は伝統的な木箱を作る熟練した箱屋だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お座敷へ向かう芸者さんを乗せた車を、箱屋が先導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近では、カスタム梱包箱を専門に作る箱屋も増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ハコベラ　ハコベラはナデシコ科のハコベである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このハコベラはこの草の昔の称えであるが今でも稀れにこの古名をそのまま呼んでいる地方もある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波の祖谷山ではホウベラ、春の七草の一つのハコベラが、この草であったことが想像せられる。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
