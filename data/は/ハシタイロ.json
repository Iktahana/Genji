          "standard": [
            {
              "text": "彼女は、落ち着いた半色（はしたいろ）の着物を上品に着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕焼け空が、空全体を優しい半色（はしたいろ）に染め上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この布の色、半色（はしたいろ）が綺麗ね。何に仕立てようかしら？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには人足達の肩を煩はしたいろ／＼の貨物の山、起重機で捲き揚げられた鉄材、思ひ／＼に旅装をして汽船に乗り込む客、艀から上陸する人、そこには常に放浪病者を魅惑するやうな遠い国々の幻影が漂うてゐた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
