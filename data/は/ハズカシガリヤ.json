        "examples": {
          "standard": [
            {
              "text": "彼女は昔から恥ずかしがり屋で、人前で話すのが苦手だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいクラスメイトは少し恥ずかしがり屋だが、話してみるととても優しい子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うちの猫は初めての来客にはいつも隠れてしまう、かなりの恥ずかしがり屋だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「あの方は大変な恥ずかしがり屋なの、ホームズ先生。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わかった、あんた恥ずかしがり屋さんね、女の子と一緒にお湯へはいるの恥ずかしいのね。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥ずかしがり屋に悪人ってものないわ」「恥ずかしがり屋に悪人はないとも。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが俺ら恥ずかしがり屋かなア」「あたしの眼に狂いないわ」「それならいいが」「フーッ。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "権、いい人だわ、恥ずかしがり屋だわ。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤のクイーン　恥ずかしがり屋さんだね、あんたを羊のモモ肉に紹介してやるよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと恥ずかしがり屋で、フィリップスの印象では、友人が無く、若い身空の大部分を、わがままな道楽父親の犠牲になっているようだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、靴下どめは、ひどくはずかしがりやだったものですから、そんなことに答えるのは、なんだかおかしな気がしました。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
