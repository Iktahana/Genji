    "definitions": [
      {
        "index": 1,
        "gloss": "Ba Yi (ancient Chinese dance practiced in the court of the Zhou king)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "孔子の時代、八佾は周の天子の前でだけ許される舞であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "儀式において、荘厳な八佾が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地方の諸侯が八佾を舞うことは、当時の秩序を乱す行為とされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あのでれ助が胡麻の蠅とは、こいつはちいつと出来すぎたわい。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜荷では少しさびしく、七｜荷ではちいつとばかり贅沢だつたが、だいじな一人娘なぞには親がきばつて七荷にすることが多かつた。",
              "citation": {
                "source": "よめいり荷物",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
