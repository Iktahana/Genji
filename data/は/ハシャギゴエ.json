        "examples": {
          "standard": [
            {
              "text": "公園から子供たちのはしゃぎ声が聞こえてきて、心が和んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動会では、生徒たちのはしゃぎ声がグラウンドに響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティー会場は、楽しげなはしゃぎ声で満ち溢れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "野球が終わって、浴場でシャワーをかぶる子供たちの高いはしゃぎ声。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の仮小屋のあたりは幼いはしゃぎ声でいつもにぎやかだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
