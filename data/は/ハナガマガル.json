        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ごみ捨て場を通ったら、悪臭で思わず鼻が曲がるかと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「うわ、この匂い、鼻が曲がる！」と彼は顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "腐った魚の臭いで、本当に鼻が曲がりそうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新たに名状し難い臭いに加わって現れた例の鼻が曲がるような奇妙な悪臭が、ここではとてつもなく刺激的で、他の者どもの臭跡は完全に消し去られてしまった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
