        "examples": {
          "standard": [
            {
              "text": "破傷風抗毒素は、破傷風菌が産生する毒素を特異的に中和する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "感染後早期に破傷風抗毒素を投与することで、症状の進行を抑えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "馬由来の破傷風抗毒素を使用する際には、アレルギー反応に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "疑わしい傷のある患者に破傷風抗毒素を与えると、この恐ろしい病気は殆ど起きなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次世界大戦はこの観点からすると破傷風抗毒素の効果を示す大規模な実験だった、と言うことができる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
