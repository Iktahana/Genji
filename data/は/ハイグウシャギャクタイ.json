          "standard": [
            {
              "text": "配偶者虐待は深刻な社会問題であり、被害者を保護する制度が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は長年、配偶者虐待に苦しんできたが、ようやく支援団体に相談した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "法律では、身体的および精神的な配偶者虐待が禁止されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "配偶者虐待に抵抗する団体がいまではこの島にも出来ていて、その抵抗運動をおこなっている人たちが、このメモリアルを管理している」　ぼくは、うしろを見た。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
