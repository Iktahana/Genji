        "examples": {
          "standard": [
            {
              "text": "明日は花金だから、仕事終わりに飲みにでも行こうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「やった、やっと花金だ！週末は何しようかな」と彼は嬉しそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花金の夜は、街が人で賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "街衢を疾駆する造花金蓮。",
              "citation": {
                "source": "AU MAGASIN DE NOUVEAUTES",
                "author": "李箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "この林の中にも花金鼠が非常に多く、体に黄色の縦縞があって、長い房々した尾を栗鼠のように背に負いながら、木から木へと跳び移っている。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
