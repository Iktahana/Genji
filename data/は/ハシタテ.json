        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「箸初め」（はしぞめ）とも呼ばれるこの儀式では、赤ちゃんがお箸を初めて使う真似をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の成長を願って行われる箸初め（はしぞめ）の儀式は、地域によって様々な形で行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お食い初めの後に行われる箸初め（はしぞめ）は、離乳食への移行を祝う伝統行事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
