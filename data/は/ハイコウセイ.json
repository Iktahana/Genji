        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "光ファイバーの性能は、その材料の配向性によって大きく左右される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、結晶の配向性を分析し、新しい材料の開発に役立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "磁場を印加することで、強磁性体の配向性を制御することができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
