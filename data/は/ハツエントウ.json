        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高速道路で故障した際、発炎筒を置いて後続車に合図を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車には、万が一のために発炎筒が常備されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉄道事故の現場では、発炎筒が焚かれ、二次災害を防いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
