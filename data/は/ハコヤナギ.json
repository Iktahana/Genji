        "examples": {
          "standard": [
            {
              "text": "このステーキは適度な歯ごたえがあって美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旬の野菜はシャキシャキとした歯ごたえがたまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説は難解だが、読み応えのある歯ごたえがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "お前※とこへね、きれいなはこやなぎの木を五本持って行ってあげるよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はこやなぎかかる夜なりき、白楊うるみ色なる月かげに、飽かず別れて立ちかへり、抱きあひては歎きしが。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はこやなぎ一かかる夜なりき、白楊うるみ色なる月かげに、飽かず別れて立ちかへり、抱きあひては嘆きしが。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってみると、馬ははこやなぎの木につながれて、すっかり仕度ができていて、小舟はいつでも出発するようになっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
