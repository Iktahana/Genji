          "standard": [
            {
              "text": "細菌感染症の場合、白血球増加症が見られることが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は検査で白血球増加症と診断され、医師から経過観察を指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定のタイプの白血球増加症は、より深刻な病気の兆候である可能性もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "爆心地の残留放射能は時日の経過と共にすみやかに減衰し、二か月以後は人体の健康を損なわぬ程度になることやら、ここに来住して一か月ほどたつと放射線の刺激によって軽い白血球増加症が起こることやら、いろいろの事実がわかりました。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
