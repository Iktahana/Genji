    "definitions": [
      {
        "index": 1,
        "gloss": "person of high standing, with a warped view of reality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社長は周りの意見を聞かず、まるで裸の王様のように振る舞っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誰も真実を告げないため、彼は裸の王様になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「君、それではまるで裸の王様だよ！」と、友人は彼を諭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アンデルセンの『裸の王様』を、こういう点から見て見ると、又特別の面白さがあるだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは君が幼い頃読んだことがあるかもしれないが、御存じのアンデルセンが書いた童話で、『裸の王様』という話だ。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのが『裸の王様』の筋だ。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、開高健著の「裸の王様」を読んでのことであった。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
