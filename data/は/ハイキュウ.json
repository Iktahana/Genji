    "definitions": [
      {
        "index": 1,
        "gloss": "volleyball",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は中学時代から排球部に所属し、長身を活かした強烈なスパイクで注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末の市民体育館では、近隣のチームが集まってママさん排球の大会が開かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "排球は一人のスーパースターだけでなく、チーム全体の連携が勝利の鍵を握る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近代的のものでもゴルフの外に庭球野球｜蹴球籠球排球などがあり、今は流行らぬクリケット、クロケーから、室内用にはピンポン、ビリアードそれから例のコリントゲームまである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
