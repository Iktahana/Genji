        "examples": {
          "standard": [
            {
              "text": "破傷風菌は、主に土壌中に生息する嫌気性菌である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深い傷を負った場合、破傷風菌の感染に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "加熱殺菌では死滅しない破傷風菌の芽胞は、非常に耐久性が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "破傷風菌が死ぬぐらいなら水ムシ菌も参るだろうと考えたわけだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "1884年はとくに成果があがり、レフラーによるジフテリア菌、ニコライアーによる破傷風菌、フレンケルによる肺炎桿菌、の発見が含まれた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
