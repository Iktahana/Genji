        "examples": {
          "standard": [
            {
              "text": "彼は汎用的なスキルを多く持っているため、どんな部署でも活躍できるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この研究開発は、特定の分野に留まらず、より汎用的な応用を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この汎用的なアプローチは、多くの問題解決に役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "手帳に例えれば、汎用的に誰もが繰り返し使う情報を印刷した部分がＲＯＭ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "汎用的に繰り返し使うソフトウエアは、ＲＯＭに焼き込んで本体に組み込んでおけば、読み込みの手間を省いてマシンの使い勝手をよくすることができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
