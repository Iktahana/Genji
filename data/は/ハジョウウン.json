        "examples": {
          "standard": [
            {
              "text": "恥じらいのある女性は、控えめで奥ゆかしい魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、初対面の相手には少し恥じらいを見せるが、すぐに打ち解ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "照れ隠しなのか、彼は少し恥じらいながら、プレゼントを差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "対流渦による波状雲のことは今さら述べるまでもないが、これに類似の縞は、近ごろ「墨流し」の実験をしているときに、最初表面に浮かんだ墨汁の層が、時がたつに従って下層の水中に沈む場合にもかなりきれいに発達するのを見ることができた。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
