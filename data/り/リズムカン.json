    "definitions": [
      {
        "index": 1,
        "gloss": "sense of rhythm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生まれつきリズム感に優れており、どんな楽器でもすぐに弾きこなしてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ダンスを始めたばかりで、まだリズム感が悪く、先生の動きについていけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「君は本当にリズム感がないなあ」と、カラオケで友人に笑われてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "これは私が前に述べたリズム感の基礎をなす「固有週期」といったようなものがロシア農民と日本のファンとで著しくちがうためではないかと思われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "H.P.L.は時として頭韻を踏みながら似た意味の形容詞を繰り返す傾向があり、のめっとしたリズム感を生んでいます。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非このリズム感を原文で味わってください。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
