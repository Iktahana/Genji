    "definitions": [
      {
        "index": 1,
        "gloss": "to reach mutual understanding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
