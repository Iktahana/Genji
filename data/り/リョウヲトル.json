        "examples": {
          "standard": [
            {
              "text": "夏の夕暮れ、縁側でうちわを仰ぎながら涼を取るのは最高に気持ちがいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "木陰のベンチに座って、しばらく涼を取ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「暑いねえ」「ああ、ちょっとそこの喫茶店に入って涼を取らないか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "涼を取るべく連立た人。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜夕映の赤きところに、暗碧なる雲の浮べるをば、天人の居る山の松林ならんと思ひて、そこの谷かげには、美しき神の童あまた休みゐ、白き翼を扇の如くつかひて、みづから涼を取るらんとおもひやりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "○我国にては扇は昔より男子の携持ちたるものなれど、人の面前にて妄に涼を取るものにはあらず、形容をつくらんがため手に持つのみにて開閉すべきものにはあらざるべし。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根上の物干台に出で涼を取る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            }
          ]
        }
