          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの選手はピッチャーとしてもバッターとしても超一流の成績を残す、野球界きっての両刀使いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はプログラミングもできればUIデザインもこなせる、開発チームに欠かせない両刀使いのエンジニアだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「営業とマーケティング、どちらも一級品なんて、君は本当に見事な両刀使いだなあ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "liking both alcohol and sweets",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
