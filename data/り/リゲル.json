        "examples": {
          "standard": [
            {
              "text": "冬の澄んだ夜空を見上げると、オリオン座の右下で青白く輝くリゲルがひときわ美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プラネタリウムの解説員が、リゲルは太陽の何万倍もの光を放つ巨大な星だと教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は新しい天体望遠鏡を手に入れ、真っ先にリゲルの伴星を観察しようとピントを合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アリストテレスの『ポエティカ』を始めとしスカリゲルやボアローなどに至るカノン（規矩）主義的な批評精神に反抗して、今日の新しいクリティシズムは、作品をば、規格品としてではなく何物かの自由な表現を見るようになって来ている、というのである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は星の名を知らなかったが、オリオン座のリゲルを見つけ、じきに他の星たちもみな出てくるだろうと分かった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
