        "examples": {
          "standard": [
            {
              "text": "古いアルバムの中から、祖父が撮った珍しい立体写真が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "立体写真を見ると、昔の風景が目の前にあるかのように感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行先で、記念に現地の立体写真を何枚か購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "怪物の死骸は、現場で立体写真におさめられ、実物と寸分ちがわない模型を作りあげる仕事が進められた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを総合して立体写真のようにイエスの姿を構成するのも、イエス伝を学ぶ一つの方法でありますが、そのうち一つの伝記だけを見ても、個性のある見方でイエスの姿を学ぶことができます。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
