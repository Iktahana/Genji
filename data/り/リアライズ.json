        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "頭では理解していても、その危険性を完全にリアライズするには時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "留学して異文化に触れることで、日本の良さを改めてリアライズすることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "チーム全員が目標を共有し、その達成をリアライズするために努力した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
