        "examples": {
          "standard": [
            {
              "text": "ピラティススタジオで初めてリフォーマーを使ったが、体幹にかなり効いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "自宅にリフォーマーを導入して、毎朝のルーティンにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あのジムには最新型のリフォーマーが何台も揃っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "むずかしい、ああ云うソシアル・リフォーマーの戦わなければならない或危期であろう。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
