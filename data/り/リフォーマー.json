        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は教育界の熱心なリフォーマーとして、時代遅れの制度にメスを入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "社会的なリフォーマーたちの活動によって、労働環境は少しずつ改善されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "急進的なリフォーマーの意見は、保守層からの猛反発を招いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
