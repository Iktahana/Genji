    "definitions": [
      {
        "index": 1,
        "gloss": "return",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "投資した資金に対して、どれくらいのリターンが見込めるかを算出する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外研修で得た経験を、業務を通じて会社にリターンしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ハイリスク・ハイリターンの金融商品は、初心者にはおすすめできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コマンドを確認し、リターン・キーを叩き、プリンターに処理をわたす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば一種のリターンマッチとして、パーソナルコンピューターに接近する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの文化は、挫折組のリターンマッチ文化としての性格をある面では備えている気がします。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん私は、パーソナルコンピューターだけが彼らのリターンマッチの戦場であったなどというつもりはありません。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても、そうした逸脱組の中で自らのリターンマッチのリングを発見したものがどれくらいいるのでしょうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした回路が機能しているとき、社会はかなり柔軟で強力たりうると思うのですが、現実には逸脱組の多くはついにリターンマッチのリングを発見しえない場合の方が多いに違いありません。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加減乗除の記号をはさんで数字を入力し、リターンキーを押せば、計算の結果が表示される。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リターンマッチ　絵本作家の長谷川集平さんから、突然メールが届いた。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがリターンマッチのリングはここにある。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度ゲームをリプレイしたい場合は、キーボードのリターン・キーを入力してから００１へＧＯＴＯして下さい。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "春にはリターンマッチも行われた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "リターンのスピードも、たいへんいい。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "return (in tennis, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
