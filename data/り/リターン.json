        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "メールの宛先を入力したら、リターンを押して次の項目に進んでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プログラムの実行を確定させるために、最後にリターンを叩く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "改行しようと思ってリターンを押したのに、送信されてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
