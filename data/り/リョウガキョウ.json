        "examples": {
          "standard": [
            {
              "text": "楞伽経は、禅宗の祖である達磨大師が重視した経典として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仏教哲学を深く理解するため、漢訳された楞伽経の難解な一節を読み解く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "楞伽経には、万物は心の現れであるという唯心の教えが説かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "楞伽経の最後のところにある禁肉の理由は、トルストイの菜食論や其他の菜食説などよりもぐつと先きのところを言つてゐる。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "性を離れ相を離れ、なんぞ五色、これをよく盲せんや」と）楞伽経曰、彼生滅者是識、不生不滅者是智。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『楞伽経』に曰く、「かの生滅するは、これ識、不生不滅は、これ智」と）勝鬘経曰、世間言説故有死有生、死者諸根壊、生者新諸根起、非如来蔵有生有死、如来蔵離有為相、如来蔵常住不変。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
