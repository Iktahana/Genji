        "examples": {
          "standard": [
            {
              "text": "南極の深海堆積物の中から、宇宙空間から飛来したと思われる微小な流星塵が大量に発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大気圏に突入した流星が燃え尽きずに微細なチリとなった流星塵は、地球の表面に絶えず降り注いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "研究チームは、特殊なフィルターを使って成層圏で流星塵を採取し、太陽系の初期の物質の組成を分析している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "流星塵が他の地方より、桁はずれに多いことも、不思議だったし、雪の結晶の種類が北海道の観測結果と一致しているという話も、面白かった。",
              "citation": {
                "source": "南極・北極・熱帯の雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
