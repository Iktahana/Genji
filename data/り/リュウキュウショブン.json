        "examples": {
          "standard": [
            {
              "text": "明治政府による琉球処分は、琉球王国の終焉を意味した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "歴史のレポートで、琉球処分の過程とその影響についてまとめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "琉球処分に反対した人々もいたが、最終的に沖縄県が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "御維新になった結果琉球は最早島津氏の機関でないようになって、当然日本帝国の一部たるべき性質の者となりましたので、とうとう琉球処分ということが起って参りました。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球処分は実に迷児を父母の膝下に連れて帰ったようなものであります。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
