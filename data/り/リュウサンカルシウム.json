        "examples": {
          "standard": [
            {
              "text": "硫酸カルシウムは石膏の主成分であり、建築資材や医療用のギプスに使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "豆腐を作る際の凝固剤として、硫酸カルシウムを用いると、ふっくらとした仕上がりになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美術の時間に、硫酸カルシウムを水で練って彫刻の型を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「譬えば此の温泉の湯は化学的に分析すれば、硫酸と硫酸カルシウムと硫酸ナトリウム、硫酸カリウム、塩酸、硫酸アルミニウム、硅華硫酸鉄、まアそんなものだが、それは人体にとってはどうでも良いので、必要なのはこの温泉が果して病人に効くかどうかということだ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく消化して、次いで乾燥するまで水を蒸発させ、カプセルにかなり強い火を作用させ、最後にこのようにして得た硫酸カルシウムを秤量する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパと同じように梅毒の水銀治療は中国で何世紀にわたって行われた（塗り薬には灰色軟膏の代わりに水銀の赤色軟膏、内服には硫酸カルシウムを混ぜた昇華物）。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
