        "examples": {
          "standard": [
            {
              "text": "大学の哲学の授業で、ヴォルテールやルソーの理神論について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "理神論は、神が世界を創造した後は自然法則に介入しないと考える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はキリスト教の教義に疑問を持ち、次第に理神論へと傾倒していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "この規定に沿うて、イギリスの宗教哲学も亦、理神論（理性宗教）の形を取るし（そしてここから一種の唯物論者――トーランドなども出て来る）、やがてはヒュームの人間性論の課題も掲げられるのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ウァレリウス・ソラヌス）＊　この辺から、モンテーニュの理神論ないし汎神論が読まれる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
