        "examples": {
          "standard": [
            {
              "text": "古い教科書の間から、小学生の頃に使ったリトマス試験紙が挟まっているのが見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "リトマス試験紙は、薬局やホームセンターでも手軽に購入することができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レモンの汁をリトマス試験紙につけると、鮮やかな赤色に変化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度リトマス試験紙みたいな物だね。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平林たい子のことばをもじっていえば、戦後、凱歌を奏しつつひきかえして来た知識階級は、一九四九年にいたってふたたび、そのおなじ道を旗をまいて敗走しつつあるといえます」「一九四九年の諸事件はリトマス試験紙をさしこんだかたちであります」そして、「わかったことは、かれらは赤くも青くもないという一事です。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、救われるかもしれない」　リトマス試験紙が、青から赤に変るように、夫人の蒼白い頬に、俄かに赤い血がかッとのぼってきた。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
