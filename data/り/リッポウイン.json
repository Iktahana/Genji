        "examples": {
          "standard": [
            {
              "text": "本土復帰前の沖縄に存在した琉球政府には、住民の直接選挙で選ばれた代表者で構成される議会にあたる立法院が設置され、独自の法律を作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "社会的な関心を集めている新しい税制に関する法案の審議は、立法院の特別委員会で野党の激しい抵抗に遭い、夜遅くまで紛糾しながら続けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大学の政治学の授業の一環で行われた模擬国会で、私は緊張しながらも立法院の議長役を務め、学生たちの白熱した賛否の議論を時間内にどうにかまとめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "官吏も立法院の議院もまたそうでなければならない。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
