        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ボールペンのインクが切れたので、文房具店でリフィルを買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、そのファンデーション、ケースはそのまま使って中身のリフィルだけ交換できるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "システム手帳のリフィルを新年のものに入れ替え、気持ちを新たにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今からでも大書店で十六ミリフィルムを売り出してもよくはないか。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかにリフィルは入っていなかった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白紙のリフィルも取り出した彼は、それをバインダーの直径いっぱいにはさんだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "取材を開始すれば、分厚いリフィルはたちまち情報で埋まっていくはずだ、と彼は思った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来は革表紙の手帳のためのリフィルなのですけど、それを表紙なしで使ってました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "革表紙の裏ポケットに差し込んで使うリフィル。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以前はブランド物の手帳のリフィルを、美代子は使ってました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小さなリフィルを手帳に使うというのも、美代子らしいのよ」「なぜですか」「用が終わったはじから、ページをちぎって捨てていけるから。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手帳代わりのリフィルよりもふたまわりほど小さくて、薄いの。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かなスパイラルで綴じたリフィルが、表紙の裏側のポケットに差し込んであった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
