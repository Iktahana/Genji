        "examples": {
          "standard": [
            {
              "text": "がん細胞だけを狙い撃ちする粒子線治療は、患者の身体的な負担を大幅に軽減できる画期的な技術だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "重粒子線を用いた最先端の医療施設が、来春いよいよこの市にオープンする予定となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "粒子線が物質を通過する際に生じるエネルギー損失について、実験データを元にグラフを作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして天外より飛来する粒子の考えなどは、現在の宇宙微塵や太陽からの放射粒子線を連想させる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
