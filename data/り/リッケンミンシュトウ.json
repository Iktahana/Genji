        "examples": {
          "standard": [
            {
              "text": "支持率の低迷に悩む立憲民主党は、党のイメージ刷新を図っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "国会中継を見ていたら、立憲民主党の議員が鋭い質問をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女はボランティアとして、立憲民主党の選挙活動を手伝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "が、政権は革命的プロレタリアートの手に握られないで、国会を基礎として、立憲民主党、十月党、メンシェビキ――ブルジョアジーの代表者「臨時政府」がつくられ、それが支配した。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            }
          ]
        }
