        "examples": {
          "standard": [
            {
              "text": "この地域のインフルエンザ罹患率は、昨年よりも低い傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高齢者層における肺炎の罹患率は、依然として高いままだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喫煙と肺がんの罹患率には、明確な相関関係が認められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "図４　使用した米と脚気の罹患率。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある調査ではカリフォルニアに移住して少なくとも部分的に食事がアメリカ的になった日本人の虚血性心疾患（ＩＨＤ）は、日本の対応する住民の非常に低い罹患率のほぼ３倍であった（141）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
