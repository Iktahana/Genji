        "examples": {
          "standard": [
            {
              "text": "地域の公民館で開かれている料理教室は、主婦たちに人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「今日の料理教室で習ったレシピ、早速家で試してみようよ」「いいね！美味しくできるといいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はオンラインの料理教室に参加し、自宅で手軽にイタリアンを学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「僕の自宅のすぐ近くに住んでいる人で、母が親しくしている人がいて、僕がまだ中学生の頃に、料理教室を開いたのです。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷の料理教室へ電話をしてみた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵利子さんとは、料理教室を始めた人の長女だ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに料理教室の経営者の家の前をとおり、バス通りに向けて坂を下りた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
