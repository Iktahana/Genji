        "examples": {
          "standard": [
            {
              "text": "昔録画したビデオテープを見ようとしたら、最後まで再生されていたのでリワインドボタンを押した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "カセットテープの音楽を聴き返すために、鉛筆を穴に突っ込んで手動でリワインドした経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ミスをしてしまった瞬間、時間をリワインドしてやり直せたらどんなに良いだろうと考えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　ワラが素早くリワインドし、テープを止め、プレイ・ボタンを押す。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聴いてやって」　ワラが、テーブルにおかれた、小さなラジカセのリワインド・ボタンを押し、すぐにストップして、再生をはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
