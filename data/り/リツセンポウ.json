    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese seven-tone gagaku scale (corresponding to: re, mi, fa, so, la, ti, do) similar to Dorian mode",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
