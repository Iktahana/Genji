        "examples": {
          "standard": [
            {
              "text": "国連安全保障理事会は、内戦で揺れるその国の独立と完全な領土保全を強く支持する決議を全会一致で採択した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "国防軍に課せられた最大の使命は、外敵の侵略から国家の領土保全を確実に行い国民の命を守ることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "複数の国による多国間安全保障条約に署名することで、参加国同士の相互の領土保全が明確に約束された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国連憲章は第二条第四項で、領土保全と政治的独立に対して武力をもって脅威することを禁じている。",
              "citation": {
                "source": "世界は求めている、平和を！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち夫の英獨協商の如きは亦清國の領土保全門戸開放を以て原則としたるものなりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち夫の英独協商の如きは亦清国の領土保全門戸開放を以て原則としたるものなりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに至れば直ちに我が日本帝国の領土保全の上に大なる危害を感ずるものである。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
