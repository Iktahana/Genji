        "examples": {
          "standard": [
            {
              "text": "利付債は、定期的に利子という形で収入が得られるため、安定志向の投資家に人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は資産ポートフォリオに、国内の社債だけでなく、利率の高い海外の利付債も組み入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "債券投資には、利子のない割引債と、定期的に利子が支払われる利付債の二種類がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "今朝わたしは必要があって、額面三千ルーブリの五分利付債券を現金に換えたのです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
