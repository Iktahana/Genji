        "examples": {
          "standard": [
            {
              "text": "80年代のファッションがリバイバルし、若者の間で再び人気を呼んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔の名作映画がリバイバル上映されると聞いて、劇場まで足を運んだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地方鉄道がSLの運行をリバイバルさせ、多くの鉄道ファンが詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "而も耶蘇教徒のリバイバルの如くに『氣の伸び』を欲して、直に一切の利害を擺脱して、正しきに合せんとすることも起る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分に東京には奇体な現象があって、それを名づけてリバイバルというたのです。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこのことをあるリバイバルに非常に熱心の牧師先生に話したところが、その牧師さんに私は非常に叱られました。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その客間は若い信者や、慈善家や、芸術家たちのサロンとなって、そこからリバイバルや、慈善｜市や、音楽会というようなものが形を取って生まれ出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "1848年秋におけるテムズ川の水によるコレラ伝染　1849年のコレラ流行は1948年秋に始まったものの続きでもありリバイバルでもあり、最初の例と関連した状況のあるものは顕著であり注意する必要がある。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            }
          ]
        }
