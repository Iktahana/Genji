        "examples": {
          "standard": [
            {
              "text": "競合他社の製品をリバースエンジニアリングして、その技術や構造を分析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "リバースエンジニアリングは、互換性のある製品を開発する目的で行われることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ソフトウェアの脆弱性を発見するために、セキュリティ専門家がリバースエンジニアリングの手法を用いることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "製品化されたソフトウエアの仕様や機能を、開発工程を逆向きにたどって分析することから、リバースエンジニアリングと総称されるこうした手法は、法律で禁じられているわけではなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしリバースエンジニアリングをかけられる側の反発は、当然予測できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが中間コードが一致している以上、互換ベーシックの開発にあたって日本電気側がリバースエンジニアリングを用いたことだけは間違いのない事実だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
