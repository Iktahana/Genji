        "examples": {
          "standard": [
            {
              "text": "彼は輪鼓を操り、まるで生き物のように糸の上を滑らせて見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "輪鼓を空高く放り投げ、再び糸で受け止める技は圧巻だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの玩具である輪鼓に、子供たちは興味津々で集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また昔からありきたった傀儡子が、宮中でもって輪鼓、手鞠等を興行したこともある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
