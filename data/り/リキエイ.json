        "examples": {
          "standard": [
            {
              "text": "アンカーの選手は先頭との差をじりじりと縮め、見事な力泳で逆転優勝を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "荒波の海を対岸まで泳ぎ切った彼の力泳に、観客から割れんばかりの拍手が送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ゴール直前での熾烈なデッドヒートの末、彼女の気迫あふれる力泳が勝利を引き寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "後の追いこみの力泳ぶりも珍しいが、はじめの負けッぷりの悠長なのも珍しい。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああなたは、よろこばしい魚のように身をおどらしてそこにもぐっていらっしゃるのね、それから波と体とをやさしく調和させながら、高く低く、迅くおそくと力泳して、すこしつかれたときはじっと浮んで、いつか又波のうねりに誘われて泳ぎはじめ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
