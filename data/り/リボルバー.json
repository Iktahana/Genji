        "examples": {
          "standard": [
            {
              "text": "カウボーイは素早い手つきでリボルバーを抜き、的に向かって引き金を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い机の引き出しから、錆びついたリボルバーが見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「リボルバーは装弾数が少ないが、その分信頼性は高いんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "奴はリボルバーを取り出して、私に静かにしていろと言い、地下室に下りていって背中でドアを閉めた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーキーいう鋭い騒音が聞こえ、ピックマンが何やら判らぬ言葉を喚くのが聞こえ、リボルバーを六弾全部撃ち尽くす音が耳を劈いた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
