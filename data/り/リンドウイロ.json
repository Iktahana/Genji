        "examples": {
          "standard": [
            {
              "text": "日本の伝統色である竜胆色は、深く落ち着いた紫色をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が着ていた着物は、上品な竜胆色で、会場でもひときわ目を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋の夕暮れ時、空には竜胆色に染まった雲が浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その夜は白地に秋草模様を染めた着物で、珍しく奴袴は着けず、はでな竜胆色の帯を、うしろで大きく結び、素足に草履をはいていた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
