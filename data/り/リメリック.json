        "examples": {
          "standard": [
            {
              "text": "リメリックとは、独特の韻律を持つ五行詩で、ユーモラスな内容が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "英語の授業で、先生が面白いリメリックをいくつか紹介してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は即興でリメリックを作るのが得意で、パーティーの人気者だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "とにかく、韻律がそれ自体のせいで嫌われているのなら、唄も汚れたリメリック(*2)も人気の出ようがないのだ。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
