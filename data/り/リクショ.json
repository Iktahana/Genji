          "standard": [
            {
              "text": "書道の展覧会で、同じ文字を六書の異なる書体で表現した作品に感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古い石碑に刻まれた文字が、六書のうちどの書体にあたるのかを研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "書道家は、古典を学ぶ上で六書の変遷を理解することが不可欠だと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
