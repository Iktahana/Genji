          "standard": [
            {
              "text": "美術館のショップで、ゴッホの「ひまわり」のリプロダクションを記念に購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この椅子は、有名なデザイナーズチェアを忠実に再現したリプロダクション製品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "アンティーク家具は高価で手が出ないが、リプロダクションなら手頃な価格で楽しむことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それによると、税関の役人がその人の所持品を検査した際、一絵画のリプロダクションを発見して没収したという事件です。",
              "citation": {
                "source": "役人の頭",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            }
          ]
