        "examples": {
          "standard": [
            {
              "text": "電波の届かない死角を解消するため、中継器としてのリピーターを設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長距離の通信ケーブルでは、信号の減衰を防ぐためにリピーターが挿入される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットワークの範囲を拡張するには、適切な位置にリピーターを配置する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
