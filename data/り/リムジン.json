        "examples": {
          "standard": [
            {
              "text": "結婚式の当日、式場からパーティー会場までの移動に白いリムジンを手配した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "映画祭のレッドカーペットに、主演俳優が黒塗りのリムジンで颯爽と登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "友人の誕生日を祝うため、みんなでリムジンを貸し切って夜の街をドライブした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それは二人目の運転手が一・六キロメートル先でЗИСリムジンを洗車している様子だった。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
