          "standard": [
            {
              "text": "LISPは、括弧を多用する独特の構文を持つことで知られているプログラミング言語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "Emacsエディタのカスタマイズには、LISPの方言であるEmacs Lispが使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は大学時代にLISPを学び、その強力なマクロ機能に魅了された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "柔軟で拡張性のある（FLexible EXtendable）言語という目標からフレックス（ＦＬＥＸ）と名付けた言語を書くにあたって、ケイはリスプ★★の柔軟性と簡潔性に学ぼうと目標を立てた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リスプはもう一つの、そしてもう少し耳ざわりのいい人工知能研究の成果と言えようか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
