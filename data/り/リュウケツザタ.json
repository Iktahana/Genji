        "examples": {
          "standard": [
            {
              "text": "些細な口論がエスカレートし、ナイフを持ち出す流血沙汰にまで発展した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "バーでの喧嘩が、警察が介入するほどの流血沙汰になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は平和主義者で、いかなる流血沙汰にも反対している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "事、ひとたび流血沙汰に及んだとすれば、農民達にいか程正義正当の理由があったにしても、士農工商、階級の相違、権力の相違が片手落ちならぬ片手落ちの裁きをうけて、結局悲しい処罰をうけねばならぬ者は、正しいその農民達なのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこの日の昼間のことを考えても、サンゼリゼの伝統派と左翼との格闘のさまなど、カソリックと科学との闘争だといえば云うことの出来る精神の違いの流血沙汰だったと思われた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
