    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eating rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アジアの多くの地域では、小麦のように粉にしてパンを作るのではなく、米を粒のまま炊いて食べる粒食の文化が根付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "縄文時代の後半には、土器を使った煮炊きが普及し、どんぐりやアワなどを粒食していた痕跡が見つかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "麦は粉食に適しているのに対し、米は粒食が基本となるため、それぞれの穀物に応じた調理器具が発達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度収穫を終えたばかりの馬鈴薯と畑に甘藷があるので、差迫っての餓死は兎に角、粒食は直ぐ危くなりました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は粥にして、玉蜀黍で補い、米を食い尽し、少々の糯米をふかし、真黒い饂飩粉や素麺や、畑の野菜や食えるものは片端から食うて、粒食の終はもう眼の前に来ました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅野家の米一粒食ったわし等じゃないぞ』『まあ、穏かに聞こう。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷の禄一ト粒食ったことはない武士だ。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
