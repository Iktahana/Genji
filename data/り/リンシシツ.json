          "standard": [
            {
              "text": "細胞膜の主要な構成成分はリン脂質だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リン脂質は生体内で多様な機能を持つ分子である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大豆から抽出したリン脂質は、健康食品にも利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "リン脂質はトリグリセリドの１つの脂肪酸がコリン−リン酸またはエタノール−リン酸で置き換えられたものと考えることができるであろう。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの研究者たちすべてはそれぞれの断片がいろいろな速さでリン脂質に取り込まれることを観察した。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "貯蔵脂肪中の脂肪酸は脂肪またはリン脂質の形で内臓へおよび内臓から運ばれるとみなされる。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
