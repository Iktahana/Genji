        "examples": {
          "standard": [
            {
              "text": "フランス・リテラチュアの奥深さに魅了され、翻訳家を目指すことに決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "比較リテラチュアの観点から、日本と西洋の怪談の構造を分析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は学生時代、リテラチュアの研究サークルで熱心に議論を交わしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "が何と言っても日本の探偵小説、アブノーマル・リテラチュアの中で彼はだんぜん群を抜いている。",
              "citation": {
                "source": "江戸川乱歩",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし評論などに於ける文学的精神がこの文献学精神を出ないなら（文学＝リテラチュア＝文献）そういう文学的精神は正に科学的精神の正反対物だということを、記憶せねばならぬ。",
              "citation": {
                "source": "科学的精神とは何か",
                "author": "――日本文化論に及ぶ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
