        "examples": {
          "standard": [
            {
              "text": "チケットの発売時刻に合わせてブラウザを何度もリロードしたが、結局サーバーエラーで買えなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "掲示板の最新の書き込みを確認するために、画面をこまめにリロードする癖がついてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "通信環境が悪かったのか、ページが完全に表示されなかったのでもう一度リロードしてみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "プレハーノフの女弟子、ソヴェト同盟のマルクス主義機械論的修正派の最も有名な代表者アクセリロードは、「トルストイの創作を批評するのにもスピノザの哲学を分析する際にも、彼女は永久不変の道徳法から出発している。",
              "citation": {
                "source": "婦人作家は何故道徳家か？　そして何故男の美が描けぬか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
