        "examples": {
          "standard": [
            {
              "text": "彼は今でもフィルムカメラにこだわっていて、特にリバーサルで撮った写真の色合いが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "リバーサル現像は、ネガ現像とは異なる特殊な薬品と工程を必要とする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この写真はリバーサルで撮影したもので、ポジフィルムとして仕上がっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "白黒の印刷物の複写に僕はカラーのリバーサル・フィルムを使う。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
