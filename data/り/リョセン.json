        "examples": {
          "standard": [
            {
              "text": "その雅楽の演奏は、呂旋特有の落ち着いた重厚な響きで聴衆を幽玄の世界へと誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "伝統音楽の授業で、律旋と呂旋の音階の違いについて実際に楽器を鳴らしながら学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "現代のポップスの中にも、意識的に呂旋の音階を取り入れて和風の雰囲気を演出している曲がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元来、壱越調｜呂旋であるべきこの曲が平調で唄われるさえ訝しいのに、宮声に凄切の気韻があったのはどうしたわけか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
