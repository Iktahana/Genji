        "examples": {
          "standard": [
            {
              "text": "この路線では、貨物列車よりも旅客列車の方が優先して運行される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕方のラッシュアワーには、数分おきに旅客列車がホームに入ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、全国の様々な旅客列車を写真に収めている鉄道ファンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "恰度四時四十二分に夜行の旅客列車が物凄い唸りを立てて、直ぐ眼の前の上り線路を驀進して行きました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うのは、四時四十二分に例の旅客列車が通過して、五分過ぎましたが、意外にも豚盗人はやって来ないんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一行は、Ｂ駅から直ぐ次の旅客列車に乗ってＨ駅へ来ました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とそう思って幾日も経たないのに、又々北鉄本線ハルピン新京間で旅客列車が匪賊の手によって顛覆され、多数の死傷者を出し、邦人数名が人質として拉致されたという事件である。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "客車も購入し、旅客列車の定期便もあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
