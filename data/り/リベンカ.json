        "examples": {
          "standard": [
            {
              "text": "春に咲くサクラやウメは、私たちにとって最も身近な離弁花の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "理科の実験で、離弁花であるツツジと合弁花であるアサガオの構造を比較した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "図鑑で、色鮮やかな多くの離弁花の写真を見て、植物の世界の多様性に感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "無論オリーブとヅクノキとは科も異なりオリーブは合弁花を開くヒイラギ科に属し、ヅクノキは離弁花のヅクノキ科に隷する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
