        "examples": {
          "standard": [
            {
              "text": "彼は、家族を侮辱した相手へのリベンジを心に誓い、復讐の機会をうかがっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この映画は、すべてを失った主人公が、巨大な悪の組織にたった一人でリベンジを挑む物語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「昨日の試合の借りは、必ず次の対戦で返してやる。見てろよ、完璧なリベンジだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
