          "standard": [
            {
              "text": "PTAの役員決めは揉めることが多いので、結局は輪番制に落ち着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宿直の仕事は輪番制になっており、月に二回ほど順番が回ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自由参加だった勉強会も、発表者を輪番制にしてから活気が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "或る日、表町の外食券食堂へ行く途中（私達家族三人は主食配給が遅配がちなのと、隣組の輪番制当番がうるさかつたので外食にきりかへたのだ）一人の年増婦人からかう訊ねられた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兵士の服役は輪番制によって絶えず交代するものであり、在郷兵は月二三回の訓練を受ける。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
