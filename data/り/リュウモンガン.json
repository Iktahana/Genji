        "examples": {
          "standard": [
            {
              "text": "地質調査の結果、この崖の地層は主に流紋岩で構成されていることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "流紋岩特有の美しいしま模様が、噴火当時の溶岩の流れを今に伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "河原で拾った流紋岩を薄く切って、顕微鏡でその結晶構造を観察する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "流紋岩だかなりの比重だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（石英安山岩か流紋岩から来た。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巌峰は流紋岩にして、柱状の節理を成す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰の正面は流紋岩の長柱を連ね、その長柱は峰の両側面に及ぶ。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し地表に湧出すれば流紋岩となるという）が岩脈状をなして花崗岩の間に迸入した。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師岳の如きは流紋岩に類似せる角閃小紋岩から成っている。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ見る、巨大な滝縞のある流紋岩壁が、えぐれて半環状に洞門を開いた下に、透明な温泉は豊かに湧出して、潭をなしてたたえている。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
