        "examples": {
          "standard": [
            {
              "text": "港湾地区の再開発に伴い、赤字が続いていた臨港鉄道の廃止が正式に決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "小さなディーゼル機関車が、臨港鉄道の古びた線路をゆっくりと貨車を引いて走っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "私の祖父は長年、この臨港鉄道で機関士として働き、数え切れないほどの物資を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "政友系は例の積極政策からいつでも事業を起して議員も儲け、選挙民にも悦ばれる為めの事業のあることを喜ぶのであるが、臨港鉄道問題だけは喜ばなかつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の提案は市の繁栄の為めに臨港鉄道が必要である。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで此度内務省とも、県当局とも話して、研究の結果どうしても駄目と云ふことがわかれば、小松島か古川港に臨港鉄道を以つて徳島市との聯絡を取り、残念乍ら、徳島港を放棄すると云ふことに決定したのであります。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
