        "examples": {
          "standard": [
            {
              "text": "彼が大学院で専攻しているのは量子物理学で、毎日のように数式と睨み合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのSF映画は、量子物理学の理論をベースにした並行世界を描いていて非常に興味深かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "量子物理学の観点から見れば、この現象も決して不思議なことではないらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度現在の量子物理学が生まれつつあった時代で、電子の波動性というとんでもないことを提唱したドゥ・ブロイの最初の論文を、たしか芝（亀吉）さんだったかが初めて読んだのも、この雑誌会であった。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非ユークリッド幾何学と量子物理学とくれば誰の脳髄だってパンパンに腫れ上がらすのに十分だし、それらを伝承と混ぜ合わせてゴチック物語や野蛮な炉端の囁きが仄めかす食屍鬼めいた何かの背後に異様な多次元的現実世界の痕跡を探ろうなどとしたら、精神を張りつめずにすむ訳がない。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
