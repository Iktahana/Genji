        "examples": {
          "standard": [
            {
              "text": "専門家は、その国の新しい憲法が立憲君主政体の基礎を確立したと評価している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は論文で、アジアにおける立憲君主政体の多様性について論じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "国民投票の結果、その国は共和制ではなく立憲君主政体を維持することを決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "されば国民的政治とはこの点においてはすなわち世俗のいわゆる輿論政治なりと言うべし、「天下は天下の天下なり」と言える確言をばこれを実地に適用し、国民全体をして国民的任務を分掌せしめんことは国民論派の内治における第一の要旨なりとす、この理由によりて国民論派は立憲君主政体の善政体なることを確定す。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
