        "examples": {
          "standard": [
            {
              "text": "客船の豪華な理髪室で、優雅に髪を整えてもらうひとときを過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「刑務所の中にも理髪室があって、受刑者が交代で散髪を行っているんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホテルの地下にある理髪室は、静かで落ち着いた雰囲気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "真白いエナメル塗の椅子がいくつも並んだ清潔至極な理髪室がある。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く所によると、これは荘司が二十何万円とかを鉄道省に寄付して、そこの地下に理髪室浴場などを設けることになったのだという事である。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚ホテルの理髪室へ行き、それから大阪へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三信ビル地下の理髪室へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
