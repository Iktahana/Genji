        "examples": {
          "standard": [
            {
              "text": "空中で炸裂した榴散弾から無数の散弾が降り注ぎ、広範囲に被害をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史博物館で、第一次世界大戦当時に使用されていた榴散弾の破片を間近で見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "榴散弾による攻撃を避けるため、兵士たちは急いで塹壕の中に身を隠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「砲兵の榴散弾で、城門近くの歩兵がやられて居るんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事物の自然化だとか、科学化だとか、そんなことを云ってる暇に僕らの生命力は、誰やらじゃないが、榴散弾みたいに進んでゆく。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
