        "examples": {
          "standard": [
            {
              "text": "この雅楽の楽譜は、荘厳な響きを持つ律旋で書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ベテランの演奏家は、明るい呂旋と落ち着いた律旋を、曲の雰囲気に合わせて自在に吹き分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "神社の厳かな儀式には、律旋の重厚なメロディがよく似合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "旋律の規範としての音階は、わが国には都節音階と田舎節音階との二種あるが、前者は技巧的音楽のほとんど全部を支配する律旋法として主要のものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
