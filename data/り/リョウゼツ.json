        "examples": {
          "standard": [
            {
              "text": "彼は味方の前では敵を非難し、敵の前では味方を裏切るような、両舌を使う信用できない男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の両舌にだまされ、社内の人間関係はすっかりこじれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "政治家たるもの、国民に対して両舌を使うようなことがあってはならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "これは竜の子孫に鱗の遺伝どころか、両舌竜の後身に治めらるる国民全体までも、両舌の心性を伝染したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            }
          ]
