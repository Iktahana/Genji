          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ズボンの裾上げの長さを間違えてしまったので、裁縫箱からリッパーを取り出して縫い目をほどいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ミシンで生地を巻き込んで縫ってしまった箇所を、リッパーを使って生地を傷めないように丁寧に切り離した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しく買ったこのリッパーは刃先が非常に鋭くて、厚手のデニム生地のステッチも簡単にほどける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから図表、バァイオリンケース、パイプ架、それから更に波斯スリッパー、――……と、それぞれ見まわす目に止まった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ア・ハード・デイズ・ナイト』、それに、〈ウィー・キャン・ワーク・イット・アウト／デイ・トリッパー〉などを聴いて、一週間をすごした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三番目の箱からは、これまた街路で拾った大きな真鍮ピン、長靴にうつ平鋲のちぎれたの、靴やスリッパーの扣金、真鍮の扉のハンドル、ステッキについている骨製の頭、「夢判断の神籤」その他の、つまり屑が沢山つまっているのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、ヴァッヘル事件　南欧の「ジャック・ゼ・リッパー」と称せられたヴァッヘルは、まさしく殺人狂の一人であった。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な事件では、ジャック・ゼ・リッパーなどがそれだろうと思われるが、ここには、まだ余り我国に紹介された事のない事件を記して見た。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、丸善にゆき、Ａのホワイトシャツ、一つ、自分のスリッパー一足、あと本を見、夕、Miss Wells のところ、夜、「江戸から東京へ」。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば今、太平洋横断にはアメリカのクリッパー機にのってもすくなくとも三日間はかかる、ところが成層圏までとびあがって飛行すれば、せいぜい六時間ぐらいで飛べるんだ。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この毛利アケミさんなる人物は元来素人ストリッパーである。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで女優、ダンサー、歌手、ストリッパー、いろいろギンミしたあげく、自分の好みにも合い、また見込みのありそうなのもアルバイトの女学生芸能家だと見当をつけた。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでストリッパーを踊りながら客席へ降ろすことを考えた。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのストリッパーがさのみ芸術性ゆたかなものでなかったから良いようなものの、ヒロセ元美というようなとにかく芸で見せようという心意気なのが、お尻と前を押え着物をひきずりながらモゾモゾモゾとひッこむのを見てごらん。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年を十日で暮すよい男とは相撲取りで、同じ裸でも一年を三百六十三日で暮すストリッパーは、マアお相撲さんはうらやましいわと、裸になりっぱなしの彼女達は嘆くのである。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓から流れ込む初夏の風にパーマネントの髪をなびかしている、これが有名なストリッパーの大グループとは誰が思おうぞ、ドレス・メーカーの春の旅行といった姿である。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにストリッパーというものは、寿命が短いですよ、五年がせいぜいですなあー。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "と驚く本物のストリッパー連、「アーラ物すごい、すっかりお株を取られちゃったわ」　と鳴りを沈めてびっくり仰天、どぎもをぬかれながら温泉特急は伊豆の駅についたのでした。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの一番やりたいと思っていることわかる」「ストリッパーでしょう」「ちがうちがう、幼稚園の先生なの、どーしてもなりたいの、サアー一ぱい、ついで、ちょうだい……」　一息にのみほし、胸をふくらませると、「幼稚園が駄目なら保姆さんになりたいの、なりたいわ、泣きたくなるくらいなりたいわ私！",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は逃げても駄目、裸にしちまうから」「おどかすなよ」「おどかしじゃないわよ、吉例のいけにえだもの……あたしあたし、とても悲しいのよ」　ストリッパーというのは、すぐ泣きたくなったり悲しくなったりするらしい。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正真正銘の騎士らしいいでたちで恋人に目通りするために、彼はそのとき泊っていたハンス・ヴァン・リッパーという年寄りの怒りっぽいオランダ人の農夫から馬を借り、威風堂々とそれにまたがり、冒険をもとめて旅立つ武者修行者よろしくのていで、駈けだした。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "じじつ、この馬はかつては例の怒りっぽいヴァン・リッパーという主人の愛馬だったのだ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような恰好でイカバッドと彼の馬とは、ハンス・ヴァン・リッパーの家の門をよろめき出ていったのである。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンス・ヴァン・リッパーの面に向って指をならしてやるぞ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬、ハンス・ヴァン・リッパーが憤激するおそろしさが彼の心にうかんだ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンス・ヴァン・リッパーは、あわれなイカバッドとそれから自分の鞍とにふりかかった運命が少々気になりはじめた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンス・ヴァン・リッパーは彼の遺産管理人として、先生がこの世でもっていた財産を全部いれてあるつつみを調べた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魔術の書物と詩の書き散らしとは、ただちにハンス・ヴァン・リッパーの手によって焼却された。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とすみ子は自分のスリッパーを男にはかせ、その下駄を手にさげて正面の階段を先に立って上る。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、五〇年末からはじまったいわゆるカリフォルニア・クリッパーの帆船航路であった。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇年正月のマルクスの眼に映じていなかった一現象――海の黄金狂時代が太平洋郵船ラインとともに生み出したいま一つのヒロイン――たるカリフォルニアン・クリッパーについて語らねばならぬ。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カリフォルニアン・クリッパー」こそ、アルゴノーツの心願そのままに、speed, comfort, capacity おまけにいま一つ beauty を驚異的な程度に綜合した絶品だった。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがカリフォルニアン・クリッパーに関する最大の驚異は、それがニューヨーク・サンフランシスコ間だけでなく、いわゆる「三角航海」によって全世界を席巻したからであった。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
