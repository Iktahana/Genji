        "examples": {
          "standard": [
            {
              "text": "深刻なエンジニア不足を背景に、理工系の学生を採用するための企業間の競争が年々激化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は理工系のバックグラウンドを活かし、専門的な特許翻訳の仕事でフリーランスとして独立した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "研究所の食堂は、白衣を着た理工系の研究者たちが難解な議論を交わしながらランチを食べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "生年に三年の差はあるものの、東京の世田谷に生まれ、私立有名大学の理工系に進み、同じ会社の同じ部門に籍を置くことになった二人の経歴には、共通項が多い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は理工系統をのこして、法文科は殆ど廃止、廃校になります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
