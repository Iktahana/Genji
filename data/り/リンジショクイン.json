          "standard": [
            {
              "text": "年度末の繁忙期に対応するため、市役所は臨時職員を数名採用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は結婚して退職するまで、3年間、図書館の臨時職員として働いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "臨時職員でも、仕事に対する責任感は正職員と何ら変わりはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "七月十五日、「一般保険会社」をやめ、七月三十日、「臨時職員」として半官半民の「労働者傷害保険協会」に採用される。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            }
          ]
