        "examples": {
          "standard": [
            {
              "text": "DNAの二重らせん構造は、美しい立体構造を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このタンパク質は、特有の立体構造を持つことで機能を発揮する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "建築家は、機能性と美しさを兼ね備えた立体構造の建物を設計した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "北海道などで、前を行く人の姿も見失いがちになるような濃い雪が降ることがよくあるが、そういう時は、たいていこの立体構造の雪である。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イデオロギーは――上部構造として――下部構造との連関に於て、イデオロギー相互の間に歴史的・価値的・な立体構造を有っている、諸イデオロギエンの間には一定の客観的な歴史的乃至構造的な秩序が、吾々によれば指摘出来る。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
