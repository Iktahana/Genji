        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その山奥の村は交通の便が悪く、まさに陸の孤島と呼ぶにふさわしい場所だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都会の喧騒から離れ、陸の孤島のような場所で静かに暮らしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こんな陸の孤島で、よくインターネットが繋がるもんだ。」と彼は驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "むかしのような陸の孤島ではない、ということの証だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや特定の郊外に人気が集中することはなく、陸の孤島もなくなった。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
