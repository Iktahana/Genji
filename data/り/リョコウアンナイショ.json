        "examples": {
          "standard": [
            {
              "text": "初めての海外旅行に向けて、書店で一番分厚い旅行案内書を買って熟読した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古い旅行案内書を引っ張り出してみたが、お店の情報がすっかり変わっていて役に立たなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "図書館の郷土資料コーナーには、明治時代に出版された貴重な旅行案内書が保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "又支那に『示我周行』といふ題目の旅行案内書がある。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絶好機に初音サンの心を捉えなければならない、と心に期して、その夜は明方ちかくまで旅行案内書や地理歴史考古学等の書物をひッくりかえした。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベデカ（有名な旅行案内書）一冊もっていず、金ももっていない伸子と素子とは、オペラや演劇シーズンの過ぎた五月のウィーンの市じゅうをきままに歩いて、いくつかの美術館を観た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行案内書にも、それは書かれています。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、客観的に記述された地理書であると同時に、旅行者の実際の行動を指導する旅行案内書ともなることに比することが出来るであらう。",
              "citation": {
                "source": "国語学と国語教育との交渉",
                "author": "――言語過程説の立場における――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
