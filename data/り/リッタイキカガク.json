        "examples": {
          "standard": [
            {
              "text": "高校の数学で、ユークリッド幾何学と立体幾何学を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "立体幾何学は、建築やデザインの分野で応用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は立体幾何学の難問を解き明かし、学会で発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この連鎖の主な廉々は一、シヤンチリイ二、オリヨン三、ドクトル・ニコルス四、エピクロス五、立体幾何学六、敷石七、果物屋とかう云ふ順序だよ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは立体幾何学の問題じゃ、えーと、「幾何学をもって幽霊の存在を証明せよ」どうだ分るか、もう一度いう「幾何学をもって幽霊の存在を証明せよ」問題はそれだけじゃ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、すこぶるかんたんな立体幾何学的な模型のような形をしていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美人ト不美人トノ相違ノ真髄ハ何処ニアリヤト考エルノニ、要スルニ夫レハ主トシテ眉目ノ立体幾何学的問題ニ在ル。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
