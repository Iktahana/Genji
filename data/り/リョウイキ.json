    "definitions": [
      {
        "index": 1,
        "gloss": "territory",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣の国の軍隊が突如として我が国の領域を侵犯し、国境付近で緊張が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この川の南側は昔から彼らの領域であり、無断で立ち入ることは許されていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ライオンは自分の領域に侵入してきた若いオスに対して、激しい威嚇を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "芸術といふものは、幾度もいふ通り名辞以前の現識領域の、豊富性に依拠する。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族的、歴史的存在規定をもった現象を自由に変更して可能の領域においていわゆる「イデアチオン」を行っても、それは単にその現象を包含する抽象的の類概念を得るに過ぎない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蓮の浮気は一寸惚れ」という時は未だ「いき」の領域にいた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は趣味が道徳の領域において意義をもつことを疑おうとしない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また芸術の領域にあっても、「色を求むるにはあらず、ただ色合のみ｛３｝」といったヴェルレエヌとともに我々は趣味としての色合の価値を信ずる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の進歩に伴う研究領域の専門的分化は次第に甚だしくなる一方である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このように縮小された各学者の眼界の領域はほとんど十人十色であって、それらのおのおのの領域はある部分では互いに重合して共通していても、残りの部分ではみんな少しずつちがっているわけである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう場合にその同じ部門の専門家が審査員になっていれば、当該方面の文献も手近に揃っており、従って提出された仕事がその方面の領域で占める地位とその幅員も判断されやすい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども実際は科学者が科学の領域を踏み外す危険を防止するためには、時にこれらの反省的考察が却って必要なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各測候所の平均領域の幅員に比して微細なる変化は度外視し、定時観測期間の長さに比して急激なる変化をも省略して近似的等温線あるいは等圧線を引くに過ぎず。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの予報が普通世人にとりて実用的価値を有するための条件は、思うに「その現象のために利害を感ずべき個人あるいは団体の利害を感ずる範囲領域の大きさに対して、予報の指定する範囲の大きさが比較的大ならず、且つ前者に対する後者の位置の公算的変化の範囲の小なる事」なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のごとき単純な側面観によって科学と芸術との任務や領域を遺憾なく説明しようというのではない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの疑問以上に立ち入る事は科学者の領域以外に踏み出すと思う。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々考えが形而上的に走り、罷り違えば誇大妄想狂となんら選む所のないような夢幻的の思索に陥って、いつの間にか科学の領域を逸する虞がある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿であろうが摺子木であろうが、それが純粋な猿や摺子木として取扱われている間は漫画の領域に這入り得ないように思われる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ落語や川柳にも前述のごとき意味の科学的要素を中心として発展し得べき領域のある事をこの機会に注意しておきたいと思うのである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな物ずきな比較は現在の言語学の領域とは没交渉な仕事である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去は、理智の領域のそと、その力のとどかないところで、思ひもかけない、何か物質的な物體のなかに（その物質的な物體がわれわれに與へるだらう感覺のなかに）隱されてゐる。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる二つの區切られてゐない領域のなかに住まつてゐて、その兩方のものから限りなく養はれてゐる我々の實存を、我々はもつともはつきりと認識するやうに努力しなければなりません。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人生の本當の姿はその二つの領域に相亙つてをり、又、もつとも大きく循環する血はその兩方を流れてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では発動機船に冷蔵庫と無電装置を載せて陸岸から千海里近い沖までも海の幸の領域を拡張して行った。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "field",
