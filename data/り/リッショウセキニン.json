        "examples": {
          "standard": [
            {
              "text": "刑事裁判では、被告人が有罪であることの立証責任は検察官が負う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "医療過誤訴訟では、患者側が医師の過失を証明する立証責任を負うことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「無実を証明しろ」と彼は言うが、本来、立証責任は疑う側にあるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、あなたが採用されたことの立証責任があなたに課せられているという意味です。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
