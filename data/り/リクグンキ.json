        "examples": {
          "standard": [
            {
              "text": "空には、偵察のために陸軍機が飛んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "第二次世界大戦中、多くの陸軍機が開発された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はかつて陸軍機のパイロットだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海軍機が支那奥地の爆撃に成功したとて、陸軍機がただちにこれに競争する必要はない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、陸軍機か」　彼等は、噛んで吐き出すように、云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし米国艦隊が日本沿岸何百キロの距離に近寄ったところで戦争をするとなると、日本の海岸警備隊や、陸軍機が、戦争に参加することとなる。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
