        "examples": {
          "standard": [
            {
              "text": "民主主義国家において、選挙で選ばれた議員が集まる議会は国民の意思を代表する最高の立法機関であり、法律を通じて国家の方向性を決めるその責任は極めて重い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "地方自治体における独自の立法機関である市議会の本会議で、市民からの要望が多かった公園の夜間利用の制限を緩和する新しい条例案が、賛成多数で無事に可決された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "軍事クーデターによって成立した独裁政権下では、国民の意見を反映するはずの立法機関が完全に機能不全に陥っており、大統領の出す法令が事実上の法律としてまかり通っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを、國会は「唯一の立法機関である」というのです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "立法機関とは、國の規則をこしらえる役目のある機関ということです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホップの混ぜ物処理は立法機関によって禁止されている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながら実際の腐敗は独り貴族及び貴族院に止らず、近来政党及び衆議院の腐敗は寧ろ是れに過ぎたり猟官に非ずんば賄賂の授受を目的とし、国家の立法機関を以て利益交換の市場と為し、代議士の公職を利用し、政党の佳名を藉りて営利の私計を事とし、靦然として耻づるなきは、豈衆議院の近状に非ずや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焚書時代」の出現中井正一　立法部門が自分で立法機関をもつということ、この当り前のことが、今までなかったということが、実は不思議だといえば不思議だったわけである。",
              "citation": {
                "source": "「焚書時代」の出現",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　国会第四一条　国会は、国権の最高機関であつて、国の唯一の立法機関である。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（憲法第四十一条「国会は、国権の最高機関であって、国の唯一の立法機関である。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
