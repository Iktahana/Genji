        "examples": {
          "standard": [
            {
              "text": "正規の流通経路を通さない偽造品が市場に出回っており、メーカーが注意を呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この商品は、海外から独自の流通経路で仕入れているため、他店より安く提供できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な流通経路を辿ることで、商品の最終価格が仕入れ値の数倍に膨れ上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "弱小規模ながらソフトハウスがつぎつぎと誕生し、ショップの店頭ではパッケージソフトが売れはじめていたものの、ソフトウエアの流通経路の整備はいまだに手つかずのまま放置されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの台頭によって、個々のユーザーが店頭で手にとって買う新しいソフトウエアの販売形態が生まれつつある以上、こうした動きに対応した流通経路の確立には大きなビジネスチャンスがあると孫は考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
