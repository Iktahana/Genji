        "examples": {
          "standard": [
            {
              "text": "研究室では、特殊な合成方法を用いて高純度のジホスフィン（リン化水素）を生成する実験が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ジホスフィンは自然発火性を持つため、空気中での取り扱いは極めて危険である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その論文では、ジホスフィンを反応中間体として利用した新しい触媒の開発について報告されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
