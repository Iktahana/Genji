        "examples": {
          "standard": [
            {
              "text": "平安時代の装束を纏った儀仗兵が、立纓（りゅうえい）の冠を凛々しく被っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「立纓は天皇の冠に用いられる形式で、その高さは威厳を示している」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館で、細長い板のような立纓がついた古い冠を興味深く観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東廂の北端に人影ゆらぐと見る間に、黒袍の前行に續く御劍御璽の捧持者の間を、黄櫨染の御袍、立纓の冠を召された聖上陛下が、御裾を待從に捧げさせ給ひ、げにも威風堂々として出御せさせらる。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
