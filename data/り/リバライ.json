        "examples": {
          "standard": [
            {
              "text": "企業の財務状況を分析する際は、借入金の利払い負担も考慮に入れる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "国債の利払い費が、国家予算を圧迫する大きな要因となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "住宅ローンの利払いを少しでも減らすため、繰り上げ返済を計画している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "もう二三ヶ月分もたまってる家賃、諸払い、方々への少しずつの義理、僅かながらの正月の仕度、流質の通知を受けてる質屋への利払い……そんなもののことを一度に考え廻しながら、彼と妻とは、幼い子供をかかえて途方にくれた。",
              "citation": {
                "source": "好意",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、正確な小作米、畑年貢などが予期されないとすれば、信用組合、銀行、無尽会社への利払いでさえ容易のことではない。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "天道流での「軍｜捨利払い」だ！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天道流での「軍捨利払い」だ！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "投資に対して利払いすらも出来ぬとなると、私人の関係はついに移って国家の関係となる。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
