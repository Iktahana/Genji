        "examples": {
          "standard": [
            {
              "text": "夏の川辺では、緑藻類が石にびっしりと生えているのを見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緑藻類は、水中の酸素を生成する重要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水族館の専門家が、水槽内の緑藻類の異常繁殖について調査している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして我国の学者は東垣の『食物本草』にある裙帯菜をワカメだとし前の村田氏の『鮮満植物字彙』にもそうしているが、これは間違いでこの裙帯菜はけっしてワカメそのものではなく、無論何か別の緑色海藻すなわち緑藻類である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
