    "definitions": [
      {
        "index": 1,
        "gloss": "gonorrhoea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "淋毒は性感染症の一種であり、早期の治療が非常に重要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "淋毒菌に感染すると、尿道に強い痛みや膿が生じることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "適切な抗生物質を服用することで、淋毒の症状は劇的に改善する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "留置場でヒゼンが流行る話をきき、またこの不潔なやり方を見て、何よりわたしは淋毒が目にでも入っては大変だと恐怖を感じた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
