          "standard": [
            {
              "text": "飛行機の待ち時間に空港の売店で旅行誌を買い、機内でパラパラと眺めて過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その旅行誌の巻頭特集は、「一生に一度は行きたい世界の絶景ホテル」だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はフリーのカメラマンとして、様々な旅行誌に風景写真やグルメ写真を提供している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "航海記や旅行誌がわたしの愛読書となり、あまり読みふけって、学校の正規の勉強はほったらかしの始末だった。",
              "citation": {
                "source": "わたくし自身について",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
