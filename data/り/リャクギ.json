        "examples": {
          "standard": [
            {
              "text": "本来であればお会いして伝えるべきですが、略儀ながらメールにてお礼申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "略儀ではございますが、書中をもちまして新任のご挨拶とさせていただきます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正式な作法を重んじる席で、略儀を済ませてしまうのは社会人として失礼にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "略儀ながら不束な田舎料理の庖丁をお目に掛けまする。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この度の参宮には、都合あって五二館と云うのへ泊ったが、内宮様へ参る途中、古市の旅籠屋、藤屋の前を通った時は、前度いかい世話になった気で、薄暗いまで奥深いあの店頭に、真鍮の獅噛火鉢がぴかぴかとあるのを見て、略儀ながら、車の上から、帽子を脱いでお辞儀をして来た。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の将軍家への進物十一色に比べるとはるかに略儀になっている。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは庭口ではあるが、石舟斎が隠居所、略儀はおゆるしあって、お通りください」　老父は、手ずから、左右の門をひらいて、わが子の使者を、座敷に迎え入れた。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
