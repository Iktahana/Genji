    "definitions": [
      {
        "index": 1,
        "gloss": "scheme to provoke discord (e.g. between countries)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
