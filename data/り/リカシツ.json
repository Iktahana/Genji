        "examples": {
          "standard": [
            {
              "text": "小学校の理科室には、人体の骨格模型や実験器具が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "理科室での実験は、いつも子どもたちの好奇心を刺激する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "放課後、理科室で先生に質問をする生徒たちの姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "課外に、森先生に漢文をならうのは私一人であったが、ちっとも面倒がらないで、理科室や裁縫室で一時間位ずつ教えを受けた。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
