        "examples": {
          "standard": [
            {
              "text": "数学の講義で、計算過程を簡略化するための独自の略記法を教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "速記者のメモには、一般人には判読不能な高度な略記法が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この楽譜には、繰り返しを効率的に示すための特殊な略記法が採用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "羊皮紙や紙を節約し、作業を効率化するために、手写本では略記法や短縮記号が一般的に使われていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書物の出現』によれば、初期の印刷本はじょじょに行間を広げ、略記法を減らすなどの変化を見せていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "表形法はまた一種の【略記法】でもある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
