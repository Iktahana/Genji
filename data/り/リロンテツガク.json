        "examples": {
          "standard": [
            {
              "text": "彼は大学の哲学科に進学し、特にカントの理論哲学について深く研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その教授の講義は理論哲学の基礎から始まり、学生たちの知的好奇心を大いに刺激した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "倫理学や美学といった実践哲学と対比される形で、理論哲学の重要性が見直されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "哲学に理論哲学あり、実際哲学あり、政教は実際哲学に属す。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論哲学の目的は真理を発見するにあるをもって、人外に道を講究せざるべからず。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "形而上哲学、心理学等は理論哲学なり、宗教学、教育学等は実際哲学なり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、余が内にありて理論哲学を講じ、外に出でて実際哲学を説くゆえんなり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
