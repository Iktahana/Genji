          "standard": [
            {
              "text": "この貯水槽には、最大で500立米の水を貯めることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "引越し業者に見積もりを頼んだら、荷物の量は約10立米だと言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "工事現場では、毎日大量のコンクリートが立米単位で運び込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そしたらガス会社から人が来まして、来月からガスを小さくして（火口を）、そして消費だかも一〇立米へらすことになり、金高にすると四円いくらのものが三円いくらであって、それを超すと翌月はガスをとめることもあるということになりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
