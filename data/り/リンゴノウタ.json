        "examples": {
          "standard": [
            {
              "text": "戦後の焼け野原を復興に向けて歩み出した日本において、「リンゴの唄」は人々の心を明るく照らす希望の歌だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖母は昔を懐かしむように、ラジオから流れてくる「リンゴの唄」に合わせて小さく口ずさんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "慰問コンサートで歌手が「リンゴの唄」を披露すると、会場のお年寄りたちは手拍子をして喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "リンゴの唄や、雨のブルース、それから歌つてはいけない軍歌、峰子の歌ふ唱歌。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "定子は、いま、ひといきで涙のあふれるところだつたので吻つとして小声でリンゴの唄をくちずさむ。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
