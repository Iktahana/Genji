        "examples": {
          "standard": [
            {
              "text": "子供たちがリビングでタオルケットを連結させて電車ごっこをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "幼稚園の運動会で、みんなで手をつないで電車ごっこをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、みんなで電車ごっこを始めよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "或はもう少しおとなしい子供らしく静かに電車ごっこでもする。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の涼しい時刻には庭の青桐や栴檀の樹のあたりで、電車ごっこや木登りをして遊ぶのであるが、日中は家の中で、少女たちばかりの時は飯事をし、ペータアやフリッツが加わる時は戦争ごっこをする。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
