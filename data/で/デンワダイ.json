        "examples": {
          "standard": [
            {
              "text": "リビングの片隅に置かれた電話台の上には、いつも花が飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い木製の電話台は、アンティーク家具としても人気が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "狭い玄関なので、スリムなデザインの電話台を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "左腕を電話台に託したまま、耳を傾けていた。",
