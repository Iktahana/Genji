        "examples": {
          "standard": [
            {
              "text": "授業中に突然電話がかかってきて、慌てて席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滅多に連絡してこない父から電話がかかってきて、少し驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外から電話がかかってくるのは、いつも夜中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カバレット銀座の情婦、無智な妖婦から電話がかかってくる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金瓶楼主が、きっと多勢｜引率して芝居にくるだろうと、お絹は思っていたので、電話がかかってくると、飛んでいって受話機を取った。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、一週間がすぎさった、ある日のこと、警視庁から電話がかかってくると、にわかに、明智の顔が、はれやかになりました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
