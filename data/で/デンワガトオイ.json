    "definitions": [
      {
        "index": 1,
        "gloss": "having a bad connection (phone call)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
