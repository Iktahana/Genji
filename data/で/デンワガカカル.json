        "examples": {
          "standard": [
            {
              "text": "大事な話の最中に、突然彼に電話がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もしもし、今大丈夫？」「ああ、ちょうど電話がかかってきたところだったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電話がかかってきて、取引先からの緊急連絡だと分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "間もなく煙草專賣局の本所工場觀覽招待に同行を約した内田誠君から、久保田夫人告別式の歸途自動車事故で足に負傷したのでお伴出來ぬと斷りの電話が掛かる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話が掛かることを承知していながら、わざと「女の子」と出てしまうなんて、ばかにされたような気がした。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
