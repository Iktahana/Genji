        "examples": {
          "standard": [
            {
              "text": "新聞の電子版を購読すれば、どこでも最新ニュースが読める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この雑誌は、紙の他に電子版も発行されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、この本の電子版はありますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "せめて紙よりも製作コストが下がった分を定価に反映させてくれれば、電子版の普及にいっそう拍車がかかることは間違いありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パームトップを作った連中は、具体的にはこれをシステム手帳の電子版と想定した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしここでも述べているとおり、ビジネス手帳の電子版という商品設計には全く興味がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者が拡張本に寄せた序文によれば、この電子版こそがオリジナルのスタイルにもっとも近い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
