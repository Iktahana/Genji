        "examples": {
          "standard": [
            {
              "text": "トースターの内部には、パンを焼くための電熱線がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "電熱線が切れてしまったので、ストーブが使えなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "床暖房には、見えないところに電熱線が埋め込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それまでの電熱線に比べて高熱に耐えて錆びもせず、加工しやすいというこの素材を利用し、照明から熱供給ビジネスへの拡大を図ろうと考えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じりじりと電熱線は身ぶるいをはじめ、燻げくさい熱が久振りに人間の膚を慕って、匐いよってきた。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
