        "examples": {
          "standard": [
            {
              "text": "インターネットの普及により、データ通信の需要は飛躍的に増大した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スマートフォンで動画を見るのは、大量のデータ通信を伴う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害時でも途絶えないよう、強固なデータ通信インフラの構築が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして浜田の下に、データ通信の端末装置担当セクションで浜田と同じ釜の飯を食ってきた戸坂馨が設計主任としてついた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸坂の配属されたデータ通信の端末装置担当セクションで、先輩の浜田は当時新しいタイプの技術に取り組み、その可能性に確信を持つにいたっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
