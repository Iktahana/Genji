        "examples": {
          "standard": [
            {
              "text": "高野山で伝法灌頂を受け、僧侶としての道を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝法灌頂は、真言密教における重要な儀式の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "師から伝法灌頂を授かることは、最大の栄誉とされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "法皇は、山門を刺激しても無駄だからと、三井寺での御灌頂は一応お取やめになったが、元々そのおつもりであったから、四天王寺へお出でになり、五智光院を建立、亀井の水を五瓶の智水として伝法灌頂をお遂げになったのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
