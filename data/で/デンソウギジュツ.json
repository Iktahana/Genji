          "standard": [
            {
              "text": "5Gの導入により、伝送技術はさらなる高速化を実現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映像のリアルタイム伝送技術は、遠隔医療の発展に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は最新の伝送技術を研究し、論文を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "配属された伝送技術課では、のちに会長となる大内淳義が、音声をパルスに載せて送る技術に取り組んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝送技術部に新設された電子計算機係に配属となり、ＳＥＮＡＣのプロジェクトに加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて日本電気がコンピューターに手を染めるきっかけを作った渡部和は、東北大学にＳＥＮＡＣを納めてから本業の伝送技術に戻り、その後は中央研究所で通信とコンピューター部門の管理にあたっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
