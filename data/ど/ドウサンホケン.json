        "examples": {
          "standard": [
            {
              "text": "引っ越しをする際、家具や家電を守るために動産保険に加入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外旅行中の盗難に備え、動産保険に入っておくことを勧める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は、高価な機材に対して動産保険をかけている場合が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "借家だときいて一時に索然とした表情になったが、思い直して動産保険をすすめた。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高輪の時は附近の人に質すと確に半焼けであるにも係わらず、保険会社では動産保険の全額を支払っていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一）　書籍は金に代えることの出来ないものですが、ともかく動産保険にかけ、その幾割かをかえす空襲保険をかけました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
