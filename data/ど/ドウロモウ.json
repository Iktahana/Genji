        "examples": {
          "standard": [
            {
              "text": "高速道路の開通により、全国の道路網がさらに充実した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震で寸断された道路網の復旧が急ピッチで進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の道路網は、物流の要となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ最後の王朝時代に政府が思ひ切つた苛斂誅求をして全國に完全な道路網を張つたといふのだから、おかげでわれわれまで助かるといふものである。",
              "citation": {
                "source": "聖ロヨラ",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしサンホセ盆地の錯綜する道路網を、地理不案内のため方角を間違うこともあり得る。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路網は駅亭と共に全国に行き亘っている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
