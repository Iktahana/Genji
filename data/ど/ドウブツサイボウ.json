        "examples": {
          "standard": [
            {
              "text": "「動物細胞」は、植物細胞とは異なり、細胞壁を持たない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「動物細胞」の培養には、特定の栄養素と温度管理が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この研究では、動物細胞の分化メカニズムを詳しく調べている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで動物細胞はまだ発見されていないことを忘れてはいけない。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十年後になって動物細胞が発見され当然のこととしてさらに進歩してウィルヒョウの細胞病理学が生まれた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物細胞の発見であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や動物細胞が発見されたので病気の基本的な現象を科学的に研究することが遂に可能になった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
