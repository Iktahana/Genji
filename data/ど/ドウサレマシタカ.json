        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの、お客様、顔色が悪いようですが、どうされましたか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議中に沈黙が続いたので、「皆さん、どうされましたか？何か問題でも？」と問いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペットが元気がないので、「どうされましたか？どこか具合が悪いのでしょうか」と心配になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
