        "examples": {
          "standard": [
            {
              "text": "困難を乗り越える中で、彼らの間に強い同志愛が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同じ目標を持つ仲間との間には、特別な同志愛がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スポーツチームのメンバーは、互いに同志愛を感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子は子同志愛し合うでござろうよ」　しかしこの言葉は早速には弾正太夫には解らなかった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアの強固な連帯性――根強い同志愛――というものに身を以ってぶつかる様になってから――今まで個人的な気持にのみ終始していた自分がつくづく情なくなった。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
