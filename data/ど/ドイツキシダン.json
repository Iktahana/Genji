        "examples": {
          "standard": [
            {
              "text": "ドイツ騎士団は中世ヨーロッパに存在した、ドイツ人の騎士修道会だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バルト海沿岸の征服活動で知られるドイツ騎士団の歴史を調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドイツ騎士団の城跡は、今も多くの観光客を惹きつけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "相手は国境で勤務を共にしたことのある男で、ヘルマン・フォン・シュタルケンファウストといい、ドイツ騎士団のなかでもっとも勇猛で立派な勇士の一人で、ちょうど軍隊から還るところだった。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの熱狂的な悲観主義、勇壮な生活の熱望、戦いと犠牲とにたいする熱烈な信念は、ドイツ騎士団や日本のサムライなどの軍隊的宗教的理想と同じであるかの観があった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
