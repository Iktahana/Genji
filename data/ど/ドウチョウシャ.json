        "examples": {
          "standard": [
            {
              "text": "彼の政治思想には多くの同調者がおり、大きなムーブメントを生み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "反対意見を持つ者がいる一方で、彼の改革案には熱心な同調者もいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動の初期段階では、同調者を増やすことが最も重要な課題だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "少くとも党の同調者だ。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分だけでいい気持になって、描いているうちに、だんだん同調者が出て来た。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクシスト、共産党員、共産党同調者などのほとんど全部がそうだと思います。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下院ではヘイズ議員と同調者の必死の抗議に対して、陸軍大臣が干渉せずと冷静に判断した。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
