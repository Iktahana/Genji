        "examples": {
          "standard": [
            {
              "text": "彼女はドイツ語圏の国々を旅行する計画を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドイツ語圏の文化は多様で興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は仕事でドイツ語圏へ頻繁に出張している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ドイツ語圏で、ボヘミアにありカールスバートのほど近くだ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンは独立した眼科臨床を最初に設けたドイツ語圏の大学であり1812年のことであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ドイツ語圏医学に特有なものとなり豊かな結果を生むことになった研究の専門化がウィーンで始まった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現在におけるもっとも重要な必要性によって駆り立てられ臨床医学に役立つと思われる研究分野としての病理解剖学に私は身を捧げドイツ語圏において病理解剖学が病態生理学の真の基礎として医学分野における自然研究の基礎的方法として記載できるほど重要になるようにした」と。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖学的概念すなわち科学医学はこれまでドイツ語圏には存在しなかった里子に出す場所をウィーンに見出した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
