        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "企業の不祥事に対して、法的な責任だけでなく、社会に対する道義的責任も問われるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている人を見過ごせないのは、人間としての道義的責任だと彼は考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家には、国民の信頼に応える道義的責任がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで正隆は、何の道義的責任を負わされることもなければ、不安を感じさせられることもなかった。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主的な検事局というならば、あらゆる場合、基本的な人権の劬り、事件関係に対する社会の現実に立ったリアルな科学的洞察、真の道義的責任のありどころを明確にすることがのぞまれて当然である。",
              "citation": {
                "source": "石を投ぐるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる立場に立った総理でありますならば、その道義的責任を感じて辞職するのが当然であるといわなければなりません。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万遍の道義の理屈よりも、総理みずから道義的責任を感じて退陣されることが道義昂揚の最上の方法であるといわなければなりません。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
