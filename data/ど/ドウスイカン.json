        "examples": {
          "standard": [
            {
              "text": "地下に埋められた導水管が、各家庭に水を供給している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "老朽化した導水管の交換工事が、来月から始まる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水道工事現場では、巨大な導水管が運び込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "石を大きく四角に積み上げたものの上に、これも大きな木造の水槽があり、その側面に開いている穴から出る水流が竹の導水管に流れ込むこと、図667に示す如くである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの導水管は、村の各家に達する地下の竹管に連っている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
