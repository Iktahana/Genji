        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "着物の胴締めは、帯をしっかりと固定する役割がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父は古い胴締めを大切に保管している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この剣道の胴締めは、熟練の職人によって手作りされたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
