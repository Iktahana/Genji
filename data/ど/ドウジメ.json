    "definitions": [
      {
        "index": 1,
        "gloss": "scissors maneuver (in wrestling, judo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "柔道の試合で、彼は相手に胴締めを仕掛けたが、すぐに逃れられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レスリングの練習で、胴締めの体勢から脱出する練習をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は強力な胴締め技で、対戦相手をギブアップさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は胴締めをされたような「胸苦しさ」を感じた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは下脚部が太くて、柔道の時胴締めが強く効くのと、平和なようで案外獰猛だという意味合いであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのルナ・アミーバーは、兄さんを胴締めにしていた奴です。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "威張れば威張る程別れられないし、ワカレルワカレルといっても、胴締めはワカレルという言葉のたびに、勁く締めつけられるのである。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと風入れて、「爽やかになった」　と、鎧の胴締めを締め直して、座所へ移ると、そこの山芝のうえには、豹の毛皮をしき、陣中の調度の物なども置かれて、飽くまで彼のいるところには豪奢の光がつき纒っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
