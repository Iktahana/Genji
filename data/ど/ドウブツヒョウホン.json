        "examples": {
          "standard": [
            {
              "text": "博物館には、様々な種類の昆虫の動物標本が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究室には、貴重な動物標本が厳重に保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物標本を作成することで、生物の形態学的特徴を詳細に観察できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "びん入りの動物標本などで見受けるように、小動物の肉体に特殊な液体を滲透させて、その液中に置けば、ある度までは透き通って見える。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ動物は手がけたことはないが、鼬が首尾よく斃されたら、それを手はぢめに動物標本にすゝまうかなどゝ私は期待して窓下の流れの“chatter, chatter”に耳を傾けるだけだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗さんは、剥製の動物標本を見たことなくって？",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「科学博物館の動物標本室にこんなのがあったっけ。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
