        "examples": {
          "standard": [
            {
              "text": "締め切りに間に合うか不安で、どうにかなりそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "騒音で頭が痛くて、どうにかなりそうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑すぎて、このままだとどうにかなりそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「なるほど、そう一々お砂糖をお嘗めならなくとも、どうにかなりそうなものですね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、頭もどうにかなりそうだったわ。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださらけだしてしまったらどうにかなりそうだった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がまん強いカキだってどうにかなりそうよ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿母さんだって、どうにかなりそうなものだのにねえ」　やがて、ふさ子は、重苦しい四辺の雰囲気の裡で、投げ捨てるように呟いた。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "分らなければ分らないほど、私は何かありそうに、どうにかなりそうに思わずにはいられなかったのである。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
