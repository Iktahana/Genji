[
  {
    "uuid": "fbfcb7b6-689e-5979-892a-201cf082c7d1",
    "entry": "胴突き",
    "reading": {
      "primary": "どうづき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ramming",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁師は胴突き仕掛けで海底の魚を狙う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "船が暗礁に乗り上げ、激しい胴突きに襲われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "杭を打つ際には、胴突き作業でしっかりと地面に固定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此で以て地面をどん／＼と、胴突きして廻つたのである。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、先ずこれならばと思うものが揃うと、今度は彼が先棒となって、泥運びもすれば胴突きの繩も引張る。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの扇や足の遣ひ方に、たゝら・棒づき――どうづき――或は堂供養の要素が濃厚に見られる様な気がしたのである。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "木やり・石挽き・たゝら唄・どうづき唄。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
