        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "材木を胴付きで組み合わせることで、強固な構造を作り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は胴付きの技術を駆使して、美しい家具を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このテーブルの脚は、胴付きで天板に固定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "saw with a spine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
