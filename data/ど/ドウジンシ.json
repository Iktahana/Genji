        "examples": {
          "standard": [
            {
              "text": "彼女はコミックマーケットで、自作の同人誌を販売した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの有名な漫画家も、最初は同人誌からキャリアをスタートさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同人誌の世界は、プロとアマチュアの垣根を越えた表現の場だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "同人誌や機関誌、パンフレットなど、活版で刷ると高くつく少部数の印刷物が、育ってきた高い技術に支えられて謄写版で作られるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊編注――大正十五年九月、家庭内同人誌『沈丁花』一号掲載散文詩饗宴　乾いた星を鏤めて夜空はぴつたりと地上に被さつてゐる。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校のころ仲間とつくった同人誌を綴じてから不揃いな天地などを整えるために使ったものだ。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
