        "examples": {
          "standard": [
            {
              "text": "古代エジプトでは、特定の動物崇拝が盛んで、猫などが神聖視された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自然崇拝の一環として、特定の動物崇拝が世界各地で見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らの部族は、鷲を神聖な存在とし、動物崇拝の対象としている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "由って虎を霊視するの極、本来動物崇拝を峻拒する回教徒中にあっても、かつて上帝が虎と現じて回祖と談じたと信ずる輩すらある（『太平広記』二九二。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大英百科全書』十一板二巻動物崇拝の条に、インドで猴神ハヌマンもっとも著わる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大英百科全書』十一板二巻動物崇拝の条にも挙げていない。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい話ながら動物崇拝など大抵こんな事で、金色の鼠王なども当時の中央アジア人に取っては、わが国王こそ毘沙門の正統で、現にその使物が生身でわれわれの供物を納受しましますという信念を堅め、中央アジアの文化を高むるに大いに力あった事と惟う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
