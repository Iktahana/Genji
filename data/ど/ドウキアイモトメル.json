        "examples": {
          "standard": [
            {
              "text": "彼女は同じ志を持つ仲間と同気相求めるように、新しいプロジェクトを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同じ目標を持つ者同士、お互いに同気相求めることで、より大きな力を生み出すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "似たような境遇の人が集まるのは、同気相求める心理が働くからだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "晩年大河内子爵のお伴をして俗に柘植黙で通ってる千家の茶人と、同気相求める三人の変物｜揃いで東海道を膝栗毛の気散じな旅をした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上一切が灰燼になったら同気相求める人達と一緒に旅芸人の一団でも組織して、全国を巡業してまわるのも一興だなどと真実考えに耽ってもみたりした。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
