        "examples": {
          "standard": [
            {
              "text": "患者が同意能力を欠くと判断された場合、家族の同意が必要となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもたちの同意能力は、年齢や発達段階によって異なると考えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "裁判所は、契約を締結する上での当事者の同意能力を厳しく審査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "テーテンスが精神能力として「感情」、「悟性」、「活動力（意志）」と名づけたのが最初で、メンデルスゾーンは、これを「認識能力」、「感覚」あるいは「同意能力（快不快の感情）」「意欲能力」として分けている。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
