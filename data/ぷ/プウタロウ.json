        "examples": {
          "standard": [
            {
              "text": "大学を卒業してから定職に就かず、しばらくの間プー太郎としてぶらぶら過ごしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつまでもプー太郎をやってないで、少しは仕事を探したらどうだ」と父親に小言を言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はプー太郎という立場を逆手に取り、自分の本当にやりたいことを見つけるための充電期間に充てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
