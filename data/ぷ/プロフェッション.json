        "examples": {
          "standard": [
            {
              "text": "弁護士や医師のような高度な専門知識と倫理観を要する職業は、古くから単なる労働とは区別してプロフェッションと呼ばれてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女はジャーナリズムというプロフェッションに強い使命感を抱き、自ら志願して危険な紛争地帯への取材に向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "社会への奉仕という側面を強く持ち、自律的な団体によって品質が保証されているのがプロフェッションの大きな特徴である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すべてのいわゆるプロフェッションはそうした環境をわれわれに供給する。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしにはいつもプロフェッションがあとからついて来た。",
              "citation": {
                "source": "感情の動き",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
