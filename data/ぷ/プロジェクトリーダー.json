        "examples": {
          "standard": [
            {
              "text": "彼は持ち前のカリスマ性と決断力で、個性豊かなメンバーをまとめ上げる頼もしいプロジェクトリーダーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロジェクトリーダーの突然の休職により、チームは一時的にパニックに陥ったが、サブリーダーが機転を利かせて窮地を脱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "若手社員を育成するため、比較的小規模な案件であえて彼をプロジェクトリーダーに指名し、責任あるポジションを経験させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一九八〇年の夏、スティーブン・ジョブズは社内の抗争によって、全力で取り組んできたリサのプロジェクトリーダーの地位を追われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロジェクトリーダーを襲ったＰＣ―９８０１失速の恐怖　いったんニューヨークまで飛んで乗りかえた成田を目指す帰りの飛行機の座席で、浜田は『ＣＰ／Ｍ入門』に読みふけっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
