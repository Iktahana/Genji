        "examples": {
          "standard": [
            {
              "text": "太陽の表面を特殊なフィルターを通して観察すると、黒点の周辺に明るく輝くプラージュが見えます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "今回の太陽フレアの発生源は、巨大なプラージュが形成されている活動領域のようです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彩層の活動を研究するため、天文台の望遠鏡で毎日プラージュの面積の変化を記録している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これをレセンプラージュと言っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "レセンプラージュの季節がすむと、もうお父さんは外へ出ようとも思わない。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
