        "examples": {
          "standard": [
            {
              "text": "リバウンド争いで相手選手を背後から押してしまい、プッシングのファウルを取られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "サッカーの試合中、ペナルティエリア内でのプッシングにより相手にPKを与えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "審判が笛を吹き、両手を前に突き出すジェスチャーでプッシングの反則を宣告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その下に、六本のいかめしいプッシング碍子の台の上にのっていたガラスの箱は、碍子を残しただけで、あとかたもない。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うならフランクリンの自伝だとかプッシング、ツー、ゼ、フロントだとか、おれでも知ってる名を使うがいい。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
