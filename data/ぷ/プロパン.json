        "examples": {
          "standard": [
            {
              "text": "「今週末のキャンプに向けて、ツーバーナー用のプロパンガスボンベを二本買い足しておこう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都市ガスが通っていない地域では、家の裏に設置されたプロパンガスのボンベがキッチンやお風呂の熱源を支えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロパンは燃焼時の二酸化炭素排出量が少なく、クリーンで持ち運びが容易なエネルギー資源として重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "電気は自家用発電機、暖房と炊事はプロパンガス、水は雨水を使う。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いと神経痛が痛む上に、心臓の発作もおこり易く、病室のスチームは頼りにならないので、電気やプロパンガスのストーブを二つも三つも持ち込んでいる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
