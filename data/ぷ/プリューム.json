        "examples": {
          "standard": [
            {
              "text": "地球の深部から上昇してくる高温のマントルの柱は、マントルプリュームと呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ハワイ諸島は、固定されたホットスポットから湧き上がるプリュームによって形成されたと考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ロケットのエンジンから激しく噴き出す白煙のプリュームが、青空にくっきりと軌跡を描いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人間はプリューム（羽毛――ペン）のない二本足だと言ったばか者がいる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
