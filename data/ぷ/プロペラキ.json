        "examples": {
          "standard": [
            {
              "text": "大型ジェット機に比べるとスピードは遅いが、離島へ向かう小さなプロペラ機の窓から見下ろす青い海の景色は格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "地方空港の滑走路で、ブーンという独特のエンジン音を響かせながら双発のプロペラ機が離陸の準備をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "台風接近による悪天候のため、私たちが乗る予定だったプロペラ機の便はあえなく欠航となってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大きなプロペラ機に特有の、自分の重さをもてあましたような表情を機体ぜんたいに漂わせ、飛行艇は海に向かった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
