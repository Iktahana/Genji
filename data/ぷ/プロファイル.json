        "examples": {
          "standard": [
            {
              "text": "OSのクリーンインストールが終わった後、外付けHDDにバックアップしておいたユーザープロファイルを復元した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "BluetoothのワイヤレスイヤホンをPCに接続して音楽を聴くには、A2DPというプロファイルに対応している必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "セキュリティソフトが、不審な動作をするアプリケーションを新しいプロファイルとして自動的に隔離した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "嘗て　わたしの歓に於て無二であった人今はこの寂寥を生む無二の人貴方は何処の雲間に見なれたプロファイルを浮べて居ますか。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "測量の簡素化を狙って開発され、プロファイルトレーサーと名付けられたこの装置の外見は、手押し式の二輪車である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "左向きのプロファイルだ。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
