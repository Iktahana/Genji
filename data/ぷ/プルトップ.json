        "examples": {
          "standard": [
            {
              "text": "最近の缶詰はほとんどがプルトップ式だから、缶切りを探す手間が省けて助かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プルトップのリングに指をかけて勢いよく引っ張ったら、中身のスープが少し跳ねてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "爪を痛めないように、スプーンの柄を使ってシーチキン缶のプルトップを開けたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "看護婦さんが持ってきてくれた氷枕に頭を沈めてから、二本目のカンのプルトップを開けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはプルトップ缶だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと二時間半もあるぞ」　どうしてプルトップにしないんだ、と文句をいいながら、慶一から受けとったコーヒーに缶切りで口をあけ、ひと口飲むと、躰を回転させ、仰向けになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はなにもいわず、プルトップを抜いて、泡立つのも意に介さず、背の高いグラスにビールを注ぎこんでいく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
