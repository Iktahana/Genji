        "examples": {
          "standard": [
            {
              "text": "その世界的企業は、アジア市場においても圧倒的なプレゼンス（存在感）を示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は部屋に入ってきただけで周囲の空気を変えてしまうほどの、強いプレゼンスを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「我が社のプレゼンスをさらに高めるためには、SNSを活用したプロモーションが不可欠だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ギョッとするようなプレゼンスがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯浅さんの持って居るような一種のプレゼンス of mind があってよい心持だ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く人それぞれがレコードによってつくりあげたその音のイメージに勝つためには、歌手は、エルヴィス・プレスリーやリトル・リチャードのような、すさまじいステージ・プレゼンスを持っていなければならなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
