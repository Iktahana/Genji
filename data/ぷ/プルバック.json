        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "トランザクション処理中にエラーが発生したため、データベースの状態をプルバックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "作業の途中で不具合が見つかったので、システムを昨日のバックアップ時点までプルバックさせる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "設定変更が原因でネットワークがダウンしたため、急遽元の構成へのプルバック作業が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
