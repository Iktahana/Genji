        "examples": {
          "standard": [
            {
              "text": "開発のプログレスを週次ミーティングで報告したところ、スケジュールの遅れを厳しく指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "画面のプログレスバーが一向に進まず、担当者はインストールが止まってしまったのではないかと焦りを感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しい治療法によって、患者の病状の回復に著しいプログレスが見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ピルグリムス・プログレスは、日本でも訳して天路歴程と云ふが、これはこの本に学んだのであらう。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱心な信仰家の持つ謙遜な忍耐、あのピルグリム・プログレスの巡礼の持つ隠忍にして撓まぬ努力の精神、それに私は感服する。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現代は長足の進歩、今のことばでいうと、プログレスを遂げておりますよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
