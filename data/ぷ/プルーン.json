        "examples": {
          "standard": [
            {
              "text": "貧血気味の娘のために、鉄分が豊富に含まれているドライプルーンを毎日のおやつに出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ヨーグルトに刻んだプルーンとクルミを混ぜて食べると、食感も良くて健康的な朝食になるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スーパーで生のプルーンを見かけたので、少し多めに買って自家製のジャムを作ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "イレクトリック・プルーンズの〈アイ・ハド・トゥー・マッチ・トゥ・ドリーム（・ラスト・ナイト）〉だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽は勉強の邪魔にはならない――たとえ、プルーンズみたいな、とほうもないサウンドでも。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
