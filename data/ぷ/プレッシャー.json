        "examples": {
          "standard": [
            {
              "text": "大事なプレゼンを任されてしまい、今から胃が痛くなるほどのプレッシャーを感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はプレッシャーに強いタイプで、本番の舞台でも普段以上の実力を発揮した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "周りからの期待が大きすぎて、かえってそれが彼女へのプレッシャーになっているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はピーボディ他五名と共に――大きなプレッシャー・リッジを乗り越える際橇が転覆し、二頭の犬を失うという汚点はあったものの――一月十一日から十八日にかけて予備的な橇行とボーリングを行い、始生代の粘板岩をどんどん掘り起こした。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真１：アドミラルティ山脈のハーシェル山写真２：エレバス山とプレッシャー・リッジ（手前の盛り上がり）写真３：ニコライ・レーリッヒ「チベット・ヒマラヤ」Тибет. Гималаи、一九三三年写真４：ロス島を臨む。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
