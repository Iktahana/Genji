        "examples": {
          "standard": [
            {
              "text": "乾杯のシャンパンの代わりに、よく冷えたイタリア産のプロセッコを用意しておきました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "休日のランチは、軽やかな口当たりのプロセッコを飲みながらテラス席でパスタを楽しむのがお気に入りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スーパーのワイン売り場で、手頃な価格帯のプロセッコを数本まとめ買いしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
