        "examples": {
          "standard": [
            {
              "text": "「ほら、あそこに見えるのがプレアデスだよ。日本では『すばる』って呼ぶんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の夜空に輝くプレアデスは、肉眼でもいくつかの星が集まっているのが見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天体望遠鏡を向けると、青白く輝くプレアデスの美しい姿がくっきりと現れた。",
              "citation": {
                "source": "幻辭AI",
