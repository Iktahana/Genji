        "examples": {
          "standard": [
            {
              "text": "大学の歴史の授業で、コミンテルンと連携して活動していた労働組合の国際組織であるプロフィンテルンについて学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "戦前の労働運動の歴史を紐解くと、プロフィンテルンの方針が日本の活動家たちにも大きな影響を与えていたことがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "図書館の地下書庫で、プロフィンテルンの設立趣意書が翻訳された、古いガリ版刷りの貴重な資料を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夜玉子、バタ　○プロフィンテルン閉会。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルにはプロフィンテルンの代表者が一杯泊り込んでいる。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
