        "examples": {
          "standard": [
            {
              "text": "雷は自然界におけるプラズマ現象の代表的な例の一つです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "核融合発電を実現するためには、超高温のプラズマを磁場によって長時間閉じ込める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この装置はプラズマを利用して金属の表面を精密に加工することができます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一九六七年の夏、フレックスに関する報告を行うためにイリノイ大学で開かれた会議に出たケイは、ここで初めてプラズマ方式を用いて作った平面型のディスプレイを見た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは血漿交換法（プラズマフェレシス）によって失われた血漿タンパク質が急速に補給されるのは血液タンパク質と組織タンパク質が動的平衡状態であることによると考えている。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "100年前シェプレーはヴァン・マンダプーツをおぼろげに予想しており、当時の発表で、宇宙プラズマが大きな母体であり、中に時間と空間と宇宙が内包されていると言った。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェイン・ハリソン女史はこれを「あの霊的なプロトプラズマ」と呼んでいる。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
