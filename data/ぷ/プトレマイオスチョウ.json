        "examples": {
          "standard": [
            {
              "text": "クレオパトラはプトレマイオス朝エジプトの最後の女王として、波乱万丈な生涯を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ナイル川流域を支配したプトレマイオス朝は、ヘレニズム文化とエジプト文化を見事に融合させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "博物館で開催された特別展で、プトレマイオス朝時代に作られた精巧な装飾品を間近に見ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我々の見解と対照的に兄と妹のあいだの結婚は推奨され、王室では盛んに行われた（プトレマイオス朝まで）。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア人のエジプト王たちであるプトレマイオス朝の首都であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "プトレマイオス朝の王たちは気前よく物質的な心配無しに彼らに仕事を行わせた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
