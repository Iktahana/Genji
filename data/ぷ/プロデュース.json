        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この映画のプロデュースには多額の予算が投じられており、衣装や美術にも一切の妥協がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "音楽プロデュースの仕事は単に曲を作るだけでなく、アーティストのブランディング全般を担う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のプロデュースによって、これまで無名だった地元の特産品が全国的なヒット商品へと成長した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
