        "examples": {
          "standard": [
            {
              "text": "彼は昼間は建設現場で働きながら、夜はボクシングジムで汗を流してプロボクサーを目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロボクサーとしてリングに上がるには、ライセンスを取得するための厳しいプロテストに合格しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "見事世界チャンピオンになったそのプロボクサーの左ジャブは、素人の目には全く見えないほどの速さだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いわゆるプロボクサーそっくりだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層階級のミュージックホールや、踊り子や、プロボクサー等を抱えています。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロボクサーがやる特殊な心臓パンチだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
