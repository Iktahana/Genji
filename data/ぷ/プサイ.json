        "examples": {
          "standard": [
            {
              "text": "量子力学の教科書では、波動関数をギリシャ文字のプサイで表すのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "教授は黒板に大きなΨの記号を書き、シュレーディンガー方程式の解説を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "心理学を意味する英語の頭文字から、プサイの記号が心理学のシンボルとして使われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "林は火曜日の午後五時、所用を帯びて銀行へいった帰途、チープサイドの喫茶店でお茶を飲んでいると、衝立の蔭にエリスともう一人見知らぬ男が席を占めているのを見た。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十一時、かかる注意にも拘らずチープサイドのある屋根が火を発した。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "チープサイドに象の印を掲げたジェイムス・グリーン商店、グレート・ブリッジの向かいに金の鷲を掲げたラッセル商店、あるいはニュー・コーヒーハウスのそばにフライパンと魚の看板を掲げたクラーク・アンド・ナイチンゲール商店といった小売商は、商品をほとんど完全に彼に頼っていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "意を決したようにテレフォン紙を脇に置き、支店を出て向かった先は一連の建屋、狭いチープサイド通りにある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、二人はチープサイドに来た。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一五九〇年チープサイドで出版され、見事なひげ文字で印刷されています。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
