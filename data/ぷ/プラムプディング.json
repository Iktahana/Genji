        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イギリスのクリスマスディナーの締めくくりには、火をつけたプラムプディングが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "初めて食べたプラムプディングは、スパイスとドライフルーツの香りが強烈で驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古いレシピ本を見ながら、一ヶ月前から仕込んでプラムプディングを作ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "よっかめの　りすたちの　おみやげは　まるまるした　カブトムシ　６ぴきで、　ぬしさまからすれば　プラムプディングに　はいってる　プラムみたいな　ものなのです。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊肉は頭もモモも取り下げられ、大きなプラムプディングが運ばれてくる。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "デザートには、プラムプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラムプディングと冷コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラダが出て、デザート、クリスマスプディングと言って出したのは、つまりプラムプディングだが、ソースはいゝが、苦くていけない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
