    "definitions": [
      {
        "index": 1,
        "gloss": "puffing (e.g. cigarette smoke)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
