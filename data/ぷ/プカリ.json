        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "湖の真ん中で、赤い浮き輪がぽつんとぷかりと浮かんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お風呂の底からおもちゃのアヒルがぷかりと顔を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "海面を漂う流木が、波に合わせてぷかりぷかりと揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
