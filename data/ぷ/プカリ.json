        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "縁側に座った祖父は、満足げに煙草をぷかりと吹かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は深く息を吸い込むと、紫色の煙をぷかりと空に向かって吐き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "焚き火の煙が、風のない夜空にぷかりぷかりと立ち昇っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "青くぬった、木の足のおかげで、ぷかり、ぷかりと、波のまにまに、浮んでいたのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどに茂作は、煙草が大好物で朝から晩まで、一日中、ぷかり／＼と煙草を吸つてをりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらりと見ると、岸にのぞんだ大きな柳の陰に、だれを乗せてきたのか、だれを待っているのか、こざっぱりとした伝馬が一艘やはりつながれてあって、六十がらみの日にやけた船頭が、ぷかりぷかりとのどかになた豆ギセルから紫の煙を吐いているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうですか」　藤枝はこう云つてぷかりと煙を輪にふいた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてぷかりぷかりと夜長を吹かす。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分は真白なターバンをぐるぐる頭へ巻きつけて、広いヴェランダに据えつけてある籐椅子の上に寝そべりながら、強い香のハヴァナをぷかりぷかりと鷹揚に吹かす気でいた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと見つめていると真っ暗な闇のなかにしゃぼん玉のような五色の泡がいくつもぷかりぷかりと湧きあがってくるように思った。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん長くたってから立ち上ると、両腕を伸したり曲げたり、体操のまねみたいなことをやり、二三度でぐったりして、また湯にはいり、頸筋を湯壺のふちにもたせて、仰向にぷかりと、死人のように浮いていました。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな腹がぷかりぷかりと水に揺られて、向うへ流れて行った。",
              "citation": {
                "source": "金魚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、夢のように、阻塞気球が、ぷかりぷかりと浮んでいた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでいつまで、ぷかりぷかり煙草ばかり喫んでけつかって……」「いま考えていっとこだ。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その土は一足一足毎にぷかり／＼と舞ひ立ち、むつとした草いきれと一緒に、脛から股から胸から顏へ匍ひ上り、たく／＼流れる汗へ飛びついて來る。",
              "citation": {
                "source": "旱天實景",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあひだの掘割に、机や小箱などが、ぷかりぷかり浮いてゐるのが物珍らしかつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷかりぷかりと煙が出た。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
