        "examples": {
          "standard": [
            {
              "text": "アインシュタインはアメリカに亡命した後、ニュージャージー州にあるプリンストン大学の高等研究所で研究を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アイビーリーグの名門であるプリンストン大学は、特に数学や物理学の分野で多くのノーベル賞受賞者を輩出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は猛勉強の末、世界中から優秀な学生が集まるプリンストン大学の大学院への入学を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アメリカでもプリンストン大学では、校内での運動を禁じた。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー生まれのユダヤ人数学者で、ヒットラーのドイツを逃れてプリンストン大学に移っていたジョン・フォン・ノイマンは、マンハッタン計画に貢献するとともに、コンピューターの基本原理の確立においても決定的な役割を演じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーベル賞の仕事たる有名な熱電子のリチャードソンの法式の基礎的研究は、プロフェッサーが亜米利加のプリンストン大学の物理の教授として赴任していた間に出来たもののように思われる。",
              "citation": {
                "source": "リチャードソン",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリンストン大学のシェリーに関する卒業論文が賞をえて出版されたので、それが刺※になって、作家をこころざすにいたったのだという。",
              "citation": {
                "source": "「ザイルの三人」訳者あとがき",
                "author": "妹尾韶夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの小原は、プリンストン大学卒業という触れこみで上品な英語をあやつるふしぎな男だった。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
