    },
    "definitions": [
      {
        "index": 1,
        "gloss": "jelly-like",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鍋に入れすぎたゼラチンが固まりきらず、全体がぷよぷよとした頼りないデザートになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "運動不足のせいか、お腹周りについたぷよぷよのお肉をつまんで彼は深くため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "水族館のタッチプールでクラゲに触ってみると、想像以上にぷよぷよしていて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女はリリーの冷めたく濡れた鼻のあたまと、へんにぷよぷよした蹠の肉とを胸の上に感じると、全く初めての出来事なので、奇妙のような、嬉しいような心地がして、真っ暗な中で手さぐりしながら頸のあたりを撫でてやった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子は悦子を遅刻させないために、早く手伝って立ててやろうと思ったけれども、そのぷよぷよした物に手を触れるのが何となく無気味だったので、足袋を穿いている足を上げて※の股に耳の先を挟んで摘み上げた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
