        "examples": {
          "standard": [
            {
              "text": "その部族が作る木彫りの仮面には、どこかプリミティブな生命力が宿っているように感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "最新のCG技術を使わずに、あえてプリミティブな表現にこだわったストップモーションアニメを作りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プログラミング言語において、整数や文字といった最も基本的なデータ型をプリミティブ型と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "赤や茶や黄や、緑や、其等の色は、「褪しゃ」を地にした此の辺の人間が着る着物のような、プリミティブな可愛らしい感じを与える。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し多くは素人として、刀の無器用な、使方不十分が反つて自然なプリミティブの感じを表はすので自刻して居る人もある。",
              "citation": {
                "source": "自刻木版画に就いて",
                "author": "岡本帰一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
