        "examples": {
          "standard": [
            {
              "text": "彼は自分の仕事に対して非常にプラウドであり、妥協を許さない姿勢で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "息子の卒業式に出席した両親は、立派に成長した彼の姿を見てプラウドな表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分たちの文化や歴史にプラウドを持つことは、アイデンティティを確立する上で重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "むしろ新年のウドンの方がふだんのウドンよりもまずいぐらいで、テンプラウドンやキツネウドンにくらべると大そう風味が悪いような特別な作り方のウドンを三※日間というもの三度々々我慢して食べてる。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来英人と云うものはプラウドな気風を帯びていて、紹介されない以上は、他に向って容易に口を利かない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから我々も英人に対しては同様にプラウドである。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ七代目樽金は振ってると思ってね……ええお待ちなさいよ羅馬の七代目の王様ですね、こうっとたしかには覚えていないがタークイン・ゼ・プラウドの事でしょう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
