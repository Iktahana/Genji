        "examples": {
          "standard": [
            {
              "text": "「プレーボール！さあ、全力でぶつかっていこうぜ！」と監督が円陣で叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "審判が「プレーボール！」と宣言すると同時に、第一投がキャッチャーミットに収まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「プレーボール！ようやくこの日が来たな」と、マウンドの投手は緊張を隠せず呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すでに一同集って、まさにプレーボール開始寸前。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            }
          ]
        }
