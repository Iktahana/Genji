        "examples": {
          "standard": [
            {
              "text": "カナダのブリティッシュコロンビア州は、英語で「プロビンス」と呼ばれる行政区画の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ヨーロッパの歴史を学ぶと、ローマ帝国のプロビンスが総督によってどのように統治されていたかが見えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "海外のショッピングサイトで住所を入力するとき、プロビンスの欄には都道府県名をローマ字で入力してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、この北の方へやって来た人間は、最初からして種がちがいました、掠奪と虐殺を目的としてやって来たのではなかったのです」　駒井が鞭で指し示したところは、今の北米のケープコッドの、プロビンス・タウンからプリモスのあたりであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
