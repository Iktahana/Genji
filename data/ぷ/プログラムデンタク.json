        "examples": {
          "standard": [
            {
              "text": "複雑な公式をあらかじめメモリに登録できるプログラム電卓は、土木工学の期末試験で必須のアイテムとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は昔買ったプログラム電卓を使って、ちょっとしたゲームを自作して暇つぶしをするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スマートフォンのアプリの方が便利だと分かっていても、物理キーの打鍵感が好きで未だにプログラム電卓を手放せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＨＰでまともな給料を取ってはいたものの、コンピューター用の部品とレコードに金をつぎ込んでいたウォズニアックは、持っていたプログラム電卓のＨＰ65を売り払って出資分を作り、ジョブズはフォルクスワーゲンを売った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
