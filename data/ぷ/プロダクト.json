        "examples": {
          "standard": [
            {
              "text": "ソフトウェア開発において、顧客の課題を解決する優れたプロダクトを作るためには綿密なユーザー調査が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は新興企業のCEOとして、全く新しいコンセプトのデジタルプロダクトを世界市場に向けて発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロダクトの品質を維持するため、リリース前には必ず専門チームによる厳しいテストが実施される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "のちに同大学の副学長を務めるブッシュは、ここでプロダクトインテグラフと名付けた積分の自動計算機を開発している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "セッションの冒頭に講演に立ったゼロックス、オフィスプロダクト部門のドナルド・マッサーロは、「これまでは自分で欲しいと思っている人にパーソナルコンピューターを売ってきたが、今後は、マシンを必要とはしていても必ずしも欲しいとは意識していない人に売っていかなければならない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あまりプロダクトはない。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
