        "examples": {
          "standard": [
            {
              "text": "災害の復旧工事に伴い、作業員たちが寝泊まりするためのプレハブの宿舎が建設された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しいオフィスビルが完成するまでの半年間、一時的に敷地内のプレハブで業務を行うことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プレハブとはいえ、最近のものは断熱性も高く、エアコンが効けばとても快適に過ごせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "プレハブ住宅もある。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷地の北側には、ふたつの和室の境目あたりに、金属プレハブの物置がひとつあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか知らないけど、九十九里にあいつの兄さんが、プレハブの別荘を買ったんだって。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちが泊まっていたプレハブの別荘は、中新田にあった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
