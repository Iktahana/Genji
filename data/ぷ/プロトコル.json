        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "火災が発生した際の避難プロトコルをチーム全員で再確認し、定期的な避難訓練を実施している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職場の安全を確保するため、有害物質を扱う際は定められた作業プロトコルを厳守してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "システム障害が発生した際の連絡プロトコルがまだ整備されておらず、対応に遅れが生じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
