          "standard": [
            {
              "text": "エクセルでのタスク管理に限界を感じ、クラウドベースのプロジェクト管理ツールを導入して進捗を見える化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大規模なシステム開発において、スケジュールの遅延や予算超過を防ぐための厳格なプロジェクト管理が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロジェクト管理の資格であるPMPを取得するため、終業後に専門学校へ通って勉強を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、ワードプロセッサーや表計算、グラフ、データベース、お絵かき、プロジェクト管理の六つのアプリケーションを標準で持っているとはいえ、本体価格だけで九九九五ドル、日本での販売価格二八二万円のリサはあまりに高価だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
