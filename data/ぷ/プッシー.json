        "examples": {
          "standard": [
            {
              "text": "庭に迷い込んできた可愛らしいプッシーに、ミルクを少し分けてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "童話に出てくる長靴をはいたプッシーのイラストが、この絵本の表紙になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は飼い猫のことを「私の愛しいプッシー」と呼んで、とても可愛がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コートに接続して、プッシー・パークと云うのがあります。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらの栗もプッシー・パークに劣らない大木で、この大きい葉のあいだから白い花がぼんやりと青い水の上に映って見えます。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
