        "examples": {
          "standard": [
            {
              "text": "プレゼン本番の5分前になってプロジェクターのランプが切れ、慌てて予備の機材を別のフロアまで走って取りに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ホームシアターを作るため、奮発して4K対応の高性能なプロジェクターと100インチのスクリーンを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昼間の明るい会議室でも文字がはっきり見えるよう、ルーメン数の高いプロジェクターを新しく導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私の眼は据えつけられた二つのプロジェクターのように、その死体に投げつけられて、動かなかった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイの表示は、ＮＡＳＡから借りた最新のビデオプロジェクターによって、縦横二〇フィートのスクリーンに投射された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の部屋のプロジェクターに、僕はフィルムをかけた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の照明を消し、僕はプロジェクターへ歩いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
