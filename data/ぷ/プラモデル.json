        "examples": {
          "standard": [
            {
              "text": "週末は部屋にこもって、新しい戦闘機のプラモデルの塗装に没頭していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "息子の誕生日プレゼントに、欲しがっていたガンダムのプラモデルを買ってあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ショーケースには、彼が子供の頃から作りためた車のプラモデルがずらりと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "プラモデルだって、自動的に潜水／浮上をくりかえす、サブマリン７０７のずんぐりしたモデルが最後だから、もう一年くらいなにも買っていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、ＴＫ―80を買い求めたアマチュアの多くは、胸をときめかせてプラモデルめいたキットを持ち帰り、目を輝かせてはんだごて片手に組み立て、それから絶望を味わって八万八五〇〇円のむだ遣いを悔いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、コルト・オートマのプラモデル買ってきてよ、ね？",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
