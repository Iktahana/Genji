        "examples": {
          "standard": [
            {
              "text": "唾液に含まれる消化酵素のプチアリンは、デンプンを麦芽糖などに分解する働きがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ご飯をよく噛むと甘く感じるのは、プチアリンの作用によって糖分が生み出されるからだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "生物学の実験で、温度の変化がプチアリンの酵素活性にどのような影響を与えるかを調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "唾液は水なり、ムチンの存在によつて粘きも、其実は弱アルカリ性の水にして、酵素のプチアリンを含めるのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此中プチアリンは消化作用の一助をなすに止まり、ムチンは蓋し外物の強烈の刺激を緩和する為に存せりと覚しく、味を解きて人に伝ふるものは、実に水の力なり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
