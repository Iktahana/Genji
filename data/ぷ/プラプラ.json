        "examples": {
          "standard": [
            {
              "text": "ランドセルの横にぶら下げた防犯ブザーが、走るたびにぷらぷらと揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "取れかけのボタンが一日中ぷらぷらしていて、気になって仕事に集中できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "赤ちゃんの足がベビーサークルからぷらぷらとはみ出しているのが可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "詩集はぷらぷらしましたがなかなかそれで落ちませんでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ赤な花がぷらぷらゆれて光っています。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼砥の上で金鋼砂がじゃりじゃり云いチュウリップはぷらぷらゆれ、陽がまた降って赤い花は光ります。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
