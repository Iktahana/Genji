        "examples": {
          "standard": [
            {
              "text": "引っ越し先のマンション、プロパンガスだから冬場の光熱費が少し心配なんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "災害時でも復旧が早いという理由で、あえてプロパンガスを導入する家庭もあるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "庭でバーベキューをするために、プロパンガスのボンベを業者に配達してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "電気は自家用発電機、暖房と炊事はプロパンガス、水は雨水を使う。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いと神経痛が痛む上に、心臓の発作もおこり易く、病室のスチームは頼りにならないので、電気やプロパンガスのストーブを二つも三つも持ち込んでいる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
