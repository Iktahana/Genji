[
  {
    "uuid": "69511e74-cd6a-557e-a22e-2ef592a4cfa2",
    "entry": "プロ",
    "reading": {
      "primary": "プロ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
