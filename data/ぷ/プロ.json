        "examples": {
          "standard": [
            {
              "text": "この商品の売上の数プロが、恵まれない子供たちを支援する団体に寄付される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誤差の範囲はわずか数プロに抑えられており、非常に精度の高い測定結果が得られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アルコールの度数が数プロ違うだけで、お酒の味わいや酔い方は大きく変わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
