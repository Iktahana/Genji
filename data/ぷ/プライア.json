        "examples": {
          "standard": [
            {
              "text": "カーボベルデ共和国の首都プライアは、大西洋に面した美しい港町として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プライアの旧市街を散策していると、ポルトガル植民地時代の面影を残す色鮮やかな建物が立ち並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "出張で訪れたプライアのレストランで、新鮮なシーフードを使った伝統的な煮込み料理を堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "北斗は大熊星座（北斗七星）、参宿はオリオン星座、昴宿はプライアデス星座である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に昴宿はプライアデス（Pleiades）のことで、オリオンの西北方に見ゆる小星の一群をいうのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
