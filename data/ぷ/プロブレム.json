        "examples": {
          "standard": [
            {
              "text": "今回のシステム障害は、ハードウェアの物理的な故障ではなく、ルーターのネットワーク設定に関するプロブレムだったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は技術的には非常に優秀なエンジニアなのだが、チームメイトとのコミュニケーションにおいて少しプロブレムを抱えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロジェクトの深刻な遅延を防ぐために、あらかじめ潜在的なプロブレムを洗い出して事前に対策を打っておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私達はいつも無意識の裡にそれ等を眞として數學のプロブレムを取扱つて來た。",
              "citation": {
                "source": "海から歸る日",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
