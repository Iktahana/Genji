        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台袖に控えるプロンプターが、台詞を忘れた俳優に小声で助け舟を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は長年オペラのプロンプターを務めており、全パートの譜面を完璧に把握している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張のあまり頭が真っ白になったが、プロンプターの声のおかげでなんとか演じ切れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
