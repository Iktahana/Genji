        "examples": {
          "standard": [
            {
              "text": "午後からの激しい雨が止み、夕晴れとなった空には大きな虹がかかっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕晴れの澄み切った空の下、公園で子供たちが楽しそうに遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、見て！急に夕晴れになったよ！」と、娘が空を指さして叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "祈祷も、奉納の申楽も、今日で終るわけだが、相変らず、一滴の雨すらなく、あすも照りらしい夕晴れだった。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
