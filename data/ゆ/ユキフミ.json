        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪深い朝、村人たちは雪踏みをして道を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "足跡のない新雪を踏みしめる「雪踏み」は、心地よい音を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "登山道は、先行者が雪踏みをしてくれていたおかげで歩きやすかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "金眸は朝より洞に籠りて、独り蹲まりゐる処へ、兼てより称心の、聴水といふ古狐、岨伝ひに雪踏み分て、漸く洞の入口まで来たり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪踏みて乾ける落葉現はれぬ一月八日　長野ホトトギス会員来る。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしの山　峰のしらゆきふみわけて入りにし人のあとぞ恋しき　あとぞ恋しき　眼にはいっぱいな紅涙があった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "静御前",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
