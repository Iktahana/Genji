        "examples": {
          "standard": [
            {
              "text": "油頁岩は、将来のエネルギー資源として注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、広大な油頁岩の層が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "油頁岩から原油を抽出する技術は、まだ発展途上にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "竪横に深く坑道を穿つて採掘する物であると思つてゐた炭砿の概念は忽ちに裏切られて、唯だ表皮の油頁岩層を三四丈も剥いで取れば、下は一面に石炭なのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剥ぎ取つた油頁岩は贅物でなく、それを乾溜して重油を製してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
