        "examples": {
          "standard": [
            {
              "text": "昔の子供たちは雪釣りをして遊んだそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雪釣りは雪国ならではの遊びだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父が雪釣りのやり方を教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "庭には綺麗に手入れが行きとどいていて、雪釣りの松や霜除けの芭蕉が冬らしい庭の色を作っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪が降ればいいのう」と、禿どもは雪釣りを楽しみに空を眺めていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
