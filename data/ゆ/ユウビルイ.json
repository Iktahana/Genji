        "examples": {
          "standard": [
            {
              "text": "有尾類は、失われた手足や尾を再生する驚くべき能力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水槽の中には、色とりどりの有尾類がのんびりと泳ぎ回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地球温暖化により、有尾類の生息環境が脅かされていることが懸念されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私の顔を見るなり、「なんだ、こないだの一物は、あれは両棲類中の有尾類。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっぽがあるから、有尾類さ。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
