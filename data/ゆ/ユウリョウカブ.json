        "examples": {
          "standard": [
            {
              "text": "投資家は安定した成長が見込める優良株を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優良株は景気変動に強い傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期投資には優良株が適していると言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "というのも国策パルプ、苫小牧製紙、東洋高圧、帝国製麻、日本製鋼、北海道電力といった優良株を、北海道に工場があるという理由で、絶対に買わない男がいるという話をとたんに思い浮べたからである。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは豪胆な投機家たちが買い支えたが、やがて目いっぱいになったり怖くなったりして、二時ごろになると優良株の中には一ポンド株が数シリングで売られる始末。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
