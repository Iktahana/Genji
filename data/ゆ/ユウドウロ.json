        "examples": {
          "standard": [
            {
              "text": "航空機は、滑走路に着陸後、誘導路を通って駐機場へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく建設された空港には、複数の誘導路が整備され、効率的な運用が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パイロットは、管制塔からの指示に従い、ゆっくりと誘導路を進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "積雪地の飛行場では、滑走路及び誘導路の除雪が、一番の問題であるが、それも実際に役に立たせるためには、迅速にやる必要がある。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
