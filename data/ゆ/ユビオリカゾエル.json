    "definitions": [
      {
        "index": 1,
        "gloss": "to count on one's fingers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、指折り数えながら、テーブルの上のリンゴの数を確かめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、指折り数えてお菓子の数を分け合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "算数が苦手な生徒は、指折り数えることで計算を補っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "都を遁れ出ましてから指折り数えると、もはや五月あまりにもなりましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官衙の建築物の如きも明治当初のままなるものは、桜田外の参謀本部、神田橋内の印刷局、江戸橋際の駅逓局なぞ指折り数えるほどであろう。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方面に志す学者は年に指折り数えるほどしかいなかった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの雑誌の読者諸君からみれば、お父さんぐらいの年頃であるが、今から指折り数えると三十年も以前、いまだに忘れることの出来ないなつかしい友達があった。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、第一に（この作者は指折り数えることが好きである）彼女の二十三歳の父はアメリカ風の瀟洒たる悪漢であり、彼女の母は飛び切り美しいけれど、近代風の貞操盲目者であったからである。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間に日曜を指折り数える週間が続いた。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これよ」　と指折り数える手真似だ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to count down the days (in anticipation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏休みが来るのを、指折り数えて待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "待ちに待ったコンサートの日を、彼女は指折り数えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリスマスまであと何日だろう、と子供が指折り数えて尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
