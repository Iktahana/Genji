        "examples": {
          "standard": [
            {
              "text": "イディッシュ語（ユダヤ語）は、アシュケナージ系ユダヤ人の間で発展した言語です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父母からユダヤ語（イディッシュ語）の歌を教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イディッシュ語（ユダヤ語）の映画は、独特のユーモアと悲哀を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "母のアンリエットは、オランダ生れのユダヤ婦人でユダヤ語とはちがうドイツ語を、完全に発音さえ出来なかった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ゴルロフカの「労働宮」にはロシア語の工場新聞のほかにもう二つ別にユダヤ語とタタール語の小新聞発行所が設けられていることだ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「労働宮」の大きくない一室のドアの上に貼られた「ユダヤ語、タタール語新聞発行所」という紙は小さいものだ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっか近くの窓のなかから、ドイツ語に似たユダヤ語で、男と女が早口に云い合いする声が起った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
