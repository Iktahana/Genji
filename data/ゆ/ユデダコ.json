          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サウナに入りすぎた彼は、顔が茹でタコのように真っ赤になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "恥ずかしくて、彼女の顔は茹でタコみたいに赤くなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い日差しに当たりすぎた子供の顔は、まさに茹でタコだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
