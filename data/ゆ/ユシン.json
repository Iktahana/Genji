        "examples": {
          "standard": [
            {
              "text": "高倍率の顕微鏡観察では、油浸レンズの使用が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究者は、細菌の詳しい構造を調べるために油浸法を用いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "油浸を行うことで、より鮮明な細胞の画像を得ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "壇上三門と称されている、その隅々に香炉が置かれ、茅草を布いた坐るところの右に、百八本の護摩木――油浸しにした乳木と、段木とが置かれてあった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の油浸と繊細なスクレーパーの一掃きが、一世紀に亘って隠されてきた表情を完全に引き出したからだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
