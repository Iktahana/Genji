        "examples": {
          "standard": [
            {
              "text": "古民家の雪見障子からは、庭の雪景色が美しく見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪見障子の下半分がガラスになっているので、雪がよく見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪景色を楽しむために、雪見障子を設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「おばアちやん、清治のお茶、また茶柱が立つてゐますよ」　雪見障子から薄い朝の陽が射し込んでゐる。",
              "citation": {
                "source": "夜福",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪見障子の外は狹い縁側で、おもとの鉢が三ツ四ツ置いてあつた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
