        "examples": {
          "standard": [
            {
              "text": "ユニバーサルデザインの製品は、どんな人でも使いやすいように工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネットは、情報のユニバーサルなアクセスを可能にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の考えは、非常にユニバーサルで誰にでも理解されやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "午後一時四十分、ユニバーサル機は東京へ向けて出発した。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうものよりも、もっと必要と感ずるのは、帝国館などで紹介している「ユニバーサル週報」の如く、外国の最近の出来事を撮影紹介するものである。",
              "citation": {
                "source": "活動写真",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "レバスティアは現在ユニバーサルカフェでドミノゲーム中。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
