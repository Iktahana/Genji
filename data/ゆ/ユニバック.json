        "examples": {
          "standard": [
            {
              "text": "UNIVACは、世界初の商用コンピュータの一つとして歴史に名を刻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "1950年代にUNIVACが登場し、情報処理の分野に革命をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンピュータの進化の歴史を語る上で、UNIVACは欠かせない存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "作表機市場でＩＢＭにはるかに差をつけられながらも二番手につけていたレミントンランドは、一九五一年、コンピューターの開発事業に乗り出していたエッカートとモークリーによるマシンをＵＮＩＶＡＣと名付け、初めて商品として売り出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＵＮＩＶＡＣから遅れることおよそ二年、科学技術計算用の７０１の発表にこぎ着け、続いて事務処理用の７０２を発表したＩＢＭは、徹底した低価格攻勢によってレミントンランドを追いかけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
