        "examples": {
          "standard": [
            {
              "text": "雨上がりの夕方、空には鮮やかな夕虹がかかり、人々を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滅多に見られない夕虹の出現に、観光客たちは一斉にカメラを向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の夕食後、偶然にも窓から美しい夕虹が見えて、なんだか得した気分になったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "空を見さだめて、非番の者たちは、夕虹の下を帰って行ったが、平四郎は、宿直部屋の同僚と話しているうちに、将棋が初まったので、つい燈火を見てしまった。",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立はすぐあがって、松や梧葉に夕陽が染まり、東山の空には、夕虹がかかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "両軍、相引きに退いて、人馬の喚きも消え去った後、山谷の空には、五彩の夕虹がかかっていた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
