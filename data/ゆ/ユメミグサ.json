        "examples": {
          "standard": [
            {
              "text": "春風に揺れる夢見草が、はかなく美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本人は古くから夢見草に美を見出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夢見草の下で、花見を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ひと昔前の事、自分がまだ中學の時代に、如何いふ心持で讀んだのか忘れてしまつたが、小山内薫氏の「夢見草」と、小山内八千代さんの「門の草」といふ文集を、常に机の上に置く十數册の詩歌集と一緒に並べて持つてゐた。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夢見草」は今も自分の本箱の中にあるが、「門の草」は何時かしら古本屋にでも賣拂つたのであらう、自分の手もとには無くなつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
