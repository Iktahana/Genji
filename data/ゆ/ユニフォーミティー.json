        "examples": {
          "standard": [
            {
              "text": "品質のユニフォーミティーを保つため、製造工程の全ての段階で厳格な検査が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このデザインは、全体のユニフォーミティーを重視しており、どの要素も調和がとれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちの学習環境では、教育内容のユニフォーミティーが公平性を保つ上で重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "スターシステムの過去のスポーツがユニフォーミティーに向って方向を辿っていることはこの共同性そのものに向って成長して行くスポーツの将来を指し示すものである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悦楽はあらゆるスポーツで一般にユニフォーミティーと呼ばるる喜びである。",
              "citation": {
                "source": "スポーツの美的要素",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
