        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は若くして優れた弓取りとして名を馳せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの弓取りの矢は、百発百中の精度を誇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦国時代には、多くの弓取りたちが活躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "bow-twirling ceremony at the end of each day of a Grand Sumo Tournament",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
