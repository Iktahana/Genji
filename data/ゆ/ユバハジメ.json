      {
        "index": 1,
        "gloss": "ceremony on the fifth day of the 10th lunar month in which the emperor would watch prize archery (Heian and Kamakura periods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
