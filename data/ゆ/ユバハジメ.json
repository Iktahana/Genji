        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代、宮中では弓場始めの儀式が盛大に行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弓場始めは、天皇が弓術の腕前を鑑賞する重要な行事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古文書には、弓場始めの様子が詳しく記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "first firing of the bow (after the New Year or the reconstruction of the archery range (in military families))",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
