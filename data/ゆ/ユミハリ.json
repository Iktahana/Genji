        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜空に輝く弓張りが、静かに地上を照らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弓張りの下で、恋人たちはロマンチックな夜を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東の空に弓張りが昇り、夜が更けていくのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
