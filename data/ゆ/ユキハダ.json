        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の雪肌は、まるで磨かれた白磁のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "化粧品CMで、モデルの雪肌が強調されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬の澄んだ空気の中で、彼女の雪肌がいっそう輝いて見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
