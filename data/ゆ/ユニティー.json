        "examples": {
          "standard": [
            {
              "text": "チームの成功には、メンバー間のユニティーが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は多様な意見をまとめ上げ、チームにユニティーをもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "全員が共通の目標に向かって努力することで、強いユニティーが生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コンティユニティーをその場々々で作るのだらうが、七時に起されて十二時半じゃ怒りたくなる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の放送のコンティユニティーを出せと言はれるので、上山雅輔に速記させ、三十分のものを作った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
