        "examples": {
          "standard": [
            {
              "text": "統計モデルの妥当性を評価するため、尤度関数を用いてデータとの適合度を計算した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ある事象が発生する尤度は、観測データに基づいて慎重に推定されるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ベイズ統計学では、事前確率と尤度を組み合わせて事後確率を導出する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たましいを持たぬだけに、いや、おゆうどのはじめ、女という女を籠絡したものであったよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
