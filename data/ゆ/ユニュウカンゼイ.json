        "examples": {
          "standard": [
            {
              "text": "政府は、国内産業を保護するため、特定の輸入品に対して高い輸入関税を課した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "輸入関税の引き下げは、消費者が海外製品をより安価に手に入れられるようになることを意味する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国は主要な輸出品には関税をかけないが、輸入関税は非常に高いことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "従ってまた、穀物を国内市場にもたらす費用と外国穀物の平均価格とに関する特定国の諸事情に従って作られた輸出奨励金と輸入関税とに関する法律制度は、消費税、土地の地代、及び労働の価格がどれほど高くとも、かかる国の農業者に対しこの貨物の生産を採算のとれるものたらしめることは、明かとなろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "過度ではない輸入関税と、ほとんどリカアドウ氏が推奨した程度の奨励金とが、おそらく我国の現状に最も適合し、かつ価格の安定を最も確保するであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
