        "examples": {
          "standard": [
            {
              "text": "出かけようと玄関を出たら、ちょうど彼が行き掛かるところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園に行き掛かったところで、雨が降り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目的地に着き掛かった時、忘れ物に気づいて引き返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "寺の門をくぐって、先祖代々の墓地へゆきかかると、その桐の木にひぐらしがさびしく鳴いていた。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と、下手より以前の老人と青年出で来たり、いつの間にか花が散ってしまったのに少しく驚くことよろしく、その代りに混雑しないで好いなどの台詞あり、二人はぶらぶらと上手へゆきかかる――。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、男は、その前へゆきかかると、「ああ、ここだ。",
              "citation": {
                "source": "公園の花と毒蛾",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
