        "examples": {
          "standard": [
            {
              "text": "自国の資源保護のため、その国はレアメタルに輸出税を課している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "輸出税の導入は、国内産業の保護にはなるが、国際競争力を損なう可能性もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は、農産物の輸出税を撤廃し、海外市場への進出を奨励した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "國内ノ物價ガ世界的原因、則チ世界大戰中ノ如キ世界的物價騰貴ノ爲ニ騰貴スルトキハ、國家ハ一般國民ノ購買能力ト世界市價トノ差額ヲ輸出税トシテ課税スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ此等ハ非常變態ノ經濟状態ニシテ輸出税ヲ課スル如キ原則ニ非ザルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "出る者には輸出税を課す。",
              "citation": {
                "source": "最近欧米に於ける財政経済事情",
                "author": "井上準之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
