        "examples": {
          "standard": [
            {
              "text": "弓を引く際、腕を保護するために弓籠手を装着する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は手作りの革製弓籠手を大切に使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の弓道家は、機能性と美しさを兼ね備えた弓籠手を用いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と活然たる弦返りの音、弓籠手に中って響いたが、既に発たれていたのであった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに夜も明け方になりしかば、武蔵坊弁慶は居たところへずんと立ち、いつも好む褐の直垂、水に鴛の脇楯し、三引両の弓籠手さし……と、お能の謡に似て、あれより勇健質朴な調子も出て来る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
