    "definitions": [
      {
        "index": 1,
        "gloss": "soaking (fabric) in lukewarm water (to soften and remove starch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
