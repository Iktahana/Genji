        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい浴衣は、着る前に一度湯通しした方が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湯通しすることで、生地が柔らかくなり、着心地が良くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "染め物を湯通しして色止めをする作業は、職人の腕の見せ所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "湯通し、蓋附土鍋、蓋無土鍋、捏鉢、水甕いずれも特色がある。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "blanching (food)",
