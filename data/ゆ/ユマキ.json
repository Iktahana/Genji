        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代の貴族は、湯巻きを着用して入浴したと記録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湯巻きは、当時の身分の高い人々の入浴習慣を物語る品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館で、当時の湯巻きを再現した展示を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
