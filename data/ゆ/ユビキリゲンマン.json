        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「指切りげんまん、嘘ついたら針千本飲ます！」と子供たちが叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃、指切りげんまんは絶対の約束だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は指切りげんまんをして、二度と遅刻しないと誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、自分では何もしようとしないので、昨日小太郎がパパに連れられて、国境平の奥の方に放牧の牛を見に行ったのを機会に今日の午後までに、宿題の一つである（夏休みの一日）という綴方を作っておくように、指切りげんまんまでして約束した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
