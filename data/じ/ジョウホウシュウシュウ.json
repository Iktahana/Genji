        "examples": {
          "standard": [
            {
              "text": "ライバル企業の動向を知るために、綿密な情報収集を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外旅行に行く前に、現地の治安について情報収集をしておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は独自のルートを使って、事件に関する極秘の情報収集を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "基礎的な情報収集の面でも、請け負う仕事に関連しても、インターネットにはまっている時間はとても長くなる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察用語でいう警備とは、共産党や新左翼など左翼関係の情報収集作業である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プエブロ号という情報収集艦が北朝鮮に捕獲された。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして訊かれるのですか」「単なる情報収集だよ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "面喰らうのは、マーキュリー新聞の情報収集が素早いことだ」　バーニ医師が言葉を挟んだ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "拒否されても別に驚きませんが、でもフェンウィック氏のあなたに対する仕打ちはほかの誰よりもひどい……」「それをどこで」「いいですか、情報収集は警察のお手の物です。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
