        "examples": {
          "standard": [
            {
              "text": "新人エンジニアは、経験豊富な先輩から実地指導を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "農家は、新しい栽培技術について農協から実地指導を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この分野では、机上の空論ではなく、現場での実地指導が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "昭和八年六月四日に、私は広島文理科大学植物学教室の職員達と一緒に同校の学生を引き連れて植物実地指導のため、安芸の国山県郡八幡村におもむいた。",
              "citation": {
                "source": "カキツバタ一家言",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年六月四日に、私は広島文理科大学植物学教室の職員達と一緒に同校の学生を引き連れて植物実地指導のため安芸の国山県郡｜八幡村に赴いた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昭和十五年十月十八日東京を立って、かねて招きにあずかっていた広島文理科大学へ学生の実地指導と講義とに出掛けた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
