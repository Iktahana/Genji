        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "過去の戦争で、ある文明は完全に尽滅してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の怒りは尽滅するまで収まらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敵軍を尽滅させるため、総攻撃を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おまへくらゐのものにまだ相対界を尽滅させられて堪るものかいと空で無頼漢が私にいふ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
