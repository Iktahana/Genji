        "examples": {
          "standard": [
            {
              "text": "工事現場ではヘルメットの着用を徹底し、事故防止に細心の注意を払っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高齢ドライバーの事故防止策として、自動ブレーキ搭載車の普及が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みを前に、小学校では水の事故防止に関する安全教室が開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "先生はこの前年海軍から航空船の事故防止の研究を委託されていたので、その基礎資料を得るために、水素の不完全燃焼の模様を調べておられたのである。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその事故防止は、大切な問題なのであった。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
