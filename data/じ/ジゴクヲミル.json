        "examples": {
          "standard": [
            {
              "text": "バブル崩壊後の連鎖倒産で家も財産も全て失った彼は、あの時期に人生の本当の地獄を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの冬の山岳救助訓練は、何度も意識が遠のきかけて、まさに生きながら地獄を見たよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦争を最前線で経験した祖父は、若かりし頃に戦地で地獄を見た時の話を、重い口調で静かに語ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "徐ろに患者を毒殺しようとした医者、養子夫婦の家に放火した老婆、妹の資産を奪はうとした弁護士、――それ等の人々の家を見ることは僕にはいつも人生の中に地獄を見ることに異らなかつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐ろに患者を毒殺しようとした医者、養子夫婦の家に放火した老婆、妹の資産を奪おうとした弁護士、――それ等の人々の家を見ることは僕にはいつも人生の中に地獄を見ることに異らなかった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィジョンとして地獄を見るほど道徳的なヨハネやダンテのような人はその火から免れる工夫をせずにはいられないであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林は人間孤独の相と云ひ、地獄を見る、と言ふ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間だけが地獄を見る。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと孤独な物思い、静かな放心から我にかえったとき、私は地獄を見ることがあった。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林は人間孤独の相と云い、地獄を見る、と言う。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            }
          ]
        }
