        "examples": {
          "standard": [
            {
              "text": "彼は自らの過ちが生んだ結果を一生の十字架を背負う覚悟で生きている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「過去の罪という十字架を背負って生きていくのは、並大抵のことではない」と彼は呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "責任ある地位に就くということは、組織の運命という重い十字架を背負うことでもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十字架を背負うた彼が、その十字架を背負わせた、その人たちの罪の救いを、かえって神に祈っている心もちは、まことに尊くありがたいものです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
