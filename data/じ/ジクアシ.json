        "examples": {
          "standard": [
            {
              "text": "投球の際、軸足にしっかりと体重を乗せることで威力を高める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダンスの基本は、軸足がぶれないように体幹を安定させることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バスケットボールで軸足を動かしてしまうと、トラベリングの反則になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "橋本直は古白のことを「映画監督になるべき人だったかも知れない」（＊４）と言っているが、確かに古白はこれによく成功した句を多く作っているといえようし、彼が戯曲に創作の場を移していったのも、ここを軸足にしたものかもしれない。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
