          "standard": [
            {
              "text": "自由放任主義は、政府の経済への介入を最小限にすべきだと主張する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済学の教科書には、自由放任主義の功罪について詳細に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "市場経済の発展において、自由放任主義は重要な思想の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "食品の混ぜ物処理について英国政府は大陸諸国に比べて自由放任主義の立場をとり、食品業界はその後も混ぜ物処理を続けた。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて措き、入学試験の必要が、教育施設の或る意味での自由放任主義から生じて来ているという点は、「良い」中等学校と良くない中等学校との対立となって現われているのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
