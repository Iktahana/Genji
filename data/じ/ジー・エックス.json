        "examples": {
          "standard": [
            {
              "text": "政府は、GX（グリーン・トランスフォーメーション）を推進し、脱炭素社会の実現を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "企業のGX（環境転換）への取り組みが、持続可能な社会の実現に貢献すると期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「GX（緑の変革）の時代には、環境に配慮した技術開発がますます重要になるだろう」と専門家は語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのさらに前が、ヤマハのＧＸ７５０だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマハのＧＸ７５０が、トップ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トップのヤマハＧＸ７５０が、豪快に車体を倒した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマハＧＸ７５０は、大きくかたむいたまま、ヘルメットの脳天を見せて、カーブのむこうに見えなくなる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
