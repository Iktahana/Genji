        "examples": {
          "standard": [
            {
              "text": "「最初は苦手なタイプだと思ってたけど、話してみると不思議と情がわく人だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捨てられた子猫を放っておけず、面倒を見ているうちに深い情がわいてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何度も修理して使い続けている機械には、新品にはない愛着と情がわくものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しぶんもそのひとりだと反省して、自己嫌悪の情がわく。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵同士でも、ひとつ屋根の下に起き臥ししていれば、いつしかそこに、情がわく。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
