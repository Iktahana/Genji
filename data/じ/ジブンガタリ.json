        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は初対面の人にも、自分の過去について延々と自分語りをする癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会話が自分語りばかりになり、聞いている方が疲れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自分の功績を誇示するような自分語りは、あまり好かれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自分語りに突入し、彼の面前で公然とぶちまけることができるタイミングを見計らっていた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし自分語りという目標を断念し、こちらがちらつかせていた重荷から解き放たれた彼の心がすぐさま自分自身の重荷を投下するための準備を開始したことを見て取って満足した。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
