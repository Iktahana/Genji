        "index": 1,
        "gloss": "ghost bound to a specific physical location (usu. where death occurred)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
