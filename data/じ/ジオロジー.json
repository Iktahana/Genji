        "examples": {
          "standard": [
            {
              "text": "大学でジオロジーを専攻し、地球の成り立ちや地層について深く学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の独特な地形は、数百万年にわたるジオロジー的な変化によって形成されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はジオロジーの専門家として、地震のメカニズム解明に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃読んだ本でありませんがマンテガッツァの『フィジオロジー・エンド・エキスプレション』という本の中にイミテーションということについて例を沢山挙げてありましたが、私は今｜一々人間という者は真似をするものであるということの沢山な例を記憶しておりませんが、茲処に二つ三つあります。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリティクス、タイラニー、デモクラシー、アナーキズム、フィロソフィー、フィジオロジー、ジオロジー、ヒストリー、はすべてギリシャの言葉である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
