        "examples": {
          "standard": [
            {
              "text": "名目賃金は上昇しているが、実質賃金は低下しており、国民生活は苦しくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府は、実質賃金の引き上げを通じて、消費の活性化を図ろうとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「 my work の実質賃金がなかなか上がらなくて、将来が不安なんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今年三六年七月の実質賃金指数は大正三年以来の最低記録を示している。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年一年の実質賃金総指数は一四一・七で、それが今年の一月には一三九・二に低下し、この七月には更に一三七・〇に降っている。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
