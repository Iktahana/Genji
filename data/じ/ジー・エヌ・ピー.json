          "standard": [
            {
              "text": "国の経済状況を把握するため、GDP（国民総生産）とともにGNP（国民総所得）の動向も注目されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昨年のGNP（国民総所得）は、記録的な伸びを示しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済学の教科書で、GNP（国民総所得）の計算方法について詳しく学びました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＧＮＰは、一九四九年が二五〇〇億ドルだったが、五五年には三九七〇億ドルにのぼった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年にピークに達したＧＮＰは、一九三三年には半分ちかくにまで落ちた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
