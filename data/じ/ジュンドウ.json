          "standard": [
            {
              "text": "純銅製のタンブラーは熱伝導率が高く、冷たい飲み物を美味しく保ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モーターのコイルには、電気抵抗の少ない高品質な純銅線が使用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い十円硬貨の表面を磨くと、純銅特有の赤みがかった輝きが戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "銅鉱の電気分解　墺国の某鉱山では近来銅鉱から純銅を採るのに電気分解法を用いているそうだ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽極には大袋に亜鉛を入れたものを用い、陰極には銅板を用い、二・五ボルトの電圧で千アンペアの電流を通すと陰極の方へは純銅がだんだんに附着し、陽極には硫酸と酸素が出て来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
