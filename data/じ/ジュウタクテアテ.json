        "examples": {
          "standard": [
            {
              "text": "会社は、従業員の生活を支援するため、住宅手当を支給している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新入社員の給与には、住宅手当が含まれているため、実質的な手取り額は大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は単身赴任中の住宅手当を利用して、快適な住まいを確保している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "住宅手当　老人手当　子供手当　私の店の従業員中、その約三割が通勤者ですが、他はいずれも第一、第二、第三の三寄宿舎に収容しています。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずその保障の諸手当をいって見ますと、寄宿を出て一家を構えたものには固定給の三割を住宅手当として支給し、つづいてその家族の中に老人のあるものには老人手当（一人四円）、さらに子供のあるものには子供手当（四円）というのを出しています。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
