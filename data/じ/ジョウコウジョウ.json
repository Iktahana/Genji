        "examples": {
          "standard": [
            {
              "text": "タクシーの乗降場は、北口を出てすぐの左側にございます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スクールバスの専用乗降場には、登校時間になると多くの生徒が集まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光バスの乗降場が整備されたことで、駅前の渋滞が緩和された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "のち、乗降場にいる二人の姿が目撃されているが、既報したように、ドレッバー氏の遺体がユーストンから遠く離れたブリクストン通りの空き家で発見されるまで、その足取りはつかめていない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、地上でいうと、プラチナ市の西方、三十五キロのサン市という小都会の地下鉄乗降場と、そしてサンサン百貨店とに、出入口があった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
