    "definitions": [
      {
        "index": 1,
        "gloss": "coming from neighboring districts (of goods or produce)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この果物は、近隣の市町村から運ばれてくる地回りの品物です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔ながらの地回りの商人は、地域経済の要でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夜道で地回りに絡まれ、所持金をすべて奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私を地回りとにらんで逃げたのでしょう。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、地回りかい」　放二はクスリと笑っただけである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地回りに、なぐられないかい」「まだそんな経験はありません」　二人の会話は重点がずれているようだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一人で、そういうしょうばいをしていれば、地回りなどがすぐ因縁をつけるか、しょうばいの邪魔をする。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
