        "examples": {
          "standard": [
            {
              "text": "営業先から戻った担当者が、クライアントとの打ち合わせ内容について上司に口頭で状況報告を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現場の作業員たちは、1時間おきに本部の無線機を通じて工事の進捗に関する状況報告を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の資料には、各部門が抱えているトラブルや今後の見通しについての状況報告が詳しくまとめられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "警部は呼鈴をならして、あの日現場の外を見廻って、その外部の状況報告を書いた巡査を呼んでもらった。",
              "citation": {
                "source": "雪",
                "author": "楠田匡介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの報告です」　警部は、あの日の外廻りの状況報告書を皆の前に拡げた。",
              "citation": {
                "source": "雪",
                "author": "楠田匡介",
                "note": "青空文庫"
              }
            }
          ]
        }
