        "examples": {
          "standard": [
            {
              "text": "図書館の児童書コーナーには、子供たちの好奇心をくすぐる絵本が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "姪の誕生日に、最近人気のあるファンタジー系の児童書をプレゼントした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔読んだ児童書を読み返してみると、大人になってから気づく深いメッセージがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "児童書の編集者に求められる教育漢字の配当学年のチェックにも、コンピューターの支援は今すぐ欲しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、1962年に大型本として出版されてから、児童書としてだけでなく大人向けの本としても読めるという言説が多くなっていき、広い世代の人々にも読まれるようになっていきます。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「緑色の目の白いネコ」という題名で足沢良子さんが児童書として翻訳されているようですが未読です。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
