        "examples": {
          "standard": [
            {
              "text": "彼は独学で日本語を習得し、その自学自習の姿勢は周囲の尊敬を集めた。",
              "text_en": "He mastered Japanese through self-study, and his attitude towards self-teaching earned him respect from those around him.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代は情報があふれているため、自学自習で新しいスキルを身につけることが容易になった。",
              "text_en": "In modern times, with an abundance of information, it has become easier to acquire new skills through self-study.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の学力を向上させるには、自学自習の習慣を身につけさせることが重要だ。",
              "text_en": "To improve a child's academic performance, it's important to instill a habit of self-study.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "而も学生は皆登校し、自学自習すること常のごとし。",
              "citation": {
