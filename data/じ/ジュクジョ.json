        "examples": {
          "standard": [
            {
              "text": "彼女は年齢を重ねるごとに艶が増し、まさに理想的な熟女として周囲を魅了している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのバーのママは、落ち着いた物腰と知性を兼ね備えた美しい熟女だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若さだけが美しさではないことを、凛とした佇まいの彼女という熟女が証明していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一つは生女眞、一つは熟女眞で、今一つは非生非熟女眞である。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "非生非熟女眞はその南方にいて、即ち松花江の支源に當る輝發江の沿岸に居た者をいふのである。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟女眞といふのは、契丹の太祖阿保機時代に、女眞が寇をすることを恐れて、女眞の豪族數千家を分けて遼陽の南方に置いた。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此の女眞人が後になつて金國を興した時に、生熟女眞に關する傳説は頗る變化を來して、一種の移住傳説となつてゐる。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟蝦夷と麁蝦夷とは、女眞に於ける熟女眞と生女眞、臺灣に於ける熟蕃と生蕃に相當す。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
