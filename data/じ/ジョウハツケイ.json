        "examples": {
          "standard": [
            {
              "text": "気象観測所では、毎日決まった時間に蒸発計を確認して、地表からの水分損失を記録する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "農業試験場の担当者は、蒸発計の数値を基に畑の散水量を細かく調整している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みの自由研究で、自作の蒸発計を使って日当たりの違いによる蒸発量の変化を調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "湖面からの蒸発は、陸上で蒸発計で測られる値の八割くらいとみられるので、話を簡単にするために、一日に一ミリ蒸発するとする。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
