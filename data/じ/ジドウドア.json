        "examples": {
          "standard": [
            {
              "text": "コンビニの自動ドアから入る冷たい風が、冬の夜には身にしみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホテルの入り口にある豪華な自動ドアを抜けると、そこには開放的なロビーが広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供が自動ドアに指を挟まないよう、保護者の方は十分に注意してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて、自動ドアが音もなく開き、頭上に旗を振りかざした男がステップを踏んで下車してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の自動ドアが開くと、ロボットはそうしゃべって会釈する仕組みになっているのだ。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後をふたり連れが歩いていくのを感じながら、両側に植え込みのある飛び石を微妙な曲線のままにいくと、ガラスの自動ドアが開いた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
