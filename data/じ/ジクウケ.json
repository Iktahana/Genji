        "examples": {
          "standard": [
            {
              "text": "自転車のペダルが重くなったので、軸受けにグリースを注した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジンの回転を滑らかにするため、高精度なボールベアリングの軸受けを使用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長期間の使用により軸受けが摩耗し、機械から異音が発生していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのかごは、外側に二本の軸がとびだし、それがかごをとりまく大きいじょうぶな輪の軸受けあなへはいっている。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その輪には、おなじような二本の軸がとびだし、かごの軸と九十度ちがった方角へでていて、それが外側にあるもう一つの大きなじょうぶな輪の軸受けあなへはいっている。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
