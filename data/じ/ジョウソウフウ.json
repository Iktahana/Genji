          "standard": [
            {
              "text": "気象バルーンを放流して、高度一万メートル付近の上層風を観測する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "西寄りの強い上層風の影響で、海外からの帰国便が大幅に早まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日のフライトは上層風が荒れる予報だから、揺れに備えておこう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "雷が多くなって暗澹たる積雲が、ひゅうひゅう上層風をはらみながら、この渓谷をとざしてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            }
          ]
