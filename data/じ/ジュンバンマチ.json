        "examples": {
          "standard": [
            {
              "text": "病院では、診察の順番待ちで1時間も待たされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人気のアトラクションは、順番待ちの列が長蛇の列だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、まだ順番待ちですか？」と受付で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ただし作業ごとのカードの束は、いつも順番待ちで機械の前にたまるのが常だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サニーベイルのビリヤード場にピンボールのマシンと並べてためしに置かせてもらうと、ポングには順番待ちの列ができ、コインボックスはたちまち硬貨でいっぱいになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
