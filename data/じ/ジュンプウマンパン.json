        "examples": {
          "standard": [
            {
              "text": "彼の大学生活は、順風満帆で、特に問題もなく進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事業は順風満帆とはいかないまでも、着実に成長を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "転職活動が順風満帆に進み、希望通りの会社から内定を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その評価を追い風に、英国の小規模大学の一つに数学教授の席を得て、どこから見ても順風満帆。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしクロショイが三時の競馬でぼろ負けしなければ、ずっと順風満帆だったかもしれない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年、外交官勤務をして、ある規律違反がなければ順風満帆だったかもしれないが、結局解雇されてしまった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
