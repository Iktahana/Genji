        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The rare historical document underwent a careful 重刻 to make it accessible to scholars.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "After its initial success, the book saw a 重刻 with updated content and a new cover.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Antique maps are sometimes valuable, but a meticulously done 重刻 can also be appreciated by collectors.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "降つて南宋の世となつて、天聖本が重刻せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "重刻両漢紀後序に、其事、咸編年に萃む。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに其經典は收めて道藏にあるが、之を得ることが極めて困難である、幸ひ貴國の帝室の御文庫中に收まつて居る（之を知つて居つたのには私も驚いた）何故に貴國で此貴い經典を重刻して廣く學界に益する樣にしないかと云ふのである、そこで私は其困難な事情を述べた。",
              "citation": {
                "source": "支那研究に就て",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "今手許にあるのは、文久二年大槻磐渓先生の重刻になるもので、この小文はそれによって書き、また摸写図もその本から複写した。",
              "citation": {
                "source": "『雪華図説』の研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は秋田の人で、文久二年｜大槻磐渓先生の重刻になる『雪華図説』が送られて来た。",
              "citation": {
                "source": "語呂の論理",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
