        "examples": {
          "standard": [
            {
              "text": "湯気の上がるせいろから取り出されたばかりの蒸餅は、もちもちして格別の味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お正月の準備として、家族全員で蒸餅を丸める作業をするのが我が家の恒例だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔懐かしい蒸餅の香りに誘われて、つい市場の和菓子屋さんに立ち寄ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鐵車の嚴重なる事と、彈藥を夥しく用意して來た事とで、今日まで猛獸の害を免かれて居るが、其内に困難を感じて來たのは、糧食と飮料水との缺乏とである、すでに昨日から、糧食箱の中には一片の蒸餅も無くなつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸餅又は芋の蒸したるものへ附け平日の食事に用ふ。",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十七日（弘安元年）　同二年十二月二十七日は、尼が初春の料の餅をおくつたと見えて、十字（蒸餅）五十まい、くしがき一れん、あめをけ（飴桶）一、送給畢。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
