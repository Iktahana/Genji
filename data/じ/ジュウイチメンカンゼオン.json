        "examples": {
          "standard": [
            {
              "text": "十一面観世音像は多くの寺院に安置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長谷寺には巨大な十一面観世音菩薩像がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "十一面観世音は衆生を救うために様々な姿で現れると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分までゞもう五十一代、肉身の相続で此十一面観世音に御仕へ申すと謂つて居られた。",
              "citation": {
                "source": "ひじりの家",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから竜ヶ鼻の十一面観世音その他の仏が沢山に彫ってある磨崖仏を見た。",
              "citation": {
                "source": "別府温泉",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
