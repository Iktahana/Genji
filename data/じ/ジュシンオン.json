        "examples": {
          "standard": [
            {
              "text": "映画館の中では、受信音が鳴らないようにスマホをマナーモードにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はお気に入りの曲を編集して、自分専用の受信音に設定している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "静かなオフィスに突然大きな受信音が響き渡り、彼は顔を赤らめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すると、受信音は急にきれいになった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく隆夫は、天井にとりつけた高声器から聞えてくるくしゃくしゃいう受信音に耳を傾けた。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "準備室からファクシミリの受信音が聞こえ始めた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
