        "examples": {
          "standard": [
            {
              "text": "17世紀のフランスでは、ジャンセニスムが大きな影響力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジャンセニスムはカトリック教会内で議論を巻き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パスカルはジャンセニスムの擁護者の一人として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "或る人がサンヂカリズムを「熱烈なる社會的ジャンセニスム」（〔ardent janse'nisme social〕）と呼んだのは理由なきことではないであらう＊＊＊＊。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "前世紀において、彼らは、不平がちなジャンセニスムにもまれたので、ジェズイット精神にたいする軽蔑とともに、悲観的な、多少不満がちなあるものを、心のうちに残していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
