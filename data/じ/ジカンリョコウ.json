        "examples": {
          "standard": [
            {
              "text": "子供の頃、時間旅行ができる物語に夢中になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もし時間旅行が可能なら、歴史上の偉人に会ってみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「時間旅行なんて、まるで夢みたいだね！」と彼女は目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、もしかの学友辻ヶ谷君の手によって、二十年前の焼跡へ戻されたなら、これは僕の楽しみにしている時間旅行がここで中絶してしまうことを意味する。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の減食は簡単なことであつたが、犬をもつと速く馳けさせることは不可能であつて、しかも彼等が朝もつと早く出発することができないために、もつと長時間旅行することはできなかつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
