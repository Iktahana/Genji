          "standard": [
            {
              "text": "巻末の事項索引を使えば、専門用語の定義が書かれたページをすぐに見つけられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "膨大な資料の中から特定のトピックを探し出すため、事項索引が非常に役立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論文を執筆する際は、読者の利便性を考えて詳細な事項索引を作成すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二、事項索引編講読、作文に於いて、文法上の説明が出た時、直に本文に検索して、その知識を確実にすることが出来るための索引である。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しくは私の『モンテーニュを語る』八五―八六頁および『モンテーニュとその時代』事項索引について知られたい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
