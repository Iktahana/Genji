        "examples": {
          "standard": [
            {
              "text": "子供の頃、公園にやってくる巡回図書館の到着を毎週楽しみに待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "坂道の多いこの町では、高齢者が本を借りやすいように巡回図書館が各自治会館を回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "巡回図書館のトラックには、最新のベストセラーから絵本までぎっしりと詰め込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしは普通の巡回図書館のくる範囲外にあったけれども、その文章がはじめは樹の皮に書かれ、今ではただ時折り亜麻布紙に写されている、世界じゅうを巡回するあの書物どもの影響を今までになかったほどつよく受けた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの巡回図書館に『｜小さい読み物』という標題の数巻からなる作品があるが、わたしはそれを、まだわたしは往ったことがないがその名前の町のことが書いてあるのだと思っていた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大きな書架……事実巡回図書館なのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
