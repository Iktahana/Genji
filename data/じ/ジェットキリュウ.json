        "examples": {
          "standard": [
            {
              "text": "ジェット気流に乗ることで、飛行機はより速く移動できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上空の強いジェット気流が、各地に異常気象をもたらしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気象予報士は、今後のジェット気流の動きを分析している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現在は、自分の家に、研究室を建て増して、そこで女房と二人で、ジェット気流の研究をしている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも彼のジェット気流の研究というのは、やはりいっぷう変っていて、雲の形から、ジェット気流の存在を見つけようというのである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェット気流というのは、対流圏の上層部、非常に高いところにある気流である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでパンアメリカンをはじめ、多くの航空会社では、このジェット気流の調査をよくやっている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでシェファー博士は、高層雲の形から、このジェット気流の位置を見つけることができはしないかと考えついた。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
