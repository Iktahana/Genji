        "examples": {
          "standard": [
            {
              "text": "ニューヨークから帰国して三日経つが、まだ激しい時差ぼけで日中に眠くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時差ぼけを防ぐためには、機内で現地の時間に合わせて行動するのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「時差ぼけのせいで会議中にうとうとしてしまった」と彼は照れ笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "胃のなかに注いだその水の底に、時差ぼけはなかば沈んだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の空港に着いてすぐに、ぼくはこのアパートメントまで来て、この部屋の新たなる入居者となり、部屋でする最初の作業として、時差ぼけをとるための昼寝をした。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような部屋では、時差ぼけがとれにくいようにぼくは思う。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　プリモによって、時差ぼけのかすかな残りは、きれいに消えた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
