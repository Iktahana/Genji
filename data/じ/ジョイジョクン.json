        "examples": {
          "standard": [
            {
              "text": "叙位叙勲（じょいじょくん、conferment of Court ranks and decorations）は、国家への貢献を称えるための公的な栄誉である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、長年にわたる社会貢献に対し、叙位叙勲を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "叙位叙勲の対象となる功績は、学術、芸術、社会福祉など多岐にわたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "余が家翁の世を去られし時にも親戚群り来りて其の筋より叙位叙勲の沙汰あるまで訃を発すべからずとなし虚栄の為に欺瞞の罪を犯す事を顧みざりき。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
