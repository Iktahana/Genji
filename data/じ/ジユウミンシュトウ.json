        "examples": {
          "standard": [
            {
              "text": "自由民主党（Liberal Democratic Party）は、日本の主要政党の一つであり、長年政権を担ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自由民主党の政策に賛同し、党員として活動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自由民主党の総裁選は、常に国の政治の行方を左右する注目イベントだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自由民主党が結成され、いわゆる五五年体制が固まって、高度成長に向けて歯車が回りはじめた頃です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
