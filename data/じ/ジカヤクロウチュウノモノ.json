        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は英語を自家薬籠中の物として使いこなしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな難しい問題も、彼にとっては自家薬籠中の物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の研究により、その分野の知識は自家薬籠中の物となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "椿岳の画はかくの如く淵原があって、椿年門とはいえ好む処のものを広く究めて尽く自家薬籠中の物とし、流派の因襲に少しも縛られないで覚猷も蕪村も大雅も応挙も椿年も皆椿岳化してしまった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来における宮方の軍需の一端を散所の人力と経済力にも結んでおくため、夙に、散所ノ太夫父子をも手なずけて、自家薬籠中の物としようと計っていたわけだった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたがた、何かのばあいのためにも自家薬籠中の物にしておかねばならぬ人間と、思うのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
