        "examples": {
          "standard": [
            {
              "text": "過去には非人道的な人体実験が行われた悲しい歴史がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新薬の開発には、倫理的な基準に則った人体実験が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのSF小説では、禁断の人体実験によって生まれた超能力者が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "普通に注入して、文字通り我が身で人体実験する。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、妙だ、人体実験で、生きているとは」　だが、ほかの者は驚きのあまり、ラリの感想など聞いちゃいない。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
