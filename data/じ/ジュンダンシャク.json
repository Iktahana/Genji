        "examples": {
          "standard": [
            {
              "text": "彼はイギリス王室から多大な貢献を認められ、准男爵の称号を授けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小説の主人公は、没落した准男爵の家系を再興するために奮闘する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "准男爵は貴族ではないが、世襲可能な称号としてイギリスの階級社会で重んじられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どうやらこの准男爵はこっちに全く気が無いようだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の話によれば、死亡した准男爵のかかりつけ医が本署に来て、検死の要請をしたそうで、明日一〇時に決まったとのこと。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、たじろぐ准男爵の寝室へ、マークが突進して、変装を取るように頼んだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "准男爵の楽天的な性分が戻ってきた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
