          "standard": [
            {
              "text": "目覚まし時計の音で目が覚めると、彼はゆっくりとベッドの上で上半身を起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "看護師の手を借りて、患者は食事を摂るために上半身を起こして背もたれに寄りかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腹筋のトレーニング中、彼は苦しそうな表情を浮かべながらも必死に上半身を起こし続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、跼めた上半身を起こすなり、撞木杖を持ち直すと、大股にとんで、板の間の端に立っている義一の足を、力まかせに殴りつけた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
