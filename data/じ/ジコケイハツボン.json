        "examples": {
          "standard": [
            {
              "text": "最近、メンタルケアをテーマにした自己啓発本がベストセラーになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、この自己啓発本、君が抱えてる問題の解決策が書いてあるかもよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通勤時間に電子書籍で自己啓発本を読み、仕事へのモチベーションを高めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジェームズ・アレン（一八六四―一九一二年）は、今でいうところの自己啓発本のライターである。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、訳し方についてだが、現代でも自己啓発本として通用するよう、語彙選択をかなり一般化させてある。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            }
          ]
        }
