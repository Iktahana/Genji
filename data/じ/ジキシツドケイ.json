          "standard": [
            {
              "text": "美術館では、貴重な絵画の保存のため、自記湿度計で常に湿度を管理している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この温室では、自記湿度計が作物の生育に適した湿度を自動で記録している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は部屋の乾燥が気になり、自記湿度計を購入して設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「自記計器のグラフを見ますと、三分間ばかり、はげしい擾乱状態にあったことが、記録されています」「なに擾乱状態が……」　私は、手を伸ばして、自記計器の一つである自記湿度計の中から、グラフの巻紙を引張り出した。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
