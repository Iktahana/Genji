        "examples": {
          "standard": [
            {
              "text": "従来の術式に比べて体への負担が少ない鏡視下手術が選択された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回のオペでは、新しい術式を採用することにしました」と執刀医がチームに告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "術式の特徴や合併症のリスクについて、図解を用いて患者に丁寧に説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "語を崩して新しい語を拵へて行く場合だつて、もつと芸術式に、もつと最奥処から出て来てほしいものです。",
              "citation": {
                "source": "新しい国語教育の方角",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに探偵小説というものは構想、トリック、よくよく行きとゞいて算術式にメンミツにまとめておいてからやらねばならぬもの、この算式に狂いがあっては、せっかく同好の士へのプレゼントが端物になって、オソマツ、何にもならない。",
              "citation": {
                "source": "私の探偵小説",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分これは魔術式文を含むハーブ・ブックだっただろう。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
