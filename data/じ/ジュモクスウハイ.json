        "examples": {
          "standard": [
            {
              "text": "古代の文化では、生命の源として樹木崇拝が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "神話には、神聖な樹木を崇拝する風習が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一部の地域では、今でも精霊が宿ると信じられている樹木への樹木崇拝が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私はそれを拾い上げてやる時にちらりっと見ると、その中には、「樹木崇拝の起原」と云ったような名前の本もあったが、たぶんこの老人は、あるいは商売にしろ物好きにしろ、とにかく貧しい愛書家で、しかも珍本の蒐集家に相違ないと思った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "『エンサイクロペジア・ブリタンニカ』十一版二十四巻に、スタンレイ・アーサー・クック氏が蛇崇拝を論じて、この問題は樹木崇拝の起原発達を論ずると等しく、一項ごとに人間思想史の諸問題を併せ解くを要し、事極めて複雑難渋だと述べ居る。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
