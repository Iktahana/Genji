          "standard": [
            {
              "text": "辞書編集の仕事は、膨大な数の用例を収集し、意味を定義していく根気のいる作業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は生涯のすべてを辞書編集に捧げ、ついには日本最大の国語辞典を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代の変化に合わせて言葉の意味や用法を更新していくことも、辞書編集の重要な役割だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "簡約版は衆知のごとく、早く印行して世に出でたが、しかし私に代って戦時中には、統理の傍ら、他方には、新たに、語詞の採訪と採集とに力を尽くしつつ専ら改訂の業に従った私の次男猛は、苦心努力の結果、辞書編集上、望外にもこよなき良い経験と智識とを得たかと信ずる。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            }
          ]
        }
