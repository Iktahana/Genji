        "examples": {
          "standard": [
            {
              "text": "主君を裏切った家臣に対し、冷酷な上意討ちが執行された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は上意討ちの命を受け、かつての親友を追う身となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「上意討ちだ！ 覚悟しろ、この卑怯者め！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上意討ちの仕手になることは、平時における武士の最大の名誉であった。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないと知って、とやかく弁明したら、弁明したことがなお御癇癖に障るは必定、障ったら切腹、改易、お手討ち、上意討ち、黒白正邪をつけないうちに、只お憎しみ一途の御諚が下るのは知れ切ったことでした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
