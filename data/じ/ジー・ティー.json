        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "国際会議では、時刻をGMT（グリニッジ標準時）に統一して連絡を取り合います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「時差があるので、日本時間からGMT（グリニッジ標準時）に変換して確認してください」と指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "GMT（グリニッジ標準時）を基準に、世界中のタイムゾーンが定められています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
