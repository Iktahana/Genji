        "examples": {
          "standard": [
            {
              "text": "この曲のサビの部分には、十六分音符の速いパッセージが連続していて、指の動きが追いつかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もっと軽やかに、十六分音符の一つひとつを粒立たせて弾くように意識してみて。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メトロノームに合わせて、十六分音符のリズムを正確に刻むための基礎練習を繰り返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その第一七小節から五小節の間は右手が六つの十六分音符を叩く間に左手は四つの十六分音符を叩く。",
              "citation": {
                "source": "音楽界の迷信",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがクリストフの時代の者らは、十六分音符のうちに社会学を取り入れていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
