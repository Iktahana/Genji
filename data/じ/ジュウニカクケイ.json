        "examples": {
          "standard": [
            {
              "text": "算数の時間で、コンパスを使って正十二角形を描く練習をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その公園にある東屋の屋根は、珍しい十二角形の形をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "十二角形のコインは、その独特な形状から偽造防止に役立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "兩側には老樹が茂り、城の前庭に達するまで深い森林を分けて行くやうな感じで、前庭からは、左に圓筒形のシーザーの塔（高さ一四七呎）、右に十二角形のガイの塔（高さ一二八呎）が仰がれ、どちらも十四世紀の塔で、塔と塔の間は高い石塀でつなぎ、その中間に大手ともいふべき二重の塔門が立つてゐる。",
              "citation": {
                "source": "ウォリクの城",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
