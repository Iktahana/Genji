        "examples": {
          "standard": [
            {
              "text": "速度と火力を高次元で両立させた巡洋戦艦は、海戦の歴史において一時期非常に重要な役割を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "設計者は、重厚な装甲をある程度犠牲にすることで、巡洋戦艦に圧倒的な機動力を与えることに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その激しい砲撃戦の最中、一隻の巡洋戦艦が弾薬庫に直撃を受けて爆沈するという悲劇が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「二百発の低速砲弾を、敵の四｜隻の巡洋戦艦に集中する。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巡洋戦艦といふやつかな。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜檣二煙突の大巡洋戦艦でおそらくは一万二、三千｜噸くらいもあったであろうか。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
