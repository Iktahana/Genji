        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パーティーでジェスチャーゲームをして、大いに盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はジェスチャーゲームが得意で、どんなお題でもすぐに表現できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チーム対抗のジェスチャーゲームで、私たちは見事に勝利した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
