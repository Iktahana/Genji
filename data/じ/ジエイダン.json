        "examples": {
          "standard": [
            {
              "text": "自分の身は自分で守る、それが自衛団の精神だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物たちは、外敵から身を守るために様々な自衛団の術を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自衛団の意識を高めるための講習会が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
