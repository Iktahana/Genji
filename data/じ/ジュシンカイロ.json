        "examples": {
          "standard": [
            {
              "text": "エンジニアは、微弱な信号も逃さない高感度な受信回路を設計した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラジオを分解して、壊れた受信回路の部品をハンダ付けで修理する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新の受信回路は、デジタルノイズの影響を最小限に抑えるよう工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だからパネルの前に人間が近づいて、目盛盤をまわしても、受信回路の同調を破ったり、ストレー・フィールドを作って増幅回路へ妨害を与えたりすることはない。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
