  {
    "uuid": "9ceffcb3-afad-59ff-8bc7-a568b4f0e635",
    "entry": "字下げ",
    "reading": {
      "primary": "じさげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indentation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "段落の書き出しは一文字分を字下げするというのが、日本語作文の基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プログラムのコードを読みやすくするために、適切な字下げを心がけてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引用部分は全体を二文字分字下げして、本文と区別することに決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "字下げも多用されれば、戯曲などでは、複雑な凹凸のある組み版が行われる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦組み対応のウェッブブラウザーという仕立てにおいても特徴的なａｚｕｒは、字下げなどのレイアウト、漢文返り点などに対応し、さらには、コメント欄に書き記された情報を手がかりに圏点や各種の傍線まで、紙の本そのままに再現してくれる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "Odan mo iya, Tinco Sa![＃数字は１字下げ、説明は３字下げ］１、ちのは雅言のとやなり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "【＃ここより３字下げ】　哲学の出立点については多くの議論があることであろう。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "【＃字下げおわり】　多と一との絶対矛盾的自己同一として自己自身によって動き行く世界においては、主体と環境とが何処までも相対立し、それは自己矛盾的に自己自身を形成し行くと考えられる世界である、即ち生命の世界であるのである。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "章立て、字下げ、ルビの付け方などのテキスト入力方法は、そのつど取り決めていく予定だったのである。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむをえず負える靴をとりおろして穿ち歩むに、一ツ家のわらじさげたるを見当り、うれしやと立寄り一ツ求めて十銭札を与うるに取らず、通用は近日に廃せらるる者ゆえ厭い嫌いて、この村にては通用ならぬよしの断りも無理ならねど、事情の困難を話してたのむに、いじわる婆めさらに聞き入れず。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
