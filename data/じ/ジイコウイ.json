        "examples": {
          "standard": [
            {
              "text": "性教育の授業で、自慰行為は自然な生理現象だと説明された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "思春期の少年は、自慰行為について友人には相談しにくいと感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自慰行為は個人のプライベートな行為であり、他人に強制されるものではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は本気で妻に自慰行為を進めようと思わぬでもない。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
