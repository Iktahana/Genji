          "standard": [
            {
              "text": "転居した際は、１４日以内に役所で住所変更の手続きを行ってください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「インターネットプロバイダーに、住所変更の連絡をしました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「住所変更、忘れないようにしないと、郵便物が届かなくなっちゃう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それから五六日過ぎて、おくれ馳せながら先日の見送りの礼と、転任の挨拶とを兼ねた活版刷りの住所変更通知が届いたが、雪子からはそれきり何の便りもなかった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
