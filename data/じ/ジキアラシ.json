        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強力な太陽フレアが発生し、地球の磁気嵐が心配されている。",
              "text_en": "A powerful solar flare occurred, raising concerns about a magnetic storm on Earth.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "磁気嵐の影響で、通信障害が発生する可能性がある。",
              "text_en": "There is a possibility of communication failures due to the effects of the magnetic storm.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オーロラは、磁気嵐によって引き起こされる美しい現象だ。",
              "text_en": "Auroras are beautiful phenomena caused by magnetic storms.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "浄き衣せしたはれめの、　　　ソーファによりてまどろめる、はてもしらねば磁気嵐、　　　かぼそき肩ををののかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、時折、わが太陽系を襲う原因不明の強力な磁気嵐は、超大巨人がこの僕たちの宇宙に原子爆撃を試みようとしているのではないか、という事実。",
              "citation": {
                "source": "宇宙爆撃",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが地球の上なら、磁気嵐のせいであるとか、デリンジャー現象だとかいえる種類の不調だったが、こんな宇宙の一角で、そうした原因でこんな不調が起るはずはなかった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうど、非常にひどい磁気嵐にでもあたったようですね。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁気嵐　透谷の『蓬莱曲』が出た。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "性慾の磁気嵐、人生の球体面に拡大する黒点、混迷と惑乱のみなもと、それもいつしか過ぎ去った。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
