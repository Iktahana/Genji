        "examples": {
          "standard": [
            {
              "text": "大手スーパーは、産地から顧客への野菜の直達サービスを開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この商品は、メーカーから消費者へ直達で届けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "直達便を利用すれば、より早く荷物が届く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その舟路を右にし、またこれを左にし、浪に激し風に逆らい、数十百里の海を経過するも、その直達の路を計れば、進むことわずかに三、五里に過ぎず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中四十八渓、険※千仭、奇巌層層、直達山頂、疎松参差点綴其間、又雑以奈樹柞樹、奇勝万千、不遑応接。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
