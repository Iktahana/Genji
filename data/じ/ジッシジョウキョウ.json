          "standard": [
            {
              "text": "プロジェクトの実施状況を定期的に報告してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "関係各所に問い合わせ、実施状況を確認する必要があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「現在の実施状況を鑑みると、目標達成は困難かもしれません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "問題の条項の実施状況及びそれがもたらす結果がまさに右に述べた如きものであるとすれば、吾々は貧民に対して許し得ない詐欺を行ったのであり、到底実行の出来ないことを約束したのだ、ということになる（訳註）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
