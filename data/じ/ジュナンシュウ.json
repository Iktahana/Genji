        "examples": {
          "standard": [
            {
              "text": "受難週の間、キリスト教徒はキリストの苦しみを偲んで節制した生活を送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受難週の金曜日には、キリストが十字架にかけられたことを記念する礼拝が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受難週が終わると、待ちに待った喜びのイースターがやってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ナースチャがもらって来た書類は、二つ折になって食堂の棚の上にのったまま受難週間になった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーニャ　わたしがここを発ったのは、御受難週間（訳注　大斎期の第五週）で、まだ寒いころだったわ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一夜あければ＊御受難週の月曜日という晩おそく、とつぜん不吉なノックの音が門口でした。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "御受難週――復活祭にさきだつ一週間。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
