          "standard": [
            {
              "text": "充足理由律とは、「根拠なしには何ものも存在しない」という論理学の基本原則だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ショーペンハウアーは、充足理由律の四重の根拠について詳細な論文を書いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "充足理由律を否定してしまうと、我々の認識そのものが成り立たなくなる恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "前者においてはその直觀的確實性は矛盾律にもとづき、後者においてはその事實的現實性によつて保證された可能性はなほ充足理由律に從つての説明を必要とする。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
