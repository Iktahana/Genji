        "examples": {
          "standard": [
            {
              "text": "バスの中ほどにある乗降口が狭いため、降りる人を優先して待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新型車両は乗降口が広く設計されており、車椅子でもスムーズに通れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "発車間際に乗降口に駆け込むのは、大変危険ですのでおやめください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　二人の制服巡査が、両方の乗降口に残って他のは出て行った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方の乗降口に立っていた制服巡査は飛び下りた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはというので、それに少々腹も空き加減の、恰もよしというところで、乗降口からレールへ飛び下りると、また駈け上って、「おい、パン。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜は強い肘を張ってミチミのために乗降口の前に道をあけてやった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、乗降口と反対の方の車掌台に立っている二三人と、車内の吊革にぶら下ってる人々とから、物珍らしげな視線が一時に集ってきた。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの狭い乗降口に押し合ったら、カヤノはひとたまりもなく圧しつぶされてしまう。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗降口で、ふとかれは、あの皮帽の男を――ともかく重大な結果を生じたこの滞留の伴侶をさがしてみよう、と思いついた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
