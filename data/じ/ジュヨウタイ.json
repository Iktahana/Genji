        "examples": {
          "standard": [
            {
              "text": "熱は、皮膚にある温度受容体によって感知される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "味覚は、舌にある味蕾という受容体によって生まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "目は、光受容体である視細胞で光を捉え、視覚を生み出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
