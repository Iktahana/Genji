        "examples": {
          "standard": [
            {
              "text": "白いワンピースを身にまとった彼女は、まさに純情可憐という言葉が相応しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "純情可憐なヒロインが登場する恋愛ドラマは、幅広い世代から人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の純情可憐な容姿の裏に隠された、意外な勝負師の一面を知って驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "純情可憐な葉子やタコスケにそれを知られて心配をかけてはこまるからだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとくして、迷信的とも見うる茶道の廃墟に松風を求めて祈るさまは、それが純情可憐な乙女達の多数を占めるだけに、気の毒でならぬ。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
