        "examples": {
          "standard": [
            {
              "text": "彼は時間を惜しむように仕事に打ち込み、多くの成果を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代は、時間を惜しんで図書館で勉強した記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「時間を惜しんで取り組めば、必ず良い結果が出るはずだ」と先生は励ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女が自分自身の時間を惜しむ近頃の癖から、もう一つは口やかましい祖父に対する反感から、眠り果てぬ眠りを装うているのだということは、祖母も母も感付いていた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　美に親しむ心、自然に親しむ時間を惜しむな。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時間を惜しむ彼にとって、この仕事がどのくらい辛かったかは想像するまでもない事です。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は時間を惜しむ余り、かうした休暇をも何かしら他の班の兵たちの及ばない智識を得させたいと思つたのであつた。",
              "citation": {
                "source": "怒れる高村軍曹",
                "author": "新井紀一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
