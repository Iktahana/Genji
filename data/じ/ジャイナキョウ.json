          "standard": [
            {
              "text": "ジャイナ教の信者たちは、あらゆる生命を尊び、殺生を徹底的に避ける厳しい戒律を守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "インドの古都で、繊細な彫刻が施された美しいジャイナ教の寺院を訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "比較宗教学の講義で、ジャイナ教の教義が仏教やヒンドゥー教に与えた影響について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それ故マホメット教もバラモン教も、ジャイナ教もいずれも面白いと思います。",
              "citation": {
                "source": "我が宗教観",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
