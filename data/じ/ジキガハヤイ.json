        "examples": {
          "standard": [
            {
              "text": "まだ計画の初期段階なので、具体的な日程を決めるのは時期が早い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が次のプロジェクトリーダーになるという話は、まだ時期が早いと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、桜の開花が例年よりも時期が早いようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそのことを語るにはまだ時期が早い（六）。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としては、まだ少し時期が早いと思つてゐたんですが、なに適当な相手さへ見つかれば、時期は何時だつてかまひません。",
              "citation": {
                "source": "頼母しき求縁（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を高頭君の太陽暦年表に拠って換算すると、十一月二十一日となるので、山の展望には少し時期が早いし、雪も浅間にはまだそう積っていない筈であるから、明瞭に望見し得なかったのは当然である。",
              "citation": {
                "source": "嘉陵紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてゝ加へて、京都や大阪は東京よりも衣更への時期が早い。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、まだ時期が早いので、何の準備も出来ていない。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
