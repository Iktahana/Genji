        "examples": {
          "standard": [
            {
              "text": "彼女は肌がとても綺麗なので、実年齢よりも10歳以上は若く見えるとよく言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アンケートには、実年齢ではなく「精神的な若さ」を答える項目があり、彼は迷わず20歳と書いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "実年齢に関係なく、新しいことに挑戦し続ける姿勢こそが、人を若く保つ秘訣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが老婆にはどう思っても事実年齢から云へば五十にも六十にもなってゐる筈の娘を考へることは出来なかった。",
              "citation": {
                "source": "霜",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の文章を書いた、先生は戸籍面四十歳、実年齢三十八歳であった。",
              "citation": {
                "source": "初めて西田幾多郎の名を聞いたころ",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
