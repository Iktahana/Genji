        "examples": {
          "standard": [
            {
              "text": "哲学の授業で、デカルトの実体論について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の思想は、一元論的な実体論に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代科学は、古典的な実体論とは異なる視点を提供する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実体論から認識論にまで進んだのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "このライプニツ主義とデカルト主義との対立――ライプニツはデカルトの幾何学主義に対して力学主義を押し立てることによってその存在論への動機を得ている――は、単に存在論＝実体論の上での対立ではなくて、自然哲学（現代の言葉では）＝自然科学の上での対立なのである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
