        "examples": {
          "standard": [
            {
              "text": "古い蔵から見つかったのは、不気味な文様が刻まれた呪具だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祈祷師は怪しげな呪具を手に取り、呪文を唱え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その呪具に触れた者は、一生解けない呪いにかかると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "採物は、其一つ／＼が、此鎮魂呪術に用ゐる呪具だつたのだらう。",
              "citation": {
                "source": "神楽記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
