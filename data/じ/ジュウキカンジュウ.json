        "examples": {
          "standard": [
            {
              "text": "敵陣から重機関銃の激しい銃撃があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "陣地の要所に重機関銃が配備されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重機関銃の連射音が、戦場の空気を切り裂いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どこからどこへ行くのか、重機関銃をもった一隊の兵士が、粛々と声もなく通りすぎていった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船の胴中からも、重機関銃や、機関砲が、オレンジ色の焔を吐いて、敵機に、いどみかかった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊夫、戦地からかえってはじめてなのです、重機関銃で一ヵ年行って居りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
