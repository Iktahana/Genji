        "examples": {
          "standard": [
            {
              "text": "山奥の古刹の境内には、苔むした岩の上に表情豊かな十六羅漢の石像が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「十六羅漢の一人ひとりの顔をよく見ると、誰かに似ているような気がしてくるから不思議だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仏教美術の講義で、十六羅漢がそれぞれどのような徳を象徴しているのかについて学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "楼上には釈迦に十六羅漢があるはず。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六羅漢の後に五、六歳の少女が独りで寝泊りしていたが、この少女なかなか利発もので生徒を驚かしていた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の内部も廣くて、古い十六羅漢の木像なぞを置き並べた部屋もあつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪幅二掛一対墨画十六羅漢明兆画とありて印なし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後になっては画家の鏑木雪庵さんに頼んで、十六羅漢の絵をかいて貰って、それを陳列して参詣の人々を仁王門に上らせてお茶を飲ませた事がありました。",
              "citation": {
                "source": "寺内の奇人団",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
