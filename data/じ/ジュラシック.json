        "examples": {
          "standard": [
            {
              "text": "ジュラシック・パークという映画は、恐竜の世界をリアルに描いた名作だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このジュラシックな風景は、まるで太古の地球に迷い込んだかのようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館で展示されているジュラシック時代の巨大な骨格標本は圧巻だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "スティーブン・スピルバーグによって映画化された、マイクル・クライトンの『ジュラシック・パーク』と、ルーイス・キャロルのアリス物を集めてたっぷり注釈を付けた『ザ・コンプリート・アノテェイティッド・アリス』です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
