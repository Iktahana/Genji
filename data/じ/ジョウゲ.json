        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地図の上下を確認してから、目的地に向かって歩き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "写真の上下が逆だと、せっかくの風景が台無しだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "画面の上下に黒い帯が入っているのは、映画の比率のせいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
