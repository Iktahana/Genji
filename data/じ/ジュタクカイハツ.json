        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大手家電メーカーからの受託開発として、新型炊飯器の制御ソフトを設計した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この工場では、海外ブランドの受託開発によるスマートフォン生産を請け負っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うちは受託開発がメインだから、ロゴは相手方のものになるんだ」とエンジニアが説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
