        "examples": {
          "standard": [
            {
              "text": "出荷前の検品で、いくつかの箱に重量不足があることが判明し、全品再計量となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おばちゃん、このお肉ちょっと重量不足じゃない？測り直してみてよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "肥料の袋に表示されていた重さと実態が異なり、農家から重量不足の苦情が寄せられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あんたなんて規定重量不足の金[99]のようなみっともない女だったのよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
