        "examples": {
          "standard": [
            {
              "text": "この道路は自動車専用道路なので、歩行者や自転車は立ち入ることができない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、自動車専用道路に入ったら急に道が広くなったね！スピードの出し過ぎに気をつけよう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自動車専用道路を走行中は、後続車との車間距離を十分に空けて安全運転を心がける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十国峠までの自動車専用道路からの眺望は美しく珍しい。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自家用自動車専用道路が公園を貫いて走った。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
