        "examples": {
          "standard": [
            {
              "text": "ローマ神話に登場する女神ジュノーは、結婚と出産を司る最高位の女神として崇められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「6月の花嫁（ジューン・ブライド）」の語源は、女神ジュノーに守護される月であることに由来する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ルネサンス期の画家たちは、威厳に満ちたジュノーの姿を数多くの神話画に描き残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジュピターの妻ジュノーの嫉妬がつのって、到頭哀れなアナキネはジュノーのために蜘蛛にさせられてしまった。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュノーとアナキネの関係が織り紡ぐ仕事における奴隷と主人との関係、義務を与えるものと、義務づけられたものとの関係を語っている。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュピターとジュノーの間に生まれた息子で、美丈夫の典型とされている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、ジュネーヴから後任にジュノー博士を送りたいといってきているが、アメリカ経由で来るのはいかんとかなんとかしきりに反対している始末だから」「公認慈善団体の軍の認可を得るには、どのへんへぶつかればいいのか。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイレル老人をして、自分の孫娘はリュドヴィジのジュノーに似た鼻をもってると断言させるには、彼に多く説きたてるの要はなかったろう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
