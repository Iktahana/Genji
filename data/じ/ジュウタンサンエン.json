        "examples": {
          "standard": [
            {
              "text": "炭酸飲料には、二酸化炭素の他に重炭酸塩が含まれていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "血液中の重炭酸塩濃度は、酸塩基平衡の指標となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "温泉水には、様々なミネラルとともに重炭酸塩が豊富に含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また硬度が石灰の重炭酸塩＝炭酸水素塩の存在だけによるとき（＊一時硬水）は、単に沸騰によって非常に良くすることができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡蠣殻粉とカリウムまたはナトリウムの重炭酸塩が普通この目的に使われる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
