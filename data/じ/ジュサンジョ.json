        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母は近所の授産所で、内職の仕事を手伝いながら交流を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "授産所への通所が、彼にとって日々の生活にハリを与える大切な習慣となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害支援の一環として、被災地に臨時の授産所が設置されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人民のための人民共和の政府がもたらされなければ、結局、婦人のために保育所一つ、授産所一つ作られないことが、わかって来たのは必然であると思う。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "授産所の村井ともう一人の女を関係して居る。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか数えきれないほどの、そのときばったりの仕事をみえも外聞もなくやったうえ、いまでは躰力も弱ったのだろうか、家におちついて、授産所からまわってくる内職を専門にやるようになった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
