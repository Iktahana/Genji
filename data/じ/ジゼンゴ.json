          "standard": [
            {
              "text": "事件が発生し、事後、捜査が開始された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "当初の決定が下され、その長期的影響は事後に評価された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は軽率な発言をしたが、その事後の謝罪は損害を回復するにはほとんど役立たなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それはことに今日初めて見る風景でもなかったが、食事前後にわたってかなり長い時間のことなので、ナイフを使いながら窓から見下ろしている均平の目に、時節柄異様の感じを与えたのも無理はなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君を追出してまた迎る事前後三人。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "学業を卒って英国に遊ぶ事前後二回還来って既に年あり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
