        "examples": {
          "standard": [
            {
              "text": "漢文の授業で、具体的な事物を表す実字と、語調を整える助辞である虚字の違いを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この詩において「山」や「川」といった実字は、作者が実際に見た風景の力強さを象徴している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文中の実字を抜き出してリスト化することで、その文章が何を主題にしているかが明確になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "町々つじつじの警備に出払ってしまってひっそり閑と静まり返っているお番所の中へさっさとはいっていくと、てこでも動くまいといいたげに、どっかりすわったところは訴状箱の前でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時のごとく目にはいったものは、町々つじつじを堅めているものものしい捕方たちの黒い影です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
