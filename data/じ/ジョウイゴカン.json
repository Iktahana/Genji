        "examples": {
          "standard": [
            {
              "text": "データの形式を工夫し、将来の拡張機能に対しても上位互換性を持たせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "低スペックの旧機種でも、新形式のファイルが開けるよう上位互換を確保した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、古いプレーヤーでもこの新しいディスクが再生できる！ 上位互換だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
