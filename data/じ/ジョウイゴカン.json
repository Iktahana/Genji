        "examples": {
          "standard": [
            {
              "text": "この新しいソフトウェアは、旧バージョンのデータとも上位互換がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "上位互換のおかげで、古い周辺機器を捨てずにそのまま使い続けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最新のハードを買ったけど、前のソフトが動くから上位互換で助かったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが日本の標準が六四〇×四〇〇に張り付いたままでいたこの十年間に、ＩＢＭは上位互換のビデオ規格を一歩一歩積み上げていった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
