        "examples": {
          "standard": [
            {
              "text": "個人の尊厳を守るためには、自らの生き方を決める自己決定が尊重されるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "終末期医療において、患者本人の自己決定をどう支援するかが課題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲の意見に流されず、自分の将来については自己決定の精神を貫きたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自由な自己決定の代りに、自然そのものの自己決定か又は自然が吾々を外部から決定することかが、実験に決定を任せるということに外ならない。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
