        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ファッション雑誌は、最近のＪＫの流行をよく反映している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は憧れのＪＫブランドのバッグを手に入れて、とても喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、あのカフェ、ＪＫに人気らしいよ。」「へぇ、行ってみようか！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ビクターには小シュナーベル（カール）が五枚入れているが、フリートマンほどの独創もない代り手際の良い器用な演奏である（ＪＫ四―八）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スラヴ舞曲」はターリッヒ指揮でチェコの管弦楽団がかなり入れている（ビクターＪＨ一四九―五二、ＪＫ四六―五〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはエーリッヒ指揮（コロムビアＪ五五〇〇）と、フィードラー指揮（ビクターＪＫ五五）とふた通りある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターの『さすらい人』（ＪＫ九）は、この曲から我々が聴き馴れた劇的な誇張はないが、申し分なく立派で、ヒュッシュの正直な表現に、多少の食い足らなさと安心を感じさせる。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
