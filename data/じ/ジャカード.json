        "examples": {
          "standard": [
            {
              "text": "ジャカード織りのネクタイは、その重厚な質感と上品な光沢がビジネスマンに好まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はジャカード生地で作られた華やかなドレスを身にまとい、パーティー会場に現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このカーテンはジャカードで複雑な模様が織り込まれており、部屋の雰囲気をぐっと引き立ててくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そんな中で統計技官のヘルマン・ホレリスは、紋様の織り込みを自動化したジャカード織機と自動ピアノから、統計表作りの革新のヒントを得る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャカードも自動ピアノも、カードにあけた穴の位置によって機械の動作を制御している点に着目したホレリスは、個人のデータを一人一枚同様の穿孔カードに記入することで、集計から手作業を追放できると考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
