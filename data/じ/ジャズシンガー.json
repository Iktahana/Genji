          "standard": [
            {
              "text": "彼女はスモーキーな歌声を持つジャズシンガーとして、都内のライブハウスを中心に活動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝説的なジャズシンガーであるエラ・フィッツジェラルドの歌唱法を、彼女は熱心に研究した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「次の曲は、私たちの尊敬するジャズシンガーをゲストに迎えてお送りします」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は南原杉子とわかっていても、舞台にいる人をジャズシンガーと思っているのだから、先入観念と、今の印象がごちゃまぜになって解し難いのだ。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この女史、ジャズシンガーだよ」　南原杉子は、マッチの火をちかづけてくれるその娘ににっこり笑った。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
