        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は飲み会での気の利いたジョークで、気まずい空気の潤滑油になってくれる存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ユーモアのセンスは、ギスギスした人間関係を円滑にするための最高の潤滑油だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の細やかな気配りが、個性の強いメンバーが集まるチームの潤滑油として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
