        "examples": {
          "standard": [
            {
              "text": "走・跳・投の全種目で高い能力が求められる十種競技の勝者は、「キング・オブ・アスリート」と称えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は十種競技の最終種目である1500メートル走で、最後の力を振り絞ってゴールした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複数の競技をこなす十種競技は、選手同士の絆が非常に強いことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は陸上競技も当時日本の第一人者で、オリムピックでは十種競技にでたように記憶する。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、オリムピックの一次予選で、兼吉選手が十種競技の走幅跳に二十尺五寸で、日本新記録であったが、六米ちょッとで今の日本の女子記録と同じぐらいである。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
