        "examples": {
          "standard": [
            {
              "text": "中世ヨーロッパの農民たちは、収穫物の十分の一を教会に納める十分の一税の義務を負っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "十分の一税は教会を支える財源となったが、貧しい人々にとっては重い負担だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宗教改革の時代、多くの人々が不当な十分の一税の廃止を求めて立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "実際この時期の遥か以前に極めて低い利潤率がすべての蓄積を制止しているであろう、そして一国のほとんど全部の生産物は、労働者に支払った後に、土地の所有者及び十分の一税と租税との受取人の財産となるであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「どうして十分の一税になさいませんか。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「十分の二税を課しても足りないのに、十分の一税になど、どうして出来るものか。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は自分の十分の一税を払うのである、」と彼は言っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
