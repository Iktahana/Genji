        "examples": {
          "standard": [
            {
              "text": "敵の攻撃をかわしながら、時間を稼ぐ作戦だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションの準備が間に合わないので、時間を稼ぐために質問をしてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、この間に時間を稼いで、援軍を待とう！」と彼は叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現代の独占資本という魔ものがひきおこすあらゆる混乱と矛盾を、魔もののしきたりの下で解決しようと、そのために時間を稼ぐ一つの手段として、それをきいただけでも身の毛のよだつ戦争という脅しの大凧があげられているわけである。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
