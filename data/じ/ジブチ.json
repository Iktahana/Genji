        "examples": {
          "standard": [
            {
              "text": "ジブチはアフリカの角に位置し、戦略的な港湾都市として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの国がジブチに軍事基地を設置しており、国際的な注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ジブチの経済は、港湾業と国際貿易に大きく依存している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "関東平野では是をボッチャラウチまたはボウジブチなどと謂って、以前の籾納のころには厳格に言えば、是が稲作最終の作業であった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
