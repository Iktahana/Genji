        "examples": {
          "standard": [
            {
              "text": "彼は会議で自分の有利な方向に誘導しようと、巧みに術策を弄する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あまり術策を弄すると、かえって周囲の信用を失うことになるぞ」と忠告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正面からぶつかるのを避け、術策を弄して相手を自滅に追い込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "権勢や名誉や物欲のために、恥を忘れて狂奔し、やっきとなって卑劣な術策を弄する人たちにも、彼は同じことを問いかけたかった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
