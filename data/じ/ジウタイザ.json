        "examples": {
          "standard": [
            {
              "text": "能楽堂の地謡座には、黒衣の地謡方が静かに座っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地謡座から聞こえる歌声は、舞台全体に深みを与えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観客は、地謡座に目を向け、演者との一体感を感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは翁の最後のお能のお稽古であったが、翁は地謡座の前の椅子に腰をかけ、前に小机を置いてその上に置いた張盤を打って朔造氏の型を見ていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから翁はワキ座と地謡座のちょうど中間の位置に在る張盤の前に敷いた薄い茶木綿の古座布団上に座る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
