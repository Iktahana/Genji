        "examples": {
          "standard": [
            {
              "text": "データベースのレコードに、一意の順序番号を自動で割り当てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通信プロトコルでは、パケットの欠落を確認するために順序番号が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受付表に印字された順序番号が呼ばれるまで、ロビーでお待ちください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この「新配列」なるものはくわしく紹介するいとまはないが、その結論だけを現行の章の順序番号で置き変えると、１・４・２・３・５・６・９・７・８・10という順序となり、そのあいだに残されている小断片をはさむというのである。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
