        "examples": {
          "standard": [
            {
              "text": "彼は業界の裏事情に非常に詳しく、周囲から情報通として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美味しい店のことなら、食べ歩きが趣味の情報通である彼女に聞くのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政治の世界に精通した情報通の記者が、特ダネを次々とスクープした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国際関係のものは勿論のこと、営利専門のものもあるし、情報通信のもの、経済関係のものなどと、ずいぶんいろいろの諜者が活躍をしていた。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の情報通は、虚と実のけじめもなく、そんなことをガヤガヤ話しあいながら、裸馬の三途行列を、首を長くして、待っていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
