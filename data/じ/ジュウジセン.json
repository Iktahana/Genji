          "standard": [
            {
              "text": "スナイパーはスコープの十字線を標的に重ね、静かに引き金を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天体望遠鏡のファインダーにある十字線を使って、観測したい星を中央に捉える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グラフィックソフトで正確な位置を決めるため、画面に十字線を表示させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "顔面の他の部分の表現が鼻を中心として飛び違うために、その十字線が丁度鼻の上に結ばって一種の錯覚を起すものである。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
