    "definitions": [
      {
        "index": 1,
        "gloss": "statue (of a living person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社の創業50周年を記念して、本社のロビーに名誉会長の等身大の寿像が設置されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の寿像を贈られた恩師は、「生きている間に銅像になるのは何だか照れくさいね」と笑っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公園の一角に立つ立派な寿像は、この町の発展に尽力した前町長の功績を称えて作られたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
