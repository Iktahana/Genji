    },
    "definitions": [
      {
        "index": 1,
        "gloss": "receiving (a donation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館は、著名な収集家から長年かけて集められた貴重な陶磁器のコレクションを受贈した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "匿名で多額の寄付金を受贈した社会福祉法人は、それを元手に新しい福祉車両を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "土地の受贈に伴い発生する税金の手続きを行うため、専門の税理士に相談することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ポストまで出かける、緑平老へ第二の詫状をおくる、岔水、多々桜君へ受贈本をそれ／″＼送る、この送料はけふこのごろの私にはこたへた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
