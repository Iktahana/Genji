        "examples": {
          "standard": [
            {
              "text": "古いテレビ番組のアーカイブは、すべて磁気テープに記録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、彼は磁気テープに好きな歌を録音して遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "磁気テープは、大容量データの長期保存に適している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "オペレーターが実際やる仕事のほとんどは磁気テープや磁気ディスクの交換など、単純な作業である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁気テープを使った記憶装置を付け加え、ハードウエアを改良したＴＸ―２も、ディスプレイとライトペンを受け継いだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナレーションと音楽の磁気テープをフィルムに光学録音しなおし、オプティカルもすませた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
