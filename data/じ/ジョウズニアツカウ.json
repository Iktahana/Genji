        "examples": {
          "standard": [
            {
              "text": "彼は扱いにくい機械でも、驚くほど上手に扱う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "反抗期の息子を上手に扱うのは、父親よりも母親の方が長けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "繊細なガラス細工なので、慎重かつ上手に扱ってください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "銀色の玉が転り出るのを上手に扱うのです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守居の心得子供を上手に扱うこと　主婦が外に出て、何よりも心にかかるのは子供のことです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守居の心得の中には、子供を上手に扱うということ、早めに仕事にかかるということ、それから臨時の出来事に気働きのある処置をすること、金銭の出し入れのあいまいにならないように、報告すべき用事を忘れないように気をつけることなど、ほとんど主婦の一家をおさめると同じだけの働きがみなことごとく含まれています。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
