        "examples": {
          "standard": [
            {
              "text": "この希少植物は、特定の自生地でしか見られないため、保護が急務となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "調査隊は、絶滅危惧種の動物の自生地を特定し、生態を記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この地域には、古代からの独特な自生地が残っているんですよ」とガイドは説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "竹原村大字宮地の川合平に日本に珍しい枝垂栗の自生地がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この栗の自生地は他にシナノの某山その他二三しか見られない由であるが、この木のある所は立山から尾根を通る神様の休憩地だから、これに触れると神罰をうけて病気にかかる、と里人は怖れて伐ることがなかったから今日に残ったと里人に信ぜられている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの大形のフキもその自生地を除いては、そう諸方には作ってはなく偶にこれを見るのみである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
