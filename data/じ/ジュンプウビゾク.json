        "examples": {
          "standard": [
            {
              "text": "その地域は、古くから醇風美俗が保たれており、住みやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統的な祭りには、醇風美俗を次世代に伝えるという意味合いがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代社会では、醇風美俗の重要性が見失われがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "＊　醇風美俗といふ言葉がある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでのやうに、警察が醇風美俗に反するといふ裁定を下すなどといふことは、これこそ醇風美俗に反するやうに私は思ふ。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　世の中が醇風美俗ばかりになることはちよつと淋しいやうな気がする。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、醇風美俗を誤りなくそれと感じる感覚だけは、人間の人間らしさとして飽くまでも尊重したい。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に日本の支配者は民衆に家族主義という醇風美俗を、日本的なものとして押しつける。",
              "citation": {
                "source": "日本の民衆と「日本的なるもの」",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
