        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "相手のわずかな油断に乗じて、一気に勝負を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "混乱に乗じて悪事を働く者が出てこないよう、警戒を強める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "景気回復の波に乗じて、新規事業を立ち上げるチャンスだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夕刻事務所から早く帰った日には、皆でテーブルを囲んで夕飯をたべ、後は談笑したり、音楽をきいたり、興に乗じると、昔ロンドンでアーヴィングが演ったハムレットの真似だと云って、芝居の真似をしたり、賑やかでした。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信のある女性にはこの手で乗じる。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるうえは一｜刻もはやく、小太郎山のとりでへ帰って、一｜党の面々にこのしまつをつげ、いよいよ兵をねり陣をならし、一｜旦の風雲に乗じるの備えをなすこそ急務である――と思ったのである。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しでも、防戦のゆるみを見せれば、その虚は、ただちに敵の乗じる機会となるからである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
