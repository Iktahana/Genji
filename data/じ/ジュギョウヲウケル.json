        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "憧れの教授の授業を受けるために、彼は遠く離れた街の大学へ進学することを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オンラインで授業を受ける形式が定着し、自宅にいながら世界中の講義を聴けるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一度も欠席することなく授業を受け続け、ついに最優秀賞で卒業した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私とそれからもう二人の子供はかなりうまく答えたというので、この日から三人は五級にいって授業を受けることになった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "代って、西村先生や、礒田先生から授業を受ける。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともある場合には、――例えば授業を受ける時とか、兵隊になった時とか、また寄宿舎でも軍隊生活を主位におくとか――すべてそう云った場合には多少この高圧的手段は免かれますまい。",
              "citation": {
                "source": "私の個人主義",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなやつは、おれを居残りにして、そのままにして、平気で授業を受けるんだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、午前中に授業を受ける者のことを朝組と云い、午後から行く者のことは昼組と云った。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
