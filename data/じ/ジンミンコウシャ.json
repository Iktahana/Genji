          "standard": [
            {
              "text": "中国では、かつて人民公社制度が導入されていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人民公社は、農業生産の集団化を目指した組織でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの頃は、人民公社でみんな一緒に働いていたんだよ。」と、祖父は昔を懐かしんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "とくに過日農業博覧会において農作物の爆発的な増産をする姿をみ、また工場建設の飛躍的な発展をみまして、とくに人民公社に深い感銘をおぼえたのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
