        "examples": {
          "standard": [
            {
              "text": "体育の時間の最初に、全員で輪になって柔軟体操を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高齢者向けの柔軟体操教室が、公民館で毎週開催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デスクワークの合間に軽い柔軟体操をして、肩こりを解消する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "毎朝柔軟体操をやる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三十分間柔軟体操をやる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しばらくは、柔軟体操をつづけた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時半　　　　ランスロット式柔軟体操。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ上半身や左右の手や腰部などで、種々なるところの挙動を示すが、これは柔軟体操ではなくしていわゆる「嬌態」であるらしい。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん初期のことで服装もそのまま両袖を結んだり、襷をかけたり、中には両肌脱ぎのシャツ一枚、不体裁お構いなし、柔軟体操からダンベル（亜鈴）、球竿、クラブ（徳利形の木製具）など相当重い奴を大汗になって振り回す、嫌々ながら物事すべて新規だから苦情もいえず、いったところで幹事や先生の一喝に縮みあがる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
