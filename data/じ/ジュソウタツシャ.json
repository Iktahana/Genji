          "standard": [
            {
              "text": "裁判所からの重要な通知書は、法律で定められた受送達者である本人に直接手渡すのが原則だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受送達者が長期不在のため書類を届けることができず、郵便局に一旦保管されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受送達者の住所が不明な場合、公告という手続きを経て書類が届いたものとみなされることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「受送達者支倉喜平を市ヶ谷刑務所につき取調べたるに別紙符箋之通り死亡せし旨田辺看守長より申出につき送達不能、依って一｜先及返還候｜也」　続いて市ヶ谷刑務所より控訴院検事長に宛て左の公文が到達した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
