          "standard": [
            {
              "text": "飢餓に苦しむ地域では、栄養強化された人造米が食糧として配布された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この健康食品は、こんにゃくを原料とした人造米で、糖質を抑えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時の非常食として、長期保存が可能な人造米が注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人工米は人造米ではないので、これは本当の米である。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
