        "examples": {
          "standard": [
            {
              "text": "送信側が暗号化しても、受信側が復号キーを持っていなければ読めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受信側の設定によっては、画像付きメールが正しく表示されない場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットワークの遅延により、受信側で映像がカクつく現象が起きている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで、一時、戦軍総司令部を呼び出すことをやめて、その代りに、空中から司令部の電波をキャッチしようと、回路を受信側に切りかえ、受話器を耳にかけた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラゴーフは今度は受信側の研究に移った。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
