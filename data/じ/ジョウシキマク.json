        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歌舞伎の舞台に黒、柿、萌黄の三色の定式幕が引かれ、いよいよ開演となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幕間に定式幕を眺めながら、次の演目の筋書きをプログラムで確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定式幕の色合いは、江戸時代の芝居小屋の伝統を今に伝える象徴的なものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鳴物入り道具ばなしと肩へ書かれてある定式幕、縁とりの辻びらを見て、圓朝はオヤッと目を疑った。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "背負っていった大風呂敷を持って彼は、舞台のほうへ出かけてゆくと、定式幕や野遠見の背景や小道具の稲叢を飾りつけた。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
