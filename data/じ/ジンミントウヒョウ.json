        "examples": {
          "standard": [
            {
              "text": "その問題については、人民投票によって最終的な決定がなされる予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人民投票の結果、国民は独立を支持しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、人民投票で決めるの？それは民意が反映される良い機会だね。」と、彼は興味深そうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "十五億九千万円の動産と百三十五万町歩の土地とをもつ日本の君主は、この波瀾万丈の日本全土を巡って、自身の宣戦によって戦争が引起され、全人民の生活が破壊されている光景を前に、人民投票をさせようとしている。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「廊下」地帶の人民投票に依る歸屬決定。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、人民投票準備期間を一箇年とすること。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一つの「何故」への具体的な答えには、農林大臣が米の専売案を語り、それと全く反対に農林省の下級官吏は結束して大会をもち、食糧の人民管理を要求し、戦争犯罪人糺弾の人民投票をやっているという今日の事実さえも、包括されなければならないのである。",
              "citation": {
                "source": "石を投ぐるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
