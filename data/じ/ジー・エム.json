    "definitions": [
      {
        "index": 1,
        "gloss": "general manager",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このプロジェクトの成功は、GM（ゼネラルマネージャー）のリーダーシップのおかげです」とチームメンバーが感謝を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホテルのGM（総支配人）は、お客様に最高のサービスを提供するために日々尽力しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい事業計画について、GM（事業部長）から承認を得る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三日後、ニューヨークは五番街のティファニイで日本人ギャルの「ウッソー、ホントにー」をＢＧＭに、慶子ちゃんの品定めに付き合っているうちに、突如体中のリンパ腺がトラフグを怒らせたように膨れ上がり、猛烈な悪寒とともに下腹が鳴り始める。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジョンは、ＢＧＭにはしないんだ」「ジョンて、ジョン・レノンのことですか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六部　特殊広告　ＧＭパワラマ　二十ページ。",
              "citation": {
                "source": "アメリカの新聞",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　サイバネティック・スキゾイドの『インビジブル・スレッド』がＢＧＭに流れてくる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　ＢＧＭに『インビジブル・スレッド』。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の顔が画面に入るか入らないかぐらいのときにＢＧＭスタートだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらずＢＧＭはボリュームいっぱいにかけてあるにもかかわらず、とても静かな店だと隼人は感じた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上一流ミュージシャンの演奏による数億種類ものＢＧＭの中から、コンピュータがその場にふさわしい曲を適宜に選択するので、気分はもうファンタジーランドの主人公！",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、このＢＧＭは何なのだ。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にかＢＧＭは聞き慣れた軽快なテンポの音楽に変わっている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからともなくロマンチックなＢＧＭが流れてくる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時半、タクシー出て、フィルムビル、ＭＧＭ試写室。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時からＭＧＭの試写あり、タクシー、久々のフィルム・ビル。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＧＭ試写室、「熱いトタン屋根の上の猫」を見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
