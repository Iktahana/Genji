        "examples": {
          "standard": [
            {
              "text": "彼は「常在戦場」の精神を重んじ、いつ何時でも気を抜くことがなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経営者にとって、ビジネスの世界はまさに常在戦場の覚悟が求められる場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師から贈られた「常在戦場」という言葉を、今も座右の銘にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "太平逸楽の頃の落語家にしてなおかつ、この常在戦場の心構えあったのではないかとさえ、むしろ私は叫びたい。",
              "citation": {
                "source": "寄席行燈",
