        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は麻薬に手を出し、ジャンキーになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジャンキーは、社会から孤立してしまうことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、ジャンキーの更生を支援するプログラムを強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ジャンキープラといふ本格歌手を生かした、音楽映画だが、何うも買へない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
