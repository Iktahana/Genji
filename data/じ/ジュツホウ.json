        "examples": {
          "standard": [
            {
              "text": "古い文献には、失われたはずの高度な術法の記述が残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は一族に伝わる秘匿された術法を使い、一瞬で姿を消した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "術法の行使には多大な精神力を消耗するため、十分な休息が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "超短波手術法なんてものが発達して、人間の身体が彫刻をするように楽に、勝手な外科手術をやれるようになった悪結果だよ」「人造人間さえ出来る世の中だから、そんなこともできるわけだわ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法は、手術法と機械代用法とで、前者は後者に比し一千倍高価である。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会法則に還元されて了う限りの芸術法則は今は論外としよう。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象批評にとって気に入らないのは、あらかじめ文献的に設定された芸術法則を以て、様々の姿態の下に刻々現われる作品に天下り式に臨むという、あの文献学的クリティシズムの学究的な愚かさである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術法だけでなく良い外科医に必要な２つのことを学んだ。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
