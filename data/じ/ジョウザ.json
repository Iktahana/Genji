        "examples": {
          "standard": [
            {
              "text": "能舞台の常座でシテがピタリと動きを止めると、会場に緊張感が走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シテ方は常座で名乗りを上げ、物語の幕開けを観客に告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台稽古で、常座での立ち位置がずれないよう何度も足の運びを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "落語家は浪曲を場違いとばかり一蹴し、浪曲師はまた博徒のような気質が日常座臥に殺伐にのこって孤立していた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い星々が滑るように常座に着いた。",
              "citation": {
                "source": "感覚の殻",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は主人としての常座を占め、客のうちでは最も遠慮のない弁信が、最も炉辺に近く座を占め、それにつづいてお雪ちゃん――最後にお銀様は、ずっと控え目に……　それでもやはり、一座の女王気分は失わず、見ようによっては、正座を占めた形で坐っておりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
