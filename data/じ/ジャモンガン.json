        "examples": {
          "standard": [
            {
              "text": "地質調査で、蛇紋岩（じゃもんがん）が多く分布する地域を発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "蛇紋岩から産出される橄欖石（かんらんせき）は、緑色が美しい鉱物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この山脈の地層には、特徴的な蛇紋岩が多数含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その時僕は、あの高洞山のまっ黒な蛇紋岩に、一つかみの雲を叩きつけて行ったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタンコガタンコ、シュウフッフッ、　　凍えた砂利に　湯げを吐き、　　火花を闇に　まきながら、　　蛇紋岩の　崖に来て、　　やっと東が　燃えだした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の近傍は花崗岩、蛇紋岩、古生層、岩から成り、中央の一部に蛇紋岩の認められることが、地質調査所の地図に明示されている。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此辺には蛇紋岩が多く露出しているように地質図には記してある。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
