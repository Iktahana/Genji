    "definitions": [
      {
        "index": 1,
        "gloss": "circulatory system (blood, lymph, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
