        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ワクチンの製造には、ウイルスの弱毒化が必要不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "放射線照射によって、種子の遺伝的な弱毒化が観察された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は病原体の弱毒化技術に関する画期的な論文を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
