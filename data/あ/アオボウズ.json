        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――この赤親仁と、青坊主が、廊下はずれに物言う状は、鬼が囁くに異ならず。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてじぶんたちは、すつぽかされて、青坊主にされて帰るのだと思ふと、松吉は、日ぐれの風がきふに、刈りたての頭やえりくびにしみこむやうに感じられました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と青坊主は、異変を恐れて、船頭に敬意を表した。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と青坊主がひよろ／＼と爪立つて逃げあるく。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、声の下で、囁きつれると、船頭が真先に、続いて青坊主が四つに這つたのである。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺の覚光という青坊主がまたお話にならない堕落坊主で、酒は飲む、博奕は打つ、女狂いはするという奴だから堪まらない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ不思議な事にはいつの間にか眼が潰れて、青坊主になっている。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青坊主があっちで変なさしずをしておりますぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたまりもなく三人の青坊主達はちぢみ上がって、へたへたとそこに手をつきました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふわりと掻きあげておくと、それらの欠点がわからなかつたので、彼は何時も無造作さうに髪の毛を伸してゐたのであつたが、あの下町の二階を飛び出して間もなく、何を、何う思ひついたのか、見るも憎態な青坊主になつてゐた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の中へ一ぱいに大福餅を押込まれたり、あの肥った体で踏んまたがれて、青坊主に剃りたてられるのが愁いのだった。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃のように煩悶が流行した日にゃ」「じゃ、兄さんからなって御覧なさいよ」「酔興にかい」「酔興でも何でもいいから」「だって五分刈でさえ懲役人と間違えられるところを青坊主になって、外国の公使館に詰めていりゃ気違としきゃ思われないもの。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は潰され、法律上の妻には出て往かれ、今は実家の厄介になって居る久さんが、何発心してか今日はまる／＼の青坊主に剃って、手拭肩に独ぶら／＼歩いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はくるくる青坊主、笠をかぶって坊ちゃんの、お家の窓から、のぞきましょう。",
              "citation": {
                "source": "あんずの花",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の頭は青坊主である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……娘の服装で青坊主では足がつくから、尼に見せかけようというので、あんな木蘭色の衣を着せて投げ込んだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼寺の床下が、広い機織場になっていて、牢造りになった暗い穴蔵で、三十人ばかりの青坊主の女が、馬の落毛の撚糸を経糸にし、自分らの髪の毛を梳きこんで呉絽を織らされていた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なんと言っても、いちどは恩になった長崎屋、みすみす自分の妹までが青坊主にされて尼寺の下で呉絽を織らされていることがわかっても、どうすることも出来ない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る十二日の槍祭、お米蔵は三吉の渡し、松前志摩殿の切立石垣に、青坊主の水死人が、それこそ落葉のように笹舟のように、人筏のように、流れ流れて寄ったという。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケシの花がやがて青坊主になる、といふのに意を寓してひつかけた作と見ると、たいへんいや味な句のやうであるが、ただそこいらにさういふ行末のかれんな少年が遊んでゐてかたはらにこの花が咲いてゐたといふ風に、単に叙景の作としてのみうけとると、これもなか／＼面白いいい句である。",
              "citation": {
                "source": "ケシの花",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青坊主に刈ってさえ、ああ大きく見えるのだから、主人のように長く延ばしたら定めし人目を惹く事だろう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、どじょう髯は、そのどじょう髯をつまんで考えこんだが、この得態の知れない青坊主、或は、大言壮語だけで自分を煙に巻いている肚かも知れない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミョムリョジュノライ　すると　なたねばたけの　なかに　うさぎが　いて、「こぼうず　あおぼうず。",
              "citation": {
                "source": "こぞうさんの　おきょう",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
