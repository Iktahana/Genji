    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patriot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛国者は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛国者が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛国者に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛国者が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛国者について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛国者についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛国者について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛国者が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛国者が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛国者は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛国者は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛国者を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛国者をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛国者が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛国者の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛国者を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛国者に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛国者について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛国者は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛国者を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こういう夢を見ることはたいした愛国者でなくてもあまり不愉快なことではあるまい。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野さんがこの書物を始める時、目次によって内容をあらかた話してくれた時、この章に書いてあるのは、アイルランドのある若い勇ましい愛国者と、その婚約の娘との間に起った実際の出来事だといったので、おぬいにはよけい興味のあるものだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は愛国者の血汐を土足に蹂躪し、国家の犠牲を馬鹿者と呼ぶに躊躇せざる也。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の愛国者は、かえって国の悪口を言うものですからね。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては皇城を下瞰するというので一部の愛国者を憤激さしたニコライの高い塔も焼けて、頂上がなくなっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりすると「演説使い」だとか「雄弁売り」――又は時と場合では「偽国士」とか「似而非愛国者」とかいう尊号を受ないとも限りませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにして国運を恢復せんか、いかにして敗戦の大損害を償わんか、これこの時にあたりデンマークの愛国者がその脳漿を絞って考えし問題でありました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども世には真正の愛国者にして国人に捨てられしものその人に乏しからず、耶蘇基督その一なり、ソクラトスその二なり、シピオ、アフリカナスその三なり、ダンテ、アリギエーリその四なり、しかして公平なる歴史家が判決を下すにあたって、これら人士の場合においては罪を国民に帰して捨てられしものの無罪を宣告せり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユダヤ国を攪乱するおそれによってその愛国者を怒らせた。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達人間様が平生愛国者振るくせに我々｜大和犬族の優等なるを忘れて外国種の下等な性質を遺伝いだ雑種犬を珍重するとは何事だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く詩人も亦た其の郷土の愛国者たるは、抜くべからざる天稟の存するあればなるべし。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の校長は一種の愛国者で、琉球人に高等教育を受けさせるのは国家のためにならないという意見を有っていたが、そういうことが動機となって、明治二十八年の秋に、沖縄の中学で未曾有のストライキが起った。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "救いはこんな愛国者からは来ない。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国を侵略したナチス軍が、占領地の愛国者たちをどう扱ったかということについては、世界がなまなましい無尽蔵の実証をもっている。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼の愛国者ソクラテスを牢死せしめたような無智な為政者の干渉なくして、青年たちを教え得る自由な学園が私に与えられるなら私はどんなに心行くことであろう。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自由の中でこそ私は真の愛国者を鉗槌して世に送り出すであろうものを！",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこの先生は一方愛国者であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、学校でギリシア人が死者に生け贄を捧げたとか、彼らが勇敢な男たちや愛国者たちの魂に敬意を払ったとかを読んだことがあるだろう」「そうですね。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "（３）愛国者の人生および世の中に純粋な金言を与えてくれた者の教え（４）孝およびその教師たちの教え、秦の時代に孔子の書物は焚かれた。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はコスモポリタンであるが故に、真の愛国者である。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアの愛国者で大政治家。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、謂ゆる愛国者の側から作者に非難が浴びせられることと思う。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼等がこの巻もそろそろ終りに近づいた頃、まるで小窓からでも覗くように、ひょっこりと不意にここへ顔を覗けた訳は、そんじょそこいらの短気な愛国者たちから受ける非難に、やんわりと一矢を酬いんがために他ならない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその愛国者たちも、今のところ、おとなしく何か哲学みたいなものに憂身をやつしたり、彼等が熱愛する祖国の富をちょろまかして私腹をこやしながら、自分たちが不正をはたらいていることは棚にあげて、ひたすら世間から不正をはたらいているようには言われまいと、是努めているのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "加野も大変だな、気の毒な奴だ……」「悟つてはいらつしたやうだけど、痩せて、元気がなかつたわ……」「大変な愛国者で、正直｜一途な男だつたね」「さうね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変な愛国者で、日本は敗ける筈がないと信じこんでゐた加野が、死んで、カソリックで、さゝやかなとむらひを出して貰つた事が、ゆき子には不思議だつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の文明を進めんとしてかえってこれを妨ぐるは、愛国者の不面目これよりはなはだしきはなかるべし。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最上の愛国者です。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
