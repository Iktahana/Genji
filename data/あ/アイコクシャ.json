[
  {
    "uuid": "a78485c4-973e-586f-a903-729ee84b14eb",
    "entry": "愛国者",
    "reading": {
      "primary": "あいこくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
