[
  {
    "uuid": "6d0a65f2-c5b1-5f22-8b1a-d731280877b9",
    "entry": "相打ち",
    "reading": {
      "primary": "あいうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
