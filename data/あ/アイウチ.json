[
  {
    "uuid": "6d0a65f2-c5b1-5f22-8b1a-d731280877b9",
    "entry": "相打ち",
    "reading": {
      "primary": "あいうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "simultaneously striking one another (in kendo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相打ちは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相打ちが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相打ちに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相打ちが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相打ちについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相打ちについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相打ちについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相打ちが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相打ちが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相打ちは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相打ちは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相打ちを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相打ちをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相打ちが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相打ちの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相打ちを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相打ちに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相打ちについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相打ちは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相打ちを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すなわち、浜べで無数の砂利が相打ち相きしるように無数の蝗の羽根が轢音を発している、その集団的効果があのように聞こえるのではないかと思われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは相打ちを伝えるために、まっ直に扇を挙げて居りました。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時も相打ちではなかったのかもわかりませぬ。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもとにかく相打ちをした二人は四度目の睨み合いへはいりました。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、余りに、ぶしつけな質問をしたのに、興をさまして、黙っていると、半兵衛が「槍をとれば、大言ながら、相打ちにまでは勝負しよう」　そう云うと、立上った。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いう思念と、　――いいえ、かたきの片われにしろ、かくも無心な、いじらしい赤児を――　どうして、憎み苦しめられようかという感情と、相打ちつづけているに相違ない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵も夢想権之助の棒には手を焼き、一般にこれを相打ちと称されているが、実際には武蔵が一生に一度の負けをとっている事実があるのだ。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「相打ち」「…………」「見事に足を。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当代剣豪十人を選んで、日本の代表的人物としたら、当然その中に入るべき人物、秋山要介正勝ほどの人が、相打ちになったというからは、彼水品陣十郎という男、伎倆は伍格と見なければならない。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ破門をされない前に、多四郎の道場で多四郎を相手に、数回「逆ノ車」をもって、立合ったことがあったのであり、そのつど陣十郎が勝ちを取るか、でなかったら相打ちとなった！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿におしでない」　匕首と銭とは、しばらく宙に相打ちました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "銕太郎は相打ちにでもするように、刀を正眼につけたままぐいぐいと進み出、岡野は左へまわりこんだ。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中の一名と相打ちして死ぬ気ならばそれも可能であるが、さもなければ、敵の一名から行動してくるのを待って、敵の四の行動が、ほんの瞬間でも、不一致を起こすところを臨んで打撃を加えるほかにない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、兄茂左衛門は、そこまでの間に、はや討たれ、弟勝兵衛も、太刀の敵と斬りむすび、相打ちとなって、近くの岩の根に斃れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
