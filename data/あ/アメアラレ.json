[
  {
    "uuid": "40e576e6-a4cc-550e-9e51-330afee1abfa",
    "entry": "雨あられ",
    "reading": {
      "primary": "あめあられ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hail (e.g. of bullets)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨あられについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨あられという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨あられの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨あられが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨あられを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨あられについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨あられの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨あられの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨あられが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨あられという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨あられという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨あられについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨あられを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨あられは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨あられについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨あられが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨あられは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨あられの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨あられは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨あられは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども、天使のかがやくつばさにあたったとたん、はねかえって、雨あられのように落ちてきました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "口径二十三ミリの砲弾はドドドッとものすごいひびきをたてて、怪物の上に雨あられと降った。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンパウダーを雨あられと蹴っとばし、なぐりつけ、あっという間もなく駈けだせば、この連れから逃げだせるかと思った。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からの強風にかてて加えて、火勢の呼び起すつむじ風もすさまじいことで、御泉水あたりの巨樹大木も一様にさながら箒を振るように鳴りざわめき、その中を燃えさかったままの棟木の端や生木の大枝が、雨あられと落ちかかって参ります。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からの強風にかてて加へて、火勢の呼び起すつむじ風もすさまじいことで、御泉水あたりの巨樹大木も一様にさながら箒を振るやうに鳴りざわめき、その中を燃えさかつたままの棟木の端や生木の大枝が、雨あられと落ちかかつて参ります。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと決めかねているうちに、コックはスープのおなべを火から外すと、いきなりあたりのものを手当たり次第に御前さまと赤ちゃんに投げつけだしてね――火元の金具がまず飛んできて、そのあと続いて小なべやお大皿小皿が雨あられ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、間一髪のところで、息せき切って到着して、お詫びの雨あられだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟音が響き、暴風が来て足をすくわれ、石や岩が雨あられと降り、海水が押し寄せてすべてが終わった。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地も裂くばかりな轟音となって、矢石鉄丸を雨あられと敵の出足へ浴びせかけた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の副将張南は、それと見るや、「おのれっ」と、弩を張って、周泰の舟へ近づきながら、雨あられと矢を向けてきた。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが城へ近づくと、味方であるはずの城中から雨あられと矢を射てくる。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その城頭からは、李輔、※賢などという魏将が雨あられと、矢を放っていた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この　きのみの　あめあられは　いったい　どういうわけ？",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
