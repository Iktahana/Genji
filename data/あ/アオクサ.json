    "definitions": [
      {
        "index": 1,
        "gloss": "green grass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、その時は、地球の表面に存在するもの悉くに、其の持主の名札が貼られ、一坪の青草原さへ殘つてなかつた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門次が一行の案内を務めるのは、言うまでもない、雨でグッショリ濡れた青草や、仆れている朽木からは、人の嗅覚をそそるような古い匂いがして、噎びそうだ、足が早いので、一丁も先になった嘉門次は、私を振り返って「他所の人足は使いづらくて困る」とブツブツ言いながら、赤石の河原に出た。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲が延びると、裾野のぼやけた緑は、水底に揺らめく青草の波になった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして鉄路の附近に、氷河湖の跡が乾からびて、今は青草の生えた牧場になって、牛が遊んでいる。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の広さも両岸の崖、ところどころの洲の青草。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前に百花園からつるの手をつけてある目籠に長命菊つくし石竹の苗其他数種の青草を植込にしたやつを買って来て置いたのを持って往ったのであるきょうは暖炉の掃除をやったとの事で先生は八畳の座敷に石油暖炉をたき東向になってねていられた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この溝の水はたぶん、小金井の水道から引いたものらしく、よく澄んでいて、青草の間を、さも心地よさそうに流れて、おりおりこぼこぼと鳴っては小鳥が来て翼をひたし、喉を湿おすのを待っているらしい。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれから二三日とたたないある朝、庭の青草の上に長く冷たくなっているのを子供が見つけて来て報告した。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目で見なかった代わりに、自分の想像のカンバスの上には、美しい青草の毛氈の上に安らかに長く手足を延ばして寝ている黄金色の猫の姿が、輝くような強い色彩で描かれている。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌えさかつた堤の青草は霧のやうな乳白色を含んで、河原の川柳はそよ風にざわ／＼と騷いではゐたが、雨の脚はまだ何處にも見えなかつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは一つかみずつの青草をまんべんなく牛にやって、また歩きだした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋏をいれたかとも思はれる様な丈の揃つた青草の中の小途を、亨一とすず子は上つて行く。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋏をいれたかとも思はれる樣な丈の揃つた青草の中の小途を、亨一とすず子は上つて行く。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "病める青草の萎えむとして水の涸いたのであつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前もな、青草ものの商売や。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏山をあるく、青草に寝ころんで雲をながめる。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・朝風の青草食みつつ馬は尾をふる・日影ゆるゝは藪ふかく人のゐて・炎天の機械がうごく人がうごく（アスフアルトプラント）　　　　□　ひらいてゆれてゐる鬼百合のほこり・朝からはだかで雑草の花　糸瓜さいて垣からのぞく　殺された蚊でぞんぶんに血を吸うた蚊で・風が吹きとほすまへもうしろも青葉　七月廿日　土用入。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には活々と青草の生えている古い頽れかけた屋根を見える。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか奈良へ旅した時、歩きくたぶれて、道傍の青草原に、べったり坐ってしまったくらいだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　私の髭は日ましに青草のように勢いよく延び初めた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　食慾も、またあの性慾とやらも、何も無い涼しい恋の会話が続いて、夢で、以前に何度も見た事のある、しかし、地球の上には絶対に無い湖のほとりの青草原に私たち夫婦は寝ころぶ。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと前方を見ると、緑いろの寝巻を着た令嬢が、白い長い両脚を膝よりも、もっと上まであらわして、素足で青草を踏んで歩いている。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」佐野君は、釣竿を河原の青草の上にそっと置いて、煙草をふかした。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラプンツェルは、こんどは泣きたくなって、岸の青草の上に崩れるように坐りました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青草の景色もあれば、胸のときめく娘もいた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでしかたのない夕暮れになつてしまつた燈火をともして窓からみれば青草むらの中にべらべらと燃える提灯がある。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし意地のきたない動物の本能として、絶えず路傍の青草を食ひ散らしながら。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
