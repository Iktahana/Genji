[
  {
    "uuid": "14647c40-8c80-515b-8980-1a345e428538",
    "entry": "怪しい",
    "reading": {
      "primary": "あやしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suspicious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日怪しいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "怪しいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は怪しいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には怪しいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "怪しいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは怪しいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "怪しいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は怪しいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では怪しいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に怪しいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では怪しいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "怪しいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると怪しいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では怪しいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に怪しいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により怪しいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "怪しいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に怪しいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼が異国人と夜のまったく明けはなれるまで談じ合うほど語学ができるかどうか、そういうことからして怪しいもんだと私は思っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクラの満開の日と、生れた日と、こんなにピッタリ合うなんて、なんだか、怪しい。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立止って気をつけて見ると、頭に突き出た大きな眼は、怪しいまなざしに何物かを呪うているかと思われた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクラの滿開の日と、生れた日と、こんなにピツタリ合ふなんて、なんだか、怪しい。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚から出た四つ這ひの形のままで、前方の怪しい酒宴のさまを熟視し、「氣持よささうに、醉つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ゆきが怪しいので、私は多少の気がかりで、大沢の小舎を立った、すぐ眼の前には、その大沢の難所なるものが控えている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで自分の腕時計を調べて、それからまるで食い込むように向うの怪しい時計を見つめました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然という魔法の戯れが手品師のようにいきなり怪しい煙を起こしたのだから山崎が誤解したのは全く無理もないことだ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊売りが問題の夜更けに問題のアパート階上の洗面場で怪しい男の手を洗っているのを見たという証言のあたりから、記者席の真犯人に観客の注意が当然集注されるから、従ってその時に真犯人は真に真犯人であるらしい挙動をして観客に見せなければならないこと勿論である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も意外に感じた事は自分が比較的によく体験し体得しているつもりでいた専門の学問上の知識の中にもよくよく吟味してみると怪しい部分が続々発見された。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六十八段、大根が兵士に化ける話は少し怪しいが、次の六十九段と合せて読んで見ると寓意を主として書いたものとも思われる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような立場から云うと、基礎の怪しい会社などを始めから火葬にしないでおいたためにおしまいに多数の株主に破産をさせるような事になる。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にならァ」Ｓ＝表　怪しい屑屋が内部を窺って居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達になって来て下さるか、どうだか怪しいものですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下界隈の怪しい酒場で酔泥れた一列の黒奴の火夫達が、最新流行歌をうたって和服の蠱惑の街に傾いた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、ほんとだよ」「ふふふ、怪しいもんだわ。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に怪しい者でなく三人の小娘が枯れ枝を拾っているのでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と問いますと、子供はうなずいたまま例の怪しい笑いをもらして、口を少しあけたまま私の顔を気味の悪いほど見つめているのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のたつうちに、この怪しい子供の身の上が次第にわかって来ました、と言うのは、畢竟私が気をつけて見たり聞いたりしたからでしょう。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はまず城山を捜すがよかろうと、田口の僕を一人連れて、ちょうちんの用意をして、心に怪しい痛ましいおもいをいだきながら、いつもの慣れた小道を登って城あとに達しました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお秀が局を欠勤でから後も二三度会って多少｜事情を知って居る故、かの怪しい噂は信じなかったが、此頃になって、或という疑が起らなくもなかった。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お富はお秀の様子を一目見て、もう殆ど怪しい疑惑は晴れたが、更らに其室のうちの有様を見てすっかり解かった。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに、たとえば、飲んだくれの亭主が夜おそく帰って来て戸をたたくと女房のクサンチペがバルコンから壺の中の怪しい液体をぶっかけ、結局つかみ合いになるという活劇をもわずかな小道具と背景を使って映し出して見せた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　むらさきの鯉は怪しい女の手によって、台所のあげ板の下から持ち出された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは夢をみているのではないかとも疑ったが、だんだんに落ち着いてかんがえると、怪しい女はどうも江戸川の水の底から抜け出して来たらしく思われてならなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不安に絶えずおびやかされている矢さきへ、測らずも今夜のような怪しい女に襲われて、お徳はいよいよその魂をおののかせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに何だかおかしい女が来たんだよ」　怪しい女に鯉を抱え出された一件を女房の口から聴かされて、藤吉はいよいよ顔の色を変えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又かの怪しい女は何者か、その女と藤吉とのあいだに何かの関係があるのか無いのか、役人たちもその判断に苦しんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房がそっと起きて来て、今夜自分が見とどけた怪しい出来事を話すと、祭礼の酒に酔っている亭主はそれを信じなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以外には何の怪しい廉もないが、たった一度、女の手紙らしいものを持っていたことがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
