        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒木について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒木という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒木の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒木が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒木を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒木について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒木の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒木の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒木が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒木という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒木という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒木についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒木を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒木は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒木について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒木が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒木は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒木の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒木は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒木は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "荒木さんも、うるさいね。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田さん、西郷さん、荒木さんは、それぞれ、その犬の飼ひ主の名前であります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木田久老の『信濃漫録』の中にも龍麿の説を信用しないようなことを書いております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木又右衛門が三十余人を相手に奮闘するのを見て理屈抜きにおもしろいと思わない日本人は少ないであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、映画の世界にもいつかはまたそうした人が出るであろうという気長い希望をいだいてそうしてそれまでは与えられたる「荒木又右衛門」を、また「街のルンペン」をその与えられたる限りにおいて観賞することに努力すべきであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても、かたき討は大石内蔵助と荒木又右衛門に株を取られてしまったので、今更どんな掘出し物をしても彼らを凌ぐことはむずかしい。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石には芸州の浅野が附いている、荒木には備前の池田が附いている。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉妹の娘に料理を教えに行く荒木家蛍雪館のある芝の愛宕台と自宅のある京橋区の中橋広小路との間に相当の距離はあるのだが、彼は最寄の電車筋へも出ずゆっくり歩るいて行った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この市隠荘はお絹等姉妹の父で漢学者の荒木蛍雪が、中橋の表通りに画帖や拓本を売る蛍雪館の店を開いていた時分に、店の家が狭いところから、斜向うのこの露路内に売家が出たのを幸、買取って手入れをし寝泊りしたものである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路内の市隠荘はしばらく戸を閉めたままであったのを、鼈四郎が蛍雪に取入り、荒木家の抱えのようになったので、蛍雪は鼈四郎にこの市隠荘を月々僅な生活費を添えて貸与えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊丹の城主、荒木村重につかえて横目役を勤め、年久しく主家を泰山の安きに置いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて村丸贔屓の城主荒木は、このたびもまた笑って、よろしい、蝦夷一覧もよかろう、行っておいで、若い頃の長旅は一生の薬、と言って事もなげにその我儘の願いを聞き容れてやった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川橋のお針の師匠の家には荒木という髪の毛の長い学生が下宿していた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸でいいから来てごらん」「何さ、勿体振って……」　そう云いながら、二階の荒木の部屋へ随って上ると、荒木はいきなり安子を抱きしめた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木の息は酒くさかった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその部屋を出てゆく時、安子は皆が大騒ぎをしていることって、たったあれだけのことか、なんだつまらないと思ったが、しかし翌日、安子は荒木に誘われるままに家出して、熱海の宿にかくれた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと知りたいという好奇心の強さと、父親の鼻を明かしてやりたいと言う気持に押し出されて、そんな駈落をする気になったのだが、しかし三日たって追手につかまり、新銀町の家へ連れ戻された時はもう荒木への未練はなかった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど荒木はつまらぬ男だったのだ。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "折井は荒木と違って、吉原の女を泣かせたこともあるくらいの凄い男で、耳に口を寄せて囁く時の言葉すら馴れたものだったから、安子ははじめて女になったと思った。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木村重なども、やはりそうである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川は、元荒木村重の被官で、以前此の山崎附近の糠塚で、和田伊賀守と云う剛将を単身で打ち取った剛の者で、勝手知ったる戦場ではあるし、目ざましい奮戦をつづけて、早くも勝機を作ったのである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、畿内を分領していた筒井、松永、荒木、和田、別所など大名小名の手の者で、『鎗中村』を知らぬ者は、おそらく一人もなかっただろう。",
              "citation": {
                "source": "形",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長は荒木｜村重との初対面に、刀で餅を刺して、壮士ならこれを啗へ、と云つて突き出したが、後年｜叛かれてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな人の頼んだ絵など、いっそいつまでも出来ない方がようござります」　この藩の用人荒木｜頼母の伜千之丞は、伝兵衛の推挙で先ごろ千倉屋へたずねて来て、澹山に西王母の大幅を頼んで行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして三月あまりを送るうちに、彼は伝兵衛の推挙で城の用人荒木頼母の伜千之丞から掛物の揮毫を頼まれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜ふけにお邪魔をいたしまして相済みませんが、荒木様の御子息様からおあつらえの掛物はまだお出来に相成りませんか」と、伝兵衛は坐り直して訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに荒木千之丞は絵の催促にたびたび来たが、伝兵衛がいつもいい加減にことわっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは用人の荒木頼母がせがれ千之丞の仕業に相違あるまいと、わたくしは睨んで居ります」　千之丞はかねて千倉屋の娘に懸想していて、町人とはいえ相当の家柄の娘であるから、仮親を作って自分の嫁に貰いたいというようなことを人伝てに申し込んで来たが、娘も親も気がすすまないので先ずその儘になっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正六年に荒木｜攝津守村重が攝津國｜伊丹の有岡城に籠つて織田信長に背いた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔島わにあらき潮騒を〕宮沢賢治島わにあらき潮騒をうつつの森のなかに聴き羊歯の葉しげき下蔭に青き椿の実をとりぬ　　南の風のくるほしく　　波のいぶきを吹き来れば　　百千鳥　すだきわぶる三原の山に燃ゆる火のなかばは雲に鎖されぬ",
              "citation": {
                "source": "〔島わにあらき潮騒を〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
