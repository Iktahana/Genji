[
  {
    "uuid": "8d7d5845-75a9-5eb4-9b49-7f7555502ada",
    "entry": "商う",
    "reading": {
      "primary": "あきなう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
