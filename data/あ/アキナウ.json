    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to trade in (commercial goods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "吉田の弟の店のあるところはその間でも比較的早くからできていた通り筋で両側はそんな町らしい、いろんなものを商う店が立ち並んでいた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また此外に矢張りこれも同級の男で野崎というのがありましたが、此野崎の家は明神前で袋物などをも商う傍、貸本屋を渡世にして居ました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬翁はちょっと意地の悪い笑いを洩らしたが、ひそかに慧鶴を呼び寄せ娘の手紙を示し乍ら「恋女房とさし向いで、呉服を商うのもまた風雅ではないか」としきりに彼に還俗をすすめた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　先生は見ざる真似して、少年が手に傾けた件の畚を横目に、「生憎、沙魚、海津、小鮒などを商う魚屋がなくって困る。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と嘗め廻す体に、足許なんぞじろじろと見て商う。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が商う魚だって、品に因っちゃ好嫌えは当然だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他の魚屋の商うのは鯛さ、め組のに限っちゃ鯛よ、なあ、めい公。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋詰の小店、荒物を商う家の亭主で、身体の痩せて引緊ったには似ない、褌の緩い男で、因果とのべつ釣をして、はだけていましょう、真にあぶなッかしい形でな。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側に立樹の茂った空地の森を風情にして、如法の婆さんが煮ばなを商う。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴は、今でも埋火に鍋を掛けて暖めながら、飴ん棒と云う麻殻の軸に巻いて売る、賑かな祭礼でも、寂びたもので、お市、豆捻、薄荷糖なぞは、お婆さんが白髪に手抜を巻いて商う。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同風呂を設けた処は、酒や雑貨を商うかたわら、旅籠を兼ねている家であった。",
              "citation": {
                "source": "風呂供養の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　街路一つ距てて母屋と向きあった肆は、四｜間室口で硝子戸が入り、酒味噌酢｜類を商うかたわらで、海苔の問屋もやっていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に案ずるまでもない、同町の軒並び二町ばかり洲崎の方へ寄った角に、浅草紙、束藁、懐炉灰、蚊遣香などの荒物、烟草も封印なしの一銭五厘二銭玉、ぱいれっと、ひーろーぐらいな処を商う店がある、真中が抜裏の路地になって合角に格子戸｜造の仕舞家が一軒。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「知ッてますよ、手習師匠兼業の奴なんで、媽々が西洋の音楽とやらを教えて、その婆がまた、小笠原礼法｜躾方、活花、茶の湯を商う、何でもごたごた娘子の好な者を商法にするッていいます。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通うた壁の穴を求むると、隣りに饂飩を商う家あり、その饂飩の粉の中に鼠棲んでこの家へ来る故白鼠と見えたと判り、皆々大笑いして帰った。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインのある街に絹物を商う店があった。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はあの男に俺の尾行を依頼したんだ」　清三は貴金属宝石を商う金星堂の店員だった。",
              "citation": {
                "source": "被尾行者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親たちが横浜の叔父の方へ引き寄せられて、そこで襯衣や手巾ショールのような物を商うことになってから、東京にはお庄の帰って行くところもなくなった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は、村で呉服物などを商う家だということを、お庄も思い出した。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い散歩街の両側に、屋内通路と、赤、緑、白に塗り立てたおもて口、漆喰細工の稚い装飾、不可解に垂れ下った屋根、多角形に張り出ている軒、宝石・象牙・骨董を商う店、絹地屋――など、これらの商店はどこも象の模様で食傷している。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側には仏具を商う店舗、右は寺々の高い石垣、その石垣を覆うて一面こまかい蔦が密生している。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来、私どもの家はお茶々を商うのが家の業いでございまして、蛸薬師下るの方へ移りましても矢張お茶々の商売をいたしました。",
              "citation": {
                "source": "昔尊く",
                "author": "二千六百年を迎えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "草市と盂蘭盆　魂まつりということ、釈迦の教えに基づいて年々の盂蘭盆に、精霊壇へ百味五果を供え、以て祖先の霊を招くは江戸ッ児のザックバランにも合する振舞いで、その魂まつる日の数々の供物など、草市の商いは陰気でどこかうら淋しい感じはするが、それでも商うどの出店は、数も歳の市に多くは譲らぬ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫と河鹿　松虫、鈴虫、轡虫、さては草雲雀、螽斯なんど、いずれ野に聞くべきものを美しき籠にして見る都びとの風流は、今も昔に変らぬが、ただこの虫というもの、今は野生のを捕え来て商うのではなくて、大方は人工孵化。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像を売る家、香華を商う店、様々の商店が並んでいたが、けばけばしい色彩は見られない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五軒の湯宿と雑貨や駄菓子などを商う小店と、あとは川を挟んで飛びとびに農家があるばかりだった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平の店の右手の低い板敷には、肥料・米俵・糠俵・煙突・セメント・左官材料等と、それを商うときにつかう大きいカンカン秤が置かれており、人気ない真昼間などには折々鼠の尻尾が俵の間に見えがくれした。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに大道で商うとは、若いとはいえ不埒千万、しかし食うための商売とあれば、強いて咎めるにもあたるまい。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、花屋といふ商売を、賤業と見なしてゐる徳川頃に、如何におちぶれても、仏の花を商うてゐる家を、旧家七軒の中に数へなかつたであらう。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、収穫時の稲田の間を廻って、樽柿と籾米とを換えて商うのであった。",
              "citation": {
                "source": "秋の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
