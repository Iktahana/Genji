        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、政江もかつて崎山に、「あんさんらは、何でんナ、青切符が無料でおますよって、旅する云うても結構でおますナ」と言ったことがある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だ、青切符か。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物も何も無い気楽さに直ぐに切符売場へ行って、博多までの二等切符を買って来ると、三等待合室の中央に立って待っている到翁が眼早く青切符を見咎めてサッと顔色を変えた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に骨までしゃぶられるだろう」「そう、やくな、やくな――」　二人は東京行の青切符を買って、向かいあった座席を占めた。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後一時三十五分品川行きの列車が汽笛を鳴らして運転をはじめたころ、エビスビールあたりの帰りであろう、面長の色の浅黒い会社員らしい立派な紳士が、眼のあたりにポッと微薫を帯びて、洋杖を持った手に二等の青切符を掴んで階壇を飛び降りて来た。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん二等、三等の区別などはない、たまに青切符の権利をでも主張しそうな態度を見せようものなら、それこそ大変だった。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ辨慶の制札を思ひ出して、詰まらない興味をも起したりしてゐたが、そこへ、車掌が切符改めに來たので、棚の上の帽子をおろして、そこへ挾んでゐた青切符を取り出した。",
              "citation": {
                "source": "素材",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "青切符（二等）を買える金は持っていたけど（そのころ、汽車は一等、二等、三等とあったのだ）、乗りつけない二等に乗って目立ってはまずいから、赤切符（三等）で行った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
