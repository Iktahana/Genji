        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油絵について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油絵は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油絵の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油絵について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油絵は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油絵の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油絵に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油絵が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油絵を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油絵の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油絵が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油絵が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油絵について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油絵は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油絵は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油絵は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油絵について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油絵の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油絵の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油絵の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "潔癖が自慢の或るお方は、古道具屋から買つて来た油絵をタハシでおすりになつた。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画よりはむしろ油絵の画題であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがブランギンの油絵を思い出させる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後『文章世界』で読者から紀行文家を投票させて、最高点を得た人に、彫塑かまたは油絵肖像を贈呈するということであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は油絵の肖像を希望した。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその水車風景は、コンスターブルの油絵で見たものとは遠く、小林清親が水彩画から新工夫をして描き上げた、富士を背景とした静岡竜宝山の水車風景の版画（明治十三年版）の方が、ぴたりと胸に来た。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分の描き集めた若干の油絵だけがちょっと惜しいような気がしたのと、人から預かっていたローマ字書きの書物の原稿に責任を感じたくらいである。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵があんまりのんきで、その描き方があんまり気楽なので、思わず二人で笑ってしまった事があるが、同じ油絵をかくのでも、人によってこんなにもちがうものかと思った。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点で、これらの絵は、有り来りの油絵よりは、むしろ東洋画に接近しているかもしれない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤この頃自分で油絵のようなものをかいているものだから、色々の人の絵を見ると、絵のがらの好き嫌いとは無関係な色々のテクニカルな興味があるのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾度か額をはずし、油絵の裏側を覗いたりした。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員の怪しむような眼を睨みかえして油絵を見た。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "その壁には鉛筆画、チョオク画、油絵｜等のスケッチを多く掛けあり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれはむしろやはり油絵の題材でないか。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにそうかと云って、洋画家で絵絹へ油絵具を塗る試みをあえてする人、日本画家でカンバスへ日本絵具を盛り上げる実験をする人がないのはむしろ不思議なくらいである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油絵に凝っていた頃の事である。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさまを油絵にかかした額が客間にかかっていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代に少しばかり油絵をかいてみた事はある。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代には、油絵といえば、先生のかいたもの以外には石版色刷りの複製品しか見た事はなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二十何年の間に自分はかなり多くの油絵に目をさらした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芸術としての油絵というものに対する考えもいろいろにうつって行った。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに拙劣でもいいから、生まれてまだ見た事のない自分の油絵というものに対してみたいというのであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう言われてみると自分のかいた顔は普通の油絵らしくなくて淡彩の日本画のように白っぽいものである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、そのころどこかからもらった高価な舶来ビスケットの箱が錠前付きのがんじょうなブリキ製であったが、その上面と四方の面とに実に美しい油絵が描かれていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生あまり文通をしていないこの人から珍しい書信なので、どんな用かと思って読んでみると、　郷里の画家の藤田という人が、筆者の旧宅すなわち現在Ｔ氏の住んでいる屋敷の庭の紅葉を写生した油絵が他の一点とともに目下｜上野で開催中の国展に出品されているはずだから、暇があったら一度見に行ったらどうか。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう短命なものを批評するのと、彫刻や油絵のような長持ちのするものを批評するのとでは、批評の骨の折れ方もちがうわけである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付きを着て撮った写真や、それをモデルにしてかいた油絵などを見ても、なんだかほんとうの祖母らしく思われないが、ただ記憶の印象だけに残っているこの「糸車の祖母像」は没後四十六年の今日でも実に驚くべき鮮明さをもって随時に眼前に呼び出される。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいことには、その時の手術室の壁間に掲げてあった油絵の額が実にはっきり印象に残っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど絵が好きなので、こうして油絵のできて行く道筋を飽きずにおしまいまで見届けようとしているのかと思ってもみた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
