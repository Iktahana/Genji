    "definitions": [
      {
        "index": 1,
        "gloss": "early morning (before the break of dawn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝まだきの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "旅館の主人、馬を勧め、剛力を勧め、蓆を勧め、編笠を勤む、皆之を卻く、この極楽の山、只一本の金剛杖にて足れりと広舌して、朝まだき裾野を往く。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日朝まだきに起き出でて見るに有明の月東の空に残りて雨はなごりなく晴れたり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）翌朝――猿若町に櫓の太鼓鳴り響けば　鳴り響く櫓太鼓――　＝（Ｆ・Ｉ）お光の茶店（朝まだき）　駕籠が一丁待っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき、東の空ようやく白みしころ、人々皆起きいでて合羽を着、灯燈つけ舷燈｜携えなどして波止場に集まりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき霧の晴れぬ間に家を出で野を歩み林を訪う」同二十六日――「午後林を訪う。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、」　温泉の口なる、花室の露を掻潜って、山の裾へ出ると前後になり、藪について曲る時、透かすと、花屋が裏庭に、お雪がまだ色も見え分かぬ、朝まだき、草花の中に、折取るべき一個の籠を抱いて、しょんぼりとして立っていた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥夫が朝まだき提灯で道案内に立つた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全市街はその日朝まだきより、七色を以て彩られ候と申すより他はこれなく候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭倶樂部都のみどりば瞳にいたく緑蔭倶樂部の行樂はちまたに銀をはしらしむ五月はじめの朝まだき街樹の下に竝びたるわがともがらの一列ははまきたばこの魔醉より襟脚きよき娘らをいだきしむ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだきは納豆売、近所の小学に通ふ幼きが、近路なれば五ツ六ツ袂を連ねて通る。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月一日の朝まだき、神々の御父ジュピタア様の宮殿へおまいりの途中で逢った三人目の男のひとを私の生涯の夫ときめよう。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだきは、旅館の中庭の其處此處を、「大きな夏蜜柑買はんせい。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを狩るか狩るまいかの問題で、寺の住職と町村との間に一｜悶着あったそうですが、結局、住職が譲歩し、その筋の了解も得て、朝まだきの人の迷惑にならない一時間ほどの間を狩ることになったのだそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いでわれ親ら往いて求めんとて、朝まだきに力強き漕手四人を倩ひ、湊を舟出して、こゝかしこの洞窟より巖のはざまゝで、名殘なく尋ね給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "初は朝まだきに馬の秣の一｜籠を刈るに過ないけれど、燬くやうな日のもとに畑も漸く極がついて村落の凡てが皆草刈に心を注ぐ樣に成れば、若い同志が相誘うては遠く林の小徑を分て行く。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　渦を卷いて狂つてゐる雨風や、ツイ溪向うの山腹に生れつ消えつして走つてゐる霧雲を、僅かにあけた雨戸の隙間に眺めながら、朝まだきから徳利をとり寄せた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困りましたネ、これでは立てませんネ」　渦を巻いて狂っている雨風や、ツイ渓向うの山腹に生れつ消えつして走っている霧雲を、僅かにあけた雨戸の隙間に眺めながら、朝まだきから徳利をとり寄せた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぐらもち新嘗まつりほどちかき霜ふり月の朝まだき、乾反葉しらむ籬根に骸こそ見つれ※鼠。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽があがって間もないのに、江戸の六月は朝まだきから蒸し風呂のなかに這入ったような暑さです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の洗い砂礫を敷きつめたその坂下御門前に行きついたのは、冬の陽の冷たい朝まだきの五ツ前である。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき、夏の大江戸の町は、すがすがしい涼風でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "角楯組の最も貧しい一兵卒だ、――教会堂の天気鶏の翼が未だ暁の露に沾うてゐる朝まだきに起き出でて、大隊長から小隊長までの楯と剣を磨いた後に、起床ラッパを吹き鳴らさなければならない身分の番兵だ。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しくも唯ひとり、唯ひとり、きのままに、棺のうち、唯ひとり、唯ひとり、のこしきて、朝まだき、はなやかに、はなやかに、うちつれて、歌ふやう「時くれば、時くれば、ゆくみちぞ、このをとめ、みまかりぬ、みまかりぬ、戀やみに。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある気持ちのよい朝まだき、根岸、朱舜水の屋敷から、一群の旅人が発足した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主　　朝まだきに如何なる珍事が出來したのぢゃ、予が夢を驚かして呼出だすは？",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島の朝まだき、飛行甲板の上には、一台の軽旅客機が、今にも飛びだしそうな恰好で、しきりにプロペラーをまわし、エンジン試験をつづけていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は、朝まだきから降り初めた秋雨が、午後の三時頃まで降り續いた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は神無月末の或る朝まだき、處は矢張此の新山祠畔の伯母が家。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は、朝まだきから降り初めた秋雨が、午後の三時頃まで降り続いた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
