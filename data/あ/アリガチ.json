        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有りがちについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りがちという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りがちの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りがちが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りがちを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りがちについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りがちの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りがちの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りがちが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りがちという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りがちという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りがちについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りがちを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りがちは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りがちについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りがちが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りがちは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りがちの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りがちは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りがちは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あまり道具を尊重し過ぎて本然の目的を忘れるのは有りがちな事であるから、これもよく考えてみなければならない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたぶん有りがちな幻覚かもしれない。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわゆる名所旧跡などのすぐ前を通りながら知らずに見のがしてしまったりするのは有りがちな事である。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの記憶にはこんな失策は有りがちであるが、このようなカメラの思いちがいは珍しい。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことは往々にして有りがちなのですから、しかし、そういう幸福に当らなかった人はどうでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この社会に有りがちのことでもあり、親や妹たちもいるので、銀子もよほど目を瞑ろうと思うこともあったが、脂肪質の顔を見るのも※液が走るようで、やはり素直にはなれないのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大丈夫としてからが、ああいう美しいのには有りがちだから、肺病の憂があってはならず、酒井の親属関係、妙子の交友の如何、そこらを一つ委しく聞かして貰いたいんだがね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち酷寒酷暑に於ける従事、或いは虫害その他についての繁雑な手当て、緻密な観察、時間的に不規則な労働に服す等の種々の場合に、努力しなければ中途で止める状態になることも間々ある理屈で、換言すれば好んで為すと云っても、その間には好ましくない事情が生じるようなことは人生に有りがちな事である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう宜しくないかというと、多くは血の下降する癖が有りがちで頭部の血が不足し腹部などに集まる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」答「これは有りがちな強弁です。",
              "citation": {
                "source": "大衆文芸問答",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはその青年は旅から岸本の許へ葉書をくれ、どんなに海が青く光っていても別にこれぞという考えも湧かない、例の柳並木の方が寧ろ静かだと書いてよこしたり、時には東京の自宅の方から若い日に有りがちな、寂しい、頼りの無さそうな心持を細々と書いてよこしたりした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は節子の側を離れて家の内をあちこちと歩いて見たが、しまいには気の弱いものに有りがちな一種の幻覚として年若な姪の言ったことを一概に笑ってしまえなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、Ｅや龍子の生活にはむしろ有りがちな、と云ふよりは、始終折さへあれば、何にかの名で降つて来るにきまつた、小さな災難だつた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽の下で笑う　男ばかりの集まった時の雑談は女に聞かせ難いことがあり、大人ばかりの雑談は子供に内密で有りがちである。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東京のさわがしいことから人の様子から言葉つきから御丁寧にその人達のだれにでも有りがちなくせまではなした。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日はまた春に有りがちなしとしと雨が銀線を匂やかな黒土の上におちて居た。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもすんだ晴れた声で丸く話をすることや、どこのこまっかい皮膚にでも男に有りがちのあぶらっこい光りをもって居ない事等が千世子が特別にうれしく思う事だった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い中は有りがちでございますから、まア／＼淫奔は出来ませんものでございます。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に間違いは有りがちでも、恋愛そのものが間違いではないのであるから、青年特有の正義心を信頼し、夢多き年代の特質を生かしてやる思いやりが欲しいものだ。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（空中勤務に、予期しない困難が、あとからあとへと起るのは、有りがちのことだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくして、あの方がお出になったけれど、目も見合わさずに、私がじっと思い詰めたようにしていると、あの方は「こんな事は世に有りがちな事だのに、そんなに歎いてばかりおられるのは、わたしの事をちっとも頼みに思っていてくれないからなのだろう」と私を反って恨むように言われるのだった。",
              "citation": {
                "source": "かげろうの日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんな事さえも、その日頃にはとかく有りがちなのであった。",
              "citation": {
                "source": "かげろうの日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして未婚の天光光氏がアヤマチを犯すのは有りがちで、フシギはないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、我々が酔っ払った場合、又は酔っ払った周囲に於て有りがちなことが、ドッとまとめて起っていたにすぎないからである。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に被告が検事の催眠術にかかったなどといいがちなのは、被告の弱点を最大公約数的につくので、両者の焦点がずれていても、ぬきさしならぬような結論がでてくることが有りがちではないかと思うのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろびとに有りがちなこの過ちを、咎めることはできない筈だ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、浮浪者や窃盗常習者がヤミ屋を殺したというような極めて有りそうな事件では、被告に不利な心証の傾斜が加わり易いのは裁判官も人間であるからには有りがちなことで、誰しもオレは別だと云いたいでしょうが、却々もって。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し公憤のあまり筆が走り過ぎてか、自分の発言を相当に歪曲して書いた事実はジャーナリズムには時には有りがちの事だが、自分としては甚だ迷惑で、其の事情は自分が東京新聞（五月卅一日）に書いた通りである。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い冬が終ろうとして、どうやら春めきだしたころ有りがちな陽気。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十六　家族は六人・目一ツ半",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また、默つてゐる人によくありがちの、皮裏の陽秋といふんですか、そんな胸中ひそかに辛辣の觀察を行ふなんて事も、乙姫は決してなさらない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
