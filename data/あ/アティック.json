          "literary": [
            {
              "text": "「その夕、アドリアティックの海は菫色であった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、陽の輝いている間は、アドリアティックの海は竹色であり、夕暮れるに従って菫色に変って来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階――と言ってもアティックだが――に酒の空瓶がゴロゴロしているには驚いた。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
