[
  {
    "uuid": "ae1125bc-b6aa-5eb8-ba4b-c9bbe6568f27",
    "entry": "余り",
    "reading": {
      "primary": "あまり",
      "alternatives": [
        "あんまり"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "remainder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日余りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "余りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は余りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には余りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "余りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは余りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "余りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は余りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では余りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "余りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に余りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では余りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "余りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると余りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "余りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では余りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に余りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により余りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "余りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に余りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これは、一つには私が今迄に、詩人である人と余りおつきあひして来なかつたといふことに過ぎないのかも知れません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もこんなに抽象的になつてゐることの一つの理由は、外国はいざ知らず我が国では、お互ひが痛い所に余りに触れなさすぎたからではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が認められること余りに遅かつたのは、広告不充分のためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩といへば、余りに贋物を掴まされすぎた経験からといふのでもあるか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、友達として一言忠告させて貰ふなら、その生活ぶりに、時として余りに野放図なものがあるので、謂はば必要以上に衰弱して居る日があつて、そんな日に出来た詩は、あの感覚と同居しにくい抽象概念を招きすぎて、読者を混乱させる場合がある。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し新短歌様式を規範的に吟味してみて、私の考へが余り間違つてゐるやうには思はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分三十才前後といふ頃に、人は余り死なないものなのであらう。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もひどく無頓着だつた彼女は、彼等との交際も余りしなかつたのではあるが。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（茲で一寸断つて置くが、ホンの少しの事が分ると、分つたことが当人にとつて余りに珍しいので却つて書けるといつたあの生々しい文学青年をも「書いてゐる奴」の中に入れて話してゐるのではない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学といふものが、凡そ文字を知つてゐれば、誰にも読むことが出来るといふことからして、余りに文士志望者が容易に生じるといつた現状だが、文学を仕事とするからには、※ルレーヌの言葉を以てすれば、「自分の通り道にあつたものだけを読むだけ」の努力では何にもならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来自然を友とすることが多かつた我が国人は、感傷の綱の海を漕ぎゆくには余りに清廉であり、されば比較的清廉でなかつた人が用に与つて来たかも知れませぬ。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もが芸術家にならなかつたといふわけは、云つてみれば誰もが固定観念を余りに抱いたといふことである。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『生得の詩人達』中の、コルビエールの篇は、四五年前、雑誌『社会及国家』に、私が訳載したのだが、文壇とは余り縁のない雑誌ゆゑ、大方は御存知ないことと思ふ。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一韻文音楽家たるには余りに芸術家であつた彼は、その形式の中に、根本的に絵画の或る物を持つてゐた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外国映画は、余り好まない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今彼に対面する者は、彼をただ友人とのみ考へるなら、余りに肉親的な彼の温柔性に辟易しなければならない破目になるだらう。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言ふかといふと形容詞的な余りに形容詞的なことか、それとも学問的な余りに学問的なことなのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――余りに実利的な一般人が、形式論（原理）と実地とを直接連つたものと考へたがる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、日本の詩の伝統はと見ると、（茲では明治初年井上博士に依つて新体詩と銘名された、泰西の詩を見てから後の詩のことを云ふ）余り豊富だと云ふことが出来ない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは余りお菓子の欲しくない人が駄菓子の方が寧ろ美味い、といふ時のやうなふうにして発生した通念と見えるが、それにしても、一応の由来はあると思へるので、一寸その事に就いて云つてみれば、　西洋人の方が、我々よりも尠くも形の上では楽天的である、従つて即興的であるよりも構成を怡しむ習性を一層持つてゐる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実我々が詩作の場合に、我々の周囲に一杯ある短歌や俳句の影響は余りにも浸入するといふやうな有様なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、序でに、論旨を現代生活と連関させてみるならば、現在我が国が、芸術に対する関心を余り持つてをらぬといふのならば私にも分る。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠くとも理論と事実とが余りに対立して、人格の分裂となる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに彼は余りに側面的に刹那を考へはしなかつたか？",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の幹も見る間に余りなく濡れていつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労性の妻君が余りに赤坊の泣き声が変なので庭を横切つて来てそこから覗いてゐる所だつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "手短かに云へば、作家牧野は、もつと書き流す態の作をするにはあまりに純粋の要求があり過ぎたし、完固たるフォルムに到達するためにはあまりに情調派であり過ぎたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
