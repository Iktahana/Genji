    "definitions": [
      {
        "index": 1,
        "gloss": "Asiatic dayflower (Commelina communis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "〔染付と赤繪〕　日本の染付を支那で青華（青花）といつてゐる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に於てわれ自ら名づくるに来青花の三字を以てしたり。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "満庭の樹影｜青苔の上によこたはりて清夏の逸興｜遽に来るを覚ゆる時、われ年々来青花のほとりに先考所蔵の唐本を曝して誦読日の傾くを忘る。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "来青花その大さ桃花の如く六瓣にして、其の色は黄ならず白ならず恰も琢磨したる象牙の如し。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ茉莉素馨の花と而してこの来青花に対すれば必先考日夜愛読せし所の中華の詩歌｜楽府艶史の類を想起せずんばあらざるなり。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また青花と呼ばれる下品な花も現れる。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ雍正だの李朝だの青花だのといふ類ひだつたが、なかに不思議なものがあつた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨傘の柄を握った手の甲、青花の袖口から隙いて見える二の腕、さては頬被りで隠した首筋から顔一面に赤黒い小粒な腫物が所嫌わず吹き出ていて、眼も開けないほど、さながら腐りかけた樽柿のよう。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしと大ていおんなし位の時代には、梅島昇君、鴨下晁湖君、西沢笛畝君、渋沢青花君、「重箱」の大谷平次郎君たちがいる。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い居間は傘付き電灯に照らされ、食卓には黄色い春の花々が古い青花瓶に生けてあった。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい亭主、ここへもう一本」「へい、どぶろくのお代りで」「ばかアいえ、そっちにある青花模様の酒甕のを、おれにも二｜角ほど貰おうか」「これはいけません」「なぜ、いけねえ？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでこの行者に、お布施を授けてくれたようなもンだ」　武行者は、店へ入るやいな、かの垂涎三尺の眺めにたえなかった青花模様の上酒甕を抱え込んで大いに笑った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると仁太は、得意になって、あおばなをすすりもせずに、「氏神さまからなら、すぐじゃった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
