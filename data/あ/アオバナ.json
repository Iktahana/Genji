    "definitions": [
      {
        "index": 1,
        "gloss": "greenish nasal mucus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "間もなく小学校ゆえ君枝を自身俥に乗せて河童路地へ連れて戻ると君枝は痩せて顔色がわるく、青洟で筒っぽうの袖をこちこちにして、陰気な娘だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして五年が経ち、間もなく小学校ゆえ君枝を河童路地へ連れて戻ると、君枝は痩せて顔色がわるく、青洟で筒っぽうの袖をこちこちにして、陰気な娘だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方まだ済ないンだろう、なぞと思いながら、うッかり覗いていたが、ふッと気が附くと、先刻から側で何処かの八ツばかりの男の児が、青洟を啜り啜り、不思議そうに私の面を瞻上げている。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "青洟ではなく、透明な粘液的なものであった。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかよろしく頼んます、村の為めならどんなこつてもさせますで」と親爺は懇ろに頭を下げて、青洟をたらした子供等にまで仲間入りを頼んだ。",
              "citation": {
                "source": "泥の雨",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "善因善果、悪因悪果、早く絞首台へ追いあげられて、青洟をたらして往生しろ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺八寸のノッポで、顔は臼のようにでっかく、二十八歳で青洟を二本垂らそうという抜群さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "駕籠の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "又八も青洟を垂らし、武蔵もまだ八ツか九ツ頃の悪戯ざかりの当時、村の桑畑や本位田家の台所などで、この老婆に、（童ッ）と一声呶鳴られると臍がもんどり打ったように、縮み上がって逃げたものである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……洲股城におった頃、貴さまは青洟を垂らして、母親の手にひかれて来たろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに見る羽柴家子飼の者にしても、かつて、長浜の小姓部屋時代には、どれもこれも、青洟を垂らしかねない芋の子、山の子揃いだったのが、それが、どうして？",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると仁太は、得意になって、あおばなをすすりもせずに、「氏神さまからなら、すぐじゃった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
