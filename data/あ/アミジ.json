[
  {
    "uuid": "7d69aa95-db4a-53af-8c4f-fb655b008f91",
    "entry": "網地",
    "reading": {
      "primary": "あみじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "net fabric",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網地について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網地という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網地の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網地が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網地を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網地について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網地の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網地の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網地が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網地という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網地という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網地についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網地を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網地は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網地について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網地が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網地は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網地の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網地は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網地は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鮎川の港に近く相對して横はつた大きな島が網地島でぽつ／＼と漁人の家が見える。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "船首東南を指して、牡鹿半島を左にし、田代、網地の二大島を右にす。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "網地島の根元に凄じく打寄せてゐる波が白く線を成して見える。",
              "citation": {
                "source": "旅から帰つて",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れていれば右に網地島、左に鹿がいる金華山島が見えるのだそうだが、ただ行く手は暗黒一色に塗りつぶされている。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　それは網地島の第五明神丸という鰹船であった。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家はどこですか」「あの一番池の北の堤の下の松林のわきにあるそりゃあみじめな家なんだよ」とおっしゃる。",
              "citation": {
                "source": "同じ娘でも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああみじめにも、私はどうなるのであろう？",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
