        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日杏について考えている。",
              "source": "幻辞"
            },
            {
              "text": "杏という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は杏の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には杏が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "杏を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは杏について学習した。",
              "source": "幻辞"
            },
            {
              "text": "杏の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は杏の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では杏が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "杏という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に杏という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では杏についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "杏を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると杏は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "杏について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では杏が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に杏は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により杏の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "杏は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に杏は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この詩のモチーヴとなってるものは、漢詩のいわゆる楊柳杏花村的な南国情緒であるけれども、本質には別の人間的なリリシズムが歌われているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人夫婦の外には二十二、三の息子らしい弱そうな脊の高い男と、それからいつも銀杏返しに結うた十八、九の娘と、外には真黒な猫が居るようであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬が容捨もなく迫って来て木枯しが吹き募るある夜、散歩の帰り途に暗闇阪近くなった時、自分の数間前を肩をすぼめて俯向いて行く銀杏返しの女がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の親戚を見舞うことは断念して松住町から御茶の水の方へ上がって行くと、女子高等師範の庭は杏雲堂病院の避難所になっていると立札が読まれる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、停車場の前の、水晶細工のやうに見える銀杏の木に囲まれた、小さな広場に出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、「いき」と見られた結振りは銀杏髷、楽屋結など略式の髪か、さもなくば島田でも潰し島田、投げ島田など正形の崩れたものであった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今年は実際に小春の好晴がつづき、その上にこの界隈の銀杏の黄葉が丁度その最大限度の輝きをもって輝く時期に際会したために、その銀杏の黄金色に対比された青空の色が一層美しく見えたのかもしれない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村はずれの坂の降口の大きな銀杏の樹の根で民子のくるのを待った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はいつの間にか来ていて、昨日の雨で洗い流した赤土の上に、二葉三葉銀杏の葉の落ちるのを拾っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまア銀杏の葉の綺麗なこと。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア出掛けましょう」　民子の美しい手で持ってると銀杏の葉も殊に綺麗に見える。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の奴らに逢うのがいやだから、僕は一足先に出て銀杏の下で民さんを待っていたんでさア。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく田圃へ降りて銀杏の木が見えた時に、二人はまた同じ様に一種の感情が胸に湧いた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は今日を別れと思ってか、髪はさっぱりとした銀杏返しに薄く化粧をしている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ辻の赤いポストも美しく、煙草屋の店にいる娘さえも、杏のように明るくて可憐であった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "松住町から湯島臺へ上つて行く左手のバラツク屋根のなかゝら、茫然とした空に向つてへんにどぼーん／＼と立つてゐる四五本の銀杏樹――それにははつきり誘惑された。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんと一緒に銀杏を買いに寄ったことのある市場だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから中座の筋むかい、雁治郎飴の銀杏返しに結った娘さんから、一｜鑵、ゆいわたを締めつけるように買ってきた包のなかから、古典の都市がちらちら介在する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよとの風もない部屋の蒸暑さ、窓の向うに見える緑の深い銀杏の並木さへ葉をうなだれてゐたが、私の感覺はただ顯微鏡の小さな孔から映つてくる鬼蘭の、青い格子縞のやうな纖維に集中されてゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷大学正門内の並み木の銀杏の黄葉し落葉するのにも著しい遅速がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銀杏でもプラタヌスでも、やはり一種の生物であってみれば、ただの無機物のようにそうそう簡単でないのはむしろ当然のことであろう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　杏仁水　ある夏の夜、神田の喫茶店へはいって一杯のアイスクリームを食った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれが杏仁水であることを思い出すと同時に妙な記憶が喚び起されて来たのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で考えるとあの飲料の匂の主調をなすものが、やはりこの杏仁水であったらしい。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十年代の片田舎での出来事として考えるときに、この杏仁水の饗応がはなはだオリジナルであり、ハイカラな現象であったような気がする。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら好きの学生達は彼に「杏仁水」という渾名を奉っていた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由は簡単なことで、いかなる病気にでもその処方に杏仁水の零点幾グラムかが加えられるというだけである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはいちばんはじめにあんずの王様のお城をたずねるよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでぼくはでてきてあんずのおひめ様をつれてお城に帰るんだ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏　あんずと漢めきたる名を呼ばるゝからもゝの花は、八重なる、一重なる、ともに好し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
