[
  {
    "uuid": "49923e13-119b-5bb1-8262-0d17af2d1896",
    "entry": "安定感",
    "reading": {
      "primary": "あんていかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sense of stability",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安定感について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安定感という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安定感の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安定感が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安定感を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安定感について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安定感の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安定感の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安定感が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安定感という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安定感という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安定感についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安定感を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安定感は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安定感について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安定感が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安定感は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安定感の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安定感は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安定感は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たださあ、ちがうものがならんでいるほうが、おなじものがならんでいるより、いいんじゃないかなあ」「建物ってのはよ、安定感がなきゃあ、ダメなんだって」　こいつらは、建築家にでもなる気なのか、と慶一はうんざりした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり物理的安定感て奴を望むのだね。",
              "citation": {
                "source": "椅子と電車",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店へ入っても大概の奴が無意識に壁の方へくっつくのがそれで、結局人間は何か安定感を絶えず求めてゐるのださうだ。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も私は消滅した郷里の牧歌―そこにはともかく子供らしい安定感があった―を書きのこしておきたいと頻りに夢みる。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の顔も私の死ぬる前になれば、これはこれなりにもう少ししつくりと落ちつき、今よりはずつと安定感を得てくるに相違ない。",
              "citation": {
                "source": "顔の美について",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本の人々の感情の中には、もとよりファシズムでもない、さりとて共産主義にもつきかねて、何処かに安定感を求めている感情があります。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにこの所謂「挙国一致」は国民に生活安定感を与えることが一応出来る。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がそれにも拘らず、いやそれであるが故に、この国民生活安定感は、観念的な安定感だというのである。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――現実の実際の国民生活安定の代わりに、国民は、生活の観念的な安定感を与えられる。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、既成勢力の安定感として感じとられている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、僕は自分の部屋でもないこの部屋に（もつとも、さうでもするより他はなかつたのだが……）うつかり安定感を抱きかけてゐた。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な家屋の不安定感は、僕が動くたびに僕を脅やかし、いつでも頭上に崩れ落ちて来さうなのだ。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕がこの階段下の狭い玄関、一メートル四方にも足りない土間で、その靴を穿いて立上ると、この窮屈な家屋全体の不安定感は僕の靴の踵に吸収されてしまふ。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十を越しても尚、舞台顔に安定感を持ち続けることの出来るのは、立役の持つ幸福である。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、ここにある一種の安定感。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "必然性の上に立って活動するのだ、と思いこむのは、やはり何らかの安定感、僕に言わせれば用もない生温い背景を持つことにすぎない。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全體のがつしりした安定感はこの男のもつ職務意識の強さを物語り、顏面骨相の品格に乏しい鋭い小人物的個性は迫眞を通り越し、横向はことに暴露的である。",
              "citation": {
                "source": "古代エジプトの作品",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘプバーンのようなのッけからのあどけなさ無邪気さには安定感がない。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "末席は一番多忙でありながら、これ以上おちるところがない安定感があった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味のうちに籠められた甚だ清潔にして華麗な思想や、色彩の趣味や、部分的には鐘楼と鼓楼の睨み合つた落付など、均斉の意志といふことは別として一面人に泌みるところの現実の安定感を思ふだけでも、恐らく隠元その人は遠く狂者と離れた人で、隠元豆の円味すら帯びた人格であつたかも知れません。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川は不均斉を露出する逆方法によつて、先手をとりながら危なさを消す術の方を採用してゐたのでしたが、日本人の生得論理と連絡のないニヒリズムの暴力の前では、映画の中で行ふ種類の木遁の術の手並でも、却々もつて彼等のひねくれた眼力を誤魔化し、安定感を与へてやることはできません。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸にたずさわり、批判的に芸を見がちな私のようなものが、その劇場に居る限りは、作者や教師、演者たちの機智にまかせきって、たのしめるという安定感を与えてくれる劇団はそう多くはありません。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その安定感を与える力があれば、それは大人の舞台と申すべきで、宝塚は名は少女歌劇ですが、その舞台は大人のものと申せます。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ芸の未熟な少女も未熟ながらみんな生かして使っており、見ばえとか効果というものを自家薬籠中のものとしたシニセの安定感と申しましょうか。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その錯覚を振りおとさうと、大海人はわざと肩へ力を入れたり、頬杖のかげんを強めたり弱めたりして、わが身の安定感をためしてみる。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいつもいふ、まるで急行列車がトンネルに走入つたやうな、その騒音は、夜の夜中、反つてそれをききなれた私の耳には、はげしい刺戟といふよりも一つの平和な常態で、その騒音は、私の耳には、いはばある安定感の保証のやうなものでもあつた。",
              "citation": {
                "source": "海辺の窓",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫やりしてゐても見る物は見てゐるのではないか、あれで却々奧底は判らないといふ不安定感が、その夜は荷物を見ることをやめて部屋に引き取るやうにさせた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えて見るとディレッタンティズムは実は甚だ積極的なあるものの現われなのであって、ただそれがこの社会の一定層の成人にあり勝ちな生活安定感を破らない限度において、安全な消極的な表現をしか試みないものに他ならない。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な栗材の井桁の上は、廣々として充分の安定感があり、釜一つ置いたところで、何んの危な氣もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
