      {
        "index": 1,
        "gloss": "any shark of genus Centrophorus (esp. the dwarf gulper shark, Centrophorus atromarginatus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
