    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be anxious (about)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案じるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "案じるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案じるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案じるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案じるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案じるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "案じるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案じるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案じるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案じるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案じるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案じるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案じるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案じるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案じるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案じるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案じるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案じるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案じるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案じるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、そのままお前の身を案じるやうに消毒室の方へ出て行つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてこの間の女が出て来て、さぞびっくりしたろうが、決して案じることもない、怖がることもない、唯おとなしくして、わたし達の云う通りになっていれば好いと、優しくいたわってくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私はすぐに「鮓」を思い出してそれを足場にした付け句を案じるであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案じることはない」　父は歩いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に会話受持のチャペルという教師は、非常に点数の辛い人であるから、会話の成績が悪いとあるいは落第するかも知れぬと実事虚事打混ぜて哀訴嘆願に及ぶと、案じるよりも産むが易く、ヘボンの字書なら買ってもいいということになって、すぐに二円五十銭を渡された。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し案じるよりも生むが易い。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "案じるほどのこともなく、みんなが声援してくれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、遠く離れて居れば、むす子の健康が、一番心配だとしきりに案じるかの女を安心させるため、むす子はかの女達が、英国や独逸へ行って居る間に出来た友人で、巴里でも有名なある外科病院の青年医を両親に見せることにした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると案じるより産が安いで、長い間こうやって一所に居るが、お前様の断念の可いには魂消たね。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍してやらあ、案じるな。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "案じるよりは生むが易いかも知れない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「持病とあれば左程案じることもなかろう、癒るまで逗留して、それから出発せらるるが宜い」「お詞にあまえるようで、心苦しゅうございますが、どうぞ乳母の病気が癒りまするまで、お助けに預かりとうございます」　壮い女は涙を流した。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の母が悪いのではないかと母が案じる。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "気さえ確になりゃ、何お前案じるほどの容体じゃあねえんだぜ。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ無事に収まる地震の分ってる奴等が、慌てて逃げ出す必要があって、生命が危険だと案じる俺達が、密閉されてる必要の、そのわけを聞こうじゃないか。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、従来も度々言ひましたし、又今日こんなに言ふのも、皆｜阿父さんの身を案じるからで、これに就いては陰でどれほど私が始終苦心してゐるか知つてお在は無からうけれど、考出すと勉強するのも何も可厭になつて、吁、いつそ山の中へでも引籠んで了はうかと思ひます。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "案じるよりは産むが易いとは此の事です」　最後に残ったのは女二人の始末である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "案じるよりも産むが易いの譬えで、思いのほかに主人がこころよく免してくれるかも知れないと言った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよ　ふだんと違って此頃は、帰りが遅いと内でも案じるであろうから、日の暮れぬうちに早くお帰りなさい。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ誰かが飛び込んで取｜鎮めるから案じることはない。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これからワザと母の前で、お蝶を案じるようなことばかり云つてやらう、そんなことを彼は思ひながら、「いづれ帰つてから、いろいろ話しますが、あまり便りがないとすると、僕は今度そつちへ行つたついでに、静岡まで行つて見て来ようかと思つてるんですよ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂の声には義妹の容態の悪化を案じるよりも、病院の申出に至らしめたとよ子の現在を詰問する口ぶりの方が、あらわであった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「処世の道なんてものは案じるより生むが易いと云はるる通りですからね。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎　まあ、まあ、さう案じることはない。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家を案じるのは道理であるが、夜詣りをするようになってから、彼は決して供を連れて行かないということが妻の注意をひいた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その藻の父が長くわずらっているので、彼は自分の父を案じるように毎日見舞いに来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならあんじることはない」　むしろ、一｜党の人は、それで愁眉をひらいていた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
