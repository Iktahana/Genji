[
  {
    "uuid": "e8f45a9d-70ea-53fc-8388-a7f47e2d5962",
    "entry": "案じる",
    "reading": {
      "primary": "あんじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
