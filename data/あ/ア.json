        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アルゼンチンはタンゴの発祥地です。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチンの牛肉は世界的に有名です。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチンはW杯優勝国です。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチンの首都はブエノスアイレスです。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチン経済は成長を続けています。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチンワインは高品質です。",
              "source": "幻辞"
            },
            {
              "text": "アルゼンチン人の多くはスペイン系です。",
