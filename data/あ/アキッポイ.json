        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これが犬の子を持って来て、すぐに飽いたのでしょう、捨てたらしい、これは飽きっぽい子ですから、とそう言うのです。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は自分で飽きっぽい男だと言ってるが、案外そうでもないようだね。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が二人とも飽きっぽいんで、さんざっぱら可愛がったそのあげくには、千住か、品川か、新宿で、稼いで貰わなけりゃあならねえかも知れねえ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人と云う奴は飽きっぽいんでね。",
              "citation": {
                "source": "人を呪わば",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽きっぽい日頃にも似ず、こればかりはすっかり腰を据えて、芸名をそのまま、沢村千代之助と名乗って売り出しました。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜一は少し飽きっぽい性質で、一つの遊びをそう永く続けようとはしない。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "短気で飽きっぽい彼は、次つぎと仕事を変えながら、どんな仕事も一年とは続かず、一年か二年おきくらいに、家をとびだすようになった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の代り、また非常に飽きっぽい質で、惚れて／＼惚れ抜いて、執拗い程ちやほやするかと思えば、直きに餘熱がさめて了い、何人となく女房を取り換えます。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてナオミは非常に飽きっぽいたちで、どんな遊びでも初めは馬鹿に夢中になりますが、決して長つづきはしないのでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでしょう、なにしろ飽きっぽい人ですから、と答えながらおかやは喜兵衛に酌をした。",
              "citation": {
                "source": "霜柱",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょろはおちつきのない空想家で、飽きっぽい饒舌漢なのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもお話する通り、私はこれで相当の教育は受けながら、妙に物事に飽きっぽいたちだものですから、何かの職業に就いても、大抵一年とはもたない。",
              "citation": {
                "source": "モノグラム",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺のは刹那的一夫一婦主義だ」と云っていたが、つまり極端に惚っぽく、飽きっぽいたちなのである。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに多くのおいしい醜聞が発生したので、飽きっぽい世間の記憶から消えた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽きっぽい彼は、三日目あたりになると、もう押入れの寝台には興味がなくなって、所在なさに、そこの壁や、寝ながら手の届く天井板に、落書きなどしていましたが、ふと気がつくと、丁度頭の上の一枚の天井板が、釘を打ち忘れたのか、なんだかフカフカと動く様なのです。",
              "citation": {
                "source": "屋根裏の散歩者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、こう申上げると、わたくしは甚だ移り気な、あきっぽい人間のように思召されるかも知れませんが、わたくしは例の怪談研究の傍らに探偵方面にも興味を持ちまして、この頃はぼつぼつその方面の研究にも取りかかっております。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、こう申し上げると、わたくしは甚だ移り気な、あきっぽい人間のように思召されるかも知れませんが、わたくしは例の怪談研究の傍らに探偵方面にも興味を持ちまして、この頃はぼつぼつその方面の研究にも取りかかっております。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの地方の百姓たちで、もしそれがあきっぽい性格なら、百姓をやめて他国に移住するか、自殺でもするよりか仕方がない。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一体あきっぽいたちでして、これまで同じ仕事を二年と続けたことはない程ですが、その私が教会に五年も辛抱したというのは、そういう訳で、私などにも、自然実入りがたっぷりあって、居心地がよかったからでしょうね。",
              "citation": {
                "source": "盗難",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
