        "examples": {
          "standard": [
            {
              "text": "毎日、呆気について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の呆気戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "呆気の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "呆気という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは呆気について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "呆気の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "呆気に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは呆気を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での呆気は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、呆気は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "呆気は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な呆気を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「呆気」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
