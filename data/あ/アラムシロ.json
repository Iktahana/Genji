    "definitions": [
      {
        "index": 1,
        "gloss": "loosely woven mat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒筵について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒筵という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒筵の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒筵が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒筵を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒筵について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒筵の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒筵の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒筵が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒筵という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒筵という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒筵についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒筵を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒筵は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒筵について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒筵が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒筵は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒筵の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒筵は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒筵は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "片側は滑かであるが、裏側はずいぶんざらざらして荒筵のような縞目が目立って見える。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神さんは私を引入れましたが、内に入りますと貴方どうでございましょう、土間の上に台があって、荒筵を敷いてあるんでございますよ、そこらは一面に煤ぼって、土間も黴が生えるように、じくじくして、隅の方に、お神さんと同じ色の真蒼な灯が、ちょろちょろと点れておりました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "話に聴いた、青色のその燈火、その台、その荒筵、その四辺の物の気勢。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの土間には荒筵が敷かれてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼次が藥貰ひに出た跡で手に餘る茶の葉をいぢつて居たのであるが強くなつた葉はいくら荒筵の上で押し揉んでも容易によりつからぬ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月なかばの夕日は孤城を囲んだ大軍のように筵張りの小屋のうしろまでひた寄せに押し寄せて、すこしの隙もあらば攻め入ろうと狙っているらしく、破れた荒筵のあいだから黄金の火箭のような強い光りを幾すじも射込んだ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにこの楽屋はちっとも風がはいらないんだからね」　お辰は病める太夫の枕もとをそっと離れて、楽屋のうしろに垂れている荒筵を少し押し分けると、夕日の光りはもう山の手の高台に隠れて、下町の空は薄い浅黄色に暮れかかっていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けから午までは青物市がここに開かれるので、西両国には荒筵を一面に敷きつめて、近在の秋のすがたを江戸のまん中にひろげていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "床には荒筵を敷いて、棚には素焼の壺などが二つ三つ乗せてあった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面には荒筵二枚の上に、新しい畳二枚を裏がえしに敷き、それを白木綿で覆い、更に毛氈一枚を襲ねてある。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪のくすぶっている炉の傍に、薬湯がかかっていて、蝿が荒筵の条目を斜めに匐っているばかりだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと向こうに数枚の荒筵が、つなぎ合わされて垂らしてあった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒筵の遥かの奥の方から、祈祷の声が絶えず聞こえ、鈴を振る音が合間合間に聞こえた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に荒筵の奥から、男の怒鳴る声がした。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ヒョロヒョロした歩き方で、一匹の犬の側へ行ったが、やにわに頸がみを掴まえると、荒筵の方へ引きずって行った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「贄持って来オ――、贄が足りねえ――ッ」「オ――」　と、こっちからまた一人が云った、坊主あがりらしい円い頭の男が、ノッとばかりに立ち上がると、一匹の狐をひきずりながら、荒筵の前まで行き、狐を向こうの部屋へ投げた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に荒筵が、向こう側からかかげられ、金剛杖に身を縋らせた、金地院範覚がよろめき出た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下りだ、気をつけなさい」　という里好の声で、お蔦が足をすべらせないように木で張った梯子段をおり切ると、眼の前の二間ほどの所に、荒筵が二枚だらりと下がっていて、その目を通して、何やら黄色い光が、地獄の夢のように、ぼうっともれている。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ている敷物はいつしか荒筵に変っている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "御隱殿裏に着いたのは、まだ朝のうち、とある藪蔭に、荒筵一枚を褥に、淺ましくも美女の死骸は横たへられて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "萠え始めた若葉の上、連翹が上から差しのぞいて、淡い春の陽、遠卷にした野次馬の眼にも、荒筵からはみ出した白い脛と、踏み脱いだ下駄が、赤い鼻緒を下にして、八文字に飛散つてゐるのが、不思議な魅力だつたでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれですが、親分」　町役人をわけて入つた三吉は、荒筵を退けて、平次の前に死骸をさらしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に入ると、見物はバラリと五十人ばかり、草の上に荒筵を敷き、その上に茣蓙を敷いて、下足は銘々持ち、芝居は何やら物々しく展開して居り、見物は固唾を呑んでそれに陶醉して居る樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "轉婆娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「備後表だ」　荒筵でもあることか、死骸を包んだのは眞新しい備後表、縛つた繩は、荷造用の逞ましい麻繩です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "据物斬の腕がなきや人間の首は切れねえ」「――」「奧座敷か奧庭で斬つたから、荒筵でも菰でもない、大納戸にでも入つて居る疊表に包み、荷造の麻繩で縛つて、不淨門から持出させたのさ」「――」「殿樣の無體の折檻、女は言ふ事を聽かずに死んだ――可哀想に」　平次はもう一度美女の死骸に首を垂れるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤井左門から命令があつたものか、庭先には高張提灯をかゝげ、番手桶を積み荒筵を敷き、俄か事乍らすべてお白洲其儘に作つて、往來に向いた庭木戸を眞一文字に開かせました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "大盜懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は庭の眞ん中に敷いた荒筵の上に引据ゑられて荒筵を突き破つて打ち込んだ青竹に、半身裸のまゝ荒繩で縛り上げられました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "大盜懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下の大地の臥床が、贅沢乍ら落ち付きのある、最上等の寝室に変って、荒筵がスプリングの寝台に化け、街灯の遠い光が、美しい電灯の近い光に、そして何時も私の寝込を襲って、叩き起こす髯武者のお巡りさんが、思いもよらぬ美しく若い女中に変って居るのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の儘眠ってしまえば、翌る朝私は、あのいつもの橋の下で、荒筵の中に眼を覚すでしょう。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
