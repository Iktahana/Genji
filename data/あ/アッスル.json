        "examples": {
          "standard": [
            {
              "text": "毎日、圧するについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の圧する戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "圧するの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "圧するという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは圧するについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "圧するの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "圧するに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは圧するを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での圧するは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、圧するは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "圧するは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な圧するを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「圧する」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧する」という概念について深く考察する必要があります。",
              "source": "幻辞"
