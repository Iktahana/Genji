    },
    "definitions": [
      {
        "index": 1,
        "gloss": "matter (to discuss)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案件について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案件という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案件の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案件が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案件を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案件について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案件の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案件の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案件が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案件という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案件という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案件についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案件を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案件は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案件について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案件が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案件は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案件の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案件は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案件は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "僕の些細な案件をひとつふたつ記録してくれるくらいは構わないのだが。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "手元の案件のうちでは、ひとつだけやや込み入った事件の問い合わせが、マルセイユからあるのだが、それ以外は惹かれるものが何もない。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの案件に謎など何もありはしない。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "多忙のあまりベイカー街へも行けなかったし、向こうも職業上の案件をのぞいてはほとんどどこへも出かけなかったからだ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "当社はマティルダ・ブリッグス案件でのご活躍を記憶するものにて。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "注目に値する案件、だ！",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『貴君の案件喜んで調査する所存。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "似たような案件のご経験は？",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "案件の出来からして、自ら調べるべきです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの目から見てもさぞや扱いがたく、ややこしい案件でしょう。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕の流儀で案件を取り扱うことお許し願いたい。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイカー街一一月二一日　　　吸血鬼の件拝復　一九日付のご来信について、当方、貴社依頼人ロバート・ファーガソン氏（ミンシン横町の紅茶卸ファーガソン＆ミュアヘッド経営）の調査を請け負い、案件を無事解決したことを恐れながらここに申し上げます。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この案件に対して貴殿が取り組むさまをながめるのは、これまで知的娯楽でもあったのだが、忌憚なく言うならば、こう過激な手立てを講じるのは、予としても実に心苦しい。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いやはや、』と言いながら僕は立ち上がる、『この楽しい会話につられて、よそで僕を待つ重要案件も放り出すところでした。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "金博士始末案件（一）王水険博士を擁立し、金博士を牽制するとともに、必要に応じて、金博士をおびき出すこと。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それももちろん重大な案件であるが、それだけならば、まだ話が簡単であるともいえる。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重大な案件の討議は、夜食の後、撞球室でやることになっていたが、誰であれ、いくらかでも霊的な感受性を持っているかぎり撞球室会議に連なる資格があり、ラスプーチンの席はその当人がまだペテルブルクに現われない前からすでに用意されていたというわけなのであった。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この指名は、他のすべての案件に先だつて、これを行ふ。",
              "citation": {
                "source": "新憲法の解説",
                "author": "日本國憲法",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん時世に相応した幾つかの補充訂正をもって、さらに未来の可能性を討究すべき現実の案件であったのかもしれない。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の広田外相は同月五日の閣議に於て云っている、「今回の事件は先の北支停戦協定違反事件と異り、純然たる外交交渉案件である故、専ら外交当局をして折衝せしめている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "広田外相は五日の閣議に於て云っている、「今回の事件は先の北支停戦協定違反事件と異り、純然たる外交交渉案件である故、専ら外交当局をして折衝せしめている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者はあなたの案件を、解剖し公式化し名を指し言い現わし、語らしめてくれるでしょう。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君にピッタリの案件だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからハーマンに渡す名刺を置いて、重要案件で今晩会いたいと言え。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミがここへ来たのは国家の重大案件を論ずるためだな。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「休暇どころじゃない、これは絶対警察案件じゃないなあ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク市警から持ちこまれた案件で、コベントリを逮捕したいからでございます。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり海軍大臣と東女帝丸艦長が重要案件で会談する。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の半生はあんけんさつ続きで、芽の出ないずくめだと笑っていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんけんさつとは何なのか判らん。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
