    "definitions": [
      {
        "index": 1,
        "gloss": "aftercare",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフターケアについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフターケアは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフターケアについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフターケアの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフターケアが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフターケアを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフターケアが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフターケアが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフターケアは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフターケアは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフターケアは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフターケアについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフターケアの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフターケアの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフターケアの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "感覚的には、ソフトもアフターケアーもハードのおまけだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフターケアはサナトリウム治療と同じくらい重要でありサナトリウム治療は教育、早期発見に始まりリハビリテーションに終わる一連の社会的処置の一環に過ぎない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
