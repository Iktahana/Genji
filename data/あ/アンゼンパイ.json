        "examples": {
          "standard": [
            {
              "text": "私は毎日安全牌について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全牌という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全牌の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全牌が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全牌を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全牌について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全牌の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全牌の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全牌が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全牌という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全牌という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全牌についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全牌を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全牌は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全牌について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全牌が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全牌は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全牌の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全牌は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全牌は興味深い例である。",
              "source": "幻辞"
            }
