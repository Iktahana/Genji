        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例えば（サル）（ワ）（カー）（マ）（サ）（ムリ）（ダ）（シア）（アシユ）（ワ）（メ）（ダ）（シア）（ヤト）（フア）（ラム）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪を下りて行くと別莊だか茶店だかゞあつて其前の養魚池の岸にかはせみが一羽止まつて居たが、下の方から青年團の服を着た男が長い杖をふりまはして上がつて來たので其のフアシズムの前に氣の弱い小鳥は驚いて茂みに飛び込んでしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アシビ」明37・５",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ボードレエルは、酒と阿片とアシッシュとに就いて、その藥物學的比較觀察をした後で、酒がいちばん健全であり、毒物的危險性がない上に、意志を強くするといつて推奬してゐる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿片やアシッシュに比べれば、酒はたしかに生理的であり、神仙と共に太初から有つたところの、自然の天與した飮物である。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次観念してシャアシャアと、Ｔ「今日も亦旦那の糞詰り見てえな面にぶつかりやしたね」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜シャアシャアとして続ける。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴女の移気な恋愛のオアシス、近代女の株式、同盟破棄！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグのオアシスはいまでは相場師で埋もれてはいないであろうか？",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテアシタハヒルトナリ、　　水音イヨヨシゲクシテ、　鳥トキドキニ群レタレド、　　　ヒトノケハヒハナカリケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ高木モ夜トナレバ、　　　サラニアシタヲ云ヒカハシ、ヒトビトオノモ松ノ野ヲ、　　　ワギ家ノカタヘイソギケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ている沢山の群集の中に尊いアショウカ大王も立たれました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっつけるばかりでなく、恐らくそのシャアシャアした婦人を暗く不幸にせずにはおかないように思えました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西北隣のロシアシベリアではあいにく地震も噴火も台風もないようであるが、そのかわりに海をとざす氷と、人馬を窒息させるふぶきと、大地の底まで氷らせる寒さがあり、また年を越えて燃える野火がある。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、何ていったかしら、アシクリゲ、……」「膝栗毛だろう。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーティストは、つめたい水でシャアシャアと私の頭を洗ひ時々は指で顔も拭ひました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アワよくば能を鼻でアシラって遣ろう。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーティストは、つめたい水でシャアシャアと私の頭を洗い時々は指で顔も拭いました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その狭い往来に五、六株の大樹が繁っているのであるから、邪魔といえば邪魔であるが、電車も自動車もない時代にはさのみの邪魔とも思われないばかりか、長い堀ばたを徒歩する人々に取っては、その地帯が一種のオアシスとなっていたのである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔の江戸時代には、他にもこういうオアシスが沢山見出されたのであろう。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストは、アシかなにかのように、まんなかから、ポキッと折れてしまいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、みどりのアシのあいだから、そっとのぞいていたのでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは、あのみどりの色をした、アシに似ているんだよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、アシは、一度切りとられれば、もう二度とみどりの葉を出すことができないだろう。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、ただ、アシのあいだに休ませてもらって、沼の水をほんのすこし飲ませてもらえば、それだけでよかったのです。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、二羽のガンは、アシの中へ、まっさかさまに落ちて、死にました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
