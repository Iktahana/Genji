[
  {
    "uuid": "e3f1a0c7-461a-561d-a5bc-f452f0040a19",
    "entry": "悪し",
    "reading": {
      "primary": "あし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "'shiku' adjective (archaic)"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "つまり、大男の自分を憎悪しているのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に就中蕪村の如く、文化が彼の芸術と逆流しているところの、一の「悪しき時代」に生れた者は、特に救いがたく不遇である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう想い出の国の人々は、別にえらい人でもなんでもなかったであろうが、そういう人々から全く無意識の間に受けた教育の効果は、よかれ悪しかれ実に予想外に重大なものであるということが、やっとこの頃になって少しばかり分りかけて来たような気がするのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか悪しからず御諒察を願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな取止めもない事では雑誌に載せて頂くのは如何かと存じますが御返事までに申上げます、どうか悪しからず願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし個人的には、たとえそれは自覚されないにしても、何かしら自ずから一定の標準をもっていて、それに当嵌めて口調の善し悪しを区別している事だけは否定し難い事実である。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くともこれほど信頼する山が悪しゅうは取計う筈はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "形悪しきには死にかかっているものが住んでいた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "禍ひの神といふ者もしあらば、正しく我身さそはれしなり、此時の心何を思ひけん、善とも知らず悪しとも知らず、唯懐かしの念に迫まられて身は前後無差別に、免がれ出しなり薄井の家を。",
              "citation": {
                "source": "雪の日",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さん意地悪したから教えない事よ」　「手紙あるだろう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四日間」の戦争の悲惨を憎悪した内容が二葉亭の当時の態度を暗示しているかもしれないが、それらは、若し次の機会があらば、すべてをまとめて、もっと完全なものとしたいと思う。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「決して御客様方の人格を疑うような訳ではありませんが、これも職務で御座いますからどうか悪しからず御勘弁を願います」と云う。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人も、職長も、古参の社員も、嫌悪した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と、きまりも悪し、もじもじ聞くとの。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く芳はしき香も悪しからず、花の黄金色なせるも地にこぼれて後も見ておもむき無きならず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての自然の風景を、理智に依って遮断し、取捨し、いささかも、それに溺れることなく、謂わば「既成概念的」な情緒を、薔薇を、すみれを、虫の声を、風を、にやりと薄笑いして敬遠し、もっぱら、「我は人なり、人間の事とし聞けば、善きも悪しきも他所事とは思われず、そぞろに我が心を躍らしむ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイアボロス、ベリアル、ベルゼブル、悪鬼の首、この世の君、この世の神、訴うるもの、試むる者、悪しき者、人殺、虚偽の父、亡す者、敵、大なる竜、古き蛇、等である。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに蒼ざめて血色｜悪しき顔の夜目には死人かと怪しまれるばかり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに蒼ざめて血色悪しき顔の夜目には死人かと怪しまれるばかり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は尺八のことにはまるで素人であるから、彼が吹くその曲の善し悪し、彼の技の巧拙はわからないけれども、心をこめて吹くその音色の脈々としてわれに迫る時、われ知らず凄動したのである。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日はぜひ諸君に聞いていただかねばならぬ用事があったことですから悪しからず許してください。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか悪しからず」　とできるだけ言葉少なに思いきっていってしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　名刺を返して、「悪しからず……お名前だけ記憶します。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が歇んだので未醒画伯戦場ヶ原の真中へ三脚を立て、悠々写生を初めたところが、折悪しく吹き捲くって来た一陣の烈風に、画板を吹っ飛ばされ、絵の具は躍り出す、いやはや大｜狼狽。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も上京して応援したいんだけれども知つての通りの境遇だから悪しからず思つてくれ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "この血の跡を慕い行かばその行先を突留め得べきが、単身にては気味悪しと、一まず家に立帰りて、近隣の壮佼の究竟なるを四人ばかり語らいぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子は苦悶して悲鳴を揚げ、右に左に枕を代えて、長き黒髪地を掃きしが、最後の一撃は手元狂いて打処や悪しかりけむ、うむとのけぞりて渠は絶せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風月堂のかすてらも悪しからず、引包めて二両ばかり買うが可い。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　極りも悪し、摺り状に退った。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシックはテンポが遅いどころか、「ああした深いことをもう云つてのけたのか」と、君が若しミュジックなるものの存在に耳を触れるに相応しければ当然感ずる次第なのであつたかも知れない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
