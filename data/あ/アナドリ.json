        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日侮りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "侮りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は侮りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には侮りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "侮りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは侮りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "侮りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は侮りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では侮りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "侮りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に侮りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では侮りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "侮りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると侮りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "侮りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では侮りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に侮りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により侮りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "侮りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に侮りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "つまり忠実な体感をすればよかつたのだが、彼のやうに絶対の要求の強い人はそれを二次的のことと侮り易い。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来正賓は近年逆境におり、かつまた不如意で、惜しい雲林さえ放そうとしていた位のところへ、廷珸の侮りに遭い、物は取上げられ、肋は傷けられたので、鬱悶苦痛一時に逼り、越夕して終に死んでしまった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るれば福を致し、或は侮り、或は亢れば災を致すのは、何事に於ても必ず然様有る可き道理である。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり文明の力を買いかぶって自然を侮り過ぎた結果からそういうことになったのではないかと想像される。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むだな侮りを受けたくないのである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い侮りの笑い声がドリアンの唇から洩れた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の卑屈な知恵や小力が、どう悪あがきしても侮り難い強大な意志に圧迫されるのでしょうな。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、自分を今にきつとえらくなるものと思つてゐたし、英雄としての名譽をまもつて、たとひ大人の侮りにでも容赦できなかつたのであるから、この落第といふ不名譽も、それだけ致命的であつたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然樣いふ場合には一婦人の身を以ても、中々侮り難い事を做し出すもので、所謂『氣の張り』は才智をも發展させ、擧手投足をも敏活にさせるもので有るから、「其の人の天より稟けただけのものを十分に使用し盡す」情状になる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐米の人はすべて古代を侮り、未來を夢想的に賞美して居つて、時間さへ經過すれば世は必らず文明光耀の黄金期に入るもののやうに感じて居る傾が多いが、大空間の地球も掌上の獨樂も同じ事であつて、其の能く自ら保ち支へて廻轉して立つて居る間は幾干も無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来正賓は近年逆境に居り、且又不如意で、惜しい雲林さへ放さうとして居た位のところへ、廷珸の侮りに遭ひ、物は取上げられ、肋は傷けられたので、鬱悶苦痛一時に逼り、越夕して終に死んで仕舞つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女あがりの女をと気がさして、なぜか不思議に、女もともに、侮り、軽んじ、冷評されたような気がして、悚然として五体を取って引緊められたまで、極りの悪い思いをしたのであった。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は新米の乞食のわたくしを見て、女と侮り矢庭に「擲るぞ」と拳を振上げて、威嚇しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして酒徒としての私にはやや差し障りそうな道連ではあったが時とすると侮り難い小さな監督者であろうも知れぬが、だが、私自身にも寧ろ或はそれを望んだ心もちもあった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小勢の敵と侮りて不覺を取るな。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠城軍が堅守の戦法は、なかなか侮り難い上に、寄手の軍勢は戦意が薄い為に、戦局は、一向はかばかしくない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は、昌幸の武勇侮りがたしと思って、真田の嫡子信幸を、本多忠勝の婿にしようとした。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、夫人も今は、この小娘侮りがたしと見て、必死だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の貧しきを侮り、その目しひたるを奇貨として、我は我が未だ嘗て敢てせざりしところのものを敢てしたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドにもクリアン・チャンド王狩りすると兎一疋林に入りて虎と化けた、「兎ほど侮りゃ虎ほど強い」という吉瑞と判じてその地にアルモウー城を建てたという。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は今日歐米の車夫などが客を侮り辱めて詛言する如く、吾邦にも中世下等人は動もすれば輕々しく詛言した證でも有れば、又歐米と等しく其頃は詛言者を犯罪として縛り罰し得た徴でも有る。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、さも侮り軽んじたごとき調子で落しめて言うのに和して、「狂人だ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の話、花柳界の話、なんでも来いというような者もあって、大道商人といえども迂濶に侮りがたい時代であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらぬは坐したるままにて答ふれど、侮りたるにもあらず、この仲間の癖なるべし。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には一婦人の身であっても中々｜侮り難い事を為すもので、いわゆる「気の張り」は才智をも発展させ、挙手投足をも敏活にさせるもので有るから、「その人が天より受けただけのものは十分に使い尽す」状態になる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米の人はすべて古代を侮り、未来を夢想的に賞美していて、時間さえ経過すれば世は必ず文明光耀の黄金期に入るもののように感じている傾向が多いが、大空間の地球も掌の上で回る独楽と同じ事であって、その能く自ら保ち支えて回転して立っている間はいくらもないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "気負って才能を誇る者、頭から学問を馬鹿にし、繰り返し習う（稽古）という事も、昔のことを調べる（温故）ということも、何の益が有るものかと思い侮り、俺は人の弟子になるより人の師となる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って天命を疑い、大人を軽んじ、お言葉を侮り、ひたすら自己の私情を基本にして、勝手気ままに昂ぶり、いわゆる形式呼ばわりして先人の訓を卑しみ、形式に囚われると云っては大道に従わず、自己の発露・個性の展開などと譫語・妄言する者は皆この同類である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "侮りし風早もかくては与し易からず思へるなるべし。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より間は幾許も有らざるに、急所の血を出せる女の足取、引捉ふるに何程の事有らんと、侮りしに相違して、彼は始の如く走るに引易へ、此方は漸く息疲るるに及べども、距離は竟に依然として近く能はず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
