    "definitions": [
      {
        "index": 1,
        "gloss": "to act as an intermediary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これより寝間に入る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急ぎて寝間に入る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間に入るやバケツを投るように置いて大急ぎで炭俵の口を開けて見た。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間に入るほど迷信は雪と共に深い。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭の話から寮の中のそういう男女の感情生活を察し返すと今更けち臭くも小骨の折れる気がして、再仲間に入るのが億劫になって来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と佐山銀之助は茶の間に入ると直ぐ訊た。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が先生に呼ばれてその居間に入る時、梅子は何故あんな相貌をして涙を流して自分を見たろう。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はやや沿岸を離れて桑畑と雌松の林間に入る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "進みて一の廣間に入るに、地に委ねたる石柱の頭と瓦石の堆とは高草の底に沒し、こゝかしこに色硝子の斷片を留めたる尖弧式の窓をば幅廣き葡萄の若葉物珍らしげにさし覗き、數丈の高さなる墻壁の上には荊棘叢り生ぜり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出てこの垣根に沿ひ十間も行くと、徑は森の間に入る。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　南瓜　街道は小山の間に入る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの通りから厨の傍やら帳場の傍やらを通つて奥深く入つて行くと、そこに入口があつて、その向うに幅の広い階段がある、それを登つて八畳の間に入ると、海が一目に見わたされるその料理屋。",
              "citation": {
                "source": "島の唄",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　二階の薄汚い彼の居間に入ると、彼は、耐えとおして来た悲しさと口惜しさとを一時に爆発させて、側らの硝子戸がビリビリ鳴り出したように思われるほど、大声を挙げて、泣いて泣いて泣きまくった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢやによつてそれはやはり當事者の間で先づ話し合うて見て、どうしても話し合ひがつかん時に、事情によつてはわしらが間に入るといふのが、これがまアものの順序やらうと思ふ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私事だから村長の職にあるものが、最初から間に入ることが出來ない、といふことは駿介には理解しかねることであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出してゐた方がもらふ方になり、拾錢が間に入ると、相互の態度も亦一變した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、須磨子が湯上りの身体に派手な沿衣を引掛けてとんとんと階段を上つて自分の居間に入ると、ふと承塵に懸つた額が目についた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エヂソンはその翌る晩ある宴会に誘ひ出されたが、騒々しい人なかを好かない性なので、客間に入るとすぐに片隅に置いてあつた椅子にもたれて、何か考へごとをしてゐるらしかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入って行って、その時分でさえ、小さく窮屈だった椅子に横にかけ、机にのしかかり、話の仲間に入る。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も先ず廊下へ誰が出たとて容易には見附からぬ無難な所へ身を隠して篤と考えて見ねばならぬ、夫には二階へ上り、甚蔵の元の寝間に入るが第一だ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんにちは――」といいながら、上って、茶の間に入ると、そこに稲子さんと窪川さんとがいた。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さぞ道中御つかれの事と存じまするで、今宵はどうかお早くお寝みを願いまする」　主人の挨拶を幸いに純之進は漸く奥まりたる一間に入るを得、ただ一人打くつろぐ事が出来た。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、そうすることは、私が社会主義者の仲間に入るということを意味するので、今まで世話になった伊藤にすまないと思った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "逼りたる水はやむなく山と山の間に入る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世は、子供から青年になる時一度といふ事に大抵なつて居りましたが、昔は村や町の若者仲間に入る場合と、其からもう一つ、もつと小さい時のがあつて、それが古風でした。",
              "citation": {
                "source": "古代生活に見えた恋愛",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、船乗になって悪い仲間に入る前には、よい育ちであったのだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分勿論そうなり、然し、モヤ余り、そんな仲間に入る為に来たのではないなどと云う故、自分も腹を立て、いやな心持になった。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んだ女はこんな政治やの仲間に入ることを却って恥とする位だろう。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち日本國見在書目録であつて、編纂の時代は支那で唐昭宗の時代に當るから、順序より云つたら隋書經籍志と舊唐書經籍志との間に入るべきである。",
              "citation": {
                "source": "日本國見在書目録に就いて",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、櫛の歯が髪の毛のあいだにはいるかはいらないうちに、おそろしい毒が、姫の頭にしみこんだものですから、姫はそのばで気をうしなってたおれてしまいました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
