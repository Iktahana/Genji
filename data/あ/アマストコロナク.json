[
  {
    "uuid": "191f6cb0-216c-5072-a6bf-cc536843ba5d",
    "entry": "余すところなく",
    "reading": {
      "primary": "あますところなく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
