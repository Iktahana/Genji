        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ヴェランダの床には、律儀にならんで立った空き缶がふたつ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "缶詰をもちこむのは、空き缶の処理にくらべれば、朝飯前だということが、部室にたむろっている連中にも、身にしみて理解できるようになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいちに、ロッカーに隠す必要があるので、たとえコーラでもなんでも、高志が空き缶をかならず洗うように強要する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空き缶の怨霊かなんかに崇られたらどうしよう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昼食もすでに終わりに近づき、令子はメロンに手をつけるまえに、鶏の骨だの、パンの食べのこしだの、空き缶だのといったゴミを片づけにかかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「憶えてるか、空き缶を山に埋めたのを」「うん。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだと思っただろうな、あんなもの」「腐った空き缶だと思ったんじゃないか」　一九七〇年にはじまったこの一帯の開発は、なにかの感慨を呼ぶような悠長なものではなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生きた心地もなく、石油の空き缶を頭の上から被ったまま身体を丸く縮めて、落ちてくる石塊の当るにまかせていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまドロップスの入っていた空き缶の蓋を払いのけて底に小さな孔をあけ、そこに糸をさし入れて缶を逆さに釣り、鉛筆の軸かなにかでコーンと一つ叩いてみるがいい。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、もう一つのドロップの空き缶をとりあげて、前と同じように、糸でとめて、ぶら下げて置く、その上で、最初の缶を思いきり強く叩くのである。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空き缶詰　亀之介を退室させた後、帆村は「どうでしたか」と感想を検事たちに需めた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――写真の中には、さっき彼女がいったとおり、一ポンド入りの空き缶が一つ残った。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたしか、中が洗ったように綺麗な空き缶だったね」「そうです」「君は、この缶詰の中から毒瓦斯がすうッと出て来たと考えているんじゃあるまいね」　と検事の言葉に、「ははは、まさかそんなことが……手品や奇術じゃあるまいし。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、手品や奇術や魔術でも、この缶にそれを仕込むことは不可能でしょう」「しかし、この空き缶が一体どうしたというだろう」　検事はふしぎでたまらないという風にひとり言をいって、首を振った。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、あの空き缶についている指紋がたいへん参考になるんですが聞いて頂けませんか。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、この缶詰が空き缶になっているときに見ましたか、それともまだ空いていないときに見ましたか」「見ません。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本庁から、例の空き缶がここへ届けられたのである。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重の白い布片にまかれてあった空き缶は大寺警部の手によって小卓子の上でしずかに布片を解いて、取出された。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は見たのだ、大寺警部が取出した問題の空き缶をお手伝いお末が一瞥した瞬間、彼女はそれまでの落着きを失って、はっとなって目を瞑じ、次に目を開いたときには明らかに愕きの色を示して、大きく目をみはり、息をすいこんだのである。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あの空き缶が犯行に一体どんな役目を持つと考えられますか。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、彼女の部屋から多数の缶詰や空き缶を発見したのであった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空き缶の方はどうだろうか。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中が洗ったように綺麗なのがあるかい」　こんどは空き缶探しにうつった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題の空き缶のように中の綺麗な缶は一つもなかった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこへ行けば、問題の空き缶についていた未詳の指紋の主が分るかもしれん。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず問題は、お末すなわち本郷末子の行状を調べることと、例の空き缶についていた未詳の指紋の主を探しあてることだ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなぜ彼女の指紋が、問題の空き缶についていたのであろうか。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ三郎」　木曾のさしだしたものを三郎が見ると、それは缶詰の空き缶のようなものであった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月の世界には、生物はすんでいないはずだろう」「そうさ」「ところが、この缶詰の空き缶のころがっているところをみると、何者かがこの月にすんでいると考えられるのだ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしているときも、いつどこから不意に、月にすんでいる先住生物におそわれるかもしれない」「はあ、いよいよ気もちがわるくなった」「早くひきかえして、みんなにこの空き缶をみせて知らせてやろうじゃないか」「そうだねえ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
