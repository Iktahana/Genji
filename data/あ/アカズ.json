    "definitions": [
      {
        "index": 1,
        "gloss": "without tiring (of something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だれでも海べに出ていちばん見飽かずおもしろいと思うのは、遠い沖の果てから寄せて来ては浜に砕ける、あの波でしょう。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いほうのは室のすみの洗面台の上にやってしまって、この新しいベコニアを枕もとに飽かずながめた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際多くの連作は一つの植え込みをいろいろな角度から飽かずいつまでもながめているような趣があって、この点ではどうしても静的であり絵画的である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店で新聞を読んで居た鶴吉は美しい心になつて、飽かずそれを眺めて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぎ立ての高い香りにむせび乍ら、唇を赤くして飽かず喰べた。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい体格だね、」と私は惚れ惚れしてそれを飽かず見入るのであつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひたいことがあるなら何事でも聞いてやらうと云つたやうな態度で、飽かず審問をつゞけた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りとは雖も、生前手をとりて親しかりし時だに、その容を見るに飽かず、その聲を聞くをたらずとせし、われら、君なき今を奈何せむ。",
              "citation": {
                "source": "芥川龍之介氏を弔ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は半死半生のお葉を抱え起して、霎時は飽かずに其顔を眺めていたが、やがて傍の谷間の清水を掏い取って、女の口に注ぎ入れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠一も霎時は飽かず眺めていたが、やがて手に取って打返して見ると、兜の吹返しの裏には、「飛騨判官藤原朝高」と彫ってあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、重太郎も笑ましげに答えて、猶も飽かずに其花を眺めていたが、「ねえ、此花を一つ呉れないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は飽かずに眺め入つた。",
              "citation": {
                "source": "小学生のとき与へられた教訓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御辞退申兼ねて帰りては来たれども、これを思うに、われも亦御心に飽かずとせらるる文字をつらぬるに過ぎざらんと、口惜しくもまた心苦しくおもうのである、と話した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎兵衞老人は華嚴の瀧が立派な瀧であるに拘らず適當な觀賞場所が無くて、たゞ瀧見臺から觀望するに過ぎぬ事を他國の人々が飽かず思ふのを道理と感じた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ感じつつ、私たちは飽かずに視めた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽かず、倦まず、撓まないで、客に接して、いずれもをして随喜渇仰せしむる妙を得ていて、加うるにその目がまた古今の能弁であることは、ここに一目見て主税も知った。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがい憂愁も、しばし忘れさせて呉れる、常緑樹の重厚な緑のバツクに対して鬱金色の粉を吹いたやうな灌木の新芽、あらゆる形の「点」と、あらゆる形の「塊」とで清新な希望の国を構成する若葉の茂り、見れど見飽かず、眺むれど眺め尽せぬ心持ちがする。",
              "citation": {
                "source": "初夏に座す",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）頭がち、ゆらぎ遊ぶと、まだ飽かず、虫よ花よと。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯すすき、土堤の枯草、凍りつき白くきびしく、両側の立枯並木いよいよに白くさびしく、雪空の薄墨色にこまごまと梢明り、下空の小枝のほそ枝立ちつづき見れども飽かず、入り交り網目して透く。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうがうしこのピアノ、立ち添ひて、蹲み見て、蓋をひらき、鍵たたき見て、見も飽かず終日ありける。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆゆしくもゆかしきかをり、内外にも満ち溢るれば、ここ過ぐと人は仰ぎ見、道行くと人はかへりみ、むらぎもの心もしぬに、踏む足のたどきも知らず、草まくら、旅のありきのたまたまや、我も見ほけて、見も飽かず眺め入りけり。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺むれど見れども飽かず、言にさへ筆にさへ出ね。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯すすき、土堤の枯草、凍りつき白くきびしく、両側の立枯並木、いよいよに白くさびしく、雪空の薄墨色にこまごまと梢明り、下空の小枝のほそ枝立ちつづき、見れども飽かず、入り交り網目して透く。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺むれば見れども飽かず、言にさへ筆にさへ出ね。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飽かず打戍る）僧　さればこそ云はぬことか。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高谷君は今更のように、その美しい空の色どりを飽かずにながめた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この跫音にも心着かず、余念もない二人の状を、飽かず視めてうっとりした。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て来ると、まるでからだじゅうが肺ででき上がった人形ででもあるように、幾度も幾度も飽かずに深呼吸をしているのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして毎日あかず眺めてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言いおおせて何かある」「五六分の句はいつまでも聞きあかず」「七八分ぐらいに言い詰めてはけやけし」「句にのこすがゆえに面影に立つ」等いずれも同様である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
