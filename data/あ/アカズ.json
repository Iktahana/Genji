    "definitions": [
      {
        "index": 1,
        "gloss": "red vinegar made from fermented sake lees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "１　最上の米（新潟・福島・秋田｜辺の小粒）　２　最上の酢（愛知｜赤酢・米酢）　３　最上の魚介類、だいたいにおいていちばん高価な相場のもの。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "用いるところの酢はというと、双方ともまず似たりよったりで大差はないが、酢加減となると、赤酢ばかり用いるみっちゃんに旗を挙げていい。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして毎日あかず眺めてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言いおおせて何かある」「五六分の句はいつまでも聞きあかず」「七八分ぐらいに言い詰めてはけやけし」「句にのこすがゆえに面影に立つ」等いずれも同様である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀書にあきると手鏡をとり出し、微笑んだり眉をひそめたり頬杖ついて思案にくれたりして、その表情をあかず眺めた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼で若者はさっきから一対のおしどりをあかずながめていた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに両人の文いずれも御心にあかずして、更に匡衡に篤く御頼みありたりとて、同題にして異色の文、既に二章まで成りたる上は、匡衡が作、いずれのところにか筆を立てむ。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことことと、ひそかなる母のおとなひ幾度となく戸を押せど、はては敲けど、色濁る扉はあかず。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで待てど暮せど埓あかず、あまりに齒痒う覺ゆるまゝ、この上は使など遣はすこと無用と、予が直々に催促にまゐつた。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもぎ苗あかずつますと。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眇目の異国人が都の中にさまよう由はかねて聞き及んで居りましたが、館の御門前に立ち迷うて先刻より内を窺うは重々の不審と存じて、ともかくも取り押さえて吟味いたせど、あらぬことのみ口走りてちっとも埓あかず。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほあかずして、海に盥舟までうけて遊ぶ。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "未練が出て今一度老婆に滯在のことを頼んでみたが生返事で一向｜埓があかず、幾らか包んでやれば必ず效能があつたのだと、あとで合點が行つたが最初氣がつかなかつた。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自分の買って出るような事件があるかないかを当たって見るので、ないとなるとフンといったような顔つきで同心控え室の片すみに陣取り、もう右門党のみなさまがたにはおなじみな、あのひげをぬく癖をあかずにくりかえしくりかえし、半日でも一日でも金看板のむっつり屋をきめ込むのがそのならわしでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の来る日来る日は少しも見あかず、私を無心の世界に誘い、そこから病躯も力づけられて行った。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが部屋に、わが部屋に奇異なる事ありき、かなしきはそれのみか、その日より戸はあかず、…………せんなしや、わが夢も、足音も、赤き版古も。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかずやありけむ、二十日の夜の月出づるまでぞありける。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶あかずやあらむ、またかくなむ、「見し人の松のちとせにみましかばとほくかなしきわかれせましや」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで待てど暮せど埒あかず、あまりに歯痒う覚ゆるまま、この上は使いなど遣わすこと無用と、予がじきじきに催促にまいった。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三色さへ香さへ妙なるひとをあかずもこよひみるが樂しさ、みるが、みるが樂しさ。",
              "citation": {
                "source": "さかほがひ",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚はなかば白く、髪にもチラチラ交っているが、気はどちらかといえば若いほうで、青年を相手に教育上の議論などをあかずにして聞かせることもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は高等師範のことやら、旧友のことやら、戦争のことやらをあかず語った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は私が見られた番であるから、今朝は私がよく見ようと、あかずジイドの後姿を眺めていた。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも蕪村は其角を推したらんと覚ゆ、「其角は俳中の李青蓮と呼ばれたるものなり」といい「読むたびにあかず覚ゆ、これ角がまされるところなり」ともいえり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかず眺め、眺め心は故郷に戻ったような安息を覚えるのだ。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満目の青山、汝の見るに任す、――といつた風景、いつまでもあかずに新緑郷を漫歩する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏有先生が理を談ずるは辯を好むに似たれども、その記實にあかず思へるは無理ならじ。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一二三四五六七、さあかずへてごらん」といふと「一二三五七」とやる。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうな消息をあかずに書いて持たせてあげた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガミガミと途方もなく苛立って続けざまに発砲するのだが、癇癪を起せば起すほど腕が震えて埒があかず、終いには人畜を害ねなければ溜飲が下らなくなってしまうという始末の悪い迷信的潔癖性に富んでいた。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
