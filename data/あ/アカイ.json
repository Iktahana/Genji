        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あかい花だけ見てすぐ出るつもりでいたら、人と人との間へはさまって、ちょっと出そこなって、やっと出て見ると妻はそこにはいぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすあかい河原なでしこの花があちこち咲いてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきの木菟は旬はずれで、この頃はその尖ったくちばしを見せなかったが、名物の風車は春風がそよそよと渡って、これも名物の巻藁にさしてある笹の枝に、麦藁の花魁があかい袂を軽くなびかせて、紙細工の蝶の翅がひらひらと白くもつれ合っているのも、のどかな春らしい影を作っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすあかい河原なでしこの花があちこち咲いていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかいめだまの　さそり　ひろげた鷲の　　つばさ　あおいめだまの　小いぬ、　ひかりのへびの　とぐろ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つによると旋風のようなものが襲来して、その際に「馬のたてがみが一筋一筋に立って、そのたてがみの中に細い糸のようなあかい光がさし込む」と馬はまもなく死ぬ、そのとき、もし「すぐと刀を抜いて馬の行く手を切り払う」と、その風がそれて行って馬を襲わないというのである。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈もアセチリンもない時代で、カンテラがせいぜいで石油ランプの照明しかなかったがガラスのナンキン玉をつらねた水色のすだれやあかい提燈などを掛けつらねた露店の店飾りはやはり涼しいものであった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかいカンナ」というのと、「矢車の花いとし」というのと、二つでありますが、前者は「あかいカンナの花でした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うこんしゃっぽのカンカラカンのカアン　あかいしゃっぽのカンカラカンのカアン。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうさうこのときは丁度秋に蒔いた蕎麦の花がいちめん白く咲き出したときであの眼の碧いすがるの群はその四っ角な畑いっぱいうすあかい幹の間をくぐったり花のついたちひさな枝をぶらんこのやうにゆすぶったりしながら今年の終りの蜜をせっせと集めて居りました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うこんしやつぽのカンカラカンのカアン　あかいしやつぽのカンカラカンのカアン。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目は、あかい手絡をかけた、若い女房に手を曳かれて来たが、敷居の外で、二人ならんで恭しく平伏した。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の低い肥った女で、蝦蟆のような顔に白粉をべたべたなすって、前髪にあかい布などをかけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのうすあかい霞の下に、黒い日本甍の屋根が見える。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木馬はまはる、光はまはる、兄の肉體は疾風のやうに旋囘する、兄の左に少女がじつと立つて居る、白い前かけをした娘だ、娘のくちびるが、あかいくちびるが、林檎が、しだいに、あざやかに、私のくちびるを追ひかける。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかい色の朝の陽光が、頬にこころよくふれる。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織も着物も同じ矢絣模様の銘仙で、うすあかい外国製の布切のショオルが、不似合いに大きくその上半身を覆っていた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、あかい血、これは、くろい血。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかい血、くろい血。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というユウモラスな意味をふくんだ、あかい血、くろい血。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年まえの師走、月のあかい一夜、女は死に、私は、この病院に収容された。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばばあ、ばばあ」　お秀の母親が、「また、ばばあかい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（人形芝居の硝子越しに、あかい柑子の実が秋の夕日にかがやき、黄色く霞んだ市街の底から河蒸気の笛がきこゆる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬうらりしやらりと日が暮れてまたも夜となる、道化もの、あかい三角帽をちよいと投げてひよいと受けたら禿頭。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三年十月　あかい夕日にあかい夕日につまされて、酔うて珈琲店を出は出たが、どうせわたしはなまけもの明日の墓場をなんで知ろ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
