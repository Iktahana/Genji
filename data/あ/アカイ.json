        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "牧野さんの作品には明るい風景が出て来るし、陽に透いた桜の葉のやうな色や又赤い色があるが、その赤はうでた小海老の赤である。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰かも青い色が青い色であり、赤い色が赤い色であるやうに、夢をみようともみまいともしないで私は夢みてゐるのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水寺のすぐちかくに赤い毛氈を敷いた縁台を二つならべて置いてある小さな甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首がふとく、襟脚はいやに鈍重な感じで、顎の下に赤い吹出物の跡を三つも僕は見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い攣れた髪毛が額に迫り、その下で紅と栗との軟い顔がほつとり上気してゐる。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんが台所に這入ると、小僧は天秤棒を担ぎあげて、「ありがと、存じました」といふや、赤い手を振りながら、さつき良子が隠れた、あの通路の方へ行つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長室で、彼は卓に頬肘を突いて、眠さうな、赤い顔をして先刻から考へてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恰度百姓娘の、赤いネルの腰巻を思はせるやうな夏の日の夕飯仕度の頃の中でされるには余りに相応しいそれらの話声や物音であつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲荷を祭つた小さい山の、赤い数々の鳥居が何がなし気になつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い火の燃える炉辺。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯然と二の腕を捲ると、生白い肌が現出れて酒氣を帶びた頬が薄赤い。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかるいランプの光は人々の赤い顔に映えて何となく陽気に見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の脊中へ赤い紙片を貼付け、尻尾に摺粉木を一本縛り付けて野良へ出しておく。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉が下りて来て牛の脊中の赤い紙を牛肉と思ってつつくと、牛は蠅でも追う気でぴしゃりと尻尾ではたく、すると摺粉木の一撃で鴉が脆くも撲殺されるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畔に刈穂を積み上げて扱いている女の赤い帯もあちらこちらに見える。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向いに坐った目の赤いじいさんと相撲の話をしている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関長室には顔の赤い人の好さそうなのが航海日誌と云いそうなものへ何か書いている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜に村の煮売屋などの二階から、大勢兵隊が赤い顔を出して、近辺の娘でも下を通りかかると、好的好的などと冷かしたり、グズグズに酔って二、三人も手を引き合うて狭い田舎道を傍若無人に歩いたりするのが、非常に不愉快な感じを起させた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の奧の、やや廣い草原に、異形の物が十數人、と言ふのか、十數匹と言ふのか、とにかく、まぎれもない虎の皮のふんどしをした、あの、赤い巨大の生き物が、圓陣を作つて坐り、月下の宴のさいちゆうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前の、その、人とも動物ともつかぬ赤い巨大の生き物が、鬼といふおそろしい種族のものであるといふ事は、直覺してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほその上、鬼どもに對し、親和の情を抱いてゐるのであるから、何の恐れるところもなく、圓陣のまんなかに飛び込んで、お爺さんご自慢の阿波踊りを踊つて、むすめ島田で年寄りやかつらぢや赤い襷に迷ふも無理やない嫁も笠きて行かぬか來い來い　とかいふ阿波の俗謠をいい聲で歌ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんの瘤は、どうしてそんなに赤いのかしら。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御想像は、まあドンヂヤンドンヂヤンの大騷ぎで、大きなお皿に鯛のさしみやら鮪のさしみ、赤い着物を着た娘つ子の手踊り、さうしてやたらに金銀珊瑚綾錦のたぐひが、――」「まさか、」と浦島もさすがに少し不愉快さうな顏になり、「私はそれほど卑俗な男ではありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐つた土から赤い毒きのこが生えて出るやうに、生命の不安が言葉を醗酵させてゐるのぢやないのですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして長い頭髮の一本一本がことごとく腹の赤い毒蛇である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照さんは小さい赤い絹蒲團を掛けて寢てゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかい花だけ見てすぐ出るつもりでいたら、人と人との間へはさまって、ちょっと出そこなって、やっと出て見ると妻はそこにはいぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
