          "standard": [
            {
              "text": "引っ越しの際、挨拶代わりに隣家へタオルを持っていった。",
              "source": "幻辞"
            },
            {
              "text": "彼は挨拶代わりに軽いジョークを飛ばし、場の緊張を和らげた。",
              "source": "幻辞"
            },
            {
              "text": "初対面の相手に、挨拶代わりとして自慢のコレクションを見せた。",
              "source": "幻辞"
            },
            {
              "text": "強烈な先制パンチは、王者から挑戦者への挨拶代わりだった。",
              "source": "幻辞"
            },
            {
              "text": "「まずは挨拶代わりに一杯」と、彼はビールを注文した。",
              "source": "幻辞"
            },
            {
              "text": "都会の洗礼として、挨拶代わりの土砂降りに見舞われた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いつかの話を思い出して……」　嘉三郎は坐りながら挨拶代わりにそう言った。",
