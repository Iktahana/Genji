    "definitions": [
      {
        "index": 1,
        "gloss": "oil peddler",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油売りについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油売りは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油売りの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油売りについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "油売りは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油売りの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油売りに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油売りが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油売りを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油売りの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油売りが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油売りが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油売りについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油売りは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油売りは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油売りは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油売りについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "油売りの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油売りの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油売りの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「私、生意気者で、油売り、横着者で、悪者で……これが見せしめ……これが見せしめ……。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野の町から車をひいて来る油売り、半田の町から大野の町へ通る飛脚屋、村から半田の町へでかけてゆく羅宇屋の富さん、そのほか沢山の荷馬車曳き、牛車曳き、人力曳き、遍路さん、乞食、学校生徒などをかぞえあげました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の家だって、先祖をただせば油売りだったんだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その油売りは大きい帽をかぶって、驢馬に油桶をのせていたが、官人のゆく先に立ったままで路を避けようともしないので、さき立ちの従者がその頭を一つ引っぱたくと、頭はたちまちころりと落ちた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで奇怪なる油売りの正体は判った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この油売りはひと月ほども前から城下の里へ売りに来ていたもので、それを買う人びとも品がよくて価の廉いのを内々不思議に思っていたのであるが、さてその正体があらわれると、その油を食用に供した者はみな煩い付いて、俄かに吐いたり瀉したりした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "油売りになれば、油売った心得がのうても、油売りになって見せるのは芸じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「油売り松並荘九郎がともかくも美濃を平定し斎藤道三と宣る浮世だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに後から寄り集まった大勢の野次馬が加わって、油売り半分の面白半分といった調子で、ワイワイ騒ぎ立てたので、狭い坑道の中が芋を洗うようにゴッタ返したが、その中に、浮上った炭車の車輪の下から、思いがけない安全燈の光りと一緒に、古靴を穿いた福太郎の片足が発見されたのでイヨイヨ大騒ぎになったものだという。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにても、この若い油売りの手にかゝるお吉のいとほしさ。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（社長さん、ちょっと思い出したから尋くが、君はもと浅草の何とかいう横町で油売りをしていたってね。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア、一文銭の油売り。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが評判となって、人々は一文銭の油売りを待ちかねるようになり、ために他の油屋は客が少くなってしまった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "元祖は一文銭の油売りだ。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦法は信長が完成したが、元祖は一文銭の油売りであった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　一文銭の油売りは多額の金ができたので、そろそろサムライになってもよいころだと考えた。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "油売りの庄五郎はこの長井長弘のスイセンで妙椿の用人となることになったが、そのとき長弘が庄五郎に語るには、「貴公は南陽房が兄とたのんだほどの学識ある器量人だから、事理に暗い筈はない。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大評判、油は一文銭の油売りの油にかぎるとなって、たちまちのうちに金持ちになった。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂口先生からきいた話だが、大島からのツバキ油売りと名のる行商人がきた時に、その真偽を見破るカンタンな方法があるそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかなんとく、その石油売りにいったのでした。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の男の子が、石油売りの後を追っていきました。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、石油売りは、圃の間を通って、あちらへいってしまった。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、箱根町の油屋が近在へ油売りに出かけ、日暮れて薄暗くなったときにその場所を通りかかり、己は油を持っているから狐が邪魔するかも知れぬと思い、四方を見回している間に、藪の中より数十頭の狐が飛び出しきたり、大道をふさぎて進むことができぬ。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでいささかの希望の曙光を認め得たので俥挽きを廃業して油売り専門となり、満一ヶ年目には三百戸となり、数年目の今日五百軒に達したので、今は小僧を雇いて共に得意廻わりをなし、妻は店を担当して、夫婦共稼ぎに精々働いた結果、資本裕かになり、生活も楽になったとのことである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ油売りから身を起して、空手で美濃一国をわが物とした男だけに、最初に仕えた主人｜土岐政頼を殺し、次の主人｜頼芸をまた、国外へ追って、その妾を奪ったりなど――残忍酷薄な数々の経歴は、挙げて語ったら限りもない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧になったり、油売りしたり、実世間の流浪をいろいろな職業にわたって通って来た道三秀龍だけに、後の斎藤家と蜂須賀氏との関係を考えても、そんなことも、或はあったろうかと思われるはなしである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
