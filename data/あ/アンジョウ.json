    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on top of a saddle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日鞍上について考えている。",
              "source": "幻辞"
            },
            {
              "text": "鞍上という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は鞍上の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には鞍上が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "鞍上を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは鞍上について学習した。",
              "source": "幻辞"
            },
            {
              "text": "鞍上の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は鞍上の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では鞍上が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "鞍上という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に鞍上という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では鞍上についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "鞍上を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると鞍上は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "鞍上について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では鞍上が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に鞍上は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により鞍上の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "鞍上は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に鞍上は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "枕上鞍上厠上合わせて三上の意だという。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残る一つの「鞍上」はちょっとわれわれに縁が遠い。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上と厠上の場合にはこれが明白であるが枕上ではこれが明白でないように見える。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はこう言うと、たくましい鹿毛の馬が検量所から堂々登場、普通駈歩で前を通ったが、鞍上にはロス大佐の馬主色として知られる黒と赤の勝負服を来た騎手が乗っていた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――四つの馬は、鞍上人なく、鞍下に馬なく、青葉ゆらぐ台町馬場の芝草燃ゆる大馬場を、投げ出された黒白取り取りの鞠のように駈け出しました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ロシナンテの蹄から、ワザと水に濡らしておいた草鞋を脱ぎ去つて、体をかはかして鞍上に飛び乗つた。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上にはロス大佐の色別として有名な黒と赤との騎手が乗っていた。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それっきり自分は口をつぐんでしまったが、たった一瞬間にして通り過ぎただけの白馬｜鞍上の紳士の姿は、一生涯忘れられないほど爽かに眼に残った。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして調度掛を呼寄せて、持たせて来た壺胡※を背に負ふと、やはり、その手から、黒漆の真弓をうけ取つて、それを鞍上に横へながら、先に立つて、馬を進めた。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して東軍の士卒遂に彼を鞍上に刺して其首級を奪ふ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "数騎銜ヲ駢ベ鞍上ニ相話シテ行ク者ハ洋客ナリ。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上人なく、鞍下馬なし矣。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "タオルもてヘルメツト帽の上より頬かむりし、旅袋より毛布取出して鞍上に敷きて、また行く。",
              "citation": {
                "source": "馬上三日の記",
                "author": "エルサレムよりナザレへ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンやショパンを感ずる前に、ピアニストの指を感じさせる場合の方が多いのに、バックハウスに至っては、鞍上人なく鞍下馬無しだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上の人も固より咽喉が渇いているであろうが、馬も烈日の威に堪えず、喘ぎ喘ぎ歩みつつある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍上の人もホッとして馬を急がせる、という風にも解することが出来る。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし再案するに、この馬は鞍上の人となった場合に限る必要はない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵は、敢て辞退せず、鞍上の人になって、「伊織、先に寝め、わしの戻りは、明日になるかも知れぬ」　伊織も、外まで出て、「行っていらっしゃいまし」　と、見送った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで読むと、ほっと安心して鞍上で安堵した。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざやかに鞍上にまたがり、すぐ馬首を立てて春風に道を求めている。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏兵「行って来るぞ」　将門は、馬寄せから、鞍上の人となって、館を出て行った。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、刎ね落されるような敵ではなく、かえって跳躍を迅めて、ふたたび頼朝のまっ向へ、鞍上からすさまじい力をこめた太刀が落ちかけた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん馬は勢いよく前へのめり込み、鞍上の武将は、石ころの上へもんどり打った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばと、源氏方からも、五、六騎河べりへ乗り出して、鞍上からキリキリと満を引きしぼって返し矢を送った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱はまだ、焦れ狂う生※の鞍上に、歯がみをしながら手綱をさまざまつかいわけていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木ッ葉武者どもは、拙者がたしかに引きうけもうしたぞ」　黒鹿毛の蹄をあげて、無二｜無三にかけちらしながら、はやくも鞍上の高きところより、右に左に、戒刀をふるって血煙をあげる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜色をこめた草原のはてを鞍上から見ると――はるかに白々とみえる都田川のほとり、そこに、なんであろうか、一｜脈の殺気、形なくうごく陣気が民部に感じられた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半弓、吹矢、笛太鼓、蹴※、酒瓢などを持ちかざし、おそろしく派手に飾った化粧馬の鞍上には、例の兼軍奉行の義弟、殷直閣がニタニタと乗っていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あんじょう思うておくんなはれや。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自由軒のラ、ラ、ライスカレーはご飯にあんじょうま、ま、ま、まむしてあるよって、うまい」とかつて柳吉が言った言葉を想い出しながら、カレーのあとのコーヒーを飲んでいると、いきなり甘い気持が胸に湧いた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
