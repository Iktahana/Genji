        "examples": {
          "standard": [
            {
              "text": "私は毎日歩み方について考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩み方という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩み方の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩み方が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩み方を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩み方について学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩み方の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩み方の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩み方が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み方という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩み方という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩み方についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩み方を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩み方は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み方について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩み方が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩み方は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩み方の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩み方は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩み方は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これと同じ白衣着けたる連れの男は顔長く頬髯見事なれど歩み方の変なるは義足なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の歩み方の誤を認め、結果の前に惨めに厳粛に叩頭せねばならぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「青と白」のヒーローの歩み方を祝し、その前途を期待し、そこに善良な、博大な、そして愛も、欲求も、知能も、音楽的に精化された諧和ある人間を待ち設ける心地がいたしました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり連作らしい歩み方を踏み出したのであるが、内容としては、少し無成算な即吟の嫌ひがあり過ぎる。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村さんは首垂れて、妙にしょんぼりとした姿で、力のない歩み方でした。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあなたの歩み方は本道をまともに進んでいらっしゃらないと思います。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらに人生の勝れた歩み方を示してくれる恩人はかような人々である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ては気まぐれな運命の僅かな歩み方に懸ってるような気がしてきた。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は最初将棋の歩み方を知りませんでした。",
              "citation": {
                "source": "野ばら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして神様はお父さんであってキリストは救主である、人生の歩み方においてはまず神の国と神の義を求むべきだということを知っている者は、この世のいかなる政治家よりもいかなる学者よりも偉いことを知っている。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがイエスの御生涯の歩み方でありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる歩み方をする者の人生が必然的に十字架を負わさせる道であるのは、世間の歩み方がちょうど反対に神のことを思わず、人のことを思うからです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶の絵附師と念仏の行者と、道は異っても同じ歩み方をしているのではないでしょうか。",
              "citation": {
                "source": "益子の絵土瓶",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は今、明治大帝や伊藤博文までさかのぼり、その時分からの国家の歩み方の検討をしなおさねば、生れ変るわけに行かない。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人が始めて、“Walk with me!”と云いつつ、私の背中へ腕を廻してワン・ステップの歩み方を教えたとき、私はどんなにこの真っ黒な私の顔が彼女の肌に触れないように、遠慮したことでしょう。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体は、程度の差こそあれ、一つの歩み方、一つのありようしか持たない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄徳は数万の窮民を連れているので、一日の行程わずか十里という歩み方です。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
