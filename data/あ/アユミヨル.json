    "definitions": [
      {
        "index": 1,
        "gloss": "to compromise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩み寄るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩み寄るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩み寄るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩み寄るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩み寄るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩み寄るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩み寄るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩み寄るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩み寄るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩み寄るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩み寄るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩み寄るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩み寄るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（立ち上り、歩み寄る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "親仁は、てくてくと歩み寄ると、閣翁父子の背後へ、就中、翁の尻へ、いきなり服の尻をおッつけるがごとくにして、背合せに立った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそるおそる縁先に歩み寄る私たち三人を見つけて、むっくり起き上り、「やあ、来たか。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩み寄る心一　しかし、姉も美沢も、そんなことは縁が遠いと云うように、笑いもしなければ、美和子を見ようともしなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が入室し、ファーガソンは一、二歩妻へと歩み寄る。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑屋の人たちも、その前の会社員の家族の人たちも、街路に立って、「山が歩み寄る」という事が、予想よりも大きな事実だったのに、今更驚いているのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして間の容体はどんなですね」「いや、仕合と想うたよりは軽くての、まあ、ま、あの分なら心配は無いて」　黒一楽の三紋付けたる綿入羽織の衣紋を直して、彼は機嫌好く火鉢の傍に歩み寄る時、直道は漸く面を抗げて礼を作せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ起きてその窓に歩み寄ると、室内たちまち真闇で咫尺を弁ぜず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、それなんだがね――』　喬介は振り返って、遠去けてあった矢島五郎の側まで歩み寄ると、傍の警官には眼も呉れず、こう声を掛けた。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "九段の方へグン／＼歩いて行くように見えた青年は、美奈子の家の前まで行くと、だん／＼その門に吸い付けられるように歩み寄るのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっそりと歩み寄ると、声からしてごく静かでした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さッとどよめきうろたえながら雪崩れ散るように波を打って道を開いたその中を、ずいずいと若者のところへ歩み寄ると、莞爾たり！",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東屋氏はひと亙り室内を見渡すと、机の上へマベ貝を置いて、椅子に腰掛け、暫くジッと考え込んでいたが、やがて書架の前へ歩み寄ると、鼻先を馬のように蠢かしながら、なにか盛んに書物を漁り始めた。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の側に居た影は立上つて、大急ぎで戸口のところの妻へ近寄り、両方が歩み寄ると見るより、忽ち一つの人物に溶け合つてしまつた。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "九段の方へグン／＼歩いて行くやうに見えた青年は、美奈子の家の前まで行くと、だん／＼その門に吸ひ付けられるやうに歩み寄るのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうである以上は、あとはただいかにして妥協點を見出すか、兩方がどう歩み寄るか、といふことだけではないか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川氏の意見も穏当な態度で表現されてあるけれども、文化の上で従来の作家と大衆とが歩み寄るということは、ブルジョア作家の理解の中で見られている大衆の性質が元のままである限り、作家性が元のまま自覚されている限り、作家の側からの困難が予想される。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　刑事は囚人のところに歩み寄ると、言った、「お前の名前は草部ではないな。",
              "citation": {
                "source": "停車場にて",
                "author": "AT A RAILWAY STATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、黒い垂れ布をかかげ、後房から姿を現わしたのは、一人の威厳のある老人であったが、しずかに戸口へ歩み寄ると、閂を取り扉をあけた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「竹河」を歌って階のもとへ歩み寄る時、少将の心にもまた去年の一月の夜の記憶がよみがえってきたために、粗相も起こしかねないほどの衝動を受けて涙ぐんでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして戸棚の出外れの窓際に歩み寄ると、そこいらに貼り並べて在る写真だの、一覧表みたようなものを見まわしながら、引続いて若林博士の説明を求めて行った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "素戔嗚は荒々しく若者の前へ歩み寄ると、じっと彼の顔を睨み据えて、「おい、貴様は確かにあの娘へ、おれの勾玉を渡したと云ったな。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず同心円をめぐるようにじりじり死の前へ歩み寄るのである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "永き別れ発車前三分……我は更に戦きて汽車の窓に歩み寄る。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、僕等の前へ歩み寄ると、怒鳴りつけるやうにマツグに話しかけました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやつと体を起し、部屋の隅へ歩み寄ると、天井からそこに下つてゐた一本の綱を引きました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、僕らの前へ歩み寄ると、怒鳴りつけるようにマッグに話しかけました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやっと体を起こし、部屋の隅へ歩み寄ると、天井からそこに下がっていた一本の綱を引きました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにごとだろうと富士男はそのほうにあゆみよると、ドノバンはまっかな顔をしてどなっていた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
