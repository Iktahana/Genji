        "examples": {
          "standard": [
            {
              "text": "私は毎日怪しげについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "怪しげという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は怪しげの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には怪しげが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "怪しげを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは怪しげについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "怪しげの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は怪しげの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では怪しげが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しげという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に怪しげという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では怪しげについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "怪しげを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると怪しげは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しげについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では怪しげが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に怪しげは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により怪しげの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "怪しげは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に怪しげは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "崖の上の彼女の上に精霊が怪しげなる条を描く。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も田端といふ所は、妙に空氣がしづんでゐて、禪寺の古沼みたいな感じがするので、僕としては甚だ趣味に合はなかつたが、それでも夕方から夜にかけては動坂の通りが賑やかで、怪しげなカフエなどへ行くのが樂しみだつた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから怪しげな足取をして、暗い隅の方へ歩いて行つて、例の小さい卓の側に、腕附きの椅子の二つある、その一つに、がつかりした様子で腰を卸した。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は再び丸善薬品本店まで引返して怪しげな英語の名前を云って買物をすると、本町のニューグランド・ホテルの方へあるいて行った。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にきくと初めは例の怪しげな笑い方をしていますが、後には泣きだしそうになるのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀に迷ふを笑ふ人は、怪しげな傳説、學説に迷はぬがよい。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある年は父子三人とも熱が出たり腸を害したりして、不安心な怪しげな医者の手にかからねばならなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには怪しげな美しささえ見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新古御時計」と書いた看板の蔭に、怪しげな色の金銀細工、マガイ金剛石、猫目石、ルビー、サファイヤの類が、塵に蔽われたまま並んで光っている。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日雲飛は待ちに待つた日が來たので夜の明方に海岱門に詣で見ると、果して一人の怪しげな男が名石を擔いで路傍に立て居るのを見た。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡のわくはわずかに焦げ、丸太の端よりは怪しげなる音して湯気を吹けり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら急に内に入りて二人を求めしに、二郎は元の席にあり、十蔵はそのそばの椅子に座し、二郎が眼は鋭く光りて顔色は死人かと思わるるばかり蒼白く、十蔵は怪しげなる微笑を口元に帯びてわれらを迎えぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "折り折り人の影がかなたの山の背こなたの山の尾に現われては隠れた、日は麗らかに輝き、風はそよそよと吹き、かしこここの小藪が怪しげにざわついた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚絆穿で、むかし傀儡師と云った、被蓋の箱を頸に掛けて、胸へ着けた、扮装は仔細らしいが、山の手の台所でも、よく見掛ける、所化か、勧行か、まやかしか、風体怪しげなる鉢坊主。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、居るに違いないが……ままよ念のためだと、急がわしく、馳せ行きて北の台と名づけたる高楼の、怪しげなる戸口に到り、合鍵にて戸を開けば、雷のごとき音ありて、鉄張の戸は左右に開きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その女の案内で、つい向う路地を入ると、どこも吹附けるから、戸を鎖したが、怪しげな行燈の煽って見える、ごたごたした両側の長屋の中に、溝板の広い、格子戸造りで、この一軒だけ二階屋。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その中から、怪しげな、不気味な、凄いような、恥かしいような、また謎のようなものを取出して見せられそうな気がしてならぬ。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しげな洋服に金紙を着けて金モールと見せ、附髭をして西郷の如く拵らえ、竹の皮で作った船のような形の鍋を売る、一個一銭。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「土地の繁昌は結構だが、銀山の鉱夫などが大勢｜入込んで来たので、怪しげな料理屋などが追々殖えて来るのは些と困る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田策さんて言えよ」　小田は髪の毛をクシャクシャとかきわけながら、怪しげな笑いを笑って、「――追い出されたよ」　ひとごとのように言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小沢は学生時代、LUMPEN（ルンペン）という題を出されて、「RUMPEN とは合金ペンなり」　という怪しげな答案を書いたことがあるが、ルンペンの本来の意味は、ボロとか屑とかいう意味である。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はビールを飲みながら、じっとその容子を見ていたが、やがて怪しげな手つきで、「――おれに――ついて来たら――もっと飯を――食わせてやる――ついて来るか……」　という意味の手真似を、やり出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――梅田の闇市場の食堂から、怪しげな刺青の男に連れ出された例の唖の娘だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンはシビル・ヴェンを忘れかねて、それから毎晩、その怪しげな芝居小屋へ通った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "善美を尽した宴と、香わしい夜の部屋と、変装の冒険と、波止場の怪しげな旅籠の一室とにドリアン・グレイの不思議な生活は続いた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村は、なじみの男刈りにした肥っちょの娘と、独逸麦酒をしこたま飲んだあとで、アルゼンチン・タンゴを怪しげな身振りで踊っていた。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにそのひとの心をながれるひとつの愛憐そのひとの瞳孔にうつる不死の幻想あかるくてらされまたさびしく消えさりゆく夢想の幸福と、その怪しげなるかげかたち。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしまひにたうとうあるひとつの怪しげな島を發見した。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の先生がボールドに向って一生懸命説明して居ると、後から白墨を以って其背中へ怪しげな字や絵を描いたり、又授業の始まる前に悉く教室の窓を閉めて真暗な処に静まり返って居て、入って来る先生を驚かしたり、そんなこと許り嬉しがって居た。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
