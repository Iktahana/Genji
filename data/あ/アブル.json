[
  {
    "uuid": "3e877421-7e52-5fd7-a05b-74ddde1aa7b4",
    "entry": "炙る",
    "reading": {
      "primary": "あぶる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to warm (e.g. one's hands over a fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日炙るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "炙るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は炙るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には炙るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "炙るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは炙るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "炙るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は炙るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では炙るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "炙るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に炙るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では炙るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "炙るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると炙るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "炙るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では炙るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に炙るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により炙るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "炙るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に炙るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "肉を炙る香ばしい匂いが夕凍みの匂いに混じって来た。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは毎夜の事でその日漁した松魚を割いて炙るのであるが、浜の闇を破って舞上がる焔の色は美しく、そのまわりに動く赤裸の人影を鮮やかに浮上がらせている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立處其の手足を炙るべく、炎々たる炭火を熾して、やがて、猛獸を拒ぐ用意の、山刀と斧を揮つて、あはや、其胸を開かむとなしたる處へ、神の御手の翼を擴げて、其膝、其手、其肩、其脛、狂ひまつはり、搦まつて、民子の膚を蔽うたのは、鳥ながらも心ありけむ、民子の雪車のあとを慕うて、大空を渡つて來た雁であつた。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の意地と、張とのために、勉めて忍びし鬱憤の、幾十倍の勢をもって今満身の血を炙るにぞ、面は蒼ざめ紅の唇｜白歯にくいしばりて、ほとんどその身を忘るる折から、見遣る彼方の薄原より丈高き人物｜顕れたり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧人これを試みた者いわく、腥くてならぬ故臭い消しに炙る前、その肉をやや久しく酢に漬け置くべし味は鰻に優るとも劣りはせんと（ピエロチの『パレスチン風俗口碑記』四六頁）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって十七世紀に仏人バーボーが西アフリカのシエラ・レオナで目撃した大猴バリの幼児を土人が捕え、まず直立して歩むよう教え、追い追い穀を舂く事と、瓢に水を汲んで頭に載せ運び、また串を廻して肉を炙る事を教えたというも事実であろう（一七四五年板、アストレイの『新編航記紀行全集』二巻三一四頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それを炙ると、新鮮な肉からは、香ばしい匂いが立ち、俊寛の健啖な食欲をいやが上にも刺激する。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かみさん、酒を一杯おくれや」　鹿の湯というのは海の口村の出はずれにある一軒家、樵夫の為に村醪も暖めれば、百姓の為に干魚も炙るという、山間の温泉宿です。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎々たる青雲の念と、勃々たる覇気とは常に火の如く胸腔を炙る。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "串差しにして炙る小鳥のにおいは広い囲炉裏ばたにみちあふれたが、その中には半蔵が土産の一つの加子母峠の鶫もまじっていると知られた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来英国の貴族及び旅人は埃及に於て猟の組合を組織してを嗜み、英人の背肉を食ふに反して、の脚を炙るを見て、英人は冷笑すと。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮いつも露路へ滲んでくる、人脂を炙るやうな重いものは、その人の生が乾いてゆく匂ひであつた。",
              "citation": {
                "source": "女中",
                "author": "石川善助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおせんを搾木にかけ、火にのせて炙るのに似ていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "(Ice.)steik は steka と親類で英語の stick すなわちステッキと関係があり、串に刺して火にあぶる「串焼き」であったらしい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、香しいやうな、遠くで……海藻をあぶるやうな香が傳はる。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどちかき庖厨のほてり、絵草子の匂にまじり物あぶる騒ぎこもごも、焼酎のするどき吐息針のごと肌刺す夕。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤火たき榾たきあぶる。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾小路は背をあぶるように、煖炉に太った体を近づけて、両手を腰のうしろに廻して、少し前屈みになって立ち、秀麿はその二三歩前に、痩せた、しなやかな体を、まだこれから延びようとする今年竹のように、真っ直にして立ち、二人は目と目を見合わせて、良久しく黙っている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿司を握っている手付きや、海苔をあぶるにおい、七厘の炭のよしあし、火加減、又はまぐろの切り加減なぞをよっく見た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しい衣の色や、袖の香や、楽の音や、それもこれも一つになって、あぶるように暖かい春のひかりの下に溶けて流れて、花も蝶も鶯も色をうしない声をひそめるばかりであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその次には肛門をあぶる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを二三枚｜宛、耽念に塩煎餠をあぶるやうに遠火で乾した。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの私もこの非合法な案には賛成しかねたので行動隊には加わらなかつたが、いよいよ鹿の肉をあぶる香が聞えてくるという段取りになれば、それから先の行動はどうなつたか、いま考えてもあまり責任は持てない気がする。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷滑りや竹馬で凍へた手をお家の爐邊の火にあぶるのも樂みでした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "高尾山上に多摩川の香魚をあぶるも亦一興と慾張り、眠れる蕭何を起すも氣の毒と、裸男自腹を切り、そつと財布の底をはたいて、五六尾を連ねたる串三つばかり買ひたりけり。",
              "citation": {
                "source": "夜の高尾山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋を洗い、火鉢にかざしてあぶる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の炎天はもうとくに過ぎ去っているし、まさか火にあぶるわけにもゆかず……蛭は捨てられることになってしまった。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの仕事は着物をぬいでしぼって、それを卒塔婆の火であぶることです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年自分は九州の鐘ヶ崎［牧野いう、筑前宗像郡、海辺の地にダルマギクを産する］で、特に望んで喰わせてもらったが、海から取って来たのをよく洗って、鉄鍋を火にかけて、その上でなまのミルをあぶると、茹菜のようになるのを、酢味噌などで喰べる工合は、全く茹菜と同じである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず針のようなもので――と云うよりも、原稿などをとじる時に使用する千枚とじと称するものがあるが、あれに似たようなもの（煙千子と称するものだそうだが）その先へ小壺に這入っている阿片をつけて煙灯の火であぶり、又、小壺の中の阿片をつけて煙灯の火であぶる。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
