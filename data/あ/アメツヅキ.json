        "examples": {
          "standard": [
            {
              "text": "私は毎日雨続きについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨続きという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨続きの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨続きが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨続きを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨続きについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨続きの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨続きの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨続きが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨続きという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨続きという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨続きについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨続きを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨続きは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨続きについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨続きが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨続きは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨続きの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨続きは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨続きは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雨続きだし、石段が辷るだの、お前さんたち、蛇が可恐いのといって、失礼した。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるだけ水の上の高い処を、と拾って畦を伝えば、雨続きで、がばがば崩れる、路を踏めば泥濘で辷る、乾いた処ちっともなし。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの部屋もひっそりと寝静まった夜更に、お増の耳は時々雨続きで水嵩の増した川の瀬音に駭かされた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "とう／＼去年は五月から雨続きで、冬のやうに寒く、秋は大風大水があり、東北を始として全国の不作になつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず降り立ったロサンゼルスで四日間を過ごしたが、新聞が大きく報じるほどのめずらしい連日の雨続きで、「カリフォルニアの青い空」がさっぱり拝めないのには肩透かしを食った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか雨続きの頃、主人は会があつて不在の晩、静かに本を読んでゐる内に夜が更けました。",
              "citation": {
                "source": "兄の帰朝",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか雨続きの頃、主人は会があって不在の晩、静かに本を読んでいる内に夜が更けました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の推定では、死後十日以上というのだから、恐らく、彼が東京へ行くといって宿を出たその日に、身投げをしたのが、滝壺に沈んでいて、雨続きの増水の為に、やっとその日、宿の裏まで流れついたものであろう。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
