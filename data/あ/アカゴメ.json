    "definitions": [
      {
        "index": 1,
        "gloss": "rice that has browned (due to age)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山での食物なら、先づ赤米、白塩、緑葵、紫蓼――といつたやうなところで……」　隠遁者が色づくしの美い名前を数へ立てると、それを傍で聞いてゐたある人が、横から口を出し、「山では蔬菜ばかしをめしあがつてゐるらしいが、そのなかで何が一番お口に合ひましたな。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後、安藤さんは日本やシナの古典をしらべて、延喜式の献物品の種目をたんねんにしらべた結果、赤米というものは、近年南京米などといっしょに入って来たようなものでなく、古くからあったという点を指摘されたのである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤米のこと　穀物を作る時に、非常にきびしい物忌みをする習慣は、アフリカの野蕃人の中にもある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと昔には赤米だったのが、改良されてだんだん白くなったために、後になるとかえって赤米に重要度がおかれるようになり、何か大事な時だけ赤米をたべようということになったのではないか。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆御飯のお米の色と、赤米だけで炊いたのと、色が大変よく似ているのである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物忌みの忌日の特徴をつけ、食べる人に今日から常の日とは違うということを意識させるため、もとは赤米を炊いたのが、在来の赤米がだんだん少なくなって来たので、それによく似た小豆御飯を炊くことになったのではないかと私は考えている。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして小豆を盛んに栽培する区域と米作地帯が同じであり、小豆御飯の米の色と赤米を炊いた御飯の色とが大変近いということが、問題に対する一つの暗示ではないかと思っている。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大唐米はトウボシ又赤米とも稱し多産劣質の新種である。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大唐米はトウボシまた赤米とも称し多産劣質の新種である。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『沖縄語典』によれば、沖縄では赤米をアカグミーまたはテァウブシャという。",
              "citation": {
                "source": "大唐田または唐干田という地名",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ある赤米の起源と展開とが、将来なお少しく研究せられて行くならば、この二種の穀物の相関と聯絡とが、次第に明らかになることと私は信ずる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
