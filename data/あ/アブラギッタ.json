        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脂ぎったについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この脂ぎったは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が脂ぎったについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は脂ぎったの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では脂ぎったが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から脂ぎったを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも脂ぎったが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では脂ぎったが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも脂ぎったは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも脂ぎったは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で脂ぎったは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に脂ぎったについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎったの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する脂ぎったの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では脂ぎったの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "支那人はボール箱の荷物をおろすと、脂ぎった手で無神経にその毛布をめくり上げた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眦が下って、脂ぎった頬へ、こう……いつでもばらばらとおくれ毛を下げていた。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅僧は小児小児した柔和な眼で、脂ぎった長者の顔を一眼じっと見た後に、黙って戸外へ出て往った。",
              "citation": {
                "source": "長者",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉一枚をとって見ても、サモアの脂ぎった盛上るような強い緑色と違って、此処のは、まるで生気のない・薄れかかったような色に見える。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方藁莚の端の方には赤い編上げ靴をはいた双足が出ており、反対の方になった左横には黒っぽい洋服を着た手さきが一つあらわれて、ふとった脂ぎった掌を見せていた。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町会議員は皆非常に小柄な、肥えた、脂ぎった、利口な人たちで、眼は大きな皿のようで、顎は肥えて二重になっていて、ヴァンダーヴォットタイムイティスの普通の住民よりもよほど長い上着を着、よほど大きい靴の締め金をつけている。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の事でね……五十｜面をてらてら磨いて、薄い毛を白髪染さ、油と香水で真中からきちんと分けて、――汗ばむから帽子を被りません――化粧でもしたらしい、白赤く脂ぎった大面の頤を突出して、仰向けに薄目を開けた、広い額がてらてらして、べっとりと、眉毛に墨を入れたのが、よく見える。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の前に座を取っていた四十三四の脂ぎった商人｜体の男は、あたふたと立ち上がって自分の後ろのシェードをおろして、おりふし横ざしに葉子に照りつける朝の光線をさえぎった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何杯も何杯も、頭から水をかぶって、遠慮なく飛沫を周囲へ飛ばせ、謡曲らしきものをうなりながら自由体操を行うところの脂ぎった男などは、朝風呂に多いのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂ぎった赭ら顔は勿論、大島の羽織、認めになる指環、――ことごとく型を出でなかった。",
              "citation": {
                "source": "魚河岸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげのない下膨れの顔はてらてら脂ぎった感じで、どちらかと云えば気味の悪いような印象であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お蓮に駄目を押された道人は、金襴の袋の口をしめると、脂ぎった頬のあたりに、ちらりと皮肉らしい表情が浮んだ。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂ぎった白い顔に、ほほひげがもじゃもじゃだ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかこう、脂ぎったもの、不潔なもの、どぎついもの、むかむかするもの、そういうもの全体のようです。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのりと桃色をした柔らかな指先で脂ぎった茶碗や皿を洗った。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族はと見れば、三坪程の木小屋に古畳を敷いて、眼の少し下って肥え脂ぎったおかみは、例の如くだらしなく胸を開けはだけ、おはぐろの剥げた歯を桃色の齦まで見せて、買主に出すとてせっせと茶を沸かして居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛豚肉は滅多に食わず、川魚は少し、稀に鼬に吸われた鶏でも食えば骨までたゝいて食い、土の物の外は大抵｜塩鮭、めざし、棒鱈にのみ海の恩恵を知る農家も、斯様な時には炙れば青い焔立つ脂ぎった生魚を買って舌鼓うつのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は脂ぎった太くまん丸い顔をニタニタと笑わせる、そしてグイと一杯呑みほすと、いやに取り澄まして、やおら得意なる背亀坐を組み、おもむろに調息するのだ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給え――彼は分身の術を用いて、さむざむと武蔵野に展かれた俺の窓から、脂ぎった顔のニタニタをぬっと現す。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日の光を受けてる、その脂ぎった体力のよさを、彼は皮肉な眼で眺めていたが、何故だか、自分自身も一寸気持が納まりかねた。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "松木の脂ぎった汗が、楓の木影や新らしい井戸端を汚すもののように思えたばかりでなく、考えたくないいろんなことが、一時に頭へ上ってきた。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひんまがった口許や、脂ぎった肩や脊や、道づれの大きな瞳の学生や、自分の知っておらない顔までが、そのイリュージョンの中にあった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの幻影というのは、そこへ、赤髯の大きな脂ぎったでぶでぶの洋服男が一つ現われて、いきなり、裸体婦人の後ろから羽掻じめにして、その髯だらけの面を美人の頬へ押しつけて、あろうことか、その口を吸いにかかったのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も執拗にやって来ては僅かの彼の俸給をさえ押えると云って脅かすそのでぶでぶと脂ぎった顔が。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真っ先に立ったのは、年も恥じず赤黄青のさも華美の色模様ある式服を纏った鬼王丸で、その脂ぎった赧ら顔には得意の微笑が漂っている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼の硬張らせた脂ぎった顔と暗い眼に突然、その昔鳴らせたあの一種特別の表情が閃いた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "調理に使うほとんどすべての酸性の野菜および脂肪質すなわち脂ぎった食品は銅に作用してその一部分を溶かす。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "円い脂ぎった額をし、胸を露わしながら、いつか暮しむきを立て直そうとかんがえているのだ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思わんかね、君は」　といってハンカチを取出すと、脂ぎった猪首を赤くなるほどこすり廻し、「そればかりならいいが、弱ったことには溜池署の巡査部長が皇帝をふン縛って署へ持って行ってしまったのだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても金持ちらしい五十格好のあぶらぎった顔をした一人の顧客が、若い店員を相手にして何か話している。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
