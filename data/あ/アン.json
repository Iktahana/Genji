    "definitions": [
      {
        "index": 1,
        "gloss": "red bean paste",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日餡について考えている。",
              "source": "幻辞"
            },
            {
              "text": "餡という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は餡の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には餡が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "餡を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは餡について学習した。",
              "source": "幻辞"
            },
            {
              "text": "餡の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は餡の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では餡が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "餡という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に餡という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では餡についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "餡を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると餡は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "餡について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では餡が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に餡は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により餡の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "餡は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に餡は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "六　松木は、酒保から、餡パン、砂糖、パインアップル、煙草などを買って来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道明寺の餡入り餅であったがその外側に糯米のふかした粒がぽつぽつと並べて植え付けてあった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭には餡が這入っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ理学士｜藤野米吉君が、液の代わりに製菓用のさらし餡を水で練ったものの層に熱対流を起こさせる実験を進めた結果、よほどまで、上記自然現象の機巧の説明に関する具体的な資料を得たようである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡入りの餅のほかにいろいろの形をした素焼きの型に詰め込んだ米の粉のペーストをやはり槲の葉にのせて、それをふかしたのの上にくちなしを溶かした黄絵の具で染めたものである。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹川さんのお家は、私の家の、すぐ向いで、ご存じでしょうかしら、華月堂というお菓子屋がございましたでしょう、ええ、いまでも昔のまま繁昌して居ります、いざよい最中といって、栗のはいった餡の最中を、昔から自慢にいたして売って居ります。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶めし餡掛、一品料理、一番高い中空の赤行燈は、牛鍋の看板で、一山三銭二銭に鬻ぐ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れよりも、徹夜の温習に、何よりか書入れな夜半の茶漬で忘れられぬ、大福めいた餡餅を※つたなごりの、餅網が、侘しく破蓮の形で疊に飛んだ。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな水ッぽいもんじゃあねえや、べらぼうめ、そこいらに在る、有平だの、餡麺麭だの、駄菓子で結構だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵粮だって餡麺麭を捻込んで、石滝の奥へ、今の前橋を渡ったんだ、ちょうど一足違い位なもんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥代を差引くと其いづれかを選ばねばならない懷だから、其處で餡氣で。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いささか気障ですが、うれしい悲しいを通り越した、辛い涙、渋い涙、鉛の涙、男女の思迫った、そんな味は覚えがない、ひもじい時の、芋の涙、豆の涙、餡ぱんの涙、金鍔の涙。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは貴方、田舎出来で、沢山甘くはござりませぬが、そのかわり、皮も餡子も、小米と小豆の生一本でござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんは白餡入りの饅頭六つ賭けるさかい、豹ぼんは」何も賭けるものがなく、蓮池から亀の子一匹掴えて、負けると和尚に呉れてやることになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口が力なくダラリと開くとまだモナカの潰し餡のくっ付いている荒れた舌がダラリと見えた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力曳きたちは、お客を待っているあいだ、することがないので、つい、駄菓子箱のふたをあけて、油菓子や、げんこつや、ぺこしゃんという飴や、やきするめや餡つぼなどをつまむのが癖になっていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお客よりさきに、茶店のおかみさんが、焼きたてのほかほかの大餡巻をつくってあらわれました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も得意なのは、も一つ茸で、名も知らぬ、可恐しい、故郷の峰谷の、蓬々しい名の無い菌も、皮づつみの餡ころ餅ぼたぼたと覆すがごとく、袂に襟に溢れさして、山野の珍味に厭かせたまえる殿様が、これにばかりは、露のようなよだれを垂し、「牛肉のひれや、人間の娘より、柔々として膏が滴る……甘味ぞのッ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡子ではあんまりだ、黄色い白粉でもつけましょう、牡丹亭きな子です。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――鴾の細君京千代のお京さんの茶の間話に聞いたのだが――）　つぶし餡の牡丹餅さ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここに、信也氏のために、きつけの水を汲むべく、屋根の雪の天水桶を志して、環海ビルジングを上りつつある、つぶし餡のお妻が、さてもその後、黄粉か、胡麻か、いろが出来て、日光へ駆落ちした。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、私は、塩餡。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（忰、まあ、）と父親が寄ろうとしますと、変な声を出して、　寄らっしゃるな、しばらく人間とは交らぬ、と払い退けるようにしてそれから一式の恩返しだといって、その時、饅頭の餡の製し方を教えて、屋根からまた行方が解らなくなったと申しますが、それからはその島屋の饅頭といって街道名代の名物でございます。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十一「在り来りの皮は、麁末な麦の香のする田舎饅頭なんですが、その餡の工合がまた格別、何とも申されません旨さ加減、それに幾日置きましても干からびず、味は変りませんのが評判で、売れますこと売れますこと。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戦争の祈祷の評判、ひとしきりは女房一件で、饅頭の餡でさえ胸を悪くしたものも、そのお国のために断食をした、お籠をした、千里のさき三年のあとのあとまで見通しだと、人気といっちゃあおかしく聞えますが、また隠居殿の曲った鼻が素直になりまして、新聞にまで出まする騒ぎ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保山の大阪商船待合所で別府までの切符を買うと、八十銭残ったので、二十銭で餡パンを買って船に乗った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡パンで別府まで腹をもたす積りだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送の巡査が駅で餡パンを買ってくれた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ヵ月振りの餡気のものかとちぎる手が震えた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
