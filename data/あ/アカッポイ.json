        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その中で、赤っぽいインクで刷ってある大判のが、枠の形も周囲の余白もたっぷりしていて、柔らかみもあり、気に入った。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩私たちは、レクトル・エケクランツの店の赤っぽい電灯の灯かげで一冊の書物を買った。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風変った古風な箪笥で、よく定斎屋がカッタ・カッタ環を鳴らして町を担いで歩いた、ああいう箪笥で、田舎くさく赤っぽい電燈の光に照らされ、引手のところの大きい円い金具が目立っている。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛や肩の上へ、箪笥を照していると同じ赤っぽい電燈の光を受けながら、和服で胡坐をかいた宮本が、そこにあった紙型をとりあげて私にその拵えかたを説明した。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステッセル将軍は、ただ碧い眼に赤い髭で、赤っぽい小菊の服を着せられていた。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤っぽい小砂利が綺麗にしきつめられ、遠くの木立まですきとおる静寂が占めている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤っぽい、そう新しくない絨毯が敷いてある。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、赤っぽい上着に、ワイシャツ、長ズボンといういでたちのサーシャは勿体ぶって眉根をよせ、「この児が僕の云うことを聞かないと困るがね」　祖父はゴーリキイの頭へ手をかけて、首を下げさせた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の頁を繰るたびに、弱い赤っぽい焔は揺れ、顫える。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○やせた、鼻と顎がコーモリのように見える婦人、　○赤っぽい、波のない毛をかまわない結びようにして居る。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで塵ぼっけだった職人の腹掛も雨に打たれて香おやかな紺の色になって赤っぽい紅葉や山茶花の間を通る時に腹掛ばかりが美くしい。",
              "citation": {
                "source": "通り雨",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日ゆくと、善兵衛おじいさんが股の間へ摺鉢を入れて、赤っぽい大きなお団子をゴロゴロやっているので、摺鉢をおさえてやりながら、なににするのだときくと、ただニヤニヤ笑っていたが、やがて、古新聞がお団子色にぬりたてられた。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこないだ、あの赤っぽい紫のベルトのついた帽子をかぶって居たのにと思う。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "庶子何処　玉蜀黍の毛みたいな赤っぽい派手な背広に大きな躰を包んだ旗田亀之介だった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "手袋を受け取った男を見ると、いつはいって来たのか、黒のダブルの上衣に、赤っぽいネクタイをしめ、色眼鏡をかけた、長髪の若者なのだ。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の色の反映か、全身が赤っぽい靄に包まれてるようで、そして薄らいで見えました。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の中に、この春京都に行ったとき、電車の中で会ったモーニングに、日本の布のウェイストをつけた男、赤っぽい色や緑の形つなぎの着物をきた女とのって居るのに会った。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の水も減って、赤っぽい粘土のごみだらけのきたない処が見え出し、こちこちになってひびが入って居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母と私は紋の附いた羽織を着、女中も、仕立下しの立ったり居たりするたんびにカサコソと音をたてる様な着物を着て、赤っぽいメリンスの帯を、柔くたきすぎたお萩の様にまとまりの悪いデロリとした形恰に結んで居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、お前の顔容から、不断よく着ていたあの赤っぽい銘仙の格子縞の羽織を着た姿がちらりと眼に浮んだ。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色の勝った大きな布団と赤っぽい小さな布団と、二つ床を並べて寝ている母と子を、順造は何とも云えない心地で眺めた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、木目の飛出した天井板や、ごてごて飾り立てられた真赤に見える神棚や、お師匠さんの手に渡ってる照代の長い髪や、どこからかの電話や、美代子の痙攣や、赤っぽい電燈の光や、そんなものを断片的に意識しながら、出来るだけ縮こまってると、いつのまにかうとうとと眠ったのだった。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まだどこか昼の光の残ってる中につけられた、赤っぽい電燈の光で見る父の顔に、私はなお一層びっくりした。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤っぽい髪のながい捲毛がしろい肩にかかって、眼はつややかに、鹿の眼の和らかい優しい光を持っていた。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、意外にもうつむいていた赤っぽい頭髪が、すッとあおのいた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくてに赤っぽい提灯の光が見え出すが早いか、ばたばたと大勢の足音がとんで来て、突如、霧の中から躍り出た二十人余の人数が、橋上に平馬を取り囲んだ。",
              "citation": {
                "source": "平馬と鶯",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤っぽい光を乱して、四人の影が入りまじる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "油っ気のない、赤っぽい大たぶさが、死人のような蒼い額部へ、バラリたれさがって、枯れ木のような痩せさらばえた長身だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路に一すじ赤っぽい光を投げて、まだ一軒の煮売り屋が起きている。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れのなかをいくらかめだつたかい背の白｜浴衣地がまむかいにきて、視線があったとたん、ややあかっぽい頭髪がうつむいた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
