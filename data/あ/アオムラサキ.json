        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それで塵の層を通過して来た白光には、青紫色が欠乏して赤味を帯び、その代りに投射光の進む方向と直角に近い方向には、青味がかった色の光が勝つ道理である。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお熊さんの屍骸の口の中に在った黒い血の塊の中に、青紫色のお粥の粒が混じっておりましたのが何よりの証拠……」　半三郎は腹の底から長い長いため息を吐いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにちりばめた宝石のように白熱燈や紅青紫のネオン燈がともり始める。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定りの魚軒と言ふと、だいぶ水氣立つたとよりは、汗を掻いて、角を落して、くた／＼と成つて、つまの新蓼、青紫蘇ばかり、濃い緑、紫に、凛然と立つた處は、何うやら晝間御神輿をかついだ時の、君たちの肉の形に似て居る。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗を煮る、いい香気だ、青紫蘇のにほひもいい。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふも漬茄子、やつぱりうまい、青紫蘇の香は何ともいへない。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからの、青紫蘇を粉にしたのじゃがの、毒にはならぬで、まいれ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何しに来たこの女、何を泣いたこの女、なぜ泣かせたこの女、椎と青紫蘇の葉に懲りて、破毛布に辟易したろう。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "政枝の唇が青紫に色あせつつぴたぴた唾の玉を挟んで開け閉している。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその遥か上の空には、何時も見慣れた北漢山のゴツゴツした山骨が青紫色に空を劃っていたりする。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹の大漁と見え、到るところ眼の活きた青紫の鮮かなのが轉がしてある。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうがらし　青紫蘇、ねぎ、春菊、茗荷、菜っ葉――そういったもののみが取り残されて、申し合せたように青い葉の色で畑の健康を維持しているなかに、一株の唐辛が交って、火のしずくのような赤い実を点在させているのが眼についた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に一種の薬味として青紫蘇か茗荷の子を細かに刻んだのを用意して置いて、鰹節をたくさんにかき込んで生醤油にそれを混ぜて、冷え切った豆腐に付けて食う。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の心を尽した晩餐の膳には、鮪の新鮮な刺身に、青紫蘇の薬味を添えた冷豆腐、それを味う余裕もないが、一盃は一盃と盞を重ねた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青紫蘇の香のよろしいこと。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "草刈爺さんがけさもまた来てくれた、憾むらくは彼にはデリカシーがない、青紫蘇も蓮芋も何もかも刈つてしまつた、いつぞや萩の早咲を刈つてしまつたやうに。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――或る日、子供は畑から青紫蘇の芽生えに違いないと鑑定をつけた草を十二本抜いて来た。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "根が入る位の大きさに穴が出来ると、一本ずつ青紫蘇に違いない木を植え込んだ。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつい雨で、見ていると大事な空地の花壇の青紫蘇がぴしぴし雨脚に打たれて撓う。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもり高くして置いた青紫蘇の根元の土でさえ次第に流され、これは今にも倒れそうに傾きかけるものさえ出て来た。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の子が青紫蘇や茗荷の子を摘んでくれた、おいしかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、国森令弟わざ／＼海の幸――小鯛一籠――を持つてきて下さつた、魚に添へてある青紫蘇の香が何ともいへないフレツシユだつた、早速焼いて酢に漬けた、あゝ、この好下物あつて酒なしとは……、うらめしや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬村居から青紫蘇の苗を貰うて来て植ゑる。",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋のほうでもまた旧約書にアーロンの帯が紅青紫の刺繍された美しい麻布であったとみえているから、ずいぶんと早くからその技に熟していたようである。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く不思議な話ではあるが、この混み合った電車の皿数は、青紫蘇は眼にしみるようで、小鱸は蓋を取るとサラリと白い湯気が立つという風で、生きのままあとあとと並べられるのである。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸太がまるでピアノの鍵盤のように上ったり下ったりするため、ぼんやりしている乗客は、後頭部に瘤をつくったり、額に青紫斑をこしらえたり、またどうかすると自分で自分の舌の先きを、いやというほど噛んだりもする。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後――雨に濡れた青紫蘇をいっぱいに積み上げた中で、清江はその葉を一枚ずつむしりとる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "集り散っていった食卓の菜類の中でまだ青紫蘇だけが変らず出てくる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの窓一パイに乱れかかっているエニシダの枝｜越に、白いドローンウォークの花模様が、青紫色の光明を反射さしているのがトテモ眩しくて美しかった。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時流行の尖たん花ガスは、花の形ちをした鉄の輪の器具の上で、丁度｜現今、台所用のガス焜炉のような具合に、青紫の火を吐いて、美観を添え、見物をおったまげさせていたのだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
