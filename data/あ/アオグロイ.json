[
  {
    "uuid": "953ccfb7-c209-550b-886b-a7cad9a69570",
    "entry": "青黒い",
    "reading": {
      "primary": "あおぐろい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "black with hints of blue (as in a bruise)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ともかくもそれを云ってしまうと、それまでひどく緊張してきつい表情をしていた彼の顔が急に柔らかになってくる、そして平生気持の悪いような青黒い顔色には少し赤味さえさして来て、見るから快いような感じに変化するのである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――青黒い支那兵営の中から四五人の白露兵が歩き出して来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二人は青黒い兵営に帰ると、そのことを、ほかの者達にすっかり名誉のようにバラしてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒い兵営から、布団や、床篦子や、弾丸が持ち出された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中を平地に窪んで、居る処も川幅も、凡そ百｜畳敷きばかり、川の流が青黒い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の目の周囲には青黒い輪が歴然と残っていた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉とただ二人、ばたばた羽をならし、たびたび顔を見合せながら、青黒い夜の空を、どこまでもどこまでものぼって行きました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿の西の窓の細い障子が少し開けてあって、廂へ搦んだ糸瓜の黄な花と青黒い葉と蔓との間から真赤な夕焼雲の端と、鼠色の暮空とが透いて見える。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺は煮えて賑かに、町は寂しい樹蔭の細道、たらたら坂を下りて来た、前途は石垣から折曲る、しばらくここに窪んだ処、ちょうどその寺の苔蒸した青黒い段の下、小溝があって、しぼまぬ月草、紺青の空が漏れ透くかと、露もはらはらとこぼれ咲いて、藪は自然の寺の垣。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　四「お痛え、痛え、」　尾を撮んで、にょろりと引立てると、青黒い背筋が畝って、びくりと鎌首を擡げる発奮に、手術服という白いのを被ったのが、手を振って、飛上る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりもみんな青黒いなまこや海坊主のような山だ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木がいっぱい生えているから谷を溯っているとまるで青黒いトンネルの中を行くようで時にはぱっと緑と黄金いろに明るくなることもあればそこら中が花が咲いたように日光が落ちていることもある。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギザギザの青黒い葉の間から、まばゆいくらい黄いろなトマトがのぞいているのは立派だった。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉とたゞ二人、ばたばた羽をならし、たびたび顔を見合せながら、青黒い夜の空を、どこまでもどこまでものぼつて行きました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒い顔色、白茶けた頭髪、窪んだ眼、少し開いた口、細堅い手足――枯木のような骨を石塊のような肉で包んだ、古びた、自然の断片――ああ、それは私を最も愛してくれる、そして私の最も愛する老祖母ではないか。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてズボンのポケットから青黒い大きな宝石を一個取り出して、大の字型に投げ出した彼の右の掌に握り込ませると、その上からシッカリと両手で押えつけながら眄目に彼を振り返った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて青黒い隈の多い長身の肉体は内部から慾求するものを充し得ない悩みにいつも喘いでいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光が河の靄に溶けて朦朧として、青黒い連山は躍り上った獣の背のように見え、遠くに漁火がきらめいているかと思うとまたどこからともなく横笛の音が哀れに聞える。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と紺の鯉口に、おなじ幅広の前掛けした、痩せた、色のやや青黒い、陰気だが律儀らしい、まだ三十六七ぐらいな、五分刈りの男が丁寧に襖際に畏まった。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、その青黒いがさがさした顔には到る処に面皰が吹出していた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　パッと消えるようであった、日の光に濃く白かった写真館の二階の硝子窓を開けて、青黒い顔の長い男が、中折帽を被ったまま、戸外へ口をあけて、ぺろりと唇を舐めたのとほとんど同時であったから、窓と、店とで思わず舌の合った形になる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、袴は、精巧｜平か、博多か、りゅうとして、皆見事で、就中その脊の高い、顔の長い、色は青黒いようだけれども、目鼻立の、上品向きにのっぺりと、且つしおらしいほど口の小形なのが、あまつさえ、長い指で、ちょっとその口元を圧えているのは、特に緞子の袴を着した。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "劃っているのは飛び飛びの青黒い岩の弧線である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつぽはガラス戸の中から、どんよりした青黒い海を、びつくりして見てゐました。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛はその眼先へ竹の皮包みを開いて突きつけると、紅い生姜は青黒い海苔をいろどって、子供の眼にはさも旨そうにみえた。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の青黒い眼尻の切れあがった、きりりとした男のような眼をした仙妃の顔は青年の心を軽くした。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その仙妃というのは、どんな女であったのか、美しい女であったか」「あまり美しい女ではありません、背の低い肌の青黒い女でありました」「他にどこか、これという特徴があったか」　その時青年は仙妃の眉尻に小さな疵痕のあったことを思いだした。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の中には綿が敷かれ、其の上に青黒い蜥蜴のやうな妙な形のものが載つてゐる。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒い地獄色の皮膚、前額に乱れかかった縮れ毛。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの素晴らしい宝石の数十粒がもしかすると自分のものになるかも知れぬ、という世にも浅ましい望み一つのために、苦痛と疲労とでヘトヘトになっている身体を草の中から引き起して、インキ壺の底のように青黒い眼の前の暗の中にソロソロと這い込みはじめたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
