    "definitions": [
      {
        "index": 1,
        "gloss": "to make (someone) to meet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日会わせるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "会わせるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は会わせるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には会わせるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "会わせるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは会わせるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "会わせるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は会わせるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では会わせるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "会わせるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に会わせるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では会わせるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "会わせるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると会わせるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "会わせるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では会わせるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に会わせるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により会わせるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "会わせるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に会わせるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "結婚は女をひどい目に会わせたことのつぐないになるし、また、今後ひどい目に会わせるための正当な手段に、結婚という形式が利用されるのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜のあけ方には、派出所の巡査、檀那寺の和尚まで立ち会わせるという狂い方でございまして。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中に会わせる顔もなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜか編輯長に会わせる顔がないと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの町獣医の妻では親類に会わせる顔もないと思うから、どう考えてもあきらめられない。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらあッしが掛け合いにいっても、打つ、殴る、蹴るの散々な目に会わせるだけで、一｜向埓が明かねえんでごぜえますよ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらで無関係と認める人間を立ち会わせるわけにはいきません。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、料理人は、「それでは、あの荷物もってきた人に会わせる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六年の間、もがき苦しんでも邂逅し得えなかった敵に、得度した後に、悟道の妨げになるようにと偶然会わせるほど、天道は無慈悲なものではあるまい。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が何とかして会いたいと留置場の中で日夜願っている同志たちとはこういう細工をしてまで会わせず、会わせる者はと云えば、帝国主義官憲とグルになって、もう「コップ」の仕事はしないと云えなどとよくも恥しらずにすすめる奴らです。",
              "citation": {
                "source": "逆襲をもって私は戦います",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上神崎検事からは、自由法曹団を相手にまわしていくらでも闘ってくれる弁護人がいるといわれ、前に頼んだ今野、小沢両弁護人さんたちに会わせる顔がなくて解任届を出した。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見りゃあまだ年もとってないのに、こんな目に人を会わせる、恥だ！",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでも四辺に満ちているのは暗い野蛮、卑猥、飽きもせず繰返されている喧騒とであったが、計らず「母なるヴォルガ」はその洋々とした流れの上で、ゴーリキイの生涯にとって実に意義深い「最初の教師」をひき会わせることになった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁は廃寺等のために墓碣を搬出するときには警官を立ち会わせる。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜もそれで塩野さんといろんなお話の末に久慈さんね、真紀子さんと会わせるようなら明日は出ないって。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「会わせる事はならん」「八釜しい」　と云うなりその紫色の禿頭を平手で撫でてやったら、非常に有難かったと見えて、羽織袴のまんま玄関の敷石の上に引っくり返ってしまった。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君の御両親ばかりでなく君に対しても会わせる顔がないのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんにも私が会わせるの会わせないのって……そんな因縁ありゃしませんよ。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私の父が、今なおこの町に、生存していることを話してくれましたし、何よりその場で、私を父に会わせると誓ってくれました。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房を思い切れないからって、何故あんなに辛い目に会わせるのだろう。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きつくところまで行き着かなければ、彼は生きて会わせる顔が無いと思った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小林さんは重大なる容疑者になっているから、今君を会わせることは出来ないですよ」「そうですか」力なく彼は肯いた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼　そうすると帰り道によけいにひどい目に会わせるそうですよ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして仏さまにもお別れをさせ、葬儀にも立ち会わせる、それがつまりは、仏さまへの供養ともなり、御近所の方々への義理を立てることにもなるのです。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は四時頃迄に帰る積りであったが、話はつきず、それ迄に帰るのは、全然不可能と判ると、逆に、夕飯に帰ってＡと顔を会わせるのが、しみじみといやになった。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども政子の申出であるから、上司に報告し、慎重に協議の上、しかるべき私服を一人政子のお供につけて、両婦人の会見に立会わせることにした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに東大病院は、患者に会わせるようなことはしない。",
              "citation": {
                "source": "日月様",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、兵庫の永福寺の方では本犯者の処刑があると聞いて、パアクスは二人の書記官を立ち会わせることにした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ明白な誤謬は一つもない論文であっても、一人の人間が限りある時間に仕遂げた仕事であってみれば、あらゆる批評家のあらゆる方面から見たとき考え得らるべきあらゆる要求を満足させるようにあらゆる釘と栓を挿しあわせるということはほとんど不可能なことである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千次郎のたよりはすっかり判ったぜ」　お登久は眉を少し動かしたが、やがて調子をあわせるように、華やかに笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
