        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日合わせるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "合わせるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は合わせるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には合わせるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "合わせるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは合わせるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "合わせるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は合わせるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では合わせるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に合わせるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では合わせるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "合わせるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると合わせるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では合わせるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合わせるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により合わせるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "合わせるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に合わせるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
