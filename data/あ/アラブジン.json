        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラブ人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラブ人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラブ人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラブ人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラブ人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラブ人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラブ人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラブ人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラブ人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラブ人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラブ人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラブ人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラブ人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラブ人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アラブ人は最多く、經行未だ到らざるに婚姻す。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六世紀のレオ・アフリカヌスの『亜非利加記』第九篇には、沙漠産ズッブてふ大蜥蜴をアラブ人食用す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人がもっとも馬に親切なるについて珍譚多し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六四年版、ピエロッチの『パレスタイン風俗口碑記』に、アラブ人が馬を愛重する有様などを尤面白く書いた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人は諸畜の中のもっとも馬を貴び、患難にあっても栄華にあっても最も人に信あるものとす。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人馬掛けて誓う事｜希だが、もし馬掛けて誓えば命を亡うまでも約を違えず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらが本当か知らぬが、先はピエロッチが見たパレスタインのアラブ馬は、アラビア本土のアラブ馬と性も芸も多少｜差うと見える――アラブ人が好む騎戦戯にはその馬叫喚飛棒の間に馳せて進退最も見るべく、十分戦争を解するものに似たり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人殊に牝馬を重んじ、大金を見ても売らぬ事多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーキンスの『アビシニア住記』一にアラブ人酒で酔わせて狗頭猴を捕える由言い、氏一日読書する側にこの猴坐して蠅を捉え、またその肩に上りて入墨した紋を拾わんと力めおり、氏が喫烟に立った間に氏の椅子に座し膝に書を載せ沈思の体までは善かったが、一枚一枚｜捲り裂きて半巻を無にした所へ氏が帰った。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時アラブ人は、東西兩用の間に、盛に海上交通を營んで居つたから、このアラブ人の媒介で、羅針盤の使用が、東洋から西洋へ傳播したものかと、想像すべき餘地が多い樣であります。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古軍との觸接で、アラブ人（サラセン人）が火藥と鐵砲の使用を知つたのは、西暦十三世紀の半頃のことであらうと想はれます。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "兔に角火藥は支那からサラセン國へ傳つたものと見え、アラブ人は火藥の主要成分である硝石を Thelg as Sin 即ち支那の雪と呼び、火箭の事を Sahm Khatai 即ち支那矢と稱したさうであります。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "降つて西暦十四世紀になると、アラブ人から火藥が歐洲へ傳はりました。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐洲に於ける火藥の起源については、從來種々異説もありますが、近時火藥や火器の歴史を研究した學者の説は、多くアラブ人から歐洲に傳へたものといふことに傾いて居ます。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "Reinaud はこの物語の序論として、中世に於けるアラブ人の東洋貿易界に於ける活躍の歴史を附し、又その本文に對して尠からざる註解を施した。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）　不幸にして唐時代に關する支那人の記録に、直接の證據見當らぬ場合には、唐以前の、若くば唐以後の事蹟で、この物語の記事と相發明するに足るものを、支那人の記録中から探求し、これより推して、アラブ人の所傳の信憑すべき程度を明瞭にすること。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（４）　アラブ人の所傳と發明すべき、若くば關係ありと思はるる記事が、諸外國人の記録中に見當る場合は、成るべく之を蒐集して參考に供すること。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人はこの事實を傳へたものと思はれる。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人はペルシア灣から印度洋を經、マライ半島を廻つて、今日の廣東へ來て、盛んに通商を營んだ。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣東をその當時のアラブ人は、Khanfou (Khanfu) 　と呼んだ。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この廣州の外、嶺南の交州、江南の揚州、福建の泉州にも唐時代からアラブ人が通商を開いて居つた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人の支那通商は、その間に多少の盛衰や、一時の斷絶はあつても、大體から見渡して、唐から五代を經て、宋に至るまで、格別の變化なく繼續した。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "否宋代となると、アラブ人の通商は一層盛大を極め、又それに關係ある支那方面の記録材料も一層多く傳はつて居る。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉州は宋末や元時代のアラブ人、その他の西方外國人に、Zayton,  〔Zaytu^n〕 又は Zeytoun 等と呼ばれた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ人はこの刺桐城をその儘に、〔Me'dinet〕 Zeytoun といひ、或は城市の意味に當る 〔Me'dinet〕 を略して、單に Zeytoun と呼んだのである。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　支那居留の大食商賈　宋時代に支那に通商したアラブ人が、支那の開港埠に於ける生活状態を一瞥すると、彼等は事實としては、時に城内に支那人と雜居したこともあるが、原則としては一定の居留地をもつて、ここに住居して居つた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『萍洲可談』に據ると、北宋の末に、廣東在留のアラブ人で劉姓の人が、宗室の女を娶つて左班殿直といふ官職に就いたことがあり、また『宋會要』に據ると、南宋の初に、廣東在住の右武大夫の曾訥が、アラブ商人の蒲亞里（Abu Ali ?）といふ者の財力豐富なるを利として、この人にその妹を嫁せしめたことがある。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾が輩は更に彼の姓を蒲と稱する點から推測して、蒲壽庚は蓋しアラブ人即ちイスラム教徒であらうと斷定する。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の記録に見えて居る外國人の姓に蒲とあるのは、アラブ人の名乘に普通な、Abu (Abou) の音を表はしたものであらうといふ説は、今より二十餘年前に、ドイツのヒルト氏の唱へ出した所であるが、吾が輩はこの蒲壽庚の蒲も同樣と認めたい。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
