[
  {
    "uuid": "92cd2130-63ba-5fcf-b2c6-255c58fa4ce9",
    "entry": "姉婿",
    "reading": {
      "primary": "あねむこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the husband of one's elder sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉婿について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉婿という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉婿の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉婿が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉婿を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉婿について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉婿の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉婿の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉婿が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉婿という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉婿という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉婿についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉婿を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉婿は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉婿について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉婿が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉婿は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉婿の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉婿は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉婿は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "義兄（医学士――姉婿を云う）は忙しいし、またちっとでも姉さんを出さないのよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手代等は若檀那子之助の前途を気遣って、大坂町に書肆を開いている子之助の姉婿摂津国屋伊三郎を迎えて、家督相続をさせようとした。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃から、父子の間不和で、後天文十年父信虎を、姉婿なる今川義元の駿河に退隠せしめて、甲斐一国の領主となる。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年越の関東滞陣で兵馬が疲れているにも拘らず、直ちに陣触に及び、姉婿長尾｜政景に一万の兵を托して、春日山城を守らしめ、自分は一万三千の兵を率いて、一は北国街道から大田切、小田切の嶮を越えて善光寺に出で、一は間道倉富峠から飯山に出た。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "詮議の次第とは何事ぞ、その筋に向かいて詰問する所ありしかど何故か答えなければ、妾の姉婿某が県会議員常置委員たりしに頼りてその故を尋ねしめけるに、理由は妾が自由党員と船遊びを共にしたりというにありて、姉婿さえ譴責を加えられ、暫く謹慎を表する身の上とはなりぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上、小河の二人は次へ出て、利章方へ一人たりとも參つてはならぬと觸れ、利章の邸の前に往つてゐた者共を、利章の姉婿で、當時｜睡鴎と名告つてゐた黒田｜美作が邸と、其向側の評定所とへ引き上げさせた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な畫工には、父も財産も無かつたが、郷里には素封家の一人に數へられる伯父と、小さいながら病院を開いてゐる姉婿とがあつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本は仏蘭西に居る姉婿宛で、タナグラの安いのを見付けて呉れといふ依頼である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、叔父は、姉婿が壊れた家を支えかねて、金を拵えにと言って、田舎へ逃げ出してから、下宿の方へ来てその姉に話した。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅山は、このごろしばらく帰朝している姉婿の家へ行っていて、留守であったが、台所にいた伯母は、手を拭きながらすぐに傍へ寄って来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅山が、今の役所を罷めて、今度の帰朝を幸いに姉婿の方へ使ってもらう運動をしているのだが、それがうまく行きそうにもない様子が、母子の口から洩れた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころには、甥もその姉婿につれられて、田舎へ帰っていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉婿も同じようなことを言って、お島に意見を加えた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "習字や素読さへも、最初は兄に、後には姉婿に教はつたのみであるから、教へるはうも不規則、習ふはうは尚ほの事、互ひに気儘や我儘が勝つので、厳しく叱られて泣面になつたことの多い割合には、習ふことが身に沁みず、只ぶら／″＼と月日を過し、閑さへあればたわいもない、くだらん本ばかり読み耽つてゐたものである。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七代目団十郎や五代目瀬川菊之丞や五代目半四郎や鼻高の幸四郎なども、どういふ履歴の俳優だか、そんな事は知らなかつたが、其面附きだけは、種々の草双紙の画面に依つて、名古屋の姉婿や叔父、叔母以上によく覚え込んでゐたのであつた。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時｜姉婿花忠茂が密に遣つた手紙に、「御やしき中忍びにて御ありきはくるしからぬ儀と存じ候」と云つて、丁寧に謹慎を勧めてゐる。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安田図書　伊勢山田外宮御師　淡路町附近にて捕はる寛輔　堺北糸町医師、西村の姉婿、西村の逃亡を幇助す　捕はる正方　河内渋河郡大蓮寺隠居、杉山の伯父にして杉山をして剃髪せしむ　捕はる　以上重罪者三十一人の中で、刑を執行せられる時生存してゐたものは、竹上、杉山、上田、大西、白井彦右衛門の五人丈である。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川をお頼みなさいまし」　当時今川義元と云えば駿遠参の大管領で匹儔のない武将であったが、信虎の一女を貰っていたので晴信にとっては姉婿に当たり日頃から二人は仲がよかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すると又都合のいい事には、Ｔ子の姉婿のＧという京染｜悉皆屋が、仕様のないニヤケ男の好色野郎で、婿入りをすると間もなく、義妹のＴ子に云い寄りはじめて、恐ろしく執拗いので困っている矢先だったから、Ｗに誘いをかけられたＴ子は二つ返事で家を飛出して、福岡でＷとコッソリ同棲する事になった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も継母の姉婿の、かの絵をよく描く山本は、書もよく書くので、これに手本を書いてもらって習ったが、私は一体手習が嫌いであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本は仏蘭西に居る姉婿宛で、タナグラの安いのを見付けてくれという依頼である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の二人、弟の一人と、姉婿が棺側に附いて、最早墓守夫妻が其亡くなった姉をはじめて識った頃の年頃になった彼女の妹が、紫の袴をはいて位牌を持った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづの姉婿、加藤律治氏は杉並でクリーニング店を営み、しづは同所に居住している関係上、羽山はしばらく同所でしづと同棲、仕事を手伝ってもらいたいと懇請され、長年の得意をすてゝ、その言に従った。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "中山しづの姉婿、クリーニング業加藤律治の証言　しづは私の家内の妹です。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥の姉婿、つまりお鳥の義兄が商用で長崎から大阪へ上り、いま川口の宿にいる。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の祖父は中川家から出ているが、その祖父の姉婿にあたる人が若死したので、弟子の中の一人を家においたのが、恭次郎の親であった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "河村さんの息子が姉婿のところで修業中、それがとったのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
