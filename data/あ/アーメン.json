        "examples": {
          "standard": [
            {
              "text": "私は毎日アーメンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーメンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーメンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーメンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーメンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーメンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーメンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーメンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーメンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーメンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーメンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーメンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーメンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーメンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーメンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーメンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーメンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーメンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーメンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーメンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "終末の幕切れに教授の死を弔う学生の「アーメン」にいたっては、蛇足にサボをはかせたようなものではないかと思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学教授連盟とかいう自分にはあまり耳慣れない名前の団体から、このような芝居は教育界の神聖を汚すものだと言って厳重な抗議があったので、それに義理を立てるためにこのアーメンを付加したのだといううわさがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、竹内君は御存知ですが僕はこう見えても同志社の旧い卒業生なんで、矢張その頃は熱心なアーメンの仲間で、言い換ゆれば大々的馬鈴薯党だったんです！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕は例の熱心なるアーメンでしょうクリスマス万歳の仲間でしょう、クリスマスと来るとどうしても雪がイヤという程降って、軒から棒のような氷柱が下っていないと嘘のようでしてねエ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、眠くなって了ったわ、だからアーメンと言ったら、貴下怒っちゃったじゃアありませんか。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」スルト側から水戸の川又子、俳号を五｜茶と申す、宗匠気取りで、　ああら天狗一夜の宿を貸し給えと駄句れば、「アーメン」と誰か混ぜ返した者がある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の相貌、羅漢に似たる為か、アーメンはよくよく嫌いと見えたり。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様の思召に依りまして、チンプンカンプン様の顎タンを結ばれました事は――越中褌のアテが外れた時と全く全く同じように、ありがたい、尊い、勿体ない、嬉しい嬉しい御恵みで――ありや――す……アーメン。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アーメン、ソーメン、トコロテン。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相手がアーメンと思うと、いくら力瘤を入れても、入れ甲斐がないような気がして、チーット力瘤を入れ過ぎたようです、とうとう大椿事になりましてなあ――」　とその時の有志の一人が語った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーメンも面白かろう。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アーメン、アーメン。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ、あはれみたまへ、アーメン。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この言葉は「アーメン」を口にする人の数を、今でははるかに、抜いているのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰か主の心を知りし、孰か彼と共に議することを為せしや、孰かまずかれに施えてその報を受んや、そは万物は彼より出、かれに倚り、かれに帰ればなり、願くは世々｜栄神にあれ、アーメン。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見るとクララは咽せ入りながら「アーメン」と心に称えて十字を切った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い説教ではなかったが神の愛、貧窮の祝福などを語って彼がアーメンといって口をつぐんだ時には、人々の愛心がどん底からゆすりあげられて思わず互に固い握手をしてすすり泣いていた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーメン」　クララはこの上控えてはいられなかった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アーメン」という重い声が下から響いた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララも「アーメン」といって応じながら用意した綱で道路に降り立った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子と貞世とは恋人のように抱き合いながら、アーメンという声の一座の人々からあげられるのを待って室にはいった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男の子は、「アーメン。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるのですアーメン」　かういふことがいへる日が来たら、どんなにいいだらうか。",
              "citation": {
                "source": "沙漠の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論運動家はヘツペル先生なのだが、今朝先生は、この四、五年来といふものは永年の修行のためか或ひは年齢の加減か、殆どもうさういふ発作に駆られるやうな場合には出遇はなくなつて、何時も敬虔な気分でヒルゼルやスパイスのお経を繙けるようになつた、「アーメン！",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
