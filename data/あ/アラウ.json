[
  {
    "uuid": "53e2358c-8978-53a6-8d9d-81716fa2dc32",
    "entry": "洗う",
    "reading": {
      "primary": "あらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to wash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一同は狂気のように躍り上って、悦んだ、そうして小さい谷川へ下りたときには、敷石の水成岩の上に、腹這いになって、飲む、嗽ぐ、洗う、もう浸かるばかりにして、やっと満腹した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白っぽい砂礫を洗う水の浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ついでに洗う洗濯物が無くて、お湯にどっぷり入るときくらい嬉しいことはない。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその人は、すぐに河をわたるでもなく、いかにもわらじや脚絆の汚なくなったのを、そのまま洗うというふうに、もう何べんも行ったり来たりするもんだから、ぼくらはいよいよ、気持ちが悪くなってきた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、このキャディのうちの一人がリンクの池で鮒を一匹つかまえて、ボールを洗う四角な水桶の中に入れておいて、一廻りした後に取りに来たらもう見えなかったそうである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其製造というは、小刀で黐の木の皮を脱がし、それを自分の口でかみ摧いては水に洗うのである。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ十分かめたので水を釣って洗う順序である。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日ではどうしても顔を洗うことができぬ　顔を洗うだけは迚ても手が動かせないのだ。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "着たままで寝ていた僕はそのまま起きて顔を洗うや否や、未だほの闇いのに家を出る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きて顔を洗う金盥の置き方から、夜寝る時の寝衣の袖の通し方まで、無意識な定型を繰返している吾人の眼は、如何に或る意味で憐れな融通のきかきぬものであるかという事を知るための、一つの面白い、しかも極めて簡単な実験は、頭を倒にして股間から見馴れた平凡な景色を覗いて見る事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓膜の破れた人が耳を洗う時｜眩暈を感じたり、また健全な者でも少時間グルグル舞うた後には平均を失うて倒れたりするのは皆この三半規管を刺戟するためだという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに学問するとても顔や手を洗うひまのなき事やはある。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだ中の血液の濁りを洗うような気がする。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯をあたれば、顔を洗う湯も汲んできなければならない。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は顔を洗うひまもなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お湯どころか、米を洗う水さえなくって困っとるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使が大きなブラッシをかけて、豚のからだをきれいに洗う。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が顔を洗う前足の横側には、毛脚の短い絨氈のような毛が密生していて、なるほど人間の化粧道具にもなりそうなのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは青空よい天気まえの家でも隣でも水｜汲む洗う掛ける干す。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして顔を洗うために鉢の水が動揺すると、この水の定常振動と同じ週期で一種の楽音を発することがしばしばある。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの大嵐には黒い波が一町に余る浜を打上がって松原の根を洗うた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗緑色に濁った濤は砂浜を洗うて打ち上がった藻草をもみ砕こうとする。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもう、そろそろ足を洗うつもりでいるんだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもすぐに川をわたるでもなく、いかにもわらじや脚絆のきたなくなったのをそのまま洗うというふうに、もう何べんも行ったり来たりするもんですから、みんなはだんだんこわくなくなりましたが、そのかわり気持ちが悪くなってきました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから金だらいを出して顔をぶるぶる洗うと、戸棚から冷たいごはんと味噌をだして、まるで夢中でざくざく食べました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど手ひどい事なれば、必らず仇を返したいはもちろんの事ながら、それでは血で血を洗うのじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃア足を洗うんだ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし婆さんは何とも思わないでこの水で朝夕、鍋釜を洗うようであった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "横顔なれば定かに見分け難きも十八、九の少女なるべし、美しき腕は臂を現わし、心をこめて洗うは皿の類なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
