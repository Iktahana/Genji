        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "喬はそんななかで青鷺のように昼は寝ていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の沼地に鳴く青鷺の聲であり、月夜の葦に暗くささやく風の音である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺と、ひきがえるくらいの差がある。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わぎもこを、いとおし見れば青鷺や、言の葉なきをうらみざらまし。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの壁画を見れば、豺や鰐や青鷺などの奇怪な動物の頭をつけた神々の憂鬱な行列である。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春香取神宮槙のこずゑに、青鷺の群れて巣をもつ幽けさよ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "田家の月夜青鷺は薤ぬすむ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜に青鷺が盗みに来て射られた話がある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "本土ならば、こうした矢先にかかる鳥は一羽もいなかっただろうが、この島に住んでいる里鳩、唐鳩、赤髭、青鷺などは、俊寛の近づくのをすこしも恐れなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の句には夕風や水青鷺の脛を打つ鮓を圧す我れ酒｜醸す隣あり宮城野の萩｜更科の蕎麦にいづれのごとく二五と切れたるあり、若葉して水白く麦黄ばみたり柳散り清水｜涸れ石ところ／″＼春雨や人住みて煙壁を漏るのごとく五二または五三と切れたるもあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟練した画工たちが高価な木の板に桜や梅の花、また杉の木の頂に止まっている黄金色の目をした鷹の絵、そして、楓の木陰の下で餌を採っている小さな子鹿、雪中の鴨、飛んでいる青鷺、花開いた菖蒲、水中の月を掴もうとしている長腕の猿の絵を描いた。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼ねふる青鷺の身のたふとさよ　　　蕉　しよろしよろ水に藺のそよくらん　兆　これは凡兆の付け方、未しきやうなり。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白百合の白き畑の上渡る青鷺連のをかしき夕　日常生活を一歩も出ない常識歌を作つて、それが詩でも何でもない唯言であることを忘れてゐる或は初めから御存知ない連中が斯ういふ作を見たら何といふだらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の句には夕風や水青鷺の脛を打つ鮓を圧す我れ酒｜醸す隣あり宮城野の萩｜更科の蕎麦にいづれの如く二五と切れたるあり、若葉して水白く麦黄ばみたり柳散り清水涸れ石ところ／″＼春雨や人住みて煙壁を漏るの如く五二または五三と切れたるもあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記明応五年四月の条に、東隣すなわち正親町三条家から三栖庄内で鷹にとらしたという青鷺をもらった記事がある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今では馬鹿といえば誰でも怒りますが、馬鹿という語にはいろいろ説がありますが、インドでは馬鹿の表現が青鷺である。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺を「バカ」といいます、それが馬鹿ということになったのであろうと思います。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺の立ち迷う沼沢の多かったむかしにくらべ、この城外には、甍を立てた建物が混み合っていた。",
              "citation": {
                "source": "後の日の童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時示したのがこの句で、「下のかたより青鷺のこゑ」という脇を助然がつけている。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下のかたより青鷺のこゑ」という助然の脇も、折からの景物と思われる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「青鷺の者を呼べ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外の搦め手にあたる黒沢の裏谷に、黒沢衆とも青鷺衆ともよばれている外者（藩外の雇傭人）の小屋｜溜りがある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺の者の頭という三蔵はそれだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺衆という組の名は、その服色からきたものらしい。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら空へ立つ青鷺にも似ている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青鷺の者の三蔵は、まだ駈けつけて来ぬか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは青鷺の三蔵だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世間の奴あ、大垣の青鷺者ッてえと、お城の掃除人夫か、土方人足みたいにばかにするが、同じ青鷺仲間にも、一本差している組と、何も知らねえ日傭い稼ぎのふた色ある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鷺の三蔵は、ようやくここで人数に追いついた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
