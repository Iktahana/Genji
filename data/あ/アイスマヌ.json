    "definitions": [
      {
        "index": 1,
        "gloss": "very sorry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相済まぬは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相済まぬが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相済まぬに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相済まぬが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相済まぬについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相済まぬについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相済まぬについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相済まぬが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相済まぬが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相済まぬは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相済まぬは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相済まぬを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相済まぬをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相済まぬが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相済まぬの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相済まぬを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相済まぬに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相済まぬについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相済まぬは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相済まぬを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三四郎は役人に、Ｔ「お騒がせして相済まぬ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……また……これ程の親孝行な娘御の行末がお幸福にならねば、この猪口兵衛が天道様に対して相済まぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠に秘め置く、守刀をキラリと引抜くまで、襖の蔭から見定めて、（ああ、しばらく、）　と留めたは、さて、殺しては相済まぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、相済まぬ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（腰を屈めつつ、圧うるがごとく掌を挙げて制す）何とも相済まぬ儀じゃ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟奇の編輯者には相済まぬ事ながら、わざと黙殺を希望していたのでした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その精神で上は神明に仕え下は自己の修養に資しようという無敵、潔白の自負と、いい加減な弟子を後世に残して流風を堕落させては師匠の相伝に対して相済まぬ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に相済まぬ面目ない話であるが、実際だったから仕方がない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」七兵衛は口軽に、「とこう思っての、密と負って来て届かねえ介抱をしてみたが、いや半間な手が届いたのもお前の運よ、こりゃ天道様のお情というもんじゃ、無駄にしては相済まぬ。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "作平が悦喜斜ならず、嬉涙より真先に水鼻を啜って、「話せるな、酒と聞いては足腰が立たぬけれども、このままお輿を据えては例のお花主に相済まぬて。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手数をかけて相済まぬ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびたび無心を言うて相済まぬがな。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿までさせて頂いて、いろいろと御造作に預る居候の身がわがまま言うて相済まぬが、旅に出るとどういうものか身共、三日目に一度位ずつ、塩ものを食さぬと骨放れが致すようでならぬのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それは実際そうである……実に申しわけがない……相済まぬ次第である……そんな事があってはならぬ……ない方がむろんいいにきまっている……しかし江戸ッ子の現状を見ると、思わずそんな事を考えさせられるのだから仕方がない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは相済まぬことで。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年「無線と実験」で乞われるままに、これを誌上に送ったが、いくぶん手を入れ、また落選作と分っては極りがわるいので題名を『壊れたバリコン』と変えた次第であるが、今から考えるとまことに相済まぬことをしたと思う。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ気がひけるがあまり頑張っていて更に大きな失態をしては、事件の依頼主に対し相済まぬと思ったからである。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、僕の愚痴をならべて君を退屈させても相済まぬ。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何だか其では聊か相済まぬような気もして何となく躊躇せられる一方で、矢張何だか切に……こう……敬意を表したくて耐らない。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、読者に対してはどうかと云うに、これまた相済まぬ訳である……所謂羊頭を掲げて狗肉を売るに類する所業、厳しくいえば詐欺である。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まただれだれに逢えと、御好意を持つものと思召して御名ざしになったのに対しても相済まぬこととお思いになりませんか。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御老体のお世話をすることもできずに遠い国で年を送っていますのは相済まぬことだと思っているのですよ。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斯うしていては、秋岡先生に相済まぬ」　竜次郎は全部魂が腐敗し切ってもいなかった。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は欺て人を試験するようなもので、徳義上に於て相済まぬ罪なれども、壮年血気の熱心、自から禁ずることが出来ない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人に対して金銭の不義理は相済まぬ事と決定すれば、借金はます／＼怖くなります。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、私も、坪井君もへんに相済まぬような微笑を浮べた。",
              "citation": {
                "source": "怪異に嫌わる",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺の地歩を占むるにも幾百の勇士の血に代へて猶難しとした当年の戦跡に、かく軽快に車を駆ることは、まことに相済まぬ気がするのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「野郎なぞとおっしゃっちゃあいすまぬほどのおかたでごぜえます。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "作阿弥先生に御無礼があっては、あいすまぬ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もしやまたおまえもそんな徒輩の仲間に染み、不忠不孝の曲者にでもなり終っては、ご先祖にあいすまぬと、日夜心をいためていたところへ、あの石勇という男がみえたので」「ではまったく、あの手紙は父上の……。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
