        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒行について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒行という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒行の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒行が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒行を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒行について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒行の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒行の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒行が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒行という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒行という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒行についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒行を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒行は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒行について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒行が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒行は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒行の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒行は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒行は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もり蕎麦は、滝の荒行ほど、どっしりと身にこたえましたが、そのかわり、ご新姐――お雪さんに、（おい、ごく内証だぜ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十時間一睡もせずに書き続けて来た荒行は、何か明治の芸道の血みどろな修業を想わせるが、そんな修業を経ても立派な芸を残す人は数える程しかいない。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬鳴山では毎日滝にうたれて荒行をした。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒行をはじめた始めの一週間には種種な不思議なことがあった。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉も近来はよほど丈夫になったと人も云い、自分もそう信じているのですが、土台の体格が孱弱く出来ているのですから、迚も刺青などという荒行の出来る身体ではない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるだけその方のことは倹約することにして、荒行を山でやりたく出て来ました。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢れも、荒行に似た苦しい禊ぎを経れば、除き去ることができ、また天の羽衣を奉仕する水の女の、水に潜いて、冷さに堪えたことを印象しているのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "総て支那社会に起る暗殺、掠奪、ピス強盗の行為は、殆んど皆此等青紅幇の手に由らざるものなく、近頃市上で時々起る銭荘荒しのピス強盗の如きも大部分は彼等の荒行である。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい荒行をする猛勇な人や、夜の目も惜しんで研究する人や、また仙人のように清く身を保つ人やさまざまな人がいた。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒行にたへたその童貞の肉体は逞しく、彼の唄ふ梵唄はその深山の修法の日毎夜毎の切なさを彷彿せしめる哀切と荘厳にみちてゐた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢れも、荒行に似た苦しい禊ぎを経れば、除き去ることが出来、又天の羽衣を奉仕する水の女の、水に潜いて、冷さに堪へた事を印象してゐるのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こッちで音をあげるバカがあるか」　なるほど、その魂胆か、と才蔵は呆れたが、そんな荒行にマキゾエくっては、たまらない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分こそ廃ったけれども、その以前は、この滝にかかってかなりの荒行をしたものさえあるとのことだから、隠れて行をする信心の行者を妨げるのを恐れ多いとして、やはり噂を噂だけにして、里人はあえて近寄ろうともしません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊でもムジナでも叩き殺して食ってしまうという実に大変な奴で、時々荒行と称して山にこもるのは、この味が忘れられないせいだ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすでに寿永元年四月において、文覚上人を高雄より請して相模の江の島に大弁才天を勧請し、三七日間の断食の荒行をまで修せしめて、秀衡調伏の祈願を籠めしめたのであった。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくのお進めでござるによって、では遠慮なく逗留｜仕り……」「荒行でいささか疲労した体を、休ませていただくことにいたしましょう」　と、片岡坊こと片岡八郎と、岡本三河房が隙かさず云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文覚以来絶えてない那智の荒行をやって、十幾たび気を失い、天下に名をとどろかした怪僧であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十七日）拝啓昨今御病床六尺の記二、三寸に過ず頗る不穏に存候間御見舞申上候｜達磨儀も盆頃より引籠り縄鉢巻にて筧の滝に荒行中｜御無音致候。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文覚の荒行　清盛のいうように頼朝はさる平治元年十二月、父｜左馬頭義朝の謀叛によって殺される運命にあったが、池禅尼の必死の嘆願で死を免れ、十四歳のとき、永暦元年三月二十日、伊豆国｜北条蛭が小島に流されたものである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の殺された部屋の眞つ下に陣取り、下手人を斬り殺すんだと言つて、馬糞臭い抹香を一升五合ばかりも焚き、獨鈷を横喰へに、揉みに揉んでの荒行ですよ」「道理で煙いと思つた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒行にたえたその童貞の身体は逞しく、彼の唄う梵唄はその深山の修法の日毎夜毎の切なさを彷彿せしめる哀切と荘厳にみちていた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は一所不住の歌人｜西行、後者は高雄神護寺の荒行者｜文覚である。",
              "citation": {
                "source": "西行の眼",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、高雄に文覚という荒行者がいるそうだ、旅のついでに逢えたら逢おう、ぐらいに考えているだけであった。",
              "citation": {
                "source": "西行の眼",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが彼をして、自己克服のために、すさまじい荒行を行わしめた理由でもあり、彼の偉さもまたその点にあったのである。",
              "citation": {
                "source": "西行の眼",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、文覚の情熱と、意力と、荒行との尊さを知らないものではない。",
              "citation": {
                "source": "西行の眼",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それもまあ身体に準じたもので、無茶に荒行をやるのも感心しませんな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはこともなげに書いてあるが、冬の最中に、百日も百五十日も水行をする、そういうことは、剣術遣いの勝なればこそやれるが、おれにはできぬ、なかなか荒行をやる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うも仏教が荒行になって来ると思った。",
              "citation": {
                "source": "人生正会員",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　文覚は、まだ十九の頃に、若い髻を切って、大峰、葛城、粉河、戸隠、羽黒、そしてまた那智の千日籠りと、諸山の荒行を踏んできた、その昔の遠藤武者盛遠が成れの果てであった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の修行ぶりもまた、人なみ超えていて、那智山の荒行の如きも、諸国の名山｜大川に亙って、幾度となく体験して来たらしい。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
