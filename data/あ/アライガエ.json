    "definitions": [
      {
        "index": 1,
        "gloss": "clothes worn while one's other clothes are in the wash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い替えについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い替えの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い替えが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い替えについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い替えの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い替えが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い替えという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い替えについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い替えは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い替えが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い替えは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い替えの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い替えは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い替えは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夏が過ぎても、かれは白地一枚のほかには洗い替えの浴衣すら持たなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
