[
  {
    "uuid": "1e79ba21-1964-521d-a251-b0b81e6f6585",
    "entry": "在りし日",
    "reading": {
      "primary": "ありしひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
