    },
    "definitions": [
      {
        "index": 1,
        "gloss": "past days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日在りし日について考えている。",
              "source": "幻辞"
            },
            {
              "text": "在りし日という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在りし日の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在りし日が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在りし日を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在りし日について学習した。",
              "source": "幻辞"
            },
            {
              "text": "在りし日の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在りし日の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在りし日が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在りし日という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在りし日という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在りし日についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在りし日を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在りし日は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在りし日について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在りし日が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在りし日は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在りし日の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在りし日は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在りし日は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昨日の大阪の顔は或は古く或は新しくさまざまな粧いを凝らしていたものだが、今日の大阪はすでに在りし日のそうした化粧しない、いわゆる素顔である。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大学に在りし日に、余が品行の方正なるを激賞したる相沢が、きょうはいかなる面もちして出迎うらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大學に在りし日に、余が品行の方正なるを激賞したる相澤が、けふは怎なる面もちして出迎ふらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父在りし日さへ月謝の支出の血を絞るばかりに苦き痩世帯なりけるを、当時彼なほ十五歳ながら間の戸主は学ぶに先ちて食ふべき急に迫られぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五章　遊佐良橘は郷里に在りし日も、出京の遊学中も、頗る謹直を以て聞えしに、却りて、日本周航会社に出勤せる今日、三百円の高利の為に艱さるると知れる彼の友は皆驚けるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間貫一が鴫沢の家に在りし日は、彼の兄の如く友として善かりし人、彼の身の如く契りて怜かりし人にあらずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだにニコライ・ロマノフの写真を飾って上帝に十字を切る一団、北東の秘密活動本部をここへおく第三国際の宣伝員、すべての主義と世の動きとをよそに在りし日を夢みる階級――それらの露西亜人とその家族たちが、しばらく政治と闘争と謀策を中止して一夜の受楽のためにこうして集っているのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大学に在りし日に、余が品行の方正なるを激賞したる相沢が、けふは怎なる面もちして出迎ふらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは養母の在りし日の榮華の記念物である古琴と共に東京へ携へて來たのであつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵尊（在りし日の）大正十二年九月一日の大震に倒れただけで無事だった地蔵尊が、大正十三年一月十五日の中震に二たび倒れて無惨や頭が落ちました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、藍青の裾を長くひいた山々は、過ぎし日の温容そのままで、わが亡き父母に代わって在りし日の想い出を、私に物語るのではないか。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自分の愛しているものでも死んだような場合には、死後もなお彼女が在りし日の姿のまま、その葬られた山の奥などをしょんぼりとさすらっているような切ない感じで、その死者のことが思い出されがちでありましょう。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら在りし日さながらの妻の姿をちらりとでも見られはすまいかと思っていたが、ほんの影さえも見ることができなかった。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにクラリモンド埋めらる在りし日に最も美しき女として聞こえありし。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "窯もまた伊賀には伊賀の構築、古志野には古志野の窯が、昔ながらの形で入用なので、すべてが在りし日の昔のままに遡って、一応も二応も研究しなくてはならぬのである。",
              "citation": {
                "source": "窯を築いて知り得たこと",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえその肉体は腐っていても、在りし日の面影は認められるであろう。",
              "citation": {
                "source": "墓",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふ迄もなく「現地調査」にわざわざ千束町から龍泉寺町、地方今戸界隈迄、出かけたとは云つても、それは丁度、旅順へ観光に出かけて在りし日の激戦の様を偲ばうとするやうなもので、地形だけはざつと似てゐようとも、そこには溝も無ければ「橋」など痕跡さへその後は止どめない。",
              "citation": {
                "source": "刎橋の受け台について",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思ふに、在りし日のおはぐろ溝の刎橋とその受台をありのまゝに図したものは、偶然の写真でもなければ、この国観の絵が世の中に唯一枚のものであらう。",
              "citation": {
                "source": "刎橋の受け台について",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はモラエスさんはよく知つてゐます」といつて、案内者は、二十三歳で逝去したその女性の墓の側で、この異郷の文豪の在りし日の生活をぽつ／＼と語つた。",
              "citation": {
                "source": "心の故郷",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "在りし日と姿かわった司馬先生は、経かたびら、頭巾、さらし木綿の手甲脚絆をまとい、六文銭を入れたふくろを首に、珠数を手に、樒の葉に埋まっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを焚くと亡くなられた方の姿が、ありありと眼の前に現れ、在りし日と同じようなお話をなさいます。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お園」　美しさも、香ばしさも、在りし日のお園と変りません、温かい唇も、軟かい頬も、其の儘のお園が、蘇生って丈太郎の腕の中に、思いもよらぬ艶かしい媚態を尽すのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々を取り巻く現実の都市では建物の頂上部分は風化してしまい、幾時代も前に形なき廃墟と化していたのだが、浅浮き彫りには在りし日の姿がはっきりと描かれていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "在りし日の如くに集ひ余花の庵五月三日　水竹居追悼句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は法隆寺から夢殿、夢殿から中宮寺へかけて巡拝するたびごとに、この斑鳩の里に嘗つて太子の歩まれたことを思い、一木一草すら懐しく、在りし日の面影を慕いつつ佇むのを常とする。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奈良を訪れ、あの壮大な東大寺伽藍を仰ぎみるたびに、在りし日の栄光を思い、また今日からは想像も及ばぬような規模雄大の大仏殿｜建立に生命を傾けられた聖武天皇と光明皇后を偲びまつるのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "“生きてゐたら”とおもひ“見せたかつたなあ”とおもひ、友人たちはみな在りし日のことのみ、とたんに思ひ出されてゐたのだつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るものは演奏が良くても吹込みが悪く、或るものはトーキー音楽の如く誇張されており、また或るものは劇的に遊戯に堕している中にあって、独りシューベルトの在りし日を偲ばせるような美しさと気品を見せてくれるのは、ワルターの『未完成』である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて巴里に在りし日、ある無遠慮な一日本人がアンリ・マチスの面前で、『私の観るところでは、先生は、描く術においては古来の大画家達に比して、決して劣っておられるとは思えませんが、古来のいかなる画聖も先生の傍に据えると、一人のこらず、馬鹿野郎に見えます』と放言した。",
              "citation": {
                "source": "芸術統制是非",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "○をかにきて　ほがらかになくやうぐひすありしひのたにまのゆきにまじへたるこほるなみだはしるひとぞしる　佐藤春夫のこの詩は、仮名ばかりで書かれてあることによつて其の美しさを増してゐる。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
