        "examples": {
          "standard": [
            {
              "text": "暑い日だったので、子供は迷わずチョコレートがけのアイスクリームコーンを注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この新しいアイスクリームコーンは、サクサクとした食感とほんのりとした甘さが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏祭りの屋台では、様々なフレーバーのアイスクリームコーンが飛ぶように売れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアイスクリームコーン、すごく大きいね！」と友人は目を丸くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ワッフル生地のアイスクリームコーンは、しっかりとした甘みと香ばしさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パフェに添えられたミニサイズのアイスクリームコーンは、見た目にも可愛らしいアクセントとなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
