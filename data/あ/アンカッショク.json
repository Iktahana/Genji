    "definitions": [
      {
        "index": 1,
        "gloss": "dark brown",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗褐色について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗褐色の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗褐色が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗褐色について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗褐色の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗褐色が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗褐色という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗褐色についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗褐色は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗褐色が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗褐色は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗褐色の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗褐色は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗褐色は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暗褐色に赤に横縞のあるアンクル・サックス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗褐色の髪を振り分けに編んだ小さなギリシャ型の頭や、情熱の泉のような菫色をした瞳、それに薔薇の葩の如き唇、ドリアンは泪のために娘の顔が見分け難くなる程感動した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "「背景は例の暗褐色。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗褐色のぬらりとしたものが、わずかに見えた。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家は道路に面して鉄柵を張った前庭を置き暗褐色のどっしりした玄関が冷淡に控えて居るが、一寸横へ廻って見ると、この邸内は斜めに奥へ拡がり、四季咲きの紅白の蔓薔薇に取り囲まれた二百坪ばかりの緑の芝生の裏庭に向う室は軽快なサンルームとなって、通りすがりの男女にちょっと盗見したい気持を起させる。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒野に蔽われた田園は、今ちょうど満開のハリエニシダの花が、方々に叢り咲いていて、ロンドンの暗褐色黄褐色、――石板灰色に、あきあきしている目には、とても素晴らしいものに見えた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に、窓の方に寄りて坐りたるは、暗褐色の粗服したる媼なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗褐色なる雙脚には靴を穿かず、剪らざる髮は黒き面の邊に翻り垂れたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう云つて友達の出したのは、キユヰエエの著書で、東印度諸島に産する、暗褐色の毛をした猩々の解剖学的記述である。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘴は浅緑色、羽は暗褐色に淡褐色の斑点、長い足は美しい浅緑色をしていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風雨年月の洗礼を受け城壁のような岩の壁は暗褐色に色を変え、所々に灌木が生えている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとでもさはつたなら、ぼろぼろにくだけてしまひさうな、暗褐色の長上衣、両の肩へ垂れ下つてゐる苧屑のやうな長い黒髪、日焦けのした素足にぢかにはいた半靴――さうしたものがすべて彼の身について、その人柄を形づくつてゐるやうに見えた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "象牙の篦を結び付けた暗褐色の紐を解いて巻物をすこしばかり開くと、紫黒色の紙に金絵具で、右上から左下へ波紋を作って流れて行く水が描いてあるが、非常に優雅な筆致に見えた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、全身を覆う暗褐色の毛、丈は四フィートあるかなしかで子供のようであり、さらに一尺ほどの尾が薦骨のあたりからでている。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い斑点の中に赤黒い蝙蝠――盤得尼全部暗褐色の瓢箪――寂蓮尼真黒な英仏海峡附近の地図――智凡尼普光尼は答えず。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも抜群の色彩家ではあるが、前者は暗褐色の主調を最後まで守り通しており、後者は赤赤とした鮮明な絵の具を吝みなくぬたくり附けて、途方もなく大きなカンヴァスの上にはちきれそうな肉体を無数に列べ立てて居る。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちを案内してくれたカルコーン君は、画面の中央前方に暗褐色のびろうどの上衣を着て右手に杖を持ち左手をひろげて前にさし出した大尉フランス・バニング・コックを指ざして、どうです、あの手は画面から外へ突き出してるじゃありませんか？",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の暗褐色の樫の骨組を白堊の壁の上にむきだして、ストラトフォドで見た同種の樣式よりは少し田舍臭くせせこましく出來てるが、一階よりも二階、二階よりも三階と、上に行くだけ往來の方へ張り出して、屋根にはアティクになつた三階の窓の一つ一つを圍つた小さい破風が四つほど竝んでるのも古風でよい。",
              "citation": {
                "source": "ウォリクの城",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見れば、暗褐色のうねうねとした一列だったが、それが、劒をかずぎ背嚢を荷った兵士の縦列で、ところどころに、隊側についてる将校の剣が、きらりきらりと光っていた。",
              "citation": {
                "source": "丘の上",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃緑色と暗褐色のだんだらに塗られた、西瓜のお化けのような「魔の空間」だった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬羽は、耳羽だけに暗褐色の斑点があって美しい。",
              "citation": {
                "source": "みやこ鳥",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄いろい皮膚は、下の筋肉や動脈のはたらきを紙一重で蔽っていたし、髪の毛は艶やかに黒くてふさふさしており、歯は真珠色がかった白であったが、こういうものがりっぱなだけに、暗褐色を帯びた白の眼窩とほとんど同じように見えるどんよりした眼や、しなびた肌や、一文字に結んだどす黒い唇と、恐ろしい対照をなしていた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の間敢て霜にも雪にもメゲズ平たく地面にへばりついてその深く羽裂せる根生葉を四方に拡げ、日当りのよい処に生えている者は暗褐色を呈しているが日蔭げの場処に在る者は緑色である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暗褐色の捲毛は長くかつゆるやかに垂れていた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の花が球形の繖房花を形成し、腋生しならびに枝頭に密集してひらき、初めは橙黄色だが次第に紅を潮しついに赤色に変じ一花叢のうち両色交ごも相雑わり、これが暗褐色の枝条ならびに深緑色な葉に映じて美麗な色采を見せている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山地｜向陽の草中に野生し、オニユリのごとき丹赤色の花が咲き、暗褐色の斑点がある。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根山上千｜米の蘆ノ湖から目の下の河口まで直流してくる暗褐色の洪水が、太平洋の水面より四五米の余も高く、巨大な直線の防波堤となって、一｜哩も遠く海中に突入しているのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋の荒波が、この水の防波堤につきよせ、ぶつかり、噴騰するが、暗褐色の直流する水勢の凄さは、海の荒波の如きは、なんの抵抗にもならないのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒波のさわぎを眼下にしたがえて、暗褐色の一直線の水流は海面上数米の高さにモックリとはるか水平線に向って長蛇の如くに突入している。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
