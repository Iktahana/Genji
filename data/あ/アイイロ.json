    "definitions": [
      {
        "index": 1,
        "gloss": "indigo blue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、藍色は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは藍色が重要です。",
              "source": "幻辞"
            },
            {
              "text": "藍色に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では藍色が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で藍色について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から藍色についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では藍色について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では藍色が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では藍色が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に藍色は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において藍色は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に藍色を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に藍色をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で藍色が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、藍色の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は藍色を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は藍色に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で藍色について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から藍色は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは藍色を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "西の方には木曾御嶽が、緩斜の裾を引いて、腰以下を雲の波で洗わせている、乗鞍岳は、純藍色に冴えかえり、その白銀の筋は、たった今落ちたばかりの、新雪ででもあるかのように、釉薬をかけた色をして、鮮やかに光っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本市で汽車を下りたが、青々とした山で、方々を囲まれていて、雲がむくむくと、その上におい冠ぶさっている、山の頂は濃厚な水蒸気の群れから、二、三尺も離れて、その間に冴えた空が、澄んだ水でも湛えたように、冷たい藍色をしている、そこから秋の風が、すいすいと吹き落して来そうである。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がすっきりと霽れて、前には笠ヶ岳の大尾根が、赭っちゃけた紅殻色の膚をあらわし、小笠から大笠へと兀々とした瘤が、その肩へ隆起している、遠くの空に、加賀の白山は、いつもの冷たい藍色に冴えて、雪の縞が、むしろ植物性の白い色をおもわせる。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは宝永の噴火口で、雪が実際は消えていないのであるが、火口壁の陰影で、藍色に見えるのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "はんてんか上つぱりにし度いやうな細い縞が藍色がゝつたサラサ模様であつたやうです。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色の影をつくる腋の下に魅力を感じて立あがると、藍色のアブサン酒を彼女のグラスに注いだ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間私が青い窓から近東の藍色の空を眺めていると電流にのってアダがあらわれてきて、私の夜会服に一輸のネムの花をさすのであるが、忽ち私には彼女がマルセーユの金羊毛酒場の素足の美しい踊姿となって女の耳元で、おい、Ｙ、今晩おれにつきあえよ、と囁く追想の女となるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　孟買埠頭の藍色の海に室蘭丸が碇泊していた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑札のない女たちも、新貨幣のおかげで夜の脇腹から彼女の蠱しい横顔を藍色の夜にあらわした。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹の皮のはられた藍色の壁に向って、スモオキングを着た男たちが、自分の影にむかって挨拶をしていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　摩天楼の鏡の面からつやぶきんをとるために、私は、藍色のカーテンで市街に向ってひらいた窓を閉ざすと、「――それよりか、君のコオセット・ボタンがいくつあるか計算さしてもらいたいもんだね。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍色の帽子をかむっている若者が、何か口をさしはさんだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄藍色の着物が血で、どす黒くなった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い封蝋細工のほおの木の芽が、風に吹かれてピッカリピッカリと光り、林の中の雪には藍色の木の影がいちめん網になって落ちて日光のあたる所には銀の百合が咲いたように見えました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い藍色に煙りあがったこの季節の空は、そのとき、見れば見るほどただ闇としか私には感覚できなかったのである。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまたみんな申し合わせたように眉毛をきれいに剃り落としてそのあとに藍色の影がただよっていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さて雲のみねは全くくづれ、あたりは藍色になりました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さて雲のみねは全くくずれ、あたりは藍色になりました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍色の空には、白く光る雲が、糸のように流れているばかり…………崖の下には、真青く、真白く渦捲きどよめく波の間を、遊び戯れているフカの尻尾やヒレが、時々ヒラヒラと見えているだけです。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟を考えよう考えようとしたが、自分の両足の下の藍色の絨緞と、その上に散乱した料理や皿の平面が、前後左右にユラリユラリと傾きまわるばっかりで、どうしても考えを纏めることが出来なかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空を藍色に見せ、夕日を黄金色に沈ませ、都大路の色硝子に曇って、文明の悲哀を匂わせる。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾個かの皿すでに洗いおわりて傍らに重ね、今しも洗う大皿は特に心を用うるさまに見ゆるは雪白なるに藍色の縁とりし品なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあの透きとおるような海の藍色と、白い帆前船などの水際近くに塗ってある洋紅色とは、僕の持っている絵具ではどうしてもうまく出せませんでした。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の癖眞身に彼れの心の戸を敲くものがあると、思ひがけない藍色の悲哀がふいと顏を出す樣な事もあつた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の影が渚を打って、ひたひたと薄く被さる、藍色の西洋館の棟高く、二、三羽｜鳩が羽をのして、ゆるく手巾を掉り動かす状であった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五　さて半時ばかりの後、散策子の姿は、一人、彼処から鳩の舞うのを見た、浜辺の藍色の西洋館の傍なる、砂山の上に顕れた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い封蝋細工のほほの木の芽が、風に吹かれてピッカリピッカリと光り、林の中の雪には藍色の木の影がいちめん網になって落ちて日光のあたる所には銀の百合が咲いたやうに見えました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧も薄し、こちらからは吃驚するほど、大きく見た、が、澄切った藍色の空を遥に来たように、その胸から上半分の娘の方は、さも深そうに下の墓を覗いて、帽子を転がして、ぼんやりうつむいている多津吉を打撞ったように見ると、眉はきりりとしたが優しい目を、驚いた様に※りながら、後退りになって隠れたが。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　だのに、それから、十歩、二十歩とはまだ隔らないうちに、目の下の城下に火が起った――こういうと記録じみる――一眸の下に瞰下ろさるる、縦横に樹林で劃られた市街の一箇処が、あたかも魔の手のあって、森の一束を蒼空へ引上げたような煙が濛々と揚って、流るる藍色の川を切って暗くした。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古女房は、くたびれた藍色の半纏に、茶の着もので、紺足袋に雪駄穿で居たのである。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
