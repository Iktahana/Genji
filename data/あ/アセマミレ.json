          ],
          "literary": [
            {
              "text": "顏や首から油汗がねつとり滲み出てゐたが、手拭を忘れて來てゐたので、と云つても洋服の汚れた袖で拭くのはなほのこと氣味がわるく、私はやけ氣味に汗まみれであるいてゐた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷包の中には一枚の着がえがあり、床の上には汗まみれになった道中着と脚絆、股引、それから江戸下谷長者町小八という菅笠があった。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内ふところがそれ汗まみれだろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその取付きの百姓家の蔭から、田に添うた桑畑の若い葉の間を、女と並行した方向に曲り込むと、急に身を伏せて、獲物を狙う獣のように、線路の方へ走り出したが、桑畑と線路との境目に在る、狭い小川を飛び越えた時には、スッカリ汗まみれになって、動悸が高まって、眼が眩みそうになっていた。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "年増まじりにあくどく化粧った少い女が六七人、汗まみれになって、ついそこへ、並木を来かかる。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は洗ったように汗まみれになった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船長は寒くて、二人は汗まみれになって、日本波止場へついた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこへいくの」　先生は、汗まみれの慶一にほほえみかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "29きみが別れを告げていたことにどうして気がつかなかったんだろう〈レッド・ラバー・ボール〉サークル　開け放ったドアから射しこむ強い陽光に、慶一は汗まみれになって目覚めた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗まみれのすがたは見せたくない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はすぐ身体中汗まみれになった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、その高地を崩していた土方は、まるで熱いお湯から飛びだしてきたように汗まみれになり、フラフラになっていた。",
              "citation": {
                "source": "人を殺す犬",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い日々が夜毎、夜毎の逃亡にはじまる「ある女の生涯」という小説が、ふと、汗まみれの正三の頭には浮ぶのであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い日々が夜毎、夜毎の逃亡にはじまる「ある女の生涯」といふ小説が、ふと、汗まみれの正三の頭には浮ぶのであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はそれから約二十分ばかりして眼を開きますと、最寄りの丸の内綜合病院に運び込まれて看護婦の手当を受けている事に気付きましたが、その中に汗まみれになって這入って参りました樫尾は、看護婦に用を云い付けて追い出しました隙に、妾の耳に口を寄せてこのような事を囁きました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗まみれになった自分の髪毛を房々に撫で上げながら、赤ちゃんをあやすように言って聞かせた。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いずれこの事件の恐竜は、鎖の輪から爪を引き抜くことが、できなくなってしまうでしょう」　汗まみれになった旗太郎には、このわずかな間に、胆汁が全身に溢れ出たのではないかと思われた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年探偵の三浦三吉は、今しも外出先から汗まみれになって帰って来たところだ。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくざつないろいろな器械にとりまかれた司令室で汗まみれになって、次々に号令を下していた艇長辻中佐は、三郎の持って来た思いがけない好物の飲物をうけとって、たいへんよろこんだ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その血まみれ汗まみれの勞苦によつて到達せむとする究竟の境地は、物と遊ぶの歡喜である。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は洋食だというと、一中隊から大貫が呼びだされ、カツだ、シチュウだと思い思いの注文に応じて、出もせぬ智慧を総動員して、汗まみれになって調理に精根を枯らす。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがギルマンを冷汗まみれにしたのは二人の通行人の話だった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗まみれになっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……作った詩を書くために、汗まみれになって起き上がった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏を終えると、汗まみれになってぐったりしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、冷汗まみれの奴の顔をみて、ムーアは自分の恐怖心を恥じた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "人影は恐怖で真っ青に引きつった汗まみれのチャンだった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて十太夫は汗まみれになり、肩で息をしながら竹刀をおろす。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、例によって汗まみれの稽古着である。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
