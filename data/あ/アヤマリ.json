        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日誤りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "誤りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は誤りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には誤りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "誤りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは誤りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "誤りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は誤りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では誤りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "誤りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に誤りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では誤りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "誤りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると誤りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "誤りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では誤りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に誤りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により誤りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "誤りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に誤りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "男　あゝさうだつた、これは俺の誤り。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時これ金と云えばこの四時間何金に当るや知らねどあくびと煙草の煙に消すも残念なり、いざや人物の観察にても始めんと目を見開けば隣りに腰かけし印半天の煙草の火を借らんとて誤りて我が手に火を落しあわてて引きのけたる我がさまの吾ながら可笑しければ思わず噴き出す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では展覧会などで見る「高嶺の雪」などいう日本画には、空気を絶したような峻急な高嶺に、綿帽子のように、むやみに雪を盛り上げたのがあるけれども、あれは誤りである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "原因があって結果があると思っていたが、それも誤りらしい。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの二つの公共圏のうち、「上品」および「派手」の属するものは人性的一般存在であり、「いき」および「渋味」の属するものは異性的特殊存在であると断定してもおそらく誤りではなかろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の仕事や学説が九十九まで正鵠を得ていて残る一つが誤っているような場合に、その一つの誤りを自認する事は案外速やかでないものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、無批判的な群小は九十九プロセントの偉大に撃たれて一プロの誤りをも一緒に呑み込んでしまうのが通例である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲某は何々のオーソリチーであるとなれば、その人の所説は神の託宣のように誤りないと思われるのが通例である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万に一つの誤りをも恐るるならばむしろ一切意見の発表を止めねばならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の誤りを教えてならないとなれば世界中の学校教員は悉皆辞職しなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは夏季水道の水を汲んだままで実験していると溶けた空気が出て来て器械に附着し著しい誤りを生ずる事なども実験させた方がよいと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学上の方則には誤りはないはずであっても、これを応用すべき具体的の「場合」の前提とすべき与件の判定は往々にして純正物理学の範囲を超越する。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の方でもいつまで児供と思っていたが誤りで、自分が悪かったという様な考えに今夜はなったのであろう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍麿の研究によると、奈良朝におけるあらゆる万葉仮名は八十五類にわかれることになるのでありますが、これにはすこし誤りがあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、どちらを使ってもよいというのではなく、どちらかが誤りでなければなりませぬ。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーはレニョーの実験における浮力の補正に誤りのあることに気付いたので、もう一度詳しくやり直す必要を感じたのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに近代の多数の南画家の展覧会などに出した作品例えば御定まりの青緑山水のごときものを見ると、山の形、水の流れ、一草一木の細に至るまで実に一点の誤りもない規則ずくめに出来ている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不都合をなくするには陸上の天文台で定めた正確な時刻を無線電信で海上の船に毎朝報じ時計の誤りを正すようにすればよいというので、今度カナダ政府ではこれを実行する事になったそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふにこの事件は、室生君が卓の遠く離れた地位に居た爲に、私と岡本君との問答してゐる光景を見て、何か私が不當の暴行でも受けてゐるやうに見誤り、友人の一大事として決死的に突進して來たのである。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも私には彼等が誤りを犯してゐるのがよく解つてはゐますけれど、――それだのに、私は彼等に私の經驗の若干を――私の長びいてゐる孤獨の果實の二三を知らせてやらうとしてゐるのです、（そしてそれが虚榮からだとは私は信じませぬ！",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく詩人といふものを誤りなく見ようとするならば一切の運命の外に立たせなければならない。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助十二歳の時、子供らと海に遊び、誤りて溺れしを、見てありし子供ら、畏れ逃げてこの事を人に告げざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの仮説が誤りであって「無駄のない有益なものが可能であり、それが当然である」とすると、無駄は罪悪でないまでも不当然であり不都合である。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またよき人の説ならんからに多くの中には誤りもなどかなからん。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこういう学説が一朝にしてくつがえされ、またそのために創設者の偉さが一時に消滅するような事が可能だと思う人があれば、それはおそらく科学というものの本質に対する根本的の誤解から生じた誤りであろう。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし記憶の誤りでなければ、このジャンの音響とともに「水面にさざ波が立つ」という事が上記の記載に付加されていた。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の読み得たところが誤りでなければ、彼のいわゆる心は脳に相当し、精神は全身に広がれる知覚ならびに運動神経に相当するように見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体の元子と精神の元子とが一つずつ対になっているというデモクリトスの説は誤りである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして対者につつしんであやまります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは大しくじり、あやまりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
