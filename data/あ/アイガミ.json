    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indigo-dyed paper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、藍紙は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは藍紙が重要です。",
              "source": "幻辞"
            },
            {
              "text": "藍紙に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では藍紙が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で藍紙について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から藍紙についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では藍紙について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では藍紙が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では藍紙が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に藍紙は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において藍紙は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に藍紙を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に藍紙をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で藍紙が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、藍紙の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は藍紙を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は藍紙に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で藍紙について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から藍紙は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは藍紙を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第一図の如く、蛇の目傘の様な形で、外囲りは藍紙、中囲りは赤紙、内廻りは亦藍紙を張つてゐる。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外囲りの藍紙は、内の紙の倍の長さに作る。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は明治四十五年七月十一日、東京帝國大學卒業式に臨幸あらせられし際、余は親しく御前に於いて元暦校本萬葉集、藍紙本萬葉集等に就いての御説明を申上ぐるの榮譽を擔へり。",
              "citation": {
                "source": "芳賀博士",
                "author": "佐佐木信綱",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
