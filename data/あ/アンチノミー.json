        "examples": {
          "standard": [
            {
              "text": "私は毎日アンチノミーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンチノミーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンチノミーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンチノミーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンチノミーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンチノミーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンチノミーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンチノミーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンチノミーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンチノミーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンチノミーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンチノミーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンチノミーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンチノミーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "カントはベーコンのこの自然への問いかけとしての実験的方法に敬意を表し、批判の方法をそれによって構成し、その実験結果としてアンチノミーを導きそこに認識の限界を見いだすと共にその一般を擁護したのである（『純粋理性批判』第二版序文）。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実験でアンチノミーが導かるる過程の中にすでに弁証法へのアリアドネの糸が見いださるると共に、ここにすでに単なる自然科学的経験以外の存在論的現象論への道が展かれているかに思われる。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるブルジョワジーとは一つのアンチノミーである。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的歴史的過程において事実存在するがゆえに、そのアンチノミーは弁証法的とよばれもする。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる喘ぎにおける呼吸が、人間なる無限なるアンチノミー的構造を見透す重き歩みでもある。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョアジーとは個人の発見と個人の自己解消なる二元的アンチノミー的概念を意味する。",
              "citation": {
                "source": "壁",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "画布がみずから独立すること、それを多くの人々に観照せしめることを要求することの中には同様にすでに一つのアンチノミーを胎んでいる。",
              "citation": {
                "source": "壁",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし之を客体である物自身の性質とすれば、世界が有限であると論証することが出来ると同じ権利で、人々は又それが無限であることをも論証出来るだろうし、世界が無限に分割出来ると証明出来ると同時に、人々は又夫が不可分の単位を持っていると証明することも出来るだろう（之がアンチノミーに相当する）。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
