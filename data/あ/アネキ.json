    "definitions": [
      {
        "index": 1,
        "gloss": "elder sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉貴について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉貴という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉貴の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉貴が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉貴を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉貴について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉貴の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉貴の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉貴が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉貴という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉貴という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉貴についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉貴を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉貴は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉貴について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉貴が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉貴は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉貴の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉貴は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉貴は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "始終「姉貴姉貴」といつて、何事でも彼女の賛同なしには行らないといつた風だつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度洋食屋を新しく始めるについても、伯父は先づ彼の「姉貴」に相談し、その賛同を得、且つその資金の幾分かをも、彼女の斡旋によつて得たのであつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の酒飲むことは、姉貴も薄々知つてるが、店も忙しいし、福造のこともあつて、むしやくしやするやらうと思うて、黙つてるんやらうが、あんまり大酒飲まん方がえゝで。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の酒飮むことは、姉貴も薄々知つてるが、店も忙しいし、福造のこともあつて、むしやくしやするやらうと思うて、默つてるんやらうが、あんまり大酒飮まん方がえゝで。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
