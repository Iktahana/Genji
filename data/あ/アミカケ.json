    "definitions": [
      {
        "index": 1,
        "gloss": "area fill (in printing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網掛けについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "網掛けという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網掛けの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網掛けが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網掛けを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網掛けについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "網掛けの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網掛けの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網掛けが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網掛けという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網掛けという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網掛けについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網掛けを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網掛けは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網掛けについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網掛けが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網掛けは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網掛けの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網掛けは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網掛けは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さまざまな書き味の絵筆をマウスで操作し、気に入らないところがあれば画面上で自由に修正を加え、好みのパターンを選んで網掛け処理を行う――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさも下から黒と赤の混ざったスコッチの赤坊靴下のあみかけをもって来て編みはじめた。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛糸のショールの残り糸から、あみかけのレースの花瓶しきまで、こまごまと一つのふろしきにまとめて入っていたりする。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
