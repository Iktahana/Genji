        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安全剃刀について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全剃刀の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全剃刀が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全剃刀について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全剃刀の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全剃刀が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全剃刀という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全剃刀についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全剃刀は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全剃刀が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全剃刀は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全剃刀の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全剃刀は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全剃刀は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どうして俺が毎晩家へ帰って来る道で、俺の部屋の数ある道具のうちの、選りに選ってちっぽけな薄っぺらいもの、安全剃刀の刃なんぞが、千里眼のように思い浮かんで来るのか――おまえはそれがわからないと言ったが――そして俺にもやはりそれがわからないのだが――それもこれもやっぱり同じようなことにちがいない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは剃刀が切れ味があまりよくなくて少し痛かったせいもあるが、それまで一度も安全剃刀というものの体験をもたなかったためにそれがたいそう珍しく新しく感じられたせいもあるらしい。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、もし自分の留学後だったらバン・フーテンや安全剃刀にも別に驚かなかったはずであるから、それでこの三原山生活の年代の決定が確実にできたわけである。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午過ぎ、やっと客が来て安全剃刀の替刃一枚六銭の売上げという情けないありさまだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀、レザー、ナイフ、ジャッキその他理髪に関係ある品物を商っているのだから、やはり理髪店相手の化粧品を商っていた柳吉には、いちばん適しているだろうと骨折ってくれた、その手前もあった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曰く、仕事は楽で、安全剃刀の広告人形がしきりに身体を動かして剃刀をといでいる恰好が面白いとて飾窓に吸いつけられる客があると、出て行って、おいでやす。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい破片は抱き上げられない位のものもあり、小さいのは安全剃刀の刃位のものまでも、水面に射込んだ。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に私が、偶然に、安全剃刀の刃を用意しておりましたのは、これこそ一つの奇蹟だったかも知れません。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタガタする車体の中で、メチャメチャに燥いでお出でになった三人は、私が安全剃刀の刃で、後窓の周囲をＵの字型に切抜くのをチットモお気付きになりませんでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たくさんの参考文献や、そのほか灰皿や歯ブラシや安全剃刀などという生活に必要ないろいろな品物も入っている。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はニューブリテン島のラバウル港で、海の中に安全剃刀の刄を落してしばしば樂んだ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷に立つて安全剃刀の刄をぽとんと海に落すのである、さうするとその安全剃刀の刄は白く光つて海面に落ちてからそのまゝ靜かに海中へ沈んでいく、それが何時までもいつまでもきらきらと銀色に光つて見えてゐるのだ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラバウル附近は相當水深があるのであるが、安全剃刀の刄はなかなか底に達しない、私は時計を出して時間を計つたことがあつたけれども、安全剃刀の刄が見えなくなるまでとても時計を見てゐるのが退屈になつたほどである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍医は安全剃刀で剃りあげたばかしの綺麗な頤を撫でまはしながら、自分の前に立つてゐる一人の応募兵の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊取線香、靴篦、歯ブラシ、征露丸、梅肉エキス、蚤とり粉、毛筆、紙挟み、殆ど使用に堪へさうもない安全剃刀、パイプなど畳一杯に展げられてゐたが、ゲートル、帽子、雑嚢などになると、一層奇妙なものが多かつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず柳江の書斎にある柱時計の長針と短針とに、安全剃刀の刃を一定の位置に貼り付けて置いたのだ。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀にしろ石鹸にしろ、自分のは自分一人だけで使いたく、他人に使われるのが嫌だし、他人のを使うのが嫌だ。",
              "citation": {
                "source": "私の信条",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭いナイフ……安全剃刀の刄……アドルムの錠剤……オキシフル……絆創膏……繃帯……。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから身を起して、安全剃刀の刄を取った。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、僕との対談のうちに、安全｜剃刀の柄をくわえた――と見えたが、それから煙が出てくるところを見ると、それは安全剃刀ではなくて、どうやら煙草のパイプの類らしいことが分った。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ボロボロのスリッパ、安全剃刀の刃、煙草の銀紙等を、ひとつひとつ、つまみ上げ――どれもこれも、捨てていゝやうなものばかりだわ……。",
              "citation": {
                "source": "モノロオグ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は僕自身も、二十数年間来、毎朝鬚を剃る習慣であったが、逃避行の間に乃木大将みたいに鬚が生え、収容所でもその癖がついて、剃刀（安全剃刀は持っていても差支えなかった）を使うことが、ひどく億劫になってしまった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に何処をどう改良したというのでもなく、依然として安全剃刀の刃を手に持って切っているだけなのであるが、切れてさえくれればそんな詮索をするまでのこともない。",
              "citation": {
                "source": "雪雑記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀のどこかが工合が悪くなつたのをなほしてゐるのである。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀のなかつた時代、亭主が度々｜髮結床へ行つて、將棋を指してばかり居られなかつた社會の、それは親しみ深い、つゝましやかな風景の一つだつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀がないの、不図思いついて、いつかの行李の袋に入って来たのを思い出し、ひとにやるのは私いやですが、達ちゃんだからお下りを特別の思召で使わしてやろうと思って送りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全剃刀でガリ／＼やる。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も姉崎夫人の化粧台と書生の机の抽斗とから剃刀が発見されはしたけれど、それは両方とも殺人の兇器としては使用出来｜相もない安全剃刀であって、替刃にも別段の異状を認めることは出来なかった。",
              "citation": {
                "source": "悪霊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
