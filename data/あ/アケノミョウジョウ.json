        "examples": {
          "standard": [
            {
              "text": "明けの明星の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「奴等を退治して、明けの明星が沈まうとする暁どきに戦勝の船出をいたすのはさぞかし心地好いことであらうな。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けの明星の空に寒くかゞやく頃には、かれはいつももう起きてゐた。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けの明星のひかり、一番電車のひゞき、人の足音、水汲む音、――朝の天地は尊くも美しい。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜明けの明星とともにやっと彼の厩に帰るが、そのまま休みも眠りもしないでふたたび旅立つ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は夜明けの明星にすぎない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "常念岳の肩に、明けの明星が一段と光をますと、一晩中飛んでいたこうもりも姿を消した。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けの明星が立ちあがって、女の子にひよこの足を一本くれました。",
              "citation": {
                "source": "七羽のカラス",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上は薄桃色に染まり、明けの明星が朝ぼらけにちらついている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上には明けの明星が耀き、城の上階ではランプが一灯ちらついている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
