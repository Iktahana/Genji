        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラスカについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラスカという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラスカの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラスカが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラスカを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラスカについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラスカの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラスカの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラスカが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラスカという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラスカという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラスカについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラスカを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラスカは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラスカについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラスカが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラスカは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラスカの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラスカは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラスカは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この内ほとんど三分の一はアフリカの南部から、また四分の一は北米合衆国およびアラスカから出たのだそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は毛皮を一杯に着込んで、二人前の席をとり、アラスカ金の大きな指環をはめ、十連発のぴかぴかする素敵な鉄砲を持つていかにも元気さう、声もきつとよほどがらがらしてゐるにちがひないと思はれたのです。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談じゃないや、アラスカなんか行くとこはありゃしない。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "43　船は進路を誤って、アラスカへ着いたのであった。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "否応なく私も続くより他はなかつたが、アラスカの吹雪の中へでも飛び出したやうに、もう愚痴をいふいとまもなく、思はず羽織の裾を達磨のかたちに逆に頭からかむると、巾着切のやうに素早く横つ飛びに風を切つた――崖下の洞の前まではものゝ三丁もあらうかといふ距離であつたが、私達は夢中の風に乗つて一気に到着した。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チヤツプリンの「黄金狂時代」を見た人は、あのアラスカの大吹雪を思い出すことが出来る、あれとそのまゝが北海道の冬である。",
              "citation": {
                "source": "北海道の「俊寛」",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和通りの露地にあるアラスカの山の名前をとつた酒場である其処のスターであるお光さんは私が作る叙情詩の愛誦者である。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーリング海峡を距てて北アメリカのアラスカに対しているそうだ。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーリング海峡を距てて右の方を見ると、そこに海亀の頭のようなアラスカの突端が鼻を突合したように迫っていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカのウェールス岬がどうしたというのだ。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等一党はアラスカを放浪せんよりも、命の片々をポートマク河の吹雪と希ひしが本来の誓ひならざりしや。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠太郎は、代助の坐る大きな椅子に腰を掛けて、洋卓の前で、アラスカ探検記を読んでゐた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誠太郎、何だい、人のゐない留守に来て、御馳走だね」と云ふと、誠太郎は、笑ひながら、先づアラスカ探検記をポツケツトへ押し込んで、席を立つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "新式タービンのパリパリが、ビスケー湾の檜舞台でヘタバッたり、アラスカ沖の難航で、陸地が鼻の先に見えながら、石炭が足りなくなったりする。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だから今度はこのアラスカ丸が危えってんで、大変な評判ですがね。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで小僧はエムプレス・チャイナの給仕服のまま生命辛々の手提籠一個を抱えて税関の石垣の上でワイワイ泣いているのを、チャイナ号の向い合わせに繋留っていたアラスカ丸の船長……貴下が発見て拾い上げた……チャイナ号へ面当みたいに小僧の頭を撫でて、慰め慰め拾い上げて行った……という話なんです。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカ丸の船長はそんな曰く因縁、故事来歴附の小僧だって事を、知って拾ったんだか……どうだかってんでね。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "非道い奴はアラスカ丸が日本に着くまでに沈むか、沈まないかって賭をしている奴なんか居るんですぜ」　俺は元来デリケートに出来た人間じゃない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に厚硝子張、樫材の固定薬品棚、書類、ビーカー、レトルト、精巧な金工器具、銅板、鉛板、亜鉛板、各種の針金、酸水素｜瓦斯筒、電気｜鎔接機、天秤、バロメータなんぞが歯医者か理髪店の片隅みたいにゴチャゴチャと重なり合っている……というのがこのアラスカ丸の船長室なんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は脱線するがこのアラスカ丸の船長はむろん独身生活者で、女も酒も嫌いなんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな訳で、風前の燈火みたような小僧の生命を乗せたアラスカ丸が、無事に上海を出た。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にアラスカ近海の難航海に堪え得るだけの食料や石炭を、船が割れる程｜突込む訳だが、その作業は平生の通り二三日がかりで遣るのでさえ相当｜忙しいのに、向岸の晩香坡から突然に大至急｜云々の電報が来て、二十四時間以内の出帆という事になったので、その忙がしさといったら話にならない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ今度のアラスカまわりみたいな難航路になると必要以上の石炭を積んでおかないとドンナ海難にぶつかって、どこへ流されるかわからないので、楕円形の船の胴体と、四角い部屋部屋が交錯して作っているあらゆる狭い、人間の通れないような歪み曲った空隙に石炭をギッシリと詰め込まなければならない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカ沿岸を洗う暖流に乗り込んだのだ……と思ったのでホッとして万年｜寝床の中に起上った。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船に乗ってアラスカ近海へ廻わった経験のある人間でなければ、あの近海の波の大きさと、恐ろしさはチョット見当が付きかねるだろう。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカ丸は七千｜噸だから荷物船では第一級の大型だったが、たとい七千噸が七万噸でもあの波に引っかかったら木っ葉も同然だ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカ丸は、それから何の故障もなくスラスラと晩香坡へ着いた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その桟橋の上に群がっている人間は、五日ほど遅れて着いたアラスカ丸をどうしたのかと気づかって、待ちかねていた連中なんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、丁度ワシントン会議のあったころで、徳川公爵や、加藤友三郎大将の両全権が、鹿島丸でアラスカの沖を通っている時に、日本からの無電は白蓮事件をつたえ、乗組の客はみんな緊張して、すさまじい論戦が戦わされた。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢村さんは満洲へ、松山さんはジャワヘ、森さんは北支、七番の坂本さんはアラスカヘと皆どこかへ行ってしまった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
