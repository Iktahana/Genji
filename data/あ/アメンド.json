        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメンドについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメンドという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメンドの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメンドが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメンドを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメンドについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメンドの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメンドの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメンドが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメンドという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメンドという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメンドについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメンドを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメンドは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメンドについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメンドが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメンドは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメンドの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメンドは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメンドは興味深い例である。",
              "source": "幻辞"
            }
          ],
