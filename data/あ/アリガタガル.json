    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be thankful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り難がるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り難がるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り難がるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り難がるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り難がるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り難がるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り難がるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り難がるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り難がるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り難がるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り難がるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り難がるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り難がるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り難がるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "年忌の法会などならばその人を思ひ出すとか、今に幻に見ゆるとか、年月の立つのは早いものとか、彼人が死でから外に友がないとか、涙ながら霊を祭るとかいふ陳腐なる考を有り難がるも常人ならば詮方なきも、文学者たらん者は今少し考へあるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが陽気な語らいが広まり、面白いことにふざけて尊敬するものだから、心から有り難がる始末だ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　誠にありがたがるくらゐでは足りないのである。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と我れとの相違は、いわば十露盤の桁が違っているだけで、喜助のありがたがる二百｜文に相当する貯蓄だに、こっちはないのである。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家などいう連中には、骨董などをいじくって古味というようなものをありがたがる風流人と共通したような気取りがある。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだい、今度の日曜あたり、ちっとやって来ないかね、うまいすっぽんが来ているのだがね」　こうしたお言葉だけをいただくと、周囲の人々は恐縮してありがたがるのだろうと思うのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり喜劇に諷刺があるのは、あるべきものがあるべきところにあるというだけの話で別にありがたがるにはおよばんではないかというのである。",
              "citation": {
                "source": "ルネ・クレール私見",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……金がありがたいのではない、金をありがたがるのではない、物が、物そのものがありがたいのだ、物を造つた者をありがたがるのだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんな単純な場合では解脱にもなりますまいが、まあ例ですからそのつもりで御聞きを願います）それで読む人はありがたがる。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、却つてまたそんな俗習家に限つて、禪など云ふ、義雄が催眠術の一種に過ぎないと不斷罵倒してゐる工風を、この上もなくありがたがるものだと見ると、馬鹿にして見たくもなる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想といふものは、生その物なる主義とは違つて、さうありがたがるべきものでないこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も回教徒のアラビア人がそれをありがたがるのはどういう解釈だか聞き洩らしたが。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が朝晩赤ちゃんの守をするのを何んぼありがたがるんだか、昨日なんか涙をうかべていらっしゃるので、私恐縮してしまひました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ人たちが、とかく役持ちをありがたがる。",
              "citation": {
                "source": "大學とその總長",
                "author": "會津八一",
                "note": "青空文庫"
              }
            },
            {
              "text": "名まで覚えてありがたがるほどの歌人は稀にしかいないものだ。",
              "citation": {
                "source": "梅にうぐいす",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な坊主が地方を巡回すると、その入浴した湯を竹筒に貰うてありがたがるという話を聞いたが、およそ階級本能の退化せぬ人は上の等級の者と幾分かでも関係することがありがたくて堪らず、せめてはその肉体に触れた湯でも拝もうと思うのであろう。",
              "citation": {
                "source": "人間生活の矛盾",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも宗教なるものは階級本能の全盛であった時代に脳の働きの副産物として生じたもので、神とか仏とか教祖とかを自分の頭の上に戴いてありがたがるのであるから、階級本能の退化した人間にはとうてい信ぜられるものではない。",
              "citation": {
                "source": "人間生活の矛盾",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明のこの社会に生まれながら、昔のものなぞをありがたがるのは、じつにくだらないことだと、彼は簡単に考えたのであります。",
              "citation": {
                "source": "さかずきの輪廻",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "例繰方というのは奉行の下にあって刑律の前例を調べるのが仕事で、割合に格式のある役なのだが、格別ありがたがる風もなく、番所の書庫から赦帳や捕物帳などを山ほど持ち出し、出勤もせずに弓町の乾物屋の二階に寝っころがって、朝から晩までそんなものを読み耽っている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその熱心を聞かせたら、いかな鼻でも少しはありがたがるだろう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は何に寄らずわからぬものをありがたがる癖を有している。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例のものならこの様子でたいていはわかるはずだが、この主人は当世の人間に似合わず、むやみに役人や警察をありがたがる癖がある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の占有は、この方面においては甚だしく意義が薄く、ただ田圃ばかりをありがたがるような気風は、今だってまだ残っている。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであんな物を切支丹に見せたらそれを踏む気はしなくなって、かえってなおありがたがるだろうっていうのよ。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、安価で存在しているものを、なにをもって西洋からしをありがたがるのか。",
              "citation": {
                "source": "日本芥子",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはほかでもない、君のありがたがる自由結婚なんかして、角を生やさせられたり（妻に不貞を働かれること）人の子供を背負い込まされたりするのがいやだからですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際はその正反対で、彼らは明々白々、一見して目に映るような現実を、あきれ返るほど馬鹿げたふうに受けいれて、もうその当時から、ただ成功のみをありがたがる癖がついてしまっていたのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
