    "definitions": [
      {
        "index": 1,
        "gloss": "large brown cicada (Graptopsaltria nigrofuscata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油蝉について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油蝉は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油蝉の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油蝉について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油蝉は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油蝉の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油蝉に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油蝉が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油蝉を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油蝉の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油蝉が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油蝉が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油蝉について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油蝉は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油蝉は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油蝉は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油蝉について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油蝉の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油蝉の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油蝉の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その凝固した空気の中から絞り出されるように油蝉の声が降りそそぐ。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油蝉の暑苦しく鳴いている木の下で、私は厚く礼をいって僧と別れた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この百日紅に油蝉がいっぱいたかって、朝っから晩までしゃあしゃあ鳴くので気が狂いかけました。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには夏草が繁つて居り、油蝉が木立に鳴いて居た。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　導かるるまま、折戸を入ると、そんなに広いと言うではないが、谷間の一軒家と言った形で、三方が高台の森、林に包まれた、ゆっくりした荒れた庭で、むこうに座敷の、縁が涼しく、油蝉の中に閑寂に見えた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に蝕しつつある太陽を、いやが上に蔽い果さんずる修羅の叫喚の物凄く響くがごとく、油蝉の声の山の根に染み入る中に、英臣は荒らかな声して、「発狂人！",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日かげが漸く傾き、油蝉が一しきり鳴きさわいだ。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節はそれるが、その形は、油蝉にも似たのである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腥くさきオゾンのにほひ雫する穂麦のしらみ、今裂けし欅の大木燥るがごと疼くいたでに脂黒くしたたるみぎり、油蝉ぢぢと鳴き立つ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外はいよいよ日盛りになって来たらしく、油蝉の声がそうぞうしく聞えた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それならば他の車室へ引移れば済むことで、わざわざ下車するにも及ぶまいと思いながら、わたしは再び車外へ眼をやると、若い兄妹の姿はもうそこらに見えないで、駅の前の大きい桜に油蝉が暑そうに啼き続けているばかりであった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い風の無い日で、油蝉の声が裏の崖の方から炙りつくやうに聞えてゐた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に調子の高い、ニイニイ蝉の声のような連続的な音が一つ、それから、油蝉の声のような断続する音と、もう一つ、チッチッと一秒に二回ぐらいずつ繰り返される鋭い音と、この三つの音が重なり合って絶え間なく聞こえる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に栗の木に絡んだのは白晝の忘れる程長い間雨戸は閉ぢた儘で、假令油蝉が炒りつけるやうに其處らの木毎にしがみ附いて聲を限りに鳴いたにした處で、凡てが暑さに疲れたやうで寧ろ極めて閑寂な庭を覗いては、葉の陰ながら段々に日に燒けつゝ太りつゝ臀の臍を剥き出してどつしりと枝から垂れ下つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "熬りつける樣な油蝉の聲が彼等の心を撼がしては鼻のつまつたやうなみん／＼蝉の聲が其の心を溶かさうとする。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の油蝉が暑くなれば暑くなる程酷くぢり／＼と熬りつけるのみで、閑寂な村落の端に偶遭うた※弟はかうして只餘所々々しく相對した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の帽子の上の騒音、ああ、それは油蝉のやうにミンミン鳴く。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘や子供達はそれを箱に入れて地に伏せて置いたが、明日見ると、もう立派な蝉になつて、あるものからは油蝉、あるものからつく／″＼法師、あるものからは日暮しといふ風に生れ更つてゐた。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "油蝉の声は御殿の池をめぐる鬱蒼たる木立ちのほうからしみ入るように聞こえていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　油蝉の方言　螢夏の日なかのヂキタリス、釣鐘状に汗つけて光るこころもいとほしや。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　油蝉の方言螢夏の日なかのヂキタリス、釣鐘状に汗つけて光るこころもいとほしや。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その松では油蝉が啼いた。",
              "citation": {
                "source": "夕凪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自然の野生であるか、あるいは隣りの家の所有であるか、そんなこともよく判らなかったが、ともかくも相当の大木で、夏から秋にかけては油蝉やミンミンやカナカナや、あらん限りの蝉が来てそうぞうしく啼いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "油蝉の暑苦しく鳴いている木の下で、わたしは厚く礼を云って僧と別れた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は北の方角へむかって行くのでしたが、途中から陰った空はすっかり剥げてしまって、汽車みちの両側では油蝉の声が熬り付くようにきこえました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し会つたら今後こそは此方こそ思惑通りの饒舌家に変つて、向方が油蝉なら此方はクツワ虫の勢ひで攻め寄せてやらう、などゝ決心した。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蝉最初の声、油蝉も鳴いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あぶらぜみがなき、午後からはひぐらしがないたのでありました。",
              "citation": {
                "source": "おさらい帳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこのあいだまで聞こえていた、あぶらぜみの声がしなくなったと思うと、秋がきました。",
              "citation": {
                "source": "生きぬく力",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の木立で、あぶらぜみの鳴く声がします。",
              "citation": {
                "source": "子供は悲しみを知らず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
