    "definitions": [
      {
        "index": 1,
        "gloss": "alive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アライブについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アライブという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアライブの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアライブが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アライブを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアライブについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アライブの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアライブの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアライブが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アライブという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアライブという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアライブについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アライブを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアライブは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アライブについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアライブが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアライブは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアライブの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アライブは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアライブは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
