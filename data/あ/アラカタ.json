        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗方について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗方という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗方の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗方が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗方を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗方について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗方の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗方の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗方が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗方という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗方という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗方についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗方を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗方は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗方について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗方が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗方は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗方の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗方は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗方は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やつと宿の物音があらかた靜まつた後は、門前のカフエーから蓄音機の奏する流行小唄の甘酸つぱい旋律が流れ出して居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかた葉をふるったぶなの森の中を霧にしめった落葉を踏みしめて歩いた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふの雪はあらかた消えて、松のしたかげや石の段々の隅にだけ、鼠いろして少しづつのこつてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、あらかた茸を取ってしまってお父さんが、「さあ行こう」　と言われますと、姉さんと坊ちゃんが立ち止まって、「まあ、毒茸はみんな憎らしい恰好をしている事ねえ」「ウン、僕が征伐してやろう」　といううちに、片っ端から毒茸共は大きいのも小さいのも根本まで木っ葉微塵に踏み潰されてしまいました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野さんがこの書物を始める時、目次によって内容をあらかた話してくれた時、この章に書いてあるのは、アイルランドのある若い勇ましい愛国者と、その婚約の娘との間に起った実際の出来事だといったので、おぬいにはよけい興味のあるものだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人であらかた画室を片づける。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七人のあたまさえ四斗樽、これがあらかた片附いて、浜へ樽を上げた時、重いつもりで両手をかけて、えい、と腰を切った拍子抜けに、向うへのめって、樽が、ばっちゃん、嘉吉がころり、どんとのめりましたきり、早や死んだも同然。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかた人は分ったが、それとなく音信も聞きたい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早産後妻が病院で死んだこと、そのころから三村本家の人たちの感情がにわかに冷たくなり、自分の気持に僻みというものを初めて経験したこと、郁子の印鑑はもちろん、名義になっている公債や、身につけていた金目の装身具など、誰かいつの間にもって行ったのか、あらかたなくなっていたことも不愉快であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし客はそればかりではなく、松島も気が揉めるので、ここへ出てから二年目、前借もあらかた消えたところで、彼女は思い切って足を洗い、母や弟妹たちと一緒に、やがて湯島に一軒家をもったが、結局それも長くは続かず、松島の商売も赤字つづきで、仕送りも途絶えがちになったので、今度は方嚮をかえ公園へ出た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの結婚も甘美とは行かず、半年もたたぬうちに彼の前生活について、そっちこちで悪い噂が耳に入り、そのうち放浪時代から付き絡っていた、茨城生まれの情婦が現われたりして、彼女が十年働いて溜めた貯金も、あらかたその手切れに引き取されてしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして家具家財はチャンとしているようであるが、その中で唯一つ金庫の蓋が開いて、現金と通い帳が無くなっているようす……その前に男文字の手紙が一通、読みさしのまま放り出してあるのを取り上げて読んでみると、あらかたこんな意味の事が書いてあった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦は引越しにずいぶん馴れているらしく、もうはや、あらかた道具もかたづいていて、床の間には、二三輪のうす赤い花をひらいているぼけの素焼の鉢が飾られていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりも、まず、あらかた焼かれていました。",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち作者の名前として伝わっているのが極めて少数である事……能に盛り込まれている人生観や、宗教観、又は、その文句や脚色にニジミ出している個性や癖なぞに、共通的なにおいがかなり多い事……なぞから、そうした事実があらかた察せられる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫刻のたとえ　能楽は過去現在未来を貫いて、如何なる方面に進化して行きつつあるか……という事は以上述べて来たところに依って、あらかた察せられた事と思う。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり鼻の低い女性でも学問さえすれば鼻が高くなるという……まるで落し話しでありますが、「その人類の文化程度は建築物の高さとあらかた一致する」というのと同じ論法で真面目に伝えられているそうであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし以上述べましただけでも「鼻の表現」は存在するものである、就中その動的表現は意想外に夥しいもので、しかも顔面の表現の中で最も偉大な役割を勤めているものであるという事があらかた御諒解出来たであろう事を信じます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国情というのはあらかた御存じでもありましょうし、この話の筋に必要でもありませんから略しますが、要するに、その当時のスラヴ民族は、上も下も一斉に、皇儲の御誕生を渇望しておりましたので、甚しきに到っては、ビクトリア女皇の皇女である皇后陛下の周囲に、独逸の賄賂を受けている者が居る。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうか、お寺の方は、それで好いとして、料理の方はどうだ、」「それもあらかた定まつてをります、」「呼ぶ人の通知の方も好いんだね、」「十八にしておきました。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲と自分との交渉は洗いざらい考えてみてもまずあらかたこれだけのものに過ぎない。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の楓のはあらかた取り尽くして、他の木のもあさって歩いた。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事の次第はあらかた見当がついた。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、あらかたついてはゆけますが、正直、長さの件だけは――」　と、ここでホームズの差し出したる小さな木切れ。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "サックス・コバーグ広場のことはあらかたわかった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "殘りは爺さんの置土産にしようと思つて買つて來た燒酎をあらかた私は飮んでしまつてゐたので、其頃もまだ充分に醉つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "桃の實",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
