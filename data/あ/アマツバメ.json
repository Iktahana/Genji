[
  {
    "uuid": "49fc9f46-4986-5e18-a5ff-d90e81083a1d",
    "entry": "雨燕",
    "reading": {
      "primary": "あまつばめ",
      "alternatives": [
        "アマツバメ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "swift (any bird of family Apodidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨燕について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨燕という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨燕の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨燕が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨燕を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨燕について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨燕の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨燕の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨燕が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨燕という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨燕という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨燕についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨燕を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨燕は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨燕について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨燕が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨燕は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨燕の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨燕は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨燕は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その頂上は既に湧き上る幾重の雲に包まれ、無数の雨燕が雲の中から舞い落ちる木の葉のように群れ飛んでいた。",
              "citation": {
                "source": "北岳と朝日岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しも一群の雨燕あり、相和鳴して高く中天に翔り、風に従って倏ち行く所を知らず。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨燕も真物であったか否か不明である、唯雨中に出現したのでそう書いたものに過ぎない。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、どこからともなく、あまつばめが、群れをなして飛んできました。",
              "citation": {
                "source": "汽船の中の父と子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつばめは、めったに、こうして騒ぐものではありません。",
              "citation": {
                "source": "汽船の中の父と子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、どうしたことか、その中をあまつばめは、船のまわりに、岩角に、集まってしきりに鳴いていました。",
              "citation": {
                "source": "汽船の中の父と子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その船のまわりに、あまつばめの飛んでいる、寂しい景色がながめられたのであります。",
              "citation": {
                "source": "汽船の中の父と子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
