          "literary": [
            {
              "text": "浮世絵ましろなる塔の地階に、　　　　さくらばなけむりかざせば、やるせなみプジェー神父は、　　とりいでぬにせの赤富士。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "△椿貞雄氏――『黄富士』『赤富士』の無神経さがよい、もし神経を使つてゐるのだと作者が抗弁すると仮定したらではデティルが出てゐないぢやないかと反駁したい、部分的描写を無視して、あれだけ赤さ、黄さを表現する業はさすがである、あわてゝ色をかけた感じである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤富士だ」　と船窓を指さした。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "広重の赤富士のおだやかな蘇芳色ではない。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤富士や夕立富士はけっこうだが、なにか窟屈なところもある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨネ野口は、英国のある邸宅で、暖炉の上にかけてあった北斎の「赤富士」について質問され、答えることの出来なかったのが口惜しくて、浮世絵研究をはじめたというが、私の東海道ドライブと、牛山氏に笑われたのも、それと同じだと言えるかも知れない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ赤富士が、夕空に見えた。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
