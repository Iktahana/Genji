          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンダーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンダーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンダーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンダーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンダーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンダーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンダーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンダーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンダーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンダーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンダーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンダーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンダーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンダーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分は幸いにここでも図書室を自由に開放してもらって、読書したりノートを取ったり、また河のメアンダーに関する小さな「仕事」をさせてもらったりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば短時間の強い光源としてのアンダーソンの針金の電気爆発を使う代りに水銀のフィラメントの爆発を使ったり、また電扇の研究と聯関して気流の模様を写真するために懐炉灰の火の子を飛ばせるといったようなことも試みた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後アメリカでローランド、マイケルソン、アンダーソン等によって優秀な金属製格子が作られ、またソープ、ウォーレス（Thorpe & Wallace）のセルロイド鋳型などが出来て、レーリーの転写は実用にはならなくなった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのベデカはちゃんと一度下調べをしてところどころ赤鉛筆で丁寧にアンダーラインがしてあった。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日道子はアンダーシャツにパンツを穿き、その上に着物を着て隠し、汚れ足袋も新聞紙にくるんで家を出ようとした。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い月の光が彼女の白いアンダー・シャツを銀色に光らせ、腰から下は黒のパンツに切れて宙に浮んだ空想の胸像の如く見えた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに鉛筆や紫鉛筆でやたらにアンダーラインをしたり、？",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう放心しているらしい夢想あるいは言葉の切れ間の一つの間に、予は、褥榻の上の自分の近くにあった、かの詩人にして学者なるポリシアン19の美しい悲劇「オルフェーオ」（イタリアの最初の自国語の悲劇）の一ページをめくると、鉛筆でアンダーラインを引いた一節を発見した。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ、至るところにアンダー・ラインが引いてあるぜ、赤鉛筆か何かで――。",
              "citation": {
                "source": "読書と生活",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君が引いたアンダー・ラインの個所だけを面白く読んだよ。",
              "citation": {
                "source": "読書と生活",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先き、私はステップニャツクの『アンダーグラウンド・ラシヤ』を読んで露国の民族性及び思想に興味を持ち、この富士の裾野に旅した時も行李の中へ携えて来たが、『罪｜与罰』に感激すると同時にステップニャツクを想い起し、かつ二葉亭をも憶い浮べた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかんないよ、日本の会社はメチャクチャだから」「ヤードバーズの〈オーヴァー・アンダー・サイドウェイズ・ダウン〉だの、スタンデルズの〈ダーティー・ウォーター〉だの、騒々しい曲ばっかじゃねえか」　三日後に、ワラがアメリカへ帰る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーソン教授　択ばれた対策は、いよいよ実行に移された。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカのユタ州の技術大学のアンダーソン教授が、始めて一つの対策研究を発表したときは、実はあまり世界の注目を惹かなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアンダーソン教授の研究というのは、次のようなものであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーナー博士ほか二名は、その夜飛行機で大西洋を越え、紐育に入った、そして博士はアンダーソン教授と会見したのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会見によってどんなことが決ったか詳かでないが、それから三週間も経って、突然アンダーソン教授の対策の研究が発表せられたところから考えて、これはその日の昼間に相当の発展があったものと思われる。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーソン教授は、その反駁にも一切応うところなく、只一回の発表で、あとは沈黙してしまった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新鋭潜水艦　ヤクーツク造船所製の耐圧潜水艦ウラル号が大西洋へ乗出したのは、アンダーソン教授の生理電波説の発表があってから、更に一週間の後のことだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちの顔触れは、ワーナー博士と二人の助手、アンダーソン教授とその三人の助手、それからドレゴ記者、水戸記者、それにエミリーだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤクーツク造船所は、秘密の耐圧潜水艦を提供し、しかもワーナー博士とアンダーソン教授の希望どおりに短期間に改造を加え、乗組員の全部を提供した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "至宝ワーナー博士とアンダーソン教授は、ウラル号にその運命を托したのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫くして、アンダーソン教授の手によって、いよいよ生理電波で変調された超音波が城塞へ向けて発射された。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーソン教授は、怪人集団への信号を変更した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーソン教授とワーナー博士は、互いに身体をぴったり寄せ合い、前方を凝視している。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーソン教授が応答した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
