    "definitions": [
      {
        "index": 1,
        "gloss": "(horned) blue demon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "青鬼に呼び止められた亡者のような悲し気な顔でチラリと、恐ろしそうに眉香子の顔を振り返っただけで……それでもイクラか落ちついたらしく、長椅子の上に引っかけた上衣を横筋違いに引被りながら、ヨロヨロと応接間を出て行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "張抜らしい真黒な大釜を、蓋なしに担いだ、牛頭、馬頭の青鬼、赤鬼。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が前へ、赤鬼が後棒で、可恐しい面を被った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が、「ぼうぼう、ぼうぼう、」　赤鬼が、「ぐらッぐらッ、ぐらッぐらッ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて古色蒼然たる脇立の青鬼赤鬼も、蛇矛、長槍、張飛、趙雲の概のない事はない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれ迷つてゐると思ひますとね、閻魔堂で、羽目の影がちらり／＼と青鬼赤鬼のまはりへうつるのが、何ですか、ひよろ／＼と白い女が。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗ・Ｃへ通りがかりに、上から蔽かぶさるやうに來た時は、角のあるだけ、青鬼の方がましだと思つた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、不思議に客人の気を悪くして、入相の浪も物凄くなりかけた折からなり、あの、赤鬼青鬼なるものが、かよわい人を冥土へ引立てて行くようで、思いなしか、引挟まれた御新姐は、何んとなく物寂しい、快からぬ、滅入った容子に見えて、ものあわれに、命がけにでも其奴らの中から救って遣りたい感じが起った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼、青鬼、白鬼の、面も三尺に余るのが、斧鉞の曲舞する。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此処では話ができん、内へ入って話そう」　と、青鬼が云った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼はもう隻足を敷居に踏みかけていた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼と赤鬼の二疋は、胴を屈めるようにしてあがった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「できます、できます、手許にはないが、親類にあずけてありますから、じき執って来ます、どうぞちょっと待ってくだされ」「すぐ執って来るなら待ってやっても好いが、遅くはないだろうな」　と、青鬼が念を押した。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、もう、そんなことをなにしに申しましょう、黙って執って来ますから、どうぞ待ってくだされ」「そんなら好い、待ってやる」　と、青鬼が云うと、老婆は急いで表の方へ出て往った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼と赤鬼はその後を見送って、耳を澄ますようにしていた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼は手にした鉾を襖に立てかけた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すこし休もうか」　と、青鬼がまた云った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼の面を着ていたのは、壮い色の白い男で、青鬼の面を着ていたのは、頬髯の濃い角顔の男であった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旨くいったな」「大丈夫じゃ」　青鬼の方の男は行灯の灯で、仏壇に供えてある餅を見つけた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍には赤鬼と青鬼の面もあった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼みたいに酔っぱらっとったが、出て行く時は青鬼みたいに青うなっとったぜ。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼が青鬼になった……？",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺青鬼といふ言葉を私は思出した。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺青鬼という言葉を私は思出した。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギイギイギイ――ッ……」　青鬼のようになった三好の両眼が、酸漿のように真赤になった……と思ううちに鼻の穴と、唇の両端から血がポタポタと滴たり出した。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "続く赤鬼、青鬼、｜一つ目小僧に傘の化者……」下　しきりに村長が歓呼の声をあげ続けてゐましたが、そこまで聞くと私は、インヂアンの大酋長は、思はず、「アツ！",
              "citation": {
                "source": "馬上の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから皆は警視庁に移され、東京監獄（今の市ケ谷＝いちがや）に移され、そして青鬼とあだ名された河島判事の予審に付せられた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケケケ……ケケケケケケケケケ……」　若様らしい上品な澄夫の顔が、その笑い声につれて見る見る皺だらけの鬼婆のような、又は髪毛を逆立てた青鬼のような表情に変った。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の顔はいつの間にか恐ろしい青鬼の顔に変っていました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
