          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日余り物について考えている。",
              "source": "幻辞"
            },
            {
              "text": "余り物という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は余り物の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には余り物が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "余り物を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは余り物について学習した。",
              "source": "幻辞"
            },
            {
              "text": "余り物の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は余り物の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では余り物が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "余り物という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に余り物という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では余り物についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "余り物を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると余り物は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "余り物について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では余り物が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に余り物は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により余り物の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "余り物は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に余り物は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一體父は、余り物事に頓着せぬ、おつとりした、大まかな質でありながら、金といふ一段になると、體中の神經がピリ／＼響を立てて働くかと思はれるばかり、遣口が猛烈となる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "食を頒けるときも強壮者が美味をとり老弱者に余り物を与えるのが匈奴のふうであった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホラ……余り物ば遣るぞ』　と云うて蒲鉾小舎の入口に乾いて在る面桶に半分ばかり入れてやりましたので、非人はシキリに押頂いておりましたが、暫くしてから行ってみますと、喰うたと見えて面桶が無い。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも余り物質的の名誉を重んずる夫人の性質も極端だが、それだけにまた儕輩に群を抜いて、上流の貴婦人に、師のごとく、姉のごとく、敬い尊ばれている名誉を思え、七歳の年紀から仏蘭西へ行って先方の学校で育ったんだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代でも、余り物に凝り過ぎると馬鹿か気違いになると云ったのであるが、多左衛門も絵馬の道楽に凝り過ぎて、殆ど気違いのようになってしまったらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "とほき出し、小六ヶしい英単語を会話の中へ加へて、どうだ解るまいと悸かすのだが、その発音と素振が余り物々しく技巧的過ぎて解らず、私は英語は嫌ひで出来ないのだから文句の中にそれを挿入せずに喋舌つて呉れとをがんだ。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "静緒の驚駭は謂ふばかり無く、「あれ、如何が遊ばしました」「いえ、なに、私は脳が不良ものですから、余り物を瞶めてをると、どうかすると眩暈がして涙の出ることがあるので」「お腰をお掛け遊ばしまし、少しお頭をお摩り申上げませう」「いえ、かうしてをると、今に直に癒ります。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "質帝隷居士、百味の食を作り、清僧を請じ、余り物もてこの六比丘を請ぜしに、油と塩で熬た魚をくれぬが不足だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　駿馬痴漢を乗せて走るというが、それにしてもアノ美貌を誇る孔雀夫人が択りに択って面胞面の不男を対手にするとは余り物好き過ぎる。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、毎度余り物の値を露わにいうようでおかしいが、これも参考となるべきことですから、いって置かねばなりませんが、私の原型を作った手間がどうかといいますと、狆の丸彫り四つで百円であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "四頭の狆を製作したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もともと余り物事を深く考えることの得意でない伝さんは、いつまでたっても、この問題に解決を与えられそうな、名案を、考え出すことは出来なかった。",
              "citation": {
                "source": "三の字旅行会",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中橋新文部10・１（夕）　無茶苦茶な世の中に生きてゆく必要から、自分は余り物事に心を動かさないやうに腹を据ゑてゐるが、それでも今度の新内閣の顔触に、中橋徳五郎氏の文部大臣を見た時には、急に可笑しくなつて弾けるやうに笑ひたくなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体画かきといふものは余り物覚えがよくないやうだ）汽車を待つ間のつれづれに雲を見てゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその欠点は多くの場合、彼等の長所を裏から見た場合でございます、私が今までに感じた事は、直覚の鈍い事、自ら与えられた権利に捕われて居る事、余り物質的なことと、群集的なこととでございましょう。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三右衛門は医師が余り物を言わぬが好いと云うのに構わず、女房子供にも、役人に言ったと同じ事を繰り返して言って聞せた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは十二月三十一日なので、取引やら新年の設けやらの為めに、家のものは立ち騒いでいるが、客が少いから、純一のいる部屋へは、余り物音も聞えない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の余り物の方が実際上、猫よりも遥かに多いんだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お金がすまないうちに着なさんなとは云わないから、安心おし」　昼飯の間じゅう、婆さんが余り物のあがったことを※く喋るものだから、これも夜勤あがりで寝ていたのを二階からおりて来て一つチャブ台でたべていた旋盤工の清水が、「うー、たまんねえナ」と急に茶づけにして、かっこんで、「お婆さんは智慧者だよ。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余り物ではございますけれど」「へ、余り物とおっしゃると？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一緒に酒を飲み食事をしながら、私と妻とはごく穏かな言葉で、そういう場合に誰でも普通に云いそうなことを――故郷の人達に心配さしてはいけないとか、余り物を買うものではないとか、若い女との交際は初め何でもないつもりでも危険が伴い易いとか、そんな風なことをぽつりぽつり云ったのです。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十二枚の小判を、無雑作に他人の眼の前へ持って来て、余り物でも処分するような扱い方が、お雪ちゃんには意外に思われてたまらなかったのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この居候連中は宿屋や酒場にいりびたって、使い走りをしたり、いろいろ半端仕事をして、台所の余り物や、酒場のおこぼれにしこたまありつこうという算段である。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は余り物も言わないで足元に目を配りながら、思い思いの方向を取って静かに歩を運んだ。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "福介は、先生が余り物事に凝り過ぎて、とうとう気が狂れてしまったのだと思った。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は過日ある人から、「君は余り物を持ち過ぎるではないか」といわれた。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来彼は余り物を云わなくなった。",
              "citation": {
                "source": "恐ろしき錯誤",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の中では、三人共余り物をいわなかった。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の妻女の物吝みが強いので、自分は流しの余り物を食べ、我が食う分を残しておいて旅僧に施していた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「へへん、来やがれ、畜生、何が何だって、今頃になって、碌でもないあまりもののお客なんぞをふり当てやがるんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっけから、あまりもののお客とやられて、思わずギョッとしたのは、庄亮、Ｈ、Ｆ、白秋だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
