        "examples": {
          "standard": [
            {
              "text": "脂汗について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この脂汗は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "脂汗の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が脂汗について知っています。",
              "source": "幻辞"
            },
            {
              "text": "脂汗は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は脂汗の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "脂汗に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では脂汗が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から脂汗を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "脂汗の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも脂汗が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では脂汗が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "脂汗について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも脂汗は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも脂汗は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で脂汗は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に脂汗について学びました。",
              "source": "幻辞"
            },
            {
              "text": "脂汗の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する脂汗の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では脂汗の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自己｜嫌悪に打負かされまいと思って、彼の額から脂汗がたらたらと流れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、切り立ての鋏穴の縁辺は截然として角立っているが、揉んで拡がった穴の周囲は毛端立ってぼやけあるいは捲くれて、多少の手垢や脂汗に汚れている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて治療となると例のごとく娘が背後から抱いていたから、脂汗を流しながら切れものが入るのを、感心にじっと耐えたのに、どこを切違えたか、それから流れ出した血が留まらず、見る見る内に色が変って、危くなった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は脂汗を流していた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己嫌悪に打負かされまいと思って、彼の額から脂汗がたらたらと流れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身に水を浴びたよう脂汗をにじみ出し長身の細い肢体を捩らし擦り合せ、甲斐ない痛みを扱き取ろうとするさまは、蛇が難産をしているところかなぞのように想像される。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎は、手を痛いほど握り締め、自分も全身に脂汗をにじみ出させて、見ることに堪えていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂汗が、じつとりと額に涌いて出る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて療治となると例の如く娘が背後から抱いて居たから、脂汗を流しながら切れものが入るのを、感心にじつと耐へたのに、何処を切違へたか、それから流れ出した血が留まらず、見る／＼内に色が変つて、危くなつた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜く腫れ上り更に鼻血や脂汗で泥土のように汚ごした顔を、疼痛と憤怒と息切れでもみくちゃにひんまげた男達は、最早や彼女の友達ではない。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩いた自分の掌に男の脂汗が淡くくっついたのを敏感に感じながら、加奈江は一歩｜後退った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しわれと己れ自身を偽つたなら、白い鵞鳥は蟾蜍となり、黄金の匙は怪しいニツケルのナイフとなり、酒は酢となり、きりぎりすは蚯蚓となり、恋人の美くしい眸は忽ち賤しい波羅門の腕環にはめられて一生を浅ましい脂汗と怪しい畜類の匂に汚されて了うであらう。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛の額にも脂汗が流れた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、額の脂汗を拭きながら、見るともなしに後の客席に眼をやった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂汗を垂らしながら帳尻を合わせたのは、間違いなく編集プロダクションの哀れな若者だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがひょんなことから三途の川の川守りをしながら送られてくるレポートを眺めていると、次第に脂汗が落ちてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも以前は武芸に凝り固まって、やれ剣術の柔術のと脂汗を流して苦しんだものだが、今さら思えば馬鹿であった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことまでわかりましたか」と彼は額に脂汗をにじませながら言った。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで見つかっては僕は弱りますから」私は明日の朝警官にひきたてられて動物園を出てゆく自分の姿を想像して額から脂汗がにじみ出た。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "額には脂汗がにじみ顔色は蒼白になった。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はハァハァと息を切り、額から脂汗をタラタラと流した。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男学員ペンは上下の歯をバリバリ噛みあわせながら、額からはタラタラと脂汗を流していた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "住民の脂汗と呻吟とを載せて、音楽浴は進行していった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂汗だってタラタラ流れてくるよ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼は考へれば考へるほど、その顔に、脂汗がにじみ出して来るのであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "額に脂汗を浸ませて、咳入る度に頬を紅くしながら、激した調子で話してゐる病人の衰へた顏が、まざ／＼と見える樣だつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂汗でどの顔も赧黒く蒸せている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身が鳥肌立つて一時に冷えて行つた體の内部から、じわじわと脂汗がにじみ出て來た。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑んだ水はすぐにねつとりとした脂汗になつて皮膚面に滲み出た。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ふしぎな　ことに　じっと　一休さんを　にらんで、木刀を　ふりあげて　いる　せんせいの　てが、ぶるぶると　ふるえだし、ひたいから、じわじわ　あぶらあせが　ながれだして　きました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
