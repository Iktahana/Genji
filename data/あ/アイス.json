    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイスは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昼間は毎日暑く、今産院にゐる娘は「ブーラ、ブーラ、ブーラブラ」といふ象といふ題の児童唱歌をオルガンで歌ひ、姉娘は夜になるとパウリスタに連れてつてアイスクリームを食べさせてくれた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイスクリームでも取つてこいつてねーやにお言ひ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイスクリームを貰つたかい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンチングを横っちょにかむり、何か腹掛けのようなものを胸に当てたアイスクリーム屋のイタリー人が、いつか焼栗売りに変っている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームの寒帯から早く焼栗屋の熱帯へ……は、いらはい、いらはい。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "steak はアイスランディックの steik と親類らしいが「ひたきのおきな」の「ひたき」を「したき」となまると似て来るからおもしろい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "anger はアイスランドの 〔a&ngr〕 やＬの angor などのような「憂苦」を意味する言葉と関係があるそうで、一方ではまたスウェーデンの「悔恨」を意味する 〔a&nger〕 に通ずる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様が流行らないなら、モガの一人も張り飛ばして、食堂でアイスカフェーの食券一枚。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリーム　帝劇にバンドマン歌劇が來た時、二階も棧敷も、着飾つた西洋人で一杯だつた。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人がアイスクリームのグラスを持ち、皆がそれを少し宛、指につまんで喰べてるのである。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームといふものは、鹿皮の手袋をした上から、指先でつまんで食ふものだといふことを――。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つとき心殘だつたのはこの編輯後記が書けてなかつたのと、先日飯島を見舞つたとき一度アイスクリームを持つて行くと約束してあつたことだ。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方一同が涼み台と縁側に集まっていろんな話をしている間に、去年みんなである夜銀座へ行ってアイスクリームを食った時の話が出た。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも銀座というのはアイスクリームのある家の事と思っていたらしいという事である。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　杏仁水　ある夏の夜、神田の喫茶店へはいって一杯のアイスクリームを食った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアイスクリームの香味には普通のヴァニラの外に一種特有な香味の混じているのに気がついた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく嗅がなかった匂であったために、今このアイスクリームの匂の刺戟によって飛び出した追想の矢が一と飛びに三十年前へ飛び越したのかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことに、この一杯のアイスクリームの香味はその時の自分には何かしら清新にして予言的なもののような気がしたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリーム屋の声も、歌をうたう声も、なにからなにまで。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかけ離れたアフリカへんやアイスランドまでも網の目を広げられる事になってしまうのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドの火山 Askja は同国古語の Aska（灰）であるとすれば、これは英語の ashes（灰）と親類だそうである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎から始めて来た人などに、ここで汁粉かアイス一杯でもふるまうと意外な満足を表せられる事がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、五丁目あたりの東側の水菓子屋で食わせるアイスクリームが当時の自分には異常に珍しくまたうまいものであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前のことであるが、ある夏の日｜銀座の某喫茶店に行っていたら、隣席に貧しげな西洋人の老翁がいて、アイスクリームを食っていた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてやって来たボーイ頭をつかまえて「このアイスクリーム、チトモツメタクナイ。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツメタイアイスクリーム持って来てください」というのである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろもうアイスクリームの冷たくないのに屈辱の余味を帯びた憤懣を感じ、タオルの偶然な差別待遇にさえ世に捨てられでもしたような悲しみと憤りを覚えることの可能な年齢に近づきつつあるのかもしれない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方は揃いの新しいユニフォームをチャンと着ているのに、こちらはワイシャツにセイラ・パンツ、古足袋、汗じみた冬中折れという街頭のアイスクリーム屋式が一番上等で、靴のままコートに上って叱られるもの。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく食欲を満足したあとでアイスやコーヒーを味わいかけていい心持ちになっている時分に、これが始まるのである。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説を敷衍すれば、熱い酒に冷たい豆腐のひややっこ、アイスクリームの直後のホットカフェーの賞美されるのもやはり一種の涼味の享楽だという事になる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
