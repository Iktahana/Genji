    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dish consisting of bony fish parts boiled in soy sauce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗煮について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗煮という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗煮の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗煮が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗煮を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗煮について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗煮の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗煮の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗煮が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗煮という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗煮という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗煮についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗煮を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗煮は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗煮について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗煮が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗煮は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗煮の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗煮は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗煮は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "59人情知る老人よ、早く行って、土ふるいの小童の手を戒めてやれ、パルヴィーズ＊の目やケイコバード＊の頭をなぜああ手あらにふるうのかえ！",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "（友吉と義一の姿をアゴで指して）あんまり手あらに扱っちゃあ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしゃただの躯じゃないんだからね」とみさおは主張する、「あたしのおかずはべつにするよ」　たとえこまぎれ肉にしろ鮪のあらにしろ、みさおだけは一と皿べつにおかずをつける。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
