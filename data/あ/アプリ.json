          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アプリについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アプリという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアプリの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアプリが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アプリを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアプリについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アプリの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアプリの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアプリが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アプリという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアプリという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアプリについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アプリを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアプリは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アプリについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアプリが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアプリは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアプリの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アプリは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアプリは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だから、この表情のニュアンスを知ることは、信吉あるいは信吉的要素を持った現代の青年を理解するのに、必要缺くべからざるアプリオリとも、言えば言えるのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい水彩画と、ピカソの絵葉書、その脇には圭子自身の製作らしい麻布に葡萄の房のアプリケが、うすよごれた壁をすっかりかくしていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど独立したアプリケーションなら、自分たちの意思でウインドウズへの移植に踏み出せます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい機種のほとんどが、ＣＤ―ＲＯＭの再生装置付きで売られるようになり、アプリケーションも、ゲームも、電子化した本や写真集の類も、一気に虹色に光る銀色の円盤で供給されるようになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったブックはさっそく、「建築デザイン」、「在宅ワーキング」、「アプリケーション日本語環境」など、ニフティーで出入りしていたフォーラムに登録しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字や数字を処理するためのアプリケーション・ソフトの開発はＰＣの採用したＭＳ―ＤＯＳという基盤の上で集中して行なわれ、パーソナルコンピューターは見る間に役に立つ道具に化けていった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＯＷＮＳ　ＧＥＡＲを使って電子紙芝居を作っていく最中はＣＤ―ＲＯＭの遅さが本当に気になってしょうがなかったが、今回の発表にあわせてシステム・ソフトが手直しされ、ＣＤ―ＲＯＭからのアプリケーションの呼び出しは三〜五倍に高速化されたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにＭＳ―ＤＯＳに対応して書かれたアプリケーションは、それぞれ独自に使いこなしの流儀を組み立てた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方マッキントッシュは、基本ソフトに使いこなしの仕掛けを組み込み、すべてのアプリケーションにこれを利用することを求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自らのアプリケーションに一貫した個性を与える独自の環境を欠いてデビューした事実は、ＦＭ　ＴＯＷＮＳの役者人生をどう左右するだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝のダイナブックが口火を切った軽くて小さくて安いマシンの台頭と歩を合わせ、ソフト業界は一万円を切る低価格ビジネス・アプリケーションの波に洗われた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の富士通がそこまで踏み切った今となっては、アシストの九千七百円のアプリケーションは『低』価格というよりはむしろその本質を正しく示す『正』価格ソフトと呼ぶべきだろうとトッテン社長はいきなりくすぐりをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに同盟軍の戦線には、五種類のアプリケーションのセットで四万円のビジ・コンポを擁するクレオと、日本語ワープロのイージーライトを七千円で提供するエルゴソフトが加わっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存のパーソナルコンピューター用ソフトをぶちまけるトッテン社長のアシストは、日本の三千六百万人のデスクワーカー、二千四百万人の学生、児童、四千万人の主婦、つごう一億人を市場としうる商品にアプリケーションを大化けさせることを目指す。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがマニュアルを読むことに遺伝子レベルで禁則をかけられたこのスカートを履いたゴリラでも、マッキントッシュのアプリケーションは複数種類を日常的に自力でどうやら使いこなしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたごく基本的なルールがほんの少しだけ存在し、それがすべてのアプリケーションを支配している。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳではユーザーとのやり取りのスタイルをどう作るかは、全てアプリケーションの書き手にまかされている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしアシストはそもそも受託開発のみの日本市場に対してアプリケーション・パッケージの役割を正面に掲げることで切り込んできた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて16ビット・マシンの世界では、表計算、ワープロ、そしてデータベースといった新たなアプリケーションの登場は、新鮮な驚きと興奮の種だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳの独占に加えて、アプリケーションのヒットも出したいマイクロソフトにとっては、何ともめでたいお話しである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳとＷｉｎｄｏｗｓ、マッキントッシュ上に積み重ねられた、この個人の道具としての使用経験とアプリケーションの幅は、もはや小錦と曙と武蔵丸が束になってかかったとしても到底動かしがたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキスト情報をもっとも大量にくわえ込んだＭＳ―ＤＯＳマシンは、アプリケーションごとにまったく別の顔を見せる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太郎は日本語フロントエンド・プロセッサー（仮名を漢字に変える辞書引き担当ロボットのようなものだ）をＭＳ―ＤＯＳというプラットフォームに開き、他のアプリケーションでも使えるようにしたことで、流行りにはやった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっとアプリケーション・ソフトを見渡して、日本のソフトハウスが一から書いた製品が健闘している領域はどこか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも比較的知能指数の高い者はこれを早目に英語マシンと割り切り、新しいアプリケーションの鑑賞やゲームといったツボに味わい所を限った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあアプリケーションと周辺機器を人質に取られとるけ〜、マックとはもうちょっと縁が切れんよね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の本や雑誌などによると、Ｗｉｎｄｏｗｓ環境ではアプリケーション間で操作性が統一されるのでよろしいとある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "個別のアプリケーションの顔つきも千差万別で、相手が変わるごとに付き合い方を一から覚える必要があった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上の窓に複数のファイルや複数のアプリケーションを開いて、データを切り張りしながら仕事を進めることができる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "てなうちにフロッピーディスクとＣＰ／Ｍが現われて、アプリケーションが商品になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
