          "literary": [
            {
              "text": "」従妹「あらいやだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女　　あらいやだ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらいやだと思って、わたくしは思わず身をひこうとすると、市野さんは冗談半分でしょう、そら幽霊が取り付くぞと言って、その草をわたくしの胸へ押し込んだのです。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、そんな事はないが、」僕は口ごもって、「前から、何か、――」「あらいやだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もち米を飯にたいて、それを、あたり棒か何かでつぶすのさ」「臼でぶったたくんだね」「あらいやだ臼だって。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あらいやだなもんか本当だよ』『嫌やだわ内縁の妻だなんて。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の少いてる子は、快活で、弁当箱のふたについた御飯粒を箸の先で拾いながら、「あらいやだ、母ちゃんがまたこれ入れている、私末広きらいなのに……千葉の親類がこんなものをくれるんだもん」　そう云いながらサイの弁当をのぞいた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらいやでございますよ。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらいやな髭なんぞを生やして、と言いかけしがその時そこへ来たる辰弥の、髯黒々としたるに心づきて振り返りさまに、あら御免なさいましよ、おほほほほ、と打って変りたる素振りなり。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらいや、またそんなことをおっしゃるんだもの。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐の袖無以後｜御見限りだね」「あらいやだ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ちょっと眉根を寄せる）あらいやだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらいやだ、暫く人とおしゃべりをしないもんだから、すっかりいろんな事をしゃべってしまって……。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "女将　　あらいやだ。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あらいやよ、関係だなんて。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "初瀬は、笑ひながら、「あらいやだ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたのしみね」「あらいやだ。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもお若い御夫婦をみてると羨しくなるわね」「あらいやだ。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あらいやだね、兄さんは。",
              "citation": {
                "source": "少年の死",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻　　あらいやだ、おズボンだけ一生懸命でつまんでたわ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらいやだ、汗をかいてらつしやるわ。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっとした女、あらいやだ、冗談じゃないよこれは――と真剣にあわて出したとたん、またもや鎧櫃の真上に当たって、何やらひそひそささやきかわす人声。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど善い音ですな、吾輩などは生れてから、そんな立派なものは見た事がないですよ」「あらいやだ、みんなぶら下げるのよ」とまたちゃらちゃら鳴らす。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや絵もかくんでございますか、なかなか器用ですね、どれ拝見しましょう」と眺めていたが「あらいやだ、狸だよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾しには地味過ぎていやだから御前に上げようとおっしゃった、あれでございます」「あらいやだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその男がどうしたんで――」「その男がね奥さん見たように眠くなってぐうぐう寝ている――」「あらいやだ」「寝ている間に、ヴァルカンの子が来ましてね」「ヴァルカンて何です」「ヴァルカンは鍛冶屋ですよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに御化粧をすればたいていの人はよく見えるわ」「それじゃ雪江さんなんぞはそのかたのように御化粧をすれば金田さんの倍くらい美しくなるでしょう」「あらいやだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらいやよ、みんなでこの人形の悪口を言っては。",
              "citation": {
                "source": "眠り人形",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あらいやだ、あんたみたいなおかめを猪之さんが貰うもんですか、あのひとのお嫁さんになるのはあたしよ。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七両二分だってさ、ほんとだよ」「あらいやだ、七両二分てえば人の女房となにしたとき……まあいやだ、かあさんたら、ははははは」「なにがいやさ、洒落てるじゃないか」　こう云っているのはお菊であった。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
