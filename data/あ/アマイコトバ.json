        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘い言葉について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘い言葉の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘い言葉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘い言葉について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘い言葉の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘い言葉が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘い言葉という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘い言葉についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘い言葉は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘い言葉が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘い言葉は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘い言葉の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘い言葉は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘い言葉は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あなた様は人の世の恋人同志が、月の夜の木蔭に寄り添うて語り交す、蜜のように甘い言葉をお聴きなされたことがおありですか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という甘い言葉に乗せられ、故郷へのむかしの憎悪も、まるで忘れて、つい、うかうか、出席、と書いてしまった。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、ロドルフが、更にそっとエンマに身をすり寄せ、甘い言葉を口早に囁いているところなのですが、私は、読みながら、全然別な奇妙なことを考えて、思わずにやりと笑ってしまいました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのような時にも私の口は甘い言葉を囁かず、熱い口づけもせず、ただ欠伸をするためにのみ存在しているのであった。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日にでも遊びに来てくれとささやかれた甘い言葉を、又しても思い出した。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、夫人から、蜜のような甘い言葉を、幾度となく聴いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説などにある甘い言葉は使いたくない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間なれていて男も珍らしくないらしく、甘い言葉が力なく上辷りしている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘い言葉や、美しい言葉では、とうてい傷ついた人の心を、救うことはできないのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、この時、父がかく厳しく訓誡してくれましたことはまことに親の慈悲であって、こうした教訓を与えられず、甘い言葉を掛けられ、また父の都合上から、私の小さな力でも借りようとしたならば、私の将来もほとんど想像されたことであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "一度家に帰り父に誡められたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、夫人から、蜜のやうな甘い言葉を、幾度となく聴いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子供は父親のいない家のなかが寂しくなって来ると、思い出したように、抱いてでももらいたそうにお増の側へ寄って来るのであったが、女らしい優しさや、母親らしい甘い言葉の出ないのが、お増自身にももの足りなかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上結婚当時の甘い言葉や優しい態度など思合せると、彼の愛も卑劣な欺瞞と賤しい情慾との塊にすぎないのだと思はれた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし桂子の次のような甘い言葉の数々が、充分、私のそうした疑念を打消したのだった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも便の具合では疲労の余り、催おしたらしい柔かさだったが、ここで甘い言葉をかけてはならぬと、また手を引いて単調な杉林の路を登って行った。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説などにある甘い言葉は遣いたくない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰め、さうして、甘い言葉。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、あなたは私が恋人であるように、唯一の良人たる人であるように、くずれたような甘い言葉や甘い身のコナシを見せようと努力していた。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと云つて、彼は全然女にもてゝをらず、女の浮気のダシに使はれ、なめられ、ふみつけられ、そのあさましさを知りぬいて、見えすいた甘い言葉に相好くづして悦に入る、バカげたこと、悲しいばかり面白をかしくもないのだけれども、芸術に自信を失つては、芸術家はもう人生まつくらだ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと云って、彼は全然女にもてておらず、女の浮気のダシに使われ、なめられ、ふみつけられ、そのあさましさを知りぬいて、見えすいた甘い言葉に相好くずして悦に入る、バカげたこと、悲しいばかり面白おかしくもないのだけれども、芸術に自信を失っては、芸術家はもう人生まっくらだ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何という甘い言葉、ひくい声は琴の音のようだった。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分もう、甘い言葉ぐらい口にしたことがあるのだろう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方大寺の方は、予て道子の淋しい家庭生活をきき之に同情して居た際とて道子からの甘い言葉をきくと、学生たる本分も忘れ果て、忽ち不義の甘酒に酔うようになったのである。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今まで彼女の口にしつつあった甘い言葉とは全く釣り合わない妙な輝やきであった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　咄嗟に甘い言葉が出なかったので、私は思い切ってありのままを云いました。",
              "citation": {
                "source": "耳香水",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀屋の外を、ウロウロして居た、やくざの信三郎と、髮結の浪藏と、――これはお福の甘い言葉に取り逆上せて、是が非でも祝言を妨げようといふ仲間――。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀屋の外を、ウロウロしていた、やくざの信三郎と、髪結の浪蔵と、――これはお福の甘い言葉に取り逆上せて、是が非でも祝言を妨げようという仲間――。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから丹次が一度や二度自分の娘へ甘い言葉をかけたからって、私どもまで怨まれる道理はないじゃありませんか、ね、親分」　治兵衛は急に雄弁になります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう私が彼の前に出て行つても「戀人」だの「いとしい人」だのといふ甘い言葉で呼びかけることはなく、私にかける一番よい言葉と云へば「癪にさはる人形」とか、「意地惡の妖精」とか、「薄情者」、「とりかへ子」等であつた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりよく眠っているところを見ているうちに、若い番頭の胸の中にむらむらと、出立間際のお内儀さんの甘い言葉と、そのたっぷりした年増肌とが現われて来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
