    },
    "definitions": [
      {
        "index": 1,
        "gloss": "badger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴熊について考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴熊という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴熊の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴熊が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴熊を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴熊について学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴熊の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴熊の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴熊が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴熊という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴熊という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴熊についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴熊を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴熊は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴熊について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴熊が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴熊は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴熊の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴熊は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴熊は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "坂をするすると這上る、蝙蝠か、穴熊のようなのが、衝と近く来ると、海軍帽を被ったが、形は郵便の配達夫――高等二年ぐらいな可愛い顔の少年が、ちゃんと恭しく礼をした。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「穴熊がうまく行ったと、本人は申して居りました」と、祥慶は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊か」と、半七は思わずほほえんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊というのは、いかさま博突などをする場合、その同類が床下に忍んで、細い針を畳越しに突きあげ、むしろの上に投げられた賽を自由に踊らせるのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "松蔵は穴熊の手だてを応用して、土の下から地蔵を踊らせようとしたのてある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その穴熊がそれからかなり経つてから、若い獅子の家を再び訪ねたが、今度は前とは少しばかり様子が変つてゐて、獅子は何か不機嫌な様子であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊は煙草をとりだして、もぢもぢしてゐた、それは獅子に煙草の火をつけて貰ふといふ光栄に浴したいからであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると獅子は安楽椅子に横になつたまゝで『穴熊君、わしが煙草に火をつけてやらう』　と言つたので、穴熊は飛びあがるほど心の中で嬉しがつた、しかし獅子は椅子から立ちあがらうともしないで、頤で先方をしやくつてから『向ふの棚にライターがあるから、君こゝへ持つて来給へ―』と命令的に言つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊は自分の外套を恭々しく獅子の傍まで持つて行くと、獅子は寝そべつたまゝで、いかにも面倒臭さうに穴熊に着せた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊は森の小道を帰つてくると、ぱつたりと狐に逢つた、狐は皮肉さうに質ねた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『穴熊君、やはり君の汚れた外套を、獅子の自由主義は親切に着せてくれたかね』『いやこんどは調子が変だつたよ、着せてやるから、自分で持つて来いといつたんだ』『殿様の自由主義なんてそんなもんだよ、機嫌や、風向きの悪いときには、用心し給へ、まあ自分の外套はなるべく自分で着るやうにした方がいゝね』といつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして猟をすると、雉や鳩や山鶏や兎や穴熊など、面白いほどとれましたし、ときには、大きな鹿や猪などもとれました。",
              "citation": {
                "source": "悪魔の宝",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはたゞ志岐君が仕止めた穴熊の肉を、うまくもなんともないと思つて食つたのを覚えとるだけだ。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "番をしなけりゃならぬのは穴熊や針鼠やの奴が西瓜を噛っているのさ。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前もやつぱり穴熊の一族か」　左門の眼は踊る人々を飽くこともなく追ひつづけた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで僕は若いときからいかものが好きであって、永い年月の間に鹿、狸、狐、猿、鼠、猫、栗鼠、木｜鼬、羚羊、犬、鯨、海狸、熊、穴熊、猪、土竜など、内地の獣類は、いろいろ食べたことがある。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、上州薮塚温泉の背後に連なる広沢山の横穴で捕獲した穴熊の肉を食ったことがある。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの料理は、狸汁のように葱と蒟蒻を味噌汁のなかへ刻み込み、共に穴熊の肉を入れて炊いたのだが、海狸の肉に似ていると思った。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊というのは、南総里見八犬伝の犬山道節が野州足尾の庚申山で化け猫を退治するとき、猫といっしょにとっちめた山の神のことである。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "国によっては穴熊を貉と呼んでいるところもある。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊をはじめ、そして狸、野狐、貉、穴熊など、数知れぬほど棲んでいる。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子の方は十七八歳で、これは人種などというものから少し超越しているというのは、しゃくれた顎と低い鼻を持ち、波止場に落ちた石炭のような漆黒な眼を持っていて、これらの印象が、穴熊だとか狸だとかというものを連想させるからだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟に行って穴熊を生け捕りにしたことのある男で、村でも指｜折りの度胸のいい男であった。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また穴熊のことをむじなとよぶ地方もあり、夏時のたぬきのことをむじなといふところもあります。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の声　なまぐさい……ケダモノのくさったみたいな……男の声　穴熊ぐらい、ここいらにゃいるからね、はいりこんで死んじまって、どっかで腐っているか。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（穴熊が地面をひっかくような爪の音をさせていたが、やがて手をとめて、こっちを振り返る。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫尾の山で穴熊や猪を追うていた奴に何がわかるものか。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムジに二種あり、一はヤチムジ、他の一はマミムジ、ヤチムジは他の地方でいう狸のことであり、マミムジは穴熊またはササクマ、徳島県の山村などでクマダヌキというもののことである。",
              "citation": {
                "source": "狸とムジナ",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お名前は、　あなぐまトミーと　きつねめさん。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつねさんが　出かけているとき　たまに　あなぐまトミーが　もぐりこんでいたり　するのです（ことわりも　なしに）。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
