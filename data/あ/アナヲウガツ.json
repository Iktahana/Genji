    },
    "grammar": {
      "pos": [
        "表現",
        "Godan verb with 'tsu' ending"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to pierce a hole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日孔を穿つについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は孔を穿つの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には孔を穿つが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは孔を穿つについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は孔を穿つの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では孔を穿つが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に孔を穿つという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では孔を穿つについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると孔を穿つは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では孔を穿つが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に孔を穿つは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により孔を穿つの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "孔を穿つは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に孔を穿つは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "重さが十二キロのものは、爆発すると直径が五メートルもある大孔を穿つ。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たまた、壁の彼方に明るき世界あることを感知して、第一にその壁に孔を穿つ明智と勇気の独専者なのか。",
              "citation": {
                "source": "小山内君の戯曲論",
                "author": "――実は芸術論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はコロボツクルは一片の木切れに細き棒の先を押し當て、恰も石錐を以て土器に孔を穿つが如き運動を與へ、引き續きたる摩擦の結果として熱を得煙を得、終に火を得たるならんと考ふ。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石錐は種々の物に孔を穿つに用ゐられしなるべけれど、孔の開きたる儘にて今日迄｜遺存する物は土器のみなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
