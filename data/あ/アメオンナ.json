    "definitions": [
      {
        "index": 1,
        "gloss": "woman who brings the rain with her wherever she goes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨女について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨女という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨女の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨女が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨女を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨女について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨女の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨女の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨女が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨女という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨女という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨女についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨女を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨女は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨女について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨女が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨女は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨女の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨女は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨女は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "協会の懸賞募集脚本に、長谷川時雨女史の史劇「花王丸」当選して、一番目に上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨女史と雑誌記者12・１（夕）　もう新年が眼の前に見えるので、東京の各雑誌社では原稿の奪ひ取り合ひに血眼になつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し前ある雑誌社の編輯記者が原稿取りに長谷川時雨女史の許へ出かけたのがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨女史は原稿取りに来た男をも、自分を口説きに来た男と同じやうに、愛相よく迎へる術を知つてゐる女の一｜人である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雑誌記者はかう言つて、屹と時雨女史の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」時雨女史は怖ろしさうに態と肩をすぼめて言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時雨女史は結婚の結納料でも訊くやうに、心もち含羞むで言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、包み金で、それで加之に私達の運命まで……」　時雨女史は悔しさに泣き出しさうな顔をした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四日後の朝日に谷川徹三氏の書いた年頭神宮詣りの記事は一般にその膝のバネのもろさで感銘を与え、時雨女史も賢い形で一応の挨拶を行った。",
              "citation": {
                "source": "一九三七年十二月二十七日の警保局図書課のジャーナリストとの懇談会の結果",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記を雑記帳に六冊ばかり書き溜めていましたが、これを当時｜長谷川時雨女史によって創刊された女人芸術の二号位から載せて貰いました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村俊子、岡田八千代、與謝野晶子、等々、皆振はない中に、たゞ一人、時雨女史が、三宅やす子、宇野千代、平林たい子などの若い人以上に、お河童の女の中に餓鬼大將として、女性行進曲を吹奏してゐる事は、早呆けする日本の女としては、珍らしい人である。",
              "citation": {
                "source": "長谷川時雨が卅歳若かつたら",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江島生島」は時雨女史の若いあらゆる夢を含めたもの。",
              "citation": {
                "source": "合邦と新三",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく村雨女史のお座なりのおてんたらではあろうが、しかしこの大阪仕込みの勇者に会っては、宮本武蔵でも、鎮西八郎でも一たまりもない、まして道庵先生の如きに於ては、直さんに会っちゃ、ほんとうにかなわないという賞讃をこめたのかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そうすると、村雨女史が、またおてんたらを言いました、「直さんに会っちゃかなわない」　しかしまた、老功なる、みその浦なめ六は心配しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川の海　長谷川時雨女史は嘗て品川の所謂ステンショが波打ち際に建てられてゐて夏の明方など旅客は列車からヒラリ飛下り必らず白浪にその足を快く洗はれたものと誌してゐられた。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "通夜には、生前から「雨女」と笑われていた妻の通夜らしく、雨になった。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "横山大観、鏑木清方、長谷川時雨女史………私はさう云ふ人達を知つた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨女に風男、なんていうのもある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは、午後から『輝ク』の（時雨女史の会）歳末会があって久しぶりで出席したら私が丈夫そうになったと口々に云われ、何をつけていてそんなに艶がよいのかと云われ、一々朝起き早ねをその原因として申しのべました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその会にも次の会にも出ませんでしたが、時雨女史は、自分がすっかり勇退すると云ったらしいが、それは辞令でね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに書いてある大観氏、清方氏、時雨女史等も皆見えてゐた。",
              "citation": {
                "source": "泉先生と私",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨女史が自分のことを「私のようなしがない者が」というような謙遜な言葉づかいをしたとき、私の隣りに腰かけていた若い女性が「まあ、いやな先生。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨女史の知合いであったのだろう。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うほどに、話は閨秀作家月旦になり、その容色品評に及び、貢太郎老は、はしなくも「いや、美人では、時雨女史がなんといってもチクとええ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
