        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "持て余しておりました処へ、ちょうど荷車を曳きまして、藤沢から一日｜路、この街道つづきの長者園の土手へ通りかかりましたのが……」　茜色の顱巻を、白髪天窓にちょきり結び。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう姿が隠さりょう、光った天窓と、顱巻の茜色が月夜に消えるか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と夜具風呂敷の黄母衣越に、茜色のその顱巻を捻向けて、「厭な事は、……手毬を拾うと、その下に、猫が一匹居たではねえかね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何時迄待っても、夕方になってやがて浜辺や松林の景色が物悲しく茜色に染まって、日が暮れかけても、幸子は帰らなかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が夕映で茜色になり、空の茜が海にうつつて、海もあかくなつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹も石も片側茜色になつて、反対側に影をひいた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になると、その金属の冷たい手触りを喜びながら、植民地の新開地じみた場末の二階の窓から、茜色の空を眺めてはハモニカを吹くのであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは今立っている小川の縁の道の赤土が、昼過ぎの陽に照され、にちゃにちゃして茜色の雲を踏んで立っているような気持のするのに、眼の前一面に実のり倒れた金色の稲田を見渡して跼蹐んだ気持は何もかも何処かへ持って行かれました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、梢を透して林の中の靄が木立ごとだん／＼明るく茜色に浮き立つのを見て行きますと、櫟林はわたくしを中に歩かしたまゝ大地ごと誰かの大きな手で擡げられ、しず／＼宝の方へわたくしを近付かせられるように感じられてなりません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれに浮かれ立って、線路を田圃へ下りたんだが、やがて、稲の葉が黒くなって、田が溝染めに暮れかかると、次第に褪せて行く茜色を、さながら剥ぎたての牛の皮を拡げた上を、爪立って歩行くような厭な心持がするようになっちまった。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の支柱暁は山と山との間へ色づいた雲を茜色にひろげるあなたと私との激しい生活の中から堪へ難い苦しみをひとつひとつはぎとり精神の暁をわたしはいま眼の前にみた茜色のつよい喜びを感じてゐる愛する人よ春の聡明な色彩は日増しに美しく生活の谷間からのぼつてくる。",
              "citation": {
                "source": "小熊秀雄全集-9",
                "author": "詩集（８）流民詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "その枯れはてた枝のさき／″＼には、既に早やうす茜色に氣色ばんだ木の芽が丸みを見せて萌えかけてゐるのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その枯れはてた枝のさきざきには、既に早やうす茜色に気色ばんだ木の芽が丸みを見せて萌えかけているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門的の詳しい事を私は知らないが、此処に謂う山桜は花よりも早く葉が出て、その葉は極めて柔かく、また非常にみずみずしい茜色をしている。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　折からそよそよと街道は夕風立って、落日前のひと刻の茜色に染められた大空は、この時愈々のどかに冴え渡り、わが退屈男の向う傷も、愈々また凄艶に冴え渡って、いっそもううれしい位です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "松永博士の推断通り興奮の鎮まった「歌姫」は西の空が茜色に燃えはじめると、火葬場裏の雑木林の隠れ家から例のせつなげなソプラノを唄い出したのだ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがね……」　と、ジヤツキーと呼ばれた青年は、洗つたばかりの房々とした茜色の髪の毛が重く額に垂れさがるのを、やけに首だけで後ろに振りあげながら鹿爪らしく唸つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "決然と分岐する鋪装道路や高層ビルの一｜聯が、その上に展がる茜色の水々しい空が、突然、彼に壮烈な世界を投げかける。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜色の水々しい空には微かに横雲が浮んでいて、それは広島の惨劇の跡の、あの日の空と似てくる。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "決然と分岐する舗装道路や高層ビルの一連が、その上に展がる茜色の水々しい空が、突然、彼に壮烈な世界を投げかける。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜色の水々しい空には微かに横雲が浮んでゐて、それは広島の惨劇の跡の、あの日の空と似てくる。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙間からチラチラと行手を眺めると、国境の大山脈は真紫に冴えて、ヤグラ嶽の頂きが僅かに茜色に光っていた。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿ながらも、茜色と紺と萌黄との太い大名縞の、大芝居の引幕のやうな新らしい柄で、こんな片田舍に自分の娘より外には、そんなものを身に着けてゐるものはない。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の顔も光り輝き眩しげに微笑しているその下の、石畳に溜った水に映っている空の茜色――久慈は先から喫茶店で母に出す手紙の文句を考えながら、じっとその水溜を見詰めていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夕暮が迫って来ていて、西の方の空がぱッと茜色に明るかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓ガラスのように、堤ぎわの空あかりが、茜色に棚引き光っていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚引いていた茜色の光りは沈み、与平の顔がただ、黒い獣のように見える。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その数時間後、二人の同乗した寝台車が、折から茜色の雪解跡をついてＢ癲狂院の門を潜った。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
