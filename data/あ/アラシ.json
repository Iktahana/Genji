    },
    "definitions": [
      {
        "index": 1,
        "gloss": "storm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日嵐について考えている。",
              "source": "幻辞"
            },
            {
              "text": "嵐という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は嵐の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には嵐が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "嵐を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは嵐について学習した。",
              "source": "幻辞"
            },
            {
              "text": "嵐の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は嵐の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では嵐が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "嵐という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に嵐という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では嵐についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "嵐を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると嵐は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "嵐について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では嵐が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に嵐は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により嵐の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "嵐は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に嵐は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三造は、嵐の前の夕凪のやうに、無気味に静かである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後三十年、思へば「私の青春は嵐に過ぎなかつた、時々其処此処に陽の光のちらついた」、詩さながらではなかつたか。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の句には、芭蕉のやうな幽玄な哲学や寂しをりもなく、蕪村のやうな絵画的印象のリリシズムもなく、勿論また其角、嵐雪のやうな伊達や洒落ツ気もない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが近代の思想の嵐に倒潰した。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木の影涼しきところ木の根に腰かけて憩えば晴嵐梢を鳴らして衣に入る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐のやうな心の歴史は終焉つてしまつたもののやうにそこから繰れる一つの緒もないもののやうに燃ゆる日の彼方に睡る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはや、貧しきわが夢のほかに興ぜず※　　　　我が生は恐ろしい嵐のやうであつた、　　　　其処此処に時々陽の光も落ちたとはいへ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の面には、生の動揺といった象が見えている中に、これはまた青嵐も吹かば吹け、碧瑠璃のさざれ石の間に介まって、黙んまりとした｜死の静粛！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川楊の大木が、嵐にも洪水にも抵抗し抜いて、力も何も尽き果てたというように、ぐったりと根こそぎに、岸から川の中へ打ち倒れているのを、橋代りにして渡ったが、向う岸に着くまでには、三度ばかり冷たい水の徒渉をしないわけには行かなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の話であるが、『藪柑子集』中の「嵐」という小品の中に、港内に碇泊している船の帆柱に青い火が灯っているという意味のことを書いてあるのに対して、船舶の燈火に関する取締規則を詳しく調べた結果、本文のごとき場合は有り得ないという結論に達したから訂正したらいいだろうと云ってよこした人があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "單調な東京音頭は嵐か波の音と思つて聽き流すことが出來ると假定しても、可愛い子供の片言は身につまされてどうにも耳朶の外側に走らせることの出來ぬものである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山懷の一隅には非常時の嵐が未だ屆いて居ないのか、妙にのんびりした閑寂の別天地である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年急に襲うて來た「改造」の嵐の爲に、我邦の人の心に自然なあらゆるものが根こぎにされて、其の代りにペンキ塗りの思想や蝋細工のイズムが、新開地の雜貨店や小料理屋のやうに雜然と無恰好に打建てられて居る最中に、それ程とも思はれぬ天然の風景が方々で保存せられる事になるのは、せめてもの事である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれがふいと見当をちがえて転向してみたり、また不明な原因で勢力が衰えてしまって軽い嵐くらいですんでしまうことがしばしばあるのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はもう半ば晴れていたが千切れ千切れの綿雲が嵐の時のように飛んでいた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあね」　ふと鳴って通った庭樹の青嵐を振返ってから、柚木のがっしりした腕を把った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪井博士の説ではトサはやはりチャム系の言葉で雨嵐の国だそうである。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではこの期間に彼は政治界の嵐に捲込まれ、郷里で演説をしたり、弟の立候補の声援運動を助けたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなれば現在の色々なイズムの名によって呼ばれる盲目なるファナチシズムの嵐は収まって本当に科学的なユートピアの真如の月を眺める宵が来るかもしれない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがめぐりめぐった二十余年の今日の嵐の東京でアメリカ名物マーカス・ショーを見ようというのである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口を云われる方では辛抱して罵詈の嵐を受け流しているのを、後に立っている年寄の男が指で盆の窪を突っついてお辞儀をさせる、取巻いて見物している群集は面白がってげらげら笑い囃し立てる、その観客の一人一人のクローズアップの中からも吾々はいくらも故旧の誰彼の似顔を拾い出すことが出来るのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして激昂する心を抑えてピアノの前に坐り所定曲目モザルトの一曲を弾いているうちにいつか頭が変になって来て、急に嵐のような幻想曲を弾き出す、その狂熱的な弾奏者の顔のクローズアップに重映されて祖国の同志達の血潮に彩られた戦場の光景が夢幻のごとくスクリーンの面を往来する。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある製造工場を見学するにしても、実際の場合は一見雑然とした機械の嵐のように運転する中を案内されて説明を聞いても眼が戸まどいをして視るべき要点を掴まえることが困難であるが、適当に編輯された映画で見れば、例えば飛行機なら飛行機の製造される過程が実に明瞭によく分るのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のあらゆる眞の興味は、正に嵐の動搖にある現時の室生をその變化の成り行きについて觀察し、來るべき創造への目ざましい發展を見ることである。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、親愛なるジィドよ、何物をも要求せず、又いかなる困難をも認めずに、かかる嵐にわが身を打ち任かすことの出來たあの頃は、まあ何んと遠いことでせう！",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外には、嵐が空をかけめぐつてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐が家のなかへはひつて來たのだらうか？",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは數日のうちに嵐のやうに襲來したもので、全然私の計畫の中にはひつてゐなかつたものでした。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
