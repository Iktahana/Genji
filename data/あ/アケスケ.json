        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明け透けの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "気心が解って来ると、細君は茶の室へあがって来て、お国言葉丸出しで自分の身のうえを明け透け話した。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が空っぽの人、つまり本当に明け透けで何でも口に出して言ってしまうような人の理論に従えば、自分の仕事について語らない人達というのは、何か良くない事をやっているものなのだそうだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は香気を漂わせ、彼女は間違いなくたった今入浴したはずで、彼女の美貌は明け透けに言ってしまえば、最も扇情的なものと思われた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ目下が精神の貧寒時代であることは分つてゐますし、詩人が存外の苦吟をするのであることも分つてゐるのですから、もつとあけすけにして、もつと具体的なことを論ずることが、詩壇の急務ではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の扉がたけが低くて、中で用を足している人の顔こそ見えないが、非芸術的な二本の脚は廊下からちゃんとあけすけに見えているのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときとすると、女が何事もあけすけに打明話をしてくれるのを、自分に対して隔意がないからだとも考へ直して見て、そこに昔の大通のあつさりした遊振りを思合せて、聊かの満足を覚えることもあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "言にしろ姿にしろ其の通で、何んでもあけすけにさらけ出して、世帯の苦しいことが口に付いてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事でもぱつと口に出してあけすけに話してしまつたのでは物事を充分に観察し、味はふ暇がない私は自己反省に於ても人一倍強いやうになつた。",
              "citation": {
                "source": "小学生のとき与へられた教訓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あけすけでいや味。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのアメリカ人は傍のあの紳士を前｜葡萄牙マヌエル陛下と知らずに、あんなあけすけな態度で女の話をしかけて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　また高笑いで、「……そこで念のため云うておくがですが、内証話をあけすけなが、あんたも世間が解っておいでや。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけな書き手は、自分の処女作を買い占めて回ったり、目につく場所に移し変えたり、毎日欠かさず売れ行きを定点観測したりといった体験を語っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが去年辺りから、バラックでも建てたってなのなら、因縁のつけようもあるが、いや、おかみさん、あけすけに言っちまえばまあそんなもんですよ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が言いたい事だけをあけすけに言ってしまうと、君はしばらく黙りつづけていたが、やがて口のすみだけに始めて笑いらしいものを漏らした。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいおりを見つけて、わたしから上手にいって聞かせるまでは知らんふりをしてね……よくって……あなたはうっかりするとあけすけに物をいったりなさるから……今度だけは用心してちょうだい」「ばかだなどうせ知れる事を」「でもそれはいけません……ぜひ」　葉子は後ろから背延びをしてそっと倉地の後ろ首を吸った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけと飾らぬことを申して、ずんと面白い奴等じゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけと歯に衣着せず申してずんと面白い気ッ腑の奴じゃ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、だんな、とっくりお聞きなさいましたでございましょうね」　これで胸がすっとしたというように、あけすけといやがらせをいったものでしたから、右門はくすくす笑っていましたが、伝六を顧みるといいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはおじさんがだれだかわからなかったけれども、馬がへただったから、へたならきっと伝六のおじさんだろうと気がついて、走るのを止めてやったんだよ」「あけすけと、よぶんなことをいうねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は貴君に十分信用せらるるの自信をもってこのあけすけな手紙を書いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この提案が容れられないときは、余は貴君が余の如くあけすけになり得ない人物だと断定するであろう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎吾も五十を越えて仕事の上にもあぶらが乘り、財も出來、ひさは更年期の女らしく肥えふとつて何事によらずあけすけものをいひ、けばけばした成り上りものらしいいやらしさが家ぢゆうには充ちてゐた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とあけすけいはせるほどであつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけに言つたら、油の切れた古時計のやうに思はれた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈々あけすけに申し上げますから御免下さい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかこの人が弁疏がましい隠し立などしないで、あけすけに、公然に今度の戦争の事情を懺悔したら、どんなにか面白い書物が出来るだらう。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一つあけすけに書いてみたらと思ひましてね。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "別な例だが、横光利一という作家のシステムも、わかるようでわからなく、だがあけすけに分らないと云わせないような同時代人の或る神経にひっかかりをつけてゆく技術で、妙にはたから勿体をつけて見られた作家の一人であった。",
              "citation": {
                "source": "観念性と抒情性",
                "author": "――伊藤整氏『街と村』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子とのその時々の出来事についても、彼はあけすけに庸太郎に話しもし、見せもした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
