    "definitions": [
      {
        "index": 1,
        "gloss": "(ship's) anchor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンカーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンカーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンカーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンカーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンカーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンカーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンカーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンカーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンカーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンカーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンカーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンカーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンカーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンカーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンカーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンカーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンカーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンカーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンカーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンカーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「アンカー」と「アンガー」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
