        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "牧野さんの作品には明るい風景が出て来るし、陽に透いた桜の葉のやうな色や又赤い色があるが、その赤はうでた小海老の赤である。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論暗くなつたればとて、他人様にまで八ッ当りを始められる程の自分なら何を書かう程のことでもないけれど、暗くなると却て明るい真似をしてみたり急に他人本位になつたりしなければならない上に、それでゐて結局人からもさういふ時はやつぱり此奴暗いと見て取られてしまふからには、なんとも馬鹿化た話なんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには近代文明の不幸な疾病が憧憬する所の、あの美しく明るい健康の哲学がある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く、その中に彼の顏には、平常の明るい活氣が現はれてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽業の方は明るい上に楽隊は盛んに鳴らしてゐる、所で神明館の方は仄暗く、例の昔の映写機が、憂鬱な音を立てゝ廻つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外を見ると明るい日光が急に懐しくなつて来たので裏に出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、これらの句には、洋画風の明るい光と印象があり、したがってまた明治以後の詩壇における、欧風の若い詩とも情趣に共通するものがあるからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く春や白き花見ゆ垣の隙　この句もまた、蕪村らしく明るい青春性に富んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や月は東に日は西に　これも明るい近代的の俳句であり、万葉集あたりの歌を聯想される。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は関西の人であり、元来が南国人であるけれども、好んでまた南国の明るい風物を歌ったのは、彼自身が気質的にも南国人であったことを実証している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若葉の青色と、城の白堊とが色彩の明るい配合をしているところに、この句の絵画的のイメージがあり、併せてまた主観のヴィジョンがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鮮緑といふやうな明るい感じがすきだから、百姓風のぢみくさい気分は陰気でいやだ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間でも建築でも、田舎風の煤ぼけた者ががやがや混み合つて居るのでなくして、都会風の明るい感じの者で、小ぢんまりとして居る所が好い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣装にすれば色彩の鮮明な、白とか、青とか、水色とかいつたやうなものが好く、建築にすれば、感じの薄暗い田舎風の家より、明るい西洋建築や、軽快な都会風の家屋が好い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るいといふでもなく、暗いといふでもなく、言はばその明暗の中間が伊香保の気分であらう。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜荒物屋の裏を通ったら、雨戸を明け放して明るい座敷が見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も新しい主婦の晴れやかな顔を見て、何となくこの店に一縷の明るい光がさすように思うた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気な根津辺に燻ぶっていて、時たま此処らの明るい町の明るい店先へ立つと全く別世界へ出たような心持になって何となく愉快である。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プランクの明るい感じと反対にアドルフ・シュミット教授は何となく憂鬱な感じのする人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻眼鏡でぬうっと澄ましていて、そうして何でも実によく知っているルーベンスの傍に、無邪気で気軽く明るいプランクがいて、よくわれわれでも知っているような実験的の事実を知らないで質問する、若い連中が得意になってそれを説明するのを感心して謹聴していた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワールブルヒは腎臓でもわるいかと思われるように顔色が悪く肥大していて一向に元気がなかったが、ゴールトシュタインは高年にかかわらず顔色も若々しく明るい上品な感じのする人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い廊下のドアを開けて、室へはいると世の中が明るい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、この母と娘は氣が合つて、いつも何かと笑ひ騷ぎ、そのために、この家庭は、お旦那の苦蟲を噛みつぶしたやうな表情にもかかはらず、まづ明るい印象を人に與へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音をたてると私の心が揺れる、目が薄明るい地平線を逐ふ……黒々と山がのぞきかかるばつかりだ――失はれたものはかへつて来ない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は愈よ明るい、氷の海は一層の白を加うると共に、一分の硬味を減じて来た雪になったのである、玉屑累々ともいうべき空に懸れる雪の大路を無形の手で、橇を縦横に掻き廻しはじめたと見え、捏ね返した痕跡が割れ目を生じたころは、雪は一方に堆く盛り上られ、一方では掬われたようにげっそりと凹む。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして所々に露出した山骨は青みがかつた真珠のやうな明るい銀灰色の条痕を成して、それがこの山の立体的な輪郭を鋭く大胆なタッチで描出してゐるのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして所々に露出した山骨は青みがかった真珠のような明るい銀灰色の条痕を成して、それがこの山の立体的な輪郭を鋭く大胆なタッチで描出しているのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムッシュウ・ドュフランは呆れた顔をして夕暮の明るいイタリー街へ出た。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかるいランプの光は人々の赤い顔に映えて何となく陽気に見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
