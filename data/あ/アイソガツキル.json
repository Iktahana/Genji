    "definitions": [
      {
        "index": 1,
        "gloss": "to be disgusted with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
