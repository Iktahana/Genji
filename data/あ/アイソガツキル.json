        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "何度も約束を破る友人には、さすがに愛想が尽きたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夫の金遣いの荒さと生活態度の無責任さには、もうとっくに愛想が尽きている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "二転三転する政府の答弁に、多くの国民は愛想が尽きかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "言い訳ばかりで責任を取らない部下に、ついに上司も愛想が尽きたようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "度重なる仕様変更と理不尽な要求を繰り返すクライアントに、担当者もすっかり愛想が尽きてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「このソフトウェアはバグが多すぎる。サポートの対応も悪いし、もう愛想が尽きたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あれほど信じていたパートナーに裏切られたのだから、愛想が尽きるのも無理はない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "何度目標を立てても三日坊主で終わってしまう。そんな自分の意志の弱さに愛想が尽きそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "やっぱり自分自身に就て愛想が尽きる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女同士の咄を聞いてゐると、大抵な女には愛想が尽きる。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを考えると、俺はいつも、自分のばからしさに愛想が尽きる。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は時たま自分の顔を鏡に見て、そのあまりにまとまりのないことに愛想が尽きることがある。",
              "citation": {
                "source": "顔の美について",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山も笑いを含み「だが大原君、その大食を見てはお登和さんも愛想が尽きるだろう」妻君「オホホ、モー疾くに尽きているのです」○熱海のポンスは柏屋にて発売す。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、しまいには愛想が尽きるだろう。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの時の有様を思い出すたびに、なんで、あんな、さもしい料簡になったものかと、吾ながら愛想が尽きる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の岩屋の修行というのは、つまり斯うした失敗とお叱言の繰りかえしで、自分ながらほとほと愛想が尽きる位でございました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前という者に愛想が尽きると、俺は急にあの彫刻が恋しくなったんだ」「厭だよ。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛想が尽きるだろう」「なあに、あなた……」　この舌たるい言葉を、神尾は二様の意味で聞きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが、今夜のおれと来たら……」　と、豹吉は自分の醜態にあいそがつきるくらいだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞうさがなさすぎて、あいそがつきるじゃねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだからあっしゃ、だんなながらときどきあいそがつきるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈はとにかく痛い事は痛い、たださえ骨套的に出来上って居るかおを左頬をプクンとふくらませて八の字をよせて居る顔はさぞマアと思うとあいそがつきるほど腹が立ってしまう。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の人の気まぐれにもほんとうにあいそがつきる様だ。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つく／″＼作者の阿呆さにあいそがつきる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きっと、ひイひイいわせてやるぞ」「これは、いよいよ、あいそがつきる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたがい、若い頃の、破れ垣、夕顔棚の貧乏暮しのときから、褌一ツで、肝胆のかたらいもし、出ては、莫迦もしあい、ときには喧嘩もし、（貴様の、いいところには、ずいぶん惚れるが、阿呆なところには、つきあわんぞ）　一方がいえば、一方も、（おぬしの短所は、あいそがつきる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
