    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese curry with an additional topping (e.g. shredded beef, hayashi-rice sauce, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
