    "definitions": [
      {
        "index": 1,
        "gloss": "section of village",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まだ一字も書いてはなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ十字疾行する街路のうへそのするどさに日輪もさけびくるめき群集をこえて落しきたるを感じいのり齒をくひしめ受難の日のひくれがたわれつひに蛇のごとくなりて絶息す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情慾萩原朔太郎手に釘うて、足に釘うて、十字にはりつけ、邪淫のいましめ、齒がみをなして我こたふ。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学といふものが、凡そ文字を知つてゐれば、誰にも読むことが出来るといふことからして、余りに文士志望者が容易に生じるといつた現状だが、文学を仕事とするからには、※ルレーヌの言葉を以てすれば、「自分の通り道にあつたものだけを読むだけ」の努力では何にもならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが事実はそんなにアツサリ文字通りのことではない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チエツ、またこのまづい字か……」といふ程の意味で、それでもその文字がいかにもその女らしいことには、私は何時でも微笑むのである。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」云ひながら彼（一字不明）その面積の広い赫ら顔をシカめて、その前で手を振るのだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（書き始める）女　まあ奇麗な字を書くわねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――（少し早口になる）「私は自分が向ふへ歩いてゐるのか、自分が向ふから蒼白い顔で歩いて来てるのか分らない時がある――十字路で、みんなの元気な顔、殊には出遇つて互に喜ばしさうな挨拶を交はしてゐる人達をみる時。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野蛮人』という言葉は、彼の語藻において『西洋人』と同字義であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の知ってた日本文字は、片仮名のイロハと僅少の漢字にすぎず、彼の語る日本語は、焼津からの手紙にある通り、不思議な文法によって独創された、子供の片言のような日本語である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ヘルン自身には、英字新聞しか読めなかったから。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本字の読めないヘルンは、その『怪談』や『骨董』やの題材を、主として妻の口述から得た。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處で「跳び込む」といふ語を使つたのは、眞にそれが文字通りであつたからだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に月々の「文藝春秋」に出すアフォリズム風の文字（侏儒の言葉）は、機智のために機智を弄する弄筆者流の惡皮肉で、憎惡的にさへ不滿を感ぜずに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は彼の作品について、時にしばしば一種の鬼氣を――支那の言語で、丁度「鬼」といふ字が表象する所の悽愴感を――感じてゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の容貌や風格に、そのユニイクな文字や書體に、そしてとりわけ作品や會話の中に。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋の落ちかかる日の光で、人々は石碑の文字を讀むであらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれが文字の腐蝕を防ぎ得るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘字か、どうか不安なのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この茶碗に書いてある文字、――白馬驕不行。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（書きしだい、文字が乾く。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を執っても原稿用紙の隅に自分の似顔画を落書したりなどするだけで、一字も書けない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭座といふ名前が「火」の字に関係があるから焼けたのだといふ噂も聞きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭座という名前が「火」の字に関係があるから焼けたのだという噂も聞きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は苦笑しながら、「ところで、あの山は、」と云ひかけると、龜はまたあざ笑ひ、「ところで、とは大きく出たぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざれた恋の火傷の痕である。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
