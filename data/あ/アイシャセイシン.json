    "definitions": [
      {
        "index": 1,
        "gloss": "spirit of dedication to one's company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
