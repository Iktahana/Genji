          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日ＲＣについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＲＣの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＲＣが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＲＣについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＲＣの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＲＣが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＲＣという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＲＣについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＲＣは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＲＣが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＲＣは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＲＣの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＣは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＲＣは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "響け猪木の「ダーッ」コール低価格ＳＰＡＲＣ攻勢の彼方にサンの新必殺技の予兆を見る　バクダッドの空に、アントニオ猪木が吼えている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ハードウエアでは、独自に開発したＲＩＳＣタイプのマイクロコンピューター、ＳＰＡＲＣのデザインを半導体メーカーにライセンスし、ハード・メーカーにＳＰＡＲＣマシンの開発を促して、標準アーキテクチャを確立する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しがらみを捨てても速さを目指したいワークステーションでは、一時期これが大いに受けた）「標準ＳＰＡＲＣマシンで統合版ＵＮＩＸを走らせる」　サンは戦略的課題をここにおいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアントニオ猪木が真の最強者は誰かというアイデアにしびれて異種格闘技路線にのめり込んでいったように、ＳＰＡＲＣと統合ＵＮＩＸをコンピューターの全領域にまたがるプラットフォームとするという壮大な夢を描き始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "上はクレイがシェアを握るスーパーコンピューターから下はマッキントッシュの領域まで、ＳＰＡＲＣアーキテクチャに貫かれたＳＰＡＲＣｉｎｃｌａｙ（クレイに引っ掛けたダジャレ）からＳＰＡＲＣｉｎｔｏｓｈ（マッキントッシュに引っ掛けたくだらないシャレ）に至るマシンによってカバーするというのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ＳＰＡＲＣと統合ＵＮＩＸを武器に異種格闘技戦に乗り出し、コンピューターの全領域を支配するというサンの約束は果たされていない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンは誰が何といおうとＳＰＡＲＣを推進するし、アップルは自分でマッキントッシュのＯＳをＲＩＳＣに乗せる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＳＰＡＲＣの対抗馬に当たる、ミップス製のチップを選んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを従来の自社のＲＩＳＣチップＳＰＡＲＣに加えて、インテルのマイクロコンピューターにも載せ、幅を持ったＨＭＮＭプラットフォームとしようということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼネラルエレクトリックやウェスティングハウス、ＲＣＡなどのエリート技術者たちから情報を引き出し、マイクロコンピューターの売り先を考えるべきである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに先だってＲＣＡ社との技術提携に踏み切った日立製作所は、提携先の路線にもとづいてＩＢＭ機用に開発されたプログラムをそのまま利用できる互換路線をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプソンによれば「Ａｌｔｏは一五〇〇台製作され、ゼロックスやさまざまな外部の組織に広く普及しましたが、その影響というのは、ほとんどがＰＡＲＣを訪問した人たち――たいていの場合、夏期学生としてＰＡＲＣに滞在した人とか見学者とかを通じてのものでした」という。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイによれば「ＰＡＲＣでは、とくに私のグループではデモは生活の一部という感じで、じつにたくさんやりました。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ゼロックスのパロアルト研究所は、しばしばＰＡＲＣ（Palo Alto Resarch Center）と略して呼ばれている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★古山良二が２２０３用にコンパイラーを書き、ＮＡＲＣと名付けた当時の状況は、前出の『日本のコンピュータの歴史』第３部、第４章「日本電気」に以下のように記述されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また古山良二は科学計算用のコンパイラＮＡＲＣを開発したが、これは我が国最初の商用コンパイラであった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで君は、こういう奇妙な紋章を今まで見たことがあるだろうか」と法水が指先で突いたのは、ＦＲＣＯの四字を、二十八葉｜橄欖冠で包んである不思議な図案だった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『遠距離制御台ＲＣ一号』というネーム・プレートがうちつけてありますよ」　戸山が、博士にいった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにを考えてＩＲＣ（万国赤十字）の仕事なんか手伝っていたのか気がしれない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のパァティって、赤坂のＫ会館前であるＩＲＣの主催の、日本代表の送別会のことではございませんか。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もお手伝いにまいりますんですが」「あたしよく知らないのよ」「ＩＲＣの主催ということになりますと、治外法権ですから、いくら憲兵でも踏みこむわけにはいきませんでしょう」「そういうものなの。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の脇間の柱にびっくりするほどたくさん花をつけた、繁みのような薔薇の大枝が飾ってあって、白髪の、知的ないい顔をしたＩＲＣのグルネルさんとルロォさんが立っていて、ていねいにお辞儀をした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣの日本代表の下で働いていたひとに逢うために来た」「そのひとは雄か否」「否。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさんあたりから今夜のパァティのことを聞いて、満寿子さんが来ていると思って、誰かのタクシードを借りてそっと見にきたというわけなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさん、ペン・クラブの人達、モギレフさん、Ｍ・Ｊ博士、ローマン・カラーのいつかのカトリックのお坊さんなどの顔が見える。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
