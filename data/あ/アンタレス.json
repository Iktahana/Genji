        "examples": {
          "standard": [
            {
              "text": "私は毎日アンタレスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンタレスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンタレスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンタレスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンタレスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンタレスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンタレスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンタレスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンタレスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンタレスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンタレスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンタレスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンタレスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンタレスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昨夜焼け跡の防空壕から仰いだアンタレスは不吉な赤さで搏動していたが、今夜この平静な渓間から望めば、何か親しみたい気を起こさせる。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其第一星たる可き山は、どうしても三宝山で、中央のアンタレスの位置に在る甲武信岳では無い。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の空の星で、ぼくが一番なつかしいのは、さそり座とその主星アンタレスである。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスは赤い星である。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスの名は、「火星の敵」という意味だそうである。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスはさそりの心臓である。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスから左下にならぶ星は、ゆるい曲線でＳの字の下半分を書いて、いかにもさそりの尾を想わせる。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスは南の空であまり高くない。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレス自身はまことに巨大な星である。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径が太陽の二百三十倍もあるというから、もし太陽とアンタレスが入れかわったとしたら、地球の軌道がちょうど呑まれるくらいである。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "星の新しい進化論では三転して、アンタレスを老成した星と考えている。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽も、やがてはこのアンタレスのように、巨大な星にふくれ上ると考えている。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして巨大な、アンタレスのような星になるのか。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスの研究などはスペイス・リサーチのなかに入っていないからである。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタレスが星の生涯のどの時期にあたるのかも、変ってくるかも知れない。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれとは別に、夏の夜、西の空にいそぐさそりの姿を見、アンタレスの光のゆらぎを見るとき、年老いた星があえぎつつある姿と想像することは、いつの日にも許される、詩なのであろう。",
              "citation": {
                "source": "太陽を呑む赤い老星の秘密",
                "author": "畑中武夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
