        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "久し振りの好い秋日和で、澄み切った日光の中に桜の葉が散っていた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其處で、昨日穿いた泥だらけの高足駄を高々と穿いて、此の透通るやうな秋日和には宛然つままれたやうな形で、カラン／＼と戸外へ出た。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁菜の秋日和も見られますよ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・青田おだやかな風が尾花のゆるゝほど・秋暑く何を考へてゐる・こゝにも家が建てられつゝ秋日和・何もかも虫干してある青田風　八月廿四日秋、秋、秋寒く秋暑し、夜は秋にして昼は夏なり。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の肌にしみ込んでくる、この秋日和の物倦い眠たさに就いて、この古風なる私の思想の情調に就いて、この上もはや語らないであらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日和の三時ごろ、人の影より、黍の影、一つ赤蜻蛉の飛ぶ向うの畝を、威勢の可い声。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それもならず……」　と思入ったらしく歎息したので、成程、服装とても秋日和の遊びと見えぬ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が終って間もなく、ある野外音楽会の実況放送があったが、紹介の放送員はさすがに戦争中と異った型を出そうとしたらしく、「ここ何々の音楽堂の上の青空には、赤トンボが一匹スイスイと飛んでおりまして、まことに野外音楽会にふさわしい絶好の秋日和でございます」と猫撫声に変っていた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち秋日和に窓を開けていて、又岡田と会釈を交す日があっても、切角親しく物を言って、手拭を手渡ししたのが、少しも接近の階段を形づくらずにしまって、それ程の事のあった後が、何事もなかった前と、なんの異なる所もなくなっていた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……樹島は赤門寺を出てから、仁王尊の大草鞋を船にして、寺々の巷を漕ぐように、秋日和の巡礼街道。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に踞んだまま、女房の、藍微塵の太織紬、ちと古びたが黒繻子の襟のかかったこざっぱりした半纏の下から、秋日和で紙の明るい上框の障子、今閉めたのを、及腰で差のぞき、「可塩梅に帰りましたね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨオロッパでは寒さが早く来ますから、こんな秋日和の味は味うことが出来ませんね」と、秀麿は云って、お母あ様に対して、ちょっと愉快げな笑顔をして見せる。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂や小石は多いが、秋日和によく乾いて、しかも粘土がまじっているために、よく固まっていて、海のそばのように踝を埋めて人を悩ますことはない。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんによい秋日和じゃよ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　葉山へ移つてから、二三日の間は、麗かな秋日和が続いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼栗の匂　秋日和の此頃の日光の中にゐると、私の体から焼栗のやうな匂がして来る。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい秋日和であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵞鳥10・22（夕）　ずつと以前、丁度この頃のやうな秋日和に東京の近郊、雑司が谷の附近を｜いてゐると、一人の洋画家が古ぼけた繻子張の蝙蝠傘の下で、其辺の野道をせつせと写生してゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月七日　まつたく秋日和。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ほんに秋日和の、つるんでゐる豚・焼跡に日が射してがらくた・そよぎつつ草枯れる水音　十一月八日　九日一人、月がよかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに好い季節だ、もつたいないほどの秋日和だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "申分のない秋日和、松茸が食べたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起帰庵、何と好い秋日和。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、ぶら／＼歩きたくなつて山口へ、一片の雲影もない秋日和である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　好い秋日和。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君を待ちつつ支度をする、今日もまた松茸に豆腐のチリだ、待ちきれないで一杯やつてゐると、めづらしくも女と子供の声が山の方へ行く、何ともいへない秋日和である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十八日　晴、秋日和である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
