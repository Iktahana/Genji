        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿婆擦れについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この阿婆擦れは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が阿婆擦れについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は阿婆擦れの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では阿婆擦れが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から阿婆擦れを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも阿婆擦れが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では阿婆擦れが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも阿婆擦れは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも阿婆擦れは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で阿婆擦れは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に阿婆擦れについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "阿婆擦れの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する阿婆擦れの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では阿婆擦れの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "男に、「阿婆擦れ」だの「淪落の男」だのということが云われずに女ばかり体で価値をつけられることの腹立たしさ！",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こう云っているうちにも、阿婆擦れた女などが、そなたの恋人――いずれ、しおらしい、初心の栞殿の恋人ゆえ、同じ初心のしおらしい殿ごでござろうが、その殿ごへ、まとい付いて……」　栞の顔色は次第に変り、眼が、地面の一所へ据えられた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拙者、先ほど、阿婆擦れた女などが、そなたの恋人へ附きまとうやもしれずと申しましたな。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もしまた妾が傾城上がり……」「ええ」「阿婆擦れ女であろうとも……」「いいや決して捨てはしない！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭領の焦れている阿婆擦れだ、とっ捉まえて連れて行き、うんとこさ褒美にあずかろうぜ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品で、阿婆擦れで、派手好きで、おしやべりで、食ひ辛坊で――」　平次も少し呆れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂ぎった妖艶なお楽と、鉄火で阿婆擦れで男のように啖呵を切るお町と、出戻りとはいっても、美しくて賢いお品の間に挟まって、一と晩さいなまれたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品で、阿婆擦れで、派手好きで、おしゃべりで、食いしん坊で――」　平次も少し呆れました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ヘエ――」「ところで、兼松ほど夢中になった人間でも、お小夜のような阿婆擦れ女の命と、自分の命と取り換えちゃかなわないとおもったんだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "活き仏",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾らお紋が阿婆擦れでも、好きでこんな事をするものかね、みんな正さんと楽しくやって行きたいためじゃないか。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿婆擦れ女を送れば良かったの！",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「大勢を手に掛けたとあって、　錦糸堀五百石の御邸は　御取り潰しになり……」　「とうとう浪人生活」と云えば、五郎蔵「そりゃそうだろう」半次尚も、Ｔ「その上、　そのおきよって女が　見掛けによらんあばずれでしてね」　と話し続ける半次。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともの奴はおかめっ面のあばずれだって。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふところに来る芸者だから、三味線もよく弾けないやうな人達だつたけれども、その中の一人は、まだ十八九にしか見えない小柄な女の癖に、あばずれたきかん気の人らしかつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばずれ女の亭主が歌つたおまへはおれを愛してる、一度とておれを憎んだためしはない。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう女としての見所もない大あばずれだと私達はきいて居た。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなあばずれのいった言は、ナニ、蚊が鳴いたのだと思召しまし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなおかの女が驚きを深くしたことは、夫人の面貌や態度に、今までに決して見かけなかった、捨て鉢であばずれのところを現わして来たことだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の愛する女を人に奪られて――」　あばずれた言葉を言わなければならない羽目にある自分を憐れむためか、それとも単に激情が形に浸み出すのか、わたくしの眼から涙が零れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は町の者で非常なあばずれである。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばずれた女であるに相違ないことは知つたけれど自分の感情は其爲に損はれなかつた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "店にしゃがんで、番頭と何か話しているあばずれたような女中までが目にとまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊いお品をこのようなよごれものといっしょに投げ込んでおきますようでは、心がけのほどもまずまずあまり上等ではござらぬゆえ、逃げ隠れたところも、ばくち宿か、あばずれ者の根城か、いずれにいたせあまり感心のできる場所ではござるまい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕様のない、あばずれの、わがまゝの、手のつけようのないこの女を、なぜあの人は打つて／＼、ぶちのめして、その腕の力が萎えると共に、私を抱へて泣いて／＼は呉れないのだらう！",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、早く事の頂点に達したさに、あばずれた言葉で無茶に叫ぶ。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いきなり新宿のカフェーであばずれかかった女給としておふみが現れたとき、観客は少し唐突に感じるし、どこかそのような呈出に平俗さを感じる。",
              "citation": {
                "source": "「愛怨峡」における映画的表現の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、牢やの中のあばずれは、ともかく表現したこの女優が、この人間的飛躍のクライマックスでしめした日本式転身の姿に、うたれた。",
              "citation": {
                "source": "復活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、お前なんぞよりやアあばずれでない純粹の令孃をでも戀ひしてゐる意味か？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、――私、母あちやんて人はあばずれだと思ふわ」　何を云ひ出すのかと、秀一は、あばずれか、とをかしがつた。",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉御とは本當は姉御前の尊稱で、御とは敬し親しんだ呼び名ゆゑ、母御前とおなじに、よばれて嬉しい名でなければならないのを、きやん（侠）な呼名に轉化してしまつて、あばずれといふふうになつてしまつてゐる。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
