    "uuid": "51046e4d-662a-5c06-b97d-c3b9ac30a850",
    "entry": "足長おじさん",
    "reading": {
      "primary": "あしながおじさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anonymous scholarship system for orphans whose parents have been killed in traffic accidents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "読者の中に、もしか「あしながおじさん」という岩波文庫から出されている小説を読んだ方がありはしないだろうか。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしながおじさん」は有名なアメリカのユーモア作家マーク・トウェンの姪、アリス・ウエブスター（一八七六年―一九一六年）によって書かれ、やはり孤児院で育った娘ジャーシャの物語である。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、作者は、ジャーシャを孤児の境遇から幸福で富裕な近代若夫人に育て上げるために「あしながおじさん」というほとんどロマンティックな青年貴族をもち出している。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど少女を主人公として、その苦悩を描いた作品はイギリスの「セーラ・クルー物語」アメリカの婦人作家ウェブスターの「あしながおじさん」（岩波文庫）などのほか、フランスではジョルジ・サンドが「愛の妖精（ファデット）」（岩波文庫）などで描いている。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
