        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時は唯赤面してればよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤面を回避しようとするや、君は君の芸術を絞めにかゝつてゐるのだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は赤面し、「私のは批評ではない、これは、訓戒といふものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浦島は赤面して草履を脱いだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」龜はすかさず口をはさんで、「ひよつとしたら、この掛橋も浦島の若旦那を歡迎のために、乙姫さまが特にさかなたちに命じて、」「あ、これ、」と浦島は狼狽し、赤面し、「まさか、それほど私は自惚れてはゐません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと阿呆な言葉ばかりを連發し、湯氣の出るほどに赤面いたしました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」牝狐は赤面して、大急ぎで巣の方へ走つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま紹介されると、それは新聞の三面記事のようなジャーナリズムの臭味の強烈なものであって、紹介された学者を赤面させるようなものである。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は皆に哄笑され、赤面して座にもどつたが、しかし自分としては、とにかく一部の意志と感情とを、いくぶん會衆に代辯したやうに思つて滿足した。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私は水島や助手や看護婦の前に、いやさうして尚ほも脣を動かし續けてゐるお前の前に佇んでゐる堪らない苦痛と、赤面と、恥ぢと、戰きとにあらがつて行く事は出來なくなつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀み返してみると、あまい所や、ひどく不手際な所などあつて、作者は赤面するばかりである。",
              "citation": {
                "source": "『女性』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、はにかんで、赤面し、微笑してゐました。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "題が、いけなかったんだよ、ええっと、何だったっけな、「或る踊子の問わず語り」こっちが狼狽して赤面したね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか赤面していたのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半三郎は赤面しいしい一礼して、急ぎ足に大根畠を踏み分けて行った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く……」　そんな問答をしているうちに、松石君はやっと昨夜の事を思い出したので、思わず頭を掻いて赤面したと言う。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はすっかり赤面し恐縮してしまった。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔じゅう赤面しながらそれでも恥ずかしさを見せまいとするように白い歯なみをあらわにほほえんでファニーはつかつかと私の前に来て、堅い握手をした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、銅像が赤面した。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、市郎は返事に困って、思わず父の方を顧ると、安行は小半町ばかり先の木蔭に立って、此方を凝と見詰めているので、市郎は何とも無しに赤面した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から私は財布の中にいくらはいつてゐるか知らずに飲食したり買物したりして、勘定が足りずに赤面することがしばしばであつたが、矢野精養軒の主人はそんな時気前よく、いつでもようござんすと貸してくれたものである。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の愚問を恥じて又赤面した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあの鼓をお打ちにならないからだと申します……オホ……ほんとに失礼なことばかり……」　未亡人は赤面して私の顔を見た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日のラジオは、君には聞かせたくないと思い、君に逢ってもその事に就いては一言も申し上げず、ひた隠しに隠していたのですが、なんという不運、君が上野のミルクホオルで偶然にそれを耳にしたという事で、翌日ながながと正面切った感想文を送ってよこしたので、私は、まことに赤面、閉口いたしました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパートの窓のすぐ近くの電線に、奴凧が一つひっからまっていて、春のほこり風に吹かれ、破られ、それでもなかなか、しつっこく電線にからみついて離れず、何やら首肯いたりなんかしているので、自分はそれを見る度毎に苦笑し、赤面し、夢にさえ見て、うなされました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、女のいないところに行くんだ」　うわっはっは、とまず、ヒラメが大声を挙げて笑い、マダムもクスクス笑い出し、自分も涙を流しながら赤面の態になり、苦笑しました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさましく、かえって鴎外のほうでまごついて、赤面するにちがいない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしく不器用で、赤面しながら、とにかく私が、女学生と亭主の側からも、少し書いてみました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、今まで六回、たいへん下手で赤面しながらも努めて来たのは、私のその愚かな思念の実証を、読者にお目にかけたかったが為でもあります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
