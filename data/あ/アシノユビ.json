        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「福岡の小母さんは別嬪だけれど、足の指が、右だか左だか一本ないさうな……」　何時ぞや、父がそんなことを言つてたのをフト思ひ出した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで手足の指などは自分のからだの一部とは思われないように冷え凍えてこちこちしている代わりに頭の中などはいいかげんにあたたかいものがよい程度に充実しているような気がしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼砂が足の指先に、ザクザク障るので、闇の中でも裾野を歩くという意識があるだけだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてシンミイダンスが終って素足の踊子達が誇らしげにテーブルのうえに美しく化粧された足の指を投げ出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして足の指の爪を毒々しいまっかな色に染めているのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に一人が喜助と云う身で、若い妓の袖に附着く、前後にずらりと六人、列を造って練りはじめたので、あわれ、若い妓の素足の指は、爪紅が震えて留まる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走の算段に驅け※つて五味坂で投出された、此の時は、懷中げつそりと寒うして、心、虚なるが故に、路端の石に打撞かつて足の指に怪我をした。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の小波が誘うように、雪なす足の指の、ぶるぶると震えるのが見えて、肩も袖も、その尾花に靡く。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見れば雪の寒紅梅、血汐は胸よりつと流れて、さと白衣を染むるとともに、夫人の顔はもとのごとく、いと蒼白くなりけるが、はたせるかな自若として、足の指をも動かさざりき。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその下に胴を作り、足を作ってしまいますと、今度は髪毛をたたき出し、眼鼻を刻みつけ、耳から手足の指から爪まで作りつけて、まるで女神のように美しい女としてしまいました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青扇は素裸のまま脱衣場の畳のうえにべったり坐って足の指の爪を切っていたのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濱邊若ければその瞳も悲しげにひとりはなれて砂丘を降りてゆく傾斜をすべるわが足の指にくづれし砂はしんしんと落ちきたる。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅田はもっともらしい顔をして、「なあに、秘伝というほどの事でもないが、問題は足の指だよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのように、ほうら、こんな工合に足の指先でさぐると見つかる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の鱶がもう三尺大きい奴だったら、彼は、足の指を三本喰切られただけでは済まなかったに違いない。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱶のいる海に跳び込んで足の指三本を失ったことは不幸のようだが、それでも脚全体を喰切られなかったことを感謝しよう。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に、美的趣味に於て亡国の民は黙々として、足の指先の病を憂へるやうに、俛首れて不可思議の音楽を聞いてゐた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足の指を我と折って、頭髪を掴んで身悶えしても、婦は寝るのに蝋燭を消しません。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の病院で、二月以上煩ったが、凍傷のために、足の指二本、鼻の尖が少々、とれた、そげた、欠けた、はて何といおう、もげたと言おう、もげた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄は陣形を十二段に構え、迂廻軍の到着迄持ちこたえる策をとり、百足の指物差した使番衆を諸隊に走らせて、諸隊その位置をなるべく保つようにと、厳命した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとひぢを張つたやうに、傾斜にたへて前へついてゐた両の前足の指が内へまくれ込むと、いもりは力なく前へのめつてしまつた。",
              "citation": {
                "source": "志賀直哉氏の作品",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこらじゅうにある食物をできるだけ多く占有するように両の前足の指をできるだけ開いてしっかりおさえつける。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな円柱形の幹を両腕と両膝とでできるだけしっかり抱き、手でどこかとび出たところをつかんで、素足の指を別のにかけながら、ジュピターは、一、二度落ちそうになったのをやっとまぬかれたのち、とうとう最初の大きな樹の股のところまで這い登ってゆき、もう仕事は実質的にはすっかりすんでしまったと考えたらしかった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "白百合が裂けたように釣られた両足の指が反って震えて、素足です。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の指に力はないが、気に打たれたか、ひょいと腰、ひょろり板の間の縁が放れて、腰障子へふッと附着く。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　其の裳の触るゝばかり、すツくと枕許に突立つた、私は貝を磨いたやうな、足の指を寝ながら見て呼吸を殺した、顔も冷うなるまでに、室の内を隈なく濁つた水晶に化し了するのは蝋燭の鬼火である。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こわいわねえ」と、お花は自分の足の指が、先きに立って歩いているお松の踵に障るように、食っ附いて歩きながら云った。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今人物の鼻の頭を描いてゐたかと思ふと、次の筆は足の指を描くといふ描き方ではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "小肥りで背たけは姉よりもはるかに低いが、ぴちぴちと締まった肉づきと、抜け上がるほど白い艶のある皮膚とはいい均整を保って、短くはあるが類のないほど肉感的な手足の指の先細な所に利点を見せていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
