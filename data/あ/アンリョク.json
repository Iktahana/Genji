        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗緑について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗緑という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗緑の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗緑が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗緑を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗緑について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗緑の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗緑の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗緑が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗緑という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗緑という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗緑についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗緑を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗緑は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗緑について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗緑が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗緑は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗緑の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗緑は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗緑は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雨上りのせいもあろうが、樹木の緑の色がいかにも落着いた、重厚な、しかも美しい暗緑色をしている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バックに緑色の布のかかった箪笥があって、その上に書物や新聞の雑然と置いてあるのがいかにもうるさくて絵全体を俗悪にしてしまうから、あとからすっかり塗りつぶしてそのかわりに暗緑色の幕をたれたようなぐあいに直してみた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗緑色に濁った濤は砂浜を洗うて打ち上がった藻草をもみ砕こうとする。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自分の花豆は胚葉が出たばかりであるのに、此所の花豆はもう大きな暗緑の葉を三つづゝも擴げてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い色のはあるまいと思うけれども、その黒百合というのは帯紫暗緑色で、そうさ、ごくごく濃い紫に緑が交った、まあ黒いといっても可いのだろう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は貝母に似て、暗緑帯紫の色、一つは咲いて花弁が六つ、黄粉を包んだ蘂が六つ、莟が一つ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日別段気にもとめなかった、小さなその門は、赤いいろの藻類と、暗緑の栂とで飾られて、すっかり立派に変っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道は暗緑色の草が殆ど土を隠す程茂っていて、その上に荷車の通った輪の跡が二本走っている。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の酒場夜の酒場の暗緑の壁に穴がある。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嫌なら、あの暗緑色の深いところへ、はいつてゆかねばなるまい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生とヒビスカスの花とに囲まれた・暗緑色の木造二階建、赤屋根の家は、ひどく土人達の眼を驚かせた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の色は暗緑で陸近いほうは美しい浅緑色を示していた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、はるかの谷底には暗緑色の椴松林帯が広がり、その梢の枯枝が白骨のように雨ざれているのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒雲空を蔽ひて、海面には暗緑なる大波を起し、潮水倒立して一條の巨柱を成せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に夕陽は震怒したる海の暗緑なる水を射て、大波の起る處雪花亂れ翻れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ遥に空を衝いて、雲のその夜は真黒な中に、暗緑色の燈の陰惨たる光を放って、大屋根に一眼一角の鬼の突立ったようなのは、二上屋の常燈である。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蝦蟇出の急須に絹糸の切屑のように細かくよじれた、暗緑色の宇治茶を入れて、それに冷ました湯を注いで、暫く待っていて、茶碗に滴らす。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみの為か心なしやつれの見える夫人の容貌は、暗緑の勝ったアフタヌーン・ドレスの落着いた色地によくうつりあって、それが又二人の訪問者には甚らなく痛々しげに思われた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しい暗緑の瞳は、涙よりももっと輝く分泌物の中に浮き漂った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物すごく底光りのするまっさおな遠洋の色は、いつのまにか乱れた波の物狂わしく立ち騒ぐ沿海の青灰色に変わって、その先に見える暗緑の樹林はどんよりとした雨空の下に荒涼として横たわっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ての樹が裸かになった中に、この樹だけは幽鬱な暗緑の葉色をあらためなかった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い冷たいその海の彼方には、暗緑の鳥喰崎が、折りからの雲の切れ目を鋭い角度で射通した太陽の点光に照らされて、心持ち赤茶けながらくっきりと映えあがって来た。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも亜太郎の倒れていた東室の窓からも、目前五、六十｜米突のところに南室の窓から見えるのと同じような形の一群の木立があるにはあるが、これは明かに白緑色ではなく、明るい日光の下にハッキリと暗緑色を呈していた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　成る程、薄暗の中に一層暗くなっていなければならない筈の暗緑色の木立は、なんとした事か疑いもなく南室から見える木立と同じように、明かに白緑色を呈している。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、昼のうちは暗緑色の小葉を開いていて、夕方になると、眠るように葉の表面をとじ合わせて、白っぽい裏を出してしまう……」「成る程……判りました。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗緑色の葉のあいだにその白い花が夢の如くに開いて、夢の如くに散る。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の面までが、冬らしい暗緑色を捨てて、鮮やかな緑色に凪いでいた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、この室は私自身が、プライベェトに借り、私が勝手に展望室と名づけてゐるのであつたから、漁場の休みにも営業にも関はりのあるわけではなかつたが、私の春愁の夢が恰も四囲に暗緑の深い帷を降して、幻想の昼寝に閉ぢ込るにふさはしい日々なのであつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の実の黄色、葉の暗緑、光りの斑点などを此処から遥かに見晴すと丘のあたりは恰度派手な絨氈だ。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
