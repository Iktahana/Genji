        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルファベットについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルファベットの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルファベットが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルファベットについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルファベットの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルファベットが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルファベットという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルファベットについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルファベットは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルファベットが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルファベットは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルファベットの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルファベットは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルファベットは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして薔薇の匂という一般的なものと回想という特殊なものとの連合によって体験を説明するのは、多くの国語に共通なアルファベットの幾字かを並べて或る一定の国語の有する特殊な音を出そうとするようなものであるといっている｛３｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信機の方はピアノの鍵盤のようなものにアルファベットが書いてあって、それで通信文をたたいて行くと受信機の方ではタイプライターが働いて紙テープの上にその文句をそっくりそのままに印刷して行く仕掛けである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、今度はアルファベットになった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、又、「アルファベット数えてしまえば、親爺や、お袋がいるところへ帰って行けるんかな。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベットを操る間絶えず胸に描いていた美しい、魅力のある内地が、あの封筒一ツに覆がえされてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、アルファベットとアラビア数字がきれぎれに、一字一字、全部で三十字ほど折れ釘のように並んでいた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の詩人ルクレチウスは、物質の原子はちょうどアルファベットのようなもので、種々な言語が有限なアルファベットの組み合わせによって生ずるごとく、各種の物質がこれら原子の各種の組み合わせによって生ずると書き残したが、この考えは近世になって化学式というものによっていくらか科学的に実現された。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここに述べられたアルファベットが寄り集まっていろいろな語を作るように、若干の異種の原子がいろいろに結合していろいろのものを作るという彼の考えはほとんど現在の考え方と同様である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずおもしろい事には現在われわれは原子の符号にアルファベットを用い、しかもまたいろいろの物質をこれら符号の組み合わせで表わすのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも種々に異なる語に共通なアルファベットがあるようなものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四つのアルファベットの組み合わせ自身に何かしら不快な暗示を含んでいるのか、それともいちばん初めに聞かされた音の不快な印象が、この音を聞くたびに新しく呼び返されるのかもしれない。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、一等賞にたいしては、アルファベットのはじめのほうからかぞえていく。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベットを、最初のＡからかぞえていくと、八番めの文字はＨとなる。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の文明と芸術とは、このアルファベットの第一音から、改めて建設されねばならないのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄、赤、青のネオンサインは街の中空へ「夏はドウヴィルへこそ」とアルファベットを綴っている。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古譚詩は凡てＨ氏が島々の故老に尋ねて歩いて、アルファベットを用ひて筆記するのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古譚詩は凡てＨ氏が島々の故老に尋ねて歩いて、アルファベットを用いて筆記するのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に私の手に入ったものは、ごく短いものだったので、この記号はアルファベットのＥを表わすものだと云うことを、云い切られただけでした。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じの通り英語のアルファベットの中では、Ｅは最も普通の文字で、どんな短い文章のなかでも、一番出て来る文字ですからな。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、両手を挙げたこの人形は、アルファベットのＥであると。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存じの通り、Ｅというのは英語のアルファベットで最もよく使われ、その頻度は、どんな短文にもたくさん見つかるほどです。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん多い記号は8だから、まずそれを普通のアルファベットのｅと仮定して始めることにしよう。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、この空いているところへ当てはまる文字としてアルファベットを一つ残らず調べてみても、th がその一部分となるような語ができないことがわかるからなんだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして僕たちはt eeに局限され、そして、もし必要ならば前のようにアルファベットを一つ一つあててみると、考えられる唯一の読み方として‘tree’という語に到達する。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "表示する文字を、アルファベットの暗号ではさんだようなポストスクリプトのデータは、この通信の仕組みを利用して、そのままやり取りできます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ68は、基板に組み込んだ蛍光表示管に、アルファベットと数字を出すように作られています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "典書書体と呼ばれるこのタイプの活字を用意するにあたって、グーテンベルクはアルファベットそれぞれの大文字と小文字を鋳出すだけですませてはいません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
