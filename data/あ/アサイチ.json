        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝市の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから朝市の大きな西瓜、こいつはごろごろして台へ載りにくかったのをようやくのせると、神様へ尻を向けているのは不都合じゃと云い出してまた据え直す。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曳いて來たは空車で、青菜も、藁も乘つて居はしなかつたが、何故か、雪の下の朝市に行くのであらうと見て取つたので、なるほど、星の消えたのも、空が淀んで居るのも、夜明に間のない所爲であらう。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "透かして見れば帳場があって、その奥から、大土間の内側を丸太で劃った――（朝市がそこで立つ）――その劃の外側を廻って、右の権ちゃん……めくら縞の筒袖を懐手で突張って、狸より膃肭臍に似て、ニタニタと顕われた。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曳いて来たは空車で、青菜も、藁も乗って居はしなかったが、何故か、雪の下の朝市に行くのであろうと見て取ったので、なるほど、星の消えたのも、空が淀んで居るのも、夜明に間のない所為であろう。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隠は朝市に隠る、と。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向って鳥居から町一筋、朝市の済んだあと、日蔽の葭簀を払った、両側の組柱は、鉄橋の木賃に似て、男も婦も、折から市人の服装は皆黒いのに、一ツ鮮麗に行く美人の姿のために、さながら、市松障子の屋台した、菊の花壇のごとくに見えた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目指す博物館を目の前にして、聖堂を見上げるベンチに腰を下ろし、しばらく朝市の賑わいを味わいました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市に出るものは出、一軒一軒裏口から「おかみさん」と云って廻って歩くものは歩く。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市に間に合うのだそうである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市の間に合うのだそうである。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の店には、朝市へ買出しに行つた車がまだ歸つて來ないので、昨日の賣殘りが四種五種列べてあるに過ぎなかつたが、然しお定は、其前に立つと、妙な心地になつた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の店には、朝市へ買出しに行つた車がまだ帰つて来ないので、昨日の売残りが四種五種列べてあるに過ぎなかつたが、然しお定は、其前に立つと、妙な心地になつた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園から清水あたりまで行くこともあつたし、電車で北野の天神さんへお詣りに行つたり、時には東寺の朝市などへも連れて行つた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市には、ニースに滞在している人たちが、買出しかたがた散歩に出て賑わしかった。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は青物の朝市がある。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人物の口からこんな文句が出るかというに、にわか散切りの西洋ごしらえ、フランスじこみのマンテルにイギリスのチョッキを着け、しかもそれは柳原あたりの朝市で買い集めた洋服であり、時計はくさりばかりぶらさげて、外見をつくろおうとする男とある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡山ニ抵ルニ朝市マサニ散ゼントシテ日影食時ニ向フ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市へ行く八百屋さんが見つけて大騷ぎになり、係り合ひの町役人や、彌次馬まで加はつて搜した揚句、間もなく首のない死骸が水際の藪の中から見つかり、それが見知り人があつて、豊島町一丁目で公儀御用の紙問屋｜越前屋の大番頭清六と判つたのは、大分陽が高くなつてからでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市へ行く八百屋さんが見つけて大騒ぎになり、係り合いの町役人や、野次馬まで加わって捜した揚句、間もなく首のない死骸が水際の藪の中から見つかり、それが見知り人があって、豊島町一丁目で公儀御用の紙問屋｜越前屋の大番頭清六と判ったのは、だいぶ陽が高くなってからでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが河井から京都の朝市の事を聞き、早朝の市日を熱心に漁った。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市にぬれて並べる　鱈の魚の腹今年　雪いまだ到らず。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝市長と牧師が城に呼ばれた。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都に在住の間、私の心をいたくそそったものの一つは朝市であって、私は中々勉強した。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝市というのは月のうちの日と所とをきめて、少くとも朝の六時頃から立つ市なのである。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、それ等の朝市に凡て出掛けるとすると、大小合せ、驚く勿れ、一ヶ月のうち二十日余りもあるそうである。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと双壁をなすのが毎月二十五日の天神の朝市で、つまり北野天神の境内境外にぎっしり立つ大きな市である。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも、けじめなく売る是等の朝市は、私共には大いに魅力があった。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの朝市には五時から六時頃の間に、手車で品物が運ばれてくるのだが、車が止まるのを待ち受けているのは小道具屋連中で、めぼしいものが先ずぬかれて了う。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ほどの朝市では決してない筈なのだが、それでも見過ごして了うには、勿体ない猟場であった。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
