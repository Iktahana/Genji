[
  {
    "uuid": "40f1a26b-2d2a-5b2c-873a-d0ddfca6edc3",
    "entry": "哀れむ",
    "reading": {
      "primary": "あわれむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to pity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日哀れむについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "哀れむという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は哀れむの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には哀れむが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "哀れむを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは哀れむについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "哀れむの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は哀れむの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では哀れむが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れむという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に哀れむという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では哀れむについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "哀れむを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると哀れむは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れむについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では哀れむが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀れむは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により哀れむの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "哀れむは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に哀れむは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "殺されて行く獅子を哀れむ心を生じるだけの余裕があるであろうか。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはもちろん子を哀れみまた自分を哀れむ複雑な心理が伴なってはいるが、しかしともかくもそうした直接行動によって憤怒の緊張は緩和され、そうして自己を客観することのできるだけに余裕のある状態に移って行くのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなでもいろいろなふしあわせを主観して苦しんでいる間はなかなか泣けないが、不幸な自分を客観し哀れむ態度がとれるようになって初めて泣くことが許されるようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ哀れむべきやつサ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同病相哀れむ心から私は急いでそこを通り過ぎねばならなかった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同病相哀れむゆえんであろうか。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れむべき小雀は魂も消える許りに打倒れて、一言の弁解さへ口から出なかつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は漸く寂しく、冬は霜枯れの哀れむべきを免れざるなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽ける者は人の饑餓に臨めるを見ては、余計に之を哀れむの情を催す道理がある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最近の彼女の吉本についての思い出は、たいてい彼を哀れむ感情に変わってきていた。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が運命は決して此哀れむべき俺を哀れんで呉れなんだ。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその手紙も未だ着かざる可きその日の夕刊にて自分は彼哀れむ可き考古学者戸田元吉が佐竹廃園の丘上に他殺されその死体が発見された事を知つた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "此哀れむべき婦人を最後の一滴まで搾取した、三人のごろつき共は、女と共にすっかり謎になってしまった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らは、あらゆる瞬間の極度の緊張と、注意とにもかかわらず、自分の運命を哀れむのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに類する、哀れむべき不具な一個が彼の性質の何処かに一つ凸出してゐるに相違ない――そんな想像を回らせてゞもゐないと彼女は、我慢することが出来なかつた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と老婢ともまた屹度この哀れむべき娘のことに就いて、頼り無い噂を交はして居るのであらう。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五夜の月が、淋しく物思う地上の一人子を哀れむように照らしております。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう他の惑星の高等生物をまだわれわれが一度も見たことがないという理由によって、そういう高等生物が存在しないというものがあったとしたら、それは、余程の楽天家か、愚鈍の者か、さもなければ哀れむべき想像力の貧困なる者である。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　福沢氏はかう言つて、画家の杉浦氏を哀れみ、杉浦氏に連れ添つてゐる自分の妹を哀れむやうな眼つきをした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三がわざと擬装しているとでも思ったらしく、葉子は外へ出てからも、ここで別れる彼を哀れむように自身もいつか自身の言葉に感傷を誘われたふうで話しつづけた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "処女のような含羞があるかと思うと、不良少年のような聡慧さをもっていたが、結局人間的には哀れむべき不具者としか思えなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇雲に先きを急ぐやうな若い時の焦躁が、古いバネのやうに弛んで、感じが稀薄になるからでもあるが、一つは生命の連続である子供達の生長を悦ぶ心と、哀れむ心が、自分の憂ひを容赦してくれてゐるのであつた。",
              "citation": {
                "source": "風呂桶",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは、女をいかなる醜悪な場面、条件においても理解すべきもの、哀れむべきもの、或は愛し尊敬すべきものとして観察し、女の情慾をもある時は一つの驚くべき力として感じている。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島を哀れむのは、全体、正しいと言えるのか？",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら物語の最後ではそういう形で人との間にきめられている関係が、三郎爺をもルスタムをも、哀れむべき存在とし残酷に扱われた人間としていることを作者が見のがしていないことである。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第二巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "否寧ろ、哀れむべきとも云える。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性の感情の至純さと、素質の平等、一言に云えば夫人の良人に対する知と云うものに尊敬の払えないような、所謂男らしい欠点を多大に持った人は、こちらの女性に対して、彼の持つ、哀れむべき尊厳を犯される不安から、虚勢を張ってけなしてしまいます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等三つの群のほかに、勿論、或一点を堂々廻りして只平安に生きて死んで行く多くの人々と、アメリカの婦人の一部として、殆ど何人の注意も引かれずに、明光のささない穴ぐらの中で一生を送るような、哀れむべき貧民階級の婦人のあることは事実でございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れむべき良人は、正直に彼女を愛すが故に正直に怒りますでしょう。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは私たちの「逆廻り」を、うさんくさそうな傍目を使って、あわれむが如き素振りでゆき過ぎた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
