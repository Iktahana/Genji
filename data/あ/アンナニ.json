        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あんなにについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんなにという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんなにの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんなにが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんなにを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんなにについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんなにの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんなにの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんなにが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんなにという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんなにという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんなにについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんなにを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんなには複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんなにについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんなにが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんなには重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんなにの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんなには様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんなには興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」と彼は思ふ、「あんなにアラがあるから、あのアラが契機となつて、却て奴等は仕事が出来るのであらう……」　ところでさういふ場合に彼のアラと云つてゐるものは、概ね処世的要領の稚拙の如きを指してゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用しないのに何もかも彼の云ひなりに返事をしたといふのも変なものだが、尤もあんなに三田村が感激してゐる時には……どうも困る。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中に、あんなにグロテスクな嘘をさかんに書き並べて、こんどはくるりと裏がえしの同様の嘘をまた書き並べています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに降つてるわよ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他のことなら此方から訊いたつてロク／＼答へない男が、自分の好きなことならあんなに訊かない先に答へるんだ」と兄は思つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝まであんなに騒々しかった家内はしんとしてあまりに静かである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると精が「居る居る――要太郎があんなに走り出したらきっと鴫が居る」と云う。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにじやんじやん水を注ぎ込まれちや、處置に窮しますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞珠は、捨てられて、あんなに高い山になつてゐるぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう言へば、まあ、さうだが、」と浦島はさらに櫻桃の酒を調合して飮み、「あのお方は、何かね、いつもあんなに無口なのかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんを可愛がりすぎるのも見ちやをられないものだが、あんなに無愛想なのもよろしくない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、あんなにあそこに集ってる処を見りゃあ、外の処が手薄になってるに決ってる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに沢山ある貝が食べられないものかと子供の時によく考えたことだが、それがフランスへ行って、始めて子供の時の不審を解決することが出来た。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあんなに元気に手をあげたカムパネルラが、やはりもぢもぢ立ち上ったまゝやはり答へができませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにくるっとまはって、前の方へ来た。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにうしろへ行ってしまったから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、きれいでせう、あんなに光ってゐます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、　あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、あんなにとれたらたくさんだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてあんなになったんですか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間は二人を並べて置いて、お母さんにあんなに叱られたじゃありませんか。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さんはさっき何を考えてあんなに脇見もしないで歩いていたの」「わたし何も考えていやしません」「民さんはそりゃ嘘だよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子も真の親の様に思ってくれ私も吾子と思って余所の人は誰だって二人を兄弟と思わないものはなかったほどであるのに、あとにも先にも一度の小言をあんなに悔しがって夜中泣いて呉れなくともよさそうなもの。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆんべあんなに泣いたは全く私が悪かったから、全く私がとどかなかったのだから、お増や、お前がよく申訣をそういっておくれ……」　それからお増が、「お母さんの御立腹も御尤もですけれど、私が思うにャお母さんも少し勘違いをして御いでなさいます。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は死ぬのが本望だと云ったか、そういったか……家の母があんなに身を責めて泣かれるのも、その筈であった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時母に送った手紙に「あんなに不器用では実験家として成効しそうもない」と云ってこの政治家の余技を評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛のあんなに細い弱い糸の網で大きな蝉が捕られることから考えると、蚊帳一張りほどもない網で一台の飛行機が捕えられそうにも思われるが、実際はどうだか、ちょっと試験してみたいような気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際の競馬ではああした番狂わせにはめったに出くわせないであろうし、また観客はカメラのようにあんなに勝手に位置を変えて自由に見どころを得られるはずはないのである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天プラや、すしなどがあんなに恐ろしい鬼気をもって人に迫り得るという事を始めてこの画から教えられる。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が平常どんなところでもあらはに聞かなかつた言葉をあんなに露骨に云はれるとなにより先に全く變な氣になる。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
