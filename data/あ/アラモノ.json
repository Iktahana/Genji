    },
    "definitions": [
      {
        "index": 1,
        "gloss": "household tools (e.g. brooms, dustpans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒物について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒物という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒物の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒物が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒物を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒物について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒物の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒物の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒物が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒物という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒物という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒物についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒物を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒物は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒物について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒物が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒物は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒物の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒物は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒物は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暗闇阪を下りつめた角に荒物屋がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振りむいたとき見ると荒物屋の娘であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る年の春、上野の花が散ってしまった頃、ある夜膳を下げに来た宿の主婦の問わず語りに、阪の下の荒物屋の娘が亡くなったと云う話をした。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜荒物屋の裏を通ったら、雨戸を明け放して明るい座敷が見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やもりと荒物屋には何の縁もないが、何物かを呪うようなこの阪のやもりを行き通りに見、打ち続く荒物屋の不幸を見聞きするにつけて、恐ろしい空想が悪夢のように心を襲う。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日経て後の夕方、荒物屋の座敷には隣家の誰れ彼れが大勢集まって酒を酌んでいた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿の主婦は、荒物屋には若い好い後妻が来たと喜んで話した。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の夏、荒物屋には幼い可愛い顔が一つ増した。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では場末の荒物屋芋屋でもこれを使っている。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の台地から田端の谷へ面した傾斜地の中腹に沿う彎曲した小路をはいって行って左側に、小さな荒物屋だか、駄菓子屋だかがあって、そこの二階が当時の氏の仮寓になっていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く……」　半五郎、　「石松、早く仕度をしねえか」　「へえッ」Ｓ＝荒物屋の二階　お半其処を間借して料理屋にでも勤めるんでしょう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下で荒物屋の親爺が呼んでいる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝荒物屋の階下　石松、上り框に腰掛けて草鞋をぬぎ乍ら親爺に　「爺っつあん、今日俺の来た事ァ内緒だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｓ＝階下　鶴吉に荒物屋の親爺が、　「鶴さん、先刻石さんが帰って……」　「何んだ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物屋｜駄菓子屋の店先に客引きの意味でかかっている写真の顔が新聞やビラの広告に頻繁に現われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてそれを送って行った母が部屋へ帰って来て、またしばらくしてのあとで、母は突然、「あの荒物屋の娘が死んだと」　と言って吉田に話しかけた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その荒物屋というのは吉田の弟の家から辻を一つ越した二三軒先のくすんだ感じの店だった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなふうではじめ吉田にはその娘のことよりもお婆さんのことがその荒物屋についての知識を占めていたのであるが、だんだんその娘のことが自分のことにも関聯して注意されて来たのはだいぶんその娘の容態も悪くなって来てからであった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の人の話ではその荒物屋の親爺さんというのが非常に吝嗇で、その娘を医者にもかけてやらなければ薬も買ってやらないということであった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうはいっても吉田は、いつも家の中に引っ込んでいて、そんな知識というものはたいてい家の者の口を通じて吉田にはいって来るのだったが、吉田はさっきの荒物屋の娘の目高のように自分にすすめられた肺病の薬というものを通じて見ても、そういう世間がこの病気と戦っている戦の暗黒さを知ることができるのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はこれまでこの統計からは単にそういうようなことを抽象して、それを自分の経験したそういうことにあてはめて考えていたのであるが、荒物屋の娘の死んだことを考え、また自分のこの何週間かの間うけた苦しみを考えるとき、漠然とまたこういうことを考えないではいられなかった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "素面ではさすがにぐあいが悪いと見えてみんな道化た仮面をかぶって行くことになっていたので、その時期が来ると市中の荒物屋やおもちゃ屋にはおかめ、ひょっとこ、桃太郎、さる、きつねといったようないろいろの仮面を売っていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は博多｜竪町の荒物屋渡世……当年五十六歳で……ヘエ……」　と淀みなく言ううちに涙ぐんだ赤んべえ面を上げて水洟を一つコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは役柄をもって相尋ねるが、その方は只今も申す通りズット以前は博多の荒物屋渡世。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "親友の黒田が先年まで下宿していた荒物屋の前を通った時、二階の欄干に青い汚れた毛布が干してあって、障子の少し開いた中に皺くちゃに吊した袴が見えていた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄く照して来る荒物屋の店の灯かげでお涌がすかして見ると、小さい生きものは、小鼠のような耳のある頭を顔中口にして、右へ左へ必死に噛みつこうとしている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の荒物屋が背後へ来て、あの、また変な声で、御新姐様や、といいはしまいかと、大抵気を揉んだ事ではない。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいや思いもかけぬといえば、荒物屋の、あの老婆。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所に、癩病医者だと人はいうが、漢方医のある、その隣家の荒物屋で駄菓子、油、蚊遣香までも商っている婆さんが来て、瓦鉢の欠けた中へ、杉の枯葉を突込んで燻しながら、庭先に屈んでいるが、これはまたお雪というと、孫も子も一所にして、乳で育てたもののように可愛くてならないので。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目の浜の石屋が方へ、暮方仏像をあつらえに往った帰りを、厭な、不気味な、忌わしい、婆のあらもの屋の前が通りたくなさに、ちょうど満潮を漕げたから、海松布の流れる岩の上を、船で帰って来たせいであろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
