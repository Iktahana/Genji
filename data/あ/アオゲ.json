    "definitions": [
      {
        "index": 1,
        "gloss": "black (horse coat color)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "黒い毛氈の上に、明石、珊瑚、トンボの青玉が、こつこつと寂びた色で、古い物語を偲ばすもあれば、青毛布の上に、指環、鎖、襟飾、燦爛と光を放つ合成金の、新時代を語るもあり。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "壊れバケツに金紙の両眼を貼り、金の髭をつけ、それを一人が冠って、その頭から青毛布の波を躍らしうねらし、一人がその尻にもぐって担ぎあげて、飛んだり跳ねたり、それが日本医専の獅子舞であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、青毛布のバケツ頭の金の眼の獅子の勇気は譬えようもなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしだ、それも二度か三度か跳ね廻ると、意外にもくたくたと解体して、青毛布は尻尾の方にずるずると持って行かれてしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄の嫡子、太郎義信は時に二十四歳、武田菱の金具｜竜頭の兜を冠り、紫｜裾濃の鎧を着、青毛の駿馬に跨って旗本をたすけて、奮戦したことは有名である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の下は青毛氈を敷いたように芝草が生えていた。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後へ来た青毛布のぢいさんなどは一向匂ひなにかには平気な様子でただ虎のでけえのに驚いて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎が、茶の毛糸と青毛糸とをいかにも間に合わせに継いで寸法をのばしたジャケツを着、ゴム長をふんばって、わきからそれを眺めている。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いすみっこに、色のさめた、黒い太い縞のある、青毛布が丸くなっていた。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青駒」はいわゆる青毛の馬で、黒に青みを帯びたもの、大体黒馬とおもって差支ない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島の馬市からの戻りと見えて、青毛の親馬のほかに、当歳らしい一匹の子馬をもそのあとに連れている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "表庭の早い椿の蕾もほころびかけているころで、そのあたりにつながれている立派な青毛の馬が見える。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は当時の旅人と同じように、黒い天鵞絨で造った頭陀袋なぞを頸にかけ、青毛布を身にまとい、それを合羽の代わりとしたようなおもしろい姿であったが、短い散髪になっただけでもなんとなく心は改まって、足も軽かった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "二匹の馬は、一匹は青毛で、もう一匹は栗毛でしたが、彼等は私の顔と両手をしきりに見ていました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、青毛の馬が前足の蹄で、私の帽子をグル／＼なでまわしました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから青毛が近寄って来ると、「ヤーフ　ヤーフ」　と教えるように二度繰り返しました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "青毛の方が私を振り返って、手まねで歩けと言いました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "青毛は、そこで私に待っておれと合図しました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "青毛は、その部屋に入って、三四度いなゝきました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、そのとき、青毛が戸口から顔を出して、私に入れと合図しました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、青毛の方をかえりみては、お互に何回となく、この「ヤーフ」という言葉を繰り返しているのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "青毛は私の方へ首を向けて、「フウン、フウン」としきりに繰り返しました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとそのとき、青毛が私を招いて、こちらへ来て立て、と命じました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼上野の動物園にいって見ると（今は知らぬが）前には虎の檻の前などに来るともの珍らし気に江戸児のちゃきちゃきなどが立留って見て鼻をつまみながら、くせえくせえなどと悪口をいって居る、その後へ来た青毛布のじいさんなどは一向匂いなにかは平気な様子でただ虎のでけえのに驚いている。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「静まれ静まれ南の御奉行様の御出役だぞッ」　人波を別けて、悠然と現われたのは、暴民鎮圧に向った南町奉行鳥居甲斐守忠燿、青毛の馬に跨がり、裏金の陣笠を夕陽に輝やかせ、鞭を挙げて高々と叱咤します。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夕方毎に、日の名殘のなかで、暖かい間は、頭も考へもめつきり好くなつて來る祖母イヴォンヌと戸口の前に腰をおろして、彼女はヤンのために美しい漁夫用の青毛の襯衣を編んでゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころ虫の食った青毛氈のかけてある卓を中にして腰をおろすと、先生はすぐたずねた。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルには相変らず虫のくった青毛氈がかけてあり、「思無邪」と書いた正面の額も、昔どおりであった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々の背後から付いて来た、青毛のすらりとした小馬に乗つた男が、己の橇の側へ駆け寄つて、帽を脱いで礼をして、微笑んだ。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は青毛の馬にのつた業平朝臣といつしよに、老人に別れをつげて去つた。",
              "citation": {
                "source": "五月の雉",
                "author": "蔵原伸二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
