[
  {
    "uuid": "913dcde0-1bd6-5f08-8ae1-260d2b7c8a11",
    "entry": "赤門",
    "reading": {
      "primary": "あかもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
