    },
    "definitions": [
      {
        "index": 1,
        "gloss": "red gate (esp. at Tokyo University)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "赤門からはいって行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるバスの女車掌は大学赤門前で、「ダイガクセキモンマエ」と叫んでいたそうである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤門を潜り込んで、講座へ這い上ろうとする候補者は――勘定して見ないから、幾人あるか分らないが、一々聞いて歩いたら余程ひまを潰す位に多いだろう。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千余年の長夜の暗漸やく明けて、この国に新らしき生命の光もゆるや、彼も亦単身｜孤塁、吟杖を揮つて赤門校裡の書窓より新声を絶叫したるの一人なりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時は大学の中を抜けて赤門に出る。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤門を出てから本郷通りを歩いて、粟餅の曲擣をしている店の前を通って、神田明神の境内に這入る。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田が赤門から出て右へ曲ることのめったにないのは、一体森川町は町幅も狭く、窮屈な処であったからでもあるが、当時古本屋が西側に一軒しかなかったのも一つの理由であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日程前の午過ぎ、友人に頼まれた或る本を探すために、本郷通りの古本屋を一通り漁った私は、かなり眼の疲れを覚えながら、赤門前から三丁目の方へ向って歩いていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二木検事と村井記者は、同期の、赤門出の法学士だった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤門には清正公が祭ってある。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……樹島は赤門寺を出てから、仁王尊の大草鞋を船にして、寺々の巷を漕ぐように、秋日和の巡礼街道。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤門寺のお上人は、よく店へお立寄り下さいますが、てまえどもの方の事にも、それはお悉しゅうございましてな。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお仏師から手紙が添って――山妻云々とのお言、あるいはお戯でなかったかも存ぜぬが、……しごとのあいだ、赤門寺のお上人が四五度もしばしば見えて、一定それに擬え候よう、御許様のお母様の俤を、おぼろげならず申伝えられましたるゆえ――とこの趣であった。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん赤門の側にも、オレをくぐらせる度量などなかったろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞといふと赤門の学士会のと同類の力を頼りにして威張たがる。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくしてＳ・Ｓ・Ｓというは一人の名でなくて、赤門の若い才人の盟社たる新声社の羅馬字｜綴りの冠字で、軍医｜森林太郎が頭目であると知られた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然、万年上田博士が帰朝して赤門派が崛起すると硯友社の勢威が幾分か薄くなった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの赤門派の新進作家の。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤門の前を通るはずの電車は、大学の抗議で小石川を回ることになったと国にいる時分新聞で見たことがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤門をはいって、二人で池の周囲を散歩した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢よく赤門を引き込ませた時、法文科のベルが鳴り出した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで二人にくっついて池の端を図書館の横から、方角違いの赤門の方へ向いてきた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は赤門の所で二人に別れた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの境内から川端へ抜けるところに赤門があり、夕方になると閉されるが、いつ締まるのか誰もそれを見かけたものがない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "土井晩翠氏はその頃、高山樗牛氏はじめ、赤門出の批評家から頻りに推讚の聲を寄せられてゐましたが、私は土井氏の詩風とはどうも呼吸がぴつたりと合はないものですから、失禮ですが、あまり注意して居りませんでした。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處の角には勸工場と云つて何品でも賣る所があるし、右へ行くと三丁目の電車、左へ行くと赤門の前――赤門といへば大學の事ですよ、それ、日本一の學校、名前位は聞いた事があるでせうさ。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ赤門、『恁事をするものやら遂に解らず了ひ。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処の角には勧工場と云つて何品でも売る所があるし、右へ行くと三丁目の電車、左へ行くと赤門の前――赤門といへば大学の事てすよ、それ、日本一の学校、名前位は聞いた事があるんでせうさ。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
