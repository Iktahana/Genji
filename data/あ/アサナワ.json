        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "麻縄の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一本の麻縄に漸次に徐々に強力を加えて行く時にその張力が増すに従って、その切断の期待率は増加する。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　馬が日射病にかかって倒れる、それを無理に引ずり起して頭と腹と尻尾を麻縄で高く吊るし上げて、水を呑ませたり、背中から水をぶっかけたりしている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械室から暗窖のように暗みわたった下の方へ向けて、太い二本の麻縄が垂れ下り、その一本は下の方に、一本は上の方に静かに動いていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大勢の弟子のうちから、地震に散ばらないのだけ、四五人｜誘合って、てこに、麻縄、鋤、セメントなんどを用意して、シャツにズボンばかり、浴衣に襷がけの勢で推出したんです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、こっちの舟を目がけて長い麻縄を投げてくれた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それから今度は（先刻は縄をつけなかったのだ）両手両足を船の麻縄で縛り上げられた上、隅っこの・島民船員の食料が詰め込んであるらしい椰子バスケットと飲用の皮剥若椰子との間にころがされた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く縄を、笠松博士を掴まえたから」　刑事達はそのポケットから麻縄を出しながらばたばたっと駈けて行った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい笊に麻縄の網を張ったような鳥籠を天秤棒に担いで、矢口の村から余り遠くない池上、大森、品川のあたりを廻っていたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい時には女を素っ裸にして、麻縄で手足を引っくくって、女中部屋に半日くらい転がして置いたこともあるそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておよそ私達を吃驚さした事には、後へ廻された両の手首は丈夫な麻縄で堅く縛られ、すっこきの結び玉から何にかへくくり付けた様に飛び出している綱の続きは、一｜呎程の処で荒々しく千切れている事だ。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い機械油は、手首から麻縄の上までべっとり染み付いている。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論屍体はあの通り麻縄でガッチリ縛り、海の真中へ重を着けて沈めたんさ。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ってあの油は、背中の上部の上衣から、綻びの中のジャケットや擦り破れた肌の上まで、そして縛られた麻縄の表側へまでも、ひっこすった様に着いていたからね。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋の底を織っているのもあれば、麻縄をよっているものもある。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして子供の前掛けのように、胸に、それが明らかに監督の筆致で、「此者ハ不忠ナル偽病者ニツキ、麻縄ヲ解クコトヲ禁ズ」　と書いたボール紙を吊していた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「役人を縛って、強盗呼ばわりをするとは不届きな奴らだ」　かれらはからだ全体を麻縄で厳重にくくり上げられて、いずれも一百ずつ打たれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犯人を見附けました――」　喬介のこの言葉に少からず驚いた私達は、喬介の指差した太い麻縄のロープの一部に、深く染み込んでいる少量の赤黒い血痕を認めた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は二十五六の年増で、引窓の綱らしい古い麻縄で手足を厳重に縛られて、口には古手拭を固く捻じ込まれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銅の板の熱くなった頃に仔猫の胴中を麻縄で縛って、天井から火鉢の上に吊りさげて、四本の足が丁度その銅の板を踏むようにすると、板は焼け切っているから、猫はその熱いのにおどろいて、思わず前後の足を代る代るにひょいひょい揚げる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はその手錠を解いて麻縄で縛つてみると、三郎は以前と同じやうに手首を振つてゐたが、急に険しい眼附になつて、「何にも音がしない、こんな手錠は厭だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何というものか知らんが、下駄の緒の芯にはいる麻縄をよるのだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "田船の舳と艫とには、又別に麻縄が長く結付けてあって、どちらも両方の岸にまで届く程の長さがある。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此所の麻縄は私が世話になっていた阿波の甚右衛門の家から、代々捕縄の古く成ったのを寄進するという。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪屋は、叔母の家から半町たらず下の往来に沿うたところにあったが、狭いじめじめした土間に、水銀の剥げちらした鏡一つと、壊れた脚を麻縄でくるくると捲いた木の椅子が一つあるっきりの身窄らしい理髪屋であった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "油の黒く滲んだ床下に麻縄が解け紊れていて、一見工場の事務室のような待合室は、ソビエットに似合わしい素朴なものだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の手に蝋燭を持つて兄の背後に廻つたが、三筋の麻縄で後手に縛つて柱に括り附けた手首は血が滲んで居る。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　貢さんは勇々として躊躇ふ所なく麻縄を切り放つた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラ十は二人の手をうしろにまわさせて、麻縄でしばった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨居から鴨居へ麻縄を張り渡してあるからでございます。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鉄人Ｑはそういって、きょろきょろあたりを見まわしていましたが、部屋のすみにまるめてあった、あさなわをとって、ミドリちゃんのわきの下にまわし、「さあ、わたしにおぶさるのです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
