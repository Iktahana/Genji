        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日在り来たりについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在り来たりの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在り来たりが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在り来たりについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在り来たりの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在り来たりが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在り来たりという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在り来たりについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在り来たりは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在り来たりが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在り来たりは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在り来たりの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在り来たりは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在り来たりは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "下町の粋と云われる茶屋の板前に感心して見たり、仁左衛門や鴈治郎の技巧を賞美したり、凡べて在り来たりの都会の歓楽を受け入れるには、あまり心が荒んでいた。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで子供を生んでもらうためなんてしらじらしい、ありきたりの嘘を云ったのですか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの気取りに対するたたかいです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の片隅を指先で小さくむしっておいて、結いたての日本髪（ごくありきたりの髷だったが、何という名だか園は知らなかった）の根にさした銀の平打の簪を抜いて、その脚でするすると一方を切り開いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの品物だけれども、大事に取り扱われているためか、その瑠璃色の部分が透明で、美しい光沢を持っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨を入れて蝙蝠傘のような形に作った白紙の笠、これとてもありきたりのものだが、何んとなく清々しくって、注意してみると、一カ所、針の先でいくつとなく孔を明けた所があった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子がそう思ったのは、実は、彼女は昔下鴨から女専へ通っていた頃、やはり同じ下鴨の下宿から三高へ通っている学生に、彼女の方から話しかけて親しくなったあげく、その学生の下宿でありきたりの関係に陥ったことがある。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の事情に就ては述ぶべきことが多いが、何れはありきたりのものだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな白雨のふつてる間どこにも新しい信仰はありはしない詩人はありきたりの思想をうたひ民衆のふるい傳統は疊の上になやんでゐるああこの厭やな天氣日ざしの鈍い季節。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人はありきたりの思想をうたひ民衆のふるい傳統は疊の上になやんでゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い皮膚、薄い下り眉毛、今はもとの眉毛を剃ったあとに墨で美しく曳いた眉毛の下のすこし腫ぽったい瞼のなかにうるみを見せて似合って居ても、もとの眉毛に対応して居た時はただありきたりの垂れ眼であった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がまた追々日がたつに従って私は赫子がやはりありきたりの女性の誰でもと同じように一寸した言葉の間の負けず気や周囲の同性の身なりのほんのつまらない動静にまで皮肉や陰口で意地悪くこせこせするのを見聞するようになり、もはや赫子という女に全然興味を無くして仕舞って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとから取立てるほどのきりやうもなかつたが、それが白髪だらけになると、ただありきたりの老婆だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんな恋はありきたりよ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処中、それ巡拝札を貼り散らしたと申すわけで、中にはな、売薬や、何かの広告に使いまするそうなが、それもありきたりで構わんであります。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とは、書いてあるが、その感激は、ありきたりの悪い文学に教えこまれ、こんなところで、こんな工合に感激すれば、いかにも小説らしくなる、「まとまる」と、いい加減に心得て、浅薄に感激している性質のものばかりなのである。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの言葉、ありきたりのスタイルを以てしても、過不足なく描写出来たと思い込んでしまうのは、自分の人間観察力に与える秩序の正しさを過信しているからだろうか、小説作法の約束というものへの妄信からだろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このありきたりの情熱は一体何としたことであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁が来た日から病に取り憑かれたのだというその意味は、登勢の胸にも冷たく落ち、この日からありきたりの嫁｜苛めは始まるのだと咄嗟に登勢は諦めたが、しかし苛められるわけはしいて判ろうとはしなかった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ伏見の船宿の水六の亭主などは少し怪しい者が泊ればすぐ訴人したが、登勢はおいごと刺せと叫んだあの声のような美しい声がありきたりの大人の口から出るものかと、泊った浪人が路銀に困っているときけば三十石の船代はとらず、何かの足しにとひそかに紙に包んで渡すこともあった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪が栄えて正が虐げられるという・ありきたりの事実についてである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文通の手段の絶たれたマターファは恐らく、スティヴンスンのことを、親切そうなことを言いながら結局何一つ実際にはして呉れない白人（ありきたりの白人）に過ぎなかったのだと、失望しているのではないか？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の家を逃げ出し、それでも送金してゐるといふ点と正直な所が楢雄の気に入り、また、他の店員のやうにケバケバした身なりもせず、よれよれの人絹を着てゐるのも何か哀れで、高槻の下宿へ遊びに来させてゐたところ、ある夜ありきたりの関係に陥つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はちょっと豹一に好感を持ったのだが、こうして今日もまた待ち伏せられてみると、此の少年も矢張りありきたりの不良学生かと思われたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥しさのため腹を立てんばかりに逆上してしまった豹一と、疲労のために日頃の半分も理性が働かなかった多鶴子は、ありきたりの関係に陥った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、かりに理性が真相を探してゆくとすれは、ありきたりの面から離れている点こそ問題なんだよ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの普通の事は全てこれを面白くないとし、怪奇で珍しい事だけを面白いとするのも正を失っているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間ありきたりの法則どおりに継母はこうして苦しめられるのであると思って、空蝉はすべてを自身の薄命のせいにして悲しんでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い監督も彼の父の質問をもっとありきたりのことのように取っていたのだ。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が怖れる割合に、葉子には内田が恐ろしく思えなかったばかりか、その峻烈な性格の奥にとじこめられて小さくよどんだ愛情に触れると、ありきたりの人間からは得られないようななつかしみを感ずる事があった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
