          ],
          "literary": [
            {
              "text": "あんなことあたし達にはないわ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「一生に一度は真剣な気持ちにさせられるものにぶつかってみたいと思うことは、そりゃあたし達にだって、ちゃんとあるわ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○「あたし達に向ってはっきりした考えを言えと言ったって、そりゃ無理ですわ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾ら思つてみても、そんな事、あたし達には駄目なんですもの……」　奧さんはかすれたやうな声で答へながら、青木さんの顏を見上げた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達二人のうち一人が、もし病気になって死んだら、あとは、どうしたらいいでしょうネエ」　そう云ううちアヤ子は、面を真赤にしてうつむきまして、涙をホロホロと焼け砂の上に落しながら、何ともいえない、悲しい笑い顔をして見せました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あたし達ばかり勝手なことを云って飲んでいちゃあ、それこそ失礼だわ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達にはまだ宵の口だわ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達の眼にはなんにも見えなかったけれど……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、あたし達だけ、先に行くわよ。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつも、しっかり鎖でつないで置かないと、あたし達のところから逃げ出してしまうのだよ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてみんな、あたし達のところに、いつかないのだろう。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達、幻を見てゐたのだわ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達はそこの会社の株主でもあり支店でもありますんでね。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はバアの隅の大テーブルに腰掛けようとして思いがけなく女性に辛辣な諷刺文学者フェルナンド・ヴァンドレムが居たのを見ると調子よく――あたし達はあなたの材料になる為に席を茲へ取ったようなものねほほ……。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達の、ほんとの話は、この体操に依らなければならないなんて、何とまあ、窮屈な合宿となつたことだらう。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にも日が暮れると、その六部がときどきたずねて来て、一度は草鞋をぬいで茶の間へ上がって来たこともあるそうですが、あたし達はいつも其の時はお座敷へ出ていたのでよく知りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少女三人はさんざん口ぎたなく云い合いながら、その晩はまず無事に帰ったんですが、あくる日も又それで喧嘩をはじめて、おとくがそんならお前も蛇を掴んでみろ、いくら口惜しがってもあたしの真似は出来まいと云うと、こっちの二人も行きがかりで、何の、あたし達だって掴んでみせると云う。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "気づきますとも、あたし達が星に気づくよりも機敏に、彼等は、素早く見つけ出しますとも――。",
              "citation": {
                "source": "ランプの便り",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フロラ、それは夢だつたのだよ、あの物語をあまり熱心に音読した前夜の労れで――」「あたし達は気づかなかつたけれど、昨夜音読の練習をしてゐた間中、グリツプはこの卓子の下で、聞いてゐたものと思はれるのね。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等だけに対して、そんな規定が出来たといふわけではなくつて……」「そんな憂慮なんてことは知らないけれど、ともかく、お午までにあたし達は……？",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までは、あいつがと彼のことを細君と共々に「あいつが変梃な顔ばかりして稼がうともしないので、あたし達はずろすの掛け換へもなくなつて銭湯へも行かれやしない。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒を入れたか入れないか知らないけれども、なにしろあのおはぎを食べたせいで、あたし達はあんな目に逢ったんですから……。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、千生さんはあたし達の仇じゃあありませんか。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし達は、ほんの前芸ですもの」「前芸でたくさんだよ、この頃は……。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達も加勢に行くよ」と、お花も一緒になって嚇した。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのおかみさんも幾らか面倒をみてくれるでしょうし、あたし達もまあ、ちっとでも何とかしてやりたいと思っているんです」　聞けば聞くほど林之助の胸は痛くなった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……あたし達だけは関はないだらう、ひとりでなほるまでは――。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうしてあたし達は、気がつかなかつたんでせう。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもね、あたし達は好いけれど英一が可愛想だから、残るものなら何とかしてやらうツて、うちのお父さんが云つてゐますよ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな西洋の声色なんかでなく、あたし達にも解る日本のを聞せて下さいよ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
