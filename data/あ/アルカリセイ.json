          "standard": [
            {
              "text": "私は毎日アルカリ性について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルカリ性の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルカリ性が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルカリ性について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルカリ性の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルカリ性が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルカリ性という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルカリ性についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルカリ性は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルカリ性が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルカリ性は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルカリ性の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルカリ性は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルカリ性は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "灰の成分は主に種々の軽金属の酸化物で、なかんずく水に溶ける分は強いアルカリ性でいわゆる灰汁になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唾液は水なり、ムチンの存在によつて粘きも、其実は弱アルカリ性の水にして、酵素のプチアリンを含めるのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸性の土壌では青い花、アルカリ性の土壌では赤い花、それとも逆だったっけ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "正味は、酸性でもアルカリ性でもありはしない。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くうちに裏白の叢は黝ずんでねっとり湿りを含み、臭いもアルカリ性の強い朽葉の悪臭に変って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち今から二十四時間経たない以前にこの紳士は、その女と一緒に或るカフェーでウイスキー入りの珈琲を飲んでいるらしいが、その珈琲にはアルカリ性の毒薬が入れてあった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実物を手に入れた事がないから分析的な内容は判然しないが、強いアルカリ性のものである事は間違いないようである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "唾液は口から出てアルカリ性だから鹹い味だし、胃液は酸いし、肝臓から出る胆汁は苦い。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚を料理する時何故｜酢あるいはレモン汁を使うかという問題は」中川「それは魚の血液がアルカリ性であるから酸類と中和させるのだ」小山「聞いてみると何でもないね、しかし聞かなければ一生知らずにしまう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚のアルカリ性に酸類を中和させるのも今の試験問題にあったろう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この色素で染めた紙は酸性で赤、アルカリ性で緑になった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "金気のある水がよくないことは、前の説明で既にわかっているが、水が酸性を帯びた時と、アルカリ性を帯びた時とでは、何かちがいが無いかという点も調べておく必要がある。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルカリ性の場合は、その反対であって、蒸溜水の場合よりも粒子が小さくなり、おりる量も少なくなることがわかった。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常のコプロスタノンを重水およびアルコールのアルカリ性混合液で沸騰させると、産物にはかなりの量の重水素を含んでいた。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジフテリア菌をアルカリ性のウシ肉汁で８日から10日培養すると特に有毒な毒素を作らせることができる。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄は酸っぱいと云うつもりか後世之を｜酸性・聖書と称えて大いに珍重しているが、そうした誤植のない通俗の聖書をアルカリ性の聖書と謂ってよかろうと思う。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "血液にはアルカリ性色素と親和性をもつ細胞（好塩基球）があり他の種類の細胞（好酸球）は酸性色素に親和性がありさらに他の種類の細胞（好中球）は中性色素と親和性があった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく前から、小麦粉には腐らせると動物物質と同じようにアルカリ性の蒸気を出す物質（グルテン）の含まれることが知られていた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "壊血病は“腐敗”病であり、動物組織は腐敗するとアルカリ性になると考えられていた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "反応がアルカリ性であると変化は急速になる。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            },
            {
              "text": "尿を Nylander 液（＊尿糖の検査試薬）と熱すると試薬のアルカリ性によって暗色化は起きるがビスマスの還元は見られない。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
