        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラバマについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラバマという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラバマの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラバマが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラバマを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラバマについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラバマの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラバマの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラバマが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラバマという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラバマという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラバマについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラバマを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラバマは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラバマについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラバマが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラバマは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラバマの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラバマは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラバマは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "空想のでも、天女や戀人なら、まだしも――架空のでも、おほ鴉やアラバマから來たと云ふ鳥ならまだしも――義雄は身づから部落民だと思ふものを介抱してゐるのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけていわゆる「アラバマ号」問題は、しばしば英米国交の危機をもたらした。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラバマ号事件」というのは、こうである。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラバマ号はその一隻で、「二九〇号」とよばれていた。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六二年六月、英国のバークンヘッドのレイヤード造船所で建造中のアラバマ号は完成にちかづいており、それが軍艦であることも明白になったので、米国公使アダムスは英外相ラッセル伯にたいして、アラバマ号の用途を公文書をもって指摘し、建艦の中止を要求した。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国製軍艦によって沈められた北部の船舶は、拿捕を含めて二〇〇隻をこえるが、アラバマ号は一八六四年六月十九日に沈められるまでの二二カ月間に六〇隻を犠牲にして、最大の損害を与えた。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "南北戦争の結果の一つであるアメリカ商船業の絶望的な後退は、大半アラバマ号の大あばれのせいとされた。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "内乱終了後アメリカは、アラバマ、フロリダ、シュナンドーなど諸艦を建造した英国の中立侵犯に関して、その他の抗議に合せて損害賠償を要求した。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "この交渉はその後数年にわたって米英両国政府のあいだでつづけられたあげく、一八六九年一月十四日、ジョンソン＝クラレンドン条約の調印を見るにいたったが、この条約がかんじんのアラバマ号問題をまったく無視していることが判明するや、がぜん米国の輿論は沸騰し、四月十四日上院で圧倒的多数をもって否決された。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六九年一月―四月、太陰暦では明治元年十一月―明治二年二月はまさにこのような、「アラバマ号問題」をめぐる米英危機の第一波の時期にぞくしていた。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "その期間、「アラバマ問題」の米英緊張はすこしもよくなっていない。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "国務長官フイシュはその間一八六九年六月と、十二月と一八七〇年一月の三度にわたって、アラバマ号問題解決のため英国にカナダ割譲の意志があるかどうか、きわめて外交的な仕方ではあるが打診をくりかえしている。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラバマ号問題」は、一八七〇（明治三）年十二月五日のグラント大統領の例年教書で、がぜん再度の英米緊張をもたらす。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのサルトレーキから、伊藤が東京留守政府の井上大蔵大輔、山県兵部大輔の両名あてに発送した手紙は、日本暦で明治五年正月十日頃にあたるが、おりしも――一八七一年十二月十五日からスイスで開かれているアラバマ号問題仲裁裁判が大暗礁にのりあげて、この問題にかんする最大の英米危機が到来していた。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太平鉄路積雪の為に、既に十有余日山中なる塩湖と云へる市府に淹留、空しく曠日未だ華盛頓府に達する能はず……現今英米両国の間に起りたる“アラバマ”一条｜頗る困難の事情に至り、或は争端を起すも不可測との新聞を屡々検せり。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文中「アラバマ号問題」にかんする記述はすべて宇野君のリポートによったことを記して、同君の御協力にたいする私の謝意を表したい。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理のテストに、メードさんは八分も厚さのあるビフテキを焼いて、でかっぱちもないアラバマ・サンドイッチをつくった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　眠っているうちに、アラバマは通り抜けてしまったのだろうか。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの英米両国政府の間に於て約十年の大懸案であったアラバマ事件が、ゼネバの仲裁裁判所で平和的に解決された如きはその顕著なる実例である。",
              "citation": {
                "source": "文明史上の一新紀元",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニコチン酸が細菌増殖因子であることが見つかった後で、ついに1937年ウィスコンシンでニコチン酸とニコチン酸アミドが黒舌病に対し、そしてアラバマ州では、ペラグラ患者に対しても、高い治療効果を持つことが見出された（58,59）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "この東テュペロからアラバマに向かう道を二マイルほど車で走ったところに、プレスリー家の建物があった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくあと、テュペロで、アラバマ・ミシシッピー・フェアが、開催された。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は、子供のときタレント・コンテストに出たアラバマ・ミシシッピー・フェアだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五五年一二月、アラバマ州モンゴメリーで、ローザ・パークスという黒人女性が、バスの後部座席（黒人の席）にすわることを拒否し、これをきっかけにモンゴメリーでは一〇か月にわたる黒人によるバスのボイコットが成功し、座席差別はおこなわれないことになった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミシシッピー・アラバマ・フェアグラウンズはゲートが開いていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
