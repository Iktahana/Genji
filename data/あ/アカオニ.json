    "definitions": [
      {
        "index": 1,
        "gloss": "red-horned demon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浮世の欲を金に集めて、十五｜年がほどの足掻きかたとては、人には赤鬼と仇名を負せられて、五十に足らぬ生涯のほどを死灰のやうに終りたる、それが餘波の幾万金、今の玉村恭助ぬしは、其與四｜郎が聟なりけり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわれわれの子供の時からおなじみの「赤鬼」の顔がジャヴァ、インド、東トルキスタンからギリシアへかけて、いろいろの名前と表情とをもって横行している。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの人は、うそをつくと死んでから赤鬼に、舌べろを釘ぬきでひっこぬかれるといったものです。",
              "citation": {
                "source": "一年生たちとひよめ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んですかねえ、十文字に小児を引背負って跣足で歩行いている、四十｜恰好の、巌乗な、絵に描いた、赤鬼と言った形のもののように、今こうやってお話をします内も考えられます。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "張抜らしい真黒な大釜を、蓋なしに担いだ、牛頭、馬頭の青鬼、赤鬼。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が前へ、赤鬼が後棒で、可恐しい面を被った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が、「ぼうぼう、ぼうぼう、」　赤鬼が、「ぐらッぐらッ、ぐらッぐらッ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼が最も著しい造声で、「牛頭よ、牛頭よ、青牛よ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤鬼は、直ちに半助の地声であった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　風に乗って、飛んで、宙へ消えた幽霊のあと始末は、半助が赤鬼の形相のままで、蝙蝠を吹かしながら、射的店へ話をつけた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて古色蒼然たる脇立の青鬼赤鬼も、蛇矛、長槍、張飛、趙雲の概のない事はない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれ迷つてゐると思ひますとね、閻魔堂で、羽目の影がちらり／＼と青鬼赤鬼のまはりへうつるのが、何ですか、ひよろ／＼と白い女が。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから褞袍に着かえて、チエ子と並んで夕飯のお膳について、何本もお銚子を傾けた父親は、赤鬼のようになりながら大きな声で、今度初めて行った露西亜の話をした。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼が桃太郎に降参したやうな、そんな恰好をして……一体こりや、何ちふことぢやのう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減につき合って手間賃の分配にあずかろうとしていただけであったのだが、青砥は岸に焚火して赤鬼の如く顔をほてらし、眼をむいて人足どもを監視し、それ左、それ右、とわめき散らすので、どうにも、うるさくてかなわない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、私は怪談が好きで、おそろしさの余りめそめそ泣き出してもそれでもその怪談の本を手放さずに読みつづけて、ついには玩具箱から赤鬼のお面を取り出してそれをかぶって読みつづけた事があったけれど、あの時の気持と実に似ている。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、不思議に客人の気を悪くして、入相の浪も物凄くなりかけた折からなり、あの、赤鬼青鬼なるものが、かよわい人を冥土へ引立てて行くようで、思いなしか、引挟まれた御新姐は、何んとなく物寂しい、快からぬ、滅入った容子に見えて、ものあわれに、命がけにでも其奴らの中から救って遣りたい感じが起った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼、青鬼、白鬼の、面も三尺に余るのが、斧鉞の曲舞する。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「怖がることはない、俺達は此処の爺さんに頼まれて来た者じゃ」　と、赤鬼が云った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼と赤鬼の二疋は、胴を屈めるようにしてあがった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ど、ど、して、遅くなりますものか、小半時もかかりません、どうぞ、ちょっと待ってくだされ、お爺さんがいとしい」「しかし婆さん、俺達は地獄の使じゃ、こんなことを他の人間に話したりすると、俺達も此処にこうしていられん、そんなことは云わずに、金を持って来んといかんぜ」　と、赤鬼が云った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼と赤鬼はその後を見送って、耳を澄ますようにしていた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旨くいったな」「うむ、旨くいった」　と、赤鬼も鉾を襖に立てかけた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よかろう」　と、赤鬼が同意した。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「脱いでも好いだろう」「そうじゃ、脱いでもいいな」　二疋は首の周囲に手をやって、何かかさかさとやっていたが、やがて赤鬼からさきに鬼の顔を除ってしまった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼の面を着ていたのは、壮い色の白い男で、青鬼の面を着ていたのは、頬髯の濃い角顔の男であった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好い物があるぞ」　と、彼は起って仏壇に手をやり、二つの餅を執って来て、一つを赤鬼の男にやってその一つを己の口に入れた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍には赤鬼と青鬼の面もあった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、行って見てもいゝですが、ばあさんの部屋はきれいに片付けられていま魔除けの鍾馗さまの人形が一つ赤鬼をひっ掴んで八方を睨んでるだけでさ」　夜の八時過ぎになるのに母はなか／＼戻って来ませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
