        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これは喘ぐの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "百姓の生きて働く暑さ哉「生きて働く」という言葉が、如何にも肉体的に酷烈で、炎熱の下に喘ぐような響を持っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おふくろが、喘ぐように云ったのと、吉田が、「しっ」と押し殺すような声で云ったのと同時であった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お半……お半」　（お半の声）　「出来るだけ早く帰ってね」　（石松の声）　「お半、下の親爺に聞いたんだけど、お前――」　（お半の声）　「だから、早く帰って来てね」　石松、喘ぐ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にケルソン市の岸に立ち竝んだ例のセミオン船渠や、其の外雑多な工場のこちたい赤青白等の色と、眩るしい対照を為して、突っ立った煙突から、白い細い煙が喘ぐ様に真青な空に昇るのを見て居ると、遠くが霞んで居るのか、眼が霞み始めたのかわからなくなる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末は喘ぐやうにして水を求めて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛乘る瞬間に見た顏は、喘ぐ口が海鼠を銜んだやうであつた。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水には荒れても、稲葉の色、青菜の影ばかりはあろうと思うのに、あの勝山とは、まるで方角が違うものを、右も左も、泥の乾いた煙草畑で、喘ぐ息さえ舌に辛い。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は焚け、草は萎み、水は涸れ、人は喘ぐ時、一座の劇はさながら褥熱に対する氷のごとく、十万の市民に、一剤、清涼の気を齎らして剰余あった。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と喘ぐ、「ですが、私に考えがあって、ちょっと知己になっていたばかりなんです。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷いた野獣が喘ぐようである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずぶずぶに濡れているとみえて髪の毛がべっとりと額にみだれかかっていて、真蒼な顔色をして、おびえ切った様な眼で僕の方を見入り乍ら、何か喋っているのか、しきりと喘ぐ様に口を動かしているのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘ぐように囁やきはじめた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘ぐ馬を驅る　日曜の朝、毛竝の艶艶とした二頭の駿馬を驅つて、輕洒な馬車を郊外の竝木路に走らせる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが風のない曇天の日に、そのだらりとぶらさがつた紙の魚の、息苦しく喘ぐ姿を見る時、世の親たちが、どんな不吉な暗い感じを、子供の將來について豫感するかを思ふのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はわざとキャリコが粗腐病にかかって、身体が錆だらけになり、喘ぐことさえ出来なくなって水面に臭く浮いている姿を想像した。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流動物しか摂れなくなって、彼はベッドに横わり胸を喘ぐだけとなった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸味のある果物は喘ぐように貪り喰った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘ぐ――しかむ、泡を噴く。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁ど居合はせた権七の顔を目を挙げて恁う見ると……日に焼けた色の黒いのが又恐ろしく真黒で、額が出て、唇が長く反つて、目ががつくりと窪んだ、其の目がピカ／＼と光つて、ふツふツ、はツはツ、と喘ぐやうな息をする。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の生活に飽満してもなお美を追求する官能は、逞しく喘ぐ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽欲の極みか、甘き寂寞の大光明、に喘ぐ時。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢ふかき黒髪の奥朱に喘ぐ紅玉ひとつ、これや、わが胸より落つるわかき血の燃る滴。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかあかと日暮の街に吐血して落日喘ぐ寂寥に鐘鳴りわたり、陰々と、灰色重き曇日を死を告げ知らすせはしさに、響は絶えず天主より。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰翳は彼が肋に明暗す一張一弛、カンテラの青み吸ひつつ、縞蛇の喘ぐが如し。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "居常唯だ書籍に埋もれ、味なき哲理に身を呑まれて、徒らに遠路に喘ぐものをして、忽焉、造化の秘蔵の巻に向ひ不可思議の妙理を豁破せしむるもの、夏の休息あればなり。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽喉を切り開かれている将校を見た時には、血の出るのも気付かずに、自分の咽喉仏の上を掻きを引き放されて笑っているような血みどろの顔を見あげた時には、思わず、ハッハッと喘ぐように笑いかけたように思います。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉の喘ぐ呼吸づかいがすぐ背後で聞えた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして被害者と云うのは博士の令嬢です」　青年は眼をきょときょとさせながら喘ぐようにして云うのだった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんに締めつけられて、虎は息苦しそうにはあはあとあえぐのであるが、それでも少しもうろたえたような、弱ったような様子の見えないのはさすがにえらい。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が運動を終ると、あえぐものが水を飲んだときのように彼女は咽喉を一つ鳴らし「もうもう本当にいい気持でしたわ」と襟元を叩いた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
