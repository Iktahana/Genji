          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天邪鬼について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天邪鬼の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天邪鬼が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天邪鬼について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天邪鬼の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天邪鬼が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天邪鬼という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天邪鬼についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天邪鬼は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天邪鬼が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天邪鬼は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天邪鬼の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天邪鬼は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天邪鬼は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "僕はこれからはもう天邪鬼になって、新人がどれだけ巧い作品を書いても、感心しないことにする。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口が腐っても、惚れているとは言わぬ積りだったが、この際は簡単に言ってのける方が、お加代への天邪鬼な痛快さがあった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな無駄なお喋りを、信吉がペラペラと続けていたのは、実は薄井を本来の俗物の地位まで、自分と共にひきずり下したいという天邪鬼からであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天邪鬼のあんたの事だから、きっとそうに違いありませんですわ」　すると池上は諾いて、「それもある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　行くなと言われると、陽子はもう天邪鬼な女だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、京吉が命令するように停めたということへの、天邪鬼の反撥が、陽子の足を田村へ向けたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、それと同じ天邪鬼が、田村へ行く時間を出来るだけ伸ばして、春隆を待たせてやろうという気持を、ふと起させた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな悔恨めいた気持があっただけに、再び戻って来た京吉の言葉をきくと、陽子は思わず起ち上り、日頃の勝気な天邪鬼の手がもはや一皮むけば古い弱い女の手になって、「どうしたの、京ちゃん、おかしい人ね」　ついぞこれまで、どんな男にもあけなかったドアをあけた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金内吉平氏談）　　　　　　　　　　◇　前述のような数々の逸話は、翁一流の天邪鬼の発露と解する人が在るかも知れぬが、そうばかりではないように思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "題は「十銭芸者」――書きながら、ふとこの小説もまた「風俗壊乱」の理由で闇に葬られるかも知れないと思ったが、手錠をはめられた江戸時代の戯作者のことを思えば、いっそ天邪鬼な快感があった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、まるで私を最後の取りかえしのつかない破滅に陥らせるためのように、天邪鬼の心持がやってきた。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は、自分の魂が生きているということと同じくらいに、天邪鬼が人間の心の原始的な衝動の一つ――人の性格に命令する、分つことのできない本源的な性能もしくは感情の一つ――であるということを確信している。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天邪鬼の心持がいま言ったように、私の最後の破滅を来たしたのであった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥へ右といへば左といふ山といへば川といふ行かうといへば帰るといふ御老体は天邪鬼人生をかうヒネクレるまでには相当修業を積んだことでせう、歳月があなたの心を冷え症にしてしまつたのか痛ましいことですあなたの正気からは真実がきけさうもないちよいと旦那酔はして聞きたいことがあるわよ。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女のようなのは、天邪鬼と云うのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女のやうなのは、天邪鬼と云ふのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの愛すべき天邪鬼には、しだいに黙示図の啓示を無視してゆく傾向がある。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作らず、嘘でなく、じっさい僕が聴いた他人の告白なんて――よくよく天邪鬼でないかぎり、いえた芸ではないと思う。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに死とは、脳細胞の活動停止によるところの……」　四、「人生に安心を見いだせなかったのだね」「いや、安心という弱点が充満していることに安心できなかったのだそうだよ」「ふうむ――どこまで天邪鬼なんだろう！",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は要するに天邪鬼さ」（ついでに「ばかだ」と言いたいのだが、言えないのだ）　また、「君は一個のピュリタンだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がピュリタンである以上、君は他人にもピュリタンであることを要求する権利がある」　その時、当の「天邪鬼」は答えたものだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋本の家で貧血を起こして卒倒した時、僕の天邪鬼は勝利の日が来たと叫んだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊124　天邪鬼は、どん底において快哉を叫ぶ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天邪鬼に恰好の断末魔だ」　民衆がこう嘲った。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は天邪鬼と寛大とを交互に享楽した。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の中にある天邪鬼の気弱さがやはり顔を出すのだね」「反対に、ヴァレリイ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをさえ抹殺した「天邪鬼」の見栄と自負。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕の「天邪鬼」の哄笑と比べてみること。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間流に考えるとこの三匹はのんきで無神経で、つまり環境への順応が遅鈍であるのか、それともつむじ曲がりのあまのじゃくであるのかとも思われる。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が曇っていましたので水は灰いろに見えそれに大へんつめたかったので、私たちはあまのじゃくのような何とも云えない寂しい心持がしました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
