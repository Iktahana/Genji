        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そら、大粒の赤玉、白玉のメノーを七宝の青い葉茎がくっきりうけとめている、チューリップ！",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方面の研究者にとっては一つ一つの地震は単に一つ一つの算盤玉のようなものである、たとえ場合によっては地震の強度を分類する事はあっても、結局は赤玉と黒玉とを区別するようなものである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女等がかざしの玉の赤玉に似たるいちごを採りつゝありく奧山の道のへに咲く草花をうらめづらしみ見せまくもとなおぼつかなき歌なり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "道頓堀の赤玉にいた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、赤玉から頼まれてクリスマスの会員券を印刷したのが、そこへ足を踏入れる動機となってしまったのである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って雇人に呉れてやり、お前行けと言うと、われわれの行くところでないと辞退したので、折角七円も出したものを近所の子供の玩具にするのはもったいない、赤玉のクリスマスいうてもまさか逆立ちで歩けと言わんやろ、なに構うもんかと、当日髭をあたり大島の仕立下ろしを着るなど、少しはめかしこんで、自身出向いた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下味原町から電車に乗り、千日前で降りると、赤玉のムーラン・ルージュが見えた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤玉から遠のこうと、なんとなく決心した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、三日経ってまた赤玉へ行くと、瞳は居らず、訊けば、今日松竹座アへ行くいうたはりましたと、みなまできかず、道頓堀を急ぎ足に抜けて、松竹座へはいり、探した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本の顔はしばしば赤玉に現われていたから、見知っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちでの不義理もだんだんに多く、赤玉での勘定に足を出すことも、たび重なった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが昔赤玉で見た坂田の表情にそっくりだと、松本もいきなり当時を生々しく想い出して、「そうか。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、赤玉のムーラン・ルージュが廻らんようになったんは知らんやろなどと、黙っているわけにもいかず、喋っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤玉のムーラン・ルージュがなくなったと、きけば一層大阪がなつかしい。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "道頓堀筋、そこのキャバレエ赤玉の前を通ると、アジャーアジャーと訳の分らぬ唄声、そして途端に流れる打楽器とマラカスのチャイナルンバ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、赤玉がカンバンになると、女と一緒に千日前の寿司捨で寿司をたべ、そして、五十銭で行けと交渉した車で萩之茶屋の女のアパートへ行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が赤玉のナンバーワンということで自尊心の満足があったが、しかし養ってやるから一緒に暮そうといわれ、本当か、俺の様なものが好きだとは何かの間違いじゃないか。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵造夫婦は京城にいる賀来子の伯父を頼って朝鮮に渡り、今は京城の色町で、「赤玉」という小さな撞球場兼射的場をひらいてさゝやかな暮しをしている、内地とちがい気候が不順で困る、などとあり、この手紙のことは権右衛門の耳にいれぬ様にと念を押してあった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤玉「ナニ……兼吉が貴様を毒殺しようとした？",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどうした」「それから兼は、その村の荒物屋を探し出して、風邪引きの妙薬はないかちうて聞きますと……この頃風邪引きが大バヤリで売り切れてしまったが、馬の熱さましで赤玉ちうのならある。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人間は余計に服まなければ利くまいと思って、その赤玉ちうのを二つ買って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアンバイでは俺が兼に十円借りていたに違いないと思い思い薬の袋を破ってみますと、赤玉だというのに青い黴が一パイに生えておりまして、さし渡しが一寸近くもありましたろうか……それを一ツ宛、白湯で丸呑みにしたんですがトテも骨が折れて、息が詰まりそうで、汗をビッショリかいてしまいました」「……フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら俺の腹の中には、赤玉が二つ納まっているんだぞ……と怒鳴りつけてやりましたら、その医者は青くなって逃げ出すかと思いの外……ジーッと私の顔を見て動こうとしません」「フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは又｜何故か」「その爺は暫く私の顔を見ておりましたが……それじゃあお前は、その二ツの赤玉を、いつ飲んだんか……と云ううちにブルブル震え出した様子なので、私も気味が悪くなりまして……ナニ赤玉には違いないが、青い黴の生えた奴を、昨夜十二時過に白湯で呑んだんだ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの赤玉の一粒に使ってある熱さましは、人間に使う分量の何層倍にも当るのだから、もし本当に利いたら心臓がシビレて死んで終う筈だ……どっちにしても今酒を呑むのはケンノンだから止めろと云って、私の手を押えました」「フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の赤玉なんか西瓜一個で五千円動かせるって話だけど。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄だ、赤だ、雪白、紫、緑いろ、　白玉｜葵、赤玉葵、　スウィートロッケット、シャスターデーシー、　また、金蓮花、　そして、ちらちら、コスモスの淡紅いろの花盛りだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで玉依媛にことづけて、赤玉は、緒さえ光れど、白玉の、君が装し、貴くありけり。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
