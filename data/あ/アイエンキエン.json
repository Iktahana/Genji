    "definitions": [
      {
        "index": 1,
        "gloss": "a couple strangely but happily united",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
