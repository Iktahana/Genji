        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日予めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "予めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は予めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には予めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "予めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは予めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "予めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は予めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では予めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "予めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に予めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では予めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "予めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると予めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "予めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では予めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に予めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により予めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "予めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に予めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを予め知っておらぬと細君も驚く事があるかも知れぬが根が気安過ぎるからの事である故驚く事はない。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし富士山の位置を、北アルプスに移し換えて、その痩削的の山容を改めたらば、あるいはどういう雪の結果を齎らしたか、予め知り難いのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が予め読者諸氏に、ことわって置く必要があると云うのは、これから、第三金時丸の、乗組員たちが、たといどんな風になって行くにしても、「第一、そんな船に乗りさえしなければよかったんじゃないか、お天陽様と、米の飯はどこにでもついて、まわるじゃないか」と云われるのが、怖しいためなんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　結　　論　「いき」の存在を理解しその構造を闡明するに当って、方法論的考察として予め意味体験の具体的｜把握を期した。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　結　　論　「いき」の存在を理解しその構造を闡明するに当って、方法論的考察として予め意味体験の具体的把握を期した。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを同じ音に発音したか違った音に発音したかということは、我々は予め決めることは出来ないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるから片仮名でもやはり昔の言語の音を知ろうという場合には、字の違いがすなわち音の違いと考えることは出来ないのであって、これとこれとが同じ音であるということは予めきめる訳には行かないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆一々違った音をあらわしたとは思われませんが、とにかく文字は皆違っているのですから、その中のどれだけが同じ音で、どれだけが互いに違った音であるか、そういうようなことは予め決める訳には行かない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして撮った写真を現像する時には、どんな獣が写っているか予め分っていぬだけ非常に楽しみなものだそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "予め心積りをしていた払いの外に紺屋や、樋直し、按摩賃、市公の日傭賃などが、だいぶいった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒も皿もそれが予め命ぜられているものならひるむことはいらないことです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ予め断っておく、可か。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしさすがの「ひげ」も取り逃がした予言が一つある、ただ幾百年の間、人間の運命をながめていた「杉の杜」のみは予め知っていたに違いない。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食物は豚肉を主としている、釈迦はこの豚肉の為に予め害したる胃腸を全く救うべからざるものにしたらしい。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず予め茲で述べなければならないことは前論士は要するに仏教特に腐敗せる日本教権に対して一種｜骨董的好奇心を有するだけで決して仏弟子でもなく仏教徒でもないということであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその弁護人が摯悍矯直にして裁判官を面責することを恐れざる放胆を予め示して置いたときである。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにお通は予めその趣を心得たれば、老媼が推測りしほどには驚かざりき。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが人々は、それを予め自覚することによつて、来るべき災難を未然に防ぎ、大厄を小厄にし、幸運のチヤンスを捉へ、すべてに於て将来を賢明に用意し得る」と。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに親しい人ならば、そうしておいでになる日が予めわかっているならば、ちゃんと用意をして、徹宵、くつろいで呑み合うのであるが、そんな親しい人は、私に、ほんの数えるほどしかない。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子澄が曰く、然らず、燕は予め備うること久しければ、卒に図り難し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王は予め景隆を吾が堅城の下に致して之を殱さんことを期せしに、景隆既に※に入り来りぬ、何ぞ箭を放たざらんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○或は虚しく設け予め置き、以て自から衛護す。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何故ですか、」　と問うては見たが、予め、その意味を解するに難うはないのであった。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸中｜予めこの算ありけむ、熱の極は冷となりて、ものいいもいと静に、「うむ、きっと節操を守らせるぞ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通は見る眼も浅ましきに、良人は予め用意やしけむ、従卒に持って来させし、床几をそこに押並べて、あえてお通を抑留して、見る目を避くるを許さざりき。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "力を傾け尽さぬうち、予め其の欠点を指示して一思ひに未練を棄てさせたは、寧ろ尠からぬ慈悲である……　で、直ちに木材を伐更めて、第二の像を刻みはじめた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ予め断つて置く、可か。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし年の初め、例えば四、五月頃に七、八月の気候を予察して年の豊凶を卜し、そうしてあらかじめこれに備えることには十分な可能性がある。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るほどのものはあらかじめの心積りの高さを率て実山に宛嵌め眺めるのであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点あらかじめ読者の諒解を得ておかなければならないのである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
