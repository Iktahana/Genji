        "examples": {
          "standard": [
            {
              "text": "私は毎日姉者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "野辺の送が済んで、七々四十九日というのに、自ら恥じて、それと知りつつ今まで遂に音信なかった姉者人、その頃｜一豪商の愛妾になっていたのが尋ねて来て、その小使と、従姉妹三人が竜の腮を探るような思をして工面をしてくれた若干金とで、ようよう後弔も出来たくらい、梓の家は窮していた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かをるの方が窕子よりは年が二つ下なのだけれども、窕子はそれを『姉者、姉者』と呼んでゐた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『姉者は肥えてゐるで、何うしても他よりも暑いぢやらうな？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『うまく出來ましたね、姉者……』　窕子は言つた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『でも、かなりにあるにはありましたね……もう少し近いところかと思うた――春ならばこのくらゐの路は、かへつて徒歩より來る方が樂しみで好いのでござれど……姉者はくたびれた？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『姉者來て見やな……』　かをるもその聲をきいてそつちへと下りて行つた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――武蔵じゃ、姉者人ッ」　閉まっている戸は、引っ抱えている五寸角の柱で、軒ごとに突き破った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉者人ッ――」　彼の声は、鶏のようにシャ嗄れてしまった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉者人も、子たちも、みな達者かの」「つつがのうおりまする。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええっ」と漁師はとびあがる、「たまげたええ、繁あねじゃねえか、いまじぶんこんなところでなにしてるだ」　漁師の持っている提灯の光の中で、お繁はじろっと白い眼を向ける。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええッ」　と男はとびあがる、「たまげた、おめえ繁あねじゃねえかよ、何してるだ」「行けまあ」　お繁はじろりと白い眼を向ける、「おんだが何してべえと、いしの知ったことけえ」　彼女はまた村はずれの家並の裏にいる、そして竹きれで溝の中を掻廻している。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
