    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brightness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すくなくとも気を滅入らせない程度の明るさがなくてはならぬ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眼をひらけば冥茫模糊、薄みどり色の奇妙な明るさで、さうしてどこにも影がなく、ただ茫々たるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　前後左右どちらを見ても、ただ杳々茫々、脚下を覗いてもやはり際限なく薄みどり色のほの明るさが續いてゐるばかりで、上を仰いでも、これまた蒼穹に非ざる洸洋たる大洞、ふたりの話聲の他には、物音一つ無く、春風に似て春風よりも少しねばつこいやうな風が浦島の耳朶をくすぐつてゐるだけである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やみあがりの目にこゝろよき　雨の明るさ！",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側で新聞が読めるか読めないかというくらいの明るさの時刻が開花時で、開き始めから開き終りまでの時間の長さは五分と十分の間にある。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭にホヤをはめた燭台や手燭もあったが、これは明るさが不充分なばかりでなく、何となく一時の間に合せの燈火だというような気がする。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に、例えばザッキンの妙な人形の絵など、随分形式的にはグロテスクに出来ているが、感じの内容には、どこかある明るさと愉快さがある。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきまでの※持の興奮はいつとなくさめかかつてゐたが、それは心のどこかにまだほのかな明るさを投げてゐた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、さういふ空｜想の明るさとは反対に※持は妙に暗く沈んで行つた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、その暗記の仕方といふのが、先づ日光の中で、次は曇り日、次は夕方、次は電燈、結局最後に蝋燭の光の中でといふ風に明暗の順序を追つて眼を慣らしながら研究暗記し、乏しい明るさの中でもこの木目はこの牌とすぐ分るやうに努力するのだと言ふ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間も田舎へ行っていたあとで、夜の上野駅へ着いて広小路へ出た瞬間に、「東京は明るい」と思うのであるが、次の瞬間にはもうその明るさを忘れてしまう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来に今朝のような明るさを覚えたことが近頃の自分にあるだろうか。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼の作品の持つ明るさを以て、全世界を獲得すべきプロレタリヤの信念の明るさ、若しくは作者等の戰線を支配してゐる希望の明るさの表現されてゐるものと見ることには贊成出來ない。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは寧ろ彼自身の文學の持つ明るさである。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に鐘楼があって、小高い基礎の周囲には風が吹寄せた木の葉が黄色くまたは赭く湿れ色を見せており、中ぐらいな大さの鐘が、漸く逼る暮色の中に、裾は緑青の吹いた明るさと、竜頭の方は薄暗さの中に入っている一種の物※しさを示して寂寞と懸っていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでたぶん、年じゅう胃が悪くて時々神経衰弱に見舞われる自分のような人間には楽焼きの明るさも恋しいがまた同時に青磁にも自然の同情があるのかもしれない。",
              "citation": {
                "source": "青磁のモンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は仕方なく蓑吉を膝に凭せながら、午前九時頃の明るさを見せて来た隅田川の河づらを覗いた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空でも洩れる陽射しが、温かくて明るさを運んでくれるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろぐろと塗り磨かれた車体も、その両側に付いて居る長い銀の編針を束ねてひろげた様な二つの車輪も、すべてつやつやと掃除が行き届いて居て、さわやかな朝の明るさのなかに、何か尊いものの様に見えるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして俄かにあんまりの明るさと、あの兄妹のかあいそうなのとに、眼がチクチクッと痛み、涙がぼろぼろこぼれたのです。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていにいえば、この「起ち上ろうとする」もしくは「起ち上りつつある」――更に「起ち上った」大阪の表情のあえかな明るさに、よしんばそれがそこはかとなき表情であるにせよ私は私なりに興奮したのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るさといい、興奮と言ったが、私は嘘を言っているのではない。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼の往来の明るさからいきなり変つたその暗さに私はまごついて、覚束ない視線を泳がせたが、壁に掛つたベートーベンのデスマスクと船の浮袋だけはどちらも白いだけにすぐそれと判つた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという明るさだろう！",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眼をひらけば冥茫模糊、薄みどり色の奇妙な明るさで、さうしてどこにも影が無く、ただ茫々たるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　前後左右どちらを見ても、ただ杳々茫々、脚下を覗いてもやはり際限なく薄みどり色のほの明るさが続いてゐるばかりで、上を仰いでも、これまた蒼穹に非ざる洸洋たる大洞、ふたりの話声の他には、物音一つ無く、春風に似て春風よりも少しねばつこいやうな風が浦島の耳朶をくすぐつてゐるだけである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて防空演習のあつた晩、すべての家々の灯火が消されて、東京市中が真の闇になつてゐた時、自分は家路をたどりながら、初めて知つた月光の明るさに驚いた。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には二階の明るさを想わせる、やや急傾斜の階梯がかっちりと重々しく落着いた階段を見せている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下界は秋の夜といふに上天界のあかるさよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月のあかるさ、一人のよろしさを味ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
