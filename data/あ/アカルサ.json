[
  {
    "uuid": "d5d380ef-eb5f-57d8-a6b5-81bc958c3d43",
    "entry": "明るさ",
    "reading": {
      "primary": "あかるさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
