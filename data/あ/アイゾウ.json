        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "善重氏は、文墨のたしなみがあり、菅原白竜山人のかけ幅や、板垣退助伯が清人霞錦如の絵に題字せられた幅物などを愛蔵せられて、私たちの見るに任せられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのナイフは、夫の愛蔵のものでございまして、たしか夫の机の引出しの中にあったので、それではさっき夫が家へ帰るなり何だか引出しを掻きまわしていたようでしたが、かねてこんな事になるのを予期して、ナイフを捜し、懐にいれていたのに、違いありません。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭の朱衣の童女像は、永瀬義郎君の筆であつて私の永く愛蔵するものである。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "美玉を愛蔵する者がその珠の表面に不浄なるものの影の映るのさえ避けたい類なのであろう。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇五年には、新宿中村屋の創業者で商いの近代化に努め、妻の黒光とともに、たくさんの芸術家や、アジアの政治活動家を支援した相馬愛蔵と、劇作家、小説家で、ジュール・ルナールの『にんじん』の訳者としても知られる岸田国士の作品を公開した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は書画に於て多く好むところがないけれども、翁の短冊だけは珍襲愛蔵してゐる。",
              "citation": {
                "source": "娟々細々",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、右手には愛蔵の古ぼけたパイプを持ち、左手には手術器械の入った大きな鞄をぶら下げて……。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日頃愛蔵する書籍から、衣類、器物まで、貧しい身に貯えた一切のものを恩人の家に残して置いて来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士はそこに好い隠れ家を見つけたという風で、愛蔵する鷹の羽の矢が白い的の方へ走る間、一切のことを忘れているようであった。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、氏の特に愛蔵する夏目漱石氏の書、平福百穂氏の絵などが豊富に飾られてあった。",
              "citation": {
                "source": "狭い一側面",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は遠い旅の鞄に入れて持って行かれるだけの書籍を除いて、日頃愛蔵した書架の中の殆ど全部の書籍を売払った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、その積みあげた本の上に愛蔵のギターをソッと置いて、この土木工事は終った。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのおかげで買ったベートーヴェンの手紙や文章、同時代人の記録を編輯したアルベルト・ライツマンの二巻の『ベートーヴェン』は、今も私は愛蔵している。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "島は記念のふくさを愛蔵して、真志屋へ持って来た。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蘭軒は既に元槧千金方を有してゐたので、其影抄翼方に同一装釘を施して愛蔵した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川の遺品のピストルが山本によって愛蔵されていたのを、幼い久子がいつのまにかもて遊んでいるうち、過って引金に手がふれて発射し、一発のもとに頭を撃たれて即死したものである。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉は女のすぐ後ろに受話器を耳へ当てたまま、彼の愛蔵する写真版の De Hooghe の一枚を思ひ出した。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白無垢の着物に、白の麻｜上下をつけ、左手に、愛蔵の鎧通を握っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも其等印象派の画家がまだ名を成さない時代に買ひ集めたものが多いらしく、リユイル氏が愛蔵して売品としない物許りである。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又幾室かに亘つて歌麿の版画が陳列せられて居るのを観て、斯んなに多数の歌麿が巴里に愛蔵せられて居るかと先づ驚かされた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木さんは屋上の展望台へ私達を延いて長春全市の説明をされ、濱田氏は愛蔵の支那古陶器を携へて来て示され、本城氏も多年蒐集された古銭の代表的な物を持参して見せられた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩の蔵する山本大膳五人組帳は、佐倉の藩士宮崎重富氏が天保十年に手写して愛蔵しておったもので、同氏が巻尾に識している語を見ても、当時山本大膳の五人組帳が世に重んぜられていた一斑を知ることが出来る。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢島が感慨に沈んでいると、その人は曲解して「僕も実はタケノコとはいえ愛蔵の本を手放したことを今では悔いているのです。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その随行としては杉浦愛蔵、保科俊太郎、渋沢篤太夫、高松凌雲、箕作貞一郎、山内元三郎らをはじめ、水戸、会津、唐津等から、それぞれの人材が出かけることになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は太平坊になつて残したかつぽれの名人初代梅坊主の阿呆陀羅経のレコード「ないものづくし」「日露戦争虫づくし」「出鱈目」「鳥づくし」の四種を愛蔵してゐるが、あの馴染深かつた故人の塩辛声が、大正年代の浅草風俗をまざまざ目先に蘇らせて来ていとなつかしい。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「講談雑誌」第一号から第十号までを私は愛蔵しているが、まだまだ大正四年ころのこれらの速記はいま読むと故馬生（六代目・先代志ん生）、故小せん（初代）、故小勝（五代目）、先々代つばめ（二代目）、現左楽（五代目）など、その高座を識るものにはたしかにその人と肯かれる話癖が浮彫りになっていて微笑ましい。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が愛蔵の明治二十年代の東京地図にして現今の小石川区林町あたり、林村と記されている。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生来、決して欲張りではなく、子供の時分から気に入った人にはずいぶん愛蔵の本やレコードも惜し気なくくれてやるという風な気性であると多少は他からもほめられてきていた方だったが、なおさら、お坊ちゃんの崩れだけに生きたお金はつかえなかったのだ。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
