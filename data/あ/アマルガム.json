        "examples": {
          "standard": [
            {
              "text": "私は毎日アマルガムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアマルガムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアマルガムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアマルガムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアマルガムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアマルガムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアマルガムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアマルガムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアマルガムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアマルガムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアマルガムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアマルガムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アマルガムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアマルガムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例えば水銀の中に他の金属を入れてアマルガムにすると赤い色も出す事が出来るが、そうするとまた電力の利益が少なくなるといったような訳でまだ成効の域には達していぬ。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金歯かアマルガムがあったらペンチで引っこ抜くんだ……血だらけで見えないか。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金丹は老子が元君から受けたものとされているが、黄金の不朽の生命を表象するものとも、またアマルガム法によって金を精錬する法とも解せられる。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水銀と鉛とが一体のアマルガムを成し、それがまた展開して、水銀となり鉛となる如く、神霊作用と生殖作用とが渾然として熔合したものが人間であり、それがまた開展分化するところに生命がある。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "分つことの出来ないアマルガムが次ぎの生命の根元であるという意味である。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "質（熱、冷、乾、湿）の学説、四体液（血液、黒胆汁、黄胆汁、粘液）の学説、「精気」の学説、「自然」の学説、これらすべてのアマルガムをガレノスは作った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
