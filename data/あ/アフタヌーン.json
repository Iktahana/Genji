    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "afternoon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフタヌーンについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフタヌーンは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフタヌーンについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフタヌーンの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフタヌーンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフタヌーンを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフタヌーンが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフタヌーンが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフタヌーンは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフタヌーンは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフタヌーンは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフタヌーンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフタヌーンの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフタヌーンの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフタヌーンの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "衣裳は、三十枚のアフタヌーン・ドレス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフタヌーンのスカートは短くイブニングのスカートは長い。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達の訪れを、心待ちにしていたらしい令嬢の路子は、さっぱりした趣味のよいアフタヌーンを被て、新子を欣び迎えてくれた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い色を多く使った明るい家具が置かれ、バルコニイ近い豊かなソファに、軽い紗のアフタヌーンを被た夫人が、あだかも大公妃のような態度で、彼女を待っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみの為か心なしやつれの見える夫人の容貌は、暗緑の勝ったアフタヌーン・ドレスの落着いた色地によくうつりあって、それが又二人の訪問者には甚らなく痛々しげに思われた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄色のアフタヌーンを着て、自分の方から故算哲博士の秘書｜紙谷伸子と名乗って挨拶したが、その美しい声音に引きかえ、顔は恐怖に充ち土器色に変っていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から風采堂々たる中老半白の西洋人が通りかゝって、「グッド・アフタヌーン」　と挨拶した。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "グッド・アフタヌーンが分った丈けで、残余は些っとも歯が立たない。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
