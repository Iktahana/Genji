    "definitions": [
      {
        "index": 1,
        "gloss": "to turn red",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "喉のあたりが赤むくれになつて肉が見えてゐた。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮を剥ぎとられた部分は、鶏の肝臓のように赤むけだった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして、皆席についてしまってから、水で、無理に顔をこすったおつやさんは、赤むけになったように痛々しい面を伏せて、入って来た。",
              "citation": {
                "source": "追想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手があれるだけならまだしも下手をやると赤むけになる。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて涙も一緒に水道の水でごしごしこすった顔を因幡の兎のように赤むけに光らして、しんから切なさそうにそのひとが席へ帰って来たとき、三十二人の全級はどういう感じにうたれたろう。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで孵りたての赤むけ鳩のように、感覚ばかりで激しく未熟な生の戦慄を感じ、粗野な智慧の目醒めにいる女学校三年の娘に、どうして母の女性としての成熟しつくした苦悩がわかろう。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園のペリカンは瘠せて頸の廻りの羽毛が赤むけになっていた。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤むけの膨れ上つた屍体がところどころに配置されてゐた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤むけの膨れ上った屍体がところどころに配置されていた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ赤む蓼の茎、黒き実まじるコスモスの花、さてはまた雑草のうら枯れて斑を作る黄と緑。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹散りがたの赤むらさきの牡丹の花、青磁の大鉢のなかに幽かにそよぐ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもまた木の葉の如く、かろやかに一つ白き蝶舞ひて降れば、尖りたる赤むらさきの草ぞゆするる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕たそがれに似るうす明り、二月の庭の木を透きて、赤むらさきのびろうどの異国模様に触れるとき。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たそがれに似るうす明り、赤むらさきのびろうどの窓掛に凭るわが肌を夢となりつゝ繞るとき。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重みで肩や背中が赤むけになって、何百年もここに立ってる間には、よけいな痛い目をすることになるからね。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が村上さんのほうへ泳ぎだしたとき、鰊を追いながら浅く泳いで来た鱶の一匹が、ヤスリのような鮫皮で私の脛をこすっていきましたので、そこがベロリと赤むけになってしまいました。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『船松』の横の溝でさむらいが死んでいたのを見たとき、みなが鼻の先を赤むけにするほど、地べたばかりかいさぐっている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代文学史の中では、「私」がこういう自然の脱皮を待たず、或は、自然に脱皮するとき迄保たないほど弱くて、風雲にひっぺがされて、赤むけの脆弱な心情が、こわさの余りえらく強げになってみたり、感情に堪えず神経を太くしたりいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざやおもひのまゝに聽きあかむ。",
              "citation": {
                "source": "清見寺の鐘聲",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to redden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
