    "definitions": [
      {
        "index": 1,
        "gloss": "brought up (e.g. topic)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
