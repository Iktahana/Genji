        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘党について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘党という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘党の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘党が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘党を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘党について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘党の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘党の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘党が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘党という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘党という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘党についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘党を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘党は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘党について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘党が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘党は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘党の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘党は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘党は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "四条河原町を上へ二筋目を東へはいると、「と一」という甘党の店がある。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八ツ時分になると、甘党の松島は卓上電話で紅谷から生菓子を取り寄せ、玉露を煎れて呑んでいたが、晩餐には姐さんのためにてんやものの料理が決まって二三品食卓に並び、楽しい食事が始まるのだったが、彼自身は口がきわめて質素で、ひじきや煮豆で済ますのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに生れつきお酒がお嫌いで、大の甘党でおいでになりましたので、私が十歳にもなりました時は、よほど胃のお工合がわるく、保養のためといってよく畑いじりをしておいでになりましたが、そのせいかお顔の色が大変黒くて、眉毛の太い、お眼の切れ目の深い、お口の大きい、武士らしい怖い顔のお方で御座いました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酒も好きだが、菓子も好きになつた（何もかも好きになりつつある、といつた方がよいかも知れない）、辛いものには辛いもののよさが、甘いものには甘いもののよさがある、右も左も甘党辛党万々歳である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖が切符制になつてから、坊守さんが「お砂糖はどうしませう」と訊かれる、「甘いものには縁がありません」と私は答へる、私は辛党、甘党君は私の分まで甜めて下さい！",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大の甘党で、夜床についてからも、何かしら甘いものを枕頭へ引寄せて、ぽつ／＼食べてゐたが、しこたま買ひこんで来る丸ビルの丸菱の甘味は甘いもの嫌ひの晴代には、美味さうには見えなかつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は、元来どんな境遇にでも満足し得る人間だから、暖い日には海岸を散歩したり、半里ばかり奥にある田辺の町を訪ねて、菓子を買うて来たり（甘党の私は田舎へ行くと、うまい菓子が食べられぬので、いつも弱つた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯幸いにして日本人は肉が嫌いであったがため、あの支那料理のシュウマイみたようなものを包む代りに、餡の這入った柏餅が製されて、今に至るも五月になれば姿が見られ得るのは、甘党の私などに取って悦ばしい事の一つかも知れない。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "また普通に甘党といえばいわゆる下戸を指し、酒を好まぬことを意味するのであるが、実際社会においては両刀｜遣いする人もあり、甘党であると同時にまた酒を呑む、上戸下戸を兼ぬる人は決して少なくない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は甘党なんですがねえ」「ホイそうだったネ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では甘党辛党などゝ称し、酒好きと菓子好きとを対立させてゐるが、これはどうも理屈に合はぬらしい。",
              "citation": {
                "source": "甘い話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘党をもつて任じてゐた彼が、一変して強飲者になつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "食慾だから、いろいろのものに付きまとわなければならぬはずだが、こんにゃくのような色を見ても、そう食慾は起きないし、また私は甘党でもあるのに、着色したものだと思うせいか、菓子のようなきれいな色だけでは、それほど胃の腑を刺戟されることもない。",
              "citation": {
                "source": "乳と蜜の流れる地",
                "author": "笠信太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘党だから何かと思っているとありますから、何かお送りしましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘党の赤埴源蔵、吉田忠左衛門、堀部老人、小野寺、間瀬の人々は甘みぞれを飲んでいた。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元来甘党でないにかかわらず病気のせいかしきりに甘いものがほしい。",
              "citation": {
                "source": "胆石",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘いぜんざいでも、ようかんでも、あるとこにゃ山のようにあるそうな」　そういって歯のない口もとから、ほんとによだれをこぼしかけたところは、甘党らしい。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カングリ警部は甘党だった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで明治の甘党も心強くなり、当年の大衆向きの甘口二、三品つまんでみる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘党随喜の名代汁粉砂糖の味を食べ分けた下戸　甘党の随喜した汁粉の味、明治時代には名代の汁粉屋も多く、それぞれ自家特製の持味に御膳、田舎、小倉、塩｜餡乃至は白餡の上品まで口当りのよさ、ことに蓋を取った時のその匂い、ほんのりと特有の香味、煮抜きの餡の練れた工合、全く甘党を誘惑する。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の飲めない赤埴源蔵だの、吉田忠左衛門だの、小野寺や間瀬などの甘党は、やはり杯で「甘みぞれ」を飲み交している。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
