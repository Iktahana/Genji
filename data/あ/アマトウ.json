    "definitions": [
      {
        "index": 1,
        "gloss": "person who prefers sweet things to alcoholic drinks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
