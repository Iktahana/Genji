        "examples": {
          "standard": [
            {
              "text": "毎日、当たり屋について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の当たり屋戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "当たり屋の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "当たり屋という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは当たり屋について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "当たり屋の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "当たり屋に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは当たり屋を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での当たり屋は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、当たり屋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "当たり屋は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な当たり屋を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「当たり屋」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり屋」という概念について深く考察する必要があります。",
              "source": "幻辞"
