    "definitions": [
      {
        "index": 1,
        "gloss": "mallow (any plant of family Malvaceae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
