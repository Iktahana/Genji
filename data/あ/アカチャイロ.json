        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "向うにいた別の、少女のような美しいボーイが、赤茶色のロシア毛布を手にして馳せ出してきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に入ってゆくと赤茶色の山の蔭に僅かに沖の余波を思わせる小波が立っているのみであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "背は低く横に広く好い形に育った小松がそのみどりの葉の所々を赤茶色に染めて居るのは木のために良い悪いなんかは別にしてただ奇麗なものだ、そして又極く美術的なものだ。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去十数年の間、ひどい時期には、この赤茶色の本は、たとえ一冊でも、徳川時代の禁書のように天皇制権力の目からかくされた。",
              "citation": {
                "source": "生きている古典",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶色の艶のない髪を耳かくしに結って鏡ばかり見ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に頭の毛が一本一本にザワザワと走り出したように感じたが、そのザワザワが消えないうちに、入口の扉が半分ばかり開かれると、ガタガタと動く真鍮のノッブの横合いから、赤茶色のマン丸いものがテカテカと光って現われた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ自分の鼻の先に突立っている毛の尖端を見ると、自分では毛頭ソンナ気じゃないのに、両手がジリジリと縮んで、赤茶色の禿頭肌が吾輩の唇に接近して来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お風呂が、新しい鉄がまなそうで、赤茶色に澱んで居た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ汚れて居るだろうと思ってあけた自分の部屋には額がかけかえてあって机の上には新らしい雑誌が二冊ちゃんとならんで、赤茶色の素焼の鉢にはうす赤のふるえる様な花が千世子の方にその面をむけて笑いながら首をかたむけて居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月九日（金曜）　○シベリアの家、赤茶色の羽目に黄色いふちどりをした木造の家。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶色の箪笥、長火鉢、蠅入らず、部屋のあらいざらいの道具が、皆、テラテラ妙に光って、ぼろになった畳と畳との合わせ目から夜気がつめたくすべり込んで来る様だった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした生々した様子になると、赤茶色の水気多い長々と素なおな茎を持った菱はその真白いささやかな花を、形の良い葉の間にのぞかせてただよう。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタムは鼠のような小馬で、たてがみはぼうぼうとして、尾は長くて赤茶色だった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは背に灰黒色、胸と腹が淡赤茶色で、同じその部分の白いほとゝぎすやかっこうと區別することが出來ます。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し顔の皮膚は酒に焼けて赤茶色をして居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、風車小屋は赤茶色でした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が三本の枝の分岐点に立つと、そこから並木道の上に伸びでた大きな枝の、苔におおわれた面に、赤茶色の両手の跡がついているのがみえた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが夏の間は赤茶色で実に綺麗です。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにくっついて塀の高さとすれすれに赤茶色に塗られたパン焼工場の屋根があった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶色の屋根のゆるい勾配にそって横になっていた一人の若者が、重心をとりながら立ちあがって、ポケットから何か出した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲二は、人さし指を釘のように曲げて、納屋の外壁をほじくっては爪の間につまって来る、赤茶色の泥を食べているのである。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がふとその時彼は赤茶色の芥の山のようなものを見出して、その上にのしかかってみた。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は変にカチカチにがんばって、顔が赤茶色に光るような女になりたくないのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶色の日光の斑点が少しばかり、どこからともなくさしてきて、濃い影の中に落ちていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスはすぐカーブを切り、二人の姿は赤茶色の崖の斜面にかくれた。",
              "citation": {
                "source": "予感",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
