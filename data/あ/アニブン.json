[
  {
    "uuid": "a57e96e9-a6b0-56f7-9691-2c7f249eee1b",
    "entry": "兄分",
    "reading": {
      "primary": "あにぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sworn elder brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄分について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄分という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄分の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄分が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄分を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄分について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄分の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄分の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄分が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄分という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄分という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄分についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄分を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄分は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄分について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄分が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄分は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄分の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄分は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄分は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｋ・Ｓ氏は巴里画壇の大家の中でも、特にむす子に親しくして呉れている人であり、先輩というより、兄分といった程に寛いでむす子が交際っていることは、かの女によく知れていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し兄分｜振っているようにも見えた。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三五郎という前髪と、その兄分の鉢鬢奴との間の恋の歴史であって、嫉妬がある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は年輩から云っても、忠次の身内では、第一の兄分でなければならなかった。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾児の中で年頭でもあり、一番兄分でもある自分が、入れ札に落ちることは――自分の信望が少しも無いことがまざまざと表われることは、もう既定の事実のように、九郎助には思われた。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえまで誘い込まれて、ぽかんと口なんぞあけて見とれていたら、根こそぎ鼻毛を抜かれちまうぜ」　しきりとあいきょう者が一日の長を誇って、いやに兄分風を吹かしているのを、右門はくすくすと笑いわらい聞き流しながら、黙念としてしたくの整うのを待ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄分らしくもねえ、あんまりどじなかっこうすると、こちらのちっちゃなお公卿さまに笑われるぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "まめやかにちょこちょこと従いながら、いとものどかにひねり出したものでしたから、いつものように早くも見つけて、何か名人がきき尋ねるだろうと思われたのが、これはまたおよそ変わったことがあればあるもので、珍しく伝六がいたって兄分顔に気取りながらいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "石にかじりついても辰のかたきを討って成仏させてやらなくちゃ、兄分がいがねえんだから、伝六に男をたてさせておくんなせえまし！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君は堅固な人物であるから、兄分として交際したいと思うが、どうだな」「よろしい」と、陳も承知しました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又、村の若者の親なども、これはもう公然止むを得ざる事と黙許して居て、「家の忰もはア、色気が附いて来ただで、近い中に湯田中に遣らずばなるめい、お前方附いて居て、間違の無いやうに遊ばして呉らつしやれ」とその兄分の若い衆に頼むものさへある。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、村の若い者で、湯田中に遊びに行かぬ者は一人も無く、又初めての翌朝、兄分の者に昨夜の一伍一什を無理に話させられて、顔を赤く為ないものは一人も無い。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "重右衛門を始めて湯田中に連れて行つたのは、勝五郎といふ其頃有名な兄分で、今では失敗して行衛知れずになつて居るが、それがよく重右衛門の初陣の夜の事を得意になつて人に話した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬意を表して近附く後進者に対しては、兄分らしく、先輩らしく深切であつた。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の中には思想が深くて学問の広い内村鑑三君や、三宅君の如き兄分もいる。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "――左近はこう咄嗟に決心すると、身仕度をする間も惜しいように、編笠をかなぐり捨てるが早いか、「瀬沼兵衛、加納求馬が兄分、津崎左近が助太刀覚えたか。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――爾来人々弥左衛門を、釣鐘弥左衛門と称したが、それ程の釣鐘弥左衛門も、兄分と立てなければならなかったのは、緋鯉の藤兵衛という町奴であった。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御嶽冠者の義兄弟、石川五右衛門の兄分であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ世にいう三左陣の一人、しかも最も兄分に当たる地丸左陣の山寨であったが、ある日頭領地丸左陣は、日当たりのよい南向きの座敷で一人書見に耽っていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話がすべての人が彼に取っては種々な品物の臭気に過ぎなかった、親分の藤吉は柚子味噌、兄分の勘弁勘次は佐倉炭、角の海老床の親方が日向の油紙、近江屋の隠居が檜――まあざっとこんな工合いに決められていたのだった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宇治の茶箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが蔭へ廻つて、時々シクシク泣いてゐるのを見ちや、同じ屋根の下に住んでゐる、若い男三人、天道樣のせゐにしちや居られないわけでせう」「そのうち誰が一番臭いんだ」「喜次郎は三十五で、三人のうちでは兄分ですが、こいつは人間が甘いから、有松かな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妾の貞操",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の祖父の姉の連れ合いは二人の男の子を残して早く世を去ったので、未亡人は亡夫が丹波から連れて来た弟子の周節という医者を順養子として家に迎え、二人の兄分として医者を営ませた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三重吉は私より二つ年上だつたが、當時の私は子供だつたので、人生に關しても藝術に關しても、知識もなければ見識もなく、從つて三重吉は兄分として私を引き廻した。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、兄分らしいませた口調で、もう一人の稚児に云った。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村義雄と云って、わしよりは三つも年下であったが、貧家に育った為に、世間のことは、兄分のわしよりもずっと明るく、容貌の点でも、わしとは比べものにならぬ程美しかった。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八の年には洗張屋に奉公していたが、兄分に当るのが、寝物語に順吉の話を聞いて、「なんだ、それじゃ、お前、父なし児じゃねえか。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄分の男は「可哀そうだなあ。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "小姓組の腕白を十人ばかり預かって、兄分格となっている堀尾茂助が、小声で、「殿さまの前へ進んで、あの子のわきに坐ればよいのだ……」　と、市松に教える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
