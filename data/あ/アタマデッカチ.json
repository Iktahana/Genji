        "examples": {
          "standard": [
            {
              "text": "毎日、頭でっかちについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭でっかち戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭でっかちの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭でっかちという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭でっかちについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭でっかちの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭でっかちに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭でっかちを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭でっかちは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭でっかちは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭でっかちは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭でっかちを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭でっかち」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
