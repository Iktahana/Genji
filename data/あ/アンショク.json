        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗色について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗色という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗色の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗色が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗色を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗色について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗色の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗色の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗色が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗色という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗色という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗色についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗色を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗色は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗色について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗色が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗色は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗色の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗色は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗色は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "併し十餘年を經る時は、其の表面に存する斑理の紅色は、漸くにして黒暗色を帶びるに至るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ妙な点を、女の鋭い目というものが捉えていて、出るときに同じ暗色の外套を着ていたのだが、襟もネクタイもなかったのだという。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、そいつが中肉中背、暗色の何かを着ていたというのがわかるだけで、それ以上そいつの手がかりはありません。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、灰をあちこちの床から集めてみたが、暗色で薄片状、これはトリチノポリの灰にのみ表れるものだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが最後の梯を登りゆくとき、一人の女の小き絹の片にて髮を裹み、闊き暗色の上衣を着たるが入口に現れて、あすの名題や變りし、蹶き給ふな、マルコオと云ひつゝ迎へぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイ長の右手と右の肺の部分に紫暗色の打撲傷ができていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし十余年も経つ時はその表面の斑理の紅色は、次第に黒暗色を帯びるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかぶさって来るかと見上くれば、目のまわるほど遠のいて見え、遠いと思って見れば、今にも頭を包みそうに近く逼ってる鋼色の沈黙した大空が、際限もない羽をたれたように、同じ暗色の海原に続く所から波がわいて、闇の中をのたうちまろびながら、見渡す限りわめき騒いでいる。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙色の薔薇の花、「時」の色「無」の色を浮べて、獅身女面獸の微笑を思はせる暗色の薔薇の花、虚無に向つて開いた笑顏、その嘘つきの所が今に好きになりさうだ、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗色の壁に添うて高いテーブルが置いてある。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩父の雲の明色の多いのに引きかえて、日光の雲は暗色が多かった、かれは青田を越えて、向こうの榛の並木のあたりまで行った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭と胴とで一米に近く、毛色は赤味を帯びた暗灰色で、円形の暗色｜斑文が散らばっているという。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "為事をしているうちに、急に暑くなったので、ふいと向うの窓を見ると、朝から灰色の空の見えていた処に、紫掛かった暗色の雲がまろがって居る。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは、ちょっと他のものに、附会けていたんだがね」　と何げなく云ったけれども、その眼はただならぬ暗色を湛え、ギロリと六人の車座を見まわした。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一木の両手の中に、紫暗色をして、縮んでいた刀が、きえーっ、と、風を切って、生物の如く叫びながら、さっと延び、白く光って、落ちかかるのを見た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、眼は閉じたきりで、脣は、紫暗色に変じ、頬は、血の中から、灰紫色に見えていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、憂欝はむしろ、自己の力の過信と不明とを悔いる反省の鞭のひゞきであり、更にまた、一層強靭な「夢」を養ふ鍛錬の汗の一と時だとすれば、かゝる憂欝は暗色にして必ずしも暗色ならずと云ひ得ませう。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に沿ふた甃の路に靄の深い街燈の薄明り、夜の暗色と一緒に、噎つぽい磯の匂ひが、急にモヤモヤした液体のやうに、灯のある周囲に浮きながら流れはじめる。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼方、暗色に茫とかすんでる先に、帯を引いたような、きらきら光ってる海が見えていた。",
              "citation": {
                "source": "丘の上",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "西天を彩れる夕映の名残も、全く消え果て、星の光は有りとは言へ、水面は、空闊にして、暗色四面を鎖し、いよいよ我が船の小なるを想うのみ。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁にそいて右の方にゴチック式の暗色の櫃あり。",
              "citation": {
                "source": "痴人と死と",
                "author": "ホフマンスタアル　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて一目みただけで私の胸を燃え立たせた彼女の美しい暗色の髪は、いま長いあいだうつ向いて坐っていたのでほつれて、乱れたさまを見せていたが、そのため私には一そうふさふさと見事に見えるのであった。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにしてワイン商は樽からワインを瓶に詰めたあとで、お得意に桶の切れ端を取り出して、ワインの古さの疑いない証明として美しい暗色の細かい結晶性の酒垢を示している。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この１容をワインまたはその他の鉛の存在を疑う液体の２容にくわえると、暗色または黒い沈殿を生じて、塩酸を加えても消失しない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体の傾向からいふと、夏のうちはたしかに明色だつたものが、秋ぐちから次第に秋の深まりゆくのにつれて、目だたぬながら段々と色合ひがくすんで、暗色に近づいて来たやうな気がする。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭蓋骨底部の血管には暗色の血液充満す。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃壁にあらわれた慢性加答児と暗色の血液は、いうまでもなくローダノムの作用なのであろうが、どこにも「ヨブのような」などと言われそうな記述は見あたらない。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙な色調を持った暗色の地の上に、おぼろに残った黄色の肌や余韻の多い暗紅の衣が浮き出ている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
