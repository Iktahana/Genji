        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "堪らん、こりゃ、立っとッちゃあ埒明かん、さあ前へ行ね、貴公。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を立てて、助かろうと思うても埒明かんよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いずれも猶予するを見て）埒明かんな、伝吉ども来い。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と女中は嬉しそうな声をして、「おお、踊や言うで明かんのじゃ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「方なしじゃ、」　思いの他、声だけは確であったが、悪寒がするか、いじけた小児がいやいやをすると同一に縮めた首を破れた寝ン寝子の襟に擦って、「埒明かんで、久しい風邪でな、稼業は出来ず、段々弱るばっかりじゃ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（閉い言うて、云わしゃれても、な、埒明かん。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで十年前に北国へお立退きの際、お預けなされた三井寺の方へ此の間じゅうからさいさい掛合われなされたけれど、一向取戻しは埒明かんと言うことじゃ』信徒二『そりゃ初耳じゃ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際は充分にお前自身の思う通りやってもらわんければ埒が明かん。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "東雲師没後の事など",
                "note": "青空文庫"
              }
            },
            {
              "text": "老功の者の眼から観れば、年若の者のする事は、総てしだらなく、手緩るくて更に埒が明かん。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、私で話が分るんなら行んでも来ようが、こう云う事は、女子ではらちが明かんさかいな。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇッ、緩怠至極の奴等だ」　いらだちきった組頭は、この上は、自身｜糺問に当らねば埒が明かんと覚悟した時分、黒灰浦の海岸の陣屋の方に当って、一旒の旗の揚るのを認めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕いよいよ明かんとする時畠山古瓶以前は髯むぢやの男なりしを綺麗に剃りて羽織袴の様子よく幕外に出でうやうやしく伊井一座この度鴎外先生の新作狂言｜上場の許を得たる光栄を述べき。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は四方から詰めよって、穴の明かんばかりに局長の面を見つめる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は物事を抽象的の結末から始まるもので、この問題等も、外の所からではどうしてもらちが明かんのじゃ」「あなたがたはこういう事に気がついた事がありますかな、人というものは決して吾々のきく通りのことを答えんということをな。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸も埓明かんとぐざるぜも。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸も埓明かんでなも」「然うきゃも。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯待ってばかりいたんじゃ、埓が明かん」「策の施しようがないんです。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ」「俺は何かやらんと埓が明かんから喧嘩をしろと勧めて置いた」「はあ」「三人の候補者の中で一番優勢らしい。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰しゃるとおり、重々、御尤ではございまするが』　甲斐守は、焦々して、『埓の明かんやつだ。",
              "citation": {
                "source": "鍋島甲斐守",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親が早く亡くなっちゃったから、あかんぼのうちから襁褓を自分で洗濯して、自分で当てがった」　老妓は「まさか」と笑ったが、悲しい顔付きになって、こう云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　半次が「あかん、強い奴や」と体の筋々が痛そうです。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲蔵仰天した「そんな、無理な事」　大吉「あかんちゅうたら、駄目だ」　仲蔵「そう仰言らずに……」と必死に謝り頼む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「二両より出せません」　山左が涙を呑んで、Ｔ「せめて十両」　あかんあかんと徳兵衛ソッポ向く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかんと言った顔の左膳である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これゃ、どうしたってあかん！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これゃどうしたってあかん！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり年寄がおらんとあかんて」兄はそんな情愛の籠ったことを言った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂助　埒あかんのう。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、あなたがたは病を軽蔑しておらるるから埒あかん。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいな、あの男どうしたんだろう、いっそこの珈琲のんでしもてやろか、三匹の亀が言った途端、喫茶店の入口にじっとかくれてなかの様子を見ていた小さい方の亀が、いきなり、こらッ、飲んだらあかんぞ――と言ったというんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
