[
  {
    "uuid": "cf6c93c6-ebe2-5865-a43d-3bc2bdc66b41",
    "entry": "危うい",
    "reading": {
      "primary": "あやうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dangerous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日危ういについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "危ういという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は危ういの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には危ういが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "危ういを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは危ういについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "危ういの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は危ういの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では危ういが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "危ういという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に危ういという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では危ういについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "危ういを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると危ういは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "危ういについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では危ういが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に危ういは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により危ういの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "危ういは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に危ういは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんなことを迂濶に口外すれば宇三郎ばかりでなく、第一にわが身の上が危ういから、藤吉は忌々しいながらも我慢するよりほかはない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和魂だけで器械を使ったのでは、第一器械もこわれるが、場合によっては自身の命も危ういのである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスンの詩「プリンセス」に「戦士の亡骸が運び込まれたのを見ても彼女は気絶もせず泣きもしなかったので、侍女たちは、これでは公主の命が危ういと言った、その時九十歳の老乳母が戦士の子を連れて来てそっと彼女のひざに抱きのせた、すると、夏の夕立のように涙が降って来た」というくだりがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、わたくしは自分の胸の中のガン漬の味を知り出して来そうなので、これが癖になったら胸の想いから離されなくなるのではないかと危うい気がいたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にホームズの口からは譫言しかでないので、残していくのは危ういと思えたからだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言うように、これまた先生が学ばない者の愚を指摘し、学ばなければ則ち得ることが無いだけでなく、無暗に危ういところに留まることを示されたのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして逃げ出したことが肥後に知れたなら、負けぎらいな監は追って来るであろうと思われるのが恐ろしくて、この船は早船といって、普通以上の速力が出るように仕かけてある船であったから、ちょうど追い風も得て危ういほどにも早く京をさして走った。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その望みも危ういものになって来たではないか。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人が平生からその用心をしていれば、なんにつけても油断がなく、まさかの時にも危うい災難を逃がれることができるというもの。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげさまで、危ういところをのがれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志の身が危ういときくからは、われらも素姓知らしてやろうわ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一にも二にも異人を懼れて、外船と交易致さば神州を危うくするものじゃと愚かも甚しい妄語を吐きおるが、国が危ういと思わば内乱がましい内輪の争い控えたらよかろうぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "与茂四郎という人のおかげで、主人は危ういところを助かって、こんな目出たいことはないのですが、なにしろこういうことがあったので、一座もなんとなく白けてしまって、酒も興も醒めたという形、折角の御馳走もさんざんになって、どの人もそこそこに座を起って帰りました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはいよいよ危うい。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう信西入道の屋形で彼女に囁かれた甘いことばも、今は悪魔の囁きのように思われて、千枝太郎はややもすれば魔道へ引き入れられそうな自分の危うい運命を恐れた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その危うい一刹那に、ひとりの若い男が横合いから転がるように飛び出して来て、いきなり熊の胴腹へ組み付いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが愚鈍だと思った寺男にそれを感づかれてしまったものですから、毒食らわば皿のつもりでさらに寺男をも絞殺し、寺男に変装して危ういところを逃げだしたのですが、俊夫君のためについに逮捕されてしまいました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私は危うい瀬戸際に至って、その大罪を犯さずに済みました。",
              "citation": {
                "source": "秘密の相似",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖田刑事は危ういところで冬木刑事に先手を打たれたけれども、ほとんど同時に有力な獲物のありかを発見したことに、自分もまだ老いてはいないことを意識して多少の得意を感じたらしかった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えぬと足らぬ、加えると危うい。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると西洋の絵画史が今日の有様になっているのは、まことに危うい、綱渡りと同じような芸当をして来た結果と云わなければならないのでしょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳一、お前の身は今大変に危ういぞ！",
              "citation": {
                "source": "耳無芳一の話",
                "author": "THE STORY OF MIMI-NASHI-HOICHI",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度今省線電車の線路増設や停車場の位置変更などで、上の方も下の方も工事の最中でごった返していて、足元も危うい位の混乱を呈している。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日、社長室で社長に抱擁を強いられて、恥と怒りと驚きに※いていたときに、折よく廊下からドアをノックする者があったので、危ういところを逃れて隣室へ逃げ帰った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を斬って置きながら顔の色も変りませんのは余程｜胆の据ったもので、此の時に伊之助も正孝も危ういところは免れましたが、鼻の先でザクリ、バタリ、プーッと血烟が立ったんですから慄えて居りました。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "情ないことには互に顔を知りませんから、亭主の為に亭主を殺しにかゝりましたので、実に小三郎の身の上は危うい事でございます。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのときは、暗がりで、はっきりお顔は見えませんでしたけれど――もしや、こないだ、山ノ宿の田圃で、危ういところを、お助け下されたお方では――」　お初が、口を切った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が、その美貌ばかりを望まれて、Ｙ伯、Ｍ武官、そしてそれ等の男性に飽かれてフランス人のＨさんにまで嫁いで行き、またちぐはぐになった揚句、とうとう気違いになるまで、加奈子は美しい花が、あやうい風に吹き廻されるような美観で、うかうか京子の運命を眺めて居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神奈川の遊びの味をわすれられない彼等は、からだのあやういのを知りながら又もや港崎町へ引っ返してくると、岩亀楼でロイドに出逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五両の金とても帳合いをごまかした金だから、それが露顕すればいよいよ自分の身があやうい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
