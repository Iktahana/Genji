        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上げたり下げたりの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その一つはねずみ色の天鵞絨で作った身長わずかに五六寸くらいの縫いぐるみの象であるが、それが横腹の所のネジをねじると、ジャージャーと歯車のすれ合う音を立てながら走りだす、そうしてあの長い鼻を巧みに屈伸して上げたり下げたりしながら勢いよく走るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやがやいい罵る人ごみの中を駅員があっちでもこっちでも手を上げたり下げたりしたかと思うと、婆やは飛び上らんばかりにたまげさせられた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の中を這出して、片息になってお前、本尊の前へにじり出て、台に乗っけて小さな堂を据えてよ、錦の帳を棒の尖で上げたり下げたりして、その度にわッと唸らせちゃあ、うんと御賽銭をせしめてやがる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角な家の生物が、脚を百ぺん上げたり下げたりしたら、ペムペルとネリとはびっくりして眼を擦った。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「是は、」と同じく草につけた双の掌を上げたり下げたり、臀を揉んでもじついて、「旦那、はて、お前様、何言はつしやる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫が窓から覗いた時には、猩々はレスパネエ夫人の白髪を左の手で掴んで、右の手で剃刀を顔の前に持つて行つて上げたり下げたりしてゐた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、独言を云つて、誰かと話をして居るやうだよ……（四辺を※す）然う／＼、思つた同士、人前で内証で心を通はす時は、一ツに向つた卓子が、人知れず、脚を上げたり下げたりする、幽な、しかし脈を打つて、血の通ふ、其の符牒で、黙つて居て、暗号が出来ると、何時も奥様がおつしやるもんだから。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ打ち込んでおいたメロディーをマックがやたらテンポを上げたり下げたりと、ちょっと聞いただけではさっぱり節回しのわからない形で再生し、解答者が曲名をあてにかかる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本にならつて、腕を上げたり下げたりして見た。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げたり下げたり、しゃくにさわるね！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "交叉点では、黒の裾長外套を着た巡査が、赤い棒を鼻の先に上げたり下げたりして交通整理をやってる。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やんちゃな彼女が、さも尤もらしく桜の枝を上げたり下げたりしているのがおかしく、彼等はひとりでに笑えた。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　船は首を上げたり下げたりしつつ夕日に向って苦しげに進んでいった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎娘になって、初々しく顔を赤めてお茶を召し上れか、車井戸のつるべを上げたり下げたりしていると、私も娘のように心がはずんで来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台の向う側に妾の爪先とスレスレにかしこまったまま、それこそ狼ソックリのアバラ骨を薄い皮膚の下で上げたり下げたりして、一生懸命に咳を押え押えしていた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左様、つい気怯れ申して見物が多いと固く取っていけませぬ」「いや、見物があるので固くとらるる位なら見上げたもので御座る」　足軽大いに上げたり下げたりしている。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文藝家の一般化は化粧品の廣告によつて知られるのと同じで、眞の文運と無關係」と一方で云ふかと思ふと「作家は公人で、文壇だけのもので無く社會の公人だから、社會的謬見を正せ」と無理な注文で上げたり下げたりしてゐるし。",
              "citation": {
                "source": "春夫偏見",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、レヴユーといふものが次から次へと変化発達して行つてゐるが、西暦一九二四年ごろの巴里の本場でも、あんな風に美女が皎い歯を見せつつ、長い脚を一斉に上げたり下げたり、米搗の杵が一斉に臼の中に落ちたり上つたりするやうな具合にまでは行つてゐなかつたやうであるが、当今ではあんな風にまで発達した。",
              "citation": {
                "source": "雷談義",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして光つてゐる面の上を滑りながら足の指を上げたり下げたりなどしてゐる演者については、「その各※の動作は、大きな衣裳の重みと襞と共に、死に、打ち克たんがためのものであり、又その動作の一々は、失へる熱情の、永遠の中における緩やかなる模寫であると言へよう。",
              "citation": {
                "source": "クロオデルの「能」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昨晩和歌の浦へ泊りましたが、和歌の浦へ行って見ると、さがり松だの権現様だの紀三井寺だのいろいろのものがありますが、その中に東洋第一海抜二百尺と書いたエレヴェーターが宿の裏から小高い石山の巓へ絶えず見物を上げたり下げたりしているのを見ました。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの方は相手が要るので、そう毎晩は繰り返されなかったが、何しろ変に無器用な手を上げたり下げたりして、熱心にやっていた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も甚しいのは伊太利で、普通芝居が済むと、五六度幕を上げたり下げたりする。",
              "citation": {
                "source": "新劇の観客諸君へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今｜幸にして、天に在ます神にお出会いしましたが、蟻の命を助けたまえ、また仙……仙薬を授けたまえ……」彼は頭を上げたり下げたり、異様な恰好をしている。",
              "citation": {
                "source": "不周山",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "偖熱心に錨を上げたり下げたりしたが、時々はコトリと手答はあっても、錨の四本の足の其何れにも柄杓はかゝらない。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は子供をあやしながら猿を上げたり下げたりしてゐる。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の場末の小屋のショオには大根足の女の子が足をあげて手を上げたり下げたりするだけの無様なものであったが、それにくらべると、今のストリップは踊りも体をなしているし、そろって裸体が美しくなってることは確かであるが、裸体美というものはそう感じられない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は珍しくて暫く眺めていたが、鼠も長い尾を上げたり下げたりして、私の方を眺めているばかりで、果てしが無いのでそのまま八階に上って行った。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し下だ」などと勝手に声を懸けて、一生懸命に草の中を探している南日君を上げたり下げたりしたことを覚えている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が「お蝶夫人」をうたい終って楽屋へ帰ろうとすると、パヴロヴァが舞台裏で私のオペラの終るのを待ちながら、横木につかまって足をあげたりさげたり、一生懸命ウオーミングアップをしています。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの時でもこの練習をやっていて、しかもちっとも休むことなしに、右の足を、左の足をあげたりさげたりしています。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
