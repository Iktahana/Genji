    "definitions": [
      {
        "index": 1,
        "gloss": "to fan (oneself, flames, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "風のエネルギーは第一に蚊帳を煽るに費やされ網の目を抜ける時に摩擦で消される。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルチック海から吹き渡って来る酷風が、街の粉雪の裾を斜に煽る。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不可解な絵が妙に未知の不思議の世界に対する知識欲を刺戟しそれがいつとなく植物学全体への興味を煽るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴にもこれは可笑しかったろう、この時ばかりじゃ、真直に首を据えて厚い唇をばくりと開けた、大粒な歯を露出して、あの宙へ下げている手を風で煽るように、はらりはらり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳が煽るか、衾が揺れるか、畳が動くか、胸が躍るか。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に残って、砂地に独り峡の婆、件の手を腰に極めて、傾がりながら、片手を前へ、斜めに一煽り、ハタと煽ると、雨戸はおのずからキリキリと動いて閉った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に二三の人からすず子にあてた極めて簡単な手紙が、すず子の心熱を煽るらしかつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の身体ぢゆうに油を注いで、それに火をつけて、その火を風で煽る如に、私は苦しくつて苦しくつて、騒がずに居られないやうな、折折気が狂ふのかと思ふやうな心持がして来ますの。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に二三の人からすず子にあてた極めて簡單な手紙が、すず子の心熱を煽るらしかつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の身體ぢゆうに油を注いで、それに火をつけて、その火を風で煽る如に、私は苦しくつて苦しくつて、騒がずに居られないやうな、折々氣が狂ふのかと思ふやうな心持がして來ますの。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おなじく南どなりへ知らせにおいでの、白井氏のレインコートの裾の、身にからんで、煽るのを、濛々たる雲の月影に見おくつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工の機嫌よげなるを見るより、一人は、画工の背を抱いて、凧を煽る真似す。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に二三尺あとへ引いて、薄波を一｜煽り、その形に煽るや否や、人の立つごとく、空へ大なる魚が飛んだ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰命頂礼、賽ころ明神の兀天窓、光る光る、と追従云うて、あか柄杓へまた一杯、煽るほどに飲むほどに、櫓拍子が乱になって、船はぐらぐら大揺れ小揺れじゃ、こりゃならぬ、賽が据らぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地虫のような鼾を立てつつ、大崩壊に差懸ると、海が変って、太平洋を煽る風に、提灯の蝋が倒れて、めらめらと燃えついた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分お支度があったと見えて、するめの足を噛りながら、冷酒を茶碗で煽るようなんじゃありません。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は今宵の邂逅を出来るだけロオマンチックに煽るように努めた。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜覬覦の情無き能わざりしと雖も、道衍の扇を鼓して火を煽るにあらざれば、燕王｜未だ必ずしも毒烟猛々、蕩々、糾々、昂々として、屈す可からず、撓む可からず、消す可からず、抑う可からざる者、燕王に遇うに当って、※然として破裂し、爆然として迸発せるものというべき耶、非耶。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時かんてらが煽る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の響きは、ぶるぶると、お妙の細い靴の尖に伝わって、揺らめく胸に、地図の大西洋の波が煽る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で其の望を煽るために、最う福井あたりから酒さへ飮んだのでありますが、醉ひもしなければ、心も定らないのでありました。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞさへ破れようとする心臟に、動悸は、破障子の煽るやうで、震へる手に飮む水の、水より前に無數の蚊が、目、口、鼻へ飛込んだのであります。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、手を悶える、裳を煽る。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でその望を煽るために、もう福井あたりから酒さえ飲んだのでありますが、酔いもしなければ、心も定らないのでありました。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ破れようとする心臓に、動悸は、破障子の煽るようで、震える手に飲む水の、水より前に無数の蚊が、目、口、鼻へ飛込んだのであります。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴にも之は可笑かつたらう、此時ばかりぢや、真直に首を据ゑて厚い唇をばくりと開けた、大粒な歯を露出して、那の宙へ下げて居る手を風で煽るやうに、はらり／＼。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船一艘漕ぐなれば、蘆の穂の風に散る風情、目にも留まらず、ひら／＼と上下に翼を煽る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "…　ト前刻、止せ、と云つて留めたけれども、其でも女中が伸べて行つた、隣の寐床の、掻巻の袖が動いて、煽るやうにして揺起す。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまが何か言おうとするまえに、父はにやりと笑って、「おまえ、内密で――」　これだ／＼といって左の手でコップを煽る手附をしてみます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『恋』は華厳の寂寞に蒸し照る空気うち煽る。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
