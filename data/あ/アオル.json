    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to gulp down (alcohol, poison, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「万歳万歳」の声は四方に起り、一同は蟻の甘味に付くように水汲み隊の周囲に集り、咽を鳴らして水筒の口から水を呷る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一坪の庭も無い家へ急に移つた時に一切の菊を失つて終つてから、今はもう自分は一株の甘菊をも有たぬが、秋更けて酒うまき時、今はたゞ料理菊でもない抛つたらかし咲かせの白き小菊の一二輪を咬んで一盞を呷ると、苦い、苦い、それでも清香歯牙に浸み腸胃に透つて、味外の味に淡い悦びを覚える。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、丁晋公臨終前半月、已に食はず、但香を焚いて危坐し、黙して仏経を誦す、沈香の煎湯を以て時々少許を呷る、神識乱れず、衣冠を正し、奄然として化し去ると。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事ぞ、酒井先生の薫陶で、少くとも外国語をもって家を為し、自腹で朝酒を呷る者が、今更いかなる必要があって、前世の鸚鵡たり、猩々たるを懸念する？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、なぜか気競って云って、片手で饅頭を色気なくむしゃりと遣って、息も吐かずに、番茶を呷る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれをぐいぐいと呷る。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も焼酎を呷ることを忘れなかつた、といふよりも、呷らずにはゐられなかつた、飲むときは胸が痛いほど苦しい、しかし飲んでしまへば何となくうれしくなる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……焼酎を呷る、焼酎が焼酎をよぶ、酔うた、泥酔した、しかし、庵にかへつてぐつすり寝た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲んで酔ふことは悪くないが、酔ひたい気分で酒を呷ることはよろしくない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は飲む、浴びるほど酒を呷る、それはひつきよう空虚の苦杯なのだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てゐる、覚めると冷酒を呷る、そして寝てゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールを止揚せよ、先づ焼酎を止めろ、酒は日本酒に限る、燗してちびり／＼飲むべし、時としてぐい／＼ビールを呷るもよからう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈欝、そこらを散歩して、農学校に立寄り、樹明君から五十銭借りる、石油を買ひコツプ酒を呷る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心何となく不調、焼酎のたゝりらしい、慎むべきは火酒を呷ることだ、省みて、自分の不節制に驚く。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く起きてはならないので困つた（夜ふかしの朝寝があたりまへの社会だから）、こつそり抜けだして散歩、時局柄で朝湯もないので、コツプ酒でも呷る外ない、……不用人間の不用時間を持て余した。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡市街をムチヤクチヤに歩きまはる、やたらに酒を呷る。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "欝々として楽しまない、幸にしてＫ社から句稿料が届いたので街へ出かけて二三杯呷る、その勢で山口へ行く、飲んで酔うてＳ屋に泊る、前後不覚、一切合切が空つぽになつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一つの発見をした、それは、私の腹いたみは冷酒が、いひかへれば酒屋の店頭でグツと呷るのが直接原因であることだつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が悪酔姿でやつてくる、昨夜の酒が酒をよんだらしい、バリカン（昨夜わざと置いていつた）を眺めながら、頭を撫でながら、ひそかに案じてゐたが、やつぱり案じた通りだつたらしい、樹明君よ、独りで呷る酒はよくない、さういふ酒から離れて下さい、頼みます。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日を子供の世話と雇人等の指揮とに疲れ切つて、夕暮のゴタ／＼した勝手元で、大きな戸棚の中へ首を突ツ込んで、「白鹿」と銘のある大樽の呑口から茶漬茶碗に一杯注いだ冷酒をグツと呷ることもある。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽を鳴らす音、めしをかむ歯の響き、汁を吸う舌打ち、がぶがぶ呷る大盃に吐くため息。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、速く床をひいてくんねえ」　まごまごしている雇婆を急き立てて、冷のままの酒を、ぐっと一息に呷ると、歌麿の巨体は海鼠のように夜具の中に縮まってしまった。",
              "citation": {
                "source": "歌麿懺悔",
                "author": "江戸名人伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿茶瓶の唐變木奴、詫が言ひたかつたら、せめて伜の首でも持つて來やがれ、手前の雁首まで欲しいとは言はねえ」　松五郎は湯呑の冷酒をガブりと呷ると、中腰になつて喜兵衞を睨み据ゑます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に腰かけ酒を呷る）第二場　利根の渡し利根川渡し場。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿茶瓶の唐変木奴、詫が言いたかったら、せめて倅の首でも持って来やがれ、手前の雁首まで欲しいとは言わねえ」　松五郎は湯呑の冷酒をガブリと呷ると、中腰になって喜兵衛を睨み据えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々村村一のコップに注いだ葡萄酒を、半分は注ぎこぼし乍ら、阿夜子は二杯、三杯と、続け様に呷ると、勝ち誇った夫――大魔王――茶谷金弥の顔を振り向いても見ずに、「村一さん、一緒に」　佐々村村一の身体を抱き上げるように、衆人環視の中に、犇とすがり付くのでした。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜之助は湯呑で立てつづけに、三杯、四杯と呷ると、その一杯毎に、無性に気分が面白くなる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いしはそれを呷るように飲み、こんどは頭を力なく垂れた。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　夜半すぎから眠らずに駈けまわった、その疲れと気力の消耗のためだろう、冷のまま湯呑茶碗で三杯ばかり呷ると、頭がくらくらして飲めなくなった。",
              "citation": {
                "source": "葦",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "覘いている竹村君の後ろをジャン／＼と電車が喧しい音を立てて行くと、切るような凩が外套の裾をあおる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
