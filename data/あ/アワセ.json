        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日袷について考えている。",
              "source": "幻辞"
            },
            {
              "text": "袷という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は袷の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には袷が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "袷を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは袷について学習した。",
              "source": "幻辞"
            },
            {
              "text": "袷の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は袷の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では袷が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "袷という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に袷という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では袷についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "袷を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると袷は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "袷について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では袷が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に袷は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により袷の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "袷は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に袷は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬近き日に袷をきて非有の窮乏は酢えはてたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷を綿入に着かえて重くるしいのに裾が開きたがって仕方がない。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實家の妹が、家内に袷を一枚、持つて來て、「これ、お母さんが、ねえさんにあげなさいつて。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は下駄を穿いて居る上に寝巻にして居た日本服の古袷に長マントを着て居たので、彼の異国風俗を人々は見返ったのだ。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、「民やはあのまた薬を持ってきて、それから縫掛けの袷を今日中に仕上げてしまいなさい……。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは十五年ばかり前に、村の呉服屋で買った、その当時は相当にいゝ袷柄だった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「袷じゃせに、これゃ寒いじゃろう。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "纒いしは袷一枚、裾は短かく襤褸下がり濡れしままわずかに脛を隠せり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の犠牲は三十恰好の商人風の男で、なんでも茶がかった袷の着流しに兵児帯をしめていたように思う。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔以下原稿数枚なし〕　それから松雲閣へ帰って一つ風呂を浴びてやれといふ気持ちで更衣室に行くとこれは又さっきの異人が宿から縞の唐〔桟〕の袷を着せられてかんかんと椅子に座ってパイプをくわいて時事新報を見てゐたもんである。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで九月に袷が着られるでしょうか」「ちげえねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曽の御嶽山は夏でも寒い、　　　袷遣りたや足袋添えて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと間伸のした、しかも際立って耳につく東京の調子で行る、……その本人は、受取口から見た処、二十四、五の青年で、羽織は着ずに、小倉の袴で、久留米らしい絣の袷、白い襯衣を手首で留めた、肥った腕の、肩の辺まで捲手で何とも以て忙しそうな、そのくせ、する事は薩張捗らぬ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、袷に羽織で身は軽し、駒下駄は新しし、為替は取ったし、ままよ、若干金か貸しても可い。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る照る鈴鹿は曇る＝といい、袷遣りたや足袋添えて＝と唱える場合には、いずれも疲を休めるのである、無益なものおもいを消すのである、寧ろ苦労を紛らそうとするのである、憂を散じよう、恋を忘れよう、泣音を忍ぼうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもひどいのは、半分ほどきかけの、女の汚れた袷をそのまま丸めて懐へつっこんで来た頭の禿げた上品な顔の御隠居でした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふの新患者は、紺絣の袷をきちんと着て籐椅子に坐り、海を眺めてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "単衣から袷に移る期間はむずかしい。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、袷は、二揃いあるのだ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言ったように袷は二揃いあるのだが、絹のもののは、あまり好まない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、単衣から袷に移る、その過渡期に於いて、私には着て歩く適当な衣服が無いからでもあるのだ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの久留米絣のお気に入りらしい袷を、早く着たいのだが、それでは日中暑くてたまらぬ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ垢づいた良人や子供の冬着を輕やかな春の袷に代へる用意に若き妻も老いたる妻も眠りを忘れるのだらう。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷を着ていた私は暑さに堪えずに単衣を着て経机に向っています。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷の紺飛白に一本｜独鈷の博多の角帯を締め、羽織の紐代りに紙繕を結んでいる青年音楽家は、袖をつめた洋装を着た師の妹娘を後に従えて、箱根旧街道へと足を向けた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄無地の古い紬の袷に、同じ様な色の幅のせまい博多の丸帯を、盛り上った様な肉附の宜い腰の辺に恰好よく結んで居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿袷の條柄も分かぬまでに着古したるを後の杖と一蓋の菅笠とを膝の辺りに引寄せつ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くるしいね、絣の、大島か何かでせう、襟垢の着いた袷に、白縮緬の兵子帶を腸のやうに卷いて、近頃誰も着て居ます、鐵無地の羽織を着て、此の温氣に、めりやすの襯衣です。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織なしの引かけ帯、ゆるやかな袷の着こなしが、いまの身じろぎで、片前下りに友染の紅匂いこぼれて、水色縮緬の扱帯の端、ややずり下った風情さえ、杖には似合わないだけ、あたかも人質に取られた形――可哀や、お主の身がわりに、恋の重荷でへし折れよう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
