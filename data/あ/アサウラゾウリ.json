        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "麻裏草履の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私はまたお前が柔かい手足へ、茨や薄で傷をつけるが可哀相だから、そう云ったんだが、いやだと云うならお前のすきにするがよいさ」　それで民子は、例の襷に前掛姿で麻裏草履という支度。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺の腹掛、唐桟の単衣に角帯、麻裏草履、そのような服装をしていながら、白線の制帽をかぶって、まちを歩いたのは、一たい、どういう美学が教えた業でしょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやや失望したが、この娘に対して少しも僻んだり気おくれはしない「……あのとにかく見せて頂けないでしょうか」すると娘はまたはっきりした笑顔になり「では、とにかく、」と云ってそこにある麻裏草履を突かけて、先に立った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏のころで、少年は素足に麻裏草履をはきました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他の人に怪しまれない限り急いで庭へ出て、そこから麻裏草履をはいて河の方へと驅け出して行つた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄か雨でこの通り泥だらけにしてしまったのだから、何か丈夫そうなのを下さいな」　どうで気に入ったのは無いと承知の上で、半七はありあわせた麻裏草履を一足買った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてもう五ツ（午前八時）に近いころに、高輪の海辺へさしかかると、葭簀張りの茶店に腰をかけて、麻裏草履を草鞋に穿きかえている年頃二十七八の小粋な男があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小室の小笹裏戸覗いて　裏から帰る紺の前掛　麻裏草履あなた一人に情立てましよと泣いてわかれた　小室の小笹裏戸覗いて　裏から帰る紺の前掛　麻裏草履。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは隣り町に住んでいる建具屋の藤次郎で、脚絆に麻裏草履という足ごしらえをしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に麻裏草履をまず車へ持ていてもらって、あとから車夫におぶさって乗るなんどは昔の夢になったヨ。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで爺やが小さな麻裏草履を見つけて來まして、踵の方に紐をつけて呉れました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが其朝に限つて、兄の方には新しい鞄や、帽子や、其他學校用のものが買つて宛行はれてあるに引きかへ、弟のためには子供持の雨傘と、麻裏草履としか有りません。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに軽い新しい麻裏草履をも穿いた。",
              "citation": {
                "source": "並木・足袋",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りまで一緒に送って行って、鳥打の代りに麦藁を買って被せたり、足袋に麻裏草履などもはかせた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　わたしたち姉弟が、紺絣の筒袖に小倉の小さい袴をはいた男の児と、リボンをお下げの前髪に結んでメリンスの元禄袖の被布をきた少女で、誠之に通っていたころ、学校はどこもかしこも木造で、毎日数百の子供たちの麻裏草履でかけまわられる廊下も階段も、木目がけばだって埃っぽかった。",
              "citation": {
                "source": "藤棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝さんとおなじの、黒い、麻の着物の尻はしょりをおろして、手ぬぐいで、麻裏草履を穿いて来た足前をはたいて、上って来て、キチンとお辞儀をした。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の午時ごろ、浅草警察署の手で、今戸の橋場寄りのある露路の中に、吉里が着て行ッたお熊の半天が脱ぎ捨ててあり、同じ露路の隅田河の岸には、娼妓の用いる上草履と男物の麻裏草履とが脱ぎ捨ててあッたことが知れた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも日本人は大小を挟して穿物は麻裏草履を穿て居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども亜米利加人が往来を歩いた靴の儘で颯々と上るから此方も麻裏草履でその上に上た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻裏草履と鳥打帽子は云うまでもなく、すわと云う時に逃げ出す為で、毒薬は最後の処決の為であろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後へ入違つて這入て来ましたのが、二子の筒袖に織色の股引を穿きまして白足袋麻裏草履と云ふ打扮で男「エヽ御免なさい。",
              "citation": {
                "source": "世辞屋",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやひとしきり採りあるきて、少しくたびれが来しと見え、女中に持たせし毛布を草のやわらかなるところに敷かせて、武男は靴ばきのままごろりと横になり、浪子は麻裏草履を脱ぎ桃紅色のハンケチにて二つ三つ膝のあたりをはらいながらふわりとすわりて、　「おおやわらか！",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやひとしきり採りあるきて、少しくたびれが来しと見え、女中に持たせし毛布を草のやわらかなるところに敷かせて、武男は靴ばきのままごろりと横になり、浪子は麻裏草履を脱ぎ桃紅色のハンケチにて二つ三つ膝のあたりをはらいながらふわりとすわりて、「おおやわらか！",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "広岡子之次郎の、素肌に袷を着け乗馬袴に紺足袋をはき、麻裏草履を紐で結んでいる姿は粋で、そして颯爽としていた。",
              "citation": {
                "source": "『七面鳥』と『忘れ褌』",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の隅に麻裏草履が置いてあって、食後などには折々庭へ出て見られるのですが、上る時には必ず元のように裏返しにして置かれます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の午時頃、浅草警察署の手で、今戸の橋場寄りの或｜露地の中に、吉里が着て行ッたお熊の半天が脱捨てあり、同じ露地の隅田川の岸には娼妓の用いる上草履と男物の麻裏草履とが脱捨ててあッた事が知れた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では麻裏草履の製造仲買で数万の富を有しておられるそうな。",
              "citation": {
                "source": "牛捨場馬捨場",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の月の午時頃、浅草警察署の手で、今戸の橋場寄りの或露地の中に、吉里が着て行ツたお熊の半天が脱捨てあり、同じ露地の隅田川の岸には娼妓の用ゐる上草履と男物の麻裏草履とが脱捨てゝあツた事が知れた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに私のおった学校は田舎の田舎で麻裏草履さえないと云うくらいな質朴な所でしたから、学校の生徒でヴァイオリンなどを弾くものはもちろん一人もありません。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
