[
  {
    "uuid": "d94f53ab-7a8d-5125-8ea5-e6ffa35867ab",
    "entry": "愛飲",
    "reading": {
      "primary": "あいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drinking habitually",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛飲は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛飲が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛飲に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛飲が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛飲について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛飲についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛飲について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛飲が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛飲が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛飲は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛飲は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛飲を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛飲をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛飲が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛飲の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛飲を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛飲に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛飲について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛飲は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛飲を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "煙草はレッド・バンドを喫い、酒はラム酒、とくにネグリッタラムにてつくるバカーデ・カクテールを愛飲する。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　背もたれに寄りかかった私が愛飲の葉巻を吹かすと、ホームズも身を乗り出して要点ごとに細長い人差し指で左の手のひらを叩きつつ、これからふたりして赴くことになった事件のあらましを聞かせてくれるのだった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ「南方の魔術師」の愛飲家！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁麦酒　ライ麦の麦芽を用ゐて醸造した一種の家庭飲料で、ビールに似た軽い酒精分を含み、露西亜人の一般に愛飲するもの。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、夏のうち丈け、暑気払ひと称して、愛飲した。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が愛飲する酒の如きは、人によって天の美禄でもあり、百薬の長ともなるが、好まざる者には無価値である。",
              "citation": {
                "source": "味を知るもの鮮し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとは独立に、ポーターの愛飲家はこの麻酔毒を取り入れなくても、卒中や麻痺に非常に罹りやすいことが知られている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人はわずかばかりの酒を街の中で、きゅうくつな宴会のつぐないにして愉しく愛飲したものである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は深い飲酒者が永い時間をかけて愛飲するように、ちびりちびりと深い溝そこへはまり込んで行くように、次第に意識を円満にやわらげてゆくようにした。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "克彦はあれ以来、なぜかジョニー・ウォーカーを愛飲するようになっていた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十六日（水曜）　マチネー、ダイヤ菊愛飲者招待会といふ、気のすゝまぬことで十一時半家を出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな花か、花が見たいと思う……」　などと、かたり出で、中華では魏晋のころから紳士のあいだで愛飲されだして、唐の陸羽は、茶経という書物さえあらわしている。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、赤ワインを愛飲して大酒飲みになった人は、白ワインを飲んだときでも、ほとんど同じく耽溺するであろう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて紅玉を溶かしたような葡萄酒を愛飲し、時々、菓子器に盛ってある南蛮菓子を取っては食べ、かつ語るのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅僧の手で漢土から渡来した始めのころは、禅堂や貴人のあいだに、養生薬のように、そっと愛飲されていたにすぎなかったが、近ごろでは“茶寄合”などという言葉さえ聞くほどだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　※　扨我等の生活はとみるに、　活動か、寄席か、酒か女か玉突か、トラムプか、棋か、どれにしたもんだらう……部屋の中でジツと話してれあいいんだけれど、どうもそれもパツとしないしなあ……読書か、あれはあんまり興味もないが、さうも云つてゐられんしなあ……困つたなあ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次歩き乍ら尚もベラベラ、Ｔ「右腕の傷も、案外、軽く　想う女を手に入れて　天晴れ男ッ振りを　上げたまでは　まあいいんですがね」　と半次が言えば、五郎蔵が「それから？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、やっぱりニヤニヤ笑いながら、「読まなけれあいいんでしょう？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ペムペルとネリとはそれはほんとうにかあいいんだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にゃあいいんだろう？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "注射しなけれあいいんでしょう？",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのことなんか心配しねえで、おまえの思ったとおりなんでもどんどんやりゃあいいんだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あそこへ工場を持って来るなんて、百姓するものは、一体、何処へ行って百姓をすれあいいんだ？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳だけしていれあいいんだ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無理でしょう」　とおかみさんは、口をはさみ、「お可哀そうよ」　ちぇっ、と上原さんは舌打ちして、「そんなら、こんなところへ来なけれあいいんだ」　私は黙っていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けといったら、とっとと行きゃあいいんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえはこれから鳥越へ行って、煙草屋の伝介はどうしているか、見て来てくれ」「あいつを何か調べるんですかえ」「ただその様子を何げなしに見て来りゃあいいんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっつけりゃあいいんじゃねえか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいいんだよ」「うん」　彼はすぐに安心したように肯いた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうすりゃあいいんだ！",
              "citation": {
                "source": "どんづまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
