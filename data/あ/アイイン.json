  },
  {
    "uuid": "86d03401-64b2-529f-bc72-3612db8c12db",
    "entry": "哀韻",
    "reading": {
      "primary": "あいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sad tone (of music, words, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀韻は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀韻が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀韻に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀韻が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀韻について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀韻についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀韻について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀韻が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀韻が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀韻は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀韻は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀韻を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀韻をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀韻が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀韻の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀韻を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀韻に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀韻について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀韻は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀韻を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「おしょろ――たかしィま――（ア、スイ）およびはないが、よ――（ア、スイ／＼）せめて――（スイ）うたすつ――（ア、スイ）いそやまでよ――（ア、スイ／＼）」　その簡朴悠長にして、哀韻｜嫋々、どこまでも續いて、どこまでも絶えず、細く、長く、悲しい響きを傳へる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉を換へて云へば、この世の中の家常茶飯に、極めて意味深い哀韻の詩を見出して、之を描き出す作家なのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "「末枯」の作者",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し底を流るる哀韻を見のがし得ないのはどうしてか。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば豊潤で太い朗かな調べのうちに、同時に切実峻厳、且つ無限の哀韻を感得することが出来る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀韻は、「いさよふ波の行方知らず」にこもっていることを知るなら、上の句の形式的に過ぎない序詞は、却って下の句の効果を助長せしめたと解釈することも出来るのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この限り無き哀韻は、幾度も吟誦してはじめて心に伝わり来るもので、平俗な理論で始末すべきものではない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀韻は、近江旧都を過ぎた心境の余波だろうとも説かれている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの哀韻は支那文学の影響、或は仏教観相の影響だろうとも云われている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀韻もここまで目立たずに籠れば、歌人として第一流と謂っていい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此一首は取りたてて秀歌と称する程のものでないが、挽歌としての哀韻と、「雲の失せゆけば」のところに心が牽かれたのであった。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かく顫う哀韻を聴き得ないのは、憶良などの歌もそうだが、この一団の歌人の一つの傾向と看做し得るであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう大した歌でないようでも、惻々とした哀韻があって棄てがたい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しもとの作はやはり防人本人で、哀韻の迫ってくるのはそのためであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鄙にも月は照れれども」という句に哀韻があるのは、都の月光という相対的な感じもあり、いつのまにか秋になった感じもあり、都の月光と相愛の妻との関係などもあって、そういう哀韻を伴うのであろうか。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は歌調が読んでいていかにも好く、哀韻さえこもっているので此辺で選ぶとすれば選に入るべきものであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八丁も隔つてゐるであらう向う岸から絶壁の古林にこだましつつ響いて来る笛の音の如き哀韻を聴いた。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、やがてどこからともなく澄み切った尺八の音が、哀韻切々と耳を打ってきました。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女の語る一言一句が、遠い国の歌のしらべのように、哀韻を含んで私の胸に響いた。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喨々として水のせせらぐに似た尺八の哀韻、それは二人の数奇を物語るかのように、呂々転々の諧調を極まりなくして、心なき詰侍の者さえ泪ぐましい気持に誘われた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　※　扨我等の生活はとみるに、　活動か、寄席か、酒か女か玉突か、トラムプか、棋か、どれにしたもんだらう……部屋の中でジツと話してれあいいんだけれど、どうもそれもパツとしないしなあ……読書か、あれはあんまり興味もないが、さうも云つてゐられんしなあ……困つたなあ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次歩き乍ら尚もベラベラ、Ｔ「右腕の傷も、案外、軽く　想う女を手に入れて　天晴れ男ッ振りを　上げたまでは　まあいいんですがね」　と半次が言えば、五郎蔵が「それから？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、やっぱりニヤニヤ笑いながら、「読まなけれあいいんでしょう？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ペムペルとネリとはそれはほんとうにかあいいんだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にゃあいいんだろう？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "注射しなけれあいいんでしょう？",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのことなんか心配しねえで、おまえの思ったとおりなんでもどんどんやりゃあいいんだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あそこへ工場を持って来るなんて、百姓するものは、一体、何処へ行って百姓をすれあいいんだ？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳だけしていれあいいんだ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無理でしょう」　とおかみさんは、口をはさみ、「お可哀そうよ」　ちぇっ、と上原さんは舌打ちして、「そんなら、こんなところへ来なけれあいいんだ」　私は黙っていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けといったら、とっとと行きゃあいいんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
