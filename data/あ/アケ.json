        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朱の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "當時僕がどんなに深く感動したかは、その時讀んだ本の各頁に、鉛筆で無數の書き入れや朱線がしてあるので、今もその古い本を見る毎に、新しい追憶の感銘が興るほどだ。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "に朱罫、十八行二十四字）いっぱいに画いた附近の略地図である。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規常用の唐紙に朱罫を劃した二十四字十八行詰の原稿紙いっぱいにかいたものである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱を注いだような裸の皮膚には汗が水銀のように光っている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の歌天井に　朱きいろいで　　戸の隙を　洩れ入る光、鄙びたる　軍楽の憶ひ　　手にてなす　なにごともなし。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時少年時黝い石に夏の日が照りつけ、庭の地面が、朱色に睡つてゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦屋根の覆いを冠った朱塗の大鳥居には、良恕法親王の筆と知られた、名高い「三国第一山」の額が架かってある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕焼のように混濁した朱でなくて、聖くて朗らかな火である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川家御朱印（天文二十四年）にも、村山室中で魚を商なってはならぬとか、不浄の者の出入を止めろとか禁制があって、それには、この村山なる事を明示している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の人が、杖に「大願成就」という焼印を押してくれた上に、小御岳の朱印を押した紙に、水引を添えてくれた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは逆廻りといって、道者は忌むのだそうで、案内者をもって自任する荷担ぎの男は、私から右の水引と朱印を取りあげて、遂に返してもらえなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の中が、黄な臭いやうに、ボーッと明るくなつたとおもふと、高い空を浮ぶ雲が、夕日を受けて、鈍い朱に染まつた、蜩が、時間を一秒一秒刻み込んで、谷の中へ追ひ込んでゆくやうに、キ、キ、キと啼き落す、杉林の一本々々の樹が、どちらから寄るともなく、塊まつて、黒い法師のやうになつて、囁き合つてゐる。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺の火は燃え出した、その明るくなることは、花が発くのと同じで、万象の色が真の瞬間に改まる、槍と穂高と、兀々した巉岩が、先ず浄い天火に洗われて容を改めた、自分の踏んでいる脚の下の石楠花や偃松や、白樺の稚いのが、今眠から醒めたというように朝風に身振いしてソヨソヨと顫った、天地皆新しい。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺は黄金色とかわる。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は濃緑に朱の斑点のはいった草の葉をいじっているから「オイよせ、毒かもしれない」と言ったら、あわてて放して、いやな顔をして指先を見つめてちょっとかいでみる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「幸福」だといって朱い唇でヒステリカルに笑いもする。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たそがれは天地に立籠め、もの皆は水のいろに漂いはじめたが、ただ一つ漂わされぬものがあって山ふもとの薄明りの野に、一点の朱を留めていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホウ、そら、やれ、むかし　達谷の　悪路王、まっくらぁくらの二里の洞、渡るは　夢と　黒夜神、首は刻まれ　朱桶に埋もれ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜疊の座敷に六｜枚屏風たてゝ、お枕もとには桐胴の火鉢にお煎茶の道具、烟草盆は紫檀にて朱羅宇の烟管そのさま可笑しく、枕ぶとんの派手摸樣より枕の總の紅ひも常の好みの大方に顯はれて、蘭奢にむせぶ部やの内、燈籠臺の光かすかなり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱色の罌粟や赤椿などは前者の例であり、紫色の金魚草やロベリアなどは後者の例である。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に朱赤色や濃黄色といったような熱色の花には単調な色彩が多くて紫青色がかったものや紅でも紫がかったものにはこうした色のかがよいとでもいったものがあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は墨で片側は朱で書いてあるのを、出勤したときは黒字の方を出し、帰るときは裏返して朱字の方を出しておくのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も屠蘇そのものが既に塵埃の集塊のようなものかもしれないが、正月の引盃の朱漆の面に膠着した塵はこれとは性質がちがい、また附着した菌の数も相当に多そうである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字で書けば朱とか紅とかいうだけであるが、種類によってその赤い色がことごとくちがう。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はどうした訳か、この人の使用する青や緑と朱や紅との強い対照の刺戟が性に合わないせいでもあるか、どうも親しみを感じる訳に行かない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　黄は睨み朱は吼える、プルシアンブルーはうめく。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『朱欒』のむかしから親しく君達は私に君達の心を開いて呉れた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次尚も、Ｔ「それから　其の黒羽二重に　朱鞘の長刀　落し差して　居る処……」　と云われて仲蔵、恐る恐る「それがどうか致しましたか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ目下が精神の貧寒時代であることは分つてゐますし、詩人が存外の苦吟をするのであることも分つてゐるのですから、もつとあけすけにして、もつと具体的なことを論ずることが、詩壇の急務ではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
