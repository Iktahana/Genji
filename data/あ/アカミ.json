    "definitions": [
      {
        "index": 1,
        "gloss": "red flesh (of a fish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、教えられていたから、妻に対って、オイ、二三枚でよいが杉の赤身の屋根板は無いか、と尋ねた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの時は酔ぱらってゐて、赤身のままの奴を見たので、つい変な気持がしたのだ。",
              "citation": {
                "source": "雀",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚市場へ行ってみると、黒い背甲を擦剥いて赤身を露した奴がズラリと並んで飛ぶように売れて行ったものだが、これは春先から対州の沿岸を洗い初める暖流に乗って来た鰤の大群が、沿岸一面に盛り上る程、押合いヘシ合いしたために出来たコスリ傷だ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無赤身大力明王、穢迹忿怒明王、この大願を成就し給え」　侍は、こう叫ぶと、刀の尖を、手首のところへ当てて、青白く浮いている静脈を、すっと切った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無、赤身大力明王、邪修を摧破して、剣刃下に伏滅せしめ給え。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らない人は赤い処ばかりくれろなんぞと腿の赤身の一番悪い処を買って良い処を捨てしまう。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑゝかは親類、まじゝは赤身、ぶつ／″＼は白いところ即脂身である。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人の赤身を喰べるのが近い親類で、遠縁の者は、白身を喰ふからだと説明してゐる。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最高の錦木とは、上等のかつおぶしの中心である赤身ばかりを薄く削ること、太いよいわさびを細かいおろし金で密におろすこと。",
              "citation": {
                "source": "夏日小味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが東京へ来てみると、反対に赤身が高く、脂身が安い。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶漬けに用いるまぐろの材料も、トロ、中トロ、赤身、好みによって選択すればいいわけである。",
              "citation": {
                "source": "鮪の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂の少ない赤身は赤身で美味いし、脂の多いところはまたトロで美味い。",
              "citation": {
                "source": "鮪の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが羊羹のような赤身は脂肪分が少ないからさびが利くが、中脂肪以上、トロなんという脂肪のきついところになると、さびの辛味は脂肪で跳ね飛ばされて一向に辛くない。",
              "citation": {
                "source": "鮪を食う話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の握るものは、鱧、河豚、赤魚、つばす、牡蠣、生うに、比目魚の縁側、赤貝の膓、鯨の赤身、等々を始め、椎茸、松茸、筍、柿などに迄及んだが、鮪は虐待して余り用いず、小鰭、はしら、青柳、玉子焼等は全く店頭に影を見せなかった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "締まっていて汁気が多く、牛肉のようだが赤身ではない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤身の魚は一切駄目。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には可愛き兒の寐姿みゆ、膝の上には無情の君よ我れを打捨て給ふかと、殿の御聲あり／＼聞えて、外面には良人や戻らん更けたる月に霜さむし、たとへば我が良人今此處に戻らせ給ふとも、我れは恥かしさに面あかみて此膝なる文を取かくすべきか、恥づるは心の疚しければなり、何かは隱さん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとへば我が良人、今｜此処に戻らせ給ふとも、我れは恥かしさに面あかみて此膝なる文を取かくすべきか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合が狂人の眼のようにあかみ走って、しかも落ちついて咲いていた。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のあかみには、ごまのような、跳ねた粒子形のかたまりのような逞しい蝶が、花に打突かる獰猛さで飛んで来ては、また何処かへ行った。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕にほんのりとあかみが潮した。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けたる黝の鉄の桁構、半月形の幾円み絶えつつ続くかげに、見よ、薄らに青む水の色、あるは煉瓦の円柱映ろひ、あかみ、たゆたひぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えるような紅顔であったものが、ようやくあかみが薄らいでいる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃ハあかみちやとおしろいにて、はけぬりこてぬり／＼つぶしもし、つまづいたら、よこまちのくハしやのばゞあがついでかけ、こんぺいとふのいがたに一日のあいだ御そふだんもふそふというくらいのことかへ。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月二十日　姪春猪あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジンジャー＆ピクルスでは　あかみずたまの　ハンカチが　どうか１まいと　せいどうか３まいで　うられています。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "（春曙抄本）春はあけぼの、そらはいたくかすみたるに、やうやうしろくなりゆく山ぎはの、すこしづつあかみて、むらさきだちたる雲の、ほそくたな引たるなどいとをかし。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠元朗は遠い世にあってはこうまで厳しい人間の心が向きあう息苦しさを感じなかったのに、いまは何というまざまざとしたお互いの心を感じあうことのみに、月日が灰や炭のように消えて行くことであろうぞ――眠元朗は岩壁へ出て、そしてぼんやりした湖心のあかみに瞳を落した。",
              "citation": {
                "source": "みずうみ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのりと美しくあかみさしていて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
