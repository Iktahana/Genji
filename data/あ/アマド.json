        "examples": {
          "standard": [
            {
              "text": "私は毎日雨戸について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨戸という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨戸の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨戸が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨戸を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨戸について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨戸の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨戸の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨戸が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨戸という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨戸という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨戸についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨戸を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨戸は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨戸について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨戸が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨戸は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨戸の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨戸は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨戸は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雨戸をあけてやろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこの部屋で海賊の打ち合せをしようと思ってね」　私は馬場の興奮に釣られてうろうろしはじめ、蒲団を蹴って起きあがり、馬場とふたりで腐りかけた雨戸をがたぴしこじあけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中のお房が雨戸をしめに来たのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が去った後自分は立って雨戸を一枚あけて庭を見た。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜荒物屋の裏を通ったら、雨戸を明け放して明るい座敷が見える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "種崎の渡しの方には、茶船の旗が二つ見えて、池川の雨戸は空しく締められてこれも悲しい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず雨戸をしめて後に寝床へはいるとチンチロリンの声が聞こえなかった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こつて家を揺がし雨戸を震はすかと思ふと、それが急に丸で嘘を云つたやうに止んで唯沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こって家を揺るがし雨戸を震わすかと思うと、それが急にまるで嘘をいったように止んでただ沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭場の雨戸は未だ開いたなりに月が軒口までさし込んでいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁がね　朝月夜のかげ空に残りて、見し夢の余波もまだ現なきやうなるに、雨戸あけさして打ながむれば、さと吹く風｜竹の葉の露を払ひて、そゞろ寒けく身にしみ渡る折しも、落くるやうに雁がねの聞えたる、孤つなるは猶さら、連ねし姿もあはれなり。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉め切った雨戸をがたごと鳴らしては、虚空へ舞上ってゆく、気味の悪い風の絶間に、鋭く聞き耳をたてて、昼間から出たまま帰って来ない子供達の足音を待っている母親の心は死ぬ程不安の念にさいなまれていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして風が烈いために常よりは早く雨戸を閉め切って、戸と戸の溝に通じた穴に釘を差し込んだ。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は風雨の声いかにもすさまじく、雨戸が絶えず鳴っていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の女の姿が消えると間もなく、下の雨戸を開ける音がゴトゴトして、建付の曲んだ戸が漸と開いた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸をしめに来た女中がこの騒ぎを眺めながら「またお米があがったそうな」といった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が屋根を渡り切って、その白い影がおまきの家の引窓のなかに隠れたのを見とどけると、彼女は娘の手を強く握って転げるように自分の家へかけ込んで、引窓や雨戸を厳重に閉めてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかを掻き分けて、半七は源次と裏口から師匠の家へはいると、雨戸もまだすっかり明け放してないので、家のなかは薄暗かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の雨戸を一枚あけてくれ」と、半七は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次が起って南向きの雨戸をあけると、もう六ツ（午前六時）すぎの朝の光りは、庭から一度にさっと流れ込んで、まだ新しい蚊帳の波をまっさおに照らした、死んだ女の顔はいよいよ蒼く映って物凄くみえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々に雨戸を撫でる庭の八つ手の大きい葉に、雨の音がぴしやぴしやときこえるのも、外の暗さを想はせるやうな夜であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも物干しの一方の方へ寄っていれば見られないで済むのであるが、雨戸が開いている、それを見て大きい声を立てて注意をされたりするとなおのこと不名誉なので、彼がやって来ると匆々家のなかへはいってしまうのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳をまくって起きて出、雨戸を一枚繰った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて小用を達した様子、雨戸をばたりと開けるのが聞えた、手水鉢へ柄杓の響。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、祖母に導かれて、振袖が、詰袖が、褄を取ったの、裳を引いたの、鼈甲の櫛の照々する、銀の簪の揺々するのが、真白な脛も露わに、友染の花の幻めいて、雨具もなしに、びしゃびしゃと、跣足で田舎の、山近な町の暗夜を辿る風情が、雨戸の破目を朦朧として透いて見えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とて静に雨戸をひきたまいき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此室が宜かろうという蔵海の言のままその室の前に立っていると、蔵海は其処だけ雨戸を繰った。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸を開けたに相違ない。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴の音の波の振幅は多くの場合に耳の近くで雨戸を繰る音に比べて大きなものではないのに雷の音は著しく大きいと考えるのはやはり直接の感官を無視して音響の強度の距離と共に感ずる物理的方則を標準としているのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまどころ、えんれいさう、その他名の知れない森林植物が咲きます。",
              "citation": {
                "source": "佐渡が島のこと",
                "author": "江南文三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
