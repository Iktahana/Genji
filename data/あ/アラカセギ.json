    },
    "definitions": [
      {
        "index": 1,
        "gloss": "making a killing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒稼ぎについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒稼ぎの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒稼ぎが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒稼ぎについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒稼ぎの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒稼ぎが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒稼ぎという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒稼ぎについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒稼ぎは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒稼ぎが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒稼ぎは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒稼ぎの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒稼ぎは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒稼ぎは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "七面倒な、こうすべい、と荒稼ぎの気短徒じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう荒稼ぎで、弥三郎は文字友と一緒にうまい酒を飲んでいたが、そういうことは長くつづかない。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャッカリ屋、吉屋信子女だてらに原稿料の荒稼ぎ河童の頭の皿に精々注いで貰ひな黄金の水を――。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦のどさくさに、らくらくと荒稼ぎした連中のことを彼は自分のことのやうに熱狂して話しだす。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドッチにしてもコンナ荒稼ぎ（密輸入）の船員連中と肌が合わないのは、わかり切っているばかりじゃない。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちの仲間で、わざわざ別荘地へ金口を拾いに行く者があるかね」「居ッコタ居ッケンド、そんな奴等、テエゲ荒稼ぎダア。",
              "citation": {
                "source": "老巡査",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒稼ぎというと泥棒でもやるのかね」「何だってすらア。",
              "citation": {
                "source": "老巡査",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "野武士の中から新時代の新人もたしかに現れてくるけれども、極めて小数の心ある人物だけで、荒稼ぎッぱなしの野武士といふものは流れの泡にすぎないです」　倉田は立上つて、「ぢやア、最上先生、先刻の話、例の元伯爵、兄小路キンスケを明晩つれてくるてえ話は中止としませう。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八人の子供に武術を仕込んでめいめいにダンビラを握らせて荒稼ぎするうちに天晴れ野武士海賊の頭となりついに大名となってメデタシメデタシということは、個人的にも国家的にもない話ではなかった。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツル子の本心はサルトルに二千万円の荒稼ぎをさせたり、商事会社を起させたりすることではなかった。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのお前がどうしてまた、荒稼ぎをするようになったのかな？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　×　　　　　　×　左傷の五右衞門といふのは、海老床の親方の喜八で、少しばかり武藝の心得のあるのを資本に、下剃の周吉を見張りに使つて、大それた荒稼ぎを始めて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためたお金では傷口の肉がまだ二分の一しかあがらず退院した時にゃ腰のきれない程の借金で、それを返す為めの詮方ない荒稼ぎさ（廉売は必然止しこねえ）ところが、三つき目の今日は早もと通りで再び病院へ奉公しなきゃもう持ち堪えんこれがあたしの考えた犠牲的奉仕の報酬だってさええ！",
              "citation": {
                "source": "泥沼呪文",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから絵自体の創作態度も商品的だが、又、売込みの名人で、終戦後は画家の苦境時代だが、彼は雑誌社や文士に渡りをつけて、挿絵の方で荒稼ぎ、相変らず鬼才だのユニックな作風などと巧みにもてはやされている。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豪勢なカフェーをやってるぜ」「猪沢市太郎が荒稼ぎで大金をせしめたのか」「猪沢は死んだ」「どこで？",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごみにうまく隠れ、大手を振って荒稼ぎできる。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやら博奕場帰りやらただの旅人などを乗せて、いざ大河のまン中にかかると、張の兄弟は、かねてしめし合せの荒稼ぎにかかるのだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも淋しい日本海の浜などに、毀れて残っている古い仕来りには、沖で夜昼の荒稼ぎをした舟が、戻って来ると家へも行かずに、すぐに村中の娘を喚び集めて、酒盛りをするという話を折々聞くが、是も本来は町の人々が想像するほどに、乱雑な慣例ではなかったように思う。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "累代の楠木家の当主が、遠い地方まで出張ッて、しばしば土豪的な荒稼ぎをやった陣頭の旗である。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
