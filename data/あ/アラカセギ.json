[
  {
    "uuid": "b7a728e8-50d2-523f-9b61-51f002366499",
    "entry": "荒稼ぎ",
    "reading": {
      "primary": "あらかせぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
