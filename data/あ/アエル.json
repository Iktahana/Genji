    "definitions": [
      {
        "index": 1,
        "gloss": "to dress (vegetables, salad, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
