        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこら中を見ても、駅長や赤帽らしい人の、影もなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったらあの赤帽の信号手がまた青い旗をふって叫んでゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤帽が柱の周囲に、不性らしく立つてゐる。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったらあの赤帽の信号手がまた青い旗をふって叫んでいたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の上り下りには赤帽が世話をする、車中では給仕が世話をする、食堂車がある、寝台車がある、宿屋の手代は停車場に出迎えて居る、と言ったような時世になったのですから、今の中等人士は昔時の御大名同様に人の手から手へ渡って行って、ひどく大切にされまするので、山も坂も有ったものじゃあ有りません。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらじゅうを見ても、駅長や赤帽らしい人の、影もなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこら中を見ても、驛長や赤帽らしい人の影もなかつたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思つたらあの赤帽の信號手がまた青い旗をふつて叫んでゐたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤帽君に荷物を頼んで、廣い處をずらりと見渡したが、約束の同伴はまだ來て居ない。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と切符を三枚頼むと、つれを搜してきよろついた樣子を案じて、赤帽君は深切であつた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」其處で、別の赤帽君の手透で居るのを一人頼んで、その分の切符を託けた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」畜生、驕らせてやれ――女の口で赤帽君に、恁う言つた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――後日、東京驛へ歸つた時、居合はせた赤帽君に、その二十四――のを聞くと、丁ど非番で休みだと云ふ。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用をきいて、ところを尋ねるから、麹町を知らして歸ると、すぐその翌日、二十四――の赤帽君が、わざ／＼山の手の番町まで、「御免下さいまし。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜岡でも、三島でも、赤帽君のそれぞれは、皆もの優しく深切であつた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、黒山の中の赤帽で、そこに腕組をしつつ、うしろ向きに凭掛っていたが、宗吉が顔を出したのを、茶色のちょんぼり髯を生した小白い横顔で、じろりと撓めると、「上りは停電……下りは故障です。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いずれも、今はじめて知ったのでは無さそうで、赤帽がしかく機械的に言うのでも分る。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤帽の言葉を善意に解するにつけても、いやしくも中｜山高帽を冠って、外套も服も身に添った、洋行がえりの大学教授が、端近へ押出して、その際じたばたすべきではあるまい。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも御苦勞樣……」　幾らかけんのある眼で、却つて反撥するやうに車内をぐるりと見渡した女は、滑かな東京辯で赤帽に云つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤帽の敷いてくれた敷物の上にオペラパツクとパラソルを無造作に投げ出すと、腰掛けようともせずに手袋をぬぎにかかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、少しばかりですけれど……」　むつちりとふやけたやうな手の指先で、帶の間の紙入から五十錢札をぬき出すと、赤帽に手渡しながら、女は聞えよがしの聲で云つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、これはおおけに……」　人の好ささうな中年の赤帽は幾度か頭を下げながら、間もなく車室を出て行つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はその赤帽のうしろ姿を流し眼に見送ると、しどけなく敷物の上に腰を降ろした。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、腰掛にぢつと坐り込んでゐた女は靜に空氣草履をはいて、寢倒れた乘客達や、卑しげな眼を向けてゐる政黨屋達の姿を尻目にかけるやうにして、呼び入れた赤帽に旅行鞄を、そして、右手にオペラパツク、左手にパラソルをと、はいつて來た時の樣子さながらにそそくさと車室を出て行つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸事倹約」「寄附一切御断り」などと門口に貼るよりも未だましだが、たとえば旅行すると、赤帽に二十円、宿屋の番頭に三十円などと呉れてやるのも、悪趣味だった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷かつぎというのは、鉄道の赤帽のように、お金をもらって人の荷物を運ぶ人です。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
