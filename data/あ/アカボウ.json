  {
    "uuid": "f1560138-a8de-5976-86be-d8fd384ceb50",
    "entry": "赤坊",
    "reading": {
      "primary": "アカボウ",
      "alternatives": [
        "あかぼう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Bodianus cylindriatus (species of hogfish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "通路を距てて直ぐの向ひ側には、鉄道従業員の妻君みたいなのが、胸をはだけて赤坊に乳を飲ませてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤坊が五分置きくらゐには目を覚まして泣きはじめる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤坊の真ん前に腰掛けてゐるのは女の先生で、尤も先生だといふことは翌朝になつて分つたので、一寸見た所では薬専か歯科医専の生徒だらうと思はれた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀想に前の赤ん坊が目を覚ますたんびにその泣声に目を覚まし、俄かづくりの笑顔で以て赤坊をあやしてやる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊の洟が出た時には、その所狭い胸に挟めてあつた紙を出して、てづから洟を拭つてやつた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私は当時猶赤坊であつた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り廊下に近い一棟の病室の者達が、最早その赤坊の苦しげな絶え／＼の泣き声のために「急病人あり」と知つて、縁側に出て見えもせぬ診察室の方に首を伸してゐた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生焼けだね」と医者が云ふと赤坊を膝に載せてる母親が乞食のやうな調子で泣いて「わたくしが悪うございました」と云つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊の顔を覗き込んでる母親の日本髪を上の方からチラと憎々しげに見遣つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が拑子を突つ込むと赤坊が踏まれた蛙ののどのやうにヒクツヒクツとなつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一先づ拑子を引くと再び赤坊は此の世のものとしての苦しさうな表情となつて出来るだけ泣き喚き出した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして赤坊の唾液で濡れた拑子を指先で挟んで持つてゐながら、母親が子供を揺りながら泣いたり、その子の瞳を見入つて一言二言狂気のやうに云つたりするのを「そんなにして俺が何が出来るものか」と思つて立つてゐた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労性の妻君が余りに赤坊の泣き声が変なので庭を横切つて来てそこから覗いてゐる所だつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の視線が妻君に放たれた時に妻君がピクリと怖ぢけたので、まあ黙過しようかとも思つたが、少し赤坊の母親に気の毒な気がして来てゐた時なので云つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "両足を拡げ、反射鏡に手をかけると、今度こそ本調子に赤坊の口中を睨み込んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の赤坊が華族の家の何不足無いところに生れたとします。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然する時は此の赤坊は自然に比較的幸福であります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然る時はこの赤坊は自然に比較的不幸福であります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "善事をした訳でも悪事をしたわけでも無くて、貴家に生れると窮乏の家に生れるとで其の赤坊の運命は大なる差があります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大なる差を赤坊のせゐにするのは不道理でして、これは前定的運命を其赤坊が負うて居るのです。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ赤坊でも器量良く生れるのも、器量悪く生れるのもあります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな人並外れて大きいがに、赤坊のような人でなもし。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所に住む或る大工に片づいて、可愛いゝ二つになる赤坊をもつた一番の姉が作つてよこした毛繻子の襷をきりつとかけて、兄は実体な小柄な体をまめ／＼しく動かして働いた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して姉から赤坊を受取つて、思ひ存分頬ぺたを吸つてやりながら店を出た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に姉の膝の上で眠入つて居た赤坊が突然けたゝましく泣き出した。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末は戸口まで送つて出て、自分の腹の痛みを気にしながら、赤坊の泣き声が涼しい月の光の中を遠ざかつて行くのに耳をそばだてゝ居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の昼頃突然姉の所から赤坊が大変な下痢だと云ふ知らせが来た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その夕方可愛いゝ赤坊はもうこの世のものではなくなつて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日前に赤坊の命日をすました姉は、その日縫物の事か何かで鶴床に来て、店で兄と何か話をして居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
