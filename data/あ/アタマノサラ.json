        "examples": {
          "standard": [
            {
              "text": "毎日、頭の皿について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭の皿戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭の皿の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭の皿という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭の皿について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭の皿の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭の皿に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭の皿を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭の皿は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭の皿は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭の皿は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭の皿を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭の皿」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭の皿」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭の皿」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭の皿」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
