        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘納豆について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘納豆の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘納豆が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘納豆について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘納豆の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘納豆が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘納豆という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘納豆についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘納豆は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘納豆が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘納豆は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘納豆の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘納豆は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘納豆は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし甘納豆の場合にはこの物の形が蜂を誘うたとは思われない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か嗅覚類似の感官にでもよるのか、それとも、偶然工場に舞い込んだ一匹が思いもかけぬ甘納豆の鉱山をなめ知っておおぜいの仲間に知らせたのか、自分には判断の手掛かりがない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいう通り、滞在期間が長いから、大抵の客は甘納豆とか金米糖とかいうたぐいの干菓子をたずさえて来るので、それを半紙に乗せて盆の上に置き、御退屈でございましょうからといって、土産のしるしに差出すのである。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校、中学校、自分が学校から帰って来ると、周囲の人たちが、それ、おなかが空いたろう、自分たちにも覚えがある、学校から帰って来た時の空腹は全くひどいからな、甘納豆はどう？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カステラも、パンもあるよ、などと言って騒ぎますので、自分は持ち前のおべっか精神を発揮して、おなかが空いた、と呟いて、甘納豆を十粒ばかり口にほうり込むのですが、空腹感とは、どんなものだか、ちっともわかっていやしなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　照子の機嫌は直ぐに癒つてしまつて、甘納豆が食べ度いから買つて来て呉れなどと言つて、彼を使役した。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも云う通り滞在期間が長いから、大抵の客は甘納豆とか金米糖とかいうたぐいの干菓子をたずさえて来るので、それを半紙に乗せて盆の上に置き、ご退屈でございましょうからと云って、土産のしるしに差出すのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘納豆、豆板、飴玉など、この時も妻は悦んだ。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "慵い体を木蔭のベンチに腰かけて、袂から甘納豆を撮んではそっと食べていると、池の向うの柳の蔭に人影が夢のように動いて、気疎い楽隊や囃の音、騒々しい銅鑼のようなものの響きが、重い濁った空気を伝わって来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本山の玉露・栄太郎の甘納豆・藤村の羊羹・玉木屋の佃煮・薬種一式・遊び道具各種。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "（車庫）　　　小工場（カステラ、甘納豆）　柳島　　十二月二十八日　あしたいらっしゃい。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまでくると雪が降り出して吹雪模様になってきたので、毛皮を着込んだり、コッヘルで甘納豆をたいてカロリーをとったりして戦の準備をした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "缶詰の牛肉と甘納豆で、殊に甘納豆はうまかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早くコッヘルを出して雪と甘納豆をほうり込み火をつける。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘法の小屋にはいつでも水が出ているので、中へ入ってコッヘルで甘納豆をたき昼食をする。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行がスキーを楽しみながら一ノ越を下って行くのを見送った後、コッヘルで甘納豆をたいて昼食をすまし、十一時にここを出発する。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　十子は汚れたエプロンを胸にかけて、皆にお土産の甘納豆をふるまっている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　十子は汚れたエプロンをもう胸にかけて、皆にお土産の甘納豆をふるまっていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルックから、大切な甘味、甘納豆を取り出してちびりちびりと楽しめば、激しいアルバイトの後なので、その甘さがたまらない。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大切な甘納豆がそこら一面に飛散して物にならなくなってしまったのは、最も身にこたえた。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "マロン・グラアセは栗の砂糖漬で、日本の甘納豆に当るだらう。",
              "citation": {
                "source": "甘い話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯の花はお勝手の棚の一ばん右の隅に甘納豆の箱に入つてをります。",
              "citation": {
                "source": "早春箋",
                "author": "辻村もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても相変わらず私はそそっかしいんですね、このときあるお百姓がうちでこしらえた納豆だといって木戸へおいていったのをてっきり甘納豆だと思ってムシャムシャとやり、すっかり皆に笑われてしまいました。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットだの、林檎だの、バナナだの、甘納豆だのをロオラは好みます。",
              "citation": {
                "source": "オカアサン",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃公は甘納豆を一掴み貰って帰って来た。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田の方へは今日お母さんのお気に入りのハブ茶と中村屋の柔かい甘納豆とをお送りいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "街では、甘納豆で中毒して人死にがあったりして居る季節ですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
