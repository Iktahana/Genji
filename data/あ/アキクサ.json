[
  {
    "uuid": "5e225098-66cd-50e3-a655-406f8b358b6e",
    "entry": "秋草",
    "reading": {
      "primary": "あきくさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plants which flower in autumn (fall)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三径の十歩に尽きて蓼の花　十歩に足らぬ庭先の小園ながら、小径には秋草が生え茂り、籬に近く隅々には、白い蓼の花が侘しく咲いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草を日本趣味といふ意味での、おとなしい閑雅さから、伊香保を日本趣味といふのは適評である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前は一面の秋草原。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷葉半ば枯れなんとして見る影もなきが一入秋草の色に映りて面白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草には束髪の美人を聯想すなど考えながらこゝを出でたり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜露にしめつた秋草の葉は月の光で青白くキラキラ光つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂原つぱへ出ると、南を向いた丘の斜面の草原には秋草もあれば櫻の紅葉もあつたが、どうも丁度工合のいゝ處を此處だと思ひ切りにくいので、とう／＼其の原つぱを通り越して往還路へ下りてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所々に秋草の花が咲き、赫土の肌が光り、伐られた樹木が横たわっていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草などのある広場へ出てみると、カンナや朝貌が咲きそろって綺麗だった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長屋は右側ばかりで、左側の空地は紺屋の干場にでもなっているらしく、所まだらに生えている低い秋草が雨にぬれて、一匹の野良犬が寒そうな顔をして餌をあさっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝んでいるうちに何かがさがさという音がひびいたので、思わず背後をみかえると、小さい蛇が何か追うように秋草の間をちょろちょろと走って行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草を画いた絹行燈がおぼろにとぼされて、その夢のような灯の下に彼女も夢のような心持でかしこまっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬は足もとに闌れた秋草の鉢を見た。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "織物ではあるが秋草が茂っている叢になっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にもあるような秋草が咲いていたり、踏切番の小屋に菊が咲いていたり、路傍のマリヤのみ堂に花が供えてあるのも見ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして秋草の世界をちょっとのぞくだけでも、このわれわれの身辺の世界は、退屈するにはあまりに多くの驚異すべく歓喜すべき生命の現象を蔵しているようである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる原っぱへ出ると、南を向いた丘の斜面の草原には秋草もあれば桜の紅葉もあったが、どうもちょうどぐあいのいい所をここだと思い切りにくいので、とうとうその原っぱを通り越して往還路へおりてしまった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に引用された十首は春秋の草花に対して自分の病の悲しみを詠じたものであるが、これには異種の植物名が八つとほかに「秋草花」という言葉が現われ、「春」の字が三、「秋」が二、そうして十首のおのおのにいろいろな形で病者の感慨が詠み込まれている。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんどその半身を蔽うまで、堆い草の葉｜活々として冷たそうに露を溢さぬ浅翠の中に、萌葱、紅、薄黄色、幻のような早咲の秋草が、色も鮮麗に映って、今踏込むべき黒々とした土の色も見えたのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は温室の中を覗いてるよりも、僅四五時間で作りあげたと云ふ秋草の庭が気に入つた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "衝と立つ時、遠浅の青畳、真中とも思うのに、錦の帯の結目が颯と落ちて、夢のような秋草に、濡れた銀の、蒼い露が、雫のように散ったんです。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敷居からすぐに潜ったが、唯、見る目も涼しく、桔梗の藍が露に浮く、女郎花に影がさす、秋草模様の絽縮緬をふわりと掛けて、白のシイツを柔に敷いた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　土蜘蛛の這込む如く、大跨を蜿ってずるずると秋草の根に搦んだ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁れる水も色を添へて極彩色の金屏風を渡るが如く、秋草模樣に露敷く袖は、丈高き紫苑の梢を乘りて、驚き飛ぶ蝶とともに漾へり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座に白粉の薫をほんのりさして、絽縮緬の秋草を眺めよう。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――露の凝つた秋草を、霜早き枝のもみぢに添へて、家内が麹町の大通りの花政と云ふのから買つて帰つた事がある。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……地蔵が化けて月のむら雨に托鉢をめさるるごとく、影｜朧に、のほのほと並んだ時は、陰気が、緋の毛氈の座を圧して、金銀のひらめく扇子の、秋草の、露も砂子も暗かった。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の秋草さびしく戦ぎて、上水白く流れゆく。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これじゃあ何かの怪談もありそうだ」　門内にはそのむかし雷火に打たれたという松の大木がそのままに横たわって、古い石甃は秋草に埋められていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
