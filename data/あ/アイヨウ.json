[
  {
    "uuid": "26fa82e7-f7b7-54ee-ae89-6a192e2347c8",
    "entry": "愛用",
    "reading": {
      "primary": "あいよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
