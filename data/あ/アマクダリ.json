[
  {
    "uuid": "e036d716-b259-5e9a-ac5c-1371ed893dd8",
    "entry": "天下り",
    "reading": {
      "primary": "あまくだり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retiring high-ranking government officials taking a lucrative job in a private or semi-private corporation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天下りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "天下りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天下りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天下りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天下りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天下りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "天下りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天下りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天下りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天下りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天下りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天下りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天下りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天下りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天下りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天下りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天下りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天下りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天下りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天下りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "工場長が天下り的に工場委員会をきめるのでは何んになる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学が日常生活に食い入らなくてはならぬというのは、科学が専門家の専有物や、専門家からの天下りの物だということの反対で、つまり科学は素人自身の産むべきものだということだ。",
              "citation": {
                "source": "科学と科学の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリティシズムは作品に対して、作家が実際に追求しようとしたイデーの再追求方を命じ、又、より高い天下りの理想をさえ課題として持ち出す。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象批評にとって気に入らないのは、あらかじめ文献的に設定された芸術法則を以て、様々の姿態の下に刻々現われる作品に天下り式に臨むという、あの文献学的クリティシズムの学究的な愚かさである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "重大さはそのことにあったにもかかわらず、日本では天下りに共和党デューイ個人の当選確実があんなにも注入され宣伝された。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御糺明の喇叭さえ響き渡れば、「おん主、大いなる御威光、大いなる御威勢を以て天下り給い、土埃になりたる人々の色身を、もとの霊魂に併せてよみ返し給い、善人は天上の快楽を受け、また悪人は天狗と共に、地獄に堕ち」る事を信じている。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、天下り委員会にまかしといて、謂わば、いなされたんじゃないか」「そうだ！",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天人天下り成され候て、ゼンチヨどもは、デウス様より火のスイチヨ成され候間、何者なりとも切支丹に成り候はば、こなたへ早々御越しあるべく候。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　先日西日本新聞の座談会でこの問題がでたとき、林房雄が、オレは国語が便利になるのに反対するわけぢやないが、あんなカタワな細工物を天下り式に押しつけられては堪らぬ、強制が不愉快なんだと云つて、大いにイキマイテゐた。",
              "citation": {
                "source": "新カナヅカヒの問題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して批判を加へるのが我々文学者の義務ではないか、役人のつくつた天下りの新文法に盲従しなければならないといふアナタの考へが妙ではないか。",
              "citation": {
                "source": "新カナヅカヒの問題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠々と天下りながら、帝都の屋根を照らしていた光弾が、一瞬間にして、粉砕されてしまった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の供出と同じことで農民は不平であり、大いに隠匿米もやりたいであろうが、今日と違うところは上からの天下り命令が絶対で人民の権利だの官吏横暴などと法規を楯にする手がないから、泣く子と地頭にはかたれないということになって、逃亡とか浮浪ということをやる。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の供出と同じことで農民は不平であり、大いに隠匿米もやりたいであらうが、今日と違ふところは上からの天下り命令が絶対で人民の権利だの官吏横暴などと法規を楯にする手がないから、泣く子と地頭にはかたれないといふことになつて、逃亡とか浮浪といふことをやる。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、主筆からの天下りの原稿を採用するのをいやがりながら、敢然と沒書にもなし得なかつた。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰文は天下りに※ぎとられた一千貫の怨みが忘れられず、毎日、大酒を飲んで激発していたが、日に日に女らしくなってくる花世のなりかたちを見ると、後から追いかけられるような気がして、またしても落着かなくなった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "実証科学は、それ自身の歴史的発達の途上に於てこそ、その機械的な悟性的な形式主義的立脚点の矛盾にも気付き、弁証法的な段階にまで意識的に洗練される必然性もあるのであったのに、ヘーゲルは全く非歴史的にも、之を天下り式の「体系」にまで化石化して了ったのであった。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　思惟一般の根本法則としての唯物弁証法一般をまず想定しておいて、之を自然に対する思惟（自然科学）や社会に対する思惟（社会科学）に適用しようと考えれば、それが可能であるためには、弁証法はこの二つの科学に於ける天下り式の方法である他はなくなる。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に於けるこの天下り式方法を自然弁証法や史的唯物論だと見做すのが、デボーリン主義として批判された方法論主義である。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云う意味は、形象を完備した浮き彫りのような事物の有様だけを本当の存在と考えたり、或いは与えられた眼前の現実に対して天下り式の理想を課して、この現実と理想との絶対的な深淵を当為（ゾルレン）を以て埋め得ると考えたりすることが、観念論だというのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この発展の方法が取りも直さず弁証法なのである（カントのアプリオリは、それが経験と共に始まったという規定を結局忘れて了う処に特色を有っていた、だから夫は何か天下り式に機能すると考えられる）。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、実証的研究方法のこの結果に過ぎない処の、原理的叙述方法だけを、単独に取り出して見るならば、それは多分、初めから天下り式原理に従っている処の、観念論的弁証法の、研究方法＝叙述方法と、混同される程似ているだろう。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば旧帝院の官僚的な解散と新帝院の天下り式結成とは、必ずしもプロレタリア美術との対立などを直接意識して行なわれた現象ではないが、依然一つの文化統制現象だろう。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなぜ之は全く天下りにではなくて経験と共に始まらねばならぬのか。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程大陸の合理主義は真理の根拠を、デカルトに於てのように、表象（観念）の明証に求めたから、一種の直観主義に立脚してはいるが、併しこの明証の直観は、明析と判明（Clara et distincta）という合理的な条件を有っているので、前の常識の天下り式テーゼを直覚的に承認するのとは全く別である。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来総長や学長は大学自身が推薦する人物を文部省が任命する習慣なのだから、文部省天下りの学長は困るという建前である。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンの指導者が、農民自身の中から出て来るいきさつっていうものは――天下りの指揮者がないときに――だから、リアリズムがとことんまで徹底すれば、おのずから、あすこへ行く筈じゃないんですか。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしくしておりな」　ぎゅうとさかねじにそのきき腕をねじあげると、ずばりと切りさげたような啖呵があまくだりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員の人選も一種のあまくだりであったにしても、民主化について正直に発言し行動することのできる人々が選ばれたのであった。",
              "citation": {
                "source": "「委員会」のうつりかわり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あまくだり』の巻なる天門の景のミルトン風なるはをかしからず、また七徳の化身を白鳥伝説に結びつけしは思ひつきなれど、描写少しく露骨に失せずやと思ふなり。",
              "citation": {
                "source": "『二十五絃』を読む",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いのは、或る鉄工場に入つてゐる少年でね、そこの自治会に加入して――勿論あまくだりの会だがね――その内部をモツト自分達のものにしなきやいかんと言ふんでグングン活溌に働いてゐる奴なんかがゐるんだよ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
