    "definitions": [
      {
        "index": 1,
        "gloss": "to wash again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い直すについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い直すの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い直すが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い直すについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い直すの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い直すが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い直すという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い直すについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い直すは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い直すが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い直すは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い直すの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い直すは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い直すは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分のものは、肌のものから、足袋まで、綺麗に片づけて、火熨斗を掛けて、ちゃんと蔵って、それなり手を通さないでも、ものの十日も経つと、また出して見て洗い直すまでにして、頼まれたものは、兄さんの嬰児のおしめさえ折りめの着くほど洗濯してさ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには半時間も掛って洗っているようになり、洗って居間へ戻る途中廊下で人にすれ違うと、また引き返して行って洗い直すのである。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
