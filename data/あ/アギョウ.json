            }
          ],
          "literary": [
            {
              "text": "まあ行って火をたかう。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ行っておいで。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの野はらや丘が、あんまり立派で明るくて、それにかげろうが、「さあ行こう、さあ行こう。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ行って来るぜ、父爺。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく牛乳をとりながら見てくるよ」「ああ行っておいで。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こんどあ、おれあ行って見べが。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどあ汝あ行ってみろ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあそれであ行ぐべな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ行つておいで。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お魚はなぜああ行ったり来たりするの。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、あらかた茸を取ってしまってお父さんが、「さあ行こう」　と言われますと、姉さんと坊ちゃんが立ち止まって、「まあ、毒茸はみんな憎らしい恰好をしている事ねえ」「ウン、僕が征伐してやろう」　といううちに、片っ端から毒茸共は大きいのも小さいのも根本まで木っ葉微塵に踏み潰されてしまいました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぢやあ行つて來るぜ、父爺。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ行こう、今夜も確か来ているから。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ行って見ようや。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こんどあ、おれあ行つて見べが。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどあ汝あ行つてみろ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私あ行く処が無えんだよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川岸女郎になる気で台湾へ行くのアいいけれど、前借で若干銭か取れるというような洒落た訳にゃあ行かずヨ、どうも我ながら愛想の尽きる仕義だ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は熊本君から風呂敷を借りて、それに脱ぎ捨てた着物を包み、佐伯に持たせて、「さあ行こう。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はああ行かなければ嘘だ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ行こう』（涙を押える）幸子坊『南無阿弥陀仏、南無阿弥陀仏』蓮如『さあ参ろう』（おくみ、後姿を見送り合掌、幕）　　　　　第二場（舞台正面、源右衛門の住家。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲撃ちの時にゃあ、おれもこんな犬おどしの木刀を差しちゃあ行かねえ。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃあ行くさ」「どこかへ行って、でも、困るといけないわ」「困ったって……」「お金を幾らか持っているの？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ行くとも、――いつでもどこにでもゆくよ」「さて、これでまた昔通りになったわけだね。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ行こう、――」「ちょっと彼の女に逢わせて下さいませんでしょうか？",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸多の亭主の下手人は大津屋の重兵衛と睨んでいるものの、確かな証拠も無しに手を着けるわけにゃあ行かねえから、まあ気を長く見張っていろ」　亀吉は承知して帰ったが、それから十日ほど後に、かの孤芳は太宗寺のそばを立ち退いてしまったと報告した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うら口へまわって、そっとのぞくわけにゃあ行きませんか」「よろしゅうございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わっし一人で請け合うわけにゃあ行かねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が何か言うと、「起きたかな、お目ざましをあぎょう」と言って母は竈の熱灰の中に埋めておいた朝鮮芋を取りだして、その皮をむいて持って来てくれた。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
