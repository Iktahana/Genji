        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これは哀話の例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寝床で母からよく聞かされた阿波の鳴門の十郎兵衛の娘の哀話も忘れ難いものの一つであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古來、世界中の文藝の哀話の主題は、一にここにかかつてゐると言つても過言ではあるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、その港町の或る旅館に一泊して、哀話、にも似た奇妙な事件に接したのである。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は銀子が松の家へ住み込むちょうど一年前に起こった、この哀話を断片的に二三の人から聴き、自分で勝手な辻褄を合わせてみたりしたものだったが、土地うちの人は、この事件に誰も深く触れようとはしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来、世界中の文芸の哀話の主題は、一にここにかかつてゐると言つても過言ではあるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳右衛門の頑固な法華の主張がこんなところに顔を出しては、この哀話も、ぶちこわしになりそうだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、あの哀話の美しい姉弟が津軽の生れで、さうして死後岩木山に祭られてゐるといふ事は、あまり知られてゐないやうであるが、実は、私はこれも何だか、あやしい話だと思つてゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってここには、多くの哀話とともに鬼魅悪い話が残っている。",
              "citation": {
                "source": "焦土に残る怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名音が尼僧になったのは、中年になってからで、其の動機に就いては、小説にでもなりそうな哀話があるということだが、それに就いては語らなかった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ときパナマに駐在してゐるフランスの領事が、ルッセの部下の機械技師に服を買つてとゞけてやり、あすそれを着て午餐会に出てお出でとつたへたところ、技師はその日の中に黄色熱にかゝり、朝の三時にはもう死んでゐたといふ哀話ものこつてゐます。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人が源七から聴いたという哀話は大体こういう筋であった。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このナヴラティル夫人の物語は、数多い遭難哀話中のナンバア・ワンとして、タイタニックの名の記憶される限り残るであろう。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸か、抑亦不幸か、運命はこの危険なる時期に際して、予を予が年少の友たる本多子爵と、一夜｜墨上の旗亭｜柏屋に会せしめ、以て酒間その口より一場の哀話を語らしめたり。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外婚」のなごりとして、「つま別れ」の哀話が限りなく発展して来た訣は此点から考へられさうである。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、娘を売る哀話は、青森県の津軽半島へ入ってから実際に聞きもし見もし、私は、その売られた娘とも会って話したのであるが、これは後で述べることにして、私は先ず、青森県下へ踏み込んで、第一番に見聞した三本木町、七戸町附近、及び浦野館村一帯の飢餓地の惨状を述べなければならない。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとの話かどうか、何んでも満洲の兵隊は、一人について、歯ブラシが二十本も渡ったり、キャラメルが十ずつも配られたりするちゅうが、こちらの国の家では、六銭の金にも不自由している始末ですからな」　これに似た哀話が、中郡和徳村のある出征軍人の家族にもあった。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手紙を、今暫く書き続ける事を、恕してくれるなら、君は人生の生々しい哀話に、必らずや心を動かされずにはいられないと思う。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪談会を背景として、泉鏡花氏の口から、こうした新事実を聴いた僕は、余りに身近な、余りに生々しい現実の哀話に、何とも形容し難い重々しい心持に落ちた。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山口は以前百余戸あったものが、今はその半数、この二三年に廃戸になったものだけでも二十三戸を数え、死滅か離散か、いずれも哀話ならぬはないと、役場員の説明も声がうるんでいた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味ふかいのは、こういう誇張された話になると、語り手は自分で嘘と知りながら昂奮し、それがもし哀話であれば、その哀れさに自分で涙をこぼした。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが寒蝉の哀話からまた移って、土筆を見つける際の呪文のようにまでなったのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの一風かわったヨシキリの声によって、下郎の絶望した斬れ斬れ斬れの罵りの語を空想し、更にありそうなお寺の名を取添えて、一場の哀話を組立てたなどは、これもまた日本特産の中世の大衆文芸であったろうと思う。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それとまた、筆まめな良覚法師は、合戦以外の、いくつかの哀話や巷談をも書き忘れていなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戦後哀話の一つ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "男だの、女だの、七八人寄って、たかって、猿にからかって、きゃあきゃあいわせて、わあわあ笑って、手を拍って、喝采して、おもしろがって、おかしがって、散々慰んで、そら菓子をやるワ、蜜柑を投げろ、餅をたべさすわって、皆でどっさり猿に御馳走をして、暗くなるとどやどやいっちまったんだ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿あ、馬鹿あいわねえもんだ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更こんな雪の山の中へ来て」「じゃ言ってみようか」「あゝ」「この前、会ったときの先生は、気高くはなっていたが、まあいわば、おふくろさんかおばさんの感じだった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田川の奥さんかわいそうにまだあすこで今にもあなたが来るかともじもじしているでしょうよ、ほかの人たちの手前ああいわれてこそこそと逃げ出すわけにも行かないし」「おれが一つ顔を出して見せればまたおもしろかったにな」「きょうは妙な人にあってしまったからまたきっとだれかにあいますよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所がらといい、場合といい、深いたくらみがあって、わざわざかように人騒がせいたしたやもあいわからんぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はッ」「あいわかったか、予に成り代わって、ふびんなそのふらち者じゅうぶんに取り調べたうえ、ねんごろにいたわって、しかとしかりつけい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
