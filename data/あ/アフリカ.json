        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿弗利加について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この阿弗利加は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が阿弗利加について知っています。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は阿弗利加の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では阿弗利加が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から阿弗利加を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも阿弗利加が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では阿弗利加が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも阿弗利加は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも阿弗利加は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で阿弗利加は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に阿弗利加について学びました。",
              "source": "幻辞"
            },
            {
              "text": "阿弗利加の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する阿弗利加の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では阿弗利加の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また熱帯無人境の阿弗利加内地や、原始的なる南洋タヒチの蛮島等は、単にそれを思うだけでも、吾人にとって詩的の興奮を感じさせる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の例に於て、阿弗利加の内地や熱帯の孤島を詩的と考えるのは、煩瑣な社会制度に悩まされて、機械や煤煙やのために神経衰弱となってるところの、一般文明人の主観である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら彼は、阿弗利加の沙漠の中で、より詩的な生活を行為しようと思ったから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教的共産主義者の小さい集團は四世紀に北阿弗利加に孤立してゐたが、（Donatismus）加特力教の成立と倶に衰亡した。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "少時足藝師の子分と成り、外遊中病で置去られ、阿弗利加沿岸の地諸所多く流寓、十七年の間、或は金剛石坑に働き、又ペンキ塗などを業とせし由、ズールーの戰爭に英軍に從ひ出で、賞牌三つ計り受用す。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では世界中で亜細亜や阿弗利加を除いては到る処にエスペラント協会が出来てゐて、其教科書は各国語に飜訳されてある。",
              "citation": {
                "source": "エスペラントの話",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花の原産地は阿弗利加の喜望峰だといふ事だが、あれなぞも何処かの男が禅坊主にでも食べさす積りで持つて来たものかも知れない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレオパトラやマクベス夫人に扮して名を売つた英吉利の女優ラングトリ夫人が、まだ若盛りの頃ある宴会で、その頃ちやうど倫敦を訪れて来た阿弗利加の或る王様と一緒になつた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野と連立って、阿弗利加を経て帰って行く船の旅の方を択ぶことにした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい燈火のかげを歩き廻る時の彼の心は、どうかするとまだ巴里の大並木街の方へも行き、帰りの旅に見て来た阿弗利加の殖民地の港の方へも行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は南｜阿弗利加ダアバンの港へも寄って石炭を積んで来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心はまだ南｜阿弗利加のケエプ・タウンへも行き、ダアバンへも行き、あのマレエ人や印度人や支那人なぞの欧洲人と群居する新嘉坡あたりの町へも行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の経験から考えますと、この毒薬は阿弗利加産のストロファンツス草から採取したものだと思います。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弗利加の原地人は、こいつを槍や矢の先に塗って敵と闘いますが、これが傷口から入ると心臓｜麻痺をおこします。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弗利加の薬種を仕入れる便利が充分あります。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の宝石商ブルウス・テイラアが、南阿弗利加から巴里へ来て、このホテルへ止宿ったのは、事件の起る三日前の十月五日だった。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイラアは毎日喫煙室の隅に腰掛けて、ホテルの主人の和蘭人ミニィル・ヴァン・デル・ヴェルドを相手に、南阿弗利加の和蘭岬のことなどを、和蘭語まじりの英語で話し込んでいた。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弗利加のスウヴアの兵営に七年もいましたからな。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき船は阿弗利加沖を駛っていたが、ガルールは仏領南｜亜米利加はギヤーヌの徒刑場へ流された苦い経験を思いだし、マロンは阿弗利加屯田兵の営舎から脱走して営倉に叩きこまれたときの記憶を喚びおこして、心ひそかにこの海上の自由を讃美しているのであった。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわたしの知つて居る若い詩人のパウルが大学を卒業して阿弗利加に居る父親の処へ行く時、七年の間の屋根裏の生活を止めたので作つた詩ですわ。",
              "citation": {
                "source": "素描",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを思へば昼は詩人の領ならず、天つ日は詩人の光ならず、蓋し阿弗利加を沙漠にしたる悪しき※の気息のみ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弗利加趣味と西欧趣味とが斯う旨く調和しているなんて、なんて素的な町だろう！",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋の上海にも居りましたし、ストックホルムにも居りました――寒い北海の瑞典のね……そうかと思や南阿弗利加のケープタウンにも居りましたよ。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし貴郎は殺人鬼です」二　理学界の権威、植物学の大家として世界に其名を響かせていた理学博士のコックニー氏が阿弗利加大陸の探検を了えて自分の故郷のカンタブリア村へ自分の息子のバルビューと一緒に永住の覚悟で移転して来たのは、今から丁度二年前の金雀花の咲く春であった。",
              "citation": {
                "source": "物凄き人喰い花の怪",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……阿弗利加産の虫捕菫と阿弗利加産の『もうせんごけ』とを、コックニー博士の手腕を以て交尾わせて出来たのがこの花だ！",
              "citation": {
                "source": "物凄き人喰い花の怪",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は大旅行を常に夢み、殊に印度、中央亜細亜或は阿弗利加の奥地に心を惹かれてゐたらしいけれども、横浜から神戸までの僅か一昼夜の海上生活にたわいなく満足し、隣組の問題には驚くほど熱心で、近所の子供たちを集めて音楽会をやらせ、自分がお守役を引きうけるといふ始末である。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビヤの沙漠をわたる熱風を満面に浴びて遠くシナイの山顛を眺め、火のような阿弗利加の、空にはアクラブ Akrab, 10000ft. の英姿を仰いで、いくたび船の上で山を讃美したろう。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弗利加とは言へ二月の埃及は決して暑くはない。",
              "citation": {
                "source": "埃及雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために暗黒アフリカの真只中にロンドン製品の包紙がちらばるようなことになる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八―九年の冬の間に南アフリカへ遊びに来ないかという招待を、時の南アの長官セルボーン卿から受けたので、そのついでに南洋へも廻る気で出かけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
