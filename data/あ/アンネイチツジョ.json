          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安寧秩序について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安寧秩序の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安寧秩序が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安寧秩序について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安寧秩序の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安寧秩序が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安寧秩序という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安寧秩序についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安寧秩序は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安寧秩序が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安寧秩序は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安寧秩序の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安寧秩序は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安寧秩序は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同年九月六日この日安寧秩序を紊亂するものとして社會主義書類五種發賣を禁止せられ、且つ殘本を差押へられたり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに裁判所が公判開廷の初日に於て公開を禁止したる爲に、復疑を容るゝものありと雖も、苟も對審の公開にして安寧秩序を害するの虞ありと認めたるときは、之を停止し得べきは國法の命ずる所にして、裁判所は普通の事件に付ても之を行ふことを得。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは安寧秩序を妨げたり、臣民の義務に背かせない限りの自由である。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安寧秩序を妨げたり、臣民の義務に背かせるやうな思想は危險思想である。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民ノ安寧秩序ヲ保持スルコトガ國家ノ唯一任務ナリトセバ、國民ノ死活榮辱ヲ日夜ニ亘リ終生ヲ通ジテ脅威シツツアル此等ヲ處分セズシテハ國家ナキニ同ジ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバルトソン・スミスも「宗教は不可知的力を恐れるより起るのではない、己と血族の関係ある神を敬愛するより起るのである、また宗教は個人が超自然力に対する随意的関係ではなくして、一社会の各員がその社会の安寧秩序を維持する力に対する共同的関係である」といっている。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その趣意は、あんな消極的思想は安寧秩序を紊る、あんな衝動生活の叙述は風俗を壊乱するというのであった。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの Propagande par le fait の連中が縛られると同時に、社会主義、共産主義、無政府主義なんぞに縁のある、ないし縁のありそうな出板物が、社会主義の書籍という符牒の下に、安寧秩序を紊るものとして禁止せられることになった。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安寧秩序を紊る思想は、危険なる洋書の伝えた思想である。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三月中旬に発売されたが、発売と同時に、安寧秩序を妨害する廉を以て、忽ち差押を喰つた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私の場合には限らない、総じて大学教授の書いたものが安寧秩序を妨害すと認められ、発売を禁止されると云ふことは、その地位が問題とされる事由となり得る虞れがある。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学教授の書いたもので、社会の安寧秩序を妨害すと認定され、発売を禁止されたのは、多分これが初めてであつたであらう。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのが全国に幾つあるかしれないが皆んな合はすと大変な額だぜ』『仕方がないやね、安寧秩序を保つて貰ふ為めに払ふ税金だあね、これがなきあ吾々安心して生きて行けないんだもの。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の安寧秩序を保つ上に於て、犯罪人を検挙して告発する職務にある以上、頑強な犯人や、反社会思想の顕著な者に対し、温情を以て諄々として説く事は必要であろうし、時にその途なしと考えながらも自白すれば重かるべき罪も軽くなるように説くのも蓋し止むを得ないであろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち黄道（太陽の年毎の運行）と赤道（太陽の日毎の運行）との截點（一三――五行註參照）一〇―一二〔師〕神〔目を〕神はその創造の御業を善とし給ふのみならず、常に萬物の安寧秩序を顧み給ふ一三―一五〔圈〕獸帶。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもの始まりから他人の家へ無断でのこ／＼這入りこんでくるなんて、策の斬新奇抜なところは大いに買ふが、安寧秩序をみだし良良なる風俗を害ふ底の人騒がせは許しがたい悪徳であるなぞと途方もないことが書いてあつたよ。",
              "citation": {
                "source": "西東",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康に害なく、風俗人情を悪化せしめず、世の安寧秩序を維持する力がある。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝都の安寧秩序を保つために、この際やるところまで極りをつけるのだ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に幸福を要求する恋愛は国家の安寧秩序を破壊する純然たる叛逆である。",
              "citation": {
                "source": "恋愛と道徳",
                "author": "エレン・ケイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの議論中にひそむ大なる誤謬は社会の安寧秩序は必然に個人の犠牲によつて成就せられると云ふ観念である。",
              "citation": {
                "source": "恋愛と道徳",
                "author": "エレン・ケイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "７．たとへ藝術家と雖も公の安寧秩序に對する義務の拘束を少くとも或る種の限界までは意識せねばならぬ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "14．あらゆる日本臣民は信仰の自由を有す、但し社會の安寧秩序と臣民としての義務に抵觸する場合はこの限りに非ず。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてしかるときは、政府が一国の安寧秩序を保つの目的を達することあたわざるべし。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の安寧秩序が警察によって保証されることは、科学的に云えば要するに以上のことに尽きていると云っていいだろうと思う。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり北支一帯に於て、一種の緩衝地区とも云うべき安寧秩序の確保された地域が実現されることだけで満足するものに他ならなかった。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、実は、華北大衆の安寧秩序そのものとさえ、原則上は関係がないのだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論恐らく事実上は之が北支の安寧秩序を確保することは或る限度まで必ず出来るであろうが、それは付帯的な結果であって、本当の目的でも何でもない。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争を挑発したりして安寧秩序を害する不穏文書の取り締りのためには、出版法を改正しようではないか、というのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり北支一帯に於て、一種の緩衝地区とも云うべき安寧秩序の確保された地域が実現されることだけで満足するものに他ならない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
