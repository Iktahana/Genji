        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あるいは落ち着かない気むずかしい愛情でジョルジュを飽かせることがあったし、あるいは彼に飽きはてたがようにそのなすままに任せることがあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世は遊ぶためにあって、百姓庶民は自分たちを遊び飽かせる為に生きている――そういう公達の頭には、太政入道が空脛の青年時代に、瀕死の親の医者を迎えるため医師へ行っても来てくれず、薬価の算段に歩いても何処でもすげなく断られ、垢じみた破れ直垂一枚で、冬空の下を、　今に見ろ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体の秘密をあばいたら、それによってどちらか一人の口をあかせることが出来ると思う。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、康雄の力で、彼女の口をあかせるのが、最上の方法だと考えたのであろう。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしたはずみに、ピドールカがやつと口をあかせると、妙にきよとんとしながらも、すこしは話もして、気分もいくらか晴れるやうなのぢやが、ふと、くだんの袋を見ると、『待て待て、どうも思ひ出せんわい！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんは百軒目の大願成就の日だから錢形の親分の鼻をあかせるんだといつて、つまらない手紙なんか出したので、私は一生懸命父さんにお願ひして、代つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の役目",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
