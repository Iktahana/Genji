        "examples": {
          "standard": [
            {
              "text": "私は毎日改まったについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改まったという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改まったの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改まったが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改まったを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改まったについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改まったの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改まったの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改まったが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改まったという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改まったという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改まったについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改まったを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改まったは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改まったについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改まったが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改まったは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改まったの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改まったは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改まったは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御尊父様へよろしく」と改まったる御挨拶で。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体高山の初雪というのは、改まった暦の初めに降るという意味なのでなく、雪の消滅時季なる夏を通過してから、後に初めて降る雪を言うのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には僕が余り俄に改まったのを可笑しがって笑えば、民子も遂には袖で笑いを隠して逃げてしまうという風で、とにかく一重の垣が二人の間に結ばれた様な気合になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の入口の外の廊下には色々の人声がしていた、長岡先生のいつものような元気のいい改まった言葉も聞えた、真鍋さんが何か云うと佐野さんの愉快そうに笑う声も聞えた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん困るのは親類などへ行って改まった挨拶をしなければならない時であった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "章は改まったが、彼は抱擁したままの状態を改めなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と平常ならば恥かしいような改まった口調で云った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやや改まった様子で机の前に座っていると、思いがけない顔をしてやまがはいって来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、みんなも、」とたぬきは改まった顔つきをして、みんなを見渡し、「四年から受けるならば、ちょっと受けてみましょうなんて、ひやかしの気分からでなく、必ず合格しようという覚悟をきめて受けなくてはいかん。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（改まった顔つきになり、強い語調で）あさは、あの子をほしいと言っているのだが。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはそれには取り合わず、改まった顔つきをして、「あの、ねえさん、すみませんがね、ここのご主人にないないお話し申したい事がございますのですけど、ちょっとここへご主人を」　と言いました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と改まったように尋ねた。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそあなたの協力に本当に感謝しますわ」　改まった口調で加奈江が頭を下げてみせたので明子も段々気がほぐれて行って「お目出とう」と言った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと娘の内へ行って見ようかと思ったが、なんだか改まったような気がして、我ながら不思議な遠慮がある。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の二月に、年号は文久と改まったのである。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま、拝むように一礼すると、又も咽泣の声が改まった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、夫人が更に何を云い出すのかと、呆っ気に取られて、夫人の顔を、ぼんやり見上げていると、「子供の教育についてですねえ……」と、改まった言葉に、「はい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って、久しぶりでどことなく、ふくらみを持った気持で、鏡台に向うと、新子はまた一層気持が改まった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹が、いろいろお世話になりまして……」と、言葉が改まった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "めったに父と二人で出る事のない子供は何かしら改まった心持ちにでもなっているのか、不思議に黙っていた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六　戴いたのは新しい夏帽子、着たのは中形の浴衣であるが、屹と改まった様子で、五ツ紋の黒絽の羽織、白足袋、表打の駒下駄、蝙蝠傘を持ったのが、根岸御院殿｜寄のとある横町を入って、五ツ目の冠木門の前に立った。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見ると成程一昨年来た時も、其前に来た時も改まった挨拶などはしなかった様に覚えてるが、しかしながら今は岡村も慥か三十以上だ。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は腰を半ば上りはなに掛けたなり、予に対して鄭嚀に挨拶を始めた、詞は判らないが改まった挨拶ぶりに、予もあわてて初対面の挨拶お定まりにやる。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母もよめも改まった、真面目な顔をしているのは同じことであるが、ただよめの目の縁が赤くなっているので、勝手にいたとき泣いたことがわかる。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あら、そんなに改まった言い方をしては、おかしいわ。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が間もなく側の炭車へ腰かけながら、静かに改まった調子で口を切った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やあ、あらたまったな、なんだい。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の言う事は、いつも嘘ばかりで、ちっともあてにならないけれど、でも此のあらたまった言葉一つは、固く信じようと思った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伊沢はあらたまった口を利き、寒いから一つと言って猪口を差すので、銀子も素直に受け、一つ干して返した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時銀子は藤川のお神にちょっとお出でと下へ呼ばれ、若林の傍を離れて居間へ行くと、お神は少しあらたまった態度で、「若ーさんもお前はんが知っての通り、このごろひどい思惑はずれで蒼くなっていなさる。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
