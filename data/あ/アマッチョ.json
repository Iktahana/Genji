        "examples": {
          "standard": [
            {
              "text": "私は毎日尼っちょについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は尼っちょの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には尼っちょが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは尼っちょについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は尼っちょの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では尼っちょが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に尼っちょという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では尼っちょについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると尼っちょは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では尼っちょが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に尼っちょは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により尼っちょの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "尼っちょは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に尼っちょは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何、此の間スタニスラフの尼寺から二人尼っちょが来たんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気な尼っちょが顔を見て云った。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、「あまっちょ」「甘ったるい物の言い方」「甘い文学」などいう場合には、甘味によって明らかに反価値性が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "――このあまっちょだな。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤア、学校の先生があまっちょにいじめられている！",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の外にて小さな声「あのあまっちょめが」○ここにゼラチンを用いずして梅羊羹を作る法あり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでふくらはぎを売っとばし、めねこを一匹、こちゃ買ってな、あまっちょのねこめも愛いやつじゃ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "私までがあまっちょろ過ぎる世界にゆっくり眼をやることをしないで、立原の詩を見過ごしている時すらあった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の身でそこまで考えなければならないんだ、そういう境遇が現にこの世にあるんだ」と栄二は自分を叱りつけるように呟いた、「――きさまなんかまだあまっちょろいもんだぞ」　東仲町へゆき着くまで、彼は同じことを繰返し考え続け、幾たびも眉をしかめては舌打ちをした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
