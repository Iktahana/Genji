    "definitions": [
      {
        "index": 1,
        "gloss": "animating (a character, object, text, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アニメーション化について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアニメーション化の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアニメーション化が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアニメーション化について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアニメーション化の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアニメーション化が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアニメーション化という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアニメーション化についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアニメーション化は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアニメーション化が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアニメーション化は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアニメーション化の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アニメーション化は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアニメーション化は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
