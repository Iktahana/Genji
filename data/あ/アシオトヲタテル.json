          ],
          "literary": [
            {
              "text": "が、松の樹はすやすやと息を立てて、寝姿かと思う静さで、何だか、足音を立てるのも気の毒らしい。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は歩むにつれてバタバタと足音を立てる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついぞこれまで、クララがあんな足音を立てるのを聞いたことはない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊が足音を立てる筈はない。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
