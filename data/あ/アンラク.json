        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安楽について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安楽という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安楽の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安楽が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安楽を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安楽について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安楽の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安楽の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安楽が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安楽という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安楽という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安楽についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安楽を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安楽は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安楽について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安楽が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安楽は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安楽の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安楽は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安楽は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "小渋川よりも、川幅が狭くて、谷地が、かえって濶いだけに、徒渉の回数は少い、深山の渓流としては、先ず安楽な方で、小渋川や、槍ヶ岳の蒲田谷などとは、深さと、急と、嶮しさとにおいて、到底、比べられない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処までも、自分の邸内にとどめて可哀想な乞食音楽師を安楽に暮らさせ様と心掛けました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯後書斎で手紙の返事、十時に助手のゴルドン出勤、その日の仕事の打合せ、午前中は大抵読書か書きもの、Phil. Mag. か Ann. d. Ph. が来ると安楽椅子で約半時間それに目を通してから書棚へ入れる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、十一時から十二時頃までは安楽椅子でうたた寝をしてから寝室へ行くという不思議な癖があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側の安楽椅子によりかかって寝ているイサックの黒い顔に未来の文明が浮き出ていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ということを言いたげに呉は、安楽椅子に、ポンと落ちこんでチューインガムをしがんでいる深沢をチラと見て、にたにたと笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことは長くつづく筈はないので、一万両の金を儲け出したらば、京都へ帰って田地でも買って、安楽に一生を暮らすつもりであったと式部は申し立てた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も、安楽椅子も、飾つきの卓も、蓄音機も、骨董や、金庫も、すべて、ナラズ者の南兵の掠奪に蹂躪されてしまうだろうと居留民たちは考えさせられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用の日ざしが狭い土堤いっぱいに涼しい松の影をこしらえて飽き足らず、下の蕃藷畑に這いかかろうとする処に大きな丸い捨石があって、熊さんのためには好い安楽椅子になっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲クヨウニ」　安楽なくらしをしているときは、絶望の詩を作り、ひしがれたくらしをしているときは、生のよろこびを書きつづる。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふには、髪もひげもまるで灰いろの、肥ったふくろふのやうなおぢいさんが、安楽椅子にぐったり腰かけて、扇風機にぶうぶう吹かれながら、「給仕をやってゐながら、一通りのホテルの作法も知らんのか。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドラ床の中で朝まで安楽成仏としようかな。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどんな時でも、清逸が学問をするために牽き起される近親の不幸（父も母もそのためにたしかに老後の安楽から少なからぬものを奪われてはいるが）は、清逸をますます学問の方に駆りたてはしても、躊躇させるようなことは断じてなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとファニーは安楽椅子に仰向きかげんに座を占めた母に抱きついて処きらわず続けさまに接吻していた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはただ座禅して無心になっているその生活中に解脱や安楽があるのだと説くものもあった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも、自分の邸内にとどめて可哀相な乞食音楽師を安楽に暮させようと心掛けました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仏教には一方、安楽平易な門が拓かれ、ただ信ずることによってのみ、かの「法性」の理を身に滲ますことがいくらでも出来るのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭愛極楽、家庭というものが認められて来て、そこを中心に安楽境を作ろうとする傾向が多くなって来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、安楽というものは意識に上りにくく、苦痛の方は意識されやすいもので、極楽の方は拾い出しにくいのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うには、髪もひげもまるで灰いろの、肥ったふくろうのようなおじいさんが、安楽椅子にぐったり腰かけて、扇風機にぶうぶう吹かれながら、「給仕をやっていながら、一通りのホテルの作法も知らんのか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それはそれは、安楽に一生を送ったのだ。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち其名の示すが如く、世人は何も英雄豪傑となるの必要なし、回天の偉業とか破天荒の雄飛とかは二十世紀には流行らぬものぞかし、各自皆其分に安んじ、円満なる家庭を作り、極めて平凡に、成るべく安楽に、社会の一員として平和なる一生を送れば足れりと云ふなり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く此峠を越しさへすれば安楽浄土は十方光明の世界を現じて、麓に照りかゞやいて居る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに安楽に、どんなにのびのびした生活が出来ることであらう。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから間もなく、獄卒は病気を云い立てに辞職して、その金銀で一生を安楽に送った。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頭火には其中庵がある、そこは彼にとつて唯一の安楽郷だ！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、お前はこの中にお前の生涯安楽にして食べるに困らないだけのものを見出すことが出来るだろう。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにお前の安楽な半生が準備してあります。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんらくじにて、もりかねの、うたざらゑあり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度でも、朝の内にいぢめられてゐた方がその日一日あんらくなやうな氣がし、泥でも藁繩でも打つかけられるままにされてゐる。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
