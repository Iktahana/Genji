        "examples": {
          "standard": [
            {
              "text": "毎日、仇するについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の仇する戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "仇するの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "仇するという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは仇するについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "仇するの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "仇するに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは仇するを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での仇するは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、仇するは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "仇するは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な仇するを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「仇する」という概念について深く考察する必要があります。",
              "source": "幻辞"
