    "definitions": [
      {
        "index": 1,
        "gloss": "someone who one considers as an elder sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉分について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉分という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉分の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉分が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉分を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉分について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉分の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉分の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉分が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉分という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉分という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉分についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉分を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉分は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉分について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉分が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉分は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉分の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉分は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉分は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ところが相手の女もまだ若くて、中々赤染右衛門の代作の手はしの利いている歌に返歌は出来なかったが、幸に其の姉分に和泉式部という偉い女歌人があったから、それに頼んで答をして貰った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いのは、おなじ、師匠なかま、姉分のものの娘です。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それという声が懸ると、手取早く二人の姉分の座敷着を、背負揚、扱帯、帯留から長襦袢の紐まで順序よく揃てちゃんと出して、自分が着換えるとその手で二人分の穿物を揃えて、三味線を――その頃腕達者な烈しい姉は、客の前で弾切ると糸を掛けてる中も間が抜けるといって、伊達に換え三味線を持ったので――四張。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「右衛門さんとは滅相もない、今こそ仲違いしているものの、お前の姉分島君さんの、恋しいお方ではござらぬか。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお鈴といふ娘は兩國では決して新しい顏ではありませんが、身體も心持も女になりきつてからは、藝にも人柄にも、顏にまでも魅力が出來て、その達者な踊と、歌と、素晴らしい綱渡りの曲藝で姉分のお夢の人氣を壓するほどの人氣者になりつゝある――といふことを、これも後で平次が知つたことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一と目千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――性が合ふと言ふものか、他人のやうな氣がしない、お頼殿さへその氣なら、此後は私の家へ引取つて、娘共の姉分になつて貰はうと思つて居るよ」「旦那の御｜配偶は？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――性が合うと言うものか、他人のような気がしない、お頼殿さえその気なら、この後は私の家へ引取って、娘どもの姉分になって貰おうと思っているよ」「旦那の御配偶は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお鈴という娘は両国では決して新しい顔ではありませんが、身体も心持も女になりきってからは芸にも人柄にも、顔にまでも魅力が出来て、その達者な踊と、歌と、素晴らしい綱渡りの曲芸で姉分のお夢の人気を圧するほどの人気者になりつつある――ということを、これも後で平次が知ったことです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一と目千両",
                "note": "青空文庫"
              }
            },
            {
              "text": "身請けをしてくれた旦那に死なれて、少しばかりの家財と共に、昔の姉分の時代を頼つて、此家へ轉げ込んだといふ女です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御雪、木津屋の御雪というのだ」「ナニ、木津屋の御雪……」　お松は、聞くともなしに耳に入った名は自分の姉分になる御雪太夫のことですから、思わず身が固くなる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
