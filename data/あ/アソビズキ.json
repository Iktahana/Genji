          ],
          "literary": [
            {
              "text": "といっても、もともと遊び好きだった訳でもなかったのだ。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点に於て普通の大阪の多少富裕な家の遊び好きのぼんちに異らなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　五所川原の人たちは遊び好きだから、それはずいぶん賑はふ事だらうと思つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しく整理された商会の農場は、土人の眼に公園の如く映り、其処へ自由に入ることが許されぬのは、遊び好きな彼等にとって不当な侮辱と思われた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その洋画家は、僕はいまこそ、感じたままをはっきり言いますが、ただ大酒飲みで遊び好きの、巧妙な商人なのです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重兵衛に豊といふ遊び好きな孫があつて、ある時｜廓返りに馬を連れて、古い素麺箱を一つ、豊橋のさる骨董屋に担ぎ込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "西山氏は遊び好きの多い京都画家のなかでも、一番の遊び好きである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具屋は西山氏に自分の依頼画が早く描かせたさに、いろんな口実を拵へては、この遊び好きの画かきを、三味線と白粉の街のなかに誘ひ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳里恭といへば、聞えた遊び好きの拗ね者ですが、この人は京都から大阪へ遊びに来るのに、いつも夜船に乗つて淀川を下つて来ました。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにぶん兄らがそろって遊び好きだから、自然と僕も落語や講釈なんぞが好きになってしまったのだ。",
              "citation": {
                "source": "僕の昔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は随分遊び好きな方だった。",
              "citation": {
                "source": "昔の思い出",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のようなゼイタクな遊び好きは窮屈な女房などになれないよというのだが、たって女房になりたけりゃ、華族の長男か、千万円以上の財産家の長男の奥方になれという。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は遊び好きの金のかかる女だから」「諦められる」「仕方がねえさ」「諦められるなら、大したことないのでしょう。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "見様によれば、平凡な、遊び好きの、やゝ熱中した娘の姿にすぎなかつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "農としては出水を憂うべきだが、遊び好きなる事に於て村の悪太郎等に劣るまじい彼は、畑を流るゝ濁水の音｜颯々として松風の如く心耳一爽の快を先ず感じて、尻高々とからげ、下駄ばきでざぶ／＼渡って見たりして、其日｜限りに水が落ちて了うのを毎に残念に思うのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松は兄に反して学問ギライ、遊び好き、芸ごとが好きで、唄三味線踊りを習い、寄席や芝居へ通うのが日課だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ぐらい遊び好きの子供はいなかったから、毎年まだ誰も海へ遊びに行かないうちに遊びはじめ、海に人の姿がなくなってから遊びおさめる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊襲的なところをあげれば三日三晩も夜神楽をぶッ通しで踊りぬく遊び好きなところと、色情に対して開放的な明るさであろう。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は遊び好きで、ハデなことが好きであったが、私に対しては献身的であった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はトマサンなる遊び好きの旦那が、自分の意志でもなく肉親の意にしたがって愛する女房を離絶し、その後は悶々として、一生女房の面影を忘れ得なかったなどというのは、てんで信用ができないのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも遊び好きの男に限って、こういう甘美な感傷的伝説の中に籠城したがるのでこまる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは由さんだけのことではなくて、六さんも、三三も、吉兵衛も、その息子の吉青年も、遊び好きでアクの強いことにかけては、由さんと変りはない。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒飲みで遊び好きの三馬は、またよく人と争い、人を罵って、当時の有名な京伝、馬琴などの文壇人とも交際がなかった。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "入内の後は、大宮は、麗景殿に住み、遊び好きで、政治の嫌いな天皇に、何かと政務を見る事をすすめていたという。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父の安兵衞も道樂強いうへ、甥の吉太郎と來ては一度勘當されたほどの遊び好きでございます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の市之助が、小柄ではあるがちよいと好い男で、遊び好きで、諸藝に達して、道樂が止まないに比べて、弟の三五郎は恰幅だけは立派ですが、色の黒い、愛嬌のない、何方かと言ふと、働く外に興味も能もない、不景氣な三十男でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "百足屋殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父の安兵衛も道楽強いうえ、甥の吉太郎と来ては一度勘当されたほどの遊び好きでございます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正月の三日ですよ、親分、足止めは殺生ぢやありませんか」　さう言ふ吉三郎が、若くて遊び好きさうに見えるのも不憫です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "どんど燒",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど遊び好きの男だから、岡場所や、芸妓にも、引っ掛りがあるだろう」「ヘエ――」「今度は泊って来ちゃならねえよ」「もう大丈夫で、――懐中には百もありませんよ、親分」「呆れた野郎だ」　平次は苦笑いをして見送ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            }
          ]
        }
