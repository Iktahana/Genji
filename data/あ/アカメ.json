    "definitions": [
      {
        "index": 1,
        "gloss": "red eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "父親の医者というのは、頬骨のとがった髯の生えた、見得坊で傲慢、その癖でもじゃ、もちろん田舎には刈入の時よく稲の穂が目に入ると、それから煩う、脂目、赤目、流行目が多いから、先生眼病の方は少し遣ったが、内科と来てはからッぺた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤目の嫗は自から深く打頷いた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "のさのさのさ、頭で廊下をすって来て、夫人の枕に近づいて、ト仰いで雨戸の顔を見た、額に二つ金の瞳、真赤な口を横ざまに開けて、「ふァはははは、」「う、うふふ、うふふ、」と傾がって、戸を揺って笑うと、バチャリと柄杓を水に投げて、赤目の嫗は、「おほほほほほ、」と尋常な笑い声。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だかちっとも分らねえが、赤目鰒の腸さ、引ずり出して、たたきつけたような、うようよとしたものよ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花の穗を採つて屈めて、上下の眼瞼に張り赤目をする遊戲があつた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の医者といふのは、頬骨のとがつた髯の生へた、見得坊で傲慢、其癖でもぢや、勿論田舎には苅入の時よく稲の穂が目に入ると、それから煩らう、脂目、赤目、流行目が多いから、先生眼病の方は少し遣つたが、内科と来てはからつぺた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大にして尾長く赤目なるは禺なり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがゆく海わがゆくかたは、月明りさし入るなべに、さはら木は腕だるげに伏し沈み、赤目柏はしのび音に葉ぞ泣きそぼち、石楠花は息づく深山、――「寂靜」と、「沈默」のあぐむ森ならじ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かべちゃべちゃしゃべっている女生徒もあれば、後ろをふり返って赤目をしてみせている男生徒もある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰は米を見返って溝の中へ捨てる真似をして道傍の材木の上へ金剛石を乗せて、赤目を一度してそのまま帰った。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "がりがりの赤目芋だった。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぎょろりとした赤目で、じっと見られましたなら、彼女はどうすることでしょう。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな運命とも言えるものの象徴が、彼のぎょろりとした大きな赤目でした。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後になると、彼は、自分の大きな赤目やちぢれた耳や耳の後ろの禿げなどを、彼女からじっと見られても、ただ日にあたり風に吹かれるぐらいにしか感じなくなりました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻正子が立ち現われた時、彼女に注いだ自分の赤目の凝視が、意識にはっきり戻ってきていました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久木」は即ち歴木、楸樹で赤目柏である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰側に出るのは真砂と称し、粒も大きく、黒色の光沢を有する磁鉄礦で、不純物も少いさうだが、山陽側に出るのは赤目と称し、粒も細かく、褐色を帯び、燐、硫黄、酸化チタニウムの含有量も真砂よりは多いといふ。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の扉がギーと開くと、赤目の眇で跛の頭髪のちぢれた女房が薪を小脇にかかえて、妙な歩みつきで出て来ると、じろりと翁の方を盗むように見て、ストーブに薪を投げ入れて、また妙な足つきで奥の方へ入ってしまう。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は或時、赤目の跛を拳で擲った。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼の赤目のちぢれ毛の跛を打ったように生徒を擲ったことを聞かぬ。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤目のちぢれ毛の跛にさえ、偶々ストーブに薪を入れに来るのを呼びとめて、霊魂不滅を説き聞せたことがある。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤目のちぢれ毛は遂には翁をば怖しい人だと思って翁がただ独りで教壇に向って、瞑想している時などには、たとえストーブが冷かになるということを知っても薪を持ち運ばぬようになった。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど翁は、赤目のちぢれ毛の、怠惰者の夫に向っては神を説き聞かしたことが一度もない。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は自分の居間で食事をしたり、寝たりするのは赤目のちぢれ毛の跛も決して見たことがないという。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤目のちぢれ髪の跛がしんとした真夜中頃、扉を細目に開けて、広間を覗くと、冷かな風が隙間を漏れて来る。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤目の女は暫時扉の隙から見守っていたが、容易に翁が身動きもせずに熟としているので、その儘音を盗んで扉を閉めて、自分等の室に歩みを返して眠てしまったという。",
              "citation": {
                "source": "点",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "山邸の上の谷戸にきめたが」　すると、赤目爛れのすさまじいのが膝を進めて、「その猪狩なら、われわれもねがうところ。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、この赤目の悪魔め！",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてバックが、跳ねあがろうとして身をひきしめた時、毛は逆立ち、口はあぶくを吹きだし、血走つた眼には狂つたような光をたたえ、全くの赤目の悪魔であつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、銀色赤目の怪物は、四つの窓のそとに、つぎつぎと、あらわれては消え、あらわれては消え、目にもとまらず、はやわざをくりかえしました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
