    "definitions": [
      {
        "index": 1,
        "gloss": "for something unexpected to happen (to someone or something one is close to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
