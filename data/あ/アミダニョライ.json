        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿弥陀如来について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿弥陀如来の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿弥陀如来が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿弥陀如来について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿弥陀如来の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿弥陀如来が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿弥陀如来という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿弥陀如来についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿弥陀如来は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿弥陀如来が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿弥陀如来は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿弥陀如来の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀如来は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿弥陀如来は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "阿弥陀如来といい、観世音菩薩というものも、実はこの働き（宇宙の大生命が「道」を私たちに覚らしめようとする働き）を指して名づけたものに過ぎません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをふびんぢや気の毒ぢやと思召して、罪業の深い我々凡夫をお救ひ下さると云ふのが阿弥陀如来の本願ぢや。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声に応ずるように御姿だけは幾度拝んだか分らない阿弥陀如来が忽然として、咫尺の間に出現し給うた。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は身にしむように思って、朝露と同じように短い命を持つ人間が、この世に何の慾を持って祈祷などをするのだろうと聞いているうちに、「南無当来の導師」　と阿弥陀如来を呼びかけた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見上げると、正面の阿弥陀如来の尊いお顔がいつの間にか玉藻のあでやかなる笑顔と変わっていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀如来の尊像はくすぶるばかりの香りの煙りにつつまれた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏工は古来より阿弥陀如来の立像と、地蔵菩薩の立像をむつかしい物の東西の大関に例えてある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまではいわゆる両部混同で何の神社でも御神体は幣帛を前に、その後ろには必ず仏像を安置し、天照皇大神は本地大日如来、八幡大明神は本地｜阿弥陀如来、春日明神は本地釈迦如来というようになっており、いわゆる神仏混淆が行われていたのである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "神仏混淆廃止改革されたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは手前が本尊阿弥陀如来の前で誓言立てても苦しゅうござらぬ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に安座まします人間大の黒い阿弥陀如来の像は、和尚の差し出した蝋燭の灯に、一層いかめしく照し出された。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、阿弥陀如来の前に来たかと思うと、真下にあたる勤行の座につき、手燭をかたわらに置いて言った。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これから人殺しをするのだ」「どこで……」「ここで」「誰を殺すのですか」　和尚は返答する代わりに、殺気に満ちた顔をして、左手で、阿弥陀如来の方を指した。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀如来の後ろから、巨大な鼠のような真っ黒な怪物が、さッと飛び出して、あたりのものを蹴散らかし、一目散に逃げ出して行った。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はやはり非常に暑くて、暑いための汗と、恥かしさの汗とで、静也は多量の水分を失い、告白の最後には声が嗄れてしまって、まるで、死にともない老婆が、阿弥陀如来の前で、念仏を唱えて居るような心細い声になった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが自分はひたすらに阿弥陀如来の救済の本願にすがるばかりで、その他には所詮自分の生きる道はないというのが有名な親鸞上人の信仰の告白で、これも亦今迄に多くの人々によって幾度かくりかえされている。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、たとえ阿弥陀如来の光明に接しないでも、自分の「運命」を忍受するだけの修業は出来ていると自分では考えている。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し尻を持ってゆくなら、寧ろ僕はそれを阿弥陀如来のセイにでもしてやろうと考えている。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無料宿泊所が、自分たち同国人にのみしか与えられない恩恵を、阿弥陀如来の広大無辺の教義に民族的な息窒りをすら感じながら、本堂脇の玄関に歩いて行った。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩日向の家屋は板壁であるのを不思議に思つてゐたが宿の主人の話で、その謎が解けた、旧藩時代、真宗は御法度であるのに、庶民が壁に塗り込んでまで阿弥陀如来を礼拝するので、土壁を禁止したからだと。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中扉の青い紗を透して一番奥の掛軸の阿弥陀如来の像や、その前に供へた御飯や、花瓶や、亀の上に鶴の乗つて居る蝋燭立てや、輪燈やが眼に入つた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに見よ、世間の愚民、人の言を信じ、人の書を信じ、小説を信じ、風聞を信じ、神仏を信じ、卜筮を信じ、父母の大病に按摩の説を信じて草根木皮を用い、娘の縁談に家相見の指図を信じて良夫を失い、熱病に医師を招かずして念仏を申すは阿弥陀如来を信ずるがためなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その廚子の上には経文と一しょに、阿弥陀如来の尊像が一体、端然と金色に輝いていました。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大御神を知らねばこそ、方々はかくも信心の誠を尽して、阿弥陀如来なんぞと申す妖魔の類を事々しく、供養せらるるげに思われた。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵のお寺は、練馬の宇定寺で、覘う一件は、唐の国から伝来の阿弥陀如来像であった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の正面には、西をうしろにして木像の阿弥陀如来が立っており、その前に、にぎやかな仏壇がこしらえてあった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
