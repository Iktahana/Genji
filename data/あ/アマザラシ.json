        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨ざらしについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨ざらしの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨ざらしが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨ざらしについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨ざらしの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨ざらしが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨ざらしという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨ざらしについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨ざらしは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨ざらしが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨ざらしは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨ざらしの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨ざらしは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨ざらしは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こんなものでも半年も戸外につるして雨ざらしにして自然の手にかけたら、少しは落ちついたいい色調になるかもしれないと思ったりした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間雨ざらしになっているらしい鉄の構造物はすっかり赤さびがして、それが青いトタン屋根と美しい配合を示している。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木賃御泊宿――内湯あり――と、雨ざらしに成つたのを、恁う……見ると、今めかしき事ながら、芭蕉が奧の細道に……五月朔日の事也。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、其処には牡丹の花のきれいな燈籠が雨ざらしになっていた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、ここには守屋大臣の碑が雨ざらしにされている。",
              "citation": {
                "source": "荒雄川のほとり",
                "author": "――私の郷土を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそちらには、三尺ばかりの幅を置いて、となりの家の物置の黒い板塀の背中が見えてゐて、その下に、白く雨ざらしになつた大きな貝殻が二つ三つ、土の中に覗いてゐる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒下へ犬小舎を置いてやらない主人は、雨が一日びしょびしょ降りつづいても、小舎を雨ざらしの門傍に出したままだ。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下は物置になつてゐるが、雨ざらしの大工はしごを登つて見ると、六疊敷の座敷があつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、我々は思ひがけない――もちろん、広告軽気球がどこから昇つてゐるかなぞと考へて見たりする暇は誰にもないが――それでも、ハイカラな球とは似つかない、汚い雨ざらしの物干台に到着する。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草をわけ枝をむすんで、長いあいだここにくらしていたが、救いの舟もきたらず、ついにこのさびしい石垣のなかにたおれて、骨を雨ざらしにしたのか。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ざらしの門柱に、市木正信というまずい字の表札が出ていたが、たぶん本人の自筆であったろう。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかはすべて雨ざらしで鳥や獣に食われるのだろう、手や足がちぎれていたり、また記標に取られたか、首さえもないのが多い。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所深川の堀割の橋際、麻布芝辺の極めて急な坂の下、あるいは繁華な町の倉の間、または寺の多い裏町の角なぞに立っている小さな祠やまた雨ざらしのままなる石地蔵には今もって必ず願掛の絵馬や奉納の手拭、或時は線香なぞが上げてある。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころの休茶屋の、雨ざらしにされた床几の上には、枯葉にまじって鳥の糞が落ちている。",
              "citation": {
                "source": "曇天",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが深水と打ちあわせてある場所で、古びた藤棚の下に石の丸卓があって、雨ざらしのベンチがあった。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今度は自動車の客が、雨天の節は雨ざらしにならねばならなかった。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年のままに葎がす枯れている、家裏の日当りの悪いところに、脚の折れた机や、バネの飛びだした革張りの椅子が雨ざらしになって、いくつも投げだしてある。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢の私の家の庭には雨ざらしの木の椅子があって、立原は午前にやって来ると、私が仕事をしているのを見て声はかけないで、その木の椅子に腰を下ろして、大概の日は、眼をつむって憩んでいた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は帰ったことを、一応は皆んなに教えて来るとよかったね」　とある掛け茶屋、花には早い雨ざらしの縁台に掛けて、平次はこんな世間並なことを考えて居るのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の道の草堤に沿って、軍用トラックが八台、片方のタイヤを溝の中へおとして、雨ざらしのまま並べられている。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではお前はもう雨ざらしの材木か、ぼろ土で固めた塀も同然じゃ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ざらしの材木には彫刻は出来ぬ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "古河のほうへはその後も大量に買いつけてあったので、四月になっても送られて来る荷が、はけきれないまま物置からはみだし、空地に積まれて雨ざらしになるという始末だった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ見ても、家の軒下で何年も雨ざらしになったような、Ｔシャツと半ズボンだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうだ、四、五日のあいだ、武蔵の身は、あの千年杉の梢に上げて、手足を幹に縛りつけ、雨ざらし風ざらし、鴉に眼だまをほじらせてくれたらどうじゃろ？",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎をそこへふん縛って、頭の上のあたりへ、板を一枚打ってくれ」「なにか、お書きになるので」「そうだ」　大工の墨つぼを借りて、それへ差尺筆で、一ツ　泥棒一ぴきせんだって迄、半瓦の部屋の飯食い者、再度悪事のかど之有り候につき、雨ざらし陽ざらし、七日七晩きゅうめいさせ置候ものなり。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、二千円の代物を雨ざらしにもならず、誠に困ったものです。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "はりこの鳥居だとか、石灯籠だとか、石膏でつくった銅像のようなもの、そのほか、いろいろのものが、雨ざらしになって、おいてあるのです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ざらしにするものを」　と、せせら笑っている。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
