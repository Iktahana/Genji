        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗流について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗流という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗流の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗流が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗流を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗流について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗流の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗流の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗流が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗流という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗流という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗流についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗流を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗流は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗流について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗流が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗流は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗流の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗流は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗流は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こういうふうに考えてくると流涕して泣くという動作には常に最も不快不安な緊張の絶頂からの解放という、消極的ではあるがとにかく一種の快感が伴なっていて、それが一道の暗流のように感情の底層を流れているように思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気とか、暗流とか、気分とかといふことは、その底から起つて醸して来てゐるのである。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷は、底のほうに気持ちの悪い暗流を潜めながら造り笑いをし合っているような不快な気分に満たされた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、国際聯盟の「世界悪」退治運動の重要項目の一つに上げられてるくらいで、パンフレットを発行したりして妨止に努めてるけれど、いくら国際聯盟あたりが躍起になって騒いだって、それは単にその暗流の実在を公表するにとどまり、何ら直接｜刷掃の資にはなるまい。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家の内部的生命は、暗流の如く個人の胸中に流れて居るのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、ダンネベルグ夫人を狂人みたいにさせた、怖ろしい暗流が判ったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その黝ずんだ溝臭い溜水の中で、あの五人の方々が喘ぎ競いていたのでございますわ」　こうして、四人の神秘楽人の正体が曝露されると同時に、過去における黒死館の暗流には、ただ一つ、二つの変死事件のみが残されてしまった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、岩塩を溶かし、石灰岩を溶かし地下へ滴る石油が大盲谷をつくったといわれる」　ああ、大盲谷をうねくる、石油の大暗流。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの世相の一面に着して、故らに性慾の陥穽を按排し、以て真実の研鑽に出でたりとなす、所謂世慾に適するや否やを知らずと雖も、かゝる人心の傾向相縁りて、暗流横溢の外に立たじとするこそ極めて人情に遠きなからんや。",
              "citation": {
                "source": "抒情詩に就て",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、根競べにて、勝を制せんと思うものから、急らず逼らず、擒縦の術を尽せしが、敵の力や多少弱りけん、四五間近く寄る毎に、翻然延し返したる彼も、今回は、やや静かに寄る如く、鈎※の結び目さえ、既に手元に入りたれば、船頭も心得て、玉網を擬し、暗流を見つめて、浮かば抄わんと相待つ。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と、理を説きて帰航を促したれば、船頭も、意｜解けて、釣具を納め、錨を挙げ、暗流を下りけるが、更に再遊を約して、相分れき。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りもおり、土生仙之助の一行が左膳の助剣にあらわれたので、乱刃のままに長びいてはわが身あやうしと見た栄三郎、ひそかに、再び左膳と会う日近からんことを心中に祈りながら、橋下の暗流――雪の横川へとびこんで死地を脱した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何も、表立った白洲にかかっているわけではなく、どこといってつかまえどころのない、底にうごめいている暗流のようなものであったが、忠相は、そこに、早晩何らかの形で、事件として持ち込まれてくるであろう可能性をみたのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此先又何んか變な事がなきや宜いが――」　平次はこの事件の底を流れる無氣味な暗流に氣付いたらしく、そんな事を言ひ乍ら割り切れない心持で引揚げるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一般大衆の意識に於ける反ファシズム的な根強い暗流なのだが、インテリゲンチャの意識も亦この動向に食いつかない筈はないわけで、左翼的思想のための社会的支柱を失ったように見えた彼等インテリゲンチャは、何とかしてここから夫に代る新しい思想活動原則の拠り処を導き出そうとあせったことを、見逃してはならぬ。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、感情の暗流は、当然真木に、一種の暗い直覚を与えていた。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその暗流はすでに業に動いているのである。",
              "citation": {
                "source": "選挙人に与う",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、人心の現状に満足せぬという暗流が拡がりおるに相違ない。",
              "citation": {
                "source": "勢力の中心を議会に移すべし",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、現状に満足せぬという暗流の漲っているに相違ない。",
              "citation": {
                "source": "勢力の中心を議会に移すべし",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに内務大臣副島種臣は志を閣内の暗流にはばまれて憤然と致仕したが、松方は自らこれを兼務して議会を乗り切り、七月十四日河野敏鎌を移して内務にすえた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "譜代大名である友田喜造とは、なにかと暗流を衝突させているのかも知れない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "師として、指導のよろしきを得ねば、梵天の悪魔に化すかも知れず、その珠たる質のみがきによって、この荒び果てた法界の暗流と濁濤をすくう名玉となるかも知れない。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
