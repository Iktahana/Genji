        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "凡そ政治家の功名心を飽かすべき最好の機會は、殆ど一として公の手に觸れざることなく、是れと同時に其の政略及び行動は時として物議の中心たることありと雖も、終始善く皇上の御信任を全うして頭等元勳の待遇を受けたり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ政治家の功名心を飽かすべき最好の機会は、殆ど一として公の手に触れざることなく、是れと同時に其の政略及び行動は時として物議の中心たることありと雖も、終始善く皇上の御信任を全うして頭等元勲の待遇を受けたり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれ一層わが傍に近づき來れ、願くはしばしなりとも抱き合ひ、悲痛の思ひ飽かすべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其大神はかく命ず、アキルリュウスを飽かすべく、　175あまたの寶携へて子のヘクトール贖へと、トロイア軍の何人も同じく共に行く勿れ、ただ老年の使のみ汝に附きて騾馬を引き、輕車曳くべし、而うして彼れ英豪のアキリュウス、殺せる汝の子の屍體イ，リオン城に運ぶべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何うあらうとも、今夜は戸外にあかす覺悟して、まだ湯にも水にもありつけないが、吻と息をついた處へ――　前日みそか、阿波の徳島から出京した、濱野英二さんが駈けつけた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△放浪によりてえたる貧しき収穫より――旧作□美しき人を泣かして酒飲みて調子ばづれのステヽコ踊る旅籠屋の二階にまろび一枚の新聞よみて一夜をあかす酒飲めど酔ひえぬ人はたゞ一人欄干つかみて遠き雲みる酔覚の水飲む如く一人に足らひうる身は嬉しからまし　　　　　　　△　△　△△先日の句会では愉快でした。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、吉弥とお袋との鼻をあかすために、すッぱり腹をたち割って、僕の思いきりがいいところを見せてやりたいくらいであったが、しみッたれた男が二人も出来ているところへ、また一人加わったと思われるのが厭さに、何のこともない風で通していた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中には夜をあかす島もない。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は手紙でしばしば大木にあかそうとしたけれど、あかす機会もなかった。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も昔も初会から苗字をあかす者はない。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の長いのに余り早く泊まり過ぎたとも思ったが、今さら草鞋をはき直して次の駅まで踏み出すほどの勇気もないので、どの道ここで一夜をあかすことに決めて、明るいうちにそこらの様子を見てこようと思い立って、宿の浴衣を着たままで表へふらりと出て行った。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれも実はその古歌の心を覚っているのであるが、師直の前であらわにそれを説きあかすのを憚って、好い加減に取りつくろって逃げて来た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、一つもういっぺんあの親方の鼻をあかすかね」　ちくしょうッ、いやな野郎がうせやがった、というような顔つきで、口をとがらかしていた伝六をしり目にかけながら、にたにたとうち笑って敬四郎のところへ歩みよっていったとみえましたが、いきなりぺこりと腰を曲げると、ごく屈託のなさそうにあいさつをいたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきつばた柳河の古きながれのかきつばた、晝は ONGO の手にかをり、夜は萎れて三味線の細い吐息に泣きあかす。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきつばた柳河の古きながれのかきつばた、晝は ＊ONGO の手にかをり、夜は萎れて三味線の細い吐息に泣きあかす。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで青二は、この青年に、重大な秘密をあかすことにした。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜鈴木にて一夜幼き昔を語りあかす。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから文学批評も小さなワクをぬけ出て、人民解放のためどういう意味をもつかを人民生活の諸関係と結びつけてときあかす組織者としての批評が望ましい。",
              "citation": {
                "source": "批評は解放の組織者である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、夏になると、よく宿なしの浮浪人たちが、この墓地で夜をあかすからであります。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大平さんを娘が殺したことと思いこみ、もう外出する勇気もなく一夜をあかすと、この御方（丑村刑事）が見えましたので、一時はびっくりしましたが、それは意外にも『好色破邪顕正』に関する御たずねで御座いました。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さの用意は相当にして来たけれど、その時、風さえ加わって、たとい人家の軒下でも、一夜をあかすのは可なりに苦しかろうと思い、何とかして、人家の中でとめて貰いたいという慾望が起って来た。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保にとゞまつて山かせぎするものも、山を降りて思ひ／＼の家路に就かうとするものも、こぞり、つどつて、その一夜を飮みあかすことを駕籠かきどもの『あんこ別れ』といふよしである。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "タネをあかすことはできない。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この「神さまに忘れられた」ドュウルンに、あわれ一夜をあかすことに決心していると、パブスト老は二人のボウイをはじめ女中下男の一同をあつめて、誰でも、どこかでカイゼル、もしくはカイゼルに似た人――後姿でもいい――を見かけたものは、宙を飛んで急を私たちに告げよと申し渡している。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで星の下で夜をあかす覚悟をして、路傍の適当な草地を見つけて、そこに臥して眠りにつこうとした。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる推理小説家にとっては、この事件が他殺か自殺かをはっきりさせて、その原因、手段をときあかすことが眼目だろう。",
              "citation": {
                "source": "「推理小説」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七祖出現の使命は要するに「インド西天の論家、中夏、日域の高僧、大聖興世の正意をあらはし、如来の本誓、機に応ぜることをあかす。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人とも住む家は違ふけれども、一度、築地の經理學校のところで行きあつてから、約束もしないのだけれど、何となく二三度行きあつて、繩張りがきまつたやうになり、各々、いろんな相手を、その場次第で見つけてはそのかいわいをうろついて夜をあかすのである。",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は寝る場所さへも失くして公園で夜をあかすことをさへ忍ばねばならなかつた。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした雑誌の編集者たちと飲みあかす晩も少なくなかった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
