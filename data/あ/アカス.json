    "definitions": [
      {
        "index": 1,
        "gloss": "to pass (the night)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第二のクライマックスは赤穂城内で血盟の後｜復讐の真意を明かすところである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君が今夜は一晩星をねらいながら明かすことであろうと思って寝床にはいった。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめだね」　もう地下鉄の中ででも夜を明かすより方法がない、と娘の方へ半泣きの顔を向けると、「もう一軒当ってみましょう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、名前は明かせないと言ってるんですよ」「なぜ明かせないんですか」「明かすと、あなたは土下座しなくちゃならない」「えっ……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、名前は明かせないと言ってるんですよ」「なぜ明かせないんですか」「明かすと、あなたは土下座をしなくちゃならない」「えっ……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体あんたはどなたですか」「あたしですか」「名前は明かせないとおっしゃいましたね」「明かすと、土下座しなくちゃならない……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは最初彼が石油を取り出した時は、恐らく彼はその朝ぼくが彼女を嫌いだと言った言葉や、その後のぼくの彼女への態度から考えて、あるいはぼくが彼の肩をもって彼女の迷信だという説に反対して石油をのむかも知れないと思い、彼女の鼻を明かす積りで買って来たのだろうと思った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも腑抜けず、ぶるぶるふるえながら夜を明かすと、死骸を埋めた足で早速工事場へ濡れ鼠の姿を、首垂れて現わした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さまざまな女が、いかにも女の都の京都らしく、あるいは一夜妻の、そして土曜夫人として週末の一夜を明かすと、日曜日の朝の河原町通りは、昨夜の男が子供にせがまれていそいそと玩具のジープを買うのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、いくらか元気が出て、泣きながら夜を明かすと、また歩きました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ吉弥が僕との関係を正直にうち明かすはずはないが、実は全く青木の物になっていて、かげでは、二人して僕のことを迂濶な奴、頓馬な奴、助平な奴などあざ笑っているのかも知れないと、僕は非常に不愉快を感じた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に家に入り、気味の悪い一夜を明かす。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先はわざと明かすまい。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い思案も泛ばず、その夜は大阪駅で明かすことにしたが、背負っていた毛布をおろしてくるまっていても、夏服ではガタガタ顫えて、眼が冴えるばかりだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の飾窓で蝨をつぶしている音を聴きながら、その夜を明かすと、もう暮の二十八日、闇市の雑閙は急に増えて師走めいた慌しさであった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球戦の入場券一枚を手に入れるために前夜からつめかけて秋雨の寒い一夜を明かす勇敢な人たちの話は彼を驚かし感心させた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、解き明かすのにちょうどいい時がくるまで待つことにした。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の流儀を貫き、明かす度合いの大小も自在。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩はうちで明かすのかい？",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに雨は急に晴れそうにもないし、汽車も翌日の午後でないと乗れないから、そこで一夜を明かすことにして雨戸に手をかけると、苦もなく明いたので、内へ入って寝たところであった。",
              "citation": {
                "source": "指環",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでぼくたち、夜だけ、人間のかたちになって明かすのだからね。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いろいろな思いつきが浮びやすいということや、それがどれもこれもいかにももっともらしいということは、この謎をとき明かすことのたやすさよりも、むしろそのむずかしさを示すものと考えなくちゃあならないんだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、強健な人が筋肉を働かせる運動を喜んで自分の肉体的能力を誇るのと同じように、分析家はものごとを解き明かす知的活動に熱中する。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、謎や、難問や、象形文字が好きで、凡人の理解力では超自然とも見えるほどの明敏さで、それらを解き明かす。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして一緒にこの恐ろしい夜を明かすことにしよう」　私の取りあげた古い書物はラーンスロット・キャニング卿の『狂える会合』であったが、それをアッシャーの好きな書物と言ったのは、真面目でというよりも悲しい冗談で言ったのだ。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷の名を明かすわけにも行かない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何うあらうとも、今夜は戸外にあかす覺悟して、まだ湯にも水にもありつけないが、吻と息をついた處へ――　前日みそか、阿波の徳島から出京した、濱野英二さんが駈けつけた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△放浪によりてえたる貧しき収穫より――旧作□美しき人を泣かして酒飲みて調子ばづれのステヽコ踊る旅籠屋の二階にまろび一枚の新聞よみて一夜をあかす酒飲めど酔ひえぬ人はたゞ一人欄干つかみて遠き雲みる酔覚の水飲む如く一人に足らひうる身は嬉しからまし　　　　　　　△　△　△△先日の句会では愉快でした。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、吉弥とお袋との鼻をあかすために、すッぱり腹をたち割って、僕の思いきりがいいところを見せてやりたいくらいであったが、しみッたれた男が二人も出来ているところへ、また一人加わったと思われるのが厭さに、何のこともない風で通していた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中には夜をあかす島もない。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
