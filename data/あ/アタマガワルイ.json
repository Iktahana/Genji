        "examples": {
          "standard": [
            {
              "text": "毎日、頭が悪いについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭が悪い戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭が悪いの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭が悪いという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭が悪いについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭が悪いの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭が悪いに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭が悪いを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭が悪いは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭が悪いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭が悪いは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭が悪いを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭が悪い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
