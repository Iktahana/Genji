        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "白芥子の花のような日光がちらり落ちる、飛白を水のおもてに織る、岩魚が寂莫を破って飛ぶ、それも瞬時で、青貝摺の水平面にかえる、水面から底まではおそらく、二、三尺位の深さであろうが、穂高岳を畳んで、延ばしたり、縮めたり、自在にする、水の底に白く透いて見えるのは、石英が沈んでいるのだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上の雲が、いくらか火を含んで、青貝をすったようなつやが出る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔沃度ノニホヒフルヒ来ス〕沃度ノニホヒフルヒ来ス、　　　青貝山ノフモト谷、荒レシ河原ニヒトモトノ、　　　辛夷ハナ咲キ立チニケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光、ただに身に添うばかりでなく、土に砕け、宙に飛んで、翠の蝶の舞うばかり、目に遮るものは、臼も、桶も、皆これ青貝摺の器に斉い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝に渡して、ほした大根のかけ紐に青貝ほどの小朝顔が縋って咲いて、つるの下に朝霜の焚火の残ったような鶏頭が幽に燃えている。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから書卓の抽出を開け、象牙の柄に青貝の鋳り込んでいる、女持ちの小形なピストルを取り出した。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士　若様はこの冊子と同じものを、瑪瑙に青貝の蒔絵の書棚、五百｜架、御所有でいらせられまする次第であります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔流行つた無地の面子の淡紫、淡紅の色、また古渡りの器皿の青貝の螺鈿の輝き、その惹起する感情は孰れも相似てゐるが、わたくしは其齎らす情緒の成因を分析する術を知らない。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又青貝の戸棚に並びたるは珍駄婁の媚酒、羅王中の紅艶酒。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては又腰に提げた堆朱の印籠から青貝の鞘、茶※、白金具という両刀の好みまで優にやさしく、水際立った眼元口元も土佐絵の中から脱け出したよう。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時あわてて馳けつけた原大隅守虎義は傍にあった信玄の青貝の長槍をとって、相手の騎馬武者を突いたがはずれ、その槍は馬の三頭（背すじの後部）をしたたか突いたので、馬はおどろいてかけ出したので、信玄は虎口を逃れた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元流石に屈せずに槍の青貝の柄を斬り折ると共に小平太の膝を割ったので小平太はのめって仕舞った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも背は二フィートで、三角の上反り帽をかぶり、股のところまで下っている真紅のチョッキを着、鹿皮の半ズボンをはき、赤い毛の靴下と、大きな銀の締め金のついた重い靴とをはき、青貝の大きなボタンのついた長い上着を着ている。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に居て、そこへ、茶盆を直した処、俯向いた襟足が、すっきりと、髪の濃いのに、青貝摺の櫛が晃めく、鬢も撫つけたらしいが、まだ、はらはらする、帯はお太鼓にきちんと極まった、小取廻しの姿の好さ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ取落したか、青貝摺ので、しかも直ぐ襟許に落ちていました。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御厨子の前は、縦に二十間がほど、五壇に組んで、紅の袴、白衣の官女、烏帽子、素袍の五人｜囃子のないばかり、きらびやかなる調度を、黒棚よりして、膳部、轅の車まで、金高蒔絵、青貝を鏤めて隙間なく並べた雛壇に較べて可い。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、能の葛桶のような形で、青貝じらしの蒔絵で、三巴の定紋附の古い組重が沢山ありますね。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の部屋には、為切の唐紙四枚の内二枚が塞がるやうに、箪笥が据ゑてあつて、その箪笥の方に寄せて青貝の机が置いてある。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "友信は穗の長さ二尺六寸餘、青貝の柄の長さ七尺五寸二分ある大身の槍に熊の皮の杉なりの鞘を篏めたのを持たせ、屈竟の若黨十五人を具して舟を守護した。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お柳の豊かな髪が青貝をちり嵌めた螺鈿の阿片盆へ、崩れ返った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "形体は私が寝ていて想像したよりも大きかったが、果して全身雨に濡れしょぼたれて、泥だらけになり、だらりと垂れた割合に大きい耳から雫を滴し、ぽっちりと両つの眼を青貝のように列べて光らせている。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つはこれに木瓜の青貝螺鈿の卓が添はつてゐた事で、今一つはこの香炉が贋物であるといふ事であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　僕は昨夜の夢に古道具屋に入り、青貝を嵌めたる硯箱を見る。",
              "citation": {
                "source": "病中雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い柄に青貝を鏤めた薙刀もかゝつてゐる。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "青貝色の櫛もさして、桃色のてがらもかけて髷も結んでみたい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青貝の櫛もさして、桃色のてがらもかけて髷も結んでみたい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は、不如意な家持ちの暮しぶりは同じことながら今はそこへ腰をすえた気分で、二階の手すりに近く深々と桐の青葉のひろがる濃さや、見下す隣家の竹垣のわきで紫陽花が青貝のような花片を燦めかせはじめたのを、眺めた。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
