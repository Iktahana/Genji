    "definitions": [
      {
        "index": 1,
        "gloss": "brown-headed thrush (Turdus chrysolaus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "車中から偶然見る湖岸に漣波が立つて赤腹といふ小魚が群騷いでゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を問えば赤腹となん答えける。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも近くの池の底に沈んでいる空缶や茶碗の破片の間に赤腹がのろく動いているのを眺める。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不潔な山が春から夏への季節には再びなみなみと湧き上がる水の底へ沈んでいきその上を蛙や赤腹が泳ぎ廻るのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠑※の赤腹を見ると、嘔吐が出る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は守宮だといったが、これはこのへんの堀にいる赤腹だ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そんなに遠くでへっぴり腰をしていないで、近くへ寄ってよく見ろ」　清五郎は首を差しのべておずおずと眺めてから、「いかにも、こりゃア赤腹」　アコ長はニヤリと笑いながらとど助のほうへ振りかえり、「とど助さん、少々妙ですな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの美しい虫も、小川に泳いでゐる小さな赤腹の魚も彼れの足を止めはしなかつた。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "囀る声はこんな天気の日の外気の中にきくのはわるくありませんけれど、それよりも時々山鳩や赤腹や野鳥が来ます百舌鳥も。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは赤腹という魚ですよ」二「――まさかね」　万三郎はそら笑いをした。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が知らないと思って、赤腹だなんてそんな、――中谷さんも人が悪いですな」「いや本当です」　あんまり笑ったので、兵馬は涙を拭きながら坐り直した。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは処により、季節によっていろいろ違った呼び方をしますが、ふつうは鮠、この腹のところに赤い斑紋ができると赤腹っていうので、これは川魚なんです」「それはどうも」　万三郎は頭を掻いた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本バヤ即ち学名うぐいはあかはら又は赤魚の名で雌雄ともに腹が赤くなるが、主として天竜に居て、諏訪湖の上流の方はうぐいは稀でおいかはが主である。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            }
          ]
        }
