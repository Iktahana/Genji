    "definitions": [
      {
        "index": 1,
        "gloss": "large green soybean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから神田の宝亭で、先生の好きな青豆のスープと小鳥のロースか何か食ってそして一、二杯の酒に顔を赤くして、例の蛙の鳴声の真似をして笑っていた。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草色の羊羹が好きであり、レストーランへいっしょに行くと、青豆のスープはあるかと聞くのが常であった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の仕込みの鰈は生きが悪かったとかコック頭とコックと喧嘩して青豆を茹で過ぎたとか、とかく店の為にならない話だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人參、じやが、青豆、鳥の椀。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんのお家の石臼は青豆を挽くのが自慢でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば芋の莖の酢煮に青豆を添へたのは、いかにも夏らしい總菜で、豐田さんの家でもよく造りましたし、今では私は食物に嫌ひな物があまり有りませんから、膳に上れば食べもします。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯には、青豆などの煮たのが、丼に盛られて餉台のうえに置かれ、几帳面に掃除されたランプの灯も、不断より明るいように思われた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫蘇粥、青豆粥、海苔粥、梅干粥……この梅干のお粥のことは良人が「味覚春秋」の新年号にも書いたほどである。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大豆は私達が熊岳城の農事試験所で見聞した所では、黄豆、青豆、黒豆の三つに大別し、細別すると弐百種以上あるが、最も多いのは黄豆で、是が食用の外に油を搾つて、灯用及び広く工業原料に用ひられ、その粕は肥料や家畜の飼糧に供せられる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは緑煮といって細かく切った肉を酒と味淋と醤油でよく煮ましてそれから湯煮た青豆を入れてまた煮て溶き葛でドロドロにします。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケッパーソースはバター一杯にてメリケン粉一杯をいため牛乳一合にて弛め塩胡椒にて味を付けたる白ソースを作りその中へ瓶詰のケッパーという酸味ある青豆の如きものを二十粒ほど入れて作るなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは青豆を乾したものですがこれは自家でこしらえたものです。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、だいぶん、なれましたよ」　三郎は、缶詰の中から、青豆を箸ではさみながら、にっこり笑った。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、清羮に種とし、人参、大根、青豆などを加役とした椀が運ばれた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに清羹に種とし、人参大根青豆などを加役とした椀が運ばれた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青豆のはいったどろどろのポタアジュが、衿から胸の中へ流れ込んで、飛びあがるほど熱いのを、そっと奥歯をかんでこらえた。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂蜜、躑躅花、青豆、片栗粉などを調味したものであったが、不思議に活きた味と高い香りがあった。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしい小粒青豆がひっこんで、ふと気がついたとき皿に出ているのは、ありふれた｜さや豆だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬のことで何も御座いませんが、この青豆は家の庭で乾かしたんですから旦那様に差上げて下さい」　わたしは彼に暮向のことを訊ねると、彼は頭を揺り動かした。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロリン米をたいて青豆を入れたりして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お米にはこの次の配給のとき一キロ青豆のほしたのがついて来ます、お米の代りに。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュ・サンジェルマンと言うか、青豆のスープ。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "青豆ポタージュに、豚のグリル、コーンフリッター。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ、青豆のポタージュで、酒の気が強く、乙の味。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
