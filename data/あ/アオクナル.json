    "definitions": [
      {
        "index": 1,
        "gloss": "to become blue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "レールを七つ組み合せると円くなってそれに電柱や信号標もついてゐて信号標のあかりは汽車が通るときだけ青くなるやうになってゐたんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールを七つ組み合せると円くなってそれに電柱や信号標もついていて信号標のあかりは汽車が通るときだけ青くなるようになっていたんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールを七つ組み合わせるとまるくなってそれに電柱や信号標もついていて信号標のあかりは汽車が通るときだけ青くなるようになっていたんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールを七つ組み合せると圓くなつてそれに電柱や信號標もついてゐて、信號標のあかりは汽車が通るときだけ青くなるやうになつてゐたんだ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青くなる前に赤くなつてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいけないやうでしたから今度はだんだんおどしにかゝって青くなる人を見てやらうと思ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度｜葉裏に隠れる虫が、鳥の眼を晦ますために青くなると一般で、虫自身はたとい青くなろうとも赤くなろうとも、そんな事に頓着すべき所以がない。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば、あのみどり色したあしのようなもので、いちど刈りとられると、もう二どと青くなることがない。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも兼次は頓着なしに指の先の青くなるまで茶を摘んで居た。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "健作――そうだ、あの女は有名なモダンだから、それに大した真珠の頸飾りを新調したというから、わしにピストルを向けられたら青くなるだろう。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞くと猿共は、赤い顔が青くなる程驚いていろいろ相談をしたが、何しろ喧嘩ずくでは狼に敵わないから一層の事、狼に喰い殺されないうちにここを逃げ出して、他の所にいい住居を探そうという事に決めた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「天野屋氣取りをして、後で青くなるな。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう荒くれ男が青くなるのは、見ている者には実に愉快なものだ。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の青インクが生かわきなので、帯封をするたびに、腕から手がいれずみのように青くなる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微粒子ってのはねえ……ほら、海の水だって掬ってみると青くないけど、どっさりだと青くなるじゃないか、ねえ、お前のその鼻水もそうだよ……」　啓吉はずるりと鼻汁をすすった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物が出来ても針をすることは先ず見合せたいと云い、一寸とした怪我でも血が出ると顔色が青くなる。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の一部分である処の指が一本もし道路に落ちていたとしたら、われわれは青くなる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしが、殺されかけたあの男、あなたが、いかに油断とは言え、あんな恥辱を取ったあの男を、いつまで、あのまま放って置くのですよう、先生」　飲めば青くなる方の平馬は、お初の言葉に、目を釣るようにして、「拙者だとて、あやつを、あのままに放って置く気はない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばで、トラ十の雑言をきいている房枝の方が、腹が立って、しらずしらず顔が青くなるほどだった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮は芽を吹く、芝生はしだいに青くなる、辛夷は朽ちた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は友だちを談うて、花嫁のありかをつきとめるために、顔色も青くなるまで尋ね廻る。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ、藤沢の安否をたずねに浅草にゆき青くなるほど疲れてかえる。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は友だちを談うて、花嫁のありかをつき止める為に、顔色も青くなるまで尋ね廻る。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉を透して来た月の光は、やつぱり青くなるのかね。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、升田の方は青くなる酔顔だ。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、酔えば酔うほど青くなる。",
              "citation": {
                "source": "人生三つの愉しみ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを伝え聞いた鼓判官は、青くなると共になんとか申し開きをしようと、これも夜を日についで鎌倉へ馳せ下った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気も水と同じで、少い時は色がついてゐないけれども、五六里も厚くなると青くなる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　或る程度以上飲むと、近頃、青くなるんです。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてそれと悟り、ユリが青くなる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
