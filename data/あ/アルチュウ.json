        "examples": {
          "standard": [
            {
              "text": "私は毎日アル中について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アル中という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアル中の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアル中が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アル中を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアル中について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アル中の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアル中の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアル中が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アル中という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアル中という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアル中についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アル中を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアル中は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アル中について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアル中が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアル中は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアル中の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アル中は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアル中は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「アル中になっているかも知れないんです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パヴィナアル中毒全治。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がもし、ひょっとアル中ででも即死して、もしこの蓮の糸が無かったら、こんなにも好きな蝶ちゃんをも永遠に見失い、暗い死の闇の中で右往左往して夢中で探し廻す自分の姿が今も眼に見えるようなのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさながらにアル中、モヒ中の患者たちのように、そうした極端な刺戟をアトからアトから渇望し初めた。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とでも云はうか、それがさつぱり据らないで、写真器を構へる手の先はアル中の如くふるへるばかりなのである。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよ／＼アル中患者だ、私も俳人から癈人になりつつあるのだらう！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がアル中であることは間違はない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル中らしくペン持つ手がふるへる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（向ひの）（裏の）・飢（餓鬼）　別れた妻の動静（再会）　　　戯作一首　いくたびかやめんと誓ひ　いくたびか死なうと思ひ　アル中になる八月廿一日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々アル中の発作に襲はれる、身辺を幻影しきりに去来する。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル中の徴候があらはれてくる、それはあたりまへすぎる報だけれど、何となく心細くもある。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル中の徴候がだん／″＼現れてきよる、ああ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の人が語る『酒は肥える、焼酎は痩せる』彼も亦アル中患者だ、アルコールで自分をカモフラージしなくては生きてゆけない不幸な人間だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室に行商の支那人五人組が来たので、相客二人増しとなる、どれもこれもアル中毒者だ（私もその一人であることに間違ひない）、朝から飲んでゐる（飲むといへばこの地方では藷焼酎の外の何物でもない）、彼等は彼等にふさはしい人生観を持つてゐる、体験の宗教とでもいはうか。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬神隧道といふのを通り抜けた、そして山口中学時代、鯖山洞道を通り抜けて帰省した当時を想ひだして涙にむせんだ、もうあの頃の人々はみんな死んでしまつた、祖母も父も、叔父も伯母も、……生き残つてゐるのは、アル中の私だけだ、私はあらゆる意味に於て残骸だ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来少し身心の調子が変だ、何だかアル中らしくもある（たゞ精神的に）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲まんと舌が縺れるというアル中患者だから止むを得んだろう……取調べの一手にソンナのが在りやせんか……アッハッハッ……。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、さる精神病医の話によると、特に日本には真性アル中というものは殆どない由である。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口といふ巡査上りの別荘番は、アル中で、頭から絶え間もなく血がふきだし、それを紙で拭きとつては、コップ酒を呷つてゐる。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間、酒が切れると、すぐ手がふるえ、舌が痺れる、よるべないその頃のアル中の私、重ねて言うが、明日の知れない、人生いとも暗澹のその頃の「私」だったのだった。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川賞を欲しいと泣き、パビナアル中毒の診療入院がいやだと泣いてゐた。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル中の一と桁上のやつだ。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうだかな――むしろ益々救いがたいんじゃないか」「そいじゃ、彼はただのアル中にすぎないじゃないか」「僕がいつも云っているとおりさ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木医師の話では、自分は専門医じゃないし、正式に診察したわけでないからよく判らないけれど、アル中の気もあるようだし、鬱状態が歴然とあらわれているようだとのことでした。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の人は本書を読んでジャックはアル中患者だなと考えたが、中には、殊に牧師たちは、これは飲酒の害悪を教える道徳的教訓と解する者もあり、禁酒聯盟、酒場撲滅聯盟などではこれを宣伝材料として利用した。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもどんな最強頭脳だろうが、一八七四年産に勝るシャンパンをアル中に飲ませれば立ち上がれない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかったか、アル中こじきめ！",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあアル中の人外だからね。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはもともとのんべえだったが、アル中こじきにおちぶれたのは、いくさに負けたからだ。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと陸軍大尉のアル中ぼろ男大曾根は、さち子の幸運を聞いて涙を流した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
