          ],
          "literary": [
            {
              "text": "ここから土地の案内に精しい輿水象次氏が一行に加わって、泥道を歩き始める。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとぼとぼと歩き始めると、船にいたよりも私は身体のふらつくのを感じた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、傍の時計屋の入口で手を腰に当てて厳しい顔で此方を見張っている彼女が母親だと判ると、俄にわざとらしく空咳をしたり髭をしごいたりして、歩き始める。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度の溜息が口に上つた時少年は立ちあがつて歩き始める。",
              "citation": {
                "source": "童貞記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はノーエ節を歌いながら、円卓のまわりを踊るように歩き始める。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからマストを持ち上げ、肩に乗せて、道を歩き始める。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上に渦巻く黒髪、苦し相に歪んだ笑い顔、浮上った乳房、身体一面に輝く水泡、その姿で、彼女は内側の二人と並んで、ガラス壁に手をささえながら、そろそろと歩き始めるのでした。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
