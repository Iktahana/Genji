        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒治療について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒治療という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒治療の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒治療が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒治療を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒治療について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒治療の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒治療の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒治療が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒治療という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒治療という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒治療についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒治療を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒治療は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒治療について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒治療が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒治療は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒治療の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒治療は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒治療は興味深い例である。",
              "source": "幻辞"
            }
          ],
