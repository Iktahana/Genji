        "examples": {
          "standard": [
            {
              "text": "毎日、相容れるは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相容れるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相容れるに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相容れるが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相容れるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相容れるについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相容れるについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相容れるが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相容れるが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相容れるは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相容れるは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相容れるを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相容れるをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相容れるが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相容れるの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相容れるを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相容れるに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相容れるについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相容れるは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相容れるを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "つまり二つの種類のちがったイーゴイストはこの点で到底｜相容れる事ができなかったのであろう。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も性格的に見ても、此の赤入道は、伝統の家に育って挙措慎重なる勝元と相容れるわけがない。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が軍人志願の漢学仕込で、岳武穆や陸宣公に鍛えられていた上に、ヘルチェンやビェリンスキーの自由思想に傾倒して意気｜欝勃としていたから、一から十までが干渉好きの親分肌の矢野次郎の実業｜一天張の方針と相容れるはずはなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし諸君が、互いに個人としての交際において、まったく相容れることのできない人々であるならば、その間に僕があるからといって、何でも強いて友人づきあいをするにも及ばない。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩者は果して相容れるであらうか。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "相容れるとすれば兩者の關係は何に存するであらうか。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、かような生活は、博いまともな道を歩きたいという私の本来の願いと相容れるものではなかった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方乱を好み戦ひを事とする蛮勇もまた、決してわが日本の国ぶりと相容れるものではございません。",
              "citation": {
                "source": "戦時下の文化運動",
                "author": "――九州地方講演筆記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人がよき日本人であり、支那人がよき支那人であるといふことは、最も多くの相通ずる美徳、相容れる性格をもつことだといふ真理を認め合ふことが第一の問題である。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも「家」の観念は、日本の「国家」観念と同様、その最も健全な本源に遡つても、それは、決して、今日の合理的立場なるものと相容れる筈はなく、そこには「宿命」があり、「信仰」があり、「血液」の神秘があるのであります。",
              "citation": {
                "source": "日本文化の特質",
                "author": "――力としての文化　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちそれは、すべての交換者が共通で同一の比例で自由に二商品を互に与えまたは受ける条件と相容れる所の最大ではないことはいうまでもない。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "加害者と被害者とは、どうしても相容れることのできない存在だからである。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
