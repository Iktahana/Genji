        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日哀れっぽいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は哀れっぽいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には哀れっぽいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは哀れっぽいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は哀れっぽいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では哀れっぽいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に哀れっぽいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では哀れっぽいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると哀れっぽいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では哀れっぽいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀れっぽいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により哀れっぽいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "哀れっぽいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に哀れっぽいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "乞食の眼や声はかなり哀れっぽいものであったが、ただそれだけでこのような不思議な印象を与えたのだろうか。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全くあの男ほど気の毒な人はないよ」と老人は例の哀れっぽい声。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうしたら、売れで売れで、凍り豆腐は、あの爺様のでねえげ駄目だぢ評判で、随分儲げだのだげっとも……長患いして、残した銭も、しっかり使ってしまって、またこうしてこれ……」　弥平爺は、声を低くして哀れっぽい調子に語尾を引いた。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独の淋しさを悩む無口な少女のように哀れっぽい花です。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして歩きながら、彼は低声に、哀れっぽい調子をつけて歌ったのであった。",
              "citation": {
                "source": "郷愁",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云う心理状態にある娘はきっと哀れっぽい涙ばっかり流さなければならない様な物語りばっかりすいて読むんです。",
              "citation": {
                "source": "現今の少女小説について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう思って見るせいか、この子は何だか哀れっぽい子ですね。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "変に哀れっぽい乾からびたパンを見てから、私の裡に在る真実が自分でも判らない一杯さで心に溢れて来た。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやっている自分に何ともいえず哀れっぽいものが感じられる。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、毛虫は哀れっぽい声で叫びました、「私がこうして葉っぱをいただくのは、未来の生活のためなんですもの。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食の子供達はこの時とばかりもう一度彼の傍へまつわりついて来て手を出しながら、「旦那、恵んで頂戴」「恵んで頂戴」　と哀れっぽい声を絞った。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲乞食は人の立ちどまった気配がすると、哀れっぽい声を振りしぼって、「お助けなされて下さりませ、旦那さま……哀れな盲でござります……」　前の乞食は身じろきもしずに、そこに突立っていた。",
              "citation": {
                "source": "幻想",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔犬はひどく哀れっぽい鳴き声をたてた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ優美第一の、哀れっぽいものでございましょう。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐにその晩ホテルへ泊って、夜中の二時頃コッソリと屋上庭園へ来てみると世にも哀れっぽい微かな微かなあっしの声で、「じゃぱアーん。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の支倉も云う事がどこともなく哀れっぽい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「哀れっぽい声を出したって駄目だよ。",
              "citation": {
                "source": "海のほとり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従者　（なつかしげに）奥様は花園を見下ろす窓に倚って、いつもいつも哀れっぽい歌をお弾きなされました。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主　彼女が歌った歌は、みんな哀れっぽいものばかりだったが、その中でも、「死に行く人魚」の歌が一番悲しい節の歌だった。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、彼んでも、灰色に見える様に陰気な、哀れっぽい部屋の中にお君は、たった独りぽっちで寝て居る。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の欠けたのや、目のクシャクシャや、跛足や、膝行や、膏薬貼が、おのおの盛装を凝らして持つべきものを持ち、哀れっぽい声を振絞って、江戸へ向って繰込むことの体が世の常ではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れながんりきに、水を一杯恵んでやっておくんなさいまし」　イヤに哀れっぽい声を出して、がんりきの百蔵が所望する水一杯を、誰も相手になって、恵んでやろうとするものは無いらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お母さんは哀れっぽい声でいわれました。",
              "citation": {
                "source": "遠くで鳴る雷",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、地虫は、さながら、春の夜を思わせるように哀れっぽい調子で、唄をうたっていました。",
              "citation": {
                "source": "冬のちょう",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたゞ、天を仰ぎ両手を合せながら、お願いするように、哀れっぽい調子で、何かと言ってみました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺は、一｜日じゅう人の顔さえ見れば、哀れっぽい声を出せるだけ絞り出して、頭を下げられるだけ低く下げて頼んでみたが、これんばかりしかもらわなかった。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れっぽい顔をした年輩の男が、涙を流し鼻に皺を寄せ、「悲しや悲しや我らのご主人様の、多門兵衛正成公は、戦い利あらずと観念あそばされ、昨日深夜にお腹を召され、この世を去りましてござります。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ歌の調子が、いかにも哀れっぽい、怨めしい、陰気な、形容が出来ないが、調子は忘れ難い印象をとどめている。",
              "citation": {
                "source": "僧",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、あわれっぽい節を付けて、売りに来る声を聞くでしょう。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いうあわれっぽい女の納豆売の声を、よく聞きます。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
