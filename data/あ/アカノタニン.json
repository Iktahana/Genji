        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしＡ、Ｂ、Ｃ相互になんらの交渉もない赤の他人である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片親の父に相談してみても物堅い老舗の老主人は、そんな赤の他人の白痴などに関まっても仕方がないと言って諦めさせられるだけだった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "契約期限切れは赤の他人だわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七年から八年の中ごろまでは、通りがかりの赤の他人にさえ言葉をかけてみたいようであったのが、今ではまたもとの赤の他人どうしの往来になってしまった。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れてかなうまじき人といわなければならない、そこでここに恩愛の契りもなければ義理もない、ほんの赤の他人であって、本来をいうと忘れてしまったところで人情をも義理をも欠かないで、しかもついに忘れてしまうことのできない人がある。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗難や詐欺にかかった被害者の女師匠などが、加害者でもなんでもない赤の他人の立派なお役人を、どうでもそうだと言い張る場合などがそれである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがたとえ事実とどれほど離反していても、そんなことは元来加害者にも被害者にも縁故のない赤の他人の一般読者にはどうでもよいのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、拝啓、と書いて、それから、何と書いていいのやら、別段用事は無いのだし、それに私はあなたにとってはまるで赤の他人なのだし、ペンを持ったままひとりで当惑するばかりなのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしくその人と思うのが、近々と顔を会わせながら、すっと外らして窓から雨の空を視た、取っても附けない、赤の他人らしい処置｜振に、一驚を吃したのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間前までは、信吉と伊都子は赤の他人であった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも区長と犯人との間柄は、赤の他人以上に無関係です」「しかし君は、そうした犯人に関する意見を、何故に司法主任の馬酔君に話さなかったのですか。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、まだ籍も何も入れてない赤の他人で、一生懸命に働いて行くうちに、私達が死ねば、お礼にお前と、この家の財産を遣る口約束がしてあるだけの人間だよ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうよりのちは赤の他人と思っていただきたい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人の二人に手をつなぎ出さしたのは、始め誰かゞふと思い付きの悪戯だったそうですけれども、二人は手をつないで物乞いしてみると、人は愛嬌にして物も容易く呉れ、夫婦乞食と呼ばれて世間からやゝ暖くも待遇されるので二人の手は離し難くなったのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の旦那を赤の他人の女に添わせるよりはと。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子はきびしく叱りつけ、銀造を見る眼は赤の他人以上に冷たく白かった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子がなぜ自分をたずねて来たのか、まるで判らなかったが、カメラのレンズだけで覗いていた陽子が、今こうして一個の肉体となって現実に自分の前に現れて来た以上、もはや陽子は赤の他人ではなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは乱歩氏の作品に限らず、ほかの小説でも同様で、調べること嫌いの私は「猟奇」とか「探偵」とかいう名目すらも、ツイこの五六年前までは、赤の他人の名前と同様に、通りすがりに記憶しているくらいの事でした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が儲けて貴様が遊ぶ事じゃケニ文句は云わんが、赤の他人でも親類になる……見ず知らずの他人の娘でも蹴倒おす金の威光だけは見覚えておけよ』　というのが死んだ親父の口癖で御座いましたが、全くその通りの懸価なしで、五十｜幾歳のこの年になって、ようようの事、世間が見えて来ましたがチット遅う御座いましたナア。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は故翁から習ったに過ぎない一教授佐藤文次郎氏の謝恩の一念から起り、全くの赤の他人である彫塑家津上昌平氏の感激から来た犠牲的熱意によって完成された事業である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人にでも奉仕する。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私たちは全く赤の他人になってしまいました。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、私には全然赤の他人の、ブレシントンと云う名の紳士に訪問されたことでした。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人であって親の様に思われ子の様に愛するということは、無情な人の夢にも知ったことではない、先生と長塚との間柄は親子としてはあまりに理想的で、師弟としてはあまりに情的である、ゆえに予はこれを理想的愛子と名附けた。",
              "citation": {
                "source": "正岡子規君",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭といっても赤の他人ではなく、幸八はお才の遠縁にあたる者で、丸多の夫婦には実子が無いために、行く行くは彼を養子にすることに内定していたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人に成つて其後はふつゝり消息もない。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもここでお里に因果をふくめて赤の他人になるよりほかはない。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子といえども互いの本質にくると赤の他人にすぎないのだなという淋しさも襲ってきた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
