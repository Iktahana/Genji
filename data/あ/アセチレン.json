          ],
          "literary": [
            {
              "text": "魚〔を〕とるときのアセチレンランプがたくさんせはしく行ったり来たりして黒い川の水はちらちら小さな波をたてゝ流れてゐるのが見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚をとるときのアセチレンランプがたくさんせわしく行ったり来たりして黒い川の水はちらちら小さな波をたてて流れているのが見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚をとるときのアセチレンランプがたくさんせわしく行ったり来たりして、黒い川の水はちらちら小さな波をたてて流れているのが見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、私たちは、アセチレンを十ばかりつけて出かけました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアセチレンの青の光の中をみんなの見てゐる前でまだ石がコロコロ崩れてころがって行くんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアセチレンの仕度はいゝか。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその子供の助手が、アセチレン燈を四つ運び出して、鏡の前にならべ、水を入れて火をつけました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈しく鳴って、アセチレンは燃えはじめたのです。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈のかはりのアセチレンで、あたりがすっかり青く変りました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの床屋のアセチレンも消されるぞ。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚をとるときのアセチレンランプがたくさんせはしく行つたり來たりして、黒い川の水はちらちら小さな波をたてて流れてゐるのが見えるのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法界節の文句通りに仕方がないからネエエ――てんで、月琴を担いで上海にでも渡って一旗上げようかテナ事で、御存じの美土代町の銀行の石段にアセチレンを付けて、道楽半分に買集めていた探偵小説の本だの教科書の貰い集めだのを並べたのが病み付きで、とうとう古本屋になっちまいましてね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアセチレンの仕度はいいか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈のかわりのアセチレンで、あたりがすっかり青く変りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近づいて行くと、その葉が風にもまれて次から次と湧いているよう、枝と枝とがぶっつかり合って、じぶんから青白い光を出しているようなのもわかるようになり、またその下に五人ばかりの黒い影が魚をとったりするときつかう、アセチレン燈をもって立っているのも見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはアセチレン燈をもって工場の外の芝生に出ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしどもの影はアセチレンの灯に黒く長くみだれる草の波のなかに落ちて、まるでわたくしどもは一人ずつ巨きな川を行く汽船のような気がしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたくしもあるき、みんなも向うへ行って、その青い、風のなかのアセチレンの灯と黒い影がだんだん小さくなったのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺一ぱいにならんだ屋台の青い苹果や葡萄が、アセチレンのあかりできらきら光っていました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亮二は、アセチレンの火は青くてきれいだけれどもどうも大蛇のような悪い臭がある、などと思いながら、そこを通り抜けました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅の棚のとこにアセチレン燈が一つあった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署長はちょっと鹿踊りのやうな足つきをしたがとっさにふっとアセチレンの火を消した。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたん、アセチレンの火が向ふでとまった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アセチレンの火はすぐ横から足もとへやって来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アセチレン燈もまだ持ってゐる。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はアセチレンをそこへ置いてまるで風のやうにうごいて綱を持って来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ少しあかるいのに、青いアセチレンや、油煙を長く引くカンテラがたくさんともって、その二階には奇麗な絵看板がたくさんかけてあったのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋にアセチレンの照明器を灯し、またその近くに僅かばかりの炭火を貸船用の莨の火鉢に熾して、お秀は文吉の着物の裾を着たまゝで乾してやっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
