        "examples": {
          "standard": [
            {
              "text": "毎日、アイシャドウは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイシャドウが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイシャドウに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイシャドウが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイシャドウについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイシャドウについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイシャドウについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイシャドウが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイシャドウが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイシャドウは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイシャドウは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイシャドウを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイシャドウをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイシャドウが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイシャドウの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイシャドウを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイシャドウに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイシャドウについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイシャドウは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイシャドウを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "銀座式のハイカラさが大阪では受けるのだと思ったのは、まだいい方で、たいていは外国映画のメーキャップを模倣し、エキゾチシズムとはアイシャドウを濃くして、つけ睫毛を太くすることだと考えたので、グロテスクな効果だけ残って、失敗した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の形、頬紅やアイシャドウの使ひ方なども教はつて、何うにか女給タイプにはなつて来たのだつたが、どこか此処の雰囲気に折り合ひかねるところもあつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い化粧部屋で、ドオランを塗ったりアイシャドウをつけたりしているマネキン達の後から、宿屋の女中達が珍しそうに覗きに来た。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ッ昼間だというのに、黄色のドーラン化粧に、青のアイシャドウ、おまけに垂れ滴るような原色の脣をもった、まるでペンキを塗った腸詰のようなその黴毒女を、春日が、例え噂にもしろ「ネネ」と呼んだ、ということについては、激しい不満を感ぜずにはいられなかった。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の娘という娘がみんなパーマネントをかけて頬紅口紅、アイシャドウ、毒々しいまでにメイキアップをして、中には着物を洋装に着代え靴まではきかえて出てくるのがある。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
