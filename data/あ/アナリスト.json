        "examples": {
          "standard": [
            {
              "text": "私は毎日アナリストについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナリストという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナリストの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナリストが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナリストを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナリストについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナリストの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナリストの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナリストが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナリストという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナリストという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナリストについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナリストを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナリストは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナリストについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナリストが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナリストは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナリストの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナリストは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナリストは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "プウシュキンもとより論を待たず、芭蕉、トルストイ、ジッド、みんなすぐれたジャアナリスト、釣舟の中に在っては、われのみ簑を着して船頭ならびに爾余の者とは自らかたち分明の心得わすれぬ八十歳ちかき青年、××翁の救われぬ臭癖見たか、けれども、あれでよいのだ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ジャアナリストのあいだの黙契にて、いたしかたございませぬ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の青年も母親に似て、ジャアナリスト的な才能を多く有っているようである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩庸三は、小夜子の家で遅くまで花を遊んだが、遊びに来ていたジャアナリストや漫画家も一緒だった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそこで落ち会ったジャアナリストの一人と、川風に吹かれながらバルコニイへ出て、両国から清洲橋あたりの夜景を眺めていたが、にわかに廊下へ呼びこまれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の気持はよく解るけれど、ジャアナリストの手に乗るということがありますかよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先きの目当てのつかない彼女の下宿生活が、彼からの少しばかりの補助でいつまで持ちつづけられるはずのものでもなかったし、ジャアナリストに見放された葉子の立場を持ち直すこれという方法もなかったので、打開の道を講ずるために、何らか行動を執っているであろうことも考えられないことではなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのころ、庸三に接近しているある大新聞の学芸欄記者に拾われて、その下に働いたことがあり、ほんの二三カ月だったが、とにかくジャアナリストとしての一役を当てがわれて、すっかり朗らかになっていたこともあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "名士の死者は、本篇の冒頭に挙げた富豪連の他に、有名な作家でジャアナリストの Mr. W. T. Stead 大幹鉄道社長ヘイズ氏―― Mr. C. M. Hays, the President of the Grand Trunk Railways ――其の他。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした同胞のムチモウマイに乗じ更にそれを煽りたて、同胞をある一国の奴隷に売ろうとしている売弁政治家たちにジャアナリスト。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時にブリックリンは、こうした計算の道具を提供すれば、企業の経理担当者や管理職、財務アナリストなどに需要が見込めるのではないかと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今になつて考へて見ると、最も内心に愛してゐたのは詩人兼ジヤアナリストの猶太人――わがハインリツヒ・ハイネだつた。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、本質的にはどこまで行つても、畢竟ジヤアナリスト兼詩人である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は実にかう云ふ点ではジヤアナリストであると思つてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて職業的ジヤアナリストを兄弟であると思つてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ人々の作品も（僕はその作家の名前を知らなかつたにしろ）僕に詩的感激を与へた限り、やはりジヤアナリスト兼詩人たる今日の僕には恩人である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕を作家にした偶然はやはり彼等をジヤアナリストにした。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも僕はジヤアナリストだつた。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日もなほジヤアナリストである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来も勿論ジヤアナリストであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし諸大家たちは暫く問はず、僕はこのジヤアナリストたる天職にも時々うんざりすることは事実である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は詩人兼ジヤアナリストを完成する為に作つてゐるのである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクリストは洗礼を受けると、四十日の断食の後、忽ち古代のジヤアナリストになつた。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨブ記」を書いたジヤアナリストは或は彼よりも雄大だつたかも知れない。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はジヤアナリストであると共にジヤアナリズムの中の人物――或は「譬喩」と呼ばれてゐる短篇小説の作者だつたと共に、「新約全書」と呼ばれてゐる小説的伝記の主人公だつたのである。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジヤアナリストとなつた後、彼の孤身を愛したのは疑ひのない事実である。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストは名高いジヤアナリストになつた。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はロオマの詩人たちにも遜らない第一流のジヤアナリストだつた。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
