        "examples": {
          "standard": [
            {
              "text": "毎日、当たり前について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の当たり前戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "当たり前の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "当たり前という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは当たり前について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "当たり前の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "当たり前に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは当たり前を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での当たり前は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、当たり前は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "当たり前は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な当たり前を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「当たり前」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "』『当たり前じゃないの。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみれば実に当たり前のそうした事情を、あらためて強く意識するようになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターでも、通信は当たり前になった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当たり前になってきたＣＤ―ＲＯＭ　当初エキスパンドブックとして出し直そうと考えてから、一年あまりをかけて原稿を準備する過程で、電子出版物をめぐる状況はかなり大きく変わってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々が考えながら文章を書く場合、せいぜい十分百文字程度であることを考えれば、手書きのニーズは間違いなくある」　こう主張するＤ博士にインタビューしたオレは、車の運転が常識とされるように、キーボード操作は今後、誰にとっても当たり前の技術になるのじゃないかと異論をはさみ続けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後発から追いかけたソニーのパーソナルコンピューターは憤死し、世界市場に向けた欧文ワードプロセッサーはいったんはかなり伸びたものの、その後ＰＣでワープロ・ソフトを使う流儀が当たり前となって、市場その物が消滅した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダンナ、そんなことは当たり前でしょう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻水にまみれたそのころのオレは、父と母の双方から庇護の翼が差し伸べられることを、当たり前の慰謝と信じて疑わなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当たり前と思っていたことが当たり前でないと突き付けられたとき、心の底には穴があく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは当たり前以前で、前提の前提。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間命の惜しいのは当たり前だ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたのようなしょうばいをしておれば、しょっちゅうお客のあるのは当たり前なんだから」　私は何でもなしに言ったのだけれど、みさをは、私の言葉が癪にさわったのか、執拗にだまりこくって莨ばかりふかしていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまいなア、先生は」「それは当たり前よ、先生じゃねえか」「あああれがあの雲だ」「その下のがあの家だ」　黙って筆を運ばせていると、勝手なことを言ってしゃべっている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはきわめて平凡な、当たり前のことでしたが、わたしのいやが上にも昂奮せしめられた心は、彼女の焼ける姿に恐ろしい妄覚を起こしたのです。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから叔父さんが犯人かとも思ったんですけれど、叔父さんの紙を誰かが盗んで使ったのかもしれず、金庫の上に叔父さんの指紋のあるのは、当たり前であるし、それにあの暗号が気になったものですから、叔父さんを犯人と断定するのはまだ早いと思いました。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肉がくさり落ちて骨ばかりになれば、帽子がすこすこになるのが当たり前です。",
              "citation": {
                "source": "頭蓋骨の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺された人間がありゃ、殺した人間のあることは当たり前じゃないか」「そりゃ君、無理だよ。",
              "citation": {
                "source": "現場の写真",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "算盤尽くの市場の理屈や、お札に書き込まれた仕様書だけでなく、美しいものへのあこがれや不思議に震えるやわらかな心の渇きもまた、人をプログラミングに誘うのだという当たり前の事実を、祝田さんの仕事は思い起こさせる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターを理解しようとするプロのいる会社なら、テレタイプの一台や二台あって当たり前という発想だったのだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "できたばかりの半導体事業部に所属し、以来半導体作り一筋に打ち込んできた後藤が、超小型とはいえコンピューターのシステムに興味を持ってこの時期いじり回していることは、けっして当たり前のことではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからのキミたちはマイコンぐらい知っているのが当たり前で、知らないと恥ずかしいぐらいになるかも知れない」（『マイコン入門』廣済堂、一九七七年）　勢い込んだ渡辺たちはさらに、ＴＫ―80の延長線上につぎつぎと新しい製品を企画してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋に数学的な角度から計算機がどう論理を処理していくかを解説したこの本で、松本はこれまではまったくわけの分からない存在だったコンピューターが、当たり前の理屈に支えられていることを初めて実感できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディスクベーシックの貧弱なファイル管理機能では、今後フロッピーディスクが当たり前になり、さらにハードディスクに大量の情報を蓄積して使うようになった段階ではまったく対応しきれなくなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも国の名みたいなものだ、フランス――でもなし」「じゃ、イギリスだろう」「それだそれだ」「困ったやつだな、あれはイギリススパナーというので、やっぱりスパナーのうちなんだよ」「よく知ってるね」「当たり前さ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "トックの信ずるところによれば、当たり前の河童の生活ぐらい、莫迦げているものはありません。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きているときはさんざん人に骨を折らしたんですから、汽車に轢かれて自分の骨をおっぺしょるのは当たり前ですよ」　お玉は泣いたような、笑ったような声で言った。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうあたりまえのことにひょいと気がつくと何とも知れない涙が眼の奥から浸潤み出るのだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　既に同一感情と生活意識の上に立って生きて居るとしますれば一つのものを喰べ、同じ所を視、なるべく同じ所に居たいのはあたりまえです。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こうほめられてもあたりまえのような気がします。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでものぼりたいのはあたりまえだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
