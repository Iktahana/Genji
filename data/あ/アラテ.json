[
  {
    "uuid": "cda42494-7471-5c83-95b4-10adb4961db9",
    "entry": "新手",
    "reading": {
      "primary": "あらて",
      "alternatives": [
        "しんて"
      ],
      "is_heteronym": false
    },
    "grammar": {
