    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fresh troops",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日新手について考えている。",
              "source": "幻辞"
            },
            {
              "text": "新手という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は新手の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には新手が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "新手を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは新手について学習した。",
              "source": "幻辞"
            },
            {
              "text": "新手の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は新手の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では新手が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "新手という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に新手という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では新手についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "新手を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると新手は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "新手について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では新手が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に新手は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により新手の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "新手は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に新手は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "吾輩は元来ここまで一行を見送り、明日は失敬して帰京する予定なので、旅装も何もして来なかったが、新手の武者さえ馳せ加わっては、見苦しく尻に帆掛けて逃出す訳にも行かない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」詩人は、美濃の此のような多少の文才も愛しているし、また、こんな物語を独りでこっそり書いている美濃の身の上を、不憫にも思うのだが、けれども、美濃のこんどの無法な新手の恋愛には、わざと気づかぬ振りをしていようと思った。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この河童の尻が、数え年二百歳か三百歳という未だうら若い青さに痩せていた頃、嘘八百と出鱈目仙（千）人で狐狸かためた新手村では、信州にかくれもなき怪しげな年中行事が行われ、毎年大晦日の夜、氏神詣りの村人同志が境内の暗闇にまぎれて、互いに悪口を言い争ったという。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に罵られても、この夜ばかりは恨みにきかず、立ちどころに言い返して勝てば、一年中の福があるのだとばかり、智慧を絞り、泡を飛ばし、声を涸らし合うこの怪しげな行事は、名づけて新手村の悪口祭りといい、宵の頃よりはじめて、除夜の鐘の鳴りそめる時まで、奇声悪声の絶え間がない。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるに些か思う所存あって、今宵｜新手村の上空を飛行せしに、たまたまこの山中に汝の姿を見受けし故、忍術の極意を以って木遁を行いしが、最前よりの汝の働き近頃屈強なり。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新手村の大晦日の夜と、それから城中での歌合せの夜の二度まで、自分を振り切るように逐電してしまった佐助が一途に恋しくて、思い余ったその挙句に、佐助たずねてのあてなき旅の明け暮れにも、はしたなく佐助ばりの口調が出るとは、思えば佐助も幸福な男である。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生一代の対局に二度も続けてこのような手を以て戦った坂田の自信のほどには呆れざるを得ないが、しかし、六十八歳の坂田が一生一代の対局にこの端の歩突きという棋界｜未曾有の新手を試してみたという青春には、一層驚かされるではないか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "相懸り法は当時東京方棋師が実戦的にも理論的にも一応の完成を示した平手将棋の定跡として、最高権威のものであったが、現在はもはやこの相懸り定跡は流行せず、若手棋師は相懸り以外の戦法の発見に、絶えず努力して、対局のたびに新手を応用している。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし玄人でも、こうして生まれた能のヨサ、有り難さが解かっていながらに、一と通り芸が出来るようになると、自分独りで豪くなったように思って、恣に羽根を伸したり、新手を編み出したりする者があれば、それは能楽界の外道である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿崎隊は新手を入れかえ入れかえ無二無三につき進み切り立てたため、さしもの典厩隊も苦戦となり隊伍次第に乱れるにいたった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新手に敵し難く新発田隊は退却をはじめ、狗ヶ瀬を渡った甲軍も、謙信の旗本の背後にむかって猛進した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この犀川をわたるに当って甲軍の新手の追撃をうけて或は討死し或は溺れる者が続出した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、官軍の援兵大いに来って、歩兵は三十二個中隊に及んだので、新手をもって次ぎ次ぎ攻めたてた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新手を丸山の前に備えた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬兵衛の兵も、盛政の新手の勢の為に残り少なくなって居る処に、退き口である麓の小屋小屋に火の手が挙った。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から隆景の先手の兵が来たので宗茂は、一先ず部隊を引まとめて小丸山に息をつぎ、隆景旗下粟屋四郎兵衛｜景雄、井上五郎兵衛景貞の六千の新手に正面の明軍を譲った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "追撃して高陽附近に至る頃明将楊元新手を率いて来り援った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月初旬には、九州の諸大名も新手をもって来り会したから、信綱は令して諸軍の陣所を定めた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり思わぬ新手の出現で、楠軍の突進隊は後方から切断された訳だ。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがオイルショックで社会が縮こまった中、新手の電子部品にはさっぱり販路が開けなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは新手の情報機器、しこうしてその実体はＰＣといったブックマン流のアプローチは、ここで触れている電話絡みのマシンでも今後しばしば採用されるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに新手の情報家電をＰＣの資産を活かして作り、Ｗｉｎｄｏｗｓで仕上げの化粧を施そうというわけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幽霊の観世物を利用して人殺しを思いつくなぞは、江戸時代ではまあ新手の方でしょうね」「信次郎は死にましたか」「あくる日の夕方に死にました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、今度のは今までと違って、すこし新手だな」と、半七は笑いながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ではまだこの新手を知るまいと思ったので、かれらはその首をかかえ出して神田や深川で例の軍用金を徴収した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし頭をあげなば獅子の如くに汝われを追打ち……汝はしばしば証する者を入れかえて我を攻め、我に向いて汝の怒を増し新手に新手を加えて我を攻め給う」とヨブは神の迫撃盛なるを怨じ、そして十八節以下においてまた死を慕う心を哀々たる文字を以て発表するのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い階段の中程に一人の裸婦が、凝ツと正面を向いてたゝずむでゐる一見平凡な構図であるが、陰影を持たぬ久保の新手法が機械的構成美の上で目醒しい進境を示したものとして評判が高かつた。",
              "citation": {
                "source": "階段",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見て残った四十がらみが、うで蛸のごとく真赤になった時、どかどかと人込みを押し割って、門弟らしい者を六七人随えた、一見剣客と思われる逞しい五分月代が、突如そこに姿を見せると、明らかに新手の助勢であることを示しながら、叱咤するように叫びました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見て残った四十がらみが、うで蛸のごとく真赤になった時、どかどかと人込みを押し割って、門弟らしい者を六七人随えた、一見剣客と思われる逞しい五分月代が、突如そこに姿を見せると、明らかに新手の助勢であることを示しながら、叱※するように叫びました。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第一話　旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく並木道にあらての自転車の灯がみえ、悲劇の現場にとまると、小柄の年ぱいの紳士がおりて、自転車を女中パートン夫人に持たせて、死体のそばにしゃがんだ。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
