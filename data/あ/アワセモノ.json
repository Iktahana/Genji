        "examples": {
          "standard": [
            {
              "text": "私は毎日合わせものについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "合わせものという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は合わせものの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には合わせものが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "合わせものを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは合わせものについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "合わせものの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は合わせものの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では合わせものが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせものという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に合わせものという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では合わせものについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "合わせものを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると合わせものは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせものについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では合わせものが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合わせものは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により合わせものの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "合わせものは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に合わせものは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それに比べて見ると、そこらに立っている婦人の衣服の人工的色彩は、なんとなくこせこせした不調和な継ぎ合わせもののように見えた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのものがただ外見だけの間に合わせもので、ほんとうに根本の研究を経て来たものでないとすると、実際われわれは心細くなる。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻筋のすっと通ったを、横に掠めて後毛をさらりと掛けつつ、ものうげに払いもせず……切の長い、睫の濃いのを伏目になって、上気して乾くらしい唇に、吹矢の筒を、ちょいと含んで、片手で持添えた雪のような肱を搦む、唐縮緬の筒袖のへりを取った、継合わせもののその、緋鹿子の媚かしさ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日のお客さんは無理なご馳走を嫌いなかたであるから当節むきに、台所にある有り合わせもので間に合わせばよい。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八〇四年以前に他界した英雄どもはまことに仕合わせものだ！",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっこちなんていうもなア、いわば合わせものに離れもの、好きな間だけ一緒にいてよ、厭になったらオサラバさ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな薄赤いその汗もは、仕合わせものたちで、パフに白い粉をつけたのを、不器用らしい器用さで、パタパタとつけられました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二人で、一度あわせものをしましょうね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはいるひと、たれがいちばんしあわせものか。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんしあわせもの。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時はツァウォツキイも「ああ、おれはなんと云う不しあわせものだろう」とこぼしている。",
              "citation": {
                "source": "破落戸の昇天",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔蔽いせる者　人はその日の午後に来た道楽者の煙突｜掃除人をしあわせものだと言っていた。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらかた（古形）からきたと思われる「かたのよきもの」すなわち仕あわせものを意味するのは特殊の変形的使用法である。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんは、なんてしあわせものなんだろう。",
              "citation": {
                "source": "うまい商売",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、しあわせものだ。",
              "citation": {
                "source": "温泉へ出かけたすずめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたちは、しあわせものですよ……。",
              "citation": {
                "source": "美しく生まれたばかりに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみれさん、あなたは、しあわせものですね。",
              "citation": {
                "source": "すみれとうぐいすの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "造麻呂　なよたけはしあわせものでございます。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、だいたい、わたしたちの組はふしあわせものが多いですね、先生。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
