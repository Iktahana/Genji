[
  {
    "uuid": "bafaefc2-25ac-5b89-95a2-6f1e343d9fd6",
    "entry": "穴ぼこ",
    "reading": {
      "primary": "あなぼこ",
      "alternatives": [
        "アナボコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴ぼこについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴ぼこの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴ぼこが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴ぼこについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴ぼこの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴ぼこが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴ぼこという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴ぼこについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴ぼこは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴ぼこが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴ぼこは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴ぼこの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴ぼこは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴ぼこは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそれから数時間の後に行って見ると、だれかが押し入れの中にオルガンの腰掛けを横にして作ってやった穴ぼこの中に三毛が横に長くねそべって、その乳房にこの子猫が食いついていた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに美しい空の色をうつしている場所があると思えば、その浅い水の下には命とりの穴ぼこがある。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯は寝てる飯より、立ってる飯、つやのある飯、穴ぼこのある飯はきらい。",
              "citation": {
                "source": "朝御飯",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦やコンクリートの破片に躓くし、穴ぼこに落ちこむし、茨に引っ掻かれるし、何度ぶっ倒れたか知れない。",
              "citation": {
                "source": "狸石",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼みに思う箱自動車が穴ぼこの中に落ちてしまったのでは、これからてくてく歩くしかないのだ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "車がいくら大丈夫でも、穴ぼこの中にえんこしていたんじゃ仕様がないじゃないか。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "車をこの穴ぼこから上へひっぱりあげればいいんだよ」「なんだって。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴ぼこから、車をひっぱりあげるって。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、チャンポン屋で渋い酒をのみながら、金鍔次兵衛ともあらう豪の者が、原城へ入城もしないで、あんな穴ぼこの中でつかまるとは、返す／″＼も残念至極だと、酩酊に及んでしまつたのである。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "沃度丁幾をつけてあるが、おできのあとともすこしちがうような気がするんだが、大学の鑑定事項の中へ、穴ぼこが意味する病名を指摘するように書き加えて置いて呉れ給え」「不思議ですな、前の春江の場合にも、やっぱり首のところに万創膏が小さく貼ってあったじゃありませんか？",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ウーンすると、ことによると犯行に関係ある穴ぼこかも知れない。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻ヶ谷君はその鉄ぶたの穴へ指を入れ、上へ引っぱるとふたがとれ、その下は穴ぼこになっていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴ぼこの中からがちゃがちゃという音がきこえたと思ったら、彼の手は鉄の鎖を握って引っぱりだした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、村そのものが一つの動揺となつて、居たり立つたり空間の一ヶ所を穴ぼこのやうに視凝めたり、埋葬のやうにゆるぎだしたり、ぢりぢりと苛立ちはじめたりした。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけなく穴ぼこに落ちこんだのである。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ沼の水面が、なんにも浸っていないのに、一部分が抉りとったように穴ぼこになっていたのだ。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッドの身体を本庁で縫い合わせたとき、肩の肉が途中で落したものか無かったため、穴ぼこになっているのです。",
              "citation": {
                "source": "一九五〇年の殺人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対側には、水に穿たれて穴ぼこだらけの嶮しい岩岸がすっかり照らし出されて、ちらちらと川面に映り、矢のような奔流に千々に砕けている。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の人間らしい気持は、まるで穴ぼこに射した陽の光のように、むなしく消えてゆくんです。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに道路が穴ぼこだらけだからなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何や、急からしう、………」「これ、見て御覧、―――」夫婦の居間になつてゐる奥の六畳の押入を開けると、下の段の隅ツこの、柳行李と用箪笥の隙間の暗い穴ぼこになつた所に、紅くもく／＼かたまつてゐるものが見える。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何や、急からしゅう、………」「これ、見て御覧、―――」夫婦の居間になっている奥の六畳の押入を開けると、下の段の隅ッこの、柳行李と用箪笥の隙間の暗い穴ぼこになった所に、紅くもくもくかたまっているものが見える。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "危ない危ないと思っているうちに、案の定、穴ぼこの中へ右足を踏みこんでえらい勢いでひっくりかえる……。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、こんな事をかんがえながら、一方では、穴ぼこのなかからやさしく佐伯氏を助け起こしている。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の袖を廻つて、塀に圍まれた穴ぼこのやうなところに、四五軒で使ふ釣瓶井戸があつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "水垢離",
                "note": "青空文庫"
              }
            },
            {
              "text": "光太郎は提灯をさげてぶらぶらルダンさんの家のほうへ歩いて行ったが、道普請の壊えのあるところへくると、われともなく、「おい、ここは穴ぼこだ。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "外科から病室へ帰って来る途中の菩提樹並木のところで、伸子は人のふまない白い雪の上に、いくつもいくつも泥のしぶきでまわりの雪のよごれた小さい黒い穴ぼこができているのを発見した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の枝々からしたたり落ちる雪どけ水が点々と地べたの雪をうがってつくる穴ぼこだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は、一度ならずトラックがこしらえた深い穴ぼこの水たまりにはまった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
