    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unexpectedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案外について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案外という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案外の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案外が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案外を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案外について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案外の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案外の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案外が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案外という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案外という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案外についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案外を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案外は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案外について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案外が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案外は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案外の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案外は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案外は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さういふ定説といふものを云ひ出す方は案外呑気に云ひ出すのであるが、云はれる方は辛いものである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新体詩様式は、未だ十分の発達を示してはゐないけれども、人々はその案外に困難なる故を以てかどうか、何時の間にか退却し、昨今再び立向つてゐる状勢だが、猶極めて怠惰な立向ひ方と云へよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、さういふことにすれば、現今文学者が彷徨してゐるといふことも、私には案外簡単なことに思へて来る。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　併し小説家の傍にゐるなんて、案外労いもんですよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、　歩き出すと案外に平気だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、いまのこの時代に、もっともっとたくさんあって当然のように私には感ぜられるのだが、しかし、案外、見当たらない。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、こんなところに全体主義の困惑があるのではないか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、長生きするのではないか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとある微分値の間を駆け巡り、今日積分値にまで漸く辿りついてみると、案外に道は近きにあるに驚かざるを得ない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやＭの性質では案外そんなことを言はないかも知れませんよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案外に淡泊と返事をしたが、これが彼の平生のこんな場合の返事振ではない、額口に皺を寄せて火鉢の縁か何かをチヨンと指で弾いてそれから返事をするのが彼の平生のこんな場合の返事振なのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの訳を読んだ人たちは、案外原作のつまらないのに失望して不平を言つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこれが案外親切な巡査で戸籍簿のようなものを引っくり返して小首を傾けながら見ておったが後を見かえって内に昼ねしていた今一人のを呼び起した。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はかよわい身一つで病人の看護もせねばならず世話のやける姪をかかえて家内の用もせねばならず、見兼ねるような窮境を郷里に報じてやっても近親の者等は案外冷淡で、手紙ではいろいろ体の好い事を云って来ても誰一人上京して世話をするものはない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこの家へ行くのは、どうも大儀だ、窮屈だ、と思ひながら澁々出かけて行く時には、案外その家で君たちの來訪をしんから喜んでゐるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小照太宰治　いつも自分のところへ遊びに來てゐる人が、自分の知らぬまに、自分を批評してゐるやうな小論文を書いてゐるのを、偶然に雜誌あるひは新聞で見つけた時には、實に、案外な氣がするものである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しいことには、古来の屋根の一型式に従ってこけら葺の上に石ころを並べたのは案外平気でいるそのすぐ隣に、当世風のトタン葺や、油布張の屋根がべろべろに剥がれて醜骸を曝しているのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものごとが凡て、原則どおり単純に行って済むのなら世の中は案外やさしいものです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは自分の一生も案外小ぢんまりした平凡に規定されてしまう寂寞の感じはあったが、しかし、また何かそうなってみての上のことでなければ判らない不明な珍らしい未来の想像が、現在の自分の心情を牽きつけた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段「男は案外臆病なものだ」と養母の言った言葉がふと思い出された。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場にしては案外狭く感じた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも案外見られる服装をしてやって来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が比較的に云って、近代の青年は案外真面目な思想を抱いているものが多い様です。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　女の方も女の権利とか位置とかを楯にして案外｜浅薄な利己主義な、お芝居気を満足させるための気障なのも往々にして見受けます。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠蘇と一緒に出される吸物も案外に厄介なものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の仕事や学説が九十九まで正鵠を得ていて残る一つが誤っているような場合に、その一つの誤りを自認する事は案外速やかでないものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある読者はますますあるいは始めていわゆる精密科学の基礎の案外薄弱な事を考えて、その価値と効果を疑うかもしれない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんに意外と当惑の心持が増すにつれて私は、東京という処は案外に不便な処だという気がして来た。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に立交わって人とつき合うときの心得を説いたものが案外に多い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父っつあんがいくら……いくら、いくら何んと云ったって……」　「もういい石松、分った分った分ってるよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
