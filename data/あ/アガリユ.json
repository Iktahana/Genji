          "literary": [
            {
              "text": "これは風呂から出て、ちょうど上がり湯を使おうとしたところらしい。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬琴は水槽の前へ来て、心静かに上がり湯を使った。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がり湯は既に水になつてゐます。",
              "citation": {
                "source": "佐渡が島のこと",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくに体を洗いもしないで、それから伊兵衛と馬春堂が、上がり湯をザッと浴びて着物を引っかけ初めたころ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかしやの花さく見れば水の上にはかなき夏の夢もやどりぬ片恋のわれをあはれと鈴麦の花さく傍を通ひ来にけり夕青き微光の中をあがりゆく足長蜂は足を垂らせり玉赤き蝋マツチする草のなかすでに蛍の臭気むせべり　こうした所縁の深い新作が増補として、「第二桐の花」としてでも加えられねばならない恋々たる気持にもなる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
