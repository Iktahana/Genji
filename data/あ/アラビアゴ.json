        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラビア語について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラビア語の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラビア語が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラビア語について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラビア語の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラビア語が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラビア語という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラビア語についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラビア語は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラビア語が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラビア語は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラビア語の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラビア語は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラビア語は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おもしろいことには、アラビア語の川は「ナフル」、ヘブライのが「ナハル」「ナーバール」等。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事全部分からないアラビア語ででもあればかえって楽であろうが、困った事には時々ところどころ分かる日本語であるからいけないのである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鳥のアラビア語 tair. 咽喉のシナ語 hou lung）。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビア語でも sinn というのは歯を意味しまた年齢をも意味する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ヨーロッパ諸國の紙に關係ある言葉で、アラビア語から派生して居るものもある。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を擧げると、英語で紙一｜束を Ream といふが、之はスペイン語の Resma イタリー語の Risma ドイツ語の Ries フランス語の Rame と等しく、何れもその語源をアラビア語の Rezma に求むべきである（28）。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館に行くと、トーキーはフランス語でしゃべっているが、説明の字幕は左端にアラビア語、右端にギリシア語が出た。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バザーへ行くと、しかし、アラビア語でないと幅がきかない。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フスタトの語意についてはいろんな説があるが、ローマ人がバビロンの城砦に外濠を繞らしてフォサトゥムと呼んでいたのを、アラビア語化してフスタトとし、陣営の意味で用いたという説が妥当らしい。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスル（ミスル）はエジプトを意味するアラビア語である。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エル・カヒラ 〔El-Ka^hira〕 はアラビア語のカヒル 〔Ka^hir〕（火星）の転訛で、それが都市の名称となったについてはおもしろい記録が残っている。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプトの到る所にアラビア語が一番多く用いられてる事によってもその勢力は想見される。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等は先祖を忘れてアラビア語を母語としてるが、それでも言葉の習得に達者で、近代ヨーロッパ語をよく話し、店員として重宝がられ、領事館などにも使用されてる者が多く、しかし政治的・社会的には非力である。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、アンリが、ペルシア語やアラビア語やサンスクリット語に注意を奪われたので、私もつい誘われて同じ勉強を始めた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一人一人に、或は、英語で、或はフランス語で、また、時にはアラビア語かなにかで、いちいち話しかけ、それが、ズバリと、その女の母国語であるらしいのに、おれは面喰つた。",
              "citation": {
                "source": "放浪者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "尨大な稀覯本の蒐集その中には稀に解し得ない本もあって、大部分はアラビア語だったと思います。",
              "citation": {
                "source": "墓場",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア語、アラビア語、ラテン語をこの首都の人たちは常に使っていて、12世紀のシチリアの学者たちはギリシア語から直接に訳していた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプト攻略の後で、ギリシア語の著作はしばしばシリア語を介してアラビア語に翻訳された。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは翻訳者の２家族として知られているバフティシュアス家とメシュエス家のものであったが、共にシリア人であってギリシア語にもアラビア語にもあまり堪能では無かったようであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドおよびペルシアの医師の著作もアラビア語に翻訳された。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に述べたように北アフリカのキリスト教僧侶のコンスタンティヌス・アフリカヌスは広範に旅行して多くの言語を学んで、サレルノに来て多くのアラビア語の著作、とくにヒポクラテスとガレノスの著書をラテン語に訳した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くのあいだ学問におけるユダヤ人の言語はアラビア語であり、アラビアの知識およびその翻訳は、彼らを経過して南ヨーロッパおよび中央ヨーロッパに移された。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア語からシリア語へ、シリア語からアラビア語へ、アラビア語からヘブライ語へ、およびヘブライまたはアラビア語からラテン語への翻訳において、ギリシアの古い著作者の形態および思想にしばしば混乱が無いわけではなく、しばしば誤りが生まれ、ガレノスの解剖学は伝達にさいしてひどい目にあっていた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、初期の医学書の著者67人の182版のうちで、23人は13世紀と14世紀で、30人は15世紀、8冊はアラビア語で書かれており、何冊かはサレルノ学派のもので、6冊だけが古典時代のものであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――トーマス・ヤングは一七七三年七月十三日生れで、十四、五歳のときには、既にオランダ、ギリシャ、フランス、イタリア、ヘブライ、ペルシア、アラビア語を読んだ。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアラビア語伝記者が引用している失われた彼の本の１冊で、キリスト教信者が徳を愛していることを彼は高く評価している。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わりの６冊は今ではアラビア語の翻訳版だけ存在し、そのうちの２冊はオクスフォード大学のボーレアン図書館に保存されている。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で現われたファラビは九世紀の後半にトルキスタンのファラブで生れ、早くよりバグダードに来てアラビア語とギリシア哲学を学び、やがて自ら講義するに至った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
