        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗刻について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗刻という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗刻の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗刻が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗刻を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗刻について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗刻の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗刻の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗刻が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗刻という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗刻という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗刻についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗刻を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗刻は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗刻について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗刻が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗刻は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗刻の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗刻は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗刻は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから小さいインチキでは、サイドの計算のときに、飜牌の暗刻があるとて大分とられるが、そのとき、本当は暗刻ではなく、二枚しかその飜牌はなく、裏がえしの牌は、他のデモ牌であったりする。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗刻のあやしいのは、ひっくりかえしてみてやるに限る。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "明暗刻々　謙信は佇立していた。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンコールをやっていますが、何かみじかいものでもきかせてやってくださいませんか。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂュプラは名優がアンコールされたときの態度のように少し首を傾げ上目使いに揉手しながら気取って答礼をしている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三曲の演奏にアンコールを許したり、裸体彫像に生花を配したり、ずいぶん突飛なことも彼によって示唆されたが、椅子テーブルの点茶式や、洋食を緩和して懐石の献立中に含めることや、そのときまで、一部の間にしか企てられていなかった方法を一般に流布せしめる椽の下の力持とはなった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコーのフライを作れ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してお客さんのお気に召すかどうか、待て、アンコーのフライとそれから、卵味噌のカヤキを差し上げろ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう云うと、美和子はエレクトロラにかけ寄って、コンチタのレコードを、アンコールした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコール、アンコール、アンコールと望みたい――などゝ云ひ過ぎて妻君に反感を持たれたりした、――で、それだけ方々の芝居を見て、それが一番面白かつた（これは僕ばかりではない、観客全部の大喝采なのだ。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＨ氏はこのアンコールに応じて、再び立つて行つた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　拍手が「アンコール」を呼ぶように、何時迄も続いた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "）さて二号室は「歌姫」と呼ばれ、いい髯面の男だてらに女の着物を着て可憐なソプラノを張りあげ、発狂当時覚えたものであろう古臭い流行歌を夜昼なしに唄いつづけては、われとわが手をバチバチ叩いてアンコールへの拍手を送り、送ったかと思うとケタケタと意味もなく笑い出したりした。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は直ぐにアンコールだ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フール・オン・ザ・ヒル」の演奏を終えたあと、アンコールの声を充分待ちきることなくアルテアが次の演奏に移った点には不満が残ったが、耳を澄ませてラジオからの音を追う聴衆の視線の熱に、ドンピアはくすぐられるような喜びが湧き上がるのを抑えられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンピアはアンコールに、コンピューターが奏でるにふさわしい「デイジー」を用意していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコールが始まると、大半のメンバーの脳裏にスタンリー・キューブリックの「二〇〇一年宇宙の旅」の印象的な場面がよみがえった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアがアンコールを終えると、会場には歓声と口笛と拍手が湧き起こった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "髭の男は、梅の実のカクテルをアンコールして寒子には甘いサンザノを註文してくれた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、この八重岳の山容は、仏印のアンコールトムのバイヨンに似てゐると思ひ、その頃の話をぽつりぽつり話してゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルロ・ナイン嬢の姿が三度ほどアンコールされた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコールのあとも拍手はしずまらなくて、もう一度出て来たそのお辞儀もやっぱり、さっぱりと真率なものでされている。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はうたい終っておじぎをし、アンコールの拍手に、何度もおじぎをしてさてステージを去ろうとして驚いてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日アドリナ・パティはアンコールに「ホーム・スイート・ホーム」をうたいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒にどうしようと思った瞬間、アンコールの拍手に蝶々さんが起きあがって、ニッコリ笑っておじぎをしましたので、私は自分自身が生き返ったように嬉しくなりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍手がいつまでもいつまでも続き、何度アンコールにおじぎしても拍手がやまない、恐ろしい熱狂ぶりなのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコーのような怪書生でも現れてくるかと思うと、ショボ／＼した老婆が現れて、「裏から来るんだよ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、押し出すやうな日本語で繰返しながら、大真面目な感謝の眸をじつと十吉の眼につけて、アンコールに呼び出された音楽家よろしくの身のこなしで、後じさりに退場して行つた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでわたしがアーサの好きな曲をひくと、かれは「アンコール」（もっと）と声をかける。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはいく度もアンコールを受けた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
