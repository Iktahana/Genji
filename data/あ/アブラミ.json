        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脂身について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この脂身は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "脂身の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が脂身について知っています。",
              "source": "幻辞"
            },
            {
              "text": "脂身は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は脂身の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "脂身に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では脂身が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から脂身を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "脂身の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも脂身が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では脂身が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "脂身について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも脂身は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも脂身は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で脂身は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に脂身について学びました。",
              "source": "幻辞"
            },
            {
              "text": "脂身の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する脂身の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では脂身の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ブリスケを買う時は脂身の附いている処でないと美味しくありません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑゝかは親類、まじゝは赤身、ぶつ／″＼は白いところ即脂身である。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四角のうち半分ぐらい、すなわち、上部一寸ぐらいが真白な脂身で、実にみごとな肉であった。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂身が厚く、しっかりしている。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつ、ついでに述べておけば、面白いことに、昔は豚の肉でも京都の方では、赤いほうが安く、白い脂身が高かった。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なども脂身が美味いと思っていた。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが東京へ来てみると、反対に赤身が高く、脂身が安い。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京は美味いところが安いのだね」などと言って、脂身を買って食ったことを憶えている。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、これも今日になってみれば、脂身ばかりでも困る。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも、ものを食う心得がないからのことで、私だったら、まず脂身のところで野菜を煮て、別に肉を取って、かたければ薄く切り、これを徐々になべに追加しながら、煮えるそばから食べるようにする。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、猪の味だけで食おうとすれば、相当脂肪のついた肉（脂身）を豊富に使うべきである。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも冬場でも、まぐろの腹部の肉、俗に砂摺りというところが脂身であるゆえに、木目のような皮の部分が噛み切れない筋となるから、この部分は細切りして、「ねぎま」というなべものにして、寒い時分、東京人のよろこぶものである。",
              "citation": {
                "source": "鮪を食う話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はというと、これは羊羹色の脂身の少ない部分、男が食べては美味くないというところをよろこぶ。",
              "citation": {
                "source": "鮪を食う話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いのししの肉は牛肉や鶏のように大してうまい味があるというものではないから、白色の脂身が入用である。",
              "citation": {
                "source": "夜寒に火を囲んで懐しい雑炊",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い脂身と赤い肉と混ざったものを細かに切り、皮山椒を少々加えて、別の鍋に淡泊な味付けで汁たくさんに煮る。",
              "citation": {
                "source": "夜寒に火を囲んで懐しい雑炊",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人も精査することを好まないような秘密が醜い襤褸の山や、腐った脂身の塊りや、骨の墓場の中に育まれかつ隠されていた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "水でも飲みたいと思っていると、昼刻になって、黒々として眼鼻もわからないような黒坊の子供が、小麦を蒸した切餅を一切れに鯨の脂身のようなものを添え、砂糖を入れた茶を持って来た。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、鯨の脂身だと思ったのはこれだったのかと、気色が悪くなって寒気が出た。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても鯨の脂身はうまかったといった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは流すのだからやってみようと、あらかた前もって、アジが悪かったらタコに替わろうと思っていたので、タコの餌に豚の脂身は持ってきている。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌の豚の脂身の上にまたがる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな業の尽きないおばさんの魂魄が、焼いても焼ききれるはずはないから、その焼跡にまだうろうろしていることも一応は不思議ではないが、ここに出現したのは、あの脂身たっぷりなイヤなおばさんの幽霊としては、あんまりしみったれで、景気のないこと夥しい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯を注ぐと、赤い色の細身が白っぽい脂身のような色に変った。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、最初は蝋燭でなくて、山羊の脂身をしぼって、燈心を燃やす油を取ったのだよ」　哲雄君は実に物おぼえがいいのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、僕らも鹿の脂身から、油を作れないかしら」「そうだね。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂身などはちッとも交じらんとこを切れよ」「かしこまりました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には脂身ばかりのとこを、もう十斤」「へえ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂身ばかしなんて、何になさるんで」「よけいな詮索するな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は豚のあぶらみとか、あぶらろうそくというようなものはなんにもしらないのかね。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう年なんだ　はぐきも弱い　あぶらみでやっとだ　なのにガチョウほねごと平らげ――　なんなんだ　わかいころは　へりくつばっか　夫婦ゲンカさ　おかげでアゴもじょうぶよ　こりゃ一生ものさ　もう年なんだ　ふつうだったら　目もしょぼしょぼのはず　なのに鼻にウナギを立てて――　器用かよ！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
