          ],
          "literary": [
            {
              "text": "意なく投げ疊ねたらむやうに見ゆる、礎の間より、水流れ落ちて、月は恰も好し棟の上にぞ照りわたれる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好しワチカアノの畫廊開かるべき日なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好しフランチエスカの君は、臨時の費もあるべく又日ごろの勞をも忘れしめんとて、百「スクヂイ」の爲換を送り給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好し將に沒せんとする夕日はそのなごりの光を最高列の窓より射込みたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルピイおろしの寒威は、恰も好し、我が沸きかへる血を鎭むるならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖アントニウス寺の七穹窿は、恰も好し月光に耀けり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち刀が出來て來たので、伊織はひどく嬉しく思つて、恰も好し八月十五夜に親しい友達柳原小兵衞等二三人を招いて、刀の披露｜旁馳走をした。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五行を五臟に配する時は恰も好し五帝は猶ほ五臟の神の如く、而して泰一は頭腦の如き位置に立つものである。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好し叔父杏坪が当主｜重晟の嫡子｜斉賢の侍読となつて入府するので、山陽は附いて広島を立つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "両本は恰も好し有無相補ふのであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は恰も好し春の釈奠の日に会して、向井祭酒を見、又高松南陵の講書を聴いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の例として催す「豆日草堂集」は、恰も好し、雪の新に霽れた日であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "権に十四歳を以てしたとすると、恰も好し斎の子懐之と同庚であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉永は恰も好し昨日門司より来りたる由にて、奇遇を喜候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "採薬途上の甘酒は、恰も好し、トランシシヨンの用をなした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好し、幕府の任命が下つて、柏軒は幸にして苦境を脱することを得たと云ふのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旅店に入れば、恰も好し、一家の人、午食をすましたる處にて、つめたき客座敷よりは、むさくるしけれど、冬の山里の唯一の馳走、いざ入らせ給へとて、勝手の間の爐側をわれら一行に讓りぬ。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く／＼と桃葉をうながして、停車場へ駈けつけ、切符を買ふより早く、プラツトホームに出づれば、恰も好し上り汽車來たる。",
              "citation": {
                "source": "狹山紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "立往生の客ばかり、哀れ気の毒に見えたりしが、恰も好し、某学校の制服着けたりし賀客両人、入り来りしかば、五つ紋の先客は、九死の場合に、身代りを得たる思を為し、匆々辞して起ちたりしが、主人は尚分れに臨み、『それなら、四日の朝四時までに、僕の家に来給へ。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、桓武天皇は、仏教の改革に御心を用ゐられてゐたが、あたかもよし、この時代に空海（弘法大師）最澄（伝教大師）の二傑僧が現はれ、仏教自身、その宿弊を一掃した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもよし、後続第六軍団はこの頃戦場に到着した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもよし、花見月のおまつり日和。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもよし、この時｜葡萄牙人我が種子島に来て小銃及び火薬を伝えた（小銃の事を当時は種子ヶ島と言ったものである）。",
              "citation": {
                "source": "東西両文明の調和を論じて帝国の将来に及ぶ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもよし、この景勝の籠り堂が、堂守夫婦きり、冬はたいていがら空きが例、と聞くや、これぞ天の与えと、事情を述べて、借用かたを申し入れる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回了り、あたかもよし、すし久来り、あなご、卵、胡瓜巻、いか等十個位食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
