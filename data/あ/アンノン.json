          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安穏について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安穏という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安穏の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安穏が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安穏を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安穏について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安穏の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安穏の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安穏が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安穏という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安穏という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安穏についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安穏を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安穏は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安穏について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安穏が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安穏は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安穏の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安穏は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安穏は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしこの清少納言のオーソリティが九百年もそのままに保存されて来たとすると、自然界に対する日本人の知識がいかに長い間平和安穏であったかという事を物語っている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして死後の生活を指導することが出来ようぞ、もっとも、この僧は首を斬られて死ぬときに、大きな声で「吽」と叫んだら、その声は数里の外まで響いたという奇蹟を伝記者は附け加えているが、そんなことぐらい、生きる上の幸福をも、死後の安穏をも共々、宗教に求めている慧鶴には何の力にもならなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――八大竜王鳴渡りて、稲妻ひらめきしに、諸人目を驚かし、三日の洪水を流し、国土安穏なりければ、さてこそ静の舞に示現ありけるとて、日本一と宣旨を給りけると、承り候。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、僕は七年の間日本で安穏な日を送ることが出来たのでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津拝領は八月中旬の事で、もう其歳の十月の二十三日には羊の木村父子は安穏に草を※んでは居られ無くなって、跳ねたり鳴いたり大苦みを仕始めたのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは将門が安穏を得させようとして跡を埋め身を隠させた其の愛妻を敵が発見したことであつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによれば、何等の機縁が有ったのでも無く、我児が一人で世に立って行かれるようになったので、予ての心願に任せて至極安穏に、時至って瓜が蔕から離れるが如く俗世界からコロリと滑り出して後生願い一方の人となったのであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これは源信寂心にはじまったことではなく、経に在っては月光童子の物語がこれと同じ事で、童子は水観を初めて成し得た時に、無心の小児に瓦礫を水中に投げ入れられて心痛を覚え、それを取出して貰って安穏を回復したというのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後いよいよ御静養のことと思い安心しておりましたところ、風のたよりにきけば貴兄このごろ薬品注射によって束の間の安穏を願っていらるる由。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖武天皇は仏教に依つて、国家を治めようと思召し、天下泰平、国土｜安穏を祈らせ給うて、国毎に国分寺を建てられ、総国分寺として奈良の東大寺を建立された。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もし私が素直にここを立ち去って、彼の女を安穏にのこして行ってくれるなら、夫の眠っているのを見計らって、暁け方の三時に起きて来て、私に立ち退くように説得するために、金を持って来ました。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は相変らず郭外サン・ジェルマンの自分たちの部屋に住みながら、先のことは空吹く風にまかせ、ただ現在を安穏に眠り暮して、周囲の退屈な世界を夢のなかに織りこんでいたのだった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "――八大竜王鳴渡りて、稲妻ひらめきしに、諸人目を驚かし、三日の洪水を流し、国土｜安穏なりければ、扨こそ静の舞に示現ありけるとて、日本一と宣旨を給りけると、承り候。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殉死者の遺族が主家の優待を受けるということを考えて、それで己は家族を安穏な地位において、安んじて死ぬることが出来ると思った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子で推すれば、一族のものも安穏には差しおかれまい。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野さんは親が坊さんにすると云って、例の殺生石の伝説で名高い、源翁禅師を開基としている安穏寺に預けて置くと、お蝶が見初めて、いろいろにして近附いて、最初は容易に聴かなかったのを納得させた。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安穏寺の住職は東京で新しい教育を受けた、物分りの好い人なので、佐野さんの人柄を見て、うるさく品行を非難するような事をせずに、「君は僧侶になる柄の人ではないから、今のうちに廃し給え」と云って、寺を何がなしに逐い出してしまった。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまが私をいちどお殺しになって、それから昨日までの私と違う私にして、よみがえらせて下さったのだわ」　それから、きょうまで、私たち二人きりの山荘生活が、まあ、どうやら事も無く、安穏につづいて来たのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山荘の安穏は、全部いつわりの、見せかけに過ぎないと、私はひそかに思う時さえあるのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白柄組の頭と頼む水野殿が亡びた以上、お身達とても安穏では済むまい。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれを此のように殺したからは、敵も安穏には捨て置くまい。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やと定子……こんな純粋な愛情の中に取り囲まれて、落ち着いた、しとやかな、そして安穏な一生を過ごすのも、葉子は望ましいと思わないではなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は向島の小さい穏かな住居で、維新の革命も彰義隊の戦争も、凡て対岸の火事として安穏に過して来ました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、安穏な家庭の幸福で、満足している平凡な人間です。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うか安穏な御家庭で何時までも平和にお暮し遊ばせ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな平和な、安穏な環境に生きている自分に、一体警察｜沙汰になるような事件の渦中に巻きこまれる可能性があるだろうか？",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしの夫が罪なくして殺された以上、どうしても相手を安穏に捨てて置くことは出来ません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "続夷堅志・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはとにかくとして、南蛮屋の店へはいった以上、安穏ではいられまい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあれだけ立派な証拠を残して来た犯罪事件ではあったが、震災直後の手配不備のせいであったか、それから一月経っても、二月経っても、司直はミチミたちを安穏に放置しておいた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、安穏な家庭の幸福で、満足してゐる平凡な人間です。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
