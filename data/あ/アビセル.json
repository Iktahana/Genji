        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浴びせるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この浴びせるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が浴びせるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は浴びせるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では浴びせるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から浴びせるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも浴びせるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では浴びせるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも浴びせるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも浴びせるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で浴びせるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に浴びせるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "浴びせるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する浴びせるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では浴びせるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "絶壁の下なる大深谷からは、霧がすさまじいいきおいで、皺嗄れ声を振り立てて上って来る、近づくほど早くなるかと思うと、端から砕けてサアッと水球を浴びせる、そうして呻りながら、尾根につかまり、槍先へ這いずり上って、犠牲になる生霊もがなと、捜し廻っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈までが安値に心易い光をそれらの人達にきらきら浴びせる美しさ、そして暖かさ、みなクリスマスの買物の人達を見せる光景です。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかもあの時、思いがけない、うっかりした仕損いで、あの、お染の、あの体に、胸から膝へ血を浴びせるようなことをした。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる、その（お出ばな）のためであった、女に血を浴びせるような事の起ったのは。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッ、悪く御託をつきゃあがると、汝がの口へ氷を詰めて、寒の水を浴びせるぞ、やい！",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストキはわめくような笑いを船長に浴びせると、そのままグルリと振りかえって、おもての方へ帰って行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝらで一歩違へば立所に道子は剣のやうな冷笑を真向から浴びせることは解つてゐる。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その激昂に、水を浴びせるように夫人は云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしわがれた悲壮な声が、水を浴びせるように実之助に徹してきた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その激昂に、水を浴びせるやうに夫人は云つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はだんだん笑ひくたびれて、何とはなしに吐息をもらすと、また浴びせる。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ちっそくしながら、地上あらゆる女性に向って、死物狂いの呪咀を浴びせるのではございますまいか。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は背後に浴びせる亭主はじめ女房や娘共の嘲笑が聞えるやうな気がした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「煙草屋だ」と、主人はコブセの振り浴びせる手を避けようと、しきりに身を反らしながら唸った。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、ロシアの津々浦々、到るところで、馬を励ましたり、急き立てたりする時に浴びせる、いろんな掛声だの、滅多矢鱈な、あらゆる罵り声だのが取り入れてあった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大の悪口屋で、いつもいろんな辛辣な皮肉を浴びせるものだから、彼はよく、【ふん、何を言ってやがるんだい、ケチな皮肉屋め！",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れ際に悪口を浴びせるのは宜しくないことぢや、殊に何時また会へるやら知る由もない相手にむかつては尚更のことぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶をするにも握手を身につけた手振りでするものが多かったが、気羞しげに船客を取り巻いたまま無言で遠くから見ているものや、いきなり冗談を浴びせるものらの中で、真紀子もすぐ千鶴子に近よって来て、握手をした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの音も、また弾丸のように水を浴びせるのも、みんな水圧を利用しているのだ」と法水は飛沫を避けながら、何気なしに云ったけれども、検事はこのバロック風の弄技物から、なんとなく薄気味悪い予感を覚えずにはいられなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また一方では、それが法水麟太郎に、散光を浴びせる動機ともなったのである。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ烈風と寒冷が髭を硬ばらせ、風は隊列を薙いで粉のような雪を浴びせる。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これは、人間の本能的な弱さからだと、ぼくには許せる気になるのでしたが、同時に、誰でもが持っている岡焼き根性とは、いっても、クルウの先輩連が、ぼくに浴びせる罵詈讒謗には、嫉妬以上の悪意があって、当時、ぼくはこれを、気が変になるまで、憎んだのです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から「人間もだいぶ奇麗でした」と浴びせるように付け加えた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人は親切に慰めて呉れるかも知れない、ある人は、いやどうも飛んだ御災難でと恰も災難ででもあったかの如くまともに慰問の言葉を浴びせるかも知れない。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　が、そのうちに、私はそれにもめげずに、じっと空中に目を注いだなり、いつか知らず識らずの裡に自分自身をその稲光りがさっと浴びせるがままに任せ出していた。",
              "citation": {
                "source": "かげろうの日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人が通りいつぺんの挨拶で同じ問ひを浴びせるなら通りいつぺんの気軽さで答へる手段もあるだらう。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬に浴びせていた可愛ゆい言葉を、兵馬が去ればまたほかの人に惜気もなく浴びせる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩に一太刀あびせるが浅手である。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀金平勝忠、武田勢を追いながら、「旗を棄てて逃げるとは、それで甲州武士か」と嘲笑をあびせると、武田の旗奉行振り返って、「いやその旗は旧くなったものだから棄てたので、かけ代え此処に在り」と云って新しい大文字の旗を掲げると逃げ出した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本軍は壁に拠って突喊して来る明軍に鳥銃をあびせる。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
