        "examples": {
          "standard": [
            {
              "text": "私は毎日アンダーラインについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンダーラインの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンダーラインが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンダーラインについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンダーラインの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンダーラインが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンダーラインという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンダーラインについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンダーラインは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンダーラインが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンダーラインは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンダーラインの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーラインは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンダーラインは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのベデカはちゃんと一度下調べをしてところどころ赤鉛筆で丁寧にアンダーラインがしてあった。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに鉛筆や紫鉛筆でやたらにアンダーラインをしたり、？",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう放心しているらしい夢想あるいは言葉の切れ間の一つの間に、予は、褥榻の上の自分の近くにあった、かの詩人にして学者なるポリシアン19の美しい悲劇「オルフェーオ」（イタリアの最初の自国語の悲劇）の一ページをめくると、鉛筆でアンダーラインを引いた一節を発見した。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句集はいつのころ讀んだものか赤鉛筆のアンダーラインが引いてある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いアンダーラインのしてあるその一つを、相手はだまつて指でついた、杉村はそこに自分と小泉の名を見た。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先達てもフロベールの手紙を読んでいたら、次のような文句があったので、私はまたアンダーラインした。",
              "citation": {
                "source": "書物の倫理",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題は此のアンダーラインした est である。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの本のたった一ヶ所にアンダーラインをひいていた。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこに限ってアンダーラインをひいていたことを、その道々苦笑したが、後日になっては、見るに堪えない自責に襲われ、殆ど、強迫観念に苦しむようになったのである。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、こんなところに、アンダーラインしてあるぞ」　今まで気がつかなかったが、下欄の小さい活字のところが、数行に亙って、黒い鉛筆でアンダーラインしてあった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな記事に、鉛筆でアンダーラインがしてあるんだが、誰が、これを引いたんだろうね」　そういって、仏天青は、例の日本将校フクシ大尉の失踪に関するパリ電信の記事を見せた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでメチャメチャにアンダーラインを引張ってみたり、それでも駄目だと一つところを何回も何回も大きな声を出して繰り返した。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の逡巡と内氣とは、却つて君の見せるを敢てしないところにまで、此處に注目せよとアンダーラインを引くと云ふ結果を持ち來してゐる。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然あらはれたページには、鉛筆で二重に引いた荒つぽいアンダーラインがあつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは試驗前に、アンダーラインをして置いた問題だけ、ずつとやれば大丈夫だと思つてゐるんです。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上に〈測量技師〉って文字に青くアンダーラインしてあるのを探すんだよ」「ここは暗すぎるのよ」と、細君がいった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書類の上には〈測量技師〉という字に青くアンダーラインがしてあるんだよ」　村長は反対しなかった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダーラインまで引いてね。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――文中傍点の個所はベートーヴェンの原文にアンダーラインのある部分である。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ベートーヴェンは自分の持っていた本のこの部分にアンダーラインをしていた。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
