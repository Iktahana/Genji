        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日過ちについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "過ちという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は過ちの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には過ちが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "過ちを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは過ちについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "過ちの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は過ちの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では過ちが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "過ちという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に過ちという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では過ちについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "過ちを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると過ちは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "過ちについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では過ちが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に過ちは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により過ちの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "過ちは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に過ちは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "分類が終るや能事足れりとなす所に、現代インテリの過ちがあり、恐らくこの過ちが彼を不幸にした大きい理由であつたと云へよう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭公に過ちがあったのは、わしの不徳の致すところだ。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "観聞志もし過ちたらむには不都合なり、王勃が謂ふ所などは何うでもよし、心すべき事ならずや。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが、生活という自動車に乗って、人生の路を気ままに走っているとき、過ちの曲り角へ来ると、「菩提心」は急に制動機をかけます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそうして毎日々々二人きりでさし向いの為事をしている中に、何方から云い出すともなく、小野と美代子はつい過ちを犯してしまったのである。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そんな怖しい過ちのもとは、みんなわたくし自身なのでございますから。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "不具者のもちまえで、彼女は頑に、親の教えた過ちを信じて改めなかった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おのずから出ずべき疑をおのずからの調子で尋ね問われて、女はギクリと行詰まったが、「それがわたくしの飛んでも無い過ちからでござりまして。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ちは時の魔というものだ、免してやる。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而かもなほ過ちにけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ち易きは、人のみち、算盤の珠。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが頑骨を愛して我が犠牲となりし者の為に、半知己の友人を過ちたりし事もあり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽ろうと思えば偽り得る範囲に限られていると見て大した過ちは無いようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "失策をした僕としては、勝手な云い草だけれど、僕に過ちがあるにしろ、貴女が一度も僕を詰らずに、冷然としているんで、僕は何だか貴女が恨めしくなってしまったんだ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もしそれならば、美沢が美和子との関係を告白し、それが感覚的な一時の過ちであったことを謝っている以上、……また美和子が、美沢に対して、ケロリとしてしまっている以上、美沢を許して、以前のような愛人関係に……いな雨降って地竪まるように、前よりももっと具体的な愛の誓いを交してもいいはずではないか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが過ちの因というものだ。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「罪はないが、大きな過ちをひとつ犯している。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く空いたとはいえ、過ちの記憶と復讐への渇望は、やはりジョン・フェリアの墓前で立ち尽くしたあの忘れ得ぬ夜からまったく変わりない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "人若し過ちて此門に入るときは、多くは再びこれを出づることを得ず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ちを改めざるを過ちと言うとあるに、入らぬところに意地を立て、熊楠はともあれ他の諸碩学の学問上の希望を容れられざりしは遺憾なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、各の引退き、戸を閉た後ち、其役目の刀自が來て、指もて手際よく嫁の素を破り、布に其血を受て、其婦徳に過ち無りしを壻に示す。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "観聞志もし過ちたらんには不都合なり、王勃が謂う所などはどうでもよし、心すべき事ならずや。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もなぜ早く池を埋めなかつたか、取返しのつかぬ過ちであつた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその恩に報いなくてはならぬ、その過ちを償わなくてはならぬと思い込んでいた長十郎は、忠利の病気が重ってからは、その報謝と賠償との道は殉死のほかないとかたく信ずるようになった。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来、人は皆勝つことを好んで心｜昂ぶり、好んでまやかしの説を聴き、昔から万人が行って過たず、万々人が行って過ちのない大道路を役立たないとし、石ころだらけの荊道に力を奮い、前進し、突破しようとする傾向がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もなぜ早く池を埋めなかったか、取り返しのつかぬあやまちであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩愛ふかき親に苦を増させて、我れは同じき地上に彷遑ん身の、取あやまちても天上は叶ひがたし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　園は、今更ながら、瞬時と雖も、心の影が、其の熱に堪へないものゝ如く、不意のあやまちで、怪我をさした人に吃驚するやうに、銀の蓋を、ぱつと取つた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は多く北風吹き、火のあやまちは冬多きものなれば、怪むべくもあらぬ事ながら、東京の大火を叙せんとて、心も無く、北へ行く雲に火の色うつりて天は紅霞のわたれるが如し、など別の故も無きに筆を舞はして記さば、如何に見苦しきものに老いたる人などの見なさん。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のあやまちを非難する事が出来ないのです。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
