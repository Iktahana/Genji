          ],
          "literary": [
            {
              "text": "カエルたちはね、水の中からあたしたちにおじぎをして、コアックス、コアックス！",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ふざけて、声を挙げて、「クラアックス、クラアックス！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クラアックス、クラアックス！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは百戦功を経たエクスパートであり、Ｂは初めて氷にアックスを揮うビギナーである。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍沢の小屋の屋根に八尺の雪をはかり、槍沢の恐ろしい雪崩の跡を歩いて、槍のピークへロープとアックスとアイスクリーパーでかじりついた時には、春なのか夏なのか、さっぱり分らなくなった。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにアックスでステップを切ると金のような氷が飛ぶ。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもこれからは、ロ−プとアックスとクリーパーものである。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自がアックスを持っていなくてはいけない。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏、真新しくて羞しくもあり、また、如何に勇気凛々としていたとは言え、アイスアックスをかついで大阪から汽車に乗りこむ訳にも行かないので、新聞紙に包んで信州大町まで持って行った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年から大正十五年の六月まで、私のアイスアックスは大町の対山館に居候をしていた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な雪で、また大町――富山の大正十五年度の最初の旅行だったので、アイスアックスが大いに役に立った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってアイスアックスも大阪へ帰って来たが、何もすることがない。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々令夫人が石突きで石油の鑵をあけたり、立てつけの悪い襖をアックスを用いてこじあけたりする。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ですべてを意味するアイスアックスも、大阪郊外の住宅地では、かくの如く虐待されている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、私はこのアイスアックスが非常に好きである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスアックスが、登山のシンボルであるような気がするからである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来私が、氷河の無い日本の山を、而も夏に限って登るのに（将来あるいは冬登るかもしれないが）大して必要でないばかりか、ある時には却って邪魔になるアイスアックスなんぞを買い込んだ理由は、実にこれなのであった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀剣の好きな人が、日本刀に大和魂を見るように、私はアイスアックスに登山者の魂を見出す。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、冬の夜長など、心しきりに山を思う時、取り出して愛撫する品としては、アイスアックス以外に何も無い。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山者としての私は道具オンチではないから、あまり色々な物を持っていはしないが、それにしても若干ある登山具を、一つ一つ考えて見るに、座敷に持ち込んで愛撫し得るものは、アイスアックス丈である。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にアブラハム氏の「コムプリート・マウンテニヤ」の第三章「登山具」を読むと、第一に登山靴、第二にロープ、次でアイスアックス、ルックサックなる順序に説明してある。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいよいよアイスアックスが出て来る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アックスは鋼鉄を冠った鍛鉄である。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に持ち、左手に持ち、あるいは柄の木理を研究し、アックスをカチカチ爪でたたいて盃の数を重ねて行けば、いつか四畳半の茶の間も見えなくなり、白皚々たる雪を踏んで大雪原に立つ気になったりする。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒風身にしみてくさめをし、気がついたらうたゝ寝をしていたなどというのでは困るが、とにかくアイスアックスは、我をして山を思わしめ、山を思えば私はアイスアックスを取り出して愛撫する。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むを得ず、アイスアックスで雪に穴を堀り、四人がかたまって一夜をあかすことにしたが、気温は下降する一方で、ついに暁近く二人は凍死した。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
