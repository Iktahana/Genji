    "definitions": [
      {
        "index": 1,
        "gloss": "person of mixed parentage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人の子供も黒人の子供も、すべての人間の子供は、本來フアンタスチツクな夢の宮殿に住んでゐるのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがって居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が水の上を雌に求め寄ってゆく、それは人間の子供が母親を見つけて甘え泣きに泣きながら駆け寄って行くときと少しも変ったことはない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の子供でも時々いじめ苦しめ、かついだりだましたりするのがかえって現実の世の中に生きて行く道を授けることにならないとも限らないのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐は人間の子どもにばけることができたからでありました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて狐は、うまく人間の子どもにばけて、しりきれぞうりを、ひたひたとひきずりながら、村へゆきました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この驚くべき技巧がもっともっと自由に応用され、観客が次第にそれに慣らされて、そうしてそれに固有な効果を十二分に感受することのできる日が来るとしたら、その日から人間の子孫にとっては全く新しい世界が生まれるであろう。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人の人間は立つことを普通に考えるが、乳児時代の這い廻る人間の子の速さを観察するとき、あれがあのまま二十年三十年這い廻り続けたら、どんなに素早っこく這い廻り、跳ねられることであろう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠来い簑着て来い行燈の油に火を持って来い……………………　仲間の子供たちが声を揃えて喚き出したので、お涌も井戸端から離れた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな入り江に来ると、人間の子供たちが、大ぜい集まっていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "コウノトリの子供たちに、人間の子供や、おとなの人の年が、どうしてわかるはずがありましょう。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがつて居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が何か發言するとき、いつもその仲間の子供たちが顏をしかめた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人間の子が鰈の子になるのは、なかなか易いことではない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠来い簑着て来い行燈の油に火を持つて来い……………………　仲間の子供たちが声を揃へて喚き出したので、お涌も井戸｜端から離れた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く澄んだ人間の子供の眼を。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手を、母さん狐はしばらく握っている間に、可愛いい人間の子供の手にしてしまいました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケツネの子でも人間の子みたいな泣き方をするとは、おどろいた。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ――学園の校長さんは地方の素封家出の文化人で、子供が多いところから一つ自分の手で思うような教育をしてみようと思い立ったのが始まりで、世間の子女たちも預る学校に発展さしたのですが、通って来る講師には著名の芸術家なども多く、男女共学なども行って一風変った学校でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし妖女といふものは、人間の子をすきだと思ふと、たちまち妖女の魔力がなくなつてしまふのでした。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしても人間の子供でない」　二人の少年は組んずほぐれつやっていたが、力が合っているのか何方も倒れない。",
              "citation": {
                "source": "庭の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、狡猾い猿だけは、こうして毎日何の仕事もなく、ごろごろと惰けてゐても、それでお腹も空かさないでゆかれるので、暢氣な顏をして、人間の子どもらの玩弄品になつて、いつもきやツきやツと騷いでゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何萬とも數へ切れぬ數十種の海鳥共が群れてゐるのだが、殘念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何万とも数え切れぬ数十種の海鳥どもが群れているのだが、残念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の子供などはとても、自分のからだをこれだけ典雅に取り扱われようと思われない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の子供の子供らしさと、どことは明らかに名状し難いところに著しい類似がある。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがあいのこじゃねえか」そして目の前に相手をおいたとでも云うように叫び声を上げた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、自分が破滅に陥ったばあいのことを想像して驚くこともあった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、きっと、さかなとえびのあいのこにちがいない。",
              "citation": {
                "source": "かき",
                "author": "УСТРИЦЫ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
