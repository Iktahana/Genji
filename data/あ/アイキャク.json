[
  {
    "uuid": "40e8ed18-4d04-5878-a65b-a9f167980a7f",
    "entry": "相客",
    "reading": {
      "primary": "あいきゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fellow guest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相客は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相客が重要です。",
              "source": "幻辞"
            },
            {
              "text": "相客に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相客が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相客について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相客についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相客について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相客が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相客が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相客は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相客は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相客を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相客をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相客が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相客の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相客を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相客に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相客について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相客は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相客を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新屋といふ安宿に泊る、愛嬌のない、井戸もない宿だつた、相客はいかけやさん、料理人、前者はおしやべり、どこか抜けたところがある、後者は生来の世間師、いらないものがある。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙崎の宿はよかつた、設備（部屋も夜具も便所も湯殿も井戸も）待遇（その大半はおかみさんのサービス如何にある）共によかつた、木賃料は一昨夜の宿とおなじく三十銭だが、その倍の値打はある、相客三人、屋号は寺田屋。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝月残る木槿が咲いてゐるながれ　島へ渡しの、氷や菜葉や郵便や・氷屋ができて夾竹桃の赤や白や・落ちてきて米つく音の水がながれる・近道のいちはやく山萩の花・水は岩からお盆のそうめん冷やしてある　　行乞雑感（一）　八月十一日晴、暑かつたが気持は軽かつた、仙崎町行乞、そして滞在、新相客は伊佐で同宿の老遍路。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……相客は一人、若い鮮人で人蔘売、おとなしい人柄だつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "父がこのごろ天気続きの為めか、身体がだいぶよろしゅうございますので、お茶一つ差上げたいと申しますが、明日あたりお昼飯あがり傍々、いらして頂けないでございましょうか、お相客はどなたもございません。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相客には浅野長政、前田徳善院、細川越中守、金森法印、有馬法印、佐竹｜備後守、其他五六人の大名達を招いた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自然と相客の贔負贔負が有るから、右方贔負の人々をば右方へ揃え、左方贔負の人々を左方へ揃えて坐らせる仕方もあれば、これを左右｜錯綜させて坐らせる坐らせ方も有る訳で、其時其人其事情に因って主人の用意は一様に定った事では有るまいが、利家が此日人々を何様組合せて坐らせたかは分らない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し此日の相客の中で、佐竹の家は伊達の家と争い戦った事はあるが元来が親類合だから、伊達が蒲生に対する場合は無論備後守は伊達贔負の随一だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手染め澁染の衣は、これは慥に畸人の大槻如電と相客になつた時、流石の如電先生もその澁臭いのに悲鳴を擧げさせられたといふ。",
              "citation": {
                "source": "淡島寒月のこと",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に相客といふものは無かつた。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に取っては迷惑千万な宗教問題を得たり賢しと自分に引取って面白くもない自己吹聴を並べたてる回々教徒の女の誇張した恍惚感の説明や排他的な語気は、たとえ相客が表面無礼を感ぜぬように装って居るにしても主人側から見て英国人のサロンの空気をにがにがしくするように思った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐助はどこをどう歩いていたのか、鈴鹿峠を去って何日か経ったある夜、彦根の宿のある旅館の割部屋に泊った客の、どこやら寂しい横顔を、鈍い行燈の灯に透かせば、かくしもならぬアバタ面、後からはいって来た相客がつくづくと眺めて、「猿飛どのではござらぬか」　と、声を掛けた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅籠、旅籠で割部屋を所望致せしは幸い相客の中に首なき男もがなとの念願から」　と、無敵は語り終わって「――貴公はさぞお嗤いであろう」　打ちしおれていた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何故か絶対的に相客のあることを拒んだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他の旅客を相客に持つことを絶対に拒絶した。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィスのまんなかで、急行馬車に、ほかの八人の相客といっしょにつめこまれていました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か相客を呼んで下さらんか」「何分にもこの通りの偏土でござりまして……」と、太守は答えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は他に相客がなかったので、主婦はいよいよ彼を丁寧に取扱った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "相客は原口安斎という詩人だけで、霽波が社主に代って主人役をするというのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが――　そうして、まだ十分もしないうちに、列車が品川の駅へとまると、クルミさんのボックスへ、一人の相客が割りこんで来た。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は自分の乗った船はいつでも相客もろともに転覆して沈んで底知れぬ泥土の中に深々ともぐり込んで行く事を知った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼むぜ」「ようがす」　二人は連れ立って、そこらの小料理屋へあがると、時刻はもう午を過ぎているので、狭い二階には相客もなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をなされます、こんな名器を……」　席に居残つて、何かと世間話に興じてゐた二人の相客は、びつくりして主人の顔を見つめました。",
              "citation": {
                "source": "利休と遠州",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、先日室町一条の鉄斎翁の画室で和尚はある相客に逢つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "相客は大阪辺のある富豪らしかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして富尾木氏の側に坐つた相客の方へ首を捻ぢ向けた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "相客といふのは、島華水、岡本橘仙、湯浅半月……といつたやうな、検校とは古馴染で、これまで幾度か平家琵琶を聞いて、無事に生存へてゐる程健康な人達だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓連が一頻り雀のやうにぺちやくつて、さつと引き揚げて往くと、後に残つた一人の相客は溜息を吐きながら言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "相客が余所行きの上品な言葉で風流話に無中になつてゐる間に、良寛はひとり猿公のやうなきよとんとした顔をして、指先きで頻りと鼻糞をほじくつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
