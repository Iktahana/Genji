[
  {
    "uuid": "2c4a32a3-78cb-5aad-bd59-4230277ce528",
    "entry": "油揚げ",
    "reading": {
      "primary": "あぶらあげ",
      "alternatives": [
        "あぶらげ"
      ],
      "is_heteronym": false
    },
    "grammar": {
