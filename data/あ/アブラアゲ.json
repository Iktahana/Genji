        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油揚げについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油揚げは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油揚げの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油揚げについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "油揚げは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油揚げの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油揚げに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油揚げが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油揚げを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油揚げの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油揚げが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油揚げが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油揚げについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油揚げは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油揚げは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油揚げは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油揚げについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "油揚げの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油揚げの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油揚げの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "太宰に食わせる油揚げはよそを捜して見つけたらいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、むかし、とっこべとら子は大きな川の岸に住んでいて、夜、網打ちに行った人から魚を盗ったり、買物をして町から遅く帰る人から油揚げを取りかえしたり、実に始末におえないものだったそうです。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰に食はせる油揚げはよそを搜して見つけたらいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新三郎はそれで幾等かお滝の病気が好くなるだろうと思っていたが、その一方で新一は油揚げを三枚買い、それに鼠取を入れて卵塔場の中へ持って往った。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、とんびに油揚げをさらわれてしまったかもしれませんぜ」　けれども、にらんだ者はわが右門です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "当節はとびだっても、こうぞうさなく油揚げをさらえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶に油揚げをさらはれた後のやうに、皆ポカーンとしてしまつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは豆腐と油揚げと乾鮭とで日を送った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな傘を立てただけの店で、油揚げのようなものを売っている女。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち狐つきが油揚げを急に好きになったり、大食をしたりするが、大食の方はそういう狂気の性質もある、だが油揚げの方は正に病気前の見聞が暗示となったものである。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁寧にかきまわしたのでは粘りが出て、油揚げの特徴のカラリとした出来にならない。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤飯に油揚げを、大工さんのお上さんは白粉くさい手にいっぱいこんなものを持って来てくれた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒いコンニャクの煮〆と、油揚げ、里芋、雑魚の煮つけ、これだけが祭の御馳走である。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘辛い油揚げの中にいっぱいつまった飯、じとじと汁がたれそうなかんぴょうの帯。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り昆布に油揚げの煮たのに麩のすまし汁。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐屋では大鍋いっぱい油をはって油揚げを揚げている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "めじまぐろの焼いたのに、油揚げと大根の汁と、葱蒟蒻の味噌なます、谷村さんはどれも好物ではありませんでしたが、太つちよの下女の持つて来るお櫃が待ち切れないで、そつと、味噌なますなんぞ摘んでみたりしました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本なくて善人の神様を油揚げか何かで欺しておき、絵はほしいがどこで何を買ったらよいのか、不案内という愛好家や、少しも油絵などほしいとも思わない金持ちの応接室へ無理矢理に捻じ込むものがあったり、作品を持ち逃げしたりする高砂屋もあるらしい。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてね、おかずは何だと思うの、毎日毎日油揚げの煮附け」　いまは外国へいった友達がはなした。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この弁当の菜が、油揚げ、湯葉と、きまっていた。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学五年間、この油揚げと、湯葉で一貫した。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学へ行くやうになると、毎日、油揚げの菜ばかりなので、「湯葉が、たべたいな」　と、いふと、母が、湯葉の屑を、風呂敷に一杯買つてきてくれた。",
              "citation": {
                "source": "貧乏一期、二期、三期",
                "author": "わが落魄の記",
                "note": "青空文庫"
              }
            },
            {
              "text": "油揚げ百五十枚が、下谷御成道建具屋金八。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "露店で食う豚の肉の油揚げは、既に西洋趣味を脱却して、しかも従来の天麩羅と牴触する事なく、更に別種の新しきものになり得ているからだ。",
              "citation": {
                "source": "銀座",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこの頃はご領主様の花村甚五衛門様がこのご領地へ帰られたからでもありましょうが、町人どもまでが鼻息荒く、人間は万物の長であるの、狐は悪獣の王であるのと、私達のことを悪く云い、油揚げ一枚供えようともしない、何んと憎いではござりませぬか」「ほんとに憎らしゅうございますことね。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分でゆくと、もう一つ、足留稲荷の向うを張って、早｜発ち稲荷てえのをまつって、せいぜい油揚げをお供えしなくっちゃアなりますめえぜ」　本陣の帳場格子のなかで、番頭たちが、こんなことをいいあっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまとおきさきとがまずめして、つぎに大臣たちがおしょうばん、そしてその夜のおあまりは、翌朝おきさきが油揚げ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらお前、あぶらあげ、ね。",
              "citation": {
                "source": "ねずみさんの失敗",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶらあげを焼いてる匂ひがプンプンしてんだよ。",
              "citation": {
                "source": "ねずみさんの失敗",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く参りませんとあぶらあげの分け前を戴かれなくなりますから、早く教へて下さいませんか。",
              "citation": {
                "source": "ねずみさんの失敗",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
