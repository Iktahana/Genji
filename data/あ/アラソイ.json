[
  {
    "uuid": "0a9b8850-68a5-5a92-a971-381d30a73e3f",
    "entry": "争い",
    "reading": {
      "primary": "あらそい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日争いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "争いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は争いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には争いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "争いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは争いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "争いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は争いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では争いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "争いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に争いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では争いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "争いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると争いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "争いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では争いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に争いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により争いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "争いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に争いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は言い争いは好まない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先を争いて馬車に乗らんとあせる人狂気のごとく、見る間に満員となりて馳せ出せば友にはぐれて取り残さるゝ人も多し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然と人とは互に冥通する何者かを失うことなしに或は争い或は親しんだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　震源　従来でもちょっとした地震のある度にいわゆる震源争いの問題が日刊新聞紙上を賑わすを常とした。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震源とは何を意味するか、また現在震源を推定する方法が如何なるものであるかというような事を多少でも心得ている人にとっては、新聞紙のいわゆる震源争いなるものが如何に無意味なものであるかを了解する事が出来るはずである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の座長の演説の中に物理学者の二つの流派、すなわち実験派と理論派との各自の偏見から来る無用の争いを誡めた一節は、そのまま現代にもあてはまるべきものである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　お絹と棚倉の争い。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が傾く鬱積を、こういう夫婦争いで両親は晴らしているのだ、と息子はつくづく味気なく感じた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――他国と他国との秘密な取引所、個々の個人の制限のない政治的な争い、投機的な現在支那の商業上の競争、周期的経済恐慌。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してもっとまじめで真剣なだけにいちばん罪の深い人間的な宣伝の場合と思われるのは、避くべからざる覊絆によって結ばれた集団の内部で、暗黙のうちに行なわれる、朋党の争いである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば昔あったような姑と嫁の争いである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、現在、この縄張りの広狭争いのような喧嘩が起ろうとしているのである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の極へおとされてゆく私の気持は、然し、本能的な逆の力と争いはじめました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、「彼奴高慢な顔をして、出来も仕無い癖にエラがって居る、一つ苦しめて遣れ」というような事ですから、今思い出すとおかしくてならんような争い方を仕たものです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い争うような声が聞えたので眼を覚まし、窓の方を見ると、佐吉さんは長い梯子を屋根に立てかけ、その梯子の下でお母さんと美しい言い争いをして居たのでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と若い子は眉をひそめてまじめに言い、それから私にはよくわからない「花柳隠語」とでもいうような妙な言葉をつかって、三人の紋附の芸者が大いに言い争いをはじめた。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、女どもの言い争いは、いつまでもごたごた続いている。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は優しく、にぎやかな、いい人ですが、叔父さんの事になると、時々、父と言い争いを致します。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩見先生から、叮嚀なお手紙をもらってから、二三日後に父と母は、とうとう、ひどい言い争いを致しました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、顎をしゃくって私と弟に、あっちへ行けというような合図をなさいましたので、私は弟をうながして、勉強室へ引き上げましたが、茶の間のほうからは、それから一時間も、言い争いの声が聞えました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく母と、ひどい言い争いになりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の間の言い争いを、私は勉強室で聞きながら、思うぞんぶんに泣きました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、茶の間の言い争いを聞きながら、つくづく自分をいけない娘だと思いました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶お友の語るところに依れば、お露は美人ならねどもその眼に人を動かす力あふれ、小柄なれども強健なる体格を具え、島の若者多くは心ひそかにこれを得んものと互に争いいたるを、一度大河に少女の心｜移や、皆大河のためにこれを祝して敢て嫉もの無かりしという。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶お友の語るところに依れば、お露は美人ならねどもその眼に人を動かす力あふれ、小柄なれども強健なる体格を具え、島の若者多くは心ひそかにこれを得んものと互に争いいたるを、一度大河に少女の心移や、皆大河のためにこれを祝して敢て嫉もの無かりしという。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはおとといから、めんどうなあらそいがおこって、ちょっと裁判にこまりましたので、あなたのお考えを、うかがいたいとおもいましたのです。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君を下からはねのけるときに、久助君の胸をついたが、どうも、じょうだん半分のあらそいの場合の力の入れかたとはちがっている。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口あらそいは勿論、相当はげしくつかみ合った証拠には、今その帰りだといって、おれの家へ自動車で乗りつけた時は、袖がひき千切れ、髪の毛は浅ましくばらばらだった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "町ののら犬たちも、このふたりが肉屋のまえにいるのを、もうあたりまえのように思って、けっしてあらそいもせず、さっさととおっていきます。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子で言いあらそいをしているうちに、輿がもう門口へ来て、お供の侍女が群をしていた。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
