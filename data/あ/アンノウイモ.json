        "examples": {
          "standard": [
            {
              "text": "私は毎日安納芋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安納芋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安納芋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安納芋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安納芋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安納芋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安納芋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安納芋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安納芋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安納芋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安納芋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安納芋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安納芋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安納芋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安納芋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安納芋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安納芋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安納芋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安納芋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安納芋は興味深い例である。",
              "source": "幻辞"
            }
          ],
