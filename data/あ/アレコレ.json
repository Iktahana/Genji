[
  {
    "uuid": "396051fc-79bc-5027-b685-ee12603d5007",
    "entry": "彼是",
    "reading": {
      "primary": "あれこれ",
      "alternatives": [
        "かれこれ",
        "ひし",
        "アレコレ"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "副詞",
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "this and that",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日彼是について考えている。",
              "source": "幻辞"
            },
            {
              "text": "彼是という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は彼是の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には彼是が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "彼是を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは彼是について学習した。",
              "source": "幻辞"
            },
            {
              "text": "彼是の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は彼是の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では彼是が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彼是という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に彼是という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では彼是についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "彼是を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彼是は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "彼是について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では彼是が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彼是は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により彼是の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "彼是は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に彼是は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "斯くいふは世人屡々芸術作品を以て、箒なら箒、手拭なら手拭といふ一定のテーマがあつて、それの種々なる解説（インタプリテイション）が彼是の作品だとなしがちだからである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が只、もはや自分の口に何が合ふかも分らなくなつてゐる程に、尚彼是と食はうとはしない方がよいのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "只其の家庭問題を、彼是云うて居る夫子其の人の家庭が、果して能く整うて居るのであろうか、平生円満な家庭にある人などは、却って家庭問題の何物たるかをも知らぬと云うような事実がありはせまいか、是れは少しく考うべき事であると思う。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二の悲劇が終つて彼是する中、大磯へ着くと女中が三｜人ばかり老人夫婦を出迎に出て居て、其一人が窓から渡した包を大事さうに受取つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私だって口惜いと思わないことはないけエど、あんな人達が彼是れ言うのも尤ですよ、貴姉……祖母さんね…」とお秀は口籠った、そしてじっとお富の顔を見た目は湿んでいた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「山路六｜里……彼是七｜里でございます。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持って来て匡衡は、定基が妻を迎えたと彼是同じ頃に矢張り妻を迎えたのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう彼是一週間になるが、まだ熱が下らない。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私にしたところで、教育界に身を置いて彼是三十年の間、自分の耳の聾だつたのかも知れないが、今迄つひぞ悪い噂一つ立てられた事がない積りです。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐにも草鞋を買はして、と思つたけれども、彼是晩方に成つたから、宿の主人を強ゐて、途中まで案内者を着けさせることにして、其の日の晩飯は済せました。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "權藏は最早彼是六十です。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前の薬を三十分もかかって彼是と調合するのだね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で彼是その詩風に就ても流通するものがある。",
              "citation": {
                "source": "「白秋詩集」第一巻解題",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "未決監を出てからもう彼是一と月、その間、日となく夜となく緊張し切つた俺の神経はまるで螽斯のやうに間断もなく顫へ続けた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と氣のついた時は、此｜曠野に踏込んでから、もう彼是十哩も歩いてゐた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯山告ぐるに、彼是間の通信者に、最も必用なるを答う。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是空しく時間を送つた爲に、日の暮れない内に二回牽く積であつたのが、一回牽出さない内に暮れかゝつて終つた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう彼是二十日間は泊つてゐるだらう、彼はどうしてホテルに自分が泊らせられてゐるか理由をみいだすのに困つたが、係官はその理由をはつきりと知つてゐた、即ち『下駄は携帯すべからず履いて歩るくべきものなり』といふことであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、河野が放蕩を始めたからと云って、それを彼是云おうとは思わない。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其歐人又其子孫たる米人が今度の唯一の例を引いて彼是れいはゞ是れ百歩を以て五十歩を責る者だ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ、Ｈ氏だけは「彼是言ふべきものぢやない。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはお邸を下つた当座一度会ひに行つたのを、たつたこなひだのやうに思つてゐたけれど、もう彼是四月から上になる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう彼是八時ぐらゐでございませうね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居を出たのは彼是れ五つ（午後八時）過ぎで、贅沢な人は茶屋で夜食を食って帰るものもありますが、大抵は浅草の広小路辺まで出て来て、そこらで何か食って帰ることになっている。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都つて言ふところはお金をたんまり持つて旅人として遊びに來るには好い所だが、住むに好い所ぢあないね、やつぱり東京の方がどんな生活でも出來るし、長く住んだせゐか氣樂だよ」京都へ住むやうになつてから、彼是もう半歳になる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是百人近くはあつたらう、尤も野次馬の一群も立交つて居たが、口々に歌つて居るのが乃ち斯く申す新田耕助先生新作の校友歌であつたのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是十何年も前の事ですが、私共がまだ師範學校で勉強して居た時分、其の頃で早や四十五圓も取つて居た小原銀太郎と云ふ有名な助教諭先生の監督で、小學校教授細目を編んだ事がありますが、其時のと今のと比較して見るに、イヤ實にお話にならぬ、冷汗です。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是十二時近くだつたでせうが、線香を忘れて居たのに氣が附きまして、買ひに出掛けました。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と謂ツただけで、別に引留めようともせぬので、彼は聊か心を安んじたらしく、曇つて日の見えぬ空を一寸｜背身になツて見乍ら、『もう彼是十二時にも近いし、それに今朝｜親父が然言つてましたから、先刻話した校長の所へ、これから※つて見ようかと思ふんです。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫に死なれてから、一人世帶を持つて居て、釧路は裁縫料の高い所であれば、毎月｜若干宛の貯蓄もして居たのを、此家の主婦が人手が足らぬといふので、強ての頼みを拒み難く、手傳に來てからモウ彼是半年になると云つた樣な話で、「普通の女中ぢやない。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
