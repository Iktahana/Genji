              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから間もなく新しい女が店に坐るようになった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔で云えば新しい女とかいうようにさ。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　つまり今の新しい女はそんな詩的な概念でなく、もっと実質的に入ったんだろう。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　昔の新しい女は勇気はあったが、垢抜けしていなかった。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、どうぞこちらへ」　入口へ出たお亀がうろうろしながら、新しい女客を奥へ招じ入れようとすると、案内を頼んだ女は少しためらっているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊都子は新しい女だ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ａの家の中には、これ迄そこに見慣れた女主人の持ち物と入れ代りに、もとＢの家に飾ってあった女の道具が残らずキチンとそれぞれの場所に、新しい女主人を待ち受けていたではないか。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい女が私の前に現われたのだ。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "使ってくれと新しい女給が「顔見せ」に来れば頭のてっぺんから足の先まで素早く一目の観察で、女の素姓や腕が見抜けるようになった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もっとも、近ごろの新しい女は堅苦しい女房よりも気楽な妾宅暮らしのほうを望んでいるそうだが……」　自動車は江東ホテルの玄関へ横に着いた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新春の祝賀には新しい女夫が打揃うて殿の館に參殿しようといふ次第だ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は新しい女御の参ることをお聞きになって、少年らしく興奮しておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢の石申の『星経』上に句陳は大帝の王妃なりとあれば新しい女どもが跋扈するももっとも、天さえ女主に支配さるる当世だと見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "また新しい女を得た喜悦はあるにしても、妻を他に奪はれた男の心の佗しさを感じた。",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大勢の新しい女を見た。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその新しい女が矢張平凡に自然に縛られて終つて行くのを見た。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想的にも、感覚的にも、開発された本当に新しい女性にしか、許されていないような、神々しい美しさがあった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その美しい夫人の裡に、如何なる男性にも劣らないような、鋭い理智と批判とを持った一個の新しい女性、如何なる男性とも、精神的に戦い得るような新しい強い女性を認めたのである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃｜雜誌「青鞜」は生れ、新しい女といふことが大分やかましくなつてまゐりました。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい女の先覚者の活躍時代は過ぎた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは新しい女や外交官の夫人なぞによくある着こなし方である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、時雄は惑溺せぬものならば、暫くこのままにしておいて好いと言って、そして縷々として霊の恋愛、肉の恋愛、恋愛と人生との関係、教育ある新しい女の当に守るべきことなどに就いて、切実にかつ真摯に教訓した。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂では兼家はこのごろまた新しい女に沈湎してゐるといふことであつたけれども、窕子に對しては、そんな形は少しも見せなかつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　真に独立の上にでなければ、新しい女の境地はないと言ふことを、痛切に新しい女達は考へなければならない。",
              "citation": {
                "source": "或新年の小説評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想的にも、感覚的にも、開発された本当に新しい女性にしか、許されてゐないやうな、神々しい美しさがあつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その美しい夫人の裡に、如何なる男性にも劣らないやうな、鋭い理智と批判とを持つた一個の新しい女性、如何なる男性とも、精神的に戦ひ得るやうな新しい強い女性を認めたのである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚と奴隷10・15（夕）　米国はヰスコンシンの上院議員ラ・フオレツト氏の愛嬢フオラ・ラ・フオレツト女史は彼国でも新しい女として名高い人で、先年脚本作家のヂヨルヂ・ミツドルトン氏と結婚したが、結婚後も良人の姓は名乗らないで、矢張｜里方の娘の儘で押通してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、ユタを中心として活動する沖縄の古い女は婦人問題で活動する新しい女より二千年も後れていると断言せざるを得ないのであります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥にある洋館が坪三千円かかったというのも、嘘ではないらしかったが、そこの壁にかかっている大礼服装の老人は、万事不自由のないように婦人の身のまわりを処理しておいて、今はまた新しい女に移って行ったのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
