[
  {
    "uuid": "ca72b2b9-ad08-50e1-84d3-c38b438bada5",
    "entry": "甘たるい",
    "reading": {
      "primary": "あまたるい",
      "alternatives": [
        "あまだるい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sentimental",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘たるいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘たるいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘たるいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘たるいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘たるいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘たるいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘たるいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘たるいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘たるいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘たるいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘たるいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘たるいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘たるいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘たるいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "主命というても今度は、お部屋向きの甘たるい事ばかりじゃ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気を許した女からばかり聞かれるような甘たるい親しさがこもっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜で倉地のあとに続いて船室への階子段を下る時始めて嗅ぎ覚えたウイスキーと葉巻とのまじり合ったような甘たるい一種の香いが、この時かすかに葉子の鼻をかすめたと思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勢はおそろしく顔を皺めて、甘たるい声で、「よう、放して頂戴と云えばねえ……声を立てますよ」「お立てなさいとも」　と云われて一段声を低めて、「あら引本田さんが引手なんぞ握ッて引ほほほ、いけません、ほほほ」「それはさぞ引お困りで御座いましょう引」「本統に放して頂戴よ」「何故？",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘たるい強い香が二人の間に立ちつゝあつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ文化は、一方で、トルストイやストリンドベリーのように、そういう甘たるい客間のしきたりに頑固に反撥した人々をもち、今日では、本質の異った社会連帯によって女の性を保護することが客間のエティケット以上の重要事であることを理解し、その実現に努力しているソヴェトのような実例が出現して来ている。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "終章のモラルも、ジェスチュアが目立って甘たるい。",
              "citation": {
                "source": "今日の作家と読者",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸、性格的に自分は甘たるい、つんとした、そして弱い生活を嫌う傾向を持って生れた。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の間に歓迎される種種の婦人雑誌などはいずれも女の感情に媚びて編輯された甘たるい分子が多く、男の世界では既に常識になっているほどの科学的及び社会的知識すら供給しない物です。",
              "citation": {
                "source": "婦人改造と高等教育",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘たるい強い香が二人の間に立ちつつあった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔には、人がよく白痴を装う行者や神憑りの言うことを聴きながら、その世迷い言やぼそぼそ声に何か格別な秘かな意味を推測するときに見せる、あの柔和な甘たるい殊勝げな色が浮かんでいる。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "噎せかえるような強い香水、甘たるい皮膚の香、柔らかそうな首筋、クリーム色のふっくりした胸、それ等は彼に何の刺戟も与えなかったが、ダイヤの魅力には時々自制の念を失うような、恐しい誘惑を感じた、春樹は宝石に眼を反らせて、ホールの中を踊り歩いているうちに、幾度も浮墨色の女と廻り合った。",
              "citation": {
                "source": "梟の眼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄さん」と甘たるい声を出して、「昨夜、失敗したから、――今夜はミミーを伴れて行くのよ」と云いながら、黒猫の頭を叩いて、「ミミーさえいりゃ、成功疑いなしだわ」　十三は両手でミミーの胴中を抱いて、高く差上げ、「しっかり頼むよ。",
              "citation": {
                "source": "黒猫十三",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生たちは、甘たるいくらい彼を可愛がって、呼ぶ時にはいつも名のほうを呼んで、あらゆる方法で彼のためを計ってやったし、同輩たちは彼の寵を獲ることに汲々としていたし、また往来では紳士淑女たちが彼を引きとめて、オランダ風の水夫帽からはみ出ている、薄い明色の前髪をつかみながら、こう言うのだった。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓に扮した四五人の人物が、クラリネットと甘たるい絃楽器とで、トリスタンの音楽の半音階的曲折を戯演しているのだった。",
              "citation": {
                "source": "餓えた人々（習作）",
                "author": "DIE HUNGERNDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏手に小さな庭があって、夏の間みんなは、たいてい一日中そこですごすことになっていた――近所の製糖所から、ほとんどたえ間なく、甘たるい匂いが流れて来たのだけれども。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『科学者と詩人』とは訳者の調子がわざわいしてやや甘たるいところが過重せられていると信じるが面白うございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃してしまった」　白い焔と甘たるい匂いが、彼にまざまざとよみがえって来た。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お京は、男の腕をさすり、甘たるい声で、ささやいた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
