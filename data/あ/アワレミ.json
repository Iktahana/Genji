        "examples": {
          "standard": [
            {
              "text": "私は毎日哀れみについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "哀れみという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は哀れみの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には哀れみが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "哀れみを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは哀れみについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "哀れみの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は哀れみの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では哀れみが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れみという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に哀れみという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では哀れみについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "哀れみを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると哀れみは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れみについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では哀れみが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀れみは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により哀れみの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "哀れみは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に哀れみは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　彼は、自分から癪に障るくらい哀れみを乞うような声を出してきいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはもちろん子を哀れみまた自分を哀れむ複雑な心理が伴なってはいるが、しかしともかくもそうした直接行動によって憤怒の緊張は緩和され、そうして自己を客観することのできるだけに余裕のある状態に移って行くのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは幾人もの男女が群盲のやうに手さぐりしながら彼れに近づくのに氣がつくと、何んとも云へぬ哀れみを覺えながらさう思つた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に謝罪ったり、哀れみを乞うたりすることも、彼女の性格としては、とても我慢のならないことであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明の月に血を吐くほととぎすの悲歎を曾て見知らぬ私は寧ろキヤベツ畑の雨に啼く郭公を楽しいものに哀れみ、昔ながらの古い前栽の繁みに飛ぶ蛍よりも客待の人力車のかげに仄かに蒼白いお尻のパツチを光らす東京の蛍をこの上なく今の心に親しむ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾はおそろしくて哀れみを乞うて泣いた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが多くのものの例に漏れず、始めるのは易しいがやめるのは難しいとやがて気づき、長年のあいだ薬の奴隷となりつづけて、友人や親類から、恐れと哀れみの入り交じった目で見られるのだった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知らない君を哀れみながら、私は私の時間を使用するために君の妄想の小屋から出てゆくそして路をゆく私は右足と左足とをかはりがはり単純に繰り返しつつ――。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえ一体あの娘をどこから連れて来た」「わたしが連れて来たんじゃないんです」と、金次は哀れみを乞うような悲しい眼をして、相手の顔をそっと見上げた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食が哀れみを求めたり、老人が愚痴をいうのと同様に、葉子にはけがらわしく思えていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピティー〔哀れみ、同情〕とペーソス〔悲哀〕とが大部分の作品の底に横わっている。",
              "citation": {
                "source": "ルヴエルの『夜鳥』",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに、魚は甕のなかからしきりに哀れみを乞うと、天師はまた言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "自他平等のみ仏の教えにいつわりなくば、何とぞお救いくださりませ」と、玉藻は哀れみを乞うように訴えた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　福沢氏はかう言つて、画家の杉浦氏を哀れみ、杉浦氏に連れ添つてゐる自分の妹を哀れむやうな眼つきをした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車輪にぶら下がるようにして一しょに走りながら、大声に哀れみを乞う傴僂の乞食。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いの自由を縛らないで、隣人として相哀れみ、平和な、睦じい暮らし方をする気です。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "救いを求める意思を持ち、また突然の哀れみの目的のためですので、鳴き方はおなじように悲痛なものでした。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子はいかにも哀れみを乞ふやうな樣子で、往來の男女を拜んでゐるが、人通りがちよツとでも絶えると、子は、「何かたべたい。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煩悩具足の衆生は、いづれにても生死をはなるる事かなはず、哀れみ給へ、哀れみ給へ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女學生は、最も神聖さを好む人間だと、美津江は哀れみの思ひを持つて眺める場合がある。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、支倉が云うように両刑事がペコ／＼頭を下げて、どうか自分達を助けると思って罪を背負って呉れと繰返し頼んだかどうか疑問だが、どうもこの様子では両刑事が、お前は男だろうとか宗教家だろうとか煽て上げ、自分達を助けると思って白状して呉れと哀れみを乞うように云ったかも知れない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつには、生来の己れを高く評価する性質が、不遇な人を哀れみこそはすれ、自分と同等もしくはそれ以上のものとして考える事を妨げたのである。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣｜狂痴者の迷夢哀れみたまへ。",
              "citation": {
                "source": "魚美人",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三年も行けば、（十三年と云へば長い月日だ）牢で病死をしないとも限ら無いこの哀れな罪人が、あゝ神よ、彼を哀れみ給へ。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいやな人間から犬に物を投げてやるようにして哀れみの目で見られて残り物をもらって生きるのはいちばんつらいからな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやないやなやつの門口に哀れみを乞うて親子三人立たねばならなくなるよ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今このご文は、この大菩薩が、悪業のわれらをあわれみて、救護の道をば説かしゃれた。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ある時は、お祭りの人ごみに立ちまじって、赤いゆもじの裾を染め、オモチャの笛をあわれみ詰まらせ、神木の肌を神さびさせ、仁王様の腕の古疵を疼き痛ませ、御神鏡の光を朧にした上に、伏しおがむ人々の睫毛までも白々としばたたかせて、昔ながらの迷信をいよいよ薄黒く、つまらなく曇らせる。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物に対してだってそれをあわれみいたましく思うことは勿論です。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つあわれみ、且つ可忌しがったのである。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
