        "examples": {
          "standard": [
            {
              "text": "毎日、間狂言は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは間狂言が重要です。",
              "source": "幻辞"
            },
            {
              "text": "間狂言に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では間狂言が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で間狂言について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から間狂言についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では間狂言について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では間狂言が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では間狂言が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に間狂言は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において間狂言は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に間狂言を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に間狂言をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で間狂言が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、間狂言の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は間狂言を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は間狂言に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で間狂言について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から間狂言は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは間狂言を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "上野辺のある舞台において、初番に間狂言、那須の語。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台では間狂言の高声が、見物の笑いとともに板に響いた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この効果を見るために僕は四十日間狂言をしていたんだ」　妾はその時は、あの人の言葉をうそともほんとうとも判断することができなかった。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "語と云い、口調と云い、間狂言を見るのと、大した変りはない。",
              "citation": {
                "source": "野呂松人形",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリヴォフ夫人に帰納されていった法水の超人的な解析も、この底知れない恐怖悲劇にとっては、たかが一場の間狂言にすぎなかったのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りには、チャイニイズ・グロオマン劇場で、オニイルの奇妙な幕間狂言という映画の封切に招待されました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りには、チャイニイズ・グロオマン劇場で、オニイルの｜奇妙な幕間狂言という映画の封切に招待されました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "石橋の方でも、間狂言の仙人の這入つて後、して・つれで文殊と獅子とが現れてよいはずだが、何時の間にか、獅子だけがはたらくことになつたのである。",
              "citation": {
                "source": "獅子舞と石橋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡ひ地よりも、寧、間狂言に牽かれて、獅子の出る形になつてゐる。",
              "citation": {
                "source": "獅子舞と石橋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
