        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日罨法について考えている。",
              "source": "幻辞"
            },
            {
              "text": "罨法という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は罨法の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には罨法が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "罨法を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは罨法について学習した。",
              "source": "幻辞"
            },
            {
              "text": "罨法の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は罨法の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では罨法が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "罨法という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に罨法という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では罨法についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "罨法を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると罨法は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "罨法について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では罨法が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に罨法は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により罨法の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "罨法は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に罨法は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "淡いふすぼりが、媼の手が榊を清水にひたして冷すうちに、ブライツッケルの冷罨法にも合えるごとく、やや青く、薄紫にあせるとともに、乳が銀の露に汗ばんで、濡色の睫毛が生きた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばあや、もう眼の罨法をする時間じゃなくって」「そうでございましたね。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身體が弱い爲めだから營養をよくすること、足の膝關節が痛かつたら罨法をするといふ事であつた。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は別に身體の元氣はかはらなかつたので、學校に通つて歸つて來ると一人で罨法をした。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の部屋に入ると、古びた青いビロードの椅子に腰をおろして、その膝をもんだり、痛さをこらへて少しでも折り曲げやうとしたり、または罨法してそつとのばしたり等した。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室で罨法をするのに繃帶を解きはするけれど、その時分には見える方の目はやつぱりガーゼに閉ぢられた儘である。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その午後、冷吉が蒲團の上に坐つて罨法をしてゐると、齒のとれた受附の大木さんが上つて來て、「かういふものださうですが、何とか言つてるのが私にはよく解らないのでございますが、とにかく、一寸會つて戴きたいと申しますです。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度罨法をしてから、うと／＼してゐたと思ふ内に、もう午になつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦が罨法をさせて下りて行つた後は、もう次の十一時の罨法の時間が來るまでは、またかうしてたつた一人、暗く夜に埋もれてゐなければならないのであつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷吉が自分の室に歸つて蒲團に這入つたのはもう遲かつた、間もなく看護婦が最後の罨法をさせに上つて來たから、最早下ではみんな寢てゐるのであつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "醫者の罨法も役に立たず、修驗者のやつてゐる祈祷も後には徒らに病人を焦立たせるのみとなつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛みだけでも何うかしたいと思つて、せつせと罨法を手傳つて取替へてやつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、陰嚢もその影響を受けて、起ち居にもだんだん不自由を感じて来る、医師は罨法剤と睾丸帯とを与えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お利代が寝ずに看護してくれて、腹を擦つたり、温めたタヲルで罨法を施つたりした。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お利代が寢ずに看護してくれて、腹を擦つたり、温めたタオルで罨法を施つたりした。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もつと罨法なさい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女と並んで六人の女の子が坐り、彼女等はみな各々が小さな罨法鍋を前にしてゐた。",
              "citation": {
                "source": "外に出た友",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその足ですぐ受付により、硼酸水と罨法鍋とを交付してもらって帰った。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一日に三回、二十分ないし三十分くらいずつの長さで眼を罨法した。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "医局から貰って来た硼酸水を小さな罨法鍋に移し、火をかけてぬるま湯にすると、それをガーゼに浸して眼球の上に載せて置くのである。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするのかと、好奇心を動かせながら眺めていると私が今使っているのと同じ罨法鍋がその蓙の上に六箇、片側に三つずつ二列に並べられるのであった。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう盲目の近づいた六人の少女が向かい合って鍋を前にして坐り、じっとうつむいたまま罨法を始めた。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の短い私も、ことが眼のことになるとそう短気を起こしていられなかったので、毎日根気良く罨法を続けた。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは吸入器を眼にかけて洗眼と罨法を同時に行なうのである。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど居合はせた同室の者にガーゼを温めて貰ひ、それで手足を覆つて更に繃帯でぐるぐる巻に罨法をほどこしたが、翌朝になつて見るとも早や顔面一ぱいにその紅斑は広がつてゐた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　そのあとで、机竜之助は、丹前を肩から引っかけて、両手をその襟から出し、小机の前に向って、静かに罨法を施しておりますと、「御免下さいまし……」　怖る怖る隔ての襖を開いたものがあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "振向いたとて見えもしませんから――「御免下さいまし、お邪魔をしても、さしつかえございますまいか」「お入りなさい」と罨法を施しながら、竜之助が答えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、いよいよ冷然たるもので、竜之助は冷罨法をつづけながら、「これ、若い衆……」「えッ」　男妾が、そのつめたい呼び声にヒヤリとします。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷罨法を施している竜之助は、二度とはそれに答えようとせず、男妾のみが、無暗にふるえ出してせきこみ、「私に代って、あなた様が、あの婦人を斬っておしまいになる、殺して下さる、それは本当ですか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
