      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sitting calmly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安座について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安座という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安座の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安座が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安座を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安座について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安座の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安座の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安座が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安座という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安座という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安座についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安座を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安座は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安座について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安座が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安座は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安座の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安座は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安座は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "柱鳴り瓦飛び壁落つる危急の場にのぞみて二人一室に安座せんとは。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老年になってからは、君前で頭巾をかむったまま安座することを免されていた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれで何も手落ちはないと思った五助は「松野様、お頼み申します」と言って、安座して肌をくつろげた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤の妻は安座をかいて長い火箸を右手に握っていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは馬力の上に安座をかいて瓶から口うつしにビールを煽りながら濁歌をこだまにひびかせて行った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは火の気のない囲炉裡の前に、草鞋ばきで頭を垂れたまま安座をかいた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板よりも固い畳の上には所々に獣の皮が敷きつめられていて、障子に近い大きな白熊の毛皮の上の盛上るような座蒲団の上に、はったんの褞袍を着こんだ場主が、大火鉢に手をかざして安座をかいていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう、思ひつくと、彼は、膝の上の夕刊を投げ棄てゝ、安座からむつくりと立ちあがつた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……　一刻前彼はそんな愚考に割合に強く焦かれて、たしかたつたそれだけの原因で、寝転むでゐた状態を安座に戻したらしかつた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は日当りの好い縁端に安座をかいて、「口まがり」をおさへてゐる。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る楼へ遊びに行ったら、正太夫という人が度々遊びに来る、今晩も来ていますというゆえ、その正太夫という人を是非見せてくれと頼んで、廊下鳶をして障子の隙から窃と覗いて見たら、デクデク肥った男が三枚も蒲団を重ねて木魚然と安座をかいて納まり返っていたと笑っていた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、上人の手によって得度して、了海と法名を呼ばれ、ひたすら仏道修行に肝胆を砕いたが、道心勇猛のために、わずか半年に足らぬ修行に、行業は氷霜よりも皓く、朝には三密の行法を凝らし、夕には秘密念仏の安座を離れず、二｜行彬々として豁然智度の心萌し、天晴れの知識となりすました。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから極楽に生まれ、浄土へ行っても、自分独りが蓮華の台に安座して、迦陵頻伽の妙なる声をききつつ、百｜味の飲食に舌鼓を打って遊んでいるのでは決してありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "矜羯羅が柔和で立像、制※迦が岩へ「踏み下げ」て忿怒の相、不動の本体は安座であって、片手が剣、片手が縛縄、天地眼で、岩がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に安座まします人間大の黒い阿弥陀如来の像は、和尚の差し出した蝋燭の灯に、一層いかめしく照し出された。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを察しているから、お勢がこのような危い境に身を処きながら、それには少しも心附かず、私欲と淫欲とが爍して出来した、軽く、浮いた、汚わしい家内の調子に乗せられて、何心なく物を言っては高笑をする、その様子を見ると、手を束ねて安座していられなくなる。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰謀に対してどう云ふ手段を取らうと云ふ成案がないので、すぐに跡部の所へ往かずに書面を遣つたが、安座して考へても、思案が纏まらない。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "本町辺は薬種問屋の多いところなので、あたしは安座をかいて、薬草を刻んでいるのを見て知っていたからよくわかった。",
              "citation": {
                "source": "朝散太夫の末裔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が時たまとりだして、安座をかいて、奏管（琴爪）で琴につけた譜面の星を、ウロウロ探しあてて弾いていた。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで日に三度飯を食う時に、此処だぞ此処で行儀を直さなければならぬ、姿勢を直すのは此処だぞ、疲労れた時には安座をかいて飯を食いたい、寝て物を食たいが此処だぞ、飯を食う時に急かず落付いて食べる。",
              "citation": {
                "source": "教育家の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ鼻は丸く安座をかいていて小さい目は好人物というより、滑稽味のある剥身に似た、これもけんそんな眼だ。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇の前にドッカリと安座を掻いて、両手を前に突いた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上述べたような、人類生活の内容として最も幸福な共通の標準として世界の連帯協同生活を建設することが出来れば、人は最も健全にして最も雄大な第一義生活――世界的生活の上に安座しているのです。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野は何時ものように、火の気のない炉のそばに、どっかりと安座をかいていた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等が萬葉を讀み芭蕉を讀むとき、法隆寺や藥師寺を訪ふとき、古土佐や光悦や宗達や光琳の繪畫を見るとき、又弄齋や富本や端唄を聽くとき、最後に日本の衣服を着て日本の疊の上に安座するとき、如何に我等自身のエレメントにゐることを感ずるであらう。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄味は真中にちゃんと安座していた。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西に別れて舞台に列び、仏を讃歌していうには、仏身安座一国土　　　　一切世界悉現身身相端厳無量億　　　　法界広大悉充満讃歌がおわると天人らは綵花を散らし始める。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる栄誉に対しては、今より一層精を励まし、神を凝らし、もってますます妖怪の蘊奥を究め、宇宙の玄門を開き、天地の大道を明らかにし、生死の迷雲を払い、広く世人をして歓天楽地の間に逍遥せしめ、永く国家をして金城鉄壁の上に安座せしむることを、かつ祈りかつ誓うところであります。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこのお二方の神が出雲の國のイザサの小濱に降りついて、長い劒を拔いて波の上に逆樣に刺し立てて、その劒のきつさきに安座をかいて大國主の命にお尋ねになるには、「天照らす大神、高木の神の仰せ言で問の使に來ました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光は、温かい部屋に安座している老公の白髯にまで反射していた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
