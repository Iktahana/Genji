[
  {
    "uuid": "b467b0fe-005c-59a4-aba2-cf2909298931",
    "entry": "安座",
    "reading": {
      "primary": "あんざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
