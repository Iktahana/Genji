        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "』　さう言つた窕子の言葉の中には、一月前の葵祭の棧敷に登子が同胞や姫達に雜つてくらべ馬を見てゐたのをそれと御門に目をつけられたのを悲しむといふやうな語氣がはつきりとあらはれてゐた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」光琳の羽織７・31（夕）　むかし尾形光琳と、三井家の主人八｜郎右衛門とが連立つて、加茂の葵祭を見に出掛けた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵祭祇園祭などは陳腐な故でもあらうがかへつて細しく書いた者を見ぬ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日坂本山王祭、明々後日葵祭拝見候て、南都へ一先罷越可申と存居候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は中宮の母君である、六条の御息所の見物車が左大臣家の人々のために押しこわされた時の葵祭りを思い出して夫人に語っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十五日（金曜）　葵祭り。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな葵祭が過ぎてから、殿は又かき絶えたように入らっしゃらなくなった。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐の花見や、加茂の葵祭、観学院の曲水の宴、さては仙院の五節舞などというありきたりな風流ごとにはどうしてもなじめない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江談抄」に、非人たる賀茂葵祭の放免が、綾羅錦繍を身に纏うて衣服の制に戻るとの非難に対し、彼らは非人なるが故に、国法の関するところにあらずとの説明が与えられている。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "賀茂の葵祭は前例によって去る五月の十五日を以て厳粛に行われた。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗研究会江馬務君の葵祭解説記するところによると、現時の行列には先頭に騎馬の警部が三人、次に素襖の侍が二人、次に看督長代が四人、次に騎馬の検非違使志代、これには調度掛、童、放免が各一人、火長代が二人、如木が四人、白丁が三人従っている。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今江馬君の説明を借りて、まず以て葵祭における放免の性質及び服装を紹介しておく。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上江馬氏の文）　葵祭に出る放免は検非違使庁の下部として、勅使の警固に立つ検非違使の官人に随行しているものである。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにそれが既に平安朝も末期に近い大江匡房の頃になっては、彼らは葵祭に列する際には綾羅錦繍を身に纏いて、為に識者の不審を招く程にもなっていた。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに「吉記」の著者が一々それをその日記に録上してあることを見れば、当時この服装が葵祭の呼び物であったと知られるのである。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の葵祭の行列は、おそらく元禄再興の例が継続しているものらしく、その放免の服装の如きも、「文永絵巻」に則ったものかと思われる。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐の花見や加茂の葵祭、勧学院の曲水の宴、仙院の五節舞、そういうありきたりな風流にはなじめない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……葵祭の日あたりにでも、お迎えの車をこちらに寄越せたら、……と思っています。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……葵祭の日にまた参るぞ！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……葵祭の日に迎えを寄越すぞ！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "文麻呂　葵祭の日です。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵祭の日には、大納言のお迎えの車が来て、あなたを都へ連れて行ってしまうのです。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの葵祭だってのに、こんな碌でもない試験勉強なんて馬鹿馬鹿しいにも程があらあ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いくらなんでも葵祭の翌日に試験をするなんて、あんまり非常識すぎるよ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今年の葵祭はおじゃんだ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女８　あれも確か去年の葵祭の時だったんじゃございません？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや、これは私が、この年に一度の葵祭の吉日を選んで、皆さんを喜ばせて上げようと思って、一月も前から考えていたことなのですよ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "地に落ちし葵踏み行く祭かな　　　　子規　これは加茂の葵祭を咏じたもので、葵祭にはさまざまのものに葵を掛けるのであるが、その葵が地に落ちている、それを人が踏んで行くというのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵祭を描くにもいろいろの事があるであろうが、その葵が地上に落ちていてそれを人が踏むという一事実を捕え来ったところが、この句の清新な味のある所以である。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
