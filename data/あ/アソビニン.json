          ],
          "literary": [
            {
              "text": "ややあって一人の遊び人とすれちがう。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の遊び人から掏り盗った紙入れを取り出し、中味を抜いて空の紙入れを捨てんとして、フッと思い出して立ち止った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几に腰を下ろして休んで居ると、其処へ一人の遊び人風の男がやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人は一杯機嫌で茶を持って来たお絹の手をグイと掴んで引き寄せ様とする。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人が「冗談だよ」と嫌な笑。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って遊び人のすぐ傍へ腰を下した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が浪人の処へ茶を持って来ると、酔っ払った遊び人は横あいからお絹の腕を掴みに行って再び振り放された。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人はいい気になって後を追って行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の中からお絹が「御冗談ばっかし」とか何とか遊び人を振り切って出て来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から尚もしつこく遊び人が追い廻して出て来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人は「ナニッ」と遊び人の胸倉をとる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人の懐から半分覗いて居る浪人の紙入れの大写。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニをするんだと抵抗する遊び人の懐から紙入れを取り出した浪人が、　「憎い奴！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げられた遊び人泡食って、Ｔ「ナッナッ何かの間違いですよ」　と言いわけするのも聞かず、さんざん叩きのめす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ廻る遊び人と浪人の三枚目がかった立廻りがあって、浪人は結局フラフラになった遊び人の首筋掴んで引きずって行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その群集の一番最後の遊び人風の男が二人、歩き乍ら話し合う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝表　遊び人乙、クルッと裸になった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝表では　裸になった遊び人の乙が、済まんなァと着物を着て、甲が裸になった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくり坊主の桃川如燕が張り扇で元亀天正の武将の勇姿をたたき出している間に、手ぬぐい浴衣に三尺帯の遊び人が肱枕で寝そべって、小さな桶形の容器の中から鮓をつまんでいたりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に遊び人が多いのです。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び人か、と思はれる角刈で、その癖パナマ帽を差置いた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　遊び人の旦那は仰向に呻つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の着流しに総しぼりの帯、素足に革の草履――という身なりは、どこか遊び人風めいていたが、存外律義そうな顔立ちで、「腹が空いてるのンか」　と、きいた声は、女のように優しかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜遅くベイカー街に戻ってきた友人は、唇を切っているわ額には変色した瘤があるわで、おまけに全身の格好はスコットランド・ヤードのおたずねものがふさわしくらいの遊び人然としたものだった。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、遊び人にしちゃあ野暮に出来ているし、まあ、屋敷の大部屋にでも転がっていたような奴ですね」「折助か」と、半七はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女はよい辰という遊び人の娘で、去年まで新宿の芸妓をしていたんですとさ。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは遊び人で、土地でも相当に顔が売れていた男なんですが、五、六年前からよいよいになってしまって、この頃では草履をはいて、杖をついて、ようよう近所を歩くくらいのことしか出来なくなったので、世間ではよい辰といっているんです。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井は、かねてから京子の美しさに心をひかれていたが、妻があったときは、遊び人たる彼もそれを禁断の果だと思っていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その遊び人のような男が、『どうです、親方。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
