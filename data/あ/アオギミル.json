    "definitions": [
      {
        "index": 1,
        "gloss": "to look up (at)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だが、シッソン、ウイードあたりから、仰ぎ見るシャスタの偉大さは、アルプス式の山々に見ることの出来ない鮮明美がある、孤にして閑である、独にして秀で、単にして完き姿である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仰ぎ見る天空の頂は麓の土とどういう関係に在るのか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しうありて仰ぎ見るに、空なる月と水のかげと孰れを誠のかたちとも思はれず。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の上に寝て仰ぎ見るすべての人の顔が非常に高い所にあるように思われた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の子は遊びをやめて、私のほうに真正面向いて、私の顔を仰ぎ見る。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ見る大ぞら、晴に晴れて、黒澄み、星河霜をつつみて、遠く伊豆の岬角に垂れたり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にそういう所で仰ぎ見る空の色が以前よりも深く青く見えだしたような気がする。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言いさま整然として坐り直る、怒気満面に溢れて男性の意気｜熾に、また仰ぎ見ることが出来なかったのであろう、お雪は袖で顔を蔽うて俯伏になった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋上と云ひ、アラビヤ砂漠の中と云ひ、私は星を仰ぎ見る度に古代の人の心に立ち帰つて見るのであつた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "臙脂屋早く身退りし、丹下は其人を仰ぎ見る、其眼を圧するが如くに見て、「丹下、けしからぬぞ、若い若い。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ見るだに目が盲ひさうになる深いもの、高いもの、恐ろしいもの、やさしく、寂びしく、美しいもの、手を触れるだに勿体ない光であつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "告ぐ、基督は救ふべきものを救ひ、救ふべからざるものを救はざる事を、千言万句の祈祷は一たび基督を仰ぎ見るの徳に若かず、仰ぎ見るは心を以て仰ぎ見るべし、祈祷の教会をかしましうするは、尤も好ましからぬことなれ、我は凡ての教会の黙了せん時に、大活気の炎上すべきを信ず。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "かな物の臭ひと挾みの音とに父を思ひ出しながら、渠が今、縁ばなから仰ぎ見るものがある上で、例のちよきん、ちよきんをやつてゐると、堅い枝に出くわした時、自分も亦思はず顎を明けて、宙に齒をかみ合せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "或高い岩鼻をまはる時など、仰ぎ見ると、西日に當つて七色を映ずる虹の錦の樣なおほ瀧だ。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つく／″＼本尊の容態を仰ぎ見るに驚く可し。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヌンチヤタは我が僅に能く仰ぎ見るものゝ名にして、我手の屆くべきものゝ名にあらず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "よるべなき孤なりし生立より、羅馬にてアヌンチヤタと相識り、友なりけるベルナルドオを傷けて、拿破里に逃れ去りし慘劇まで、涙と共に語り出でしに、可憐なるマリアの掌を組合せて、我面を仰ぎ見るさま、我記憶の中に殘れるフラミニアが姿に髣髴たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此旅人の迫持の石柱を仰ぎ見るに及びて、我はそのベルナルドオなるを識りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの町の第一の高官であり、かの豚でさえ崇敬の念をもって彼を仰ぎ見るのである。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女老若、仰ぎ見る能はず、南無阿彌陀佛と回向す。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに、夏の日影はげしく照りては、眼もくらみて仰ぎ見ること能はざれども、紅葉かつ散る小春の日和のうらゝかなるまゝに、南の軒の下に横はりて脊をあぶらむは、如何に心ゆくことの限りなるらむ。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "』まだ比較的若い船頭は、船尾のところで徐かに綱を解いてゐたが、仰ぎ見るやうにして、『何しろもうお天道さまがあんなところにゐますからな。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日に川原に落つる湯瀧に肩を打たせながら見るとなく、仰ぎ見る山の上の雲の輝きは何と云つてももう夏である。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷大神宮の神前でも、彼は瑠璃子の顔を、仰ぎ見ることさえなし得なかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一雨さっと降り上った後の初夏の青磁色の空の新鮮さもさることながら、大空そのものの底の知られない深さと透明さとは、この頃ならでは仰ぎ見るべくもない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐み給へ、外科醫を仰ぎ見る怪我人の目付を、そのさま、暴風雨の下の天幕に似たり。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもこゝを通る時、電車の窓から見えるのは、中佐殿の脚下に見得をきつてゐる何とか曹長の顏だけだが、今夜はつく／″＼中佐殿の雄姿も仰ぎ見ることを得た。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかにとくに目をひくは、南半球においてのみあおぎみることのできる、南十字星である。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
