        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その物語に題は通えど、これは東の銭なしが、一年思いたつよしして、参宮を志し、霞とともに立出でて、いそじあまりを三河国、そのから衣、ささおりの、安弁当の鰯の名に、紫はありながら、杜若には似もつかぬ、三等の赤切符。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一等の白切符を上等と称し、三等の赤切符を下等と呼んだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお序に、袂と、帯の間を撫でまわしてみると、筥崎から佐賀までの赤切符の未改札が一枚と、小型の名刺に「早川ヨシ子」「時枝ヨシ子」と別々に印刷したのが十枚ばかりずつ白紙に包んだのが、帯の間から出て来た。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、出札口への行列にいつとなく入って兎に角に裾野駅までの赤切符を買った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は純赤切符（といっても小学卒業内外）階級の江戸ッ子と非江戸ッ子である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "職人の供給過剰　東京市中の第三階級、即ち赤切符等は現在どんな生活をしているか。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　人間は皆赤切符！",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで盛岡行の赤切符を買つて改札口へ出ると、『向側からお乗りなさい。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで盛岡行の赤切符を買つて改札口へ出ると、『向側からお乘りなさい。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又包みを抱いた霜焼けの手の中には、三等の赤切符が大事そうにしっかり握られていた。",
              "citation": {
                "source": "蜜柑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又包みを抱いた霜燒けの手の中には、三｜等の赤切符が大事さうにしつかり握られてゐた。",
              "citation": {
                "source": "蜜柑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又包みを抱いた霜焼けの手の中には、三等の赤切符が大事さうにしつかり握られてゐた。",
              "citation": {
                "source": "蜜柑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさんざん待ちあぐんだ後、漸く電車が来て、胸を躍らせながら、赤切符もかまわずに、二等車に乗り込んでみると、もう彼女の姿はどこにも見当りません。",
              "citation": {
                "source": "二等車に乗る男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "権力濫用時代のかかるモノポリーが、弊害の巣窟とならなかったらむしろ不思議で、巷間伝えられるような聞くに堪えない数々のスキャンダルや、五百万ポンドとかの赤切符の謎や、二百万ポンドに及ぶ保管用紙の行方や、それらのすべては真偽の程は別として、その原因は皆ここに胚胎しているのである。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青切符（二等）を買える金は持っていたけど（そのころ、汽車は一等、二等、三等とあったのだ）、乗りつけない二等に乗って目立ってはまずいから、赤切符（三等）で行った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
