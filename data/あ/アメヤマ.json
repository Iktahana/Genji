[
  {
    "uuid": "2c018322-605c-5351-b916-8e9a9bd49110",
    "entry": "天山",
    "reading": {
      "primary": "あめやま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "enormous thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天山について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天山という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天山の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天山が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天山を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天山について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天山の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天山の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天山が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天山という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天山という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天山についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天山を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天山は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天山について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天山が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天山は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天山の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天山は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天山は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "冬が近くて、天山はもうまっ白になり、桑の葉が黄いろに枯れてカサカサ落ちました頃、ある日のこと、童子が俄かに帰っておいでです。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに西辺を窺う匈奴の右賢王を天山に撃とうというのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らに先だって夏のうちに天山へと出撃した弐師将軍はいったん右賢王を破りながら、その帰途別の匈奴の大軍に囲まれて惨敗した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝法院の前を来るまでは見たのですのに、あれから、弁天山へ入るまでの間で、消えたも同じに思われました。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、あしたでも好かろう」　弁天山の五ツ（午後八時）の鐘を聞いて、二人は再びここを出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、帝釈、天帝に謁せんとカイラス天山に趣く、留守の天女ども、鬼王が化けたと知らず、帝釈帰ったと思うて至誠奉仕し、鬼王歓を尽くして地に還る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気のいい日で、お腹の空かない奴は、弁天山付近に集まって石蹴りなぞをして遊んでいる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和２・８「文芸倶楽部」）半七招介状　明治二十四年四月第二日曜日、若い新聞記者が浅草公園弁天山の惣菜（岡田）へ午飯を食いにはいった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁王門のわきの久米の平内から辨天山のあたりは、やはり昔ながら、木立が芽を出して、銀杏の木も火にも燒けずに青い葉をつけてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音の地内は、仁王門から右へ弁天山へ曲がる角に久米の平内の厳めしい石像がある（今日でもこれは人の知るところ）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四　水晶のお土産ある日、父さんは人に連れられて梵天山といふ方へ行きました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い躑躅の花なぞの咲いて居る山路を通りまして、その梵天山へ行つて見ますと、そこは水晶の出る山でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に金瓶大黒は娼妓も二、三人になり、しがなくなって止めたそうだが、浅草観世音仁王門わきの弁天山の弁天様の池を埋めたり、仲見世を造ったり、六区に大がかりな富士山の模型をつくったりした。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二村、天山の二カ村が表高百五十石に御座りまするが、内実は二百石に上りまする」「ほかに表高二百石の処は無いか」「ほかには寸地も……」「ウム。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二村、天山は良い鷹場じゃ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草公園の売茶の店は、仁王門のわきの、粂の平内の前に、弁天山へ寄って、昔の十二軒の名で、たった二軒しか残っていなかった。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時班超は竇固の部下に加はり天山の麓の蒲類海（今の巴爾庫爾）の戰ひに功名を建てた。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國の Stein 氏が天山南路で發掘した古文書は隨分あるが、その中に唐の代宗から徳宗時代にかけての古文書で、年代の明記されて居るものが都合七種ほどある。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "Wiesner 教授はマホメット教國の産紙と天山南路で發掘された支那紙とに對して綿密なる化學試驗、顯微鏡調査を行ひ、この二國の紙を比較して、大要次の如き斷案を下して居る。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも天山南路で發掘された支那紙――Wiesner 教授によれば樹皮を主要原料とせる――と同一の成分ではなかつたであらうと思はれる。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　Stein 氏が天山南路の探檢に着手して以來、ヨーロッパ諸國の探檢者は陸續この方面に出掛けた。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國からは Stein 氏が再び天山南路に出掛け（西暦一九〇六―一九〇八）敦煌で幾多の遺籍、文書を發見した。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫餘は今の農安長春の南北に據り、烏孫は今の天山の西部に住み、其間大約我が千里を距つ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお天山というがあって、五つの小さい山があったから、詩人は五岳とも呼んでいた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "南、島原半島の筑紫富士（温泉岳）と遥にあひたいし、小城と東松浦との郡界の上に聳え、有明海沿岸の平野を圧するものを天山――また、あめやまともいふ――となす。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "六天山塞　さて、戸倉老人をさらっていったヘリコプターはどこへ飛び去ったか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもまちがいなく六天山塞へもどって来たのである。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六天山塞とは、何であるか？",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六天山塞の指揮権を持っている頭目の四馬剣尺は重傷の戸倉老人と会見することになった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは、六天山塞の頭目四馬剣尺の手から猫女の手へ移った。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
