    "definitions": [
      {
        "index": 1,
        "gloss": "accidentally",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日誤ってについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "誤ってという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は誤っての意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には誤ってが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "誤ってを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは誤ってについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "誤っての使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は誤っての定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では誤ってが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "誤ってという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に誤ってという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では誤ってについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "誤ってを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると誤っては複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "誤ってについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では誤ってが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に誤っては重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により誤っての意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "誤っては様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に誤っては興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "したがってまた「技巧的」「主知的」「印象的」「絵画的」等、すべて彼の特色について指摘されてるところも、定評として正しく、決して誤っていないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ蕪村が、従来誤って単なる絵画的写生詩人と評され、浅薄に価値づけられた所以であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に杯盤の音、戸口に見送りの人声、はや出立たんと吸物の前にすわれば床の間の三宝に枳殻飾りし親の情先ず有難く、この枳殻誤って足にかけたれば取りかえてよと云う人の情もうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代青年に対するあなたの観察は勿論一部分に対するものとしては誤っては居ません。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の仕事や学説が九十九まで正鵠を得ていて残る一つが誤っているような場合に、その一つの誤りを自認する事は案外速やかでないものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて児童が誤った、また全然誤っていないにしても浅薄な解釈しか出来ないことになる。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし上記のような場合があればそれは理論の適用を誤っているか、そうでなければ問題の分析が不充分なためである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ省察の結果が誤っていて、そのために流言が実現されるような事があっても、少なくも文化的市民としての甚だしい恥辱を曝す事なくて済みはしないかと思われるのである。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば子供の誤って呑込んだおはじきが消化器系を通過する径路を示すのを見たが、これなどでも消化器というものの本質には少しも触れないで、ただ土管のつながりのようなものとしか思われないように出来ていた。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは一つ貰いましょうと云って、財布を取り出すために壷を一度棚に返そうとする時に、どうした拍子か誤ってその壷を取り落した。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に受けた印象は誤っていなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、藁一本にすがりつこうとしたのが誤っていたのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、幹太郎の疑問は誤っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめてこの時少年の面貌｜風采の全幅を目にして見ると、先刻からこの少年に対して自分の抱いていた感想は全く誤っていて、この少年もまた他の同じ位の年齢の児童と同様に真率で温和で少年らしい愛らしい無邪気な感情の所有者であり、そしてその上に聡明さのあることが感受された。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは誤っている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "質的に間違った仮定の上に量的には正しい考究をいくら積み上げても科学の進歩には反古紙しか貢献しないが、質的に新しいものの把握は量的に誤っていても科学の歩みに一大飛躍を与えるのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時代に上記のごときおとぎ文学や小説戯曲に読みふけっているかたわらで、昆虫の標本を集めたり植物※葉を作ったり、ビールびんで水素を発生させ「歌う炎」を作ろうとして誤って爆発させたり、幻燈器械や電池を作りそこなったりしていたのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、大小方円の見さかいもつかないほどに頭が悪いおかげで大胆な実験をし大胆な理論を公にしその結果として百の間違いの内に一つ二つの真を見つけ出して学界に何がしかの貢献をしまた誤って大家の名を博する事さえある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、誤ってジャーナリストの擒となった学者はそのつかまった日一日だけどうにかしてのがれさえすればそれでもう永久に逃げおおせることができるのは周知の事実である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は翌日誤って舟より落ち遂に水死せるなり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚に絵の具箱をのせる空所もなかったのでベンチにのせかけて持っているうちに、誤って取り落とすと隣に立っていた老人の足に当たった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は命を的にしなければ、うっかり誤ってでも人の足も踏めず、悪口も無論言われなかった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の血縁の一人は夜道で誤って突き当たった人と切り合って相手を殺し自分は切腹した。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "師や友に導かれて誤って曠野の道に迷っても怨はないはずではあるまいか。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の最中のある日に観測中に某君が誤って水中に落ち、そのために病気を起こした事もあった。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスは唯物史観に立脚したと称せられているけれども、もし私の理解が誤っていなかったならば、その唯物史観の背後には、力強い精神的要求が潜んでいたように見える。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに空想的理想主義者は、誤っていかなる境界におかれても、人間の精神的欲求はそれ自身において満たされうると考える傾きがある。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは誤っています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどちらが正当だか私には分らない、とにかくその時は全く恥じ入って、つい無意識にあやまってしまった訳である。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも最初のうちはあやまって堪忍されたのであるが、あまりにそれが度重なるので、ほかの芸人がすべて彼女と一座するのを嫌うようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
