        "examples": {
          "standard": [
            {
              "text": "私は毎日アラビアン・ナイトについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラビアン・ナイトの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラビアン・ナイトが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラビアン・ナイトについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラビアン・ナイトの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラビアン・ナイトが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラビアン・ナイトという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラビアン・ナイトについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラビアン・ナイトは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラビアン・ナイトが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラビアン・ナイトは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラビアン・ナイトの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラビアン・ナイトは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラビアン・ナイトは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一方ではゲーテの「ライネケ・フックス」や、それから、そのころようやく紹介されはじめたグリムやアンデルセンのおとぎ話や、「アラビアン・ナイト」や「ロビンソン・クルーソー」などの物語を、あるいは当時の少年雑誌「少国民」や「日本の少年」の翻訳で読み、あるいは英語の教科書中に採録された原文で読んだりした。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英文の印刷されたプログラムによって、その狂言がアラビアン・ナイトであることを知ったが、登場俳優はみなスマトラの原住民だそうで、なにを言っているのか僕らにはちっとも判らなかった。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかったかの」　筆者は何となくアラビアン・ナイトの中の人間になったような気持で田圃通りに筥崎へ向った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "祥子は、かわいそうな話と恐い話が好きで、アラビアン・ナイトの悪魔を壺へ封じ込める話など、幾度もくり返して聴きたがった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一　ハルンアルラシッド――『アラビアン・ナイト』（千一夜物語）の主人公。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、　スタンレーの「アフリカ探険記」、キャピテン・クックの「世界三週航実記」、「ロビンソン・クルーソー」、「不思議の国巡廻記」「アラビアン・ナイト」等が翻訳された。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、「竹取物語」、「西遊記」、「アラビアン・ナイト」、スチブンソンの「宝島」、アミーチスの「クオレ」、マロオの「家なき少女」、トウエンの「ハックルベリー・フィンの冒険」「トム・ソーヤの冒険」、「ロビンソン・クルーソー」、「不思議の国巡廻記」等。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて、このマタ・アリの生涯を語ることは、今日の太陽のごとき生色を帯び、現代そのもののような複雑性を暗示し、しかも、アラビアン・ナイトを思わせる絢爛たる回想であらねばならぬ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十三日　日　晴　Francis Edwards と云う本屋からＡに来たカタログ、「アラビアン・ナイト」等なかなかいい本があるのに、皆 10 pounds 以上、情けなし、僅かのキプリング、ビョルンソンを命じることにする。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何年か経つて、やや長じた少年が、はじめてアルハンブラ物語を読んだり、アラビアン・ナイトの挿絵本を手にしたりした時、彼の想像が著るしく、その柱廊の印象によつて補はれ強められたことは疑ひがない。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本といふのは、本文も二色刷り、それに色刷りの挿絵もふんだんにはいつた大型のアラビアン・ナイトだつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、不眠と興奮とで黄色くにごつた空気のなかへ、しらじらと朝の光が射しはじめた部屋で、少年は自分の大事なアラビアン・ナイトが、丁寧に畳まれた彼女のコオトやショールと入れ代りに、鹿子絞りの風呂敷に包まれるのを見た。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はその絵を見ながら（と云つても、彼の椅子は奥村さんの椅子とデスクの間に挟まれてゐて、いやでも目をそらすわけには行かなかつたのだが――）、またアラビアン・ナイトの中の或る場面を思ひ浮べてゐた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がはじめて小遣を蓄めて購つた高価な本は、絵入りの贅沢な『アラビアン・ナイト』だつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かほかの事業でしたら、セエラ初め学校の中の少女達は、どんなにお金が儲かるにしても、あまり気にとめずにすんだでしょうが、ダイヤモンドの鉱山だというので、『アラビアン・ナイト』を聞いた時のように、耳を聳てたのでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書もその一つなら、『資本論』もその一つであり、『戦争と平和』もその例に漏れ難く、近頃の人にとっては、『南総里見八犬伝』や『ドン・キホーテ』や、『アラビアン・ナイト』もそうかもしれない。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説は楽し",
                "note": "青空文庫"
              }
            },
            {
              "text": "『源氏物語』『アラビアン・ナイト』『南総里見八犬伝』『戦争と平和』『水滸伝』『大菩薩峠』と。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アラビアン・ナイトの大魔王の嫉妬のために、海中に封じ込められている美女のことを、佐々村さんは御存じだわねエ」「え」「私は丁度その女なの、夫と名のつく大魔王の、金力と権力と、智慧と腕力と、それよりもタチの悪い義理という呪縛にかかって、陽の目も見ることの出来ない囚われの身なんです」「？",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな馬鹿なことが――」　というと、「夫の四番目の妾が、忠義立てをして私の跡を蹤け、此隠れ家を突き留めてしまったのです、夫はアラビアン・ナイトの大魔王よりも、残酷で皮肉です。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアラビアン・ナイトの悪魔の嫉妬に譬えられ、オセロの嫉妬に比べられて、笑いと軽蔑と、そしてよき戒めとさえなったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "音盤の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アラビアン・ナイトでございます」　つや子は、左右にたらした短い編下げの頭をふるようにして、「お姉ちゃまア」と伸子を見あげた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書棚をちらと眺めて、私はビュウイックの「英國鳥禽史」の二卷が三段目の昔の場所にあることも、「ガリヴァの旅行記」と「アラビアン・ナイト」とがその直ぐ上段に並んでゐることも、分るやうな氣がした。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして事に触れ、物に触れては、味な話を持ち出して、兵馬をからかったり、もたれかかったり――兵馬にとっては、この女の物語が、アラビアン・ナイトであったり、デカメロンであったりする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏物語、アラビアン・ナイト、八犬伝、戦争と平和、大菩薩峠。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "オ父サンニハ約束ノ「アラビアン・ナイト」ガ「ケリー・ウォルシュ」ニアッタカラ持ッテ行クト云ッテ下サイ、コレハ大人ノ読ム「アラビアン・ナイト」デス。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供ノ読ム「アラビアン・ナイト」デハアリマセン。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど駄賃を貰わなけりゃあ合わん仕事だよ」「大人の読むアラビアン・ナイトって、子供のとまるきり違うんですか、お父さん」高夏の言葉におぼろげながら好奇心を感じたらしい弘は、さっきから父の手の蔭になった挿絵の方へ探るような眼を光らしていた。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――アラビアン・ナイトと云うものは全体大人の読む本なんだよ。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――アラビアン・ナイトを読んでいらっしゃいます」「お前、宿題を早くやっておしまい、遊んでいないで」「小父さんはまだ？",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
