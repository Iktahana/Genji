        "examples": {
          "standard": [
            {
              "text": "私は毎日飴色について考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴色という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴色の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴色が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴色を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴色について学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴色の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴色の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴色が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴色という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴色という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴色についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴色を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴色は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴色について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴色が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴色は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴色の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴色は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴色は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その列車の食堂は明るくて、その天井は白いロイドで貼つてあり、飴色の電燈は、カツカと明つて燈つてゐました。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路に沿うたとある森影から青い洋服を着て、ミレーの種蒔く男の着て居るやうな帽子をかぶつた若者が、一疋の飴色の小牛を迫うて出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い天鵞絨の頭巾をかぶったちひさな子が、毛布につつまれて窓の下の飴色の壁に上手にたてかけられ、まるで寢床に居るやうに、足をこっちにのばしてすやすやと睡ってゐます。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――前日、子の口の朝の汀に打ち群るゝ飴色の小蝦の下を、ちよろ／＼と走つた――真黒な蠑※に似て双ながら、こゝに其の丈十｜丈に余んぬる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路に沿うたとある森影から青い洋服を着て、ミレーの種まく男の着ているような帽子をかぶった若者が、一匹の飴色の小牛を追うて出て来た。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実のところ今朝から客足が思わしく無く持荷の半分も捌ける見当がつかず、いたずらに納屋で飴色の腹に段々鼠色の斑が浮いて出る沢山の鮎の姿を思い出すとうんざりした。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水飴色のうららかな春の日の中に両岸の桜は、貝殻細工のように、公園の両側に掻き付いて、漂白の白さで咲いている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間から細縁を上ると其処は六畳敷ばかりの板の間へ薄い藺呉座が延いてあって、女中や下男の、古い飴色の箱膳が並んで居る。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白ぼたん、という筆太な、お家流の様な字を細長く囲んだ四角な框を中心に、二つ三つ葉をあしらった牡丹の花を、派手に刷った西洋紙の小さな薄い包みが器用に、婆やの掌の上で開かれると、ぴかぴか、光る銀の延紙のなかの飴色の透きとおる下包の紙の上に、ぼてぼてした粉なお白粉が、多量に盛られてある。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてへ出て見ると日光は実に暖かくぽかぽか飴色に照ってゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "調絲の走る途だけ飴色につやが出た竹の車で糸を紡いで、彼は暗い行燈の灯をかきたてゝは眠い目を強ひて明けて夜業をした。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は、黄金色のお日さまの光が、とうもろこしの影法師を二千六百寸も遠くへ投げ出すころからさっぱりした空気をすぱすぱ吸って働き出し、夕方は、お日さまの光が木や草の緑を飴色にうきうきさせるまで歌ったり笑ったり叫んだりして仕事をしました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみんなが飴色の夕日にまっ青にすきとおって泣いているのを見て驚いてたずねました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、とのさまがえるは、だんだん色がさめて、飴色にすきとおって、そしてブルブルふるえて参りました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車蝦の小蝦は、飴色に重って萌葱の脚をぴんと跳ねる。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きの多い空の雲の隙間から飴色の春陽が、はだらはだらに射し下ろす。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の落葉を載せた清く浅い水が、飴色の川床の上を幽かな歌を歌つて流れて行つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子に水飴色の陽が射して、ぽつん／＼冬の蠅の障子紙に突当る音が聞えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高島田に笄が飴色に冴えているお京さん。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟窓からさし込む陽に飴色の油虫が二三びき光った。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンヂェル・フィッシュに似た黒い派手な竪縞のある魚と、さよりの樣な飴色の細い魚とが盛んに泳いでゐるのを見下してゐる中に、眠くなつて來た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、ひまさえあれば、白い石の上に淡飴色の蜂蜜を垂らして、それでひるがおの花を画いていた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンジェル・フィッシュに似た黒い派手な竪縞のある魚と、さよりのような飴色の細い魚とが盛んに泳いでいるのを見下している中に、眠くなって来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴色の半月低く崖下に懸れるを見れば、来し方、行末の事なぞ坐ろに思ひ出でられつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘鯛、いとより鯛、魴※の濡れて艶々したのに、青い魚が入交って、鱚も飴色が黄に目立つ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憶ひ出の中では飴色の光りが輝き、青空にくつきりとそびえた山々の青肌に翼を拡げた鶴のやうなかたちの雪の痕が点々と望まれる和やかな冬の日ばかりが続いてゐるが、案外にもこのあたりの朝は、早朝から達磨型の矢倉岳を吹き降す烈風が麓の部落に渦を巻く日が多く、滅多に絶好の凧上げ日和などは見出せなかつた。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ずっぱく立てこもった酒と煙草の余燻の中に、すき間もる光線が、透明に輝く飴色の板となって縦に薄暗さの中を区切っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側には飴色の陽が深くさしてゐた。",
              "citation": {
                "source": "熱海へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に照らされる年齢あめいろにいろどられた月光のふもとにことばをさしのべて空想の馬にさやぐものは、わきたつ無数のともしびをてらして　ひそみにかくれ、闇のゆらめく舟をおさへてふくらむ心の花をゆたかにこぼさせる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "あめいろをした甕の地に疣のような焼きの斑点が、幾十となくあった。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
