          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その時、国史専修の学士は、静に糸を取って、無心に繋合せて、灯を宙に釣したと思うと、袴の下へ手を入れて、片手で赤本をおさえてみたが、そのまま腰を掛けて、また読みはじめる、岩見重太郎武勇伝。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの鼻垂小僧の両親は、赤本漫画の有害なことを、知らなかつたのであらうか、充分に感じてゐたに違ひない、何故なら現在の我国の家庭に於ける児童の位置といふものを考へてみたらいゝ、家庭は子供達にとつては、ヱレン・ケイ女史のいふ、それは家庭があつても、無いと同様な『無家庭』の状態にをかれてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "此故に腥き血の臭失せて白粉の香鼻を突く太平の御代にては小説家即ち文学者の数次第々々に増加し、鯛は花は見ぬ里もあれど、鯡寄る北海の浜辺、薯蕷掘る九州の山奥に到るまで石版画と赤本は見ざるの地なしと鼻うごめかして文学の功徳無量広大なるを説く当世男殆んど門並なり。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば赤本の探偵小説は従来いくらも日本にだって流布していたからである。",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてマアセルは、好きなように安楽な姿態で赤本を読み出した。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいぶ赤本めいた話だけれど、知ってる人は知ってる事実である。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に娯楽雑誌という名目で卑猥な内容を中心とする赤本雑誌が横行した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、日本の民主化にいろいろの変調が加えられて、たとえば用紙割当委員会の権限が、ずるずると内閣に属す委員会に移され、文化材の合理的割当を口実に、官僚統制、赤本屋委員会に堕してしまうころから、吉田茂の明るい展望が記者団との会見で語られるようになった。",
              "citation": {
                "source": "「委員会」のうつりかわり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎の好んで読んだ小説は、赤本、菎蒻本、黄表紙の類であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "下せど下せど綱は底触れず、頭上の裂罅も一線とほそまり――なんていうのが、地下鉄売りの赤本にあるよ」　最後に、折竹は淋しそうに笑い、その日の会見はそれまでになった。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は為永春水の『絵入教訓近道』で、一は式亭蔵書印のある『赤本智恵鑒』である。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に挙げた『赤本智恵鑒』が如何なる文学史的地位を有するかは知らない。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤本は文学史家の一斉に軽視する所であり、単に童蒙の娯楽書に過ぎぬように思われて居るし、実際其に違いあるまい。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "※先生は祖父母に甘やかされて生長し、赤本を耽読して悉く之を誦じ、其他雑芸雑学に通じて衆愚に説法することを楽しむ一個の閑人であるが、胸に一物ある巧案という鍼医の画策によって文殊の再生と言い触らされ、其名も愛読書の猿蟹合戦に因んで猿蟹上人と改めて文殊菩薩直伝の智恵授所という看板を掲げることとなる。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで怠け者や博奕好きの息子を持て余す父親や、放蕩無頼の息子に苦しめられる母親、絶えず喧嘩口論する二人の手代の仲裁を依頼する商人、流行らぬ医者や貧に苦しむ坊主、大酒に身を持ち崩す儒者などに赤本を題材として適切な教訓を与える。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "新刊の『活文壇』は再三上野｜三宜亭に誌友懇談会を開き投書家を招待し木曜会の文士｜交※文芸の講演を試むる等甚｜勉むる処ありしが、書肆早くも月々の損失に驚き文学を疎じて赤本を迎へんとするに至つて『活文壇』は忽ち廃刊となりき。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶又｜木場貞は玩具店鴻麓堂の収入だけでは暮しが立たないので、俗に赤本屋と称して地方新聞連載の小説や講談筆記を刊行する鰯屋書店の編輯員になつたことも報告書に見えてゐた。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はうーん、むにゃむにゃと云いながら例の赤本を突き飛ばして、黒い腕を皮癬病みのようにぼりぼり掻く。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年になっても、何々情話式の、安価な赤本新派劇の序幕あるいは二幕目に、たとえば山崎長之輔扮するところの仕事師と河原市松扮するところの芸妓とが相合傘で雨の中を出て来る底の色もようの道具位にしかつかわれず栄えないことおびただしい。",
              "citation": {
                "source": "上野界隈",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の探偵小説は、いわゆるコナン・ドイル以前の偶然型、押しつけ型で、大した面白いものではないが、その時分、少年時代を過ごした私などは、一面幼稚なる文学少年であったにも拘わらず、探偵小説のもつ、スリルとサスペンスに惹かれて、お小遣を溜めては、根気よく赤本の探偵小説を読んだことである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "銭形平次以前",
                "note": "青空文庫"
              }
            },
            {
              "text": "曝書風強し赤本飛んで金平怒る書函序あり天地｜玄黄と曝しけり明治四十一年八月五日　日盛会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこでは興亜書房とか云って一方で赤本出しているのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「曝書風強し赤本飛んで金平怒る」などというような、えらい風ではない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんこれには赤本は含まれていないのである。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
