      {
        "index": 4,
        "gloss": "Red Guide (Michelin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
