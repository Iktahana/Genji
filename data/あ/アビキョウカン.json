        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿鼻叫喚について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この阿鼻叫喚は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が阿鼻叫喚について知っています。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は阿鼻叫喚の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では阿鼻叫喚が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から阿鼻叫喚を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも阿鼻叫喚が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では阿鼻叫喚が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも阿鼻叫喚は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも阿鼻叫喚は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で阿鼻叫喚は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に阿鼻叫喚について学びました。",
              "source": "幻辞"
            },
            {
              "text": "阿鼻叫喚の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する阿鼻叫喚の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では阿鼻叫喚の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "天空には星影一｜點、二｜點、又た三｜點、風死して浪黒く、船は秒一秒と、阿鼻叫喚の響を載せて、印度洋の海底に沈んで行くのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がいままで阿鼻叫喚で生きて来た所謂「人間」の世界に於いて、たった一つ、真理らしく思われたのは、それだけでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、硫黄の臭もせず、蒼い火も吹出さず、大釜に湯玉の散るのも聞えはしないが、こんな山には、ともすると地獄谷というのがあって、阿鼻叫喚が風の繞るごとくに響くと聞く……さては……少い女が先刻――（ここは地獄ですもの。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと気づかぬうちに潜り込んできたクソ虫が暴れだして以来の阿鼻叫喚、血と涙の今日に至る日々を振り返って、このオレがもっとも不幸だったのは「やられた」と観念した瞬間だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――）僕への打擲はまだしもそれがきぬに加へられるときは、阿鼻叫喚の凄じさがこの少女と四十女との間に、あらゆる秘術を以つて行はれたのである。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の可聴域の上限を突きやぶりそうな周波数で知子が絶叫し、あとはもう、どれがだれの声ともわからない阿鼻叫喚となった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はほかの非江戸ッ子……上は成金から下は乞食まで、あらゆる種類階級の人々と共に、一様に阿鼻叫喚の巷にさまようた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に阿鼻叫喚ともいうべき苦しみを凌いで、半分は夢中でどうにかこうにか場内へ押込まれて、やれ嬉しやと初めてほっと息をつくという始末。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした怖ろしい阿鼻叫喚のまん中へ飛び込んだ二人は、いくら物馴れていてもさすがに面喰らって、あとへも先へも行かれなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "疼痛｜烈しき時は右に向きても痛く左に向きても痛く仰向になりても痛く、まるで阿鼻叫喚の地獄もかくやと思はるるばかりの事に候。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがぼくと別れ、女ひとりになったリエが、この世の阿鼻叫喚に忽まちまきこまれ、影も姿も消えうせる恐ろしさにぼくは堪えられぬ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々はめりめりと唸りを立て、歪められ、倒され、人々はその家の下に生き埋めにせられ、辛うじて遁れ出たものも狂犬のように吠えまわり走りまわり、かくて一瞬の間に文明の楽園は阿鼻叫喚の巷と化してしまった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、打たれながらも、その沙門は、にやりと気味の悪い微笑を洩らしたまま、いよいよ高く女菩薩の画像を落花の風に飜して、「たとい今生では、いかなる栄華を極めようとも、天上皇帝の御教に悖るものは、一旦｜命終の時に及んで、たちまち阿鼻叫喚の地獄に堕ち、不断の業火に皮肉を焼かれて、尽未来まで吠え居ろうぞ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は道ばたに咲き出た松虫草の花やひるがおの花に明るい陽光の降り濺いでる静寂の中に彳んで、阿鼻叫喚の修羅の光景を実感して見ようとしたけれども、あまりにも平和な今の環境は全くそれを不可能にした。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚といふやうな「音響効果」は、空襲の惨状を写すに、是非ともなくてはならぬものかどうか。",
              "citation": {
                "source": "空襲ドラマ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚とは、正に、その夜のことだったろう。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚の声、器物の壊れる音――その中に嵐のように荒れ狂う銃声があった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチパチと木のもえさける音、ドカーン、ドカーンとひっきりなしに聞える炸裂音、そのたびに、蒼白い閃光が、パッと焔と煙をつらぬいて、阿鼻叫喚の地獄絵巻とはまったくこのことだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇佐美で身動きできなくなったが、網代でドッと押しこみ突きこみ、阿鼻叫喚、十分ちかくも停車して、ムリムタイにみんな乗りこんでしまったのは、網代の漁師のアンチャン連だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすればヤジウマの大半が終電事につめかけたわけで、罹災者の乗りこむ者も多いから、終電車の阿鼻叫喚が思いやられた次第であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "百蔵一人がエライわけではないけれど、百蔵一人のために大混乱を引起して、その大混乱が阿鼻叫喚の世界に変ろうとする時でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "混乱以上に阿鼻叫喚の焦熱地獄となりまさり火事の焔の熱気に堪えかね、空地へ耕地へ……耕地へ耕地へと、さながら怒濤の崩れる如く、百、二百、三百、四百！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の因果か太郎、元来、蛇が好きで、いつもニョロニョロ生きたのを楽屋へ携帯、一夜、どこかの寄席でこれが客席へ這い出したので、たちまちに女子供は阿鼻叫喚。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音寺山城が織田氏の軍に攻略された際、城中の婦女子の逃げ落ちた、阿鼻叫喚のさまを伝えているという。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚の声、一時に起る。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　阿鼻叫喚をどこ吹く風と聞き流して、群衆を馬蹄にかけ、やっと門前までのしあがってきた源三郎の一行――。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身からチューリップ色の汗を流してのたうちまわり、夜も昼も絶叫して、阿鼻叫喚のうちに悶死した。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夢の湖、楽しい湖へ……」　阿鼻叫喚のすごい苦悶の中で息をひきとるのではなくて、自分がえらんだ、魅力のある方法で、ひっそりと消えて行くのだと思うと、なんともいえないほど楽しくて気持が浮き浮きしてきた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
