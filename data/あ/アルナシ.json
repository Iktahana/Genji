        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有る無しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有る無しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有る無しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有る無しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有る無しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有る無しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有る無しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有る無しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有る無しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有る無しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有る無しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有る無しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有る無しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有る無しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有る無しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有る無しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有る無しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有る無しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有る無しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有る無しは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「修行の淺い我々でござれば、果して奇特の有る無しはお受合ひ申されぬが、兎も角も一心を凝らして得脱の祈祷をつかまつると致しませう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文帝の事、得る有る無し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "棊有つてより以来、言を立て道を論ずる、これに過ぐる者有る無し、目して棋家の孫子と為すも、誰か敢て当らずとせんや。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六は結果を報告して、「一ばんごてると思った若旦那が案外あっさりしてなさったので救りました」　嘉六が池上から持出されたたゞ一つの条件は、この事件の有る無しに係らず、今後も蝶ちゃんとの交際は続けさして貰い度いという希望だったそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり俺が片付けてやる」　といった程度の安請合いに対する誠意の有る無しは、その眼よりも口よりも真中でニヤニヤ笑っているところに最もよく現われていなければなりませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「修行の浅い我々でござれば、果たして奇特の有る無しはお受け合い申されぬが、ともかくも一心を凝らして得脱の祈祷をつかまつると致しましょう」「なにぶんお願い申す」　やがて時分どきだというので、念の入った精進料理が出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "建網に損じの有る無し、網をおろす場所の海底の模様、大釜を据えるべき位置、桟橋の改造、薪炭の買い入れ、米塩の運搬、仲買い人との契約、肥料会社との交渉‥‥そのほか鰊漁の始まる前に漁場の持ち主がしておかなければならない事は有り余るほどあるのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草を吸う女学生　東京の或る女学校では、健康診断や体格検査の時に女生徒に口を開かせて、虫歯の有る無しを調べさせる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの日向に転がつてゐる物から物へと、一々そつと触つてみて、熱の有る無しを検べてゐるらしい検疫医のやうなしほからとんぼ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は旅の土産ともいうべき自分の仕事に取掛った時で、彼女に与える仕事らしい仕事を用意する余裕もなく、写し物とか校正とかそういう方の手伝いでも頼みたいと思っていたが、そういう仕事の有る無しに関らず彼は節子と共に働いていると考えることを楽みとした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "137いつまで有る無しのわずらいになやんでおれよう？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "143いつまで一生をうぬぼれておれよう、有る無しの論議になどふけっておれよう？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪の有る無しは話には成らぬ。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の有る無し身分の上下。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えた敬太郎は、自然の順序として相応の機会が廻って来るまでは、黒子の有る無しを見届けるだけは差し控えた方が得策だろうと判断した。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "金が入って来ると、十人近い女は自分の持ち番の客の有る無しに係らず、ドッと喚いて一斉に彼に飛びついてゆくという騒ぎである。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには異状又は異状の痕跡の有る無しのこと、もう一つには妾の懐胎の機能が健全であるか不健全であるかということ、この二つについて早速検べてくれるように頼んだのであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今度はそのヨメさんの居所を突きとめ、加十の側から見た事実が平作たちの側からの物とズレの有る無しを確かめる方法はあるまいかと考えたのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子供の有る無しはまつたく節句と関係がなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人が研究しても恐らく一致すると云ふ點は、唐の代に南北の書派が有る無しに拘らず、一大變遷がある。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はわたくしと対談の際、わたくしを呼ぶに必先生の敬語を以てするので、懇意になるに従つて、どうやら先輩と門生といふやうな間柄になつて来たが、然し二人が日常の生活については、其住所を知るの外、わたくしの方からは一度も尋ねに行つたことがないので、余程後になるまで、妻子の有る無しも知らずにゐた。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエ、お宝の有る無しじゃアございませんよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そっちへ歩き去った他の人物の有る無しを探る場合に、たとえば質屋の倅というような特殊な一人を想定してはいけません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の有る無しにかかわらず、日本人だったら、たとえ金を出す人があっても、宛もないあの中央亜細亜の砂漠へ二年の計画でそんなものを探しに出かける人があるだろうかな。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の言うのは金の有る無しによってでなく、要するに金というものに対する我々の態度を考えるのだと思ってもらえば間違いありません。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じに、教養の有る無しが考えられ得るのだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがここで云う人間学はそうしたものから区別された人間学のことであって、この区別を与えるものがとりも直さず解釈学の有る無しにあるのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「しかし、わずかの人材でも、その有る無しでは大変なちがいである。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが鉱毒問題に働くのは、これは精神的な運動であって、決して金銭の有る無しに影響されるものでないからだ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかこの小ぽけな島、馬島という島、人口百二十三の一人となって、二十人あるなしの小供を対手に、やはり例の教員、然し今度は私塾なり、アイウエオを教えているという事は御存知あるまい。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
