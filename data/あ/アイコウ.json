            }
          ],
          "literary": [
            {
              "text": "「かやうな都会の私立中学にあつては、編入者や退学者が大変多いために、生徒の愛校心は至つて乏しいのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正門が立派でなければ愛校心が湧くものではない」といつて是迄の木の門は打倒され、石の門が建てられた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、小学校、中学校、高等学校を通じて、ついに愛校心というものが理解できずに終りました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大音寺の云ふところに依ると、応援団の幹部に欠員を生じてゐるところ故、君を余程熱心な愛校者と見ての上ですゝめるのだが、若しもリーダーが不得意なら、旗手になれと誘ふのであつた。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛校者と見られたのが非常に嬉しかつたのです。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛校心なきものは日本男児にあらず」　こうした校訓というものが、いつの頃からか五ヶ条ばかりあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の愛校心と、ファッショや右翼団体的な愛国心とは同じ偏したものだ。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愛校心とか、自由主義思想とかいう名目の下ではなく、面白いからであった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団というものは、スポーツから独立して、勝敗だけを旨としており、愛校心という名をかりて、いたずらに戦闘意識をもやしており、あの校歌だの応援歌というものは、坊主のお経によく似ているなア。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育者の権威に煩わされなくなった時代には儕輩の愛校心を嘲り学問研究の熱心を軽蔑した。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから特別な「愛校心」が産まれたり、又勇敢な「応援団」が出来上ったりするのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程野上氏には之で見ると、あまり「愛校心」はなかったようだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の見込は何うしても帝大出だよ」　と山下さんは一向帝大｜栄えもしていないのに、無暗と愛校心が強い。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男　　さあいこうよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあいこう、にいさん。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあいこうぜ」とお美代はいせいよくいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあいこう」　阪井はだまっている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあいこう、ねえ、みっともないじゃないか、車でも呼ぼうか」　手を取ってたすけ起こそうとする柳の手をぐっとにぎって阪井は目をかっとあいた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柳、ゆるしてくれ」「なにをいうんだ、過去のことはおたがいにわすれよう」「おれはおまえに悪いことばかりした、それだのにおまえは二度ともおれを救うてくれた」「そんなことはどうでもいいよ、さあいこう」　柳は阪井を強いて立たした、ふたりはだまって裏通りへでた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあお兄さんに悪いのね」「どうしても東京へゆくのか」「もしお兄さんに悪いのなら、あたし独りでもいくわ」　じゃあいこうかねと云い、彼はりつ子の雪を払ってやった。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、道場へ来てくれ」と十太夫は片づいている机の上を見てせきたてる、「ちょっと道場へ来て相手になってくれ、癇が立ってしようがないんだ、一本でいいから相手になってくれ、さあいこう、おい、手っ取り早くしてくれよ」　そこで土田正三郎は立ってゆく。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
