    "definitions": [
      {
        "index": 1,
        "gloss": "love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛好は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛好が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛好に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛好が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛好について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛好についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛好について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛好が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛好が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛好は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛好は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛好を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛好をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛好が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛好の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛好を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛好に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛好について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛好は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛好を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "又、「本校」と口にする時には、愛好の調子を含めようとして努力してゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古來歴史上の大科學者、例へばガリレオや、ワツトや、ニユートンや、エヂソンやが、その少年時代に於て、いかに夢想的な子供であり、いかにフアンタスチツクな童話の愛好者であつたかを、彼等の教育者等は知らないのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕事はどうも私には荷が勝った仕事ですが、いずれ勤先とも話がつきましたら専心この計画にかかって私の生涯の事業にしたいと思いますので」　その節は、亡父の誼みもあり、東海道愛好者としても呉々も一臂の力を添えるよう主人に今から頼んで置くというのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一歩進むとその歴史に関したあらゆる記録、古文書、古器物に対して丁度骨董家が有つような愛好の念をもってこれを蒐集する人もある。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の詩の愛好者は、私が当初に予期したよりも遙かに多数であり且つ熱心でさへあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また世の蔭にひそんで人知れず自己の作品を書き努める無名の作家、雜誌への投書を樂しむつつましき文藝愛好者、そこにもそれぞれに懷しく、忘れ難い處女作の思ひ出は隱れてゐることであらう。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北川冬彦にも嘗て器物愛好があつた。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の文士とか批評家とか、又は学者、その他の芸術研究家、もしくは芸術愛好者の類で、時々「能」にチョッカイを出す人があるが、筆者の思うほどに「能」に突込んでくれる人が一人もいない。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "純素人として、全霊を裸体にして能と四ツに取り組んで、能の真実の力に打ちひしがれて満足し得る芸術愛好者、もしくは芸術研究家は、この尖端芸術とか、大衆芸術とか言って差別待遇を受けている吾々の仲間以外にいないのであろうか。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそういう音楽家の潔癖を尊重するものではあるが、それと同時に一般の音楽愛好者が蓄音機を享楽する事をとがめてはならないと思うものである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は蓄音機をきらう音楽家のピュリタニズムを尊敬すると同時に蓄音機を愛好する素人を軽視する事はどうしてもできない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの現象から、日本人は世界じゅうで最もはなはだしく書籍を尊重し愛好する国民であるということを推論することはできない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれがまた、この映画が日本あるいは東京の一般活動愛好者の感激を促し得ない理由であろうと想像される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化主義的音楽愛好家などは、時代のキザな流行熱で鹿鳴館時代のハイカラの如く、何の根柢もありはしない。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻川氏は自分の屹々した神経の尖端を傷めないＫ氏の外廓形態の感触に安心してＫ氏のなか味のデリカな神経に触接し得る適宜さでＫ氏をますます愛好して居るのではあるまいか。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼の、かねてからの文芸愛好の情に油をそそいで燃えあがらせた悪戯者として、あの一枚の幻燈の画片を云々するよりは、むしろ、日本の当時の青年たちの間に沸騰していた文芸熱を挙げたほうが、もっと近道なのではあるまいかとさえ私には思われる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道衍の卓敬に於ける、私情の憎嫉ありて、方孝孺に於ける、私情の愛好あるか、何ぞ其の二者に対するの厚薄あるや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し強ひて試に之を解して見れば、惜福者は人に愛好され信憑さるべきもので有つて、不惜福者は人に憎惡され危惧さるべきものであるから、惜福者が數※福運の來訪を受け、不惜福者が終に漸く福運の來訪を受けざるに至るも、自ら然るべき道理である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は近頃漫画として鳥羽僧正の画をひどく愛好して居る様です。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の氏の傾向としては、西洋の宗教画家や東洋の高僧の遺墨などを当然愛好します。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも有名なドーヴィル愛好者だ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　更に作品に就き詳述して置く事も、私の芸術愛好者若くは後世の白秋研究家に取り全く無意義な事では無いやうに思はれる。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし夫れ侠なるものを愛好するやと問はるゝ人あらば、我は是を愛好すなりと答ふるに躊躇せざるべし。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "道義の生命に於て快楽を願欲するに至る時は、単に｜自然の摸倣を事とする美術を以て真正の満足を得ること能はざるは必然の結果なるが故に、創造的天才の手に成りたる美を愛好するに至ることも、亦た当然の成行なり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅花と桜花との比較　梅花と桜花とは東洋詩人の尤も愛好するものなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人生を汚濁穢染の土とせば、処女の純潔は燈明の暗牢に向ふが如しと言はむ、もし世路を荊棘の埋むところとせば、処女の純潔は無害｜無痍にして荊中に点ずる百合花とや言はむ、われ語を極めて我が愛好するものを嘉賞せんとすれども、人間の言語恐らくは此至宝を形容し尽くすこと能はざるべし。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いたほん物の天竜が大きに欣んで一日葉公の家に降り己の愛好者を覗き見た。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、二人ともに、小動物、殊に猫を愛好する所がそれかも知れぬ、と、三造は気が付いた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、有能な実際的科学者で、忠実な大英国の技術官で、敬虔なスコットランド教会の信徒で、かの基督教のキケロといわれるラクタンティウスの愛読者で、又、骨董と向日葵との愛好者だった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男　　さあいこうよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
