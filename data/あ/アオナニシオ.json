        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "のみならず万一、この一件が片付き兼ねる……下手人がわからぬとなると吾々は元よりの事、御主人の松倉様まで、十手捕縄を返上せにゃならぬかも知れぬと言うので、松倉十内様は今のところ青息吐息、青菜に塩の弱りよう……」「ちょっと良助さん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半助がそう申すと、びしゃびしゃと青菜に塩になりましたっけが、（それでは外様を伺います。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社仏閣の堂と名医の室は、いかなる者にも神聖に感じられて、さすがの愛吉、ここへ入ると天窓が上らず、青菜に塩。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒尾先生、青菜に塩ですご／＼と帰つたが、俺も其後姿を見送つた時は可哀相になつたよ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシリーサ・カシュパーロヴナにかかつては、誰彼なしに、青菜に塩も同様だつたから。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "青菜に塩をかけたようになって嘆息した。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときばかりはさすがの机博士も、よっぽど肝をひやしたと見えて、青菜に塩のようにげんなりしていたが、それでも、いうことだけはいい。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……添役、氷見役は青菜に塩、どうでもこりゃ、お叱りはまぬかれない」　顎十郎は、のんびりと顔を振りあげ、「しかし、それだと言って、盗っとの顔ぐらいは見たろうから、こりゃ、まあ、すぐ知れる」　寅吉は首をふって、「……ところが、そうじゃねえんで。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬子をどなりつけて振り向いたとたん、思いがけない泰軒のいることに気のついた与の公、はッとすると同時に青菜に塩としおれ返ってしまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ、なんという名誉なことじゃ」「光栄じゃ」　名誉だ、光栄だと、口では言いながら、みんな青菜に塩としおれかえって、ベソをかいている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで青菜に塩の体で、考え込みながらふらふらと数寄屋橋御門から西紺屋の河岸っ縁へ出た。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘子軍の「赤ン坊を救え」のあった翌日はまた北浜は大暴落で、愛国銀行が潰れたという号外で、仲買人は青菜に塩のような顔をしている。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもない事冷素麺、それはかうするものであろと、さつと一杓水かけて、すすぎし上のゆで加減、何とでござんす良人と、この頃の信用恢復に、鼻もたかだかさし付くるつもりなりしに、青菜に塩のそれならぬ、生素麺に水の奇特。",
              "citation": {
                "source": "今様夫婦気質",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "町方の世話にゃならねえなどと大見得切った連中が今日は青菜に塩で、腹を切ろうか、八所借りで一万両まとめようか、坊主になろうか、それとも夜逃げをしようかと、朝っからの大評定で」　八五郎はすっかり有頂天ですが、平次はそれを聴くと、妙に考え込んでしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよ時節到来だぞ」「さよう典木はやはり正義の士だった」「大集会の席で摘発とはさすがではないか」「金吾一派を見ろ、もうすぐ青菜に塩だぞ」「これは一世一代のみものになる、面白し面白し」　このあいだに泰三の準備が出来た。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
