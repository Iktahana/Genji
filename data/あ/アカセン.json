        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "以前は、宮城県にいたようで、貯金帳の住所欄には、以前のその宮城県の住所も書かれていて、そうして赤線で消されて、その傍にここの新しい住所が書き込まれています。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "感激したからと言って、文章の傍に赤線ひっぱったりなんかは、しないことにしましょう。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか心細くなって、それでも勇気を鼓舞して、股引ありますか、と尋ねたら、あります、と即座に答えて持って来たものは、紺の木綿の股引には、ちがい無いけれども、股引の両外側に太く消防のしるしの赤線が縦にずんと引かれていました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか心細くなつて、それでも勇気を鼓舞して、股引ありますか、と尋ねたら、あります、と即座に答へて持つて来たものは、紺の木綿の股引には、ちがひ無いけれども、股引の両外側に太く消防のしるしの赤線が縦にずんと引かれてゐました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕邊に懸けてある温度表を見ても、赤鉛筆や青鉛筆の線と星とが大抵赤線の下に少しづゝの曲折を示してゐるに過ぎない。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると私が書いた昨日の夕刊記事の全部に、毒々しい赤線が引いてある。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火炎高く昇れるが、火炎の中に数十条の赤線直上し、その末火花となりて、半天に四散し、下界の煙火などには見られざる壮観を呈するに、酒ますます味を加う。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図の上には日本軍の進路が赤線で書き込まれ、占領地点には夫々旗を立てた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと無意識に生垣へ身を密めた鷺太郎の目に、白の半ズボンに白のシャツの男と、も一人、矢張り白地に大胆な赤線を配したズボンを穿いた断髪の女とが、ひょっこり現れた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その匕首のつけ根から流れ出た血潮が、あの白地に大胆な赤線を配した洋服の上へ、さっと牡丹の花を散らしたように、拡がっていた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄んだ大きい眼をしていて、格別、眼を患っているようでもなかったが、「彼の地では赤線ひとつあってもそれを理由として、日本人の上陸を拒むんですからね」何故そんなに排日の激しい処に行かなければならぬのか知らないが、彼女は異情な情熱を見せてそういった。",
              "citation": {
                "source": "独り旅",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の文句に引っぱってある赤線は、只の赤線でない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　四月号の時評だの、投書だののあっちこっちに赤線が引っぱってある。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると主任が、「一寸……」と手をさし出し、「働く婦人」四月号の赤線のところだけをよって貪るように目を通した。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、ベージュ色に細い赤線をあしらった地味なスウェータアに包まれている宏子の胸のあたりを眺めまわした。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら各行毎に赤線が引かれて戻ってきた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところは、こうしなくてはならない」　機械人間は、机の上から赤鉛筆をとると、壁にはってある設計図の上に赤線をひいて、元の設計を訂正していった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それです」　帆村はその細い赤線がついていたことまで覚えていた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの缶にも、赤線の符牒がついていますよ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱は體温表の上で一時非常にジグザグな線を描いたが、そのジグザグは次第にその振幅をちぢめて行きながら、遂に完全に赤線（三十七度）以下になつた。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はかなりの高い熱で苦しめられた跡を示してゐるが一人は熱はさほどになく、たいていが七度――赤線であるから良く判る――以下を上下してゐた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙと二人朝 ВОКС に行く時、前に赤線入りの自動車が二台あった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはＡ子という婚約者がありますが、たまたま宴会に酔っての帰り友に誘われて泊った赤線区域のＢ子のマゴコロを知り忘れがたくなりましただってさ。",
              "citation": {
                "source": "人生案内",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとさっきひいた赤線と、いまひいた青線とが交ったその地点こそ、勿来関！",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱は体温表の上で一時非常にジクザクな線を描いたが、そのジクザクは次第にその振幅をちぢめて行きながら、遂に完全に赤線（三十七度）以下になった。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
