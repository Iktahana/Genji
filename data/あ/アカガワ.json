        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "丈の高い男の嚴丈さうな腕に、もたれるやうに腰を抱きかかへられながら、女は踵の高い赤革靴の運び輕げに踊つてゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立おろしの紺の背広を着、赤革の靴もキッキッと鳴ったのです。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」狐は赤革の靴をはき茶いろのレーンコートを着てまだ夏帽子をかぶりながら斯う云ひました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神はしばらくの間たゞぼんやりと狐を見送って立ってゐましたがふと狐の赤革の靴のキラッと草に光るのにびっくりして我に返ったと思ひましたら俄かに頭がぐらっとしました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」狐は赤革の靴をはき茶いろのレーンコートを着てまだ夏帽子をかぶりながら斯う云いました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神はしばらくの間ただぼんやりと狐を見送って立っていましたがふと狐の赤革の靴のキラッと草に光るのにびっくりして我に返ったと思いましたら俄かに頭がぐらっとしました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶羅紗霜降の大外套を、風に向つた蓑よりも擴く裾一杯に着て、赤革の靴を穿いた。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ってるものはみな赤シャツで、てかてか光る赤革の長靴をはき、帽子には鷺の毛やなにか、白いひらひらするものをつけていた。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の停車場に着くと、父は車夫を呼んでチェッキで大きな赤革のスートケースを二つも受け取らせた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤革靴に霜降の流行型の背廣を着た方は金縁眼鏡を掛け、和服の方は羽織を脱いだ着流し姿になつて、毛もくぢやらの足を腰掛下に突き出してゐる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤革の靴を穿き、あまつさえ、リボンでも飾った状に赤木綿の蔽を掛け、赤い切で、みしと包んだヘルメット帽を目深に被った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いって夫人は、自分の赤革のケースから、スリー・キャッスルの細巻を出して、青年がライターをつけてくれるのを待った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正勝さんへ来たんですがね」　電報配達夫は、それでも小さな赤革の鞄の中から電報を取り出した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし、いい赤革張りの書き物机を新調しまして、誓って申し上げて、バニスタも請け合いましょうが、ずっと毛羽も汚れもございません。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、膝の上の大きな赤革の化粧ケースの蓋をあけて、化粧をしながら、「自分にはアカデミシアンの胸は全く解らない。",
              "citation": {
                "source": "ガール・シヤイ挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆは、膝の上の大きな赤革の化粧ケースの蓋を開けて、その中の鏡に顔を写して、のべつに頬のあたりを白粉で叩きながら、「私は、そんな性質は知らない。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋館へ帰って、玄関へ行ってみると、もう村川の赤革の靴がなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関のくつぬぎの上には、彼の赤革の編あげ靴に並んで、飾りのついた黒いハイヒールの彼女の靴が、つつましやかに並んでいた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には数々の履物に交つて赤革の夏靴が一足脱いであつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には數々の履物に交つて赤革の夏靴が一足脱いであつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　髯の男は内田と名乘り、赤革の鞄をひらき何かを探つてゐたが、一枚の紙を取出すとそれを擴げ、突然杉村の前にぐつとつきつけた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その餓鬼の大群集がぽかんと口をあけて、探険家然と赤革の外套なんかを着用している、二人とふたりの持物に飽かず見入っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れる、と思わず瞬間ぎょっとしあわてて避けたはずみに見ると、それは水瓜ではなく、子供の遊戯に使う大きな赤革のボールであった。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長上衣だけでもお前の短衣と赤革の靴より高価かんべえ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉はカーキ色の仕事服に戦闘帽をかぶり、飛行将校のはくやうな、赤革の短い長靴をはいて、意気な家の格子を開けた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ十歩と歩かないうちに、ふと赤革の手袋を一つ落していることを発見した。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉は霜曇りの空の下に、たった一つ取り残された赤革の手袋の心を感じた。",
              "citation": {
                "source": "寒さ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、同人所有のものと思われる鞄は、赤革のスーツケースにして、大きさに不相応なる大型の金具及び把手を備え居り、その蓋を開きみたるに、長さ二尺ばかりの杉角材が四本と古新聞紙が詰めありたる外めぼしきものも、手懸りとなるものも見当らず。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも新宿の専売局跡の露店街において、昼日中のことだが、ゴム靴などを並べて売っている店に一つの赤革の鞄が置いてあったが、この鞄がどうしたはずみか、ゆらゆらと持上って、ゴム靴の海の上をすれすれに往来へ出ていったのである。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
