          "standard": [
            {
              "text": "これはＩＲＣの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「なにを考えてＩＲＣ（万国赤十字）の仕事なんか手伝っていたのか気がしれない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のパァティって、赤坂のＫ会館前であるＩＲＣの主催の、日本代表の送別会のことではございませんか。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もお手伝いにまいりますんですが」「あたしよく知らないのよ」「ＩＲＣの主催ということになりますと、治外法権ですから、いくら憲兵でも踏みこむわけにはいきませんでしょう」「そういうものなの。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の脇間の柱にびっくりするほどたくさん花をつけた、繁みのような薔薇の大枝が飾ってあって、白髪の、知的ないい顔をしたＩＲＣのグルネルさんとルロォさんが立っていて、ていねいにお辞儀をした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣの日本代表の下で働いていたひとに逢うために来た」「そのひとは雄か否」「否。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさんあたりから今夜のパァティのことを聞いて、満寿子さんが来ていると思って、誰かのタクシードを借りてそっと見にきたというわけなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさん、ペン・クラブの人達、モギレフさん、Ｍ・Ｊ博士、ローマン・カラーのいつかのカトリックのお坊さんなどの顔が見える。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ゲルハルトがニキシュの伴奏で歌った有名なＩＲＣＣのレコードのことについては、『巨匠の回顧』の項に書く）　ゲルハルトの声は万人に優れたものであった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
