        "examples": {
          "standard": [
            {
              "text": "私は毎日あやについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あやという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあやの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあやが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あやを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあやについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あやの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあやの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあやが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あやという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあやという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあやについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あやを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあやは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あやについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあやが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあやは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあやの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あやは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあやは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀想に前の赤ん坊が目を覚ますたんびにその泣声に目を覚まし、俄かづくりの笑顔で以て赤坊をあやしてやる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の機微を、あやまたず人に言い伝えるのは、至難である。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一巻の創作集の中から、作者の意図を、あやまたず摘出してくれる。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことはない、あやつり人形の所作でも見ているような心地がした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ或る日、或る一隅に於ける諸君の美しい行為は、かならず一群の作者たちに依って、あやまたず、のこりくまなく、子々孫々に語り伝えられるであろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むさしや」といふ家のはなれを借りて根合せならねど、あやめの歌合といふを試みけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやめは、池のこのもかのもに咲き誇れり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て、梅津の君は、あやめも知らぬ戀人は、このわたりにはあらじかし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事ぞとみかへれば、あやめの花束、手にさげて參りたり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所のお内儀さんなどが通りがかりに児をあやすと、嬉しそうな色が父親の柔和な顔に漲る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ小柄で、ほつそりとして、手足も華奢で可愛く、ぞつとするほどあやしく美しい顏をしてゐるが、しかし、ヴイナスのやうな「女らしさ」が無く、乳房も小さい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立体構成面の威嚇的偉大さを、駭くべき簡単なる曲線で、統整して、しかも委曲に至っては、富士で謂うところの八百八谷の線から、おのずと発生する凹凸面の、複雑なる入り乱れのために、眼もあやになることを如何ともしがたい。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は一寸怒つたやうな顏を見せたが、驚いてあやまつたらすぐに心が解けたやうである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が駿河路にかかったときには花後の樗の空に、ほととぎす鳴きわたり、摺らずとも草あやめの色は、裳に露で染った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の歿したのちは男の手一つで女中や婆あやや書生を使い、私を育てて来た父には生甲斐として考証詮索の楽しみ以外には無いように見えたが、やはり寂しいらしかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして対者につつしんであやまります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあやしいその銀河の水は、水素よりももっとすきとほってゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕そして青い橄※の森が見えない天の川の向ふにさめざめと光りながらだんだんうしろの方へ行ってしまひそこから流れて来るあやしい楽器の音ももう汽車のひゞきや風の音にすり耗らされて〔〕ずうっとかすかになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからていねいにあのあやしい化石を掘りはじめました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども東の空はもうやさしいききょうの花びらのようにあやしい底光りをはじめました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山の裾野にあかねさす紫匂ふ花あやめかも櫻草の花によく似る紫の花めでつゝも名を知らずけり花あやめしみ咲きにほふ紫の花野を來れば物思もなし紫の雲ゐる野べに朝遊び夕遊びます二荒の神湯の滝を見、湯本に遊びて帰る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "次回のさかりの時をあやまるなと男共及び妻に注意した十六日　前夜より寺島の犢がしきりに鳴く。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
