[
  {
    "uuid": "51558e22-bef8-52aa-91f3-28ac216f320f",
    "entry": "綾",
    "reading": {
      "primary": "あや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "figure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日綾について考えている。",
              "source": "幻辞"
            },
            {
              "text": "綾という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は綾の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には綾が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "綾を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは綾について学習した。",
              "source": "幻辞"
            },
            {
              "text": "綾の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は綾の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では綾が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "綾という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に綾という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では綾についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "綾を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると綾は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "綾について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では綾が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に綾は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により綾の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "綾は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に綾は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あなたの御想像は、まあドンヂヤンドンヂヤンの大騷ぎで、大きなお皿に鯛のさしみやら鮪のさしみ、赤い着物を着た娘つ子の手踊り、さうしてやたらに金銀珊瑚綾錦のたぐひが、――」「まさか、」と浦島もさすがに少し不愉快さうな顏になり、「私はそれほど卑俗な男ではありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの間をつづってオリーブのつくり葉が、金銀のモール線を綾なして居るのは、どこでも同じしつらえではあるが、独逸はやっぱり独逸らしい。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相模｜嶺の小嶺を見過し、真砂｜為す余綾の浜を通り、岩崩のかげを行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の奥の綾むしろは暖く、結燈台の油｜坏に油はなみなみとしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場が殖え、会社の社宅が建ち並んだが、むかしの鐘ヶ｜淵や、綾瀬の面かげは石炭殻の地面の間に、ほんの切れ端になってところどころに残っていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾瀬川の名物の合歓の木は少しばかり残り、対岸の蘆洲の上に船大工だけ今もいた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひ換へれば探偵小説と云ふものは、人間が本能的に惹きつけられる處の祕密の曝露、犯罪の摘發、或は不思議の解決とか云ふ事を作る主題にして、それに筋をからませ、綾をつけて、讀者を享樂させるものである。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもどうにかこうにか綾なして、だんだんに手元へひき寄せたらしく、為さんは手網を持って掬いあげようとする。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫綾の大法衣、　　　　　　逆光線に流れしめ、六道いまは分るらん、　　　あるじの徳を讃へけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒表紙には綾があって、艶があって、真黒な胡蝶の天鵝絨の羽のように美しく……一枚開くと、きらきらと字が光って、細流のように動いて、何がなしに、言いようのない強い薫が芬として、目と口に浸込んで、中に描いた器械の図などは、ずッしり鉄の楯のように洋燈の前に顕れ出でて、絵の硝子が燐と光った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりして、子の口までの三｜里余は、たゞ天地を綾に貫いた、樹と巌と石と流の洞窟と言つて可い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古より文人墨客の輩綾瀬以上に遡らずして、たまたまかゝる地あるを知らざりしかば、詩文に載せられて世に現るゝことなく、以て今日に至りしならん。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○綾瀬川は荒川の一転折して南に向つて流るゝところにて、東より来つて会する一渠の名なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流には支流ありて中川にも通ずるをもて船の往来も少からず、隅田川の方より綾瀬橋といへる千住道にかゝれる橋あたりを望めば、一水遠く東に入りて景色おのづから小幀の画を為す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○さんざいとは綾瀬川の隅田川に合するところの南の岸を呼ぶ俗称なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○鐘が淵は紡績会社の地先にして、隅田綾瀬の二水相会するところのやゝ下の方をいふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いでまた水の綾が乱れた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇親の間柄とて案内もなく客間に通って見ると綾子と春子とがいるばかりであった。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『姉さんはおっかさんとどこかへ出ましたよ』と綾子は答えた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『姉さんはもうこれからはあたしたちにおけいこしてくださらないのよ、』と綾子が答えた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は一面の白砂に水紋落ちて綾をなし、両岸は緑野低く春草煙り、森林遠くこれを囲みたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は与えられた一つのものに内在する有機的構造を分析展開して見せるに対して、後者は与えられた離れ離れの材料からそれによって合成されうべき可能の圏内に独創機能を働かせて建築を構成し綾錦を織り成すものだとも言われないことはないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樹の言葉に綾をかけて、かけすが雨に居所を襲はれて、けたゝましく鳴きかはした。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先きだけ赤らんだ小さい指が器用に、黒ずんだ板の上を走つて、かゞんだり立つたりする度に、お末の体は女らしい優しい曲線の綾を織つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンの目はすこしずつあかるくなって、綾目が見えるようになってきました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の綾を織り出した星々の地色は、底光りのする大空の紺青だった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の壁の鼠色も収穫小屋のまだらな灰白色も、緑蔭と日光との綾の中にさながら小跳りをしているようだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻は火の口より噴上る火焔と連って綾手の網になったりした。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
