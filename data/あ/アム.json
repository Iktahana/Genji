    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to knit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日編むについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "編むという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編むの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編むが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編むを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編むについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "編むの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編むの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編むが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編むという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編むという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編むについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編むを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編むは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編むについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編むが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編むは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編むの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編むは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編むは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "俥の歯を編む無数の銀線が、きら、きら、ぴか、ぴか、と鋭く光を放った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙を編む生命網の象徴である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の方のものなら麻もつくったけれども、小十郎のとこではわずか藤つるで編む入れ物の外に布にするようなものはなんにも出来なかったのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木を伐出いて谿河へ流せば流す……駕籠の渡しの藤蔓は編むにせい、船大工は要りましねえ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余を以て是を見れば、我国の古神学は或は俗を喜ばすべき奇異譚を編むには好材料たるべきも、到底｜所謂幽玄を本とする想詩を構ふるに適するものならず。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "三萱刈りて、篠刈りて、編むで作る、炭俵、炭をつめて、繩もて括る、眞木ゆひし、繩を解きて、一括り、二括り、三括りに括る、大き俵、小さ俵、左から見、右から見、置いて見つ、積むで見つ、よろしき炭、また燒いて、復た燒き燒く。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人の土人が裏の森の小舎で此の籠を編む。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎頭を料り虎鬚を編む。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど母上は早く往きて、友なる女房の環飾編むを助けむとのたまへば、甲斐なかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……山中や菊は手折らじ湯の匂ひ　この句は、芭蕉がしたためたのを見た、と北枝が記しているから、山中や菊は手折らぬ湯の匂ひ　世に知られたのは、後に推敲訂正したものであろう、あるいは猿簑を編む頃か。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした小さな織物を、まだ見ぬ誰かとの出会いの中で編む可能性を、電子本は膨らませてくれるのではないか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん今日は何をしますか」「うん仕方がない、繩でもなえ」「兄さんは何をしますか、繩をなうならいっしょに藁を湿しましょう」「うんおれは俵を編む、はま公にも繩をなわせろ」　省作は自分の分とはま公の分と、十｜把ばかり藁を湿して朝飯前にそれを打つ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其足から足へ渡した棒へ藁を一掴みづゝ當てゝは八人坊主をあつちへこつちへ打つ違ひながら繩を締めつゝ編むのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "神が人を造るに乳の如く斟ぎ牛酪の如く固め皮と肉とを着せ骨と筋とをもて編むというは、胎内における発生を語ったもので、当時の発生学（Embryology）の知識を示すものである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ近代の秀歌なれば、定家卿が新勅撰集を編む時、我日本とはこの輩の口にすべきでない、この日本と直さば入れようといふと、一字でも直されてはいけない、且つ日本人はみな皇民なれば天子を我君といふ、この国に生れて我日本といはん事、其人を差別すべきでないといひ張つて、直さず入れられなんだとは余程えらい。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭をば巣を編む材料にするのだそうだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後朝に巻きまきし玉の柔手の名残よと、黄金くしげのひとすぢを肩に残しゝ「若き世」や「死出」の挿頭と、例も例もあえかの花を編む「命」。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後朝に卷きまきし玉の柔手の名殘よと、黄金くしげのひとすぢを肩に殘しゝ「若き世」や、「死出」の※頭と、例も例もあえかの花を編む「命」。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "産褥から出たばかりの細君を助けて、靴下を編む、襟巻を編む、着物を縫う、子供を遊ばせるという生々した態度、時雄は新婚当座に再び帰ったような気がして、家門近く来るとそそるように胸が動いた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説を編むも同じ事也。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "出稼に出るか、養蠶をやるか、蔬菜類を賣るか、薪を伐るか、炭を燒くか、麥稈眞田を編むか、その他の副業によるかであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆肥の準備が終つたのちに、なほ殘つてゐる仕事は、苗床の掩ひに使ふ麥藁の薦を編むことである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薦を編む、といふやうな靜止的な仕事に從つてゐる時には、駿介の想ひは時々過去に走つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "云はれてゐる通りに、薦や繩を編むといふことも、駿介にはまだ自信がなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを編む手の甲は紫がかつて脹れ、その指先きはところどころ皸破れて赤く口を開いてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は例の事なので良人の方には見向きもしないで、せつせと韈を編むでゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女といふものは韈を編む時には、「ほんとに私は親切者だわ、一寸の暇も無駄にしないで、こんなにして家の人のを編んでるんだもの。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀者諸君のために言へば、わたしはこの國の貞享元祿の作者達が、あるひは『五人女』を完成しあるひは『曠野集』八卷を編むより八十餘年も前の方に、先づ諸君の想像を誘ひたい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんに前後もみないで生きて来た……私はあむまり陽気にすぎた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつものお話で何か春らしい種はありませんか」「そりゃあむずかしい御註文だ」と、老人は額を撫でながら笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
