[
  {
    "uuid": "32bc2398-0a9e-5cc0-81c3-495b30dc4173",
    "entry": "編む",
    "reading": {
      "primary": "あむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
