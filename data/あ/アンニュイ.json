        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンニュイについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンニュイの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンニュイが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンニュイについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンニュイの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンニュイが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンニュイという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンニュイについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンニュイは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンニュイが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンニュイは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンニュイの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンニュイは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンニュイは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが裏街の芥捨場や、雑草の生える埋立地で、詩人の心を低徊させ、人間生活の廃跡に対する或る種の物侘しい、人なつかしい、晩春の日和のような、アンニュイに似た孤独の詩情を抱かせるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「切符切り」でパチンとやるというような、児戯に類した空想も、思い切って行為に移さない限り、われわれのアンニュイのなかに、外観上の年齢を遙かにながく生き延びる。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィッチを捻って昼の客をそのまま夜の客に更めて照し出した軒並みのキャフェのテラス――春宵のアンニュイに導かれて足はおのずと静なラシイヌ通りに踏み入る。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる全き放心の後に来る、もの凄じきアンニュイを君知るや否や。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはかような訳の判らぬアンニュイな気持を捨鉢に朝飯の膳へ托けまして、「もう毎朝、三州味噌のおつけにも飽き果てた」　と言いましたので、池上は、「それじゃ当分、馴染の西洋料理店に話でもつけて、イギリス風の朝飯でも運ばせることにしよう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人にとぼけるという印象をあたえたのは、それは、私のアンニュイかも知れないが、しかし、その人のはりきり方には私のほうも、辟易せざるを得ないのである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、生きている間はなにかしら絶えず酔ッ払っていなければ忽ちアンニュイのとりこになってしまうのである。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　何かアンニュイを感ず。",
              "citation": {
                "source": "一九二七年八月より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まああなたの言葉を借りればアンニュイそれ自身のような生活だわね。",
              "citation": {
                "source": "文放古",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕舞にアンニュイを感じ出した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "全たく、又アンニュイに襲われたと悟って、帰りだした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動機は、単に哲学上の好奇心から来た事もあるし、又世間の現象が、余りに複雑な色彩を以て、彼の頭を染め付けようと焦るから来る事もあるし、又最後には今日の如くアンニュイの結果として来る事もあるが、その都度彼は同じ結論に到着した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれをアンニュイと名けていた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンニュイに罹ると、彼は論理の迷乱を引き起すものと信じていた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の行為の中途に於て、何の為と云う、冠履顛倒の疑を起させるのは、アンニュイに外ならなかったからである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の苦痛は何時ものアンニュイではなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活のアンニュイから来る破滅　She had no child, but had a piano, no child. Nothing to do; 余り上々の作でない。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう、さう」よりも高飛車で、「その通り」よりは素ツ気なくない、お互に呑み込み合つた、妙にアンニュイを含んだ言葉である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ、愛情なんてものは、瞬間に感じるもので、瞬間が瞬間でなくなった時には、既に、アンニュイだと考える。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある春雨の日、斉信は「御｜物忌」にこもってアンニュイに苦しめられながら、こんな日には彼女と話がしたいという気持ちになる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑暇やアンニュイが一種の文化的ポーズになる時は、それが他ならぬ有閑層のイデオロギーになっている時なのであるが、併し忙しい生活の内にも、突如として暇つぶしと退屈凌ぎとの必要を生じて来ることがあるのである。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この淫楽はおのずから自棄に通じ、やがてアンニュイに帰するものであるがこうなると、実はもはや快楽ではなくなって、前に述べた処の、あの退屈凌ぎや暇つぶしというカテゴリーに突入して来る。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその積極性の無条件な徹底は、遂に慰安と休息さえのないアンニュイに陥る。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一三年の夏に、私はアンニュイな様子を見せ始め、それまでの興味を失っていき、自分の中で変化が起こりそうだと様々な同僚に仄めかすようになった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は自分の決心を語る準備として、「芸術は宿命的に感情硬化に到達するのではなかろうか」という質問に事寄せて、彼女の焦慮とアンニュイとを仄めかした。",
              "citation": {
                "source": "感傷主義",
                "author": "Ｘ君とＸ夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は夫婦生活に潜む幾多の危機は一度も経験しなかったのみならず、共同生活に伴うアンニュイの一滴だも嘗めずに、短くはあったが、至幸な生活を満喫したのであった。",
              "citation": {
                "source": "感傷主義",
                "author": "Ｘ君とＸ夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近代人のアンニュイのように、余裕の乏しい苦悶でもなかった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
