        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "挙げての例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は新短歌が現に挙げてゐる成績に偏執し過ぎたかも知れない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大きな声を挙げて泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世は挙げて性格破産。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を挙げて合図をして「居た居た、あそこに」と云われても、どこにどんな鳥がいるのか明き盲の自分にはちっとも見えない。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいでもあるまいが、彼がこの頃年賀状の効能の一つとして挙げているのは、それが死んだ時の通知先名簿の代用になるという事である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの灯の利益な点を挙げてみれば、第一前記のごとく室の隅にまで明るくなる故、倉庫の中などにこれを点ずれば、貨物の出し入れに暗さを喞つ心配はなくなる。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このランプの利益な点を挙げてみれば、先ず電力の経済が出来、それから光る部分が大きいから物の影が少なくなって室内が昼のようになる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の終り目毎に袖を挙げて振った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうとき、私は強い衝動に駆られて、若し許さるるなら私は大声｜挙げて「タロー！",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼冷　俺等の心は、一諸に出会はう　俺は畑を耕し終へたとき、疲れた眼を挙げて、遠い南の土耳古玉の天末を望まう。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、すこし例を挙げてみよう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がドイツへ行ったのは世界大戦の直後であったからドイツ全国民を挙げて外来語の排撃につとめている時であった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず『諸国咄』の序文に「世間の広き事国々を見めぐりてはなしの種をもとめぬ」とあって、湯泉に棲む魚や、大蕪菁、大竹、二百歳の比丘尼等、色々の珍しいものが挙げてある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴の人間に関する観察帰納演繹の手法を例示するものとしてはまた『織留』中の「諸国の人を見しるは伊勢」に、取付虫の寿林、ふる狸の清春という二人の歌比丘尼が、通りがかりの旅客を一見しただけですぐにその郷国や職業を見抜く、シャーロック・ホールムス的の「穿ち」をも挙げておきたい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に卑近なる例を挙げて所説を補わん。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお直接水産方面に関して、自分の知っているだけの僅少な例を挙げてみると、第一に漁具ことに網の研究である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度この頃、彼の父は家族を挙げてミュンヘンに移転した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に『万葉集』『日本紀』の仮名についても同様で、以上三種の書について仮名の清濁の区別を挙げてあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は「ア、イ、ウ、エ、オ」の順で単語を出して、どこが濁るか、どこが濁らないかということを古典から例証を挙げて示しているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家族を挙げてターリングの邸内に移り、死ぬまでここでレーリーの片腕となって働いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下に挙げてある頁数は、エヴェリーマンス・ライブラリーの中のこの書物の頁数である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝玄関で　団九郎が取次の侍に向って大声挙げて叫んだ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然少年が頭を挙げて云つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は腰の左手を上へ挙げて、額に翳している右の腕に添え、眩しくないよう眼庇しを深くして、今更のように文化の燎原に立ち昇る晩夏の陽炎を見入って、深い溜息をした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を眩しそうにぱちつかせて、女教師の動作の全部を見届けた貝原は「型が綺麗だなあ」　と思わず嘆声を挙げてやや晦冥になりかけて来た水上三尺の辺を喰い付きそうな表情で見つめた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息詰まるような長い接吻を終えると、彼は絶望的な声を挙げて妾を突きとばしたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は恐怖のために大声を挙げて叫びました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と少年は額を少し挙げて泣声で言った。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、十一月の曇つた午後に、風が往来の砂塵を巻きあげてゐるやうなもんだと、僕の、心はともかく肉体は、左様に今はや観念してゐるやうな具合だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
