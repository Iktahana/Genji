          "standard": [
            {
              "text": "これはＩＰの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（ＷＩＰＥ）Ｓ＝奥座敷　縁側。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日お前を訪ねて此処へ来るそうだ」　「だから今夜の中にたってしまえば、まさか吉兵衛の奴も、気がつくめえと思うンだ」（ＷＩＰＥ）Ｓ＝奥座敷（前のシーンと同じ）　石松、大分飲んだ後の感じです。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護期間には、「３世代が含まれるのが公正妥当」とする考え方は、『ベルヌ条約逐条解説』（クロード・マズイエ著、黒川徳太郎訳、著作権資料協会、一九七九年七月二五日発行）においてＷＩＰＯ国際事務局著作権、広報ディレクターの肩書を持つ著者が示している。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ベルヌ条約逐条解説』に寄せた序文で、ＷＩＰＯ事務局長アルパード・ボグシュは、「ＷＩＰＯ国際事務局の任務は条約の管理に責任を負うことであり、このような解説を行うことはその権限に属するものではないから、本書はベルヌ条約の規定に関する有権的解釈を意図するものではない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミップスの最高速版であるＲ４０００の８０ＭＩＰＳに対して、ＡＬＰＨＡは３００ＭＩＰＳはでるという触れ込みで、商売人のビル・ゲイツはさっそくＷｉｎｄｏｗｓ　ＮＴをＡＬＰＨＡに載せると言いだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　酒場「ＡＮＴＩＣＩＰＡＴＩＯ」にて。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八年製――をＳＩＰしようてんだから、これは仲なかどうして地球的に荒っぽい意気さの漲るじんぎだと言わなければならない。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国船員の行列にあるこほるが参加し、林立するマストに汽笛がころがり、眠ってる大倉庫のあいだに男女一組ずつの影がうろうろし、どこからともなく出現するこの深夜の雑沓・桟橋の話声・水たまりの星・悪臭・嬌笑・ＳＨＩＰ・ＡＨＯＹ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＨＩＰ・ＡＨＯＹ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一行の目の付けどころに彼らがどんなに驚かされ、また喜んだかは、この段階ではまだ遅れ遅れの発行となっていた『ＤＤＪ』の一九七六年五月号に、「ＪＩＰＤＥＣ ＶＩＳＩＴ ＰＣＣ」のタイトルでまとめられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後のハードウエア技術の進歩を見込めば、一九八〇年代の半ばには高解像度のディスプレイ、一Ｍバイトのメモリー、一〇〇Ｍバイトの補助記憶を備え、一ＭＩＰＳの処理能力を備えたマシンが一万ドル程度になると予測できると提案は主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＩＰ（シンボリックインプットプログラム）は、電子工業振興協会で森口繁一（東京大学）の指導で共通仕様がまとめられ、刑部政司がＮＥＡＣ２２０３用を開発した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、ルセアニア人は、先刻から、ＺＩＰの手鞄を開けて取り出した｜嗅ぎ塩を、しきりに鼻へ当てていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "校正済みのテキストファイルを整えて、ＺＩＰ圧縮、ＨＴＭＬ化、エキスパンドブック作成、さらに図書カード作成、インデックス作成、〔そらもよう〕への告知……。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "髑髏の後頭部にはラテン語で｜ＮＯＳＣＥ・ＴＥ・ＩＰＳＵＭ（汝自身を知れ）と刻してあった。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に把って耳に当てると、懐しい髑髏は相変らず、ＮＯＳＣＥ・ＴＥ・ＩＰＳＵＭ　ＮＯＳＣＥ・ＴＥ・ＩＰＳＵＭと囁いてゐる。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            }
          ]
        }
