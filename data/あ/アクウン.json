          ],
          "literary": [
            {
              "text": "そして悪運強くマメで居ます。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い悪運強くも無事で居ります。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は心の自由を恢復し、悪運の手より脱れ、身の上の疑惑を懐くこと次第に薄くなり、沈欝の気象までが何時しか雪の融ける如く消えて、快濶な青年の気を帯びて来ました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、僕は如何しても悪運の児であったのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど何人も想像することの出来ない陥穽が僕の前に出来て居て、悪運の鬼は惨刻にも僕を突き落しました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や僕の力は全く悪運の鬼に挫がれて了いました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間では、前者を運に弱いとか薄命とか言うのに対して、後者を運に強いとか、又は人々は羨んで、悪運が強いとさえ悪口を言います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は腹の痛みで呻きつゞけた、しかし皆さんのおかげで、悪運強くして死なゝかつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓名判断の易者に言はせたら、此処で必ず一理窟立てる所だらうが、とに角常識で考へても、作家の名前と作風とが一致せず、表象上に食ひちがつた感じを与へるやうなのは、その人の文壇的運勢上で何となく不吉な悪運を感じさせる。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君は帽子を脱いでその家へはひり、しばらくして、笑ひを噛み殺してゐるやうな顔をして出て来て、「悪運つよし。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災をまぬかれたとは、悪運つよしだ。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は直覚的にこの男が或容易ならぬ悪運命の底を経て来た人間である事を見てとつた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から思へば実に悪運命の始まりであつた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪運が強くて罹災も、しやがらねえ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の苟めの合乗に青年と信一郎とは、恐ろしい生死の活劇に好運悪運の両極に立ったわけだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはおしらべがおつきでござりますはず、ただ一つ死体を沈めるおりに、あやまって懐中のふた品を濠に落としたのが、悪運の尽きでござりました……」「あたりめえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪運が尽きねえでどうするかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」心にかかったが立ちもあがらず、再び絵画面に見入ったが、これが悪運の基であった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながら悪運のつよき敵機の一部が、本土内に潜入するやも計りがたく、ここに於て忠勇なる国民諸君の、一大奮起をお願いする次第であります。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやでかなりにふところを肥やした筈ですが、悪運尽きて忽ち滅亡、殺した者は大部屋の仲間でもなく、ごろつき仲間でもなく、ひょっとすると例の屋敷の連中が秘密露顕の口を塞ぐために、急所の当身でも喰わせたかも知れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の苟めの合乗に青年と信一郎とは、恐ろしい生死の活劇に好運悪運の両極に立つたわけだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、悪運が尽きたとでもいうのですか、それとも、阿漕が浦で引く網も度重なれば何とやらの譬か、警察ではやっとのことで、彼等の二つの住居の中の一つを嗅ぎ出したのです。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角貴様の力でここまでやって来たが、こんどはよっぽど悪運につけこまれたんだ。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあまりに悪運を引き過ぎた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は余程の御幣かつぎとみえて、その日の新聞紙の上にくもが一ぴきとまつてゐるのを見て、気にかゝつてならないから、幸運か悪運か、どつちの前兆なのか、一つ考へてみてほしいといふのだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宅の新聞紙の上にのつてゐた蜘蛛は、幸運のしるしでも悪運のしるしでもありません。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――急に胸苦しくなつたが、すぐ快くなつた、私の悪運はなか／＼強いわい！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官殺しの犯人も遂に悪運尽いて、事件発生後十一日の昨朝逮捕された、此地方では珍しい出来事であつた、誰もほつと安堵と快心の吐息を洩らしたことである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにつきまして、この頃では、さまざまの臆説が唱えられて居るようでありまして、中には、これは科学者に共通な悪運が廻って来たものだと申し、或る者は殺人魔の跳梁であると申し、また或る者は偶然災害が続くものであって決して原因のあるものではないと反駁をいたしておるようなわけであります。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけ　ベンジャミンが　はしゃいだのに　あなぐまトミーが　起きなかったのは　あくうんが　強かったとしか　言えません。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
