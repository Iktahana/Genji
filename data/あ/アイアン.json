        "examples": {
          "standard": [
            {
              "text": "アイアン製の重厚な門扉が、その家の歴史と格式を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴルファーはグリーンを狙って、手にしたミドルアイアンを力強く振り抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日のアイアンの調子が良い」と、彼は自信ありげに次のホールへ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "無骨なアイアンのフレームがむき出しになった家具は、工業系のインテリアにぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この建物のバルコニーには、繊細な曲線を描くアイアンワークが施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラフからの脱出には、ピッチングウェッジのような短いアイアンが有効だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンティークショップで見つけたアイアンの燭台は、部屋に趣を加える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文六さんが送ってくれたセットは、アイアンは全部マクレガーであった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴルフに於ては天才は存在せず、万人が同じように上達しうるものです」　今や私の第二の教祖村田プロはこう私を慰めつつ、女房はとっくにアイアンで習っているが、あなたはまだまだ、と私だけは永遠の如くにドライバアを振りつづけるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今は想像の翼をもって、シェリーの長女のアイアンシーと一緒にシェリーの魔法の車に乗って、炎をあげている世界の城壁の永遠の門を過ぎて、彼の見ている幻想を見る。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "地に降りると、アイアンシーは天を回る魔法の飛行生活でどこでも見たことが無いものを見るであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "アガメムノーン、權勢の王は眺めて喜びて、彼らに向ひ口開き羽ある飛揚の言を曰ふ――『青銅鎧ふアカイアの衆を率ゐる＊アイアンテ、君に指令の要を見ず（君を鼓舞する不可なれば）　285君は衆人勵まして戰鬪はげしく勉めしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレーテー王憤り答へて彼に叫び曰ふ、『誹謗に最もすぐれたる＊アイアン（汝アカイアの中に他のこと皆劣る）汝の心酷きかな、いざ今こゝに三脚の鼎もしくは釜を賭け、　485アガメムノーン元戎を共に判者と戴かむ、いづれの馬が先なるや、汝敗れて悟るべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウェッディング・マアチ」の一場面、少女がニッキイと関係した後で幻覚を見て、「オ・アイアン・マン」と叫ぶ、あの場面を予に思わせた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイアンモンガー通りにメッサー・サットン社があり、英国内のほとんどの不動産を一手に扱っている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイアンブラ地区まで待ってください」　　　　　＊　アイアンブラ到着後、グライドは予想したよりいいと漏らした。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
