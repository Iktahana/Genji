        "examples": {
          "standard": [
            {
              "text": "毎日、アイアンは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイアンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイアンに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイアンが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイアンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイアンについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイアンについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイアンが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイアンが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイアンは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイアンは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイアンを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイアンをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイアンが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイアンの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイアンを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイアンに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイアンについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイアンは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイアンを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文六さんが送ってくれたセットは、アイアンは全部マクレガーであった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴルフに於ては天才は存在せず、万人が同じように上達しうるものです」　今や私の第二の教祖村田プロはこう私を慰めつつ、女房はとっくにアイアンで習っているが、あなたはまだまだ、と私だけは永遠の如くにドライバアを振りつづけるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今は想像の翼をもって、シェリーの長女のアイアンシーと一緒にシェリーの魔法の車に乗って、炎をあげている世界の城壁の永遠の門を過ぎて、彼の見ている幻想を見る。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "地に降りると、アイアンシーは天を回る魔法の飛行生活でどこでも見たことが無いものを見るであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "アガメムノーン、權勢の王は眺めて喜びて、彼らに向ひ口開き羽ある飛揚の言を曰ふ――『青銅鎧ふアカイアの衆を率ゐる＊アイアンテ、君に指令の要を見ず（君を鼓舞する不可なれば）　285君は衆人勵まして戰鬪はげしく勉めしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレーテー王憤り答へて彼に叫び曰ふ、『誹謗に最もすぐれたる＊アイアン（汝アカイアの中に他のこと皆劣る）汝の心酷きかな、いざ今こゝに三脚の鼎もしくは釜を賭け、　485アガメムノーン元戎を共に判者と戴かむ、いづれの馬が先なるや、汝敗れて悟るべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウェッディング・マアチ」の一場面、少女がニッキイと関係した後で幻覚を見て、「オ・アイアン・マン」と叫ぶ、あの場面を予に思わせた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイアンモンガー通りにメッサー・サットン社があり、英国内のほとんどの不動産を一手に扱っている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイアンブラ地区まで待ってください」　　　　　＊　アイアンブラ到着後、グライドは予想したよりいいと漏らした。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
