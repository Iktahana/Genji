    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arrangement (of music)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アレンジについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アレンジという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアレンジの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアレンジが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アレンジを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアレンジについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アレンジの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアレンジの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアレンジが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アレンジという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアレンジという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアレンジについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アレンジを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアレンジは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アレンジについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアレンジが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアレンジは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアレンジの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アレンジは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアレンジは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アレンジのシミュレーションなどやってみるには、なかなか役に立つはずだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざん文句を言ってからこういうのも何だが、楽譜書きとアレンジのシミュレーション程度には我が音楽活動にもコンピューターを使おうと思っているわけで、その節はやはりタイプライターよりは紙―ペン環境だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただコードを分解しただけの、なさけないヴォーカル・アレンジだが、いちおうコーラスの練習をしたので、各パート（といえるようなものではないが）の音をあたえたわけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おまえは、ひょっとしたら、いいアレンジャーなんじゃねえのか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、何より鋭敏な感覚と巧妙なるアレンジメントの才能こそ最も重宝なものであろう。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を腰に片っぽの肩を上げて爪立ちしたり、真直ぐに立って体操の真似をしたり、櫛を持ってきて髪を色々にアレンジしてみたり――そのうちにふふふと思い出し笑いをした。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなフォントを駆使し、自由自在に文字をアレンジしながらイメージ通りの文書を作れるようにしようとすれば、一つ一つの文字をビットマップ上のグラフィックスとして扱う形をとらざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西がアレンジした日本電気版のアルトの子供に間に合わせるだけでなく、本命であるＰＣの操作環境の未来を抑えるという譲ることのできない一線を守り抜くために、ゲイツはインターフェイスマネージャーの早急な開発を指示した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸善で、クロポトキンのリアリーテーとアイジイアルス of ロシアン・リテラチューアと云うのその他を見たいので、ついでに近藤さんに会おうとアレンジする。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリンスキー、踊そのものはクラシックのテクニックで上手だが、眠れる美人、アレンジがつまらず、衣裳も色彩のロー費をして居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいレーニンの肖像が、まるでフランス流に細そり、軽くアレンジされた鎌と槌の間について居て、まわりには、桃色のプラスターでギリシアの仮面や、牧笛などが装飾だ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のものをアレンジすることを嫌う私は、すべてオリージナルでやった。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その芝居の音楽を作曲し、弟にトランペットをふかすこと、太鼓のアレンジ。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の日常生活には、さして交渉を保たないこの二つのものが、漸次に一つの情調の中に人工的な色と形のアレンジメントを創造する。",
              "citation": {
                "source": "仙人掌と花火の鑑賞",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしたちは曲の演奏はもちろん、作詩、作曲、アレンジまで全部自分たちでやるし、マネージャーはいるけどアルバムやコンサートのプロデュースだってできたら自分たちでやるつもりなんです。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく女の子だけのバンドだと、アレンジができないとかプロデュースができないとか、とかく憎まれ口を叩かれるものですけど、あたしたちはすべての面で、男性のロックバンドが可能なことなら女性のロックバンドでも可能なんだってことを証明したいんですよ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は若い頃ハードロックのギタリストで鳴らした男で引退後はもっぱら裏方に回り、新人バンドの発掘と育成、レコーディングのプロデュース、ツアーのプロモーター関係を主な仕事としていたが、元ミュージシャンだったキャリアを生かしコンサートの音楽監督や曲のアレンジなども担当することがあった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で書くよりも人の書いたものを纒めて行く方が多いんですから、矢張り事務員に成り切らないと勤まりません」「使ってさえ戴ければ、必ず御指導に従って一生懸命にやります」「アレンジして行く仕事が主ですから、同輩との接触が緊密です。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コード進行を書きとりながら、どこをどうなおせばいいのか、ぼくは頭のなかでヘッド・アレンジをやっていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほら、ずっと前、夏のはじめに、コオ、あなたがはじめて『道草』に来たとき、私のうたった歌をヘッド・アレンジしてくれたでしょう。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コオにアレンジしてもらったのは、あとで譜面に書きなおしてもらったでしょ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっても素敵だと思って、気に入ってたわけ」「うん」「小川敬一にも、アレンジしてもらおうと思ってたのよ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小川のアレンジのほうが、気に入ったわけだ」「まあ、そうなのね」「なぜ『道草』にいるんだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのアレンジは、もとの歌の気持のとおりに、きちんと出来てるんだそうだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いまのとこ、乗気だよ」「アレンジャーとして、おまえがからむわけだ」「それはナミの勝手さ」「ふうん」「自分でつくった歌は、たくさんあると言っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのアレンジは、そんな気分をすっきりとひっぱり出してくれて、しかも、軽くはずむように、メリハリをつけてくれたのよ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "[83] おやすみ……寝ずの番をします　一八一九に作られたヴォードヴィル「夢遊病者」のロマンス、ギュスターブとセシルの二重唱の一部をアレンジしたものである。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
