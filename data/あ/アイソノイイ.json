      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "affable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛想のいいは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛想のいいが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛想のいいに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛想のいいが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛想のいいについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛想のいいについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛想のいいについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛想のいいが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛想のいいが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛想のいいは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛想のいいは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛想のいいを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛想のいいをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛想のいいが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛想のいいの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛想のいいを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛想のいいに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛想のいいについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛想のいいは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛想のいいを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "随分愛想のいいその男が、汽車に乗るや間もなく眠つてしまつたことは、なんとなくその夜学二年間の総計のやうな気がされて淋しいやうでないこともない。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、三河町の親分さん」と、女は立ち停まって愛想のいい笑顔をみせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく騒々しくって、どうもいけねえ」　そのうちに愛想のいい女房も出て来て、二人は二階の小座敷へ案内された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、客は正にそんな風な職業らしい愛想のいい微笑や言葉つきで挨拶した。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "と此の芸術家は、心の奥底に、そのゆるがぬ断定を蔵していて、表面は素知らぬ振りしてわが女房にも、また他の女にも、当らず触らずの愛想のいい態度で接していました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大變愛想のいい女で、私がバナナを喰べ終ると、犬を喰はぬかと言ふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たどたどしい私の土民語ではあるが、兎に角一応は先方にも通じるらしく、元来が愛想のいい彼等のこととて、大して可笑しくもなさそうな事を嬉しそうに笑いながら、老人は頗る上機嫌に見える。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は前の二人より余程愛想のいい・年齢も少しは上らしい男である。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大変愛想のいい女で、私がバナナを喰べ終ると、犬を喰わぬかと言う。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはその純潔な澄み切った心の鏡に、愛想のいい相手の鼻の表現の底に横たわる或るものがチラリチラリとうつるからで、いくら御機嫌を取っても誠意を示しても益反感を買うばかりとなる事すら珍らしくないのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子が、ハッと視線を上げると、思いがけなくも、路子の兄の準之助氏が、独り落ちつき払った愛想のいい物腰で、部屋の中へはいって来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズの愛想のいい声。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つには前にもいう通り、師匠の御新造が愛想のいい人で、蔭へまわって優しく労わってくれるので、それを力に我慢しているのもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都から到来の松茸の籠をみやげに持って半七老人をたずねると、愛想のいい老人はひどく喜んでくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも愛想のいい、もの柔らかな手つきだが、とにかく押しのけるのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔には、例の素っ気ない愛想のいい表情が浮んだ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりといつのまにか二進も三進もいかぬまでに自分を締めつけてしまった、逢えば愛想のいい、金にかけてはしかし糞虫のようにきたない大山の親爺のことであった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年は四十かな……もう少し出てるかな、何にしてもめつたに愛想のいいおやぢだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌の立派な、大層愛想のいい、怜悧な若者で、同僚の受けも甚だよかった。",
              "citation": {
                "source": "忠五郎のはなし",
                "author": "THE STORY OF CHUGORO",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に立って誰れかれへ挨拶をしている笑窪のよった愛想のいい洋装の婦人は、写真で見かけたことのある奥住女史に相違なかった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前の、愛想のいい面立ち、いかにも優しい魅力にとんだ仕草などを、しみじみと眺めながら、娘たちが騒ぎ立てるのも無理がないと思った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "知事は彼のことを、誠に心掛けの好い男だと言い、検事は――道理を弁えた男だと評し、憲兵大佐は――学者だと褒め、裁判所長は――なかなか物知りで、尊敬すべき人物だと持ちあげ、警察部長は――尊敬すべくまた愛すべき男だと讃え、警察部長の細君は――とても優しくて、愛想のいい方だと言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、まったく見あげた、また実に愛想のいい人物でしょう？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今しがた女主人が顔を出した扉の隙間からちょっと覗いてみて、彼女がお茶のテーブルに坐っているのを見とどけると、ニコニコと如何にも愛想のいい顔つきで、そこへ入って行った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう言って彼は、知事が手ずから刺繍をした財布などを証拠にあげて、愛想のいい彼の顔つきをしきりに褒めそやした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "知事夫人は気持よく首を振りながら、愛想のいい、ちょっと皮肉な声で、『おや、パーウェル・イワーノヴィッチ、ようこそまあ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛想のいい子供なんて拵えたって、下らなかないの」　久保は、家庭のない、健康のない、慰めのない、自分の生活の苦痛を、持ち前の強情さに還元して、その力で子供も同僚も押して行くらしく思えた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから決して愛想のいい方で無いのが、殊に御機嫌斜めだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなさま」　にこやかに笑って、あいそのいい応対ぶり、さながらにすべすべとしたぬれ岩をでもつかむようでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あいそのいい声をかける者もあった。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
