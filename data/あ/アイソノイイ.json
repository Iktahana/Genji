[
  {
    "uuid": "a7e45533-24a5-5031-8181-790c0bf9471a",
    "entry": "愛想のいい",
    "reading": {
      "primary": "あいそのいい",
      "alternatives": [
        "あいそのよい"
      ],
      "is_heteronym": true
    },
    "grammar": {
