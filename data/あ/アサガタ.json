    "definitions": [
      {
        "index": 1,
        "gloss": "early morning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝方の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その同じ季節風が朝方には陸風と打消し合って朝凪を現出することになるのである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜、今朝方だ※がな、火ぁ消でらたな、覚だが。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今朝方の新聞であの老人夫婦が殺されたと知つて誠に驚いとる譯です。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今朝方思いがけないおくみとの盃。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今朝方からなんだか風邪にかかったのですか、頭痛がして苦しいものですからこんなふうで失礼します」　などと源氏は言うのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた坊主は終夜休まず走って朝方｜荘官方へ著き、怪しからぬ屠家へ宿った、同伴は続いて来ぬから殺されたは必定と訴え出たので、荘主フォルス卿、急ぎ人を馳せて検察せしむると右の始末と、聞いた者一人も泣かずに済んだと、後日フォルス卿がフランシス一世王の母アグレームン女公の臍に茶を沸かしめて語った由。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冬空にむかって北国の南朝方が又もや頭をもたげたとかいうので、きのうも今日もその注進で忙がしい。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでも北国の南朝方がこの頃ふたたび頭をもたげ出したという噂が出た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の両輪を失った南朝方がいかに燥っても狂っても、どうなるものではないと、どの人もみな楽観しているらしかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの敵は新田の一族でもない、楠の残党でもない、南朝方でもない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝方々お歩きになつて見ると可いわ。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝方は、また二寸からの減水で、いよいよ車は水が呑めなくなりましたが、お心はたしかであつて下さいよ。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「征東大将軍｜宗良親王、信濃におわしたので信濃宮、そのお方のご遺跡をはじめとし、南朝方の諸将の遺跡が、随分信濃にはあるようでござる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――亭主、さつき帰つたシリア人は、この店先きには何時も斯んなに具合の好い雨が降るので、それで、朝方までも斯んなに客がたて込んでゐるんだらう……なんて呟いてゐたよ。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し経つと、あの噴水の傍らにきまつて現はれるウルービノ生れの花売娘を見たいばかりで、俺たちが朝方まで斯うして居残つてゐるのだ！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、朝方からばかに冷えても來てゐたので、駿介は、「お父つあん、今日は休んだらどうですか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様は今朝方、旦那様とともに五時十五分、チャリング・クロス発大陸行の汽車でお発ちになりました。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝方から註文がまたこない参りまして、……」執事は紙包を画家の前に押し並べた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝方までは確に啼いてゐましたつけが……」浅之丞は臍のまはりを指先で押へてみた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして蓋を開けたと思ふと、急に変な顔をして、じつと内部を見てゐたが、暫くすると気もない顔で、「今朝方あまり食べ過したものか、どうも食気がなくて困る。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとある朝｜夙く――あいにくにもちょうど葉子が下宿の部屋を一晩明けた朝方に、電話がかかって来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして朝方までいらいらしい神経の興奮しきっている男を、心から憎く浅猿しく思った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は仲間と一緒に請負ひの入札に行つた筈だと、晴代が思ひこんでゐると、朝方になつて裏口の戸を叩いたり、又は誰々と田舎へ山を見に行くと行つて、二日も三日も何処かにしけ込んでゐたりした。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴蘭で雑炊を食べてから、妓楼へ押し上つたのだつたが、花魁の部屋で、身のうへ話をきいてゐるうちにいつか夜が更けて、晴代は朝方ちかい三時頃に、そつと其処を脱け出し引手茶屋のお辰を呼びおこし、そこに泊めてもらつたことから、彼女のカフヱ勤めも、母に知れてしまつたのだつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が朝方止んだので大丈夫だと思って出たが、どんより空が曇っていたのが悪かったらしい。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにその頃は眠ったら駄目だと思っていたので、大声で歌を唄いつづけたため朝方には全くふらふらになってしまった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "降雪が夜中に止むと朝方には山の中腹に霧が立ち込めていることが多い。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち降雪が朝方か夜中に止んだ場合は、翌日太陽が出るとぐんぐん気温が上るから、明るくなってから出発すれば危険な粉雪雪崩に逢うことがないし、夕方雪が止んだ場合はすぐ出かけるのは危険だから相当時間をおいて、朝方出発するように気をつけなければならない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
