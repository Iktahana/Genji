    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山の中で、雪を売るということが、一方の室で、シトロンやミルクキャラメルを売っているのに対して、いかにも原始的で、室でやりそうな商いではないか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "七之助は魚商で、盤台をかついで毎日方々の得意先を売りあるいていたが、今年｜二十歳になる若いものが見得も振りもかまわずに真っ黒になって稼いでいるので、棒手振りの小商いながらもひどい不自由をすることもなくて、母子ふたりが水いらずで仲よく暮していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからと言って商いが少ないと言うわけではない。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道から取付きの石段を上って行くと両側に商い店が並んでいる。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼に河岸からみるとこの商い店たちは十七世紀の女の輿車のような派手な外側に見えた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま親しくこう近寄ってみると平凡な普通の商い店であることが判る。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、手前商いまするのは、ラジーンと申して、金山鉱山におきまして金を溶かしまする処の、炉壺にいたしまするのを使って製造いたしました、口金の保助器は内務省お届済みの専売特許品、御使用の方法は唯今お目に懸けまするが、安全口金、一名火事知らずと申しまして、」「何だ、何だ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ出しても偽物でございますが、手前商いまする銀流しを少々、」と言いかけて、膝に着いた手を後へ引き、煙管を差置いて箱の中の粉を一捻し、指を仰向けて、前へ出して、つらりと見せた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題に触れるのは、お桂ちゃんの母親で、もう一昨年頃｜故人の数に入ったが、照降町の背負商いから、やがて宗右衛門町の角地面に問屋となるまで、その大島屋の身代八分は、その人の働きだったと言う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "在原夫人は第三区の受持にて、毛糸の編物を商いたまう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうでなくて、いかに悲痛な折からでも、若い女が商いに出てまで、客の前で紙を絞るほど涙を流すのはちと情に過ぎる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――初女房、花嫁ぶりの商いはこれで分った――「ちゃんと金子を突いたでねえから、抱えぬしの方で承知しねえだよ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人　　東京でつまらない商いをしていましたが、それももう止めてしまって……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめてから三月程経ち、切れた電球千個を一個一銭の十円で電灯会社から買取り、五会の古電球屋に持って行くと、児子はん、あんたは商い下手や。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころになると父の店もやや調い、棚の前通りにズックの学生靴や捲ゲートル、水筒にランドセルなど学生向きのものも並べてぼつぼつ商いもあり、滝に打たれたせいか父の頭も軽くなり、仕事に坐ることもできた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "早急の場合仮に越して来た請地では店も張れず、どこか商いの利く処に一軒、権利を買わせるのにも相当の金が必要だった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻船業は繁昌するので、その廻船によって商いする問屋はだんだん殖え、大阪で二十四組、江戸で十組にもなった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といろいろの世界を股にかける広い広い大きな渡海商いの世界から見ましょうなら、何人が斬れるでも無い一本の刀で癇癪の腹を癒そうとし、時節到来の暁は未練なく死のうまでよと、身を諦めて居らるる仁有らば、いさぎよくはござれど狭い、小さい、見て居らるる世界が小さく限られて、自然と好みも小さいかと存ずる。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時主人は改めて大きくにッたりと笑って、其眼は客を正目に見ながら、「如何にも手広い渡海商いは、まことに心地よいことでござろう。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃ、何でさ、ええ、ちょいとその気になりゃなッたがね、商いになんか行くもんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日置き、三日｜置に参って、お山の花を頂いては、里へ持って出て商います、丁ど唯今が種々な花盛。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいまから四十年くらいまえ、村の一文｜商いやが、坂谷まで油菓子の仕入れにいった帰り、ろっかん［＃「ろっかん」に傍点」山のきつねにばかされて、まいごになったという事件でありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、村の人びとは、かねやたいこを鳴らして、山や谷をさがして歩き、ついに、泉谷の泉の中で、ももひきを頭にかむってがつがつふるえながら、「これはええ湯じゃ、ええかげんじゃ」といっている一文商いやを見つけ出すことができたのでありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいまから四十年くらいまえ、村の一文｜商いやが、坂谷まで油菓子の仕入れにいった帰り、ろっかん山のきつねにばかされて、まいごになったという事件でありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この茂助はお岩の家へも商いに来ていたのでお岩とも親しかった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸の賑かな商い店の中に混って釣船宿が二軒、鄙びて居ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上の商いの常として、気軽るに、癪に触ることも受け流し、如才なく客の多情へ下手につけ入って行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子の日本橋でのあきないは非常に少なかった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきないはそれだけであった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、かべというかべには、大きな絵がいくつもかざってあって、いくら見ていても、あきないくらいでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
