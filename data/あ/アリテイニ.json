    "definitions": [
      {
        "index": 1,
        "gloss": "as it is",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り体にについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り体にという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り体にの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り体にが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り体にを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り体にについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り体にの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り体にの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り体にが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り体にという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り体にという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り体にについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り体にを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り体には複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り体にについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り体にが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り体には重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り体にの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り体には様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り体には興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "有り体に云うと前述の錦絵は日本所産の芸術作品の中でもかなりに俗受け専門の低級浅薄なものであるが、それでもその中に含まれている画家と、彫刻師と、印刷者の苦心は、外国一流の芸術家たちを刺戟して、新生面を打開させるだけの偉大深刻な尖鋭さをもっている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り体に云えば、同伴客昼夜宿泊所又は仲介業とでも云うべきで、東京市中にいくらあるか知れぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな事さえして置かなければ、何も、こうまどわずに有り体に云ってすがられるものをと、下らない事に、先の気を悪くする様な事をした娘が小憎らしかった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうならさうと有り体に、いふてくれたらよいものを。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り体に言えば、機転と気配りが足らなかったのかもしれない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、隠密を命じられて、看破されて帰る奴が、実は、云々と、自分の失策を有り体に報告するはずもない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むずかしく言えば一種霊活な批評眼を備えていた人、ありていに言えば天稟の直覚力が鋭利である上に、郷党が不思議がればいよいよ自分もよけいに人の気質、人の運命などに注意して見るようになり、それがおもしろくなり、自慢になり、ついに熟練になったのである。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが悪い、ありていに白状しな、と出刃打ちの野郎を極め付けてやりまさあ」　渠の鼻息はすこぶる暴らかなりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていにいえば、この「起ち上ろうとする」もしくは「起ち上りつつある」――更に「起ち上った」大阪の表情のあえかな明るさに、よしんばそれがそこはかとなき表情であるにせよ私は私なりに興奮したのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに言えば、小沢の心の底には、既にその娘への、ある種の（といってもいい位複雑な）関心がひそかに湧いていた――その関心があるために、もう娘の心理が解らなくなってしまったのかも知れない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに言えば、劇団の脚本に当選した脚本なのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「近所の風呂屋で下足番してました」　ありていに答えた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに言うと、一番末の娘（といってももう三十歳だが）の持子が、姙娠したのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そんな事情をありていに章三に言ったものかどうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに事情を打ち明ければ、かえってあらぬ疑いを掛けられるようなものだから、十番館の朋輩にも頼めない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "登勢の顔をにらんだので、驚いて見なかった旨ありていに言うと、五十吉はいや見たといってきかず、二、三度押し問答の末、見たか見ぬか、開けてみりゃ判ると、五十吉が風呂敷包みを開けたとたん、出てきた人形が口をあいて、見たな、といきなり不気味な声で叫んだので、登勢は肝をつぶした。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに言うと、ひとつにはおれの弥次馬根性がそうさせたのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百円はおろか五円の金もおまへんわ」　と、わざと大阪弁をつかって、ありていに断ると、姉の亭主は、「――そうか、そりゃ、残念だ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいや遅刻したのではない、点呼令状の指定する時間前に到着したのである旨をありていに述べた。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ありていに言えば、その小説で描いた坂田は私であったのだ。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに、云ったらどうだ」　越前は、長吉が金をやった相手に迷惑がかかるのを怖れてかくしているのだと思って、そう云った。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに、云って見たらどうだ」「こんなケチな野郎に、たいした事は、出来ません。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ありていに言えば、豹一はその写真に腹を立ててしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千箱だと一万円ですね」「今買うて置かれたら、来年また上りますから結局の所……」「しかし僕は一万円も持っていませんよ」　当にしていた印税を持って来てくれる筈の男が、これも生活に困って使い込んでしまったのか途中で雲隠れしているのだと、ありていに言うと、老訓導は急に顔を赧くした。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ありていに申し立てろ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "当下屋敷に勤番中と聞いた霧島京弥殿が行方知れずになった由承わったゆえ、取調べに参ったのじゃ、知れる限りの事をありていに申せ」「はっ、申します……、申します。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、ではこの通り自由に致してつかわしたゆえ、なにもかもありていに申せ。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さ、権右衛門、上には目のある者も、慈悲を持つ者もあるゆえ、ありていに申すがよいぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうしてたき火にあたためさせてくださったご慈悲深さといい、いずれただのおかたではあるまいと存じていましたが、右門のだんなさまだったら、しょせん何もかももうお見のがしはなさりますまいゆえ、ありていに申し上げますでござりましょう」「さようか、神妙ないたりじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに申し立つるべし」　差しつけたのを見て、にやりと笑うと、松長がじつに達筆にさらさらと書きしたためました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
