    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese yew (Taxus cuspidata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日蘭について考えている。",
              "source": "幻辞"
            },
            {
              "text": "蘭という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は蘭の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には蘭が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "蘭を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは蘭について学習した。",
              "source": "幻辞"
            },
            {
              "text": "蘭の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は蘭の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では蘭が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "蘭という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に蘭という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では蘭についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "蘭を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると蘭は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "蘭について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では蘭が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に蘭は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により蘭の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "蘭は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に蘭は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "此の十九世期の一仏蘭西女、此のフェイドオ劇場の一女優、此の巡業家の妻、此の子供を育てるに実に良心的でやさしさ此の上もなかつた一小市民――それがコリンヌ風な意味ででもサッフォ風な意味ででも抒情的な詩人であつたといふわけである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルビエールは、ヴ※ルレーヌの有名な批評集、『生得の詩人達（〔Poe`tes maudits〕）』（五人の詩人が挙げられてゐる）にも出てゐて、仏蘭西では知れ渡つた詩人である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川弥太郎、酒井米子、花井蘭子などの芝居であった。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に西洋の子供たち、科學の先進國たる獨逸や佛蘭西の子供たちでさへ、今尚好んで讀んでるものは、グリムやアンデルセンの童話であり、森の妖精や魔法使の話なのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に獨逸、佛蘭西等の如く、世界で最も科學の發達してゐる國の子供は、最もよくフアンタジイのお伽話を好む子供であり、したがつてまた秀れた童話作家を、多分に所有してゐる國なのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀口大學君は、仏蘭西語の訳詩者として定評がある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードレエルは、ポオを仏蘭西人に正価で売つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ち文化の余裕といふものであり、昔の日本の江戸や、今の仏蘭西の巴里などで、この種の閑人倶楽部が市中の至る所に設備されてるのは、文化が長い伝統によつて、余裕性を多分にもつてる証左である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時一人の家来があはたゞしく王の前に参り「たゞ今二人の蘭人がこれに見えて、王に戦勝の祝の品を持つて来たと申して居ます。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源には二人の蘭人とは誰と誰であるかゞわかつて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年前に謝源がこの沖合で難破した蘭人の二人を家来の救ふて来たのを、世話してやつたことがあつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キツトその蘭人があれから先づ己の国に帰つて又日本に来る途中で自分の戦勝を聞き、取り敢へず祝の品を持つて来たのだらうと思つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその蘭人の恩を忘れぬ美しい心が又となく嬉しく思はれた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してあの蘭人であつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人はやがて紫の布に包んだ祝の品を恭しく差し出した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はその地図を蘭人に示して「もそつと、前に進んでこれを説明して呉れぬか」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は地図を下に置いて蘭人の説明を待つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い方の蘭人はスラスラ説明をして行つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い蘭人は尚説明をし続けて行つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はやがて蘭人が指さして呉れる大きな国を想像して居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人は少しためらつて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその蘭人の為に土足のまゝで鼻柱を挫かれたやうな思ひがした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の蘭人の言葉は彼にとつては致命的な侮辱であつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてキツト二人の蘭人を見つめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人達はあまりに変つた王の様子にタヾ恐ろしさの為に震つてばかり居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血ばしつたまなこで蘭人をヂツとにらめつけて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝあつて謝源は何と思つたか丈の高い方の蘭人に彼の大杯をグイツと差しのべて「飲んで見ろ」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蘭人はさすがに狼狽した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際蘭人達は日本酒、殊にアルコール分の強い泡盛は飲めなかつたのである。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしのやうな小国の王の杯は受けぬと言ふのか、恩知らず奴ツ」彼はこう叫ぶやいなや、その大杯を丈の高い蘭人の額にハツシとぶつけた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
