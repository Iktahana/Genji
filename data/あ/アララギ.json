[
  {
    "uuid": "c3279f1e-8aa2-5808-8822-606f4a258aad",
    "entry": "蘭",
    "reading": {
      "primary": "あららぎ",
      "alternatives": [
        "アララギ"
      ],
      "is_heteronym": false
    },
    "grammar": {
