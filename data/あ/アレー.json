    "definitions": [
      {
        "index": 1,
        "gloss": "alley",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アレーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アレーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアレーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアレーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アレーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアレーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アレーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアレーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアレーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アレーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアレーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアレーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アレーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアレーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アレーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアレーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアレーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアレーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アレーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアレーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この豚野郎……証拠があるぞッ……」「……証拠がある筈はないぞ……鳥が勝手に云ったんだから……」「……ウヌッ……」「……アレーッ……」　桃の刺青はイキナリ土足で縁側に飛び上ろうとしたが、グイと若旦那に突き落された。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろこの船の中には女は二人ぎりだからお互いです」　とあまりなめらかにいってのけたので、妻の前でもはばかるように今度は態度を改めながら事務長に向かって、「チャイニース・ステアレージには何人ほどいますか日本の女は」　と問いかけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女『アノナハーン、アエヅダケァガナハーン、昨日スアレー、彼ノ人アナーハン。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女『アノナハーン、アェヅダケァガナハーン、昨日スアレー、彼ノ人アナーハン。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アレーコ、若いジプシー。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とその時、お豊さんは「アレー」と一声、逃げだそうとしましたが、曲者はとびかかって手拭いで手早く首を絞めましたので、お豊さんは、蒲団の外へ半身をのりだし、どたりと倒れました。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュワン・アレーに定められた教授の宅へは私も時々伺ったが、そこにドイツ文学の古典の全集がぎっしり並んでいたのが特に私の注意を惹いた。",
              "citation": {
                "source": "ハイデッゲル教授の想い出",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリーン・アレーズという十六歳の少女に暴行を加えた後殺害。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本事件はエレーナ・アレークサンドロヴナ・パタキンによって、チホーン・アルフィモヴィッチ・グリーゼルに対して提起された養育費請求に関する訴訟です」　爺め！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレーと来りゃこっちのものだ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アレーッ……どなたか！",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく主張し得る道徳的根拠をエアレーベンしたるものを生の信者と呼ぶならば、私は生の信者として生きたい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "文「姦婦助けは置かん」　と云いながらツカ／＼と立って表の戸を締めたから、　あ「アレー」　と云って逃げようとするおあさの髻を取って、二畳の座敷へ引摺り込み、隔の襖を閉てましたが、これから如何なりましょうか、次回に述べます。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も段々と更け、以前のお竹蔵前で当今交番所のある所から割下水の方へ掛りますと、女の金切声で、「アレー人殺し／＼」というから、角右衞門は気が付き向うを屹と見ますると、一人の悪者が島田髷の女を捕えて打擲するのみならず、娘の持ったる包を引攫って逃げ行きました。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ていたおえいは驚いて、アレーと云いながら逃出しますと、馬は尚更暴れておえいを追掛けて、背後からおえいの髷を囓えて後へ引倒して、花嫁の美くしゅう濃てりとお粉粧をした顔を馬がモリ／＼ッと噛みましたから、これは全く馬が多助の讎を討ったようなものでございます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アレース（ラテン名マース）ヂュウスの子、殺戮、鬪爭の神。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ来いッ――」　……と躍りだしてはみたが、そこには思いもよらず――「アレーッ」　という若い女の悲鳴があった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のふちのアレーを、ラウフシュテークの橋へ出て、ホーフガルテンに入った、高山植物園があったが、やっと芽が出たところで、花はまるで、咲いてない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々アメリカで行われていた千五百｜米のインドアレース（陸上）なども、オリムピックのレース以上に豪華な大レースを展開するのが例で、こういうレースの在り方は選手がプロ化する危険はあるが、スポーツ本来としては、このように個人的に争わるべき性質のものだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "パアレーの『万国史』。",
              "citation": {
                "source": "十六、七のころ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害がもっとも酷く起きたシャルロット・ロウ、ラム・アレーおよびシルヴァー・ストリートだけを述べれば充分である。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろで日疋がアレーと悲鳴をあげた。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かかるべしとはしらつゆの、草踏みしだき庭伝い、忍びよったる盛遠は、月こそ冴ゆれ恋の闇、キャッー　あれ――、あなた助けて――、アレー武さんが仙ちゃんを――、あなた！",
              "citation": {
                "source": "深夜の客",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「アレー、助けて！",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『友よ、ダナオイ諸勇士よ、神アレースの部將等よ、　110見よ、クロニオーン、運命の非なるに我を屈せしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ傳令の使者をして青銅よろふアカイアの衆水陣に集むべく聲朗かに宣らしめよ、われ亦一齊連れ立ちてアカイア陣に赴きて急にアレース、勇猛の軍の神を目醒まさむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊アガメムノーン、其中に頭と眼とは雷霆の神明ヂュウス見る如し、腰はアレース、胸許はポセードーンのそれに似つ、百千群がる牧の中、すぐれて目だつ牛王の　480雄々しく列を擢んずる姿も斯くや、陣中に此日此時百千の勇將中に赫耀と、アートレ，デース神明の惠みに影を拔き出でぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスプレドーン、ミニエーのオルコメノスに住める族、將はアレース生める二子、アスカラプォスとヤルメノス、その誕生のゆかり聞け、アゼーオスの子アクトール、其｜家にむかし無垢の處女アスチオケーは樓の上昇り、軍神アレースと私かに契り生むところ、515三十艘の兵船は彼らをのせて進み來ぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬪志はげしきアバンテス、彼等の領はユウボイア、カルキス及びエレトリア、ヒースチアイア葡萄の地、ケーリントスの港市、更にヂオスの高き都市、更に其領カリストス、更に其郷スチュラの地、エレプェーノール（その父はカルコードーン）アレースを　540祖先となして猛勇のアバンテス族導きぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
