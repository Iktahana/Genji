        "examples": {
          "standard": [
            {
              "text": "私は毎日あんだけについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんだけという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんだけの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんだけが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんだけを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんだけについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんだけの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんだけの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんだけが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんだけという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんだけという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんだけについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんだけを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんだけは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんだけについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんだけが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんだけは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんだけの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんだけは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんだけは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんだけ部屋があまってんだから、ダメだなんて、いうわけないだろ」５ラジオをつけて、グルッとダイアルを回すたちまちダンスのはじまりだ〈ダンス、ダンス、ダンス〉ビーチボーイズ　ＫＷＴＳの「開局」は、六月二十日に決まった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけやりたい放題やって、被害者はないぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「駄目だよ」「なぜさ――おととい玉子あんだけ売ったんじゃないか」「またそんなこという！",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、あそこに、ほら白い屋根が見えんだろう、そいから深川八幡様だ、あそことあそこの間にあんだけえどなあ……」彼は何とかして適確にそれを示したいと伸びたり縮んだりしたが、結局どれもこれも同じ黒い屋根でいっしょくたになり、ちえっと舌打ちして「あんまり小っちゃくて見えねんだよ、先生！",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中年男、ひげ面でガクリとうなずく）……こねえだの寄合いで、あんだけ皆の衆から言われてもなあ？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓　なに、俺があんだけ言ってやったんだから、それでええのよ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "居ないものが、あんだけ呼びりん鳴らすのに、なんで誰も出て来ない？",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけの長唄ってものが叩き込んであるんだから、あれで何とか身は立たないのかしら。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう少し待ってくれとわてがこれ程言うているのに、あんだけ手広く事業をなさっている弁理士の本田一平さんともあろうもんが、そればっかりの金でそんなに――。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦一　だつて、外の連中は父つあんだけほつぽり出して行つちまつたぢやないか？",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊　だけんど、どうしてまた、あんだけしっかりした人が、選りによってそんなお嬢さんなどに思い附いたもんだろうねえ？",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだねえか、先ず第一番にこの俺がお前におっ惚れてよ、あんだけ笹屋に通いづめて言うこときけ言うこときけで、いくらそ言っても聞かねえで、四十八センチぐれえの肱鉄砲くらわしときながらよ、そのお前が、どこが好いだかこの金吾に惚れちゃって、さていくら通って来ても、様子がいまだにモノにならねえくせえや。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけキッパリなにして話をつけたのに、……だいたい、あんな奴のことを私が今になってまで、忘れないでいると思ってんの？",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それが、しかし三人であんだけ掘って……すると、このほかに、もっと地盤のやわらかい――か、この、外までの地盤の薄いところは――思い出せねえこたあねえだろう？",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がたくさん死ぬから、戦争はザンコクだと普通いっているけど、それはそうにゃ違いないけれど――もっとザンコクなことは、あんだけの戦争が終った後になっても、人間が生きて行かなくちゃならないということかも知れない。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう――こうなりゃ、もう――俺あ、こん中で戦争中、血みどろになって――あんだけ、ひでえ目に逢いながら、生きのびた人間だ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あんだけの、つらい目をしても、死にはしなかった。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……てめえが、あんだけイヤがっていた戦争を――しかも、ただ引っぱり出されただけの戦争を、まるで俺が自分でおっぱじめたような気になった。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のイノチも、お前のあんだけの気持も、かけがえのない、貴重なものだったんだ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんのことをあんだけ気にかけている弟と言うのは見たことがありませんね。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そめ　お晩で――馬方　又、泣いてるだな、こねえな所で――チェッ、しょうのねえ婆さまだのう――だから、朝逢った時、あんだけ俺が言ってやったじゃねえかよ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森山　また、よりによつて隣り同士であんだけ仲の悪い芹沢と喜十さん、分譲地まで隣り合つちまつたもんだ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（身をひるがえして扉を出て行く）せい　ですけども、あんだけのパンを。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけのファシズム勢力におさえつけられて、たえず生命の危険にさらされていたんだ、僕たちは！",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんたい、此処にあんだけ永いこと居て、差入れ一つねえのに、断食するなんて、タダのもんにゃ出来ねえことだ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、あなたの兄さんなど、あんな立派な人格の――治子　そいじゃ、そいじゃ戦争中の友吉さんが、神さまを守って、あんだけイジメられても、なにしていらしったのは、なあに？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりめえだあ、つもっても見な、あんだけ大きなイクサをして、ペチャペチャに負けたんだあね。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだけの兵隊が、おれたちのために死んだんだぜ？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、最初先生から、あんだけとめられたのに、自分でだまつて入つてしまつといて、今ごろになつてこんな事を言つて來るなんて、自分かつてだと思うんですけど――いえ、後悔しているんじやありませんの。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子さんのお宅ではお金はたんとありまっさかい、千円ぐらい何でもなかったのんですやろけど、おおびらに寄附金｜募るのんなら聞えてるが、一時融通してくれというのんおかしい、それにあんだけの校舎が千円のお金で修繕｜出来るはずもないし、分らん話やいうようなことで、お父様は断られたのんやそうですねん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
