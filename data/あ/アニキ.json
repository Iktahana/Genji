    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elder brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄貴について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄貴という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄貴の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄貴が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄貴を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄貴について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄貴の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄貴の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄貴が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄貴という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄貴という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄貴についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄貴を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄貴は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄貴について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄貴が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄貴は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄貴の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄貴は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄貴は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それこそ、兄貴の言葉ではないが、教育界にゐてそんなことをしたからこそ、失敗なので、あれで、當時の政黨にゐて動いてゐたなら、あるひは成功したのかも知れない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒達は彼を「兄貴」と呼んでゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の白痴も、件の評判の高かった頃、医者の内へ来た病人、その頃はまだ子供、朴訥な父親が附添い、髪の長い、兄貴がおぶって山から出て来た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴が造えて不当の利益を貪って居るのを、此の眼で見て知って居ながら、そんな酒とても飲まれません。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴は、まだあれでいいのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――兄貴は、その他にも何か言つたらうな。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴の烏も弟をかばう暇がなく、恋人同志もたびたびひどくぶっつかり合います。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一｜吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴はわらふ、「一吠えってもう何十万年を、きさまはぐうぐう寝てゐたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴はわらう、「一吠えってもう何十万年を、きさまはぐうぐう寝ていたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（まあそのへん）（よだかがあれの兄貴なの？",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏神様の御蔭なりゃあこそこげに気楽な一生が送れますので、福の神様が舞込んで来かかりますと、どうぞ他所様へ他所様へとお断り申上げますような事で、貧乏神から兄貴とも親分とも頼まれる心安さ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでともちゃんのハズの兄貴にあたるのが、ほんとうは俺たち五人の仲間の一人で、それがともちゃんに恋をして、貧乏と恋とのために業半ばにして死ぬことになるんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田の弟になる俺は生きて行くが、花田の兄貴なるほんとうの花田は死んだことにするんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで俺の弟は、兄貴の志をついで天才画家になるとしても、とにかく俺が死なねばならぬというのは悲壮な事実だよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺……じゃない、俺の兄貴の死に顔をちょっと見せてくれ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（石膏面を見せる）戸部　　俺の兄貴は醜男だったなあ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本　　おうい、ドモ又……と、あの、貴様のその上衣をよこせ、貴様の兄貴に着せるんだから。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴の烏も弟をかばふ暇がなく、恋人同志もたびたびひどくぶつつかり合ひます。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば私の兄貴分の作家である。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奇妙な名前の男について述べる前に、しかし、作者は、その時、「やア、兄貴！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉を兄貴と呼んだ所を見れば、同じ掏摸仲間であろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉の傍へ寄って来ると、「兄貴、えらいこっちゃ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴をびっくりさせるのはむつかしいわい。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし兄貴はなんでこない何時もびっくりせえへんネやろな。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴殺生やぜ」　と、亀吉はなぐられた頬を押えながら、豹吉に言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、お前ら、兄貴知らんか」　亀吉は豹吉の居所をききに来たのだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あの掏摸さんだっか」　と、次郎と三郎は、昼間ハナヤで豹吉を兄貴と呼んでいたことを、想い出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴を探すのにキリキリ舞いしてるんや。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
