        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "悪意は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪意対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪意に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪意がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪意は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、悪意の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは悪意を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により悪意の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における悪意の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "悪意について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日悪意について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から悪意を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により悪意の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは悪意を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で悪意に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "悪意は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪意対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪意に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪意がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪意は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "晩年多少日本に幻滅を感じた時でさえも、他の外人が日本を悪意的に批評する時、いつも憤然として大に怒り、さながら自分の愛人を侮辱された時の騎士のごとく、鋭い反撃の槍をふるって突き当って行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、斯く信ずる私の上に、神の悪意の仕業とも見える事も起るであらう。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲で一寸序でに述べたいことは、「さうか、では悪意の仕業とも見えることがあつても、関心するには及ばないのだな」と考へ勝ちな人々が少くはない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、悪意の仕業とも見える事が起ることもあるといふことは、起つても好いといふことではない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち、私は神の悪意の仕業とも見える事――不幸や災害が起る毎に嘆かずにはゐられない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ貴兄が特異で在ることと、僕が論文を纏める才にひどく乏しい上に論文の大体の相手を持たないために随分変なものかも知れないが、単なる好意で書いたものでも単なる悪意で書いたものでもないのだから、　読んだら返事を願ひます。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「社長は別に悪意を持つてるわけぢやないんだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、読者を欺すという悪意は少しもなくて、しかも結果において読者を欺すのが新聞のテクニックなのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは無責任ないし悪意あるゴシップによって日常行われている現象である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が臘虎の外套に顔をうずめて銀色の夜半の灯のもとを、二、三歩すすまないうちに、金格子の門衛室の扉がひらいて青馬のような近視眼鏡をかけた小肥なボッブの女が小走りにちかづくと、悪意のあることばで、「やあ、奥さん。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう場合に本人を素直に帰してよこすというのは、いかにも物の判った仕方で、先方に悪意のないことは能く判っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどこれは悪意で言ったのではなかったが、己を以て人を律するというもので、自分が遊びでも人も遊びと定まっている理はないのであった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ君のこの仕方は、悪意に解釈すれば私にとってあまり快くは思われない種類のものであった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ａ）尊厳がそこなわれた時の笑い、（Ｂ）人間の弱点があばかれた時の笑いなどは必ずしもこれを悪意な Schadenfreude とばかりは言われない。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「おもしろいな」というのは決して悪意に解釈してはならないと思った。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を悪意がないと云つても、法律は許さない。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪意は踴躍して渠を励ませり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心と悪意とは白糸の恃むべからざるを知りて、ついに迭いに闘いたりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと悪意でないことは判っていたが、供の又蔵は主人を突き倒されたのと、相手が小身者の子供であるという軽侮とで、その子供の襟髪を引っ掴んでいきなりぽかりぽかりなぐりつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "他のことはとにかく、あれが友人を陥入れるための、女らしい邪智の悪意で書いたものと解されては、僕として到底がまんできない。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クックという忍び笑いを入れて囁くように呼ぶ声は、揶揄い交りではあるが、決して悪意のあるものではなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君にだって悪意があるわけじゃ無いんだけど……。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまも、決して悪意でおっしゃっているのではないのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか悪意を持って、はるばるこんな田舎まで訪ねて来てくれる人もあるまい。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処では政宗に悪意が有った証は無いというのを公平とする。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪意の非難がウソなら、善意の奨励もウソである。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな事を云って、なぜ、貴下は、」　少し起返って、なお背向きに、「貴下にちっとも悪意を持っていない、こうして名誉も何も一所に捧げているような、」　と口惜しそうに、「私を苦しめようとなさるんだろうねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　お前、私の悪意ある呪詛でないのが知れたろう。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の悪意を感じます。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝に、無理矢理、劇場から引つぱり出され、さうして数枝の悪意ない、ちよつとした巫山戯た思ひつきが、高須をここへ連れこんだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
