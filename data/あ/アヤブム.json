        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日危ぶむについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は危ぶむの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には危ぶむが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは危ぶむについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は危ぶむの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では危ぶむが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に危ぶむという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では危ぶむについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると危ぶむは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では危ぶむが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に危ぶむは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により危ぶむの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "危ぶむは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に危ぶむは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いつのわれにはかわらじを、何とてさはあやまるや、世にただ一人なつかしき姉上までわが顔を見るごとに、気を確に、心を鎮めよ、と涙ながらいわるるにぞ、さてはいかにしてか、心の狂いしにはあらずやとわれとわが身を危ぶむようそのたびになりまさりて、果はまことにものくるわしくもなりもてゆくなる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来達はギェーッと今更ながら驚き危ぶむ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのわれにはかはらじを、何とてさはあやまるや、世にただ一人なつかしき姉上までわが顔を見るごとに、気を確に、心を鎮めよ、と涙ながらいはるるにぞ、さてはいかにしてか、心の狂ひしにはあらずやとわれとわが身を危ぶむやうそのたびになりまさりて、果はまことにものくるはしくもなりもてゆくなる。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば吾人民友子に対する誤解の生ぜんことを危ぶむなり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝ、あはれ、小やかに慎ましい寐姿は、藻脱の殻か、山に夢がさまよふなら、衝戻す鐘も聞えよ、と念じ危ぶむ程こそありけれ。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなわけで、文字春は津の国屋の運命を危ぶむばかりでなく、自分の身の上までが不安でならなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんでもよきは絲切つちまつたんだもの」　おつぎは危ぶむやうにして控へ目に聲を立てゝいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「消えん空なき」と尼君の歌った晩春の山の夕べに見た面影が思い出されて恋しいとともに、引き取って幻滅を感じるのではないかと危ぶむ心も源氏にはあった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠すこともできないので、林之助も正直に答えると、お此は危ぶむようにささやいた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、采女は少しく危ぶむように言った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父兄がその子弟に小説修業を危ぶむのは、さういふ場合を顧慮してゐるのである。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかったかな」と、泰親はまだ危ぶむような眼をしていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し文三が叔母の意見に負きたくないと思うも、叔母の心を汲分けて見れば道理な所もあるからと云い、叔母の苦り切ッた顔を見るも心苦しいからと云うは少分で、その多分は、全くそれが原因でお勢の事を断念らねばならぬように成行きはすまいかと危ぶむからで。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々ふと気が変って、此様な女に関係しては結果が面白くあるまいと危ぶむ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、叔父は立つ前にもそう言って、一人では道中が気遣われると言って危ぶむ母親や伯母に笑って言った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして出て来る取り次は年の頃六十程で、衣服も余ほど年を取って居る、此の向きではレペル先生というも余り世間に交際せぬ老人らしい、其の様な人が、どうして遠く英国に居る秀子を助ける事が出来ようと、余は初めて危ぶむ念を起したけれど、今は当って見る一方だ、余は唯「先生は御在宅ですか」と問うた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲には、年若い二人の結婚と出産を危ぶむ声もあったが、二人はともに歩むことを決意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼女は鏡を両手で持つたまま立ちあがると、俯むいてそれを覗きこみながら、ころびはしないかと危ぶむやうな、おつかなびつくりの歩調で、床ではなく、昨夜あの祭司の息子が真逆様にころげ落ちた、くだんの板の取りつけられた天井や、壺の並べてある棚を眼下に見おろしながら、部屋のなかを歩きまはるのであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "危ぶむ思いがきざしたとき、失った死に場所に対する深い悔恨がよみがえる。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう危ぶむ役人にむかい、そのときの阿賀妻はめずらしく血相をかえた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても先生は、自分を先生々々と呼ぶ少年の前途を危ぶむとともに、その危なつかしい前途にかゝりあつては堪らないと思ふ念に惱まされる事が多かつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　第一學校に通はせるにしても月々多額の出費だし、將來存外成功したにしても、なかなかお金にはなるまいといふのが、親として最も危ぶむ理由に外ならなかつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "四個の小世界はそれぞれに活動して、二たたび列車のなかに擦れ違ったまま、互の運命を自家の未来に危ぶむがごとく、また怪しまざるがごとく、測るべからざる明日の世界を擁して新橋の停車場に着く。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "危ぶむような、慰めるような笑が顔と共に浮いて来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、彼等が島村のことを危ぶむのも、尤もだと思うのだった。",
              "citation": {
                "source": "別れの辞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の歩く道には真紅の罌粟の花が、長い茎の項に咲き、その花がゆらゆらと揺れて、母の行くのを危ぶむように見えました。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、彼といへども、理窟が理窟どほりに行くかどうかを危ぶむくらゐの、現実を観る眼をもつてゐたのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "米人の偉大なる体格美を仰ぎ見て、我々の繊弱な素質を危ぶむごとくに、精神的低迷の瀬戸際に立たざるをえないのである。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、またのちほど」「いや、ちょっと待たれよ」　不意に横から呼びとめて、あやぶむように三宅平七が名人に念を押しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんに思えばおそろしい」「お前もその怖ろしい人にならるるのか」と、玉藻はあやぶむように男の顔をじっと見つめた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
