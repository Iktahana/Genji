        "examples": {
          "standard": [
            {
              "text": "来月から合気会の傘下にある道場で、合気道を習い始めることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合気会は、合気道創始者の植芝盛平によって設立された世界最大の合気道組織である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は長年の修行が認められ、ついに合気会本部から六段位を授与された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "毎年、日本武道館で開かれる合気会主催の全日本合気道演武大会は、多くの合気道家にとって一大イベントだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「この道場は合気会に所属していますか？」と入門希望者は尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合気会の指導員が海外に派遣され、世界各国での合気道普及に努めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合気会発行の段位証明書は、国際的にもその価値が認められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
