        "examples": {
          "standard": [
            {
              "text": "私は毎日アーベントについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーベントという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーベントの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーベントが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーベントを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーベントについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーベントの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーベントの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーベントが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーベントという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーベントという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーベントについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーベントを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーベントは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーベントについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーベントが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーベントは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーベントの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーベントは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーベントは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "映画アーベントなどという広告をよく新聞に見る。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベントという言葉を用いたのは明治の終りか大正の初めころ、帝大の山上御殿ではじめて開かれた哲学会のカント・アーベントあたりが最初であったろうと思う。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "カント・アーベントには相当に意味があるが、映画アーベントに至っては笑止の極みである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その終わりに近いあるアーベントのことだった。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はフンク博士の所でビーア・アーベント。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベント・グリューエンに燃えた八ヶ岳の連峰が、いつまでも見送ってくれていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師から大日までの山がアーベント・グリューエンに燃えて素敵だ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間、八ヶ岳、南の山等がアーベント・グリューエンに燃えていて嬉しかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立山の連峰がアーベント・グリューエンに燃えて素敵でした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師や黒岳―赤牛の尾根等がアーベント・グリューエンに燃えているのを眺めながら上ノ岳の小屋へ帰って行った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日ならとてもよい眺めで、南の方には弥陀ヶ原の広い高原を隔て大きく胸を張った薬師岳が実に雄大に見えるし、東の方には鳶山、鷲岳、鬼―竜王、天狗、別山等が見え、大日―早乙女等とともにアーベント・グリューエンに燃えている雄大な景色は立山に登った者に忘れ得ない印象を与える。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時に乗りかえて、湖水の南ぎしを、水はすぐ左手に、右には、冬枯れの牧場と板屋根の百姓家と、その上にのしかかる雪の、アーベントベルクの麓を廻って、半時間でインテルラーケンに着く。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると小屋は、忘れられたように雪の中に寂として、見渡す南の方、十里にわたる氷河は、人の生れなかった世をそのままにしんとして、彼方の空、ワリーゼル・アルペンにアーベント・グリューンが望まれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥーンの湖を渡る旅人の、眉にせまるアーベントベルクの黒木の森の上に、朝の日に燃えては、水底に眠る魚鱗の夢を破るかと、かっと中空にきらめく時、心無き旅人も、ちり気だつまでぞっとして、ふなばたにのり出して、じっと見つめる一座の山岳のあったのを忘れまい、彼のグロース・シュレックホルンである。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥーンの湖の北につづくベアテンベルクや、南岸のアーベントベルクの頂には、どす黒い雲が波のように揺れて、うみ岸のポプラの風は中々はげしかった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この静かな湖水のふちをあるいてゆくうちに、日はとっぷりと暮れて、ピッツ・ロサッチにあかあかと、アーベント・グリューンが仰がれた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュピーツを過ぎると、もう二十分で、アーベントベルクの樅の木立も、鮮な若芽が萌えて、そこに囲まれた野や畑も、冬来た時とはまるで国が異ったようだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベントベルクの麓、ハイムウェー・フルーの頂には、赤い小旗が風に飜って、ルーゲンパルクの、ユンクフラウ・ブリックにも国旗をかかげた、町の様子は、どうしても避暑地で、退屈そうには見えないが、いかにも用のなさそうな連中がぶらぶら通る。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベントベルクの頂上には、綿帽子をかぶせたように、昨日の雨は山では雪であったと見える。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむこうは、すぐアーベントベルクの絶壁になって、そことシンニゲプラッテの間には、ルーゲンパルクの真黒な樅の木立の後ろに、奥深く入り込んだ、うす暗いラウテルブルンネンのつき当りに、彼のユンクフラウの三山が仰がれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の半ばには小雨が降って、二日も三日もうすら寒い日ばかり続いたが、雨上りの山の色は、暗い日の生活のわびしさを一掃して、ゆるやかな、然し寂しい心もちを運んだ、雨雲の晴れてゆくアーベントベルクの頂は、真夏も白く、樅の梢に、雪を頂くことさえある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベントグリューンが消える頃、丘のあちこちに建てられたホテルには一斉にイルミネイションが輝り初める、そして村の楽隊の Berner-Marsch が大通りの坂道を城の方へ動いて行く時分には、村中の男女は手に手に赤地に白十字の国旗を染めた提灯をかざして、光の一団となって、静かに湖の方へ下りてゆく。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんなところでの通信をあつめたもので、中には支那に十年いたという米人記者アーベントの「支那通信」などもあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
