          "literary": [
            {
              "text": "妹から心づくしの浴衣と汗の結晶とを贈つてくれた、すなほに頂戴する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボタン一つ押し、ハンドルを廻すだけですむことを、一日中エイエイ苦労して、汗の結晶だの勤労のよろこびなどと、馬鹿げた話である。",
              "citation": {
                "source": "堕落論〔続堕落論〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
