    },
    "definitions": [
      {
        "index": 1,
        "gloss": "facing upward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　父は抛るやうに言つて手を裏へ廻して体を斜仰向けにした。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん仰向けに寝ていて描いたのだと思うがなかなか威勢のいい地図で、また頭のいい地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気紛れに、そこへ根を卸したような五葉松は、仰向けに川の方へ身を反らして、水と頷ずき合って、何か合図をしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎの小説が、中途までくると、私は、仰向けに寝転がつて、溢れる涙をそうつと、たもとでふいた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は仕事に疲れると、この縁へ出て仰向けに寝転び、都会の少し淀んだ青空を眺めながら、いろいろの空想をまどろみの夢に移し入れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側に向いている硝子窓から、工房の中が見えるのを、なるべく眼を外らして、縁側に出て仰向けに寝転ぶ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は、仰向けになって空を見ました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池に仰向けになって浮いていた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が自分の部屋にかえると隣の寝台にカーテンも引かないでペチ・コートのまま仰向けになったアダが、夢うつつにも寝床で寝るトア・ズン・ドルの女を再び見出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――………………　――………………　　　　　――――――――――――――――――――――――　クラブの化粧室に這入ると、ロップは××になって仰向けのまま寝てしまった。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし四家フユ子は英介氏の腕輪のなかに障害馬のように飛こむと、棕櫚の毛皮のような髪の毛を乱雑にカールした黄色い額の波打際を仰向けにして、ずるそうに彼にわらいかけた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きに寝ている彼女は枕を横にはずして、蒲団から少し乗り出したようになって仰向けに横たわっていたが、その結び髪は掻きむしられたようにおどろに乱れて、額をしかめて、唇をゆがめて、白ちゃけた舌を吐いて、最期の苦悶の痕がその死に顔にありありと刻まれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん、早く来てください」　近所の人達もおどろいて駈け付けると、娘のおみよは奥の六畳間に仰向けさまに倒れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ足が遅いだけならまだしも、わずかな紙の重みの下で、あたかも梁に押えられたように、仰向けになったりして藻掻かなければならないのだった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道連になった上人は、名古屋からこの越前敦賀の旅籠屋に来て、今しがた枕に就いた時まで、私が知ってる限り余り仰向けになったことのない、つまり傲然として物を見ない質の人物である。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると上人は頷いて、私は中年から仰向けに枕に就かぬのが癖で、寝るにもこのままではあるけれども目はまだなかなか冴えている、急に寐就かれないのはお前様とおんなじであろう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄じく嘶いて前足を両方｜中空へ翻したから、小さな親仁は仰向けに引くりかえった、ずどんどう、月夜に砂煙がぱっと立つ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、頤の下へ手をかけて、片手で持っていた単衣をふわりと投げて馬の目を蔽うが否や、兎は躍って、仰向けざまに身を翻し、妖気を籠めて朦朧とした月あかりに、前足の間に膚が挟ったと思うと、衣を脱して掻取りながら下腹をつと潜って横に抜けて出た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お聞き、」と涙声で、枕も上らぬ寝床の上の露草の、がッくりとして仰向けの淋い素顔に紅を含んだ、白い頬に、蒼みのさした、うつくしい、妹の、ばさばさした天神髷の崩れたのに、浅黄の手絡が解けかかって、透通るように真白で細い頸を、膝の上に抱いて、抱占めながら、頬摺していった。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ふうちに、最う茶の外套を着たまゝ、ごろりと仰向けに成つた旅客があつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吃驚して、取つて、すつと上へ引くと、引かれた友染は、其のまゝ、仰向けに、襟の白さを蔽ひ余るやうに、がつくりと席に寝た。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向けた茶わんとうつ向けた同じ茶わんとが同一物である事を自得するまでにはかなりな経験を重ねなければならぬ。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も小学生時代に学校の玄関のたたきの上で相撲をとって床の上に仰向けに倒され、後頭部をひどく打ったことがある。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして露台のデッキチェアーに仰向けになって植物図鑑をゆるゆる点検しながら今採って来た品種のアイデンチフィケーションに取りかかる。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　食うか食われるか　亀と亀とが角力をとって負けたほうが仰向けに引っくり返される。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代のある年の元旦に二三の同窓といっしょに諸先生の家へ年始回りをしていたとき、ある先生の門前まで来ると連れの一人が立ち止まって妙な顔をすると思ったら突然仰向けにそりかえって門松に倒れかかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男は仰向けになって、碧いああおい空をながめました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこで大学士はいゝ気になって、仰向けのまゝ手を振って、岩頸の講義をはじめ出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助は、仰向けになって空を見ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あおむけに寝かして心臓音を聞いてみた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
