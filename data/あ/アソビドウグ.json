          ],
          "literary": [
            {
              "text": "池川さんのお遊び道具の、あの釣船ばかりお漕ぎ遊ばす……」　お師匠さんは御存じだ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び道具は豊富で、コリントゲームだのルーレットだのわたくしには始めてゞ珍しいものゝ外にいろはかるたやトランプのような馴染のものもありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し御殿のやうに立派な少年の室には、あらゆる書物や遊び道具がすつかり備へられてあつたから退屈をするやうな事は決してなかつたのです。",
              "citation": {
                "source": "首相の思出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを遊び道具にしてたくせに」　倒れこむようにして、もうひとつのデッキチェアに慶一が躰を沈めた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々な遊び道具を疊の上へ無遠慮に開けた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、家にゐても何にも遊び道具がなくなつてしまつてお気の毒だわね。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに、あれが大事なら、稀には遊び道具位ゐ買つて呉れ――」「未だ抜かすか、こいつ奴！",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんぐりはそんな風にいろいろの遊び道具をわれわれに与えてくれた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵草紙屋では歌がるたも売る、十六むさしも売る、福笑いも売る、正月の室内の遊び道具はほとんどみなここに備わっていると云うわけであるから、子供のある人にかぎらず、歳晩年始の贈り物を求めるために絵草紙屋の前に立つ人は、朝から晩まで絶え間がなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」周子は、遊び道具の牌を手の平に転がしてゐた。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この遊び道具を好まなかつた。",
              "citation": {
                "source": "海棠の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械体操なら多少の離れ業が出来るにもかゝはらず、特にこの遊び道具が私には適してゐなかつた。",
              "citation": {
                "source": "海棠の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は尚そのほかにさまざまな、木で出來る遊び道具を作るつもりでゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本山の玉露・栄太郎の甘納豆・藤村の羊羹・玉木屋の佃煮・薬種一式・遊び道具各種。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "みのえは、自分の体の中で赤いものや青いものが上になったり下になったり、銀座の夜店で売っている色紙細工の気味悪い遊び道具のように、のたくり廻るのを感じた。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び道具としては、まことに面白いものであると思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して爺さんは、「うん」と幸福さうに答へて、女の子のために土産に買つて来た食べ物なり、遊び道具をそこへ置くのである。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の商品がその儘になっていると、それはすぐ遊び道具に役立ったし、きちんと板の間が片づいていると、静三は棚の方を見上げて「梅津商店」と屋号の入っている弓張提灯を取出したり、商品戸棚の抽斗を引抜いてみた。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あつちのウチぢや、酒と料理の外に、麻雀、碁将棋、トランプ、花フダ、遊び道具を取り揃へてお客が自分のクラブのやうに寛いだ落つきをもたせるやうにするんだな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正年間、僕が小学校のころは、朕という言葉は子供のたわむれの言葉でいわばそんな奇妙な言葉があるために天皇が子供たちの悪フザケに恰好の遊び道具となったようなものだった。",
              "citation": {
                "source": "邪教問答",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実質の伴わない架空な威厳、形式的な威厳によっては人は心服するはずはなく、あべこべに戯画となり、子供の遊び道具となる。",
              "citation": {
                "source": "邪教問答",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、そんな高価な玩具だの遊び道具は正文にとつて一種の贅沢物だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は、彼等の広い遊戯室に引揚げて来たのだが、そこは大広間に負けないほど大きくて、大小いろいろの遊び道具で一杯だった。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、子供達が住んでいた世界そのものが、一つの大きな遊び道具だったその頃には、まだおもちゃなどは一つも出来ていなかったでしょうから。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び道具も本もない疎開先の生活で、とくに連日の吹雪の夜など、子供たちはよく私に話をせがんだ。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と云ひ宗教と云ひ道徳と云ひ人生と云ふのは皆大きな遊び道具だ！",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は學校がすむと、一たんは家へかへり、それからすぐまた出直してくるのであつたが、それはカバンと草履との代りに、めいめい家から何か遊び道具を持ち出してくるためだつた。",
              "citation": {
                "source": "鼠",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その素木の積木が、その年の九月初め日本橋の三越の玩具部に売っていた唯一の子供たちの遊び道具であった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子には水遊び道具と切符遊び。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親がその恐ろしい鎖を見て、「まあ、私の子供にちょうどいい遊び道具だ、」と言ってそうさしたのだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
