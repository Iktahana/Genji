          "literary": [
            {
              "text": "ことばすずしく自分を揶揄するものであると取って、「やかましいっ」と最後には大喝を発して、顔にも、肩にも、腕にも、怒りの筋肉をもりあげ、全身をもって悪形の威厳を示した。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑は江戸期の文学の主要人物で、文学は通例若い女たちが読むので、多くの姑は悪形をもって目せられている。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
