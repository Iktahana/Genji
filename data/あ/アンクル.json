    },
    "definitions": [
      {
        "index": 1,
        "gloss": "uncle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンクルについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンクルという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンクルの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンクルが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンクルを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンクルについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンクルの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンクルの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンクルが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンクルという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンクルという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンクルについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンクルを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンクルは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンクルについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンクルが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンクルは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンクルの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンクルは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンクルは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暗褐色に赤に横縞のあるアンクル・サックス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は「アンクルトムス・ケビン」にて、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから、寮中どこにでもあるスピーカーに、音楽を流すだけのことだった（慶一は、『ナポレオン・ソロ』からとって、四〇七を「アンクル」、放送室を「スラッシュ」と名づけたが、だれも使ってくれず、この暗号名はすぐに忘れられた）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストウ夫人といふのは、人も知る『アンクル・トムス・ケビン』の作者として名高くなつた婦人である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンクル・トムの小舎」の作者、「ジョン・ファリファックス」の作者、「小公子」の作者。",
              "citation": {
                "source": "子供のために書く母たち",
                "author": "――「村の月夜」にふれつつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンクル・トムの小舎。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このリモジンの行動を掴まえなくてはと、刑事隊が、半月湾国道に沿う民家の一つひとつに即いて訊いて歩いた末、やっと拾い上げた唯一のレポウトというのは国道をホテルと反対の方向にすこし下ったところに、アンクル・タムス・キャビンという看板を掲げた郊外料理店がある。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンクル・トムス・ケビン」は合衆国の奴隷解放を描いた宣伝小説であり、かのビクトル・ユーゴーの「レ・ミゼラブル」は、歴史的小説であるとともに、仏蘭西革命を書いた政治的社会的宣伝小説である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョロヒョロして、思いがけぬ所に妙な角度が見える奇怪な身体つき、そしてオープン・アンクルの靴が彼の固い、やせた脛の後から、変な格好につき出ている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンキホーテ、アンクルトムは、自由主義というイスラエリズムをお題目にして、「英国がドイツに負けたら、同じ自由主義国の我米国もあぶない」　とばかり、今度は米国の方から、英国を後詰めしている。",
              "citation": {
                "source": "今昔茶話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄アレクサンドルが『アンクル・トム』を読んで泣かされたと書いてよこしたのに対し、十六歳のチェーホフはやや冷笑的な調子で、……このあいだ読み返したら、乾葡萄を食いすぎた時みたいな嫌な気持がした、と答えている。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄アレクサンドルが『アンクル・トム』を読んで泣かされたと書いてよこしたのに対し、十六歳のチェーホフはやや冷笑的な調子で、――僕もこのあいだ読み返してみたが、まるで乾葡萄を食いすぎた時みたいな嫌な気持がした、と答えている。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は小父さんの方のお話を聞かして下さいな、アンクル・トム。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」紳士の望みで、セエラは紳士を『アンクル・トム』と呼んでいました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は冨美ちゃんにアンクルトムスや紅はこべその他似合わしいものを見つけてやりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンクルの通路の向こうでは、ひとりの鼓手が短剣で刺された。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "テクサカーナのディスク・ジョッキー、アンクル・ダドレイからエルヴィスの人気を聞かされたトム・パーカーという男が、エルヴィスのマネジャーになった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『グランド・オール・オプリイ』のオープニング・ナイトは、アンクル・ジミー・トムスンというフィドラーが、六五分間、自分ひとりでヴァイオリンを弾きまくったのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
