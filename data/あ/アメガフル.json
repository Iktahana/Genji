        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨が降るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨が降るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨が降るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨が降るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨が降るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨が降るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨が降るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨が降るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨が降るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨が降るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨が降るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨が降るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨が降るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨が降るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "主婦はいつもこの雨のふるのにお風呂ですかと聞くが、自分は雨が降るから出掛けるのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降ると風呂に行く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月のある日、しぶしぶ雨が降る昼でした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、雨が降ると、草花も作物も枯れてしまった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪のかわりに、これから雨が降るもんだから、　そうら、あんなに、雨の卵ができている。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏へおいといた」「雨が降るかもしれんで、ずっとなかへ引き込んでおいで」「はあ。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の譬にも天生峠は蒼空に雨が降るという、人の話にも神代から杣が手を入れぬ森があると聞いたのに、今までは余り樹がなさ過ぎた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "會話のみを云ふのでは無い、例へば「雨が降る」と云つても、雨の音が聞えなければならぬ。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨が降る」といふ文章を見て、其の感の無いのは眼に訴へるので、書いてあるから、雨が降つてるのだなどは宜しく無い。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は雨が降る、降る。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを目ざして進むと、丁度本堂仏殿のありそうな位置のところに礎石が幾箇ともなく見えて、親切な雨が降る度に訪問するのであろう今もその訪問に接して感謝の嬉し涙を溢らせているように、柱の根入りの竅に水を湛えているのが能く見えた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この着物を着て、遊びに出掛けると、不思議に必ず雨が降るのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにきょうは雨が降るかもしれないそうだよ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが妙なことには、どうかして金曜日に雨のふるまわりが来ると、来る週も来る週も金曜日というと雨が降る。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は薄曇つたまゝで、三日の間はつきりした日の目を見せなかつたから、今日あたりは秋雨のやうなうすら寒い細雨が降るのだらうと彼れは川上から川下にかけてずつと見渡して見た。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、今日は雨が降るので、却々散歩に出ないんだ。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に再び雨さえ降って来たので、コリャ堪らぬ堪らぬと、杉田子はお年寄り役だけに、若手の面々を指揮して枯木枯枝を集めさせ、廃殿の横手に穴のような処を見付け出し、頻りに焚火をしようと焦ってござるが、風が吹く、雨が降る、その上燃料が湿っているので火はなかなか付かぬ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだけれども、王様だけれども、雨が降るからねえ、びしょぬれになって、可哀相だったよ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降るということには、何の意味もない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はふと眉を翳らせて、それが癖の放心しているような虚ろな眼をあげて、きょとんと白い雨足を見ていたが、一つの気分に永く閉じこもることの出来ない信吉はすぐ軽佻浮薄な笑い声にふくませて、「僕は雨男ですね、旅行するときっと雨が降るんですよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島大社のお祭りの日には、きっと雨が降るとむかしのむかしからきまっていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手な大島絣の袷に總絞りの兵古帶、荒い格子縞のハンチング、淺黄の羽二重の長襦袢の裾がちらちらこぼれて見えて、その裾をちよつとつまみあげて坐つたものであるが、窓のそとの景色を、形だけ眺めたふりをして、「ちまたに雨が降る。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを目ざして進むと、丁度本堂仏殿の在りさうな位置のところに礎石が幾箇ともなく見えて、親切な雨が降る度に訪問するのであらう今も其訪問に接して感謝の嬉し涙を溢らせてゐるやうに、柱の根入りの竅に水を湛へてゐるのが能く見えた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫も何も吹飛ばされた、恐しい音ばかりで雨が降るとも思わねえ、天窓から水びたり、真黒な海坊主め、船の前へも後へも、右へも左へも五十三十。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、この半襟かけてお店に出ると、きっと雨が降るのよ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、この半襟かけてお店に出ると、きつと雨が降るのよ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の譬にも天生峠は蒼空に雨が降るといふ人の話にも神代から杣が手を入れぬ森があると聞いたのに、今までは余り樹がなさ過ぎた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雨が降るのではない、月が欠伸する息がかゝるのであらう……そんな晩には獺が化けると言ふが、山国に其は相応はぬ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだけれども、王様だけれども、雨が降るからねえ、びしよぬれになつて、可哀想だつたよ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「雨男」とは彼が画面に現れると、必ず雨が降るという人物で、私が最も傾倒したのはこの人物である。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
