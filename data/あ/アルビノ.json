          "standard": [
            {
              "text": "私は毎日アルビノについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルビノという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルビノの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルビノが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルビノを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルビノについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルビノの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルビノの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルビノが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルビノという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルビノという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルビノについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルビノを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルビノは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルビノについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルビノが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルビノは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルビノの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルビノは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルビノは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを追って我々は拱道をくぐり、両方の懐中電灯をしれっと無関心なままの三羽組に向け、いずれも未知の巨大種に属する盲目のアルビノであることを見た。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部にはよちよち歩くアルビノペンギンが数羽おり――余所者の割には無関心で辺りを見ようともしなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この開けた空間には盲目のアルビノペンギンが何羽かおり、迫り来る存在のことを不思議なほど酷く恐れていることが明らかだった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロンド、ブルネット、赤毛、ついでに専ら興趣を添えるべくアルビノも。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
