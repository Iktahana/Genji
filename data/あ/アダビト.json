          "standard": [
            {
              "text": "毎日、徒人について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の徒人戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "徒人の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "徒人という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは徒人について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "徒人の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "徒人に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは徒人を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での徒人は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、徒人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "徒人は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な徒人を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「徒人」という概念について深く考察する必要があります。",
