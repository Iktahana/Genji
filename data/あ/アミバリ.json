          ],
          "literary": [
            {
              "text": "出来上がりが近づくと葉子は片時も編み針を休めてはいられなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストを恋い恋うて、夜も昼もやみがたく、十字架を編み込んだ美しい帯を作って献げようと一心に、日課も何もそっちのけにして、指の先がささくれるまで編み針を動かした可憐な少女も、その幻想の中に現われ出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの姿を見た夫人は、室内帽子をかぶった頭を、編み針の先で掻くと、いきなりわたしに向って、請願書を一通清書してもらえまいかと問いかけた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴下の編み針が、不安に襲われた動物の触角みたいに動いている。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから突然怒りだして、編み針を彼の頭に投げつけ、帰ってゆけと怒鳴り、大嫌いだと叫んだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また編み針の先を折りその棒をとがらして短剣とした靴職人もあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
