    "definitions": [
      {
        "index": 1,
        "gloss": "temporary lodging built to accommodate an Imperial visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日行宮について考えている。",
              "source": "幻辞"
            },
            {
              "text": "行宮という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は行宮の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には行宮が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "行宮を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは行宮について学習した。",
              "source": "幻辞"
            },
            {
              "text": "行宮の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は行宮の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では行宮が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "行宮という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に行宮という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では行宮についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "行宮を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると行宮は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "行宮について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では行宮が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に行宮は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により行宮の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "行宮は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に行宮は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その二男声女声（交互に唱和竝に合唱）菟狭はよ、さす潮の水上、豊国の行宮。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああはれ足一騰宮とよ、行宮。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮は、行宮と　青の岩根に一柱坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二男聲女聲（交互に唱和竝に合唱）菟狹はよ、さす潮の水上、豐國の行宮。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮は、行宮と青の岩根に一柱坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "正行の活動　延元四年の秋、後醍醐天皇は吉野の南山｜行宮に崩御せられた。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に正成の本拠であった河内東条と、行宮のある吉野は、官軍の二大作戦根拠地であった。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "為に後村上天皇は難を賀名生に避けられ、吉野の行宮は師直の放火によって炎上し、南朝の頽勢は既に如何ともし難い。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處から二三丁下つたところに所謂行宮の跡があつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和には武内宿禰の墓を畑とし、大阪府には敏達帝の行宮趾を潰せり、と聞く。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその建物を見て斉明天皇の朝倉の行宮の木の丸殿もこんなのではなかったかと思えて考え様によっては存外に風情があって、風変りなだけに雅致のあるものであるかも知れないとも思われた。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐後風土記日田郡ノ條ニ「昔者纒向日代宮御宇大足彦天皇、征伐球磨贈於凱旋之時、發筑後國生葉行宮、幸於此郡、有神名曰津媛、化而爲人、參迎辨申國消息、因斯曰久津媛之郡、今謂日田郡者訛也」上ノ津媛ノ上ニ、久字落チタルカ、生葉ハ、景行紀ニ的邑トアリ、今ノ生葉郡ナリ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "法皇止む事を得ずして将に六馬行宮を発せむとす。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、神明の社が紀州海道に面してゐる（宿院行宮も同様海道に面し、神明社の南十町ほどに在る）ので、神明様の怨まれるのを恐れて、避けられるのだと言ふ。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て天皇の行幸に御伴をして、山城の宇治で、秋の野のみ草（薄・萱）を刈って葺いた行宮に宿ったときの興深かったさまがおもい出されます。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○熟田津に船乗りせむと月待てば潮もかなひぬ今は榜ぎ出でな　〔巻一・八〕　額田王　斉明天皇が（斉明天皇七年正月）新羅を討ちたまわんとして、九州に行幸せられた途中、暫時伊豫の熟田津に御滞在になった（熟田津｜石湯の行宮）。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月と潮汐とには関係があって、日本近海では大体月が東天に上るころ潮が満始るから、この歌で月を待つというのはやがて満潮を待つということになる、また書紀の、「庚戌泊于伊豫熟田津石湯行宮」とある庚戌は十四日に当る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し史実上で、阿胡行宮云々とあるし、志摩に英虞郡があり、巻十五（三六一〇）の古歌というのが、「安胡乃宇良」だから、恐らく人麿の原作はアゴノウラで、万葉巻一のアミノウラは異伝の一つであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は行宮へ送られる途中磐代（今の紀伊日高郡南部町岩代）海岸を通過せられた時の歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇子は十一日に行宮から護送され、藤白坂で絞に処せられた。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、天皇は現人神にましますから、今、天に轟く雷の名を持っている山のうえに行宮を御造りになりたもうた、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本武尊が東征の時、ここに行宮を置いて、新治、筑波を過ぎて幾夜か寝つると歌を以て尋ねた時、傍の燭を持てるものが、かがなへて夜には九夜、日には十日をと答えたという事蹟がある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三野王は四月に戻ってきて信濃の図を奉ったが、翌年十月にも使をだして信濃に行宮をつくらせた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元正天皇が美濃に行宮をつくって行幸し、数日間タギ郡タド山の美泉というのをのんで帰って、「朕はミノのタド山の美泉を連用して参ったが、顔と手はスベるようになる、痛みはとまる、白髪は黒くなる、夜も目が見えてくる、その他の何にでもきく。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして次の元正女帝に至って、ミノの行宮へ行ってタド山の美泉をのんで、あんまり霊験イヤチコだからと、年号を変えて大赦を行っているのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天武帝が筑摩の温泉へ行宮をつくろうとしたのも、シナノ側にもある神聖なる霊泉をほめたてて敵を喜ばせて敵にとりいるコンタンであったかも知れません。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兒島高徳行宮題詩※吁嗟雖莫范蠡功。",
              "citation": {
                "source": "遺篇",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名を呼んで見るのもまだ多くのものにめずらしい東京の方からは新帝も無事に東京城の行宮西丸に着御したもうたとの報知の届くころである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
