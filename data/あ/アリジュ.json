    "definitions": [
      {
        "index": 1,
        "gloss": "Thai basil (Ocimum basilicum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿梨樹について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿梨樹の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿梨樹が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿梨樹について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿梨樹の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿梨樹が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿梨樹という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿梨樹についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿梨樹は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿梨樹が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿梨樹は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿梨樹の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿梨樹は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿梨樹は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "若不順我呪　悩乱説法者頭破作七分　如阿梨樹枝如殺父母罪　亦如厭油殃斗秤欺誑人　調達破僧罪犯此法師者　当獲如是殃　と一心不乱、さっと木の葉を捲いて風が南へ吹いたが、たちまち静り返った、夫婦が閨もひッそりした。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若不順我咒　　悩乱説法者　　頭破作七分如阿梨樹枝　　如殺父母罪　　亦如厭油殃斗秤欺誰人　　調達僧罪犯　　犯此法師者当獲如是殃と一｜心不乱。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
