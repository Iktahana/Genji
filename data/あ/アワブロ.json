        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日泡風呂について考えている。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は泡風呂の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には泡風呂が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは泡風呂について学習した。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は泡風呂の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では泡風呂が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に泡風呂という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では泡風呂についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると泡風呂は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では泡風呂が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に泡風呂は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により泡風呂の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "泡風呂は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に泡風呂は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
