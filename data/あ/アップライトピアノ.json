        "examples": {
          "standard": [
            {
              "text": "子供が毎日のようにアップライトピアノの練習に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "リビングの片隅に、新しいアップライトピアノが置かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "音楽教室の個室には、それぞれアップライトピアノが一台ずつ備え付けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアップライトピアノ、音がすごく綺麗だね！」と友人は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "グランドピアノに比べて省スペースなアップライトピアノは、住宅事情に合わせた選択肢として人気が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域のお祭りの会場では、アップライトピアノを使ったミニコンサートが開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アップライトピアノの調律師は、特殊な道具を使って弦の張りを調整する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
