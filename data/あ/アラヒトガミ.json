[
  {
    "uuid": "f3ab6653-ad28-5e99-9ba7-a059cc97c871",
    "entry": "現人神",
    "reading": {
      "primary": "あらひとがみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日現人神について考えている。",
              "source": "幻辞"
            },
            {
              "text": "現人神という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は現人神の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には現人神が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "現人神を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは現人神について学習した。",
              "source": "幻辞"
            },
            {
              "text": "現人神の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は現人神の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では現人神が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "現人神という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に現人神という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では現人神についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "現人神を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると現人神は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "現人神について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では現人神が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に現人神は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により現人神の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "現人神は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に現人神は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第四章大いなり、今にして現人神、かく坐せば、かぎりなき大御稜威かくあらせば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※・月に飛ぶ雪言祝大君、日の本の若き大君、神ながら朗らけき現人神。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神ながら朗らけき現人神。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民は、各氏の氏神を祭ると共に、天照大神をはじめ、天つ神を崇敬し、同時に天皇を現人神と仰ぎ奉つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類が心から現人神の信仰に悟入したところに、王道文明は初めてその真価を発揮する。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に端的に云えば、現人神たる天皇の御存在が世界統一の霊力である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は長尾の僧都は申すまでもなく、その日御見えになっていらしった山の座主や仁和寺の僧正も、現人神のような摩利信乃法師に、胆を御｜挫かれになったのでございましょう。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本は神国、帝は現人神、天皇様御親政が我国の常道、中頃武家が政権を取ったは、覇道にして変則であるが、帝より政治をお預かりし、代って行なうと解釈すれば、認められないこともない。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるごろも真土の山ゆ帰り来ぬかも（万葉集巻六）大君の命畏み、さしなみの国にいでます、はしきやし我が夫の君を、かけまくもゆゝし畏し、住吉の現人神の、舟の舳にうしはき給ひ、着き給はむ島の崎々、より給はむ磯の崎々、荒き波　風に遭はせず、つゝみなく、病あらせず、速やけく返し給はね。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、天皇は現人神にましますから、今、天に轟く雷の名を持っている山のうえに行宮を御造りになりたもうた、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして祖母と伯母二代の女帝によつて現人神としての成人を希はれ祈られ待たれた首皇子は後の聖武天皇であつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、彼女は天下第一の人格として、世に最も尊貴な、そして特別な現人神として育てられ、女としての心情が当然もとむべき男に就ては教へられてゐなかつたからだ。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに敗戦と、それに引きつづいた占領下の政策は、過去の政府と国民とがキリスト教を迫害した思想的並びに政治的根拠をくつがえし、天皇はみずから現人神であることを否定して、従来日本におけるキリスト教の伝道及び信仰を阻害した最大の障害が除去され、思想及び信仰の自由は実質的に強化された。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道や仏教では、人間と神との区別が本質的に異質ではなく、人は死ねば神として祭られ、あるいは生きている間から現人神と呼ばれたり、または人間はだれでも仏性を備えているものとして、即身成仏と唱えられる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、「天皇は現人神であらせられ」「永久に臣民国土の生成発展の本源にまします。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが水疱瘡を治すには、おきゅうがいいということであったのだが、現人神たる玉体におきゅうをすえるということは許されないという異議が出たために、ついに譲位をなさって、おきゅうの治療を受けられた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "女帝は自分を選んで帝位に即けてくれた生れながらの現人神である。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語の中の八さん熊さんにしても、なア、おッかア、あのナマグサ坊主とイチャつくのは、やめてくれねえかなア、と諫めた話はあんまり聞かないが、特に長幼の序が人生の万事を律している特殊な社会で、しかも生れながらに唯一絶対の現人神たる上皇に向って、礼なき言葉が発せられるとは思われない。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道鏡こそは、唯一絶対の現人神たる己れにつづいて、人臣最高の徳と学をそなえ、神と人との中間にも位置すべき天地第二の格あるものだ。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、祖母と伯母二代の女帝によって現人神としての成人を希われ祈られ待たれた首皇子は、後の聖武天皇であった。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、彼女は天下第一の人格として、世に最も尊貴な、そして特別な現人神として育てられ、女としての心情が当然もとむべき男に就ては教えられていなかったからだ。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は、現人神というようなものではない。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば、いつたい、明治以後「現人神」といわれてきた天皇は、歴史上、どういう地位のものであつたか。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "現人神などではなかった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は現人神でおわしますと」「あれもこまる。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
