        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイコンは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイコンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイコンに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイコンが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイコンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイコンについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイコンについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイコンが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイコンが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイコンは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイコンは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイコンを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイコンをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイコンが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイコンの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイコンを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイコンに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイコンについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイコンは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイコンを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "高価な上に保守にも金を食い、そのくせ大した意味のない、動画やステレオ音声や、アイコンとマウスのインターフェイスの化け物ばかりが幅を利かせるようになった」と、締め出しはハートを嘆かせます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕掛けが、ぱっと見て一目でわかるようアイコンと呼ばれる絵文字を利用し、やれることをメニューにして示し、画面上に複数の『窓』を開くウインドウ機能を備えるなど実に憎い仕上がりとなっていたことで、その後のパーソナルコンピューターの進化の道筋は、ここで事実上定まった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュのユーザー・インターフェイスの真髄は、アイコンの中にもウインドウの中にも存在しない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイコンを始め、認知をやさしくするために図形を多用する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小道具を使えば、今見ている場所の名前とＵＲＬを、ピンの格好のアイコンに簡単に記録できる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビットマップの特長は、機能や情報のまとまりを示す絵文字、アイコンにも生かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルト用に書かれたお絵かきのソフトウエアでは、ペンの格好をしたアイコンをマウスで操作することで、画面上に線を描くことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラシのアイコンをインク壷に浸してから動かすと、スピードに応じて微妙な筆合いが表現できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトのディスプレイ上にウインドウが重ね合わせて開かれ、アイコンが操作され、ワードプロセッサーの文章中の書体が自由に変更される様を凝視していたビル・アトキンソンは、文字も含めたすべての要素をグラフィックスとして扱うというリサの方向付けが正しかったことを、あらためて確信させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リサのインターフェイスは、ウインドウやアイコン、マウスを中心に組み上げるという方針が、見学後急遽定められ、アルト用にエディターを書いた★経験を持ち、アップルの面々にデモンストレーションを見せてくれたラリー・テスラーが引き抜かれてリサの開発チームに加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京セラ、稲盛との出会いが生んだ二つの未来志向マシン開発計画　ファーストクラスの大きな座席から身を乗り出すようにして、メモ用紙にスケッチしたディスプレイの中にいくつもウインドウを書き入れ、アイコンの役割やマウスを使った操作の利点を熱を込めて語り続ける西和彦を、稲盛和夫は唇を固く結んで見守り続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "削除を示すハサミのアイコンを選べば、それまでは矢印だったカーソルがハサミの形に入れ替わり、作業の内容によってピンセットやナイフに変化するといったインターフェイスの方向付けが、アスキーとジャストシステムの繰り返しの打ち合わせを経てまとめられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚かされたのは、自由に範囲を選んでエリアごと移動できるようにした、投げ縄のアイコンで示された機能だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
