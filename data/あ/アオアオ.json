        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は怖くなつて、とてもそのアメリカの小母さんの顔が見てはゐられなくなつて、窓の方に眼を向けると、雪の原には月が一面に青々と光つて、なんだか白熊たちは雪達磨をこしらへてゐるのでした。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本市で汽車を下りたが、青々とした山で、方々を囲まれていて、雲がむくむくと、その上におい冠ぶさっている、山の頂は濃厚な水蒸気の群れから、二、三尺も離れて、その間に冴えた空が、澄んだ水でも湛えたように、冷たい藍色をしている、そこから秋の風が、すいすいと吹き落して来そうである。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱や大根が到處に青々として、麥はまだ僅に芽を出した處がある位であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々とした春でしょうねえ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅が青々繁ってゐる。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹園宮沢賢治髪白き山田博士が書いだき帰り往くころかはたれはしづに這ひ来てふくよかに木の芽ほごるゝ鳥飛びて気圧を高み守衛長〔以下未完〕ぎごちなき独乙冠詞を青々となげく窓あり",
              "citation": {
                "source": "樹園",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草はいくら食ってもとても食い切れそうもないほど青々と繁茂しているのである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この秋、民子と二人で茄子をとった畑が今は青々と菜がほきている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔いの人に踏まれたらしいがなお茎立って青々として居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の如く掃除の行き屆いた庭の隅に、青々とした草がそよいでゐて、蛙が時々侘しさうに鳴いてゐた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして街は青々と緑に包まれて私は夜毎旗亭ダリコントに馬車で通った。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間から丘にかけて一帯に耕地が固くなって荒れるがまゝにされている中に、その一隅の麦畑は青々と自分の出来ばえを誇っているようだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカシヤは、風にもかゝわらず、なお一層青々としていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は、青々とした雑草が、勝手きまゝにそこに繁茂した。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海浸す日より棲みゐて、　　　　たゝかひにやぶれし神の、二かしら猛きすがたを、　　　　青々と行衛しられず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひかりうづまく黒の雲、　　ほそぼそめぐる風のみち、苔蒸す塔のかなたにて、　　大野青々みぞれしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道が俄かに青々と曲る。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の傍には青々とした柚の木がもう黄色い実をのぞかせていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉が身体を入れようという家は、直間近で、一｜町ばかり行くと、袂に一本｜暴風雨で根返して横様になったまま、半ば枯れて、半ば青々とした、あわれな銀杏の矮樹がある、橋が一個。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町中を水量たっぷりの澄んだ小川が、それこそ蜘蛛の巣のように縦横無尽に残る隈なく駈けめぐり、清冽の流れの底には水藻が青々と生えて居て、家々の庭先を流れ、縁の下をくぐり、台所の岸をちゃぷちゃぷ洗い流れて、三島の人は台所に座ったままで清潔なお洗濯が出来るのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "点けっ放しの百｜燭光に照らされたインキの文字がまだ青々していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝の日曜は青々と晴れたステキな庭球日和であった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は青々とした空に低く漂ッて、射す影も蒼ざめて冷やかになり、照るとはなくただジミな水色のぼかしを見るように四方に充ちわたった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲が刈り取られて林の影が倒さに田面に映るころとなると、大根畑の盛りで、大根がそろそろ抜かれて、あちらこちらの水溜めまたは小さな流れのほとりで洗われるようになると、野は麦の新芽で青々となってくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は蒸暑い雲が湧きいでて、雲の奥に雲が隠れ、雲と雲との間の底に蒼空が現われ、雲の蒼空に接する処は白銀の色とも雪の色とも譬えがたき純白な透明な、それで何となく穏やかな淡々しい色を帯びている、そこで蒼空が一段と奥深く青々と見える。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大庭真蔵は慣れたもので、長靴を穿いて厚い外套を着て平気で通勤していたが、最初の日曜日は空青々と晴れ、日が煌々と輝やいて、そよ吹く風もなく、小春日和が又｜立返ったようなので、真蔵とお清は留守居番、老母と細君は礼ちゃんとお徳を連て下町に買物に出掛けた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると往来には人気なく、あおあおと光が漲っている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の眉は人一倍あおあおとし瑞々しかった。",
              "citation": {
                "source": "眉の記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
