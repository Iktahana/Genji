        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アマンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アマンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアマンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアマンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アマンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアマンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アマンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアマンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアマンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アマンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアマンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアマンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アマンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアマンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アマンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアマンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアマンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアマンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アマンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアマンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "地理学教室ではペンクや助手のベーアマンが引率して近郊の地質地理見学に出掛けた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンクの足の早いのとベーアマンの口の早いのとに悩まされたが、ずいぶん色々とためにはなった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクトル、ベエアマンはここで花崗岩の破れ目の出来方について講釈をして聞かせた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、どこかのホテルのドアマンをしてゐたと云ふだけに大柄で好人物そうな男であつた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中でアマン・ジヤン氏の「地水火風」セカリエ・ベリユウス氏の「踊子」などが目を惹くのを思ふと矢張群を抜いて居るのであらう。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はしだいしだいに南方にむかい、八時間ののちには、南の岬をめぐって、チェイアマン島を北方地平線に見送った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "オークランドの市民は、イバンスのために義捐金を集めて一せきのりっぱな商船を買い、これにチェイアマン号と名をつけておくった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖形のギアマンの水注がある。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己のやくざな夢の殘骸にウオタアマン・インクをぶつかけてやつたら、何とかそれなりに恰好がつくかも知れぬ。",
              "citation": {
                "source": "鳥料理",
                "author": "A Parody",
                "note": "青空文庫"
              }
            },
            {
              "text": "レモンとかバニラとかアマンドとかジンジャとかシンナモンとかナツメッグとか興奮刺撃の性質の物を使ったりライスカレーなぞを食べるのは皆んな胃を刺撃させるためです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかり前に、僕はジャアマン・ベエカリイで或る男とはじめて會つた。",
              "citation": {
                "source": "「スタヴロギンの告白」の譯者に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜穂子は、銀座の裏のジャアマン・ベエカリの一隅で、もう一時間ばかり圭介の来るのを待ち続けていた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "己のやくざな夢の残骸にウオタアマン・インクをぶっかけてやったら、何とかそれなりに恰好がつくかも知れぬ。",
              "citation": {
                "source": "鳥料理",
                "author": "A PARODY",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これじゃ、まるで、騒ぎの起きるのを待ってるようなもんだ」　アマンドさんが、厚い首巻きのおくで、はっきりしない声をだす。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、そんなことのために、不幸な人間をひとりこしらえあげることは、あたしは反対です」　アマンドさんが、びっくりしたように立ちどまる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのお嬢さんを見る眼つきをごらんなさい」　アマンドさんが、クスクス笑いだす。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのお嬢さんは、レエヌからピエールをとりあげるようなことはしないから」「どうして、そんなことがわかるの」　アマンドさんは、ピクンと肩をすくめる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思っていてください」「わかった、わかった」　エステル夫人は、アマンドさんの顔をマジマジとながめながら、「どうしてあんな娘がそんなに気にいったの。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西系のカナダ人のなかで第一のお金持ち、ジャン・アマンドさんのごうしゃな快遊船である。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんの息子のピエールさんのいたずらだ。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、お待ちしててよ」　キャラコさんをアマンド氏の快遊船へひっぱって来たのはイヴォンヌさんである。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんは非常な日本びいきで、趣味というよりは心酔というのに近いふうだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらっしゃるわね」　イヴォンヌさんと山田氏の紹介で、帝国ホテルで、はじめキャラコさんに逢った時から、アマンドさんは、はればれとした、愛想のいい、しっかりしたこのお嬢さんがすっかり好きになってしまった。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんはどうしていいかわからなくなって、ハンカチでむやみに鼻ばかりかんでいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんは、キャラコさんが、すぐ自分の近くにいると思うだけでなんともいえぬよろこびを感じる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんは、キャラコさんと一緒にいられる日を、一日でも多くしようとたくらんでいるようにも見えるのである。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんという、たいへんなお金持ちの叔父さんの邸でぜいたくに暮らしていることや、カナダに籍が移ってレエヌという名になったことや、アマンドさんの息子のピエールさんと婚約したなどということを、誇らしい調子で書いてあった。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマンドさんの妹さんのエステル夫人などは、露骨にキャラコさんを毛嫌いして、「あたしは、日本贔屓というわけではないのよ」　などと、はっきりしたことをいう。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまアマンドさんが撃っているらしく、射撃台のところにまっ白な頭と桃色の首筋が見える。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
