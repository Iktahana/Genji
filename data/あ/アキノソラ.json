[
  {
    "uuid": "3a811959-e278-5004-a4ec-f8d3074a7aac",
    "entry": "秋の空",
    "reading": {
      "primary": "あきのそら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
