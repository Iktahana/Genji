    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clear autumn sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この雲の上には実に東京ではめったに見られない紺青の秋の空が澄み切って、じりじり暑い残暑の日光が無風の庭の葉鶏頭に輝いているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　今迄かつと照り渡つてゐた初秋の空に僅か飛行船程の暗雲が浮んだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつ秋の空にしんと静もり返っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のように澄みきった秋の空、日は一間半ばかりの辺に傾いて、僕等二人が立って居る茄子畑を正面に照り返して居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして穴がすつかり埋められてしまふと、蜂は暫く穴のまはりを歩きまはつてゐたが、やがてぷうんと翅音を立てながら、黒黄斑の弧線を清澄な秋の空間に描きつつどこともなく飛び去つて行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空澄み渡って三里隔つる元越山の半腹からまっすぐに立ち上る一縷の青煙すら、ありありと目に浮かんで来る。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空を背景とした柿もみじを見るような感じがする。",
              "citation": {
                "source": "青磁のモンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空は高く晴れて西からふく風がひやひやと膚身にこたえます。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな服装や色彩が、処々に配置された橙や青の盛花と入りまじり、秋の空気はすきとおって水のよう、信者たちも又さっきとは打って変って、しいんとして式の始まるのを待っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この秋の空ながら、まだ降りそうではない。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き終りて縁に立てば、午後より陰りかかりし秋の空の低く垂れたり。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂よばひ達かぬものか秋の空わが仏ひとり殖えたり神無月　この夕、少しく調ぶることありて、熊谷陣屋の浄瑠璃本をとり出して読む。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの丘の上にも、四本の手をもった風車が、はてしない秋の空の下にあって、キリキリとまわっていました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　恁て、數時間を經たりし後、身邊の人聲の騷がしきに、旅僧は夢破られて、唯見れば變り易き秋の空の、何時しか一面掻曇りて、暗澹たる雲の形の、凄じき飛天夜叉の如きが縱横無盡に馳せ※るは、暴風雨の軍を催すならむ、其一團は早く既に沿岸の山の頂に屯せり。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水たまりには秋の空が写って、雲が流れる。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "〆の形や、雁の翼は勿論、前の前の下宿屋あたりの春秋の空を廻り舞って、二三度、俊吉の今の住居に届いたけれども、疑も嫉妬も無い、かえって、卑怯だ、と自分を罵りながらも逢わずに過した。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、名を由之助という小山判事は、埃も立たない秋の空は水のように澄渡って、あちらこちら蕎麦の茎の西日の色、真赤な蕃椒が一団々々ある中へ、口にしたその葉巻の紫の煙を軽く吹き乱しながら、田圃道を楽しそう。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩秋の空ゆく黄雲、畑のいろ、見る眼のどかに夕凪の沖に帆あぐる蜜柑ぶね、暮れて入る汽笛。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……田舎だね、鍬をかついで、四角な西洋館のかげから大きな百姓の姿が躍つて来る、顔から胸までうつぴろげて輝く秋の空をふり仰ぐ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空は青空にかがやいて、大川の水はなんにも知らないように静かに流れていた。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は白い土埃を上げ、乾燥し切った秋の空気を切って日照りの街中を走った。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のやうにけざやかな秋の空は、美しい光りを孔雀の翅のやうにひろげて、その中に憧憬の歡樂を夢みる二人は、本當に幸福なんですね――本當に二人を母のやうに從順に、氣をくばつてくれるやうな、場所がほしい。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の面は秋の空、汀に蘆の根が透く辺りは、薄濁りに濁って、二葉三葉折れながら葉ばかりの菖蒲の伸びた蔭は、どんよりと白い。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛は勝手の戸をがらりと開けた、台所は昼になって、ただ見れば、裏手は一面の蘆原、処々に水溜、これには昼の月も映りそうに秋の空は澄切って、赤蜻蛉が一ツ行き二ツ行き、遠方に小さく、釣をする人のうしろに、ちらちらと帆が見えて海から吹通しの風｜颯と、濡れた衣の色を乱して記念の浴衣は揺めいた。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十｜日から廿｜日の間に渡つての暴風は懸念した程のことはなく、只秋の空は六かし相に低く成つて棒のやうな雲へ煙の樣な雲がぽつり／＼と纏つて居る日が續いて二三｜日晝から夜へ掛けてぼか／＼と暖かい空つ風が思ひ切り吹いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを晩秋の空が悉皆持ち去るので滅切と冴える反對に草木は凡てが乾燥したりくすんだりして畢ふのに相違ないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の降りが強かつたので秋の空は研ぎ出したやうに冴えて見える。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "横からも竪からも秋の空が窓を覗いて居るやうである。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空に星が光っていて、足許に、よその猫がうずくまって、動かなかった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "移り気な晩秋の空に出没する星の瞬きも移り気な頃である、あまりに低く垂れさがつて、地上からの蒸気のためにあの星の姿は稍ともすれば灰色に閉されながら光つてゐるが、やがて深い夜気が天地を撫で、一抹の筆に闇を流しはじめると、あれは追々と西の彼方へ沈んで行つた。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
