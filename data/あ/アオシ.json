          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で、「青し」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "季節の変化とともにこの傾向が顕著になる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からこの風習が形成された。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でこれは欠かせない材料とされている。",
              "source": "幻辞"
            },
            {
              "text": "観光地を訪れる際にこのポイントを押さえておくべきだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で、「青し」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "江上油のごとく白鳥飛んでいよいよ青し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ竹材には「竹の色｜許由がひさごまだ青し」とか「埋られたおのが涙やまだら竹」というように、それ自身に情趣の深い色っぽさがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ竹材には「竹の色許由がひさごまだ青し」とか「埋られたおのが涙やまだら竹」というように、それ自身に情趣の深い色っぽさがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の前身は外人相手の娼婦なので、魑魅子には東洋の古典の絵巻にあるような繊細なこころは、あいにく持っていなかったが、女取引所にあらわれる体温によって花咲いた男性の手管を、侵略に委せて刺青した、肉体的異国的な地図と感情を失ったエモーションの波、そこに愛情の新らしい鋳型を僕は見出すのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔南風の頬に酸くして〕南風の頬に酸くして、　　シェバリエー青し光芒。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜に鳴く蟲の黒い影が、世を怨む女の瞳の如く、蘆の折葉の節々は、卒堵婆に、浮ばない戒名を刺青したか、と明るく映る。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酒を思つて、たゞ杉の葉の刺青した。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて一たびただ一｜人の瞬きする間に、水も流れ、風も吹く、木の葉も青し、日も赤い。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅は花が散ってしまっていて青青した葉をひろげ、百日紅は枝々の股からささくれのようなひょろひょろした若葉を生やしていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我我もまた自然と共に青青しくならうとしてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に棟に通ずる件の階子を棟よりして入来る、岩代国麻耶郡猪苗代の城、千畳敷の主、亀姫の供頭、朱の盤坊、大山伏の扮装、頭に犀のごとき角一つあり、眼円かに面の色朱よりも赤く、手と脚、瓜に似て青し。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は青青してゐて、顏全體は卵のかたちに似てゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途、夕日を浴びて、ながいながいひとりごとがはじまり、見事な、血したたるが如き紅葉の大いなる枝を肩にかついで、下腹部を殊更に前へつき出し、ぶらぶら歩いて、君、誰にも言っちゃいけないよ、藤村先生ね、あの人、背中一ぱいに三百円以上のお金をかけて刺青したのだよ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）彼女が捲った膝の縊れが沓下の端を風鈴草の花のように反り返らせ、露になった彼女の象牙色の肉が盛り上る其処には可愛らしいジャンダークの楯が刺青してある。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ああ、今しがたまでぞ、この硝子戸の外には五｜時ごろの日の光わかわかしき血のごとくふりそそぎ、見えざる窓下のあたりより、抑圧えあへぬ抱擁の笑ひ声きこえしか――葱畑すでに青し。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かろく冷たき微風も鹹をふくみて薄青し、「秋」は流行の細巻の黒の蝙蝠傘さしてゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石踏みつつ後を通る紳士の右の手にもてる新聞紙の包はや薄青し。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は夏、青しののめ、濛濛と雨はしるなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "棗の花棗の花の咲くところ、光は強く、陽は青し。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたの首は骨牌の赤いヂヤツグの帽子かな、光るともなきその尻は、感冒のここちにほの青し、しをれはてたる幽霊か。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが魚をボートの中に引上げようとして腕をおまくりになった時、僕はあなたの肱の所にＪ・Ａと刺青してあるのを見たんです。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の天青し、海青し、菫の花青しといふを聽きて、われは董の花の香を聞き、そのめでたさを推し擴めて、天のめでたかるべきをも海のめでたかるべきをも思ひ遣りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒く、滑々とした背膚の濡色に、星の影のチラ／＼と映す状は、大鯰が藻の花を刺青したやうである。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたの首は骨牌の赤いヂヤツクの帽子かな、光るともなきその尻は感冒のここちにほの青し、しをれはてたる幽靈か。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には天鵞絨を敷いたような青あおした草が生えて、玄関口と思われる障子に燈の点いた方には、凌霄の花のような金茶色の花が一めんに垂れさがった木が一本立っていた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯を剃った青あおした顔もあった。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まっしろなばらの花が咲いて、にわとこの花がにおい、青あおした草が、いきのこっている人たちのなみだでしめっているはかばのことをうたいました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは青あおした、きれでつつまれて、うつくしい色もようのしきものの上においてありました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおしずまりなさいまし。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに青あおした芝生には、幸いお嬢さんや坊ちゃんもボオル投げをして遊んでいます。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
