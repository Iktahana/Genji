        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔、アイヌ族が繁栄していた時代には、アイヌも立派な民族文字をもっていた。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は大和朝廷の天孫民族にも知られてゐなかつたし、先住民族の土蜘蛛やアイヌ族にも知られてゐなかつた。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信夫には健康とアイヌ族の鼻髭があつた。",
              "citation": {
                "source": "山麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中から取り出されたまるみのある柔かい音、そして哄笑するアイヌ族の鼻髭。",
              "citation": {
                "source": "山麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでもなく毛人とはアイヌ族のことである。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに自分が本誌において、奥羽地方のアイヌ族がすでに先秦時代に際して、大陸と交通したのではなかろうかというような、突飛な説を担ぎ出すに至ったのは、主として津軽半島の北端に近い宇鉄から発見せられた石刀が、先秦時代のシナの刀貨と類似しているところにヒントを得たためであった。",
              "citation": {
                "source": "奥羽北部の石器時代文化における古代シナ文化の影響について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんその絶対年代を確かめることは容易でないが、もし厳格に「史」なる意義を解釈したならば、今の北海道のアイヌ族のごときは明治に至るまでもまだ史前時代にいたと言ってしかるべき場合もある。",
              "citation": {
                "source": "日本における史前時代の歴史研究について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越人は近くまで千島アイヌがクシと呼ばれたと同じく、アイヌ族に対する一つの名称であった。",
              "citation": {
                "source": "「ケット」と「マット」",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイの名は今も千島アイヌの称として存し、一方にはクシの神（少彦名命）或いはコシ（越人）の名によって伝わるクシ或いはコシ、または今も樺太アイヌの称として、また同時に久延毘古の名によって伝わるクエと根原を一にする語で、カイはすなわち今のアイヌ族と同じ系統に属するものである。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについてまず第一に考うべきは、現にアイヌ族の間に行われる宅神の信仰である。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　アイヌの宅神チセイコロカムイとオシラ神　北海道に住するアイヌ族の間には、今もってやはり一種の宅の神を祭っている。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見地から、余輩はまず次にオシラ神の本体を、アイヌ族間に行われる宅神によって説明せんと欲する。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中田法學士は亦、最近に、その「我太古史に見えたるアイヌ語の神名」史學雜誌十七の九に於て、アイヌ説コロボツクル説を共に極端に走れる誤謬なりとし、別に、コロボツクルはアイヌ族の一派なりとの説を立てられたり。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦夷人すなわちアイヌ族の出にして、立派な地位に上ったものも少くない。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（久保寺逸彦「アイヌ昔話、死者の国」――雑誌『遺伝』1955年８月アイヌ族特集号）　これらの物語の中では、次のような諸点がわれわれの注意をひく。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えるところでは、この民俗はかつて同地方に住んでいたことのあるアイヌ族が、残して往ったウフイと云う蛮習が、こうした形で面影を留めているのだと信じたい。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌ族では棺及び葬具に、その家々の格式による彫刻を入念にするので、一年位を経ぬとこの彫刻が出来上がらぬので、屍体をこうして保存するのだと云うことである。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こうした事はアイヌ族の間には、つい近年まで実行――勿論それは秘密ではあったろうが――されていたのである。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって彼れを推すとき、内地の民俗がアイヌ族の残存であることが会得される。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかばかしい」「ほんとに、駄目でございましょうか」「そなたも本気になって、その腐い物を掘る張り番をしていましたな」「でも、父の秘本に、赤い光を出す交ぜ薬のことが書いてあって、それには、墓場にあるある物から一つの薬をとるのだといっていましたが」「そんなことは、アイヌ族か熊襲でも考えたことだろう。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一四　アイヌ族をいう。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ取って喰べてしまいたいような衝動に駆られ、アイヌ族の特有な梨の花みたいな肌をすぐ頭にえがいた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
