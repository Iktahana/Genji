              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「夕暮」なき競走、油と虫となる理想！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから少し歩けるやうになると、一寸油断すればあんたは病院に出掛ける。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんよが出来出す一寸前頃は、一寸の油断もならないので、行李の蓋底におしめを沢山敷いて、その中に入れといたものだが、するとそのおしめを一枚々々、行李の外へ出して、それを全部出し終ると、今度はまたそれを一枚々々、行李の中へ入れたものだよ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路は冬のやうに白つちやけて、昔ながらの大道店が、ガマの油や、オツトセイや、古着類や、縞蛇や、得體のわからぬ壞れた金物類などを賣つてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒くでらでらした大きい油顔で、鼻が、――君レニエの小説で僕はあんな鼻を読んだことがあるぞ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰に食わせる油揚げはよそを捜して見つけたらいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、お嫁さんのおじいさんは、槍の名人だそうですからね、大隅君だって油断は出来ません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "潔癖が自慢の或るお方は、古道具屋から買つて来た油絵をタハシでおすりになつた。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画よりはむしろ油絵の画題であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香水、麝香、油煙、マニラの臭氣相混じて一種縁日臭を作り、靄々然として、人自らそが上を蹈み、そが中を歩めり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だと聞いたら油画だと云った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃田舎では石版刷の油画は珍しかったので、西洋画と云えば学校の臨画帖より外には見たことのない眼に始めてこの油画を見た時の愉快な感じは忘られぬ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折の油画にありそうな女だなど考えながら博物館の横手｜大猷院尊前と刻した石燈籠の並んだ処を通って行くと下り坂になった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の庭に向いた方の鴨居に水彩画が一葉隣室に油画が一枚掛っている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油画は御茶の水の写生、あまり名画とは見えぬようである。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江上油のごとく白鳥飛んでいよいよ青し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大府岡崎｜御油なんど昔しのばるゝ事多し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の思い出し得られる限りその当時の夜の主なる照明具は石油ランプであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が頭から銀の簪をぬいて燈心を掻き立てている姿の幻のようなものを想い出すと同時にあの燈油の濃厚な匂いを聯想するのが常である。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油ランプはまた明治時代の象徴のような気もする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何というものかと聞くと、レモン油というものだと教えられた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の頭の上へ逆さまに汗臭い油ぎった顔をさし出して、むつかしい挨拶をしむつかしい質問をしかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがブランギンの油絵を思い出させる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして黒光りのする台所の板間で、薄暗い石油ランプの燈下で一つ一つ皮を剥いでいる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう光景が一つの古い煤けた油画の画面のような形をとって四十余年後の記憶の中に浮上がって来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の油汗拭わんと、ぴくとわが硬直の指うごかした折、とん、とん、部屋の外から誰やら、ドアをノックする。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいう若い男が、ふとしたはずみで女を、むごたらしく殺してしまって、その場に茫然立ちつくしていると、季節は、ちょうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたと、烈風にはためいている音が聞えて淋しいとも侘びしいとも与兵衛が可愛そうでならなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物はいよいよ發展し、いまは膏藥では間に合はず、脱脂綿に無刺激の油藥を塗つて患部に貼りつけ、日に五、六囘も貼りかへなければなりませんでした。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "油つこいのがいいですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがなんだか若芽についたあぶら蟲か、腫物につけた蛭の群のやうに、ぎつしり詰まつて身動きも出來さうにない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
