    "definitions": [
      {
        "index": 1,
        "gloss": "to become greasy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脂ぎるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この脂ぎるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が脂ぎるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は脂ぎるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では脂ぎるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から脂ぎるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも脂ぎるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では脂ぎるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも脂ぎるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも脂ぎるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で脂ぎるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に脂ぎるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "脂ぎるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する脂ぎるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では脂ぎるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔は父の膝の上、　500ひとり羊の脂ぎる肉と髓とを口にしつ、而して眠襲ふ時遊戲を棄てて閨に入り、乳母の腕に抱かれて、心しづかに喜びに滿ち、柔軟の床の上、夢路たどりしあゝわが子。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
