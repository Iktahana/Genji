        "examples": {
          "standard": [
            {
              "text": "私は毎日アルザスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルザスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルザスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルザスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルザスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルザスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルザスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルザスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルザスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルザスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルザスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルザスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルザスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルザスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルザスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルザスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルザスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルザスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルザスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルザスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "フェルナンドは若くて死んだアルザス人だ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスからドイツのミュンヘンへ入り、チロルからウイン、ブダペストと延びて、ダニューブ河の河岸のホテルへ著いたときには、ハンガリアの曠野は、真紅の葵の花盛りだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は既にアルザス・ロートリンゲンに対し攻撃を企図している事は大体諜報で正確だと信ぜられて来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢代のこう云う案内で四人は附近のアルザス料理を食べに坂を下った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザス料理から一同は外へ出ると、河風にあたろうと云うので少し下ったケエドルセイの通りをセーヌ河に添って歩いた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港　××汽船会社支店長――アルザス生れの仏蘭西人――青島で日本軍の捕虜になつた男――独身。",
              "citation": {
                "source": "あの顔あの声",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお話は、アルザス・ローレイヌがドイツ領になつて、村々の小学校も先生がみんなドイツ人にかはつてしまつたときのお話です。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泣き声は、私たちの、アルザスの方言で言ひました。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェルダン市の廃墟からは東北にあたって、ルクセンブルグの国境とアルザス地方につづく丘陵地帯に大小三十数箇所かの要塞がつくられていて、第一次大戦時代、フランスの一等要塞をなしていたのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はドイツの生まれであった――（彼女ぐらいドイツ式な者はいなかった）――けれど、アルザスで育ち、アルザスのフランス人と交わったので、ラテン文明にひきつけられたのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて彼はアルザス・ローレンの問題に考慮を向けたことがなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリヴィエは、ラテンの土地としてアルザスを要求するフランスの権利について、歴史上の理由をもち出したが、それはクリストフになんの印象も与えなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスの人々はドイツ人であったかなかったか、それは問題とならなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスの人々は、四十年の間、種々の暴虐を受け、あるいは苛酷にあるいは隠密にいじめつけられ、また、ドイツの正確な賢い統治によって実際利するところさえあったがなお、ドイツ人となることを望んでいなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスに戻りしばらくの間コルマールに留まった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘーザーはこれ以前にこの病気の中心がアルザスおよびトリノにあったと信じている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンスフェルト（＊皇帝軍からプロテスタント軍に寝返ったドイツの貴族）の軍はドイツ南部ワイセンブルクの戦闘後にプファルツからアルザスに進み到るところに発疹チフスを残して行った。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横顔は線に丸みがあるとともにまた厳乎たるところがあって、アルザスおよびローレーヌを通じてフランス人の容貌のうちにはいってきたゼルマン式の優しみがあり、ロマン種族中にあって古ゼルマン族の特長となり獅子族と鷲族とを区別せしむるあの稜角の皆無さをそなえていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カリリアーノ公爵夫人の舞踏会の前に、貴女にお会い出来れば嬉うございます」「ヅマ、アナダノゴド、キニイッデマス」ずんぐりしたアルザス人で、その丸っこい体型が油断のならない鋭敏さを語っている男爵が言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼女は、あの太ったアルザス出の男と結婚してしまうなんて、彼女の目は一体何処を見てたんでしょうね？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのアルザス人の太っちょがくたばってくれたら、やつの血が逆流して胃が痙攣しちまえばなあ、私の可哀想な娘、彼女も幸せになれるんだがなあ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "太っちょのアルザス男は、お気に入りの踊り子のところで食事します。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず最初に僕は彼に言おう、僕自身の口で、あのアルザス人に、彼が再び幸福にしてやることが不可能となったあの女性を僕に譲るように頼むんだ」　ラスチニャックの心の葛藤は長く続いた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私達に向かって一体何を歌ってくれるんだ、あのアルザスの太った切り株野郎は？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく私は彼にアルザスの土地を、私のニュシンゲン名義で買い戻させることになるわ、あの土地に彼は執着があるの。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ねレストー、死ねアルザス野郎、奴等が私の殺人犯だ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
