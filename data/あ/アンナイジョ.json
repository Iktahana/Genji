        "examples": {
          "standard": [
            {
              "text": "私は毎日案内所について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内所という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内所の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内所が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内所を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内所について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内所の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内所の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内所が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内所という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内所という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内所についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内所を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内所は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内所について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内所が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内所は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内所の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内所は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内所は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "停車場の待合室に傘を捨て、駅の案内所で、江の島へ行くには？",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご案内所望つかまつる」「はッ、控えおりまする。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八年頃、おもだった売場にある案内所が切符一枚について十五カペイキか二十カペイキの手数料をとって切符のとりつぎ販売をしていたことがある。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大あわてにあわてて駅員から駅員と走り廻り、やっとそれが案内所の方へ忘れ物として廻してあることがわかったが、それを受取りに行って汽車に乗込むまでの忙しさといったら一通りや二通りではなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　旅行案内所では急に夏の旅行パンフレットを店先に並べ出した。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜には、まだ早かつたが、時間があつたら上野公園も歩いてみようと云ふので、約束の日に、りよは鶴石に教へられた通り、上野駅のなかの、旅行案内所の前に留吉と立つて待つてゐた。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この組はこの組で、浅草｜千束町の市川段四郎氏自宅の舞台と、歌舞伎座案内所の表二階とで稽古していた。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤帽は私をつれて案内所へ行き、顏なじみらしい男と談判してゐたが、うまく一枚だけ手に入れることができた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の前の五色温泉案内所という札をかけた家に、初めて雪の上を歩きながらとびこんだ。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど大晦日の晩で、どこの一流旅館も新年中は休みだとかで部屋がなく、駅の案内所がここを世話してくれたのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅内の案内所が甚しく不親切で、旅先の心細さが身にしみる。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく元気になれたのは宇治山田駅へ着いてからで、駅内の交通交社案内所が親切そのものであったからだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は福岡で汽車を二時間待つ間、水タキを食う気になって、案内所で、駅に近い水タキ屋をきいた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それが支柱の十文字は同じでも、橋材が鉄に変つて新装した姿が、第二図（東京名所案内所載）で、われわれは初めからずつとこれに見参してゐる。",
              "citation": {
                "source": "両国橋の欄干",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院へ行く途中の町角に、某温泉の案内所がある。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "この恐怖の期間中、漠然とした胸騒ぎに動かされて、ウィレットは国際新聞切り抜き案内所に、プラハとトランシルヴァニア東部でその時々に発生した注目に値する犯罪や事件を集めるように依頼した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "場末の劇場だし、案内所で扱う切符ではないからと、蜂谷が切符の面倒も見てくれたのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅の案内所でしらべたとき、下関行急行は朝の四時すぎ岩国へつく筈であった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、かれはサン・マルコの広場から、そこにあるイギリスの旅行案内所へはいって行って、帳場でいくらかの両がえをしたあと、かれに応待している店員に、疑っている旅行者の顔つきで、例の宿命的な問いをかけたのである。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂の右手に紙を下げて薯掘案内所。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "金堂の右側にある案内所の辺に立つと、四つの堂を一望に眺めることが出来る。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札を出ると、案内所に寄り、旅館の名を確める。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "岐阜駅の鉄道案内所の話では、下呂以外に、ヒダの小さな駅に旅館があるかどうか、たぶんないだろうという話である。",
              "citation": {
                "source": "飛騨の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなにあんないじょうを出して、こんや見せるといってあるんだから、よすことはできないんだって。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
