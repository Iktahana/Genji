      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tomorrow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "殊に女には今日の表現が明日の存在になるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れる時その話のことで「明日かあさつては是非訪ねるから」と三田村自身云つたのだが未だに来ない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明日相談に出かけるとして今晩は一人で飲んで来よう。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女郎屋の印象は、私の故郷上州で唄ふ盆踊りの歌「鈴木主水といふ侍は、女房子供のあるその中で、今日も明日もと女郎買ひばかり。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の事を思うな、とあの人も言って居られます。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日をたのんで、その場をごまかして置くような事も今は、なくなりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は別の事を訓辞して、それとなく今日のを和げようと考へた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またそれを飲むと明日朝目覚が悪くて困るから。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は出際にお客さんがありはしたし……明日立つたら……」　母が「甘い」とよく彼が言ふので、また言はれはしまいかと思つて、遠慮深さうにさう言つた時、彼はさすがに「甘い」とはいはれなかつた、却つて自分の方が「甘い」だつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、俺は何時死ぬるのか、明日か明後日か……――やい、豚、寝ろ！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前｜一樽の楽しみの外、明日は明日はと言ひ暮して、終に賢者のそしりを受けぬ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はここから汽車にのって一と息に熊本へ帰るというので、一同元気づいてだいぶ賑やかに騒いだりした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はいよいよ鷹が貰えると思ってさんざんに待ちかねて、やっとその日になってみると鷹は今ちょうどトヤに入っているからもう二、三日待ってくれというのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ過ぎ、けふと暮れ、明日またかくこそ有るべけれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の事を思ふな、とあの人も言つて居られます。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日をたのんで、その場をごまかして置くやうな事も今は、なくなりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸派では、饗庭篁村が先達で、八文字舎風の軽妙洒脱な紀行文を書き『東京朝日』の続きものとして明日を楽しませた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒気の強いのと、明日の天候が気になるので、眼がよく覚める。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「十月二十六日夜九時、御殿場富士屋へ着、寒暖計五十六度、曇天、温に過ぐ、明日の天候を気遣うこと甚だし。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からまた稲扱きに寸暇もない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちゃ、明日から忙しいから、汽車ん中で寝て行き度えんだよ」「どこへ行くんだい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、――明日も早いから――とおふくろは云ってる。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日俺の出かけるのは、工場の前のピケッチングじゃないか！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日でもいいでしょう、と云ったんだが、どうしても直ぐにって署長の命令だからね、済まないが、直ぐに来て貰いたいんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い奴を腹ん中へ入れといて、上下から焙りゃこそ、あの位に酔っ払えるんじゃねえか」「うまくやってやがらあ、奴あ、明日は俺達より十倍も元気にならあ」「何でも構わねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い病気じゃないといいが……」　明日、水葬する、と云うことに決った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はどうなるであらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れ位の細工で防がれる程度の崩れ方もあるであらうが、此の十倍百倍の大工事でも綺麗に押し流すやうな崩壞が明日にも起らないといふ保證は易者にも學者にも誰にも出來ない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシックはテンポが遅いどころか、「ああした深いことをもう云つてのけたのか」と、君が若しミュジックなるものの存在に耳を触れるに相応しければ当然感ずる次第なのであつたかも知れない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
