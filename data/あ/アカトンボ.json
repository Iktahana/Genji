        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "日はやや西に傾いて赤とんぼの羽がきらきらと光り、風なきに風あるがごとくふわふわと飛んでいる、老人は目をしばたたいてそれをながめている、見るともなしに見ている。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシオの持った竹の枝に追われて、足の弱った年寄りばったや、羽根の痩た赤とんぼが、よちよち、ふらふら、逃げまどいました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは例の赤とんぼう日和であるが、殆ど一疋も見えない。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼうが乱れ飛んで、冷たい秋の風は馬のたてがみを吹き、人の袂を吹いている。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼが、兵太郎君のうしろを通っていって、ほし草にとまった。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、クルリと眼玉を転じました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼの休んでいる竹には、朝顔のつるがまきついています。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の夏、この別荘の主人が植えていった朝顔の結んだ実が、また生えたんだろう――と赤とんぼは思いました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、ツイと竹の先からからだを離して、高い空に舞い上がりました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、さっきの竹にまたとまって、じっと近づいて来る人々を見ていました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、かあいいおじょうちゃんの赤いリボンにとまってみたくなりました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、おじょうちゃんが怒るとこわいな――と、赤とんぼは頭をかたげました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど、とうとう、おじょうちゃんが前へ来たとき、赤とんぼは、おじょうちゃんの赤いリボンに飛びうつりました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、おじょうさん、帽子に赤とんぼがとまりましたよ。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、今におじょうちゃんの手が、自分をつかまえに来やしないかと思って、すぐ飛ぶ用意をしました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おじょうちゃんは、赤とんぼをつかまえようともせず、「まア、あたしの帽子に！",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、今日も空をまわっています。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんぼとんぼ　赤とんぼ　すすきの中は　あぶないよ」　あどけない声で、こんな歌をうたっているのが、聞こえて来ました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、あのおじょうちゃんだろうと思って、そのまま、声のする方へ飛んで行きました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼが、頭の上へ来ると、おじょうちゃんは、持ってたおもちゃの金魚をにぎったまま、「あたしの赤とんぼ！",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、とても愉快です。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　書生さんは、頭をかきながら歩き出しましたが、朝顔の葉にとまって、ふたりの話をきいてる赤とんぼを見つけると、右手を大きくグルーッと一回まわしました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な事をするな――と思って、赤とんぼはその指先を見ていました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、だんだん、その円を小さくして赤とんぼに近づいて来ます。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、大きな眼をギョロギョロ動かして、書生さんの指先をみつめています。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、眼まいをしてしまいました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの瞬間、赤とんぼは、書生さんの大きな指にはさまれていました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじょうさん、赤とんぼをつかまえましたよ。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの赤とんぼをつかまえたりなんかして――山田のばか！",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
