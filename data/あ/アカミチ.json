    },
    "definitions": [
      {
        "index": 1,
        "gloss": "non-legal public road (denoted by a red line on cadastral maps; sometimes no longer physically existing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（明治四十一年九月二十五日『東京朝日新聞』）　　　　　　　　　五　　　　　　秋分　昨日まで北半球の上に照っていた太陽がまさに南半球へ越えんとして丁度赤道の真上に来る日である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大洋特に赤道下の大洋における蒸発作用の旺盛な有様を「詩」で云い現わしたと思えば、うまい云い方である。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤道へ行っても実際は地球儀にかいてあるような線はどこにも存在しない。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤道から北極まで大循環さえやるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも面白かったねえ、ギルバート群島の中の何と云う島かしら小さいけれども白壁の教会もあった、その島の近くに僕は行ったねえ、行くたって仲々容易じゃないや、あすこらは赤道無風帯ってお前たちが云うんだろう。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一生けん命すきをねらってはひるのうちに海から向うの島へ行くようにし夜のうちに島から又向うの海へ出るようにして何べんも何べんも戻ったりしながらやっとすっかり赤道まで行ったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤道には僕たちが見るとちゃんと白い指導標が立っているよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより赤道に至る八千六百ベスターというような標もあちこちにある。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "委任統治のテニヤン、ヤップ、パラオ、サイパンはもちろん、時々は赤道直下のオーシャン付近からオーストラリヤ近くまでも延しますが、もちろん冒険ですから、運が悪いとやられてしまいます。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるかぎり赤道下の炎熱に鉛のごとき鹹水は炎と燃えて、海蛇の鎌首高く、たまたまに煌めき、さてはづぶづぶと青く沈みぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "王冠の代りにヘルメット帽をかぶり、スカアトの様な短袴を着け、欧羅巴式の脚絆を巻いた、この南海のグスターフ・アドルフは大変に珍しいもの好きで、赤道直下の彼の倉庫にはストーヴがしこたま買込まれていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして父なる太陽が赤道を北に越えて回帰線への旅を急ぐころになると、その帰りを予想する喜びに堪えないように浮き立って新しい緑の芽を吹き始める。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども南半球に至りては、高緯度に有て風と潮流が西より南米大陸に向ひ、赤道近くに隨ひ、風潮並びに南米より東方に赴き去り、凡て東半球と南米間に人類の彼此往來有りし確證實例なし。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今東半球の赤道以北よりすら、甞て南米に漂著せる人の絶無ならざるを證する爲に、予の日記の一節を略ぼ原文の儘寫し出す事次の如し。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方の密室は赤道以北の住民には見る能わざる星を総称したものであろう。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に於ては死水を、大気に於ては赤道直下を、大地に於ては細菌なき土壌を、而して人生に於ては感激なき生活を。",
              "citation": {
                "source": "描かれた花",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによれば、大西洋の赤道附近の海中に怪賊団あり、従来行方不明なりし人々は海底の船艙の如きものの中に幽閉せられて居ることが明かとなった。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく赤道附近が最も穩かではないかと思はれる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ緑青を溶かしたやうな青い海は南洋から始まり赤道を越え、さらに南下してビスマルク諸島、ソロモン群島、ニューギニヤの方面までずつと續いてゐるのである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすぐ赤道にかかるのだが、それにしては涼しい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある練習艦隊が赤道近くまで来たときに士官が下士卒に望遠鏡を渡し、どうだ向うに赤い線が見えるだろう。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが赤道だとからかうと、はい見えます。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この星が直上に来れば、赤道にかかった標とのこと。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれと同時に赤道に対する黄道の傾斜角を測定した結果が二八度三五分となっている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの暗黒な外皮が太陽赤道のまわりに環状をなして集まった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが破れて（十八図）渦の極からそれの赤道の方に落ちて赤道のまわりに一つの帯を作る（十九図）。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十二図　打ち出された削り屑もまた同じ方向に回転する、のみならず、刃物との摩擦のために右方に動く、すなわち、板の赤道の運動方向と同じ方向に並行して進む。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと全く同様に、彗星が太陽の面に斜めに入り込んだ際に分離した太陽の破片はすべて同じ方向に回り、衝突後の太陽の赤道と同じような軌道を描くはずである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃ハあかみちやとおしろいにて、はけぬりこてぬり／＼つぶしもし、つまづいたら、よこまちのくハしやのばゞあがついでかけ、こんぺいとふのいがたに一日のあいだ御そふだんもふそふというくらいのことかへ。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月二十日　姪春猪あて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
