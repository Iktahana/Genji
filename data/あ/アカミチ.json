[
  {
    "uuid": "d589eed9-da72-504b-9e82-73c6a27f507e",
    "entry": "赤道",
    "reading": {
      "primary": "あかみち",
      "alternatives": [
        "あかどう"
      ],
      "is_heteronym": false
    },
    "grammar": {
