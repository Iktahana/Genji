          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "月の影、川風、思、画堂、青潮、水の音、初夏、中津川、ほたる、杜鵑……これはと思ふ心地よき題もなきに、我まづ聊かひるみたれど、稚なきものも交れる今宵なればと、人々心したりと見ゆ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなる護岸工事の板石の傾く上に乗れる青潮　これは新潟港の所見である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "青潮にはその中に作者の心が溶けてゐて抒情性がそこに生れるのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝ミネリア国の海岸が見え、舳先には青潮がゆっくり流れていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
