    "definitions": [
      {
        "index": 1,
        "gloss": "failing to get a job",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日溢れについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "溢れという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は溢れの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には溢れが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "溢れを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは溢れについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "溢れの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は溢れの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では溢れが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "溢れという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に溢れという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では溢れについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "溢れを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると溢れは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "溢れについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では溢れが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に溢れは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により溢れの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "溢れは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に溢れは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "實に彼はその病弱の體躯の中に、無限の精力に溢れた「少年客氣の勇」をもつてゐたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤や青やの派手な色をした更紗が、春風の中に艶かしく吹かれているこの情景の背後には、如何にも蕪村らしい抒情詩があり、春の日の若い悩みを感ずるところの、ロマネスクの詩情が溢れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情感深く、詩味に溢れた名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気宇が大きく、しかも無限の抒情味に溢れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花｜茨故郷の道に似たる哉「愁ひつつ丘に登れば花茨」と類想であって、如何にも蕪村らしい、抒情味に溢れた作品である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもあの頃の『ホトトギス』には何となしに活々とした創成の喜びと云ったようなものが溢れこぼれていたような気がするのであるが、それは半分は読者の自分がまだ若かったためかもしれない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴講者はいつも教場に溢れていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二勺より路は黒鉄を鍛へたる如く、天の一方より急斜して、爛沙、焦石、截々、風の噪ぐ音して人と伴ひ落下す、偶ま雲を破りて額上｜微かに見るところの宝永山の赭土より、冷乳の缸を傾けたる如く、大霧を揺るよと見る間に、急瀬上下に乱流する如くなりて、中霄に溢れ、片々｜団々、がり、故郷を望んで帰り去なむを私語く。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が草木が洗われて、富士山と釜無川の大断層と、南アルプスや、関東山脈の高屏風に囲まれた日本最大の裾野が、大空を持ちあげるばかりの力をみなぎらして、若い力から溢れる鮮新味で輝きわたるのを見たことを悦ぶ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨山脈の槍ヶ岳から鎌尾根という山稜にかかる辺に、その岩石は洪水のように溢れている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお登ると、二合二勺の室には水まで汲み込んだ樽が置いてあり、竈の側には、薪が三把ほど転がっている、防寒具を整えて来なかったが、これで焚火に事欠かないと解って、仮令天候が悪くっても、泊る宿があるという気強さが、頓に胸に溢れて来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎの小説が、中途までくると、私は、仰向けに寝転がつて、溢れる涙をそうつと、たもとでふいた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千の兄弟たちが、あの光り輝く工場の中の部署についている三千の兄弟たち、あの工場以外のどの工場にも、労働者街にも溢れている、全プロレタリアの均しく背負っている苦痛なんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "澤山の旅館の浴槽を充たしてなほ餘りがあると見えて、惜氣もなく道端の小溝に溢れ流れ下つて溪流に注いで居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月からの雨に荒川が溢れたと見えて、川沿の草木はみんな泥水をかむつたまゝに干上つて一樣に情ない灰色をして居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある学会で懸賞問題を出して答案を募ったが、その問題は「コップに水を一杯入れておいて更に徐々に砂糖を入れても水が溢れないのは何故か」というのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃林の在るところは、大体川砂の両岸に溢れた軽い地層である。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押當て其端を喰ひしめつゝ物いはぬ事小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり聲のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押当てその端を喰ひしめつつ物いはぬ事｜小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり声のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な結婚をした出戻りではあるがまだ三十になったばかりの美しい敏子はかなり派手な着物をすらりとした身体に着こなして魅力の溢れた挨拶をした。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のせいか渾身に喜びが溢れてくる。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中からシャリアピンの悲しくも美しいバスのメロディーが溢れ出るのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大都市の冬に特有な薄い夜霧のどん底に溢れ漲る五彩の照明の交錯の中をただ夢のような心持で走っていると、これが自分の現在住んでいる東京の中とは思えなくなって、どこかまるで知らぬ異郷の夜の街をただ一人こうして行方も知らず走っているような気がして来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中にいっぱいにたまっていたものが大河の堤を決したような勢いで溢れ出した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも日本人はだめだ」と口癖のように言っていた、その言葉の裏にもやはり酌んでも尽きない憂国の至誠が溢れていたのである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も勿論愉快が溢れる……、宇宙間にただ二人きり居るような心持にお互になったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の推察通り、棉は末にはなっているが、風が吹いたら溢れるかと思うほど棉はえんでいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一目逢いたかった……次から次と果てしなく思いは溢れてくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時には今夜はあぶれたと誤魔化していたんですが、それでも自分ひとりでは何だか疑われそうに思われるので、釣り仲間の為さんも一緒だなどといい加減なことを云っていたらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
