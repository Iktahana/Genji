          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日在りしについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "在りしという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在りしの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在りしが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在りしを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在りしについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "在りしの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在りしの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在りしが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在りしという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在りしという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在りしについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在りしを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在りしは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在りしについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在りしが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在りしは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在りしの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在りしは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在りしは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "カケラ、人間のカケラ、動物の一片、嘗つて在りしものの殘骸のやうなもの、これらすべてのものは、なほも動きつつあるのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の大阪の顔は或は古く或は新しくさまざまな粧いを凝らしていたものだが、今日の大阪はすでに在りし日のそうした化粧しない、いわゆる素顔である。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　われとわが作品へ、一言の説明、半句の弁解、作家にとっては致命の恥辱、文いたらず、人いたらぬこと、深く責めて、他意なし、人をうらまず独り、われ、厳酷の精進、これわが作家行動十年来の金科玉条、苦しみの底に在りし一夜も、ひそかにわれを慰め、しずかに微笑ませたこと再三ならずございました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれが真珠、いずれが豚、つくづく主客てんとうして、今は、やけくそ、お嫁入り当時の髪飾り、かの白痴にちかき情人の写真しのばせ在りしロケットさえも、バンドの金具のはて迄。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥州津軽の外ヶ浜に在りし頃、所の役人より丹後の人は居ずやと頻りに吟味せし事あり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の道衍と識るに及びたるは、道衍が嵩山寺に在りし時にあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿に在りしもの凡そ五六十人、痛哭して地に倒れ、倶に矢って随いまつらんともうす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶源頼朝の蛭が島に在りしや、僅に伊豆一国の主たらんことを願ひしも、大江広元を得るに及びて始めて天下を攘みしが如き也、正統記大鏡等、蓋し其跡に就いて而して之を拡張せる也、故に採らず」と云つてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、われ、岡の木かげに夢心地、在りし静けさ忍ばれぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大学に在りし日に、余が品行の方正なるを激賞したる相沢が、きょうはいかなる面もちして出迎うらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と搖り動すに、死屍は口を開かむとすれば、海水忽ち入り塞ぎて、苦しげなるを、骸骨は『陸上に在りしと海中とは、すべて自ら異れり、さればしづかに物いふべし。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ余りの事に呆れ果て、茫然と佇みて在りしが、物好きの心俄かに高まり来りて止み難くなりつ、何気なく前庭に出づるに、早くも起き出でし寺男と思しく、骨格逞ましく、全身に黥したる中老人が竹箒を荷ぎて本堂の前を浄め居り。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "加旃ず主人公に扮するは、嘗てナポリに在りしとき、闔府の民をして物に狂へる如くならしめきといふ餘所の歌女なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方の故郷に在りし間、常に我｜懷に往來せしものはこの景なり、この情なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は先づ當時の評語を讀みて、さて知らぬ都會の新聞紙のいかなる事を載せたるかを見ばやとて、あちこち翻し見給ひしが、忽ち我面を仰ぎ視て、おん身はアヌンチヤタの同じ時ナポリに在りしをば、まだ我に告げ給はざりきと宣給ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジユウゼツペは他郷に在りしが、我毛髮の彼銚中に入ると齊しく、今まで忘れ居つるテレザの慕はしくなりて、醒めては現に其聲を聞き、寢ねては夢に其姿を視、そぞろに旅のやどりを立出でゝ、おうなが銚の下に歸りぬといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "曩に拿破里に在りし時、獨逸の士官等の、瑞西の山水を説くを聞き、一たび往いて觀んことを願ふこと漸く切なるに、汽船もて達し易きジエノワを距ること遠くもあらぬを知れば、意を決して往くことゝしつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十四年頃、予西印度に在りし時、京都の長谷川長次郎とて十七八歳の足藝師、肺病にてジャマイカ島の病院にて單身呻吟し居たりし。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく大學に在りし日に、余が品行の方正なるを激賞したる相澤が、けふは怎なる面もちして出迎ふらん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にここに記されざる多くの苦痛がヨブに在りしことは、後章に至って知れるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父在りし日さへ月謝の支出の血を絞るばかりに苦き痩世帯なりけるを、当時彼なほ十五歳ながら間の戸主は学ぶに先ちて食ふべき急に迫られぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五章　遊佐良橘は郷里に在りし日も、出京の遊学中も、頗る謹直を以て聞えしに、却りて、日本周航会社に出勤せる今日、三百円の高利の為に艱さるると知れる彼の友は皆驚けるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "立尽せる貫一が胸には、在りし家居の状の明かに映じて、赭く光れるお峯が顔も、苦き口付せる主が面も眼に浮びて、歴々と相対へる心地もするに、姑くはその境に己を忘れたりしが、やがて徐に仰ぎ、徐に俯して、さて徐に一歩を行きては一歩を返しつつ、いとど思に沈みては、折々涙をも推拭ひつ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間貫一が鴫沢の家に在りし日は、彼の兄の如く友として善かりし人、彼の身の如く契りて怜かりし人にあらずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川臺の南端、平地にかけての大なる一と構へは、もと水戸侯の邸宅の在りし處、義公の住みし處、烈公の住みし處、藤田東湖の住みし處、今や、砲兵工廠となりて、幽趣を極めたる後樂園、深く煤烟の奧に鎖さる。",
              "citation": {
                "source": "小石川臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "澤田子、後ろに在りしが、忽ち脚を失して、ころ／＼と轉がり來たる。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、証人席に在りしアリナの実父母が歔欷するあるのみ。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此説は邪馬臺が筑紫に在りしを證するには不十分なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにわれら死ぬ時に心の杖となるものがあるなら、ありし日がわれらの何かを慄はすかの何か！",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌雲閣上人豆のごとしと思う我を上より見下ろして蛆のごとしと嘲りし者ありしや否や。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
