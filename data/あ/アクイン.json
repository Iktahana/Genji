          ],
          "literary": [
            {
              "text": "いつまでたっても終りにならぬ、どこどこまでも悪因悪果、悪果によって新に悪因をつくる。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実相平等とは善因は善報を受け、悪因は悪報を受けて、ちゃんと割り切れるという、物事の実体方面で常に不増不減のところを指します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやかしの鼓が百年の間に作って来た悪因縁が、君の手で断ち切れるか切れないかは二十六日の晩にきまるのです。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玉を懐いて罪あり」HOFFMANN「悪因縁」　　　　　KLEIST「地震」　　　　　　KLEIST　それにつづいて、四十篇くらい、みんな面白そうな題の短篇小説ばかり、ずらりと並んでいます。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　かつたいの痂うらみ西　蛙の面に水　東は悪因を有するものの徒に悪果を恨み歎ずるを笑ひ、西は冷※然として平らかなるものの如何ともす可からざるを憎めるなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪因縁だ」――軈てしてほつと眼を下に落して又染々と剃刀の刃を手元に引よせた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪因縁だ」――もう逃れつこはありやしない。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、何らの悪因ぞ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "善因善果、悪因悪果、悔い改めよの、心を入れ換えよの、やれ神罰の、仏罰の、天の怒り地の祟り、親罰、子罰、嬶罰のと、四方八方からの威し文句の宣伝ビラが昔から到る処ふり撒かれておりますが、近頃の人間は頓と相手にしなくなりました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ふた夜』これはたしか読売新聞に出た、『うき世の波』『悪因縁』これは国民之友に出た。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "クライストの『悪因縁』『地震』あれは始め『国民之友』に出た。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "このペチヨリンに比べると、『悪因縁』『地震』『ふた夜』などは、全くドイツである。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして迷ひ込んだが最後逃れやうたつて離れられるもんぢやない、次第に悪因縁は青い蛇のやうに柔らかに絡みつく、どうせ死ぬまでは白い歯形が霊の底までも喰ひ入らねば放すもんぢやない。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民小説という赤い表紙の四六版の本の中には、「地震」と「うき世の波」と「悪因縁」という三編がある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも運命は不思議なもので、この寺の近所に住む佐藤孫四郎とお近とが一種の悪因縁を結ぶことになって、お近は主殺しの大罪を犯したのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、何等の悪因ぞ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同上参照）事は今から約四十年以前、中国地方のある一寒村に於ける二つの家の悪因縁話からはじまる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間もなく結ばれた悪因縁！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪因縁の怨は今も仰々子が語り伝えている。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや一旦の悪因縁を結んで念々に解きやらず。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて虹汀は心静かに座定を出で、家人を招き集めて演べけるやうは「吾、法力によつて、呉家の悪因縁を断つ事を得たり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一番新らしい科学の知識で研究して、その悪因縁を断ち切っておこうではありませんか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武家は、長崎以来、長崎屋等と、悪因縁を持つ、浜川平之進にまぎれもなかった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは云えお前の身の上に降りかかっている悪因縁はその黒法師の為す業じゃ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しく恐ろしい悪因縁！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の後悪因縁の※わる処か、同胞にて夫婦になるという、根岸の因果塚のお物語でござりまする。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
