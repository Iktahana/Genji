    "definitions": [
      {
        "index": 1,
        "gloss": "to be possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り得について考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り得という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り得の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り得が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り得を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り得について学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り得の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り得の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り得が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り得という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り得という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り得についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り得を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り得は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り得について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り得が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り得は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り得の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り得は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り得は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかも宿命的な詩人の悲願は、その有り得べからざる夢の国を、生涯夢見続けることの熱情にある。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼死してどこにまた第二の芥川が有り得るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが子供の心理が不變の限り、童話そのものの本質が變化するやうなことは有り得ない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに科學日本の躍進を誇る現代でも、本質的にフアンタスチツクの夢を持たず、子供の心理と沒交渉に語られる如き奇怪の童話、即ち「事實に即した現實主義の童話」とか「科學的合理主義の童話」なんてものは有り得ない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理上から考へても、そんな不思議なことは有り得ない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国文化の輸入に於て、翻訳が絶対に不可能のこと、実には「翻案」しか有り得ないこと、そして結局、すべての外国文化の輸入は、国民自身の主観的な「創作」に過ぎないことは、以上の一例によつても解るのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の話であるが、『藪柑子集』中の「嵐」という小品の中に、港内に碇泊している船の帆柱に青い火が灯っているという意味のことを書いてあるのに対して、船舶の燈火に関する取締規則を詳しく調べた結果、本文のごとき場合は有り得ないという結論に達したから訂正したらいいだろうと云ってよこした人があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ多少の欠点はあるとしても、およそ神様でない人間のした事で欠点のないものは有り得ないことはあまりにも明白なことであるから、それよりも仕事の長所と美点を明白に認識して、それに対して学位を授けるということにすれば事柄はよほど簡単になるであろうと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで味いはあるがつまらぬ歌だというような歌は有り得ない事であろうと思うことに多くの疑いは起らぬけれど、味いというような感じはないが、何処か面白いというような歌はあるいはあるだろうと思われる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう事は有り得ない事ではないかもしれないが、少しおかしい事である。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一体そういう自由がこの世に有り得るものか、どの程度までそれが可能であるか、またその可能限度まで自由を許すことが、当該学者以外の多数の人間にとって果していつでも望ましい事であるか。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が彼の發議に反對するとき、いつも吃驚したやうに――有り得べからざることが起つたやうに――奇異の顏付をしてぼうとしてゐる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の自由平等といふことは、社會的や制度的には眞理であるか知らないが、人格上には決して有り得ない。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の意味での科学的事実では到底有り得ない事はもちろんであるが、しかしそれらの記録の中から今日の科学的事実を掘り出しうる見込みのある事はたしかである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狂人の文学」はわれわれの文学では有り得ないであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばＡかＢかのほかには何物も有り得ないという仮定のもとに或る人間の問題を取り扱っている際に、ある物質界の現象を学ぶことによって忽然として、他にＣの可能性の存在を忘却していたということに気がつくことがしばしば有りうるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ、きれいでない新婦などは有り得ないのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「実際有ることか無いことかは知りませんが、有り得ることとは信じます、それは。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心の不思議を知って居るものは、童児の胸にも春の静な夕を感ずることの、実際有り得ることを否まぬだろうと思います。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人一倍美しいやさしい感情を持っていなかったのであったら、このような煩悶はおそらく有り得なかったのではあるまいか。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは俳諧は有り得ない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に有り得べからざることも為し得る仙術ということさえある。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンとカンで動く水の上の作法として、このようなことも有り得るように思う。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに一石橋当夜の紳士と、生理学教室における国手とが同一人である事を確めた上は、些少たりとも犯罪に対して何等その疑いは無いのでありますが、お話のごとき事が事実有り得るものかどうか、後学のため、一種人情に対する警官の経験の為に、云うて、その室で飾ると云われた、雛を見せて貰うたです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肖像画が変化を生ずるなんて、そんな事実がこの世に有り得るであろうか。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容とは筋ではない、映画が若しも如何なる意味に於てか芸術で有り得るとするならば、その芸術自身の姿だが、そんなものは全く蔑にされ忘れられてしまっているではないか、と。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ内心では、かうした人気のない山道で、美しい娘等と道づれになり、一口でも言葉を交せられることの悦びを心に感じ、空想の有り得べき幸福の中でもぢもぢしながら。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまた金十錢の飯を食ふべく、それだけの收入が有り得るやうに、彼の善き神に向つて哀願した。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこんな事實が、實際に有り得ないといふことは無いだらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、月並みな陳套な正札付きの真実よりも、うそから出た誠にかえってより多くのより深き真実を見いだすこともありうるという意味で、こうした言葉を使っているのではないかと想像される。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
