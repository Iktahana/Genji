[
  {
    "uuid": "5e7bc47e-b4a7-592a-97c9-940b99dcbc38",
    "entry": "有らせられる",
    "reading": {
      "primary": "あらせられる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
