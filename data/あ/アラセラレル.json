    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有らせられるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有らせられるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有らせられるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有らせられるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有らせられるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有らせられるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有らせられるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有らせられるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有らせられるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有らせられるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有らせられるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有らせられるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有らせられるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有らせられるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ホオ……と僕はお道化てゐるんだがまだ見ぬ先生に意地の悪い気持を抱いてゐるんだが、煙草をまづく感じ出すと、飛行機のみならず、洋服掛にまで、異常な好奇心を覚ゆるのであつた――とにかく御幸福なお方であらせられるよ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇室のあらせられる京都が、何故このやうに悲しげな姿に見えるのか、と良寛さんは訝つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかの山河と、いくへかの雲の奥に、皇居があらせられるのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの方が仙妃であらせられる、そそうのないように」　青年はそれを聞くとそのままそこへべったりと這いつくばってしまった。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に近藤の光栄とすべきは、宮中第一の豪傑であらせられる、久邇宮朝彦親王との関係である。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、天皇は天つ神の神意を受けて、大八洲国に降臨せられた皇孫の御後裔であらせられるから、常に天つ神を祭り、その神意を奉体せられるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで、尊氏は使者を比叡山に遣し、偽り降つて、天皇の御還幸を乞ひ奉り、天皇が還幸あらせられると、花山院に幽し奉つたので、天皇は夜に乗じて、神器を奉じて吉野に行幸あらせられた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こちらはピエロ・ガールスの座附作者であらせられる北山老人」　よろしくと豹一が頭を下げると、北山は瞬間別人のように改った表情をちょっと見せて、「これは、これは……。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれにいらるるが大王であらせられる、早くお前の持っておる霊薬を差しあげてくれ、お前のことをお聞きになって、大王も非常にお喜びになっておられる」　番兵はこう言って李生の顔を見た。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは神の御声であらせられる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いくらか時機おくれで、またかなり疑わしい証言ではあるが、ドリュック夫人の鋭い非難をこうむっている無頼漢団というのはだね、この正直で遠慮深くあらせられる老夫人が、自分のところの菓子を食い、ブランディーを飲んで、勘定を払おうとはしなかったと言っている無頼漢団だけのことなんだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "この向うに座しておられるやんごとなき淑女は、わが妃、ペスト女王であらせられる。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "「陛下が一言もおっしゃらぬうちから、我が面前にあらせられるのは、ヴィルヘルム・ゴッツライヒ・ジギースモーント・フォン・オルムシュタイン、つまりカッセル＝フェルシュタイン大公であり、ボヘミア累代の王であると存じておりました。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただヴェダであらせられるあなただけが御分りでありましょう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし幸い可能であるとすれば、それがためにも最高道義の護持者であらせられる天皇が、絶対最強の武力を御掌握遊ばされねばならぬ。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車で運ばれる途中、御宅で式を挙げる時、それから披露の宴席に列なりました間、私はただもう恐しい夢を見て居るような心地がしましたが幸いに近視眼であらせられるあなたには、私のただならぬ顔色も不審がられずに済みました。",
              "citation": {
                "source": "秘密の相似",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都には、かつてわが国を無階級で自由な一国に統一して合理的な政治によって万民をうるおした聖天子の末裔があらせられる。",
              "citation": {
                "source": "文学に関する感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、皇后陛下で在らせられた皇太后様は、毎年文展に行啓あらせられ、殊のほか絵画に御興深くあらせられるように拝されました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度三室戸伯爵からも、今年六月に皇太后陛下がお久し方振りに京都に行啓あらせられるから、その折りに間に合うようにというお話もありました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御隠居様に於いては甚だ御心痛あらせられる。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度堺表の事件に就いては、外国との交際を御一新あらせられる折柄、公法に拠って御処置あらせられる次第である。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮は猫が非常にお好きであらせられるために、くわしくお尋ねになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御息所のお亡れになったのを悲しむことと宮様のいつまでも御冷淡であらせられるのをお恨みするのが私の心の全部になって、ほかのことは頭にありませんから、だれからも私は怪しまれてしかたがありません。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた美貌であらせられる姫宮をよく御覧になれぬことを物足らぬことにしておいでになるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はまだ神さまがどんなに慈悲深く、寛大であらせられるかを知らんのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シテ、その小笠原金三郎とやら申す浪人の所持致す脇差に就て、御上には御心覚えあらせられるかあらせられぬか。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御脇差を御直々に、侍女鶴江に御遣わしの御覚え、あらせられるか、あらせられぬか、何んと仰せあそばされた」「どうも覚えは無い……との御言葉」「ふむ、その御言葉は、濁っていたか。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の真の味方は国民を以て赤子とし、国民の休戚を以て大御心とせられる歴代の天皇があらせられるばかりです。",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の仰ぐ陛下は、同時に大和民族と云ふ大きな家族の家長であらせられる。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
