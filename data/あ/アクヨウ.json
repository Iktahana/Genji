          ],
          "literary": [
            {
              "text": "「記録」は客観的事実であり、これは科学の場合と同様に、無限なる利用と悪用の可能性を包蔵している。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんすべての知識には悪用の危険性を含んでいる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は特に男達から甘い点をつけられることもなく、彼女自身も、またその女の特点を、善用も悪用もしなかつたやうである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "名誉な太宰治は痲痺状態で小説を書くコツを悪用する。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸でも、きつと彼の名を悪用して飲みまはるだらうと思はれた。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　法律の力を悪用して、善人を苦しめる悪魔を懲しめる手段は、これより外にはないのでございます。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御禁中警固、京一円取締りの重任にあるべき所司代詰の役侍が、その役柄を悪用して不埒を働こうとしているだけに許せないのです。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにも拘わらず、珠数屋のお大尽を引ッ立てると殆んど同時のように、かくも身代押えを急いでいるのは、弥太一の言ったごとく、役向き権限を悪用して巧みに財物を私しようとのよからぬ下心であることが、すでにその一事だけで一目瞭然でしたから、退屈男の江戸魂は勃然として義憤に燃え立ちました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "水晶の印をお用いになれば、彼の新聞に出まするような恐ろしい詐欺や横領、その他文明社会に流行しまする法律悪用の悪漢の毒牙にかかる患いは一切ございません。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何となれば、もし薄弱なる背景があるだけならば、徒にインデペンデントを悪用して、唯世の中に弊害を与えるだけで、成功はとても出来ないからである。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレン・ケイの論旨は、要するに、スエデンの青年社会民主党に対して、「ひまな時間を増やす事の為めに闘うと共に、其のひまな時間の悪用されないように休養的教養を獲得しなければならない。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず、それは悪用される。",
              "citation": {
                "source": "「チャタレー夫人の恋人」の起訴につよく抗議する",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学との関係で政治がいわれる場合、その政治は、けっして文学の利用者また悪用者としての政治を意味しない。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者自身がもっともよく遅れた労働者がどんなに階級の負担であるかということとそれを悪用する勢力の現実を知っています。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を与えられたものはその自由を利用して国への反逆者をつくり、権力を与えられたものは、その権利を悪用して学の自由を奪おうとしている。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本国内の旧支配権力は天皇に対する連合国側のこの利用的譲歩の技術に乗じて全くそれを悪用している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電力飢饉に関連して、いわゆる「進駐軍の命令」が悪用された例をみてもわかる。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四六年度の選挙で注目されたことは、意外に多数の教育者が立候補したことと、その中のある者は最高点を得ているけれども、半面に教育者の立場を選挙運動のために悪用した候補者の例も挙げられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の人民は自分たちの政治的無経験がどんなに悪用されているかということについて目を覚ましはじめている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の愛を最もたえがたい方法によって悪用されまいとするだけにも、絶間ない精神と肉体の緊張を必要とした。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、権力が悪用しようとするすべての悪法への嫌悪と、それにあくまで抵抗してゆく民主的理論についてゆくことをこわく思う個人の心とを、ごっちゃにして歴史の前進と自身の運命を混乱させてはならないという教訓である。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体夫人の言語や挙動にはsuggestifな処があって、夫人は半ば無意識にそれを利用して、寧ろ悪用して、人の意志を左右しようとする傾きがある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体夫人の言語や挙動には suggestif な処があって、夫人は半ば無意識にそれを利用して、寧ろ悪用して、人の意志を左右しようとする傾きがある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くこっそりと起る人知れぬこんな心は、悪用すれば際限のないものにちがいない。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤慨の余り書物を悪用する例もあるけれども、善用すれば修養を積み人格を養ふ糧となる。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかこれをごらん下さい」「なに、怪電波を発射したって」　リット少将も、さすがにちょっと顔を硬ばらせて、スミス中尉のさしだした紙片を穴のあくように見つめた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は驚いてドアをあけ、母の寝室の前にいつてお母様、お母様と叫びましたけれども、中からは苦しそうなうなり声がきこえるばかりで、一向に戸のあくようすもありませぬ、戸をわれるように叩きましたが駄目です。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはすぐ穴があくようになっているのである。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊主、お喋り坊主、中で押えてるな、小癪な奴だ、しっかりと押えてあかないようにしているな、よし覚えていろ、今、あくようにしてあけて見せるからな」　神尾主膳はこう言って、暫く暴力を中止しましたから、中でお銀様は、それ見ろと言わぬばかりの心持です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時分はよしと見た頃合に、主膳は、やはり本性たがわず、投げ出しておいた槍を手さぐりに拾い取って、「坊主、覚えていろ、今、あくようにしてあけて見せるから後悔するな」　こう言って、今度は、たしかにこの土蔵の前を立去って、母屋の方へ行く足音がします。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
