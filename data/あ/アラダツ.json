[
  {
    "uuid": "013638ac-acc5-56c4-9818-04f255eae752",
    "entry": "荒立つ",
    "reading": {
      "primary": "あらだつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become rough (waves, temper, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒立つについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒立つという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒立つの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒立つが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒立つを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒立つについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒立つの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒立つの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒立つが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒立つという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒立つという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒立つについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒立つを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒立つは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒立つについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒立つが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒立つは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒立つの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒立つは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒立つは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "近頃は不作法な、弓矢、鉄砲で荒立つから、うるささもうるさしさ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、歸つてゐなければならないのにと思ふと、何をぐづ／＼してゐるのか、不埒だとまで心が荒立つて來る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやで氣が荒立つて來ると、燒け半分に筆も何もほうり出し、千代子を毆ぐりつけた時などと同じこころ持ちで家を飛び出し、半夜を全く玉突き屋で過ごしてしまうことも度々だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為めに心を紛乱し、得体のしれぬ憎悪、嫉妬、侮蔑のような感情が荒立つ儘に委された。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒立つて來れば、已むを得ず、法律にあるだけの處罰は加へますけれども、同族關係のことに就いては、政府も成るべく知らぬ顏して進んでそれに干渉しないことになつて居りまして、同族間に中々強い制裁が行れました。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスがこの地方を占領して以來、日露戰役直後ほど、安南人の人氣の荒立つたことはないと傳へられて居る。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日ごろのあの男にも似合わねえが――もっとも、武芸という奴は、出来れば出来るほど、用心深いというから、荒立つことをして、毛を吹いて傷を求めるより、あとでしずかに手だてを凝らそうとしているのかも知れねえが――ええ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんなことを思って打壊された痛い心と、面と向って突掛られる荒立つ心とを凝乎と取鎮めようとしていた。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "公安委員ともあろう人が」　小野の語気が荒立つので、署長が制した。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏箒木の巻に、鬼神も荒立つまじき御気はひなれば、はしたなく、こゝに人どもえ罵らず。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同時に、オリヴィエの思い出、オリヴィエの死から来る絶望の念、満たされ得ない創作の妄執、虚無の深淵の前に荒立つ自負心、などもあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
