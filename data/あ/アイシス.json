  {
    "uuid": "e79cd5ec-319a-508d-8274-d633f018b8ad",
    "entry": "アイシス",
    "reading": {
      "primary": "アイシス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
