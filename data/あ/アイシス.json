    "definitions": [
      {
        "index": 1,
        "gloss": "ISIS",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、ＩＳＩＳは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではＩＳＩＳが重要です。",
              "source": "幻辞"
            },
            {
              "text": "ＩＳＩＳに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではＩＳＩＳが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でＩＳＩＳについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からＩＳＩＳについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではＩＳＩＳについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではＩＳＩＳが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではＩＳＩＳが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＩＳＩＳは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてＩＳＩＳは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にＩＳＩＳを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にＩＳＩＳをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でＩＳＩＳが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、ＩＳＩＳの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はＩＳＩＳを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はＩＳＩＳに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でＩＳＩＳについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からＩＳＩＳは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはＩＳＩＳを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「……アイシスとオリシス――」　と彼は片手に抱へてゐる一冊の本の包を云つた。",
              "citation": {
                "source": "黄昏の堤",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アイシスは娘の名、オリシスは――」「恋人？",
              "citation": {
                "source": "黄昏の堤",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の各学部は古色を帯びて絵のようだが、街々もたいてい壮麗であり、すてきな緑の牧地を通って市のそばを流れるアイシス河は、木々の間に抱かれた塔、尖塔、円屋根などの集まりを映す渺茫とした水鏡をひろげている。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
