        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿父について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この阿父は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "阿父の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が阿父について知っています。",
              "source": "幻辞"
            },
            {
              "text": "阿父は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は阿父の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "阿父に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では阿父が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から阿父を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "阿父の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも阿父が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では阿父が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "阿父について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも阿父は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも阿父は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で阿父は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に阿父について学びました。",
              "source": "幻辞"
            },
            {
              "text": "阿父の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する阿父の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では阿父の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "伯爵は三番目の娘の露子に向って、「露子、和女は何うじゃ」　露子は此時初めて口を開き、「ハイ、妾何んだか恐い様に思いますけど、阿父様の仰しゃる事なら参りましょう」　斯くて相談は定まり、三人の娘は一人ずつ流星の落ちた森林を探検する事となった。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ不思議だこと、先刻の流星が此様な物を落して行ったのではありますまいか、不思議と云えば此箱こそ実に不思議なもの、持って帰って阿父様に御覧に入れましょう」と、露子は其箱を持上げて見ると非常に重かったけれど、夫れを両手に抱えて家に帰って来た。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘は呆気にとられ、「阿父様、なんですなんです」と、その跡を追いかけたが、博士は振り向きもせず、別荘の自分の書室に飛び込むやいなや、扉に鍵をピンとおろし、件の不思議なる書面を卓上に押しひろげ、いよいよ深く眉の間に皺を寄せて、ふたたび熱心に読み始めた。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘は室の外まで押し寄せきたり、鍵のおろされたる扉をコトコトと叩いて、「阿父様、何か珍しい事なら聴かせて頂戴な、あら鍵なんかおろしてひどいこと――」と呟けど、博士は知らぬ顔、「お前達の聴いても役に立たぬ事だよ」と、一声云ったばかりである。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――聞きねえ、親なり、叔父なり、師匠なり、恩人なりという、……私が稼業じゃ江戸で一番、日本中の家元の大黒柱と云う、少兀の苦い面した阿父がある。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可いかね、その気だもの……旅籠屋の女中が出てお給仕をする前では、阿父さんが大の禁句さ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人々の阿父さんや祖父さんは、六十年｜前にここを過ぎて、工事中のお台場を望んで、「まあ、これが出来れば大丈夫だ」と、心強く感じたに相違ない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も丁度ここで逢ったから、腕を掴んで引摺上げて与ろうと思ったんだけれど、生憎阿父さんが一所だったから、まあ堪忍して置いて与ったのさ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア、阿父さんと冬子さんと三人で柳屋へ行って、私が其後遊びに行ったことが有るか無いか訊いて見ましょう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿父さんは何うしたろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿父さんか、お杉か、但しは別人か。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父さんは何うも飛んだ事だったね。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うと、君ばかりでなく、死んだ阿父さんまで侮辱するようだが、実際｜詰らない災難に逢ったものだよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿馬鹿しいの、詰らないのと云うものの、君の阿父さんが斯んなことになろうとは、実に夢にも思わなかったよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "角川の阿父さんの屍体が横わっていたのは……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話が阿父のやうな壓制君主までも、此處だけは治外法權として、何等の侵略を加へ得ない奴さ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然うさ、阿父の想は解かツてゐる、俺を家の番人にしやうといふんだ………魂のある道具にして置かうといふんだ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體家の阿父なんぞは、慈愛だとか、人權を重んずるとかいふ考があツて耐るものじやない、とすりや、俺が此の家の嗣子となツたといふのも、俺自身に子爵家の嫡子となツてのさばる資格があるのじやなくツて、事件が作ツた資格さ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺に取ツちや眞箇偶然に得られた資格で、阿父からいふと必要に迫まられて與へた資格なんだ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父は俺を生むで呉れた、併し其れが何も負ふところはありやしない………俺は阿父に對して何等の義務も約束も持ツて生まれて來なかつた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜片の宣言書＝＝其は頭から尻尾まで、爆發した感情の表彰で、激越を極め、所謂阿父の横ツ頬へ叩き付けた意味のものであツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好い氣味だ、阿父め、遉に吃驚してゐるだらう。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と笑出して、「阿父め、確に俺に是れだけ行る度胸が無いものと見くびツてゐたんだからな。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大手を振ツて阿父の許へ出掛けて、俺の腕を見ろいさ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程此の事じや、其様に阿父を憎むことは出來ないて！",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやはや、も、阿父の亡くなツた時のまごつき方と謂ツたらありませんでしたね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房は傍から口を出して、「だけど、阿母さん、そりや阿父さんが生きてお在だツたら、此様に世帶の苦勞をしないでゐられるかも知れないけれども、其の代また何様な苦勞かあるか知れたもんじやないのね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父が亡くなつたからツて、此様に窮らなくツても可い譯なんですがね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "其でも滅多と欝いだり悄氣たりしてゐるやうなことはなかツたが、何うかするとツク／″＼と、「阿父さんが那如してゐたんぢや、幾ら稼いだツて到底遣切れやしないわ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
