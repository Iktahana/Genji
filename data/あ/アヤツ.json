        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日彼奴について考えている。",
              "source": "幻辞"
            },
            {
              "text": "彼奴という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は彼奴の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には彼奴が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "彼奴を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは彼奴について学習した。",
              "source": "幻辞"
            },
            {
              "text": "彼奴の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は彼奴の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では彼奴が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彼奴という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に彼奴という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では彼奴についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "彼奴を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彼奴は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "彼奴について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では彼奴が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彼奴は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により彼奴の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "彼奴は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に彼奴は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「彼奴は……」と先づ突つ附いてみた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てるやうに蠅打を手放すと、「彼奴は……」と再び両手で額を支へて考へ込んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでまた「彼奴」のことは頭を去つてしまつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……フン、そりや彼奴の云ふのにも本当はある――」「けれどもだ、……けれどもそれでは此方が困る……」　そこへ、「何方にも一理ある場合は親の方を子は聴入れなくつちやァ不可ない」といふ、常々云つてる言葉が飜然浮ぶと、彼は解決を得た喜びに敷居の辺りを意気ある眼で睨んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼奴の前には顔がよくなる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ももう、とほくはないのかもしれない……２『それではさよならといつて、めうに真鍮の光沢かなんぞのやうな笑を湛へて彼奴は、あのドアの所を立ち去つたのだつたあね。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴の目は、沼の水が澄んだ時かなんかのやうな色をしていたあね。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴又出て行きゃあがったな」　「え、たった今」　「毎晩、毎晩、困った奴だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「石松が今夜お前さんを家へ連れ込んだのは、彼奴がお前さんの身内になりたいからだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「日に二度も来ることがあるわ、あの人達、兄さんに何の用事かしら」　「なーに彼奴等、石松と兄弟分になりてえンだろう、きっとそうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟分になっときゃあ、彼奴等肩身が広えからな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前に逢い度がってるぜ」　「彼奴は逢いたがってるだろうが、俺ァ逢い度くねえ訳があるんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「てっきり彼奴」　と独り言、Ｔ「朝ッぱらから一稼ぎしてやがるかも知れ無えぞ」　其辺で鉄五郎クルッと踵を反して走り去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「此の村で、巳年の男と　言えば」　彼奴と彼奴と、と数える。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「毎夜おれが酔って、いびきかいてるうちになあ、彼奴そんな真似をしているんだよ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん夜は彼奴の向うずねを蹴ってやる。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときによってジャズ・バンドがビビの音楽をやっているとき、死海の水に映って正気を失った士官に貴女が抱かれて、独逸仕込の接吻の洪水のなかで、彼奴がロメオとジュリエットの名台詞を彼がネロのようにそりかえって早口で喋舌るときは全く貴女を薄倖の踊子だとさえ思ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたにお願いと云うのはね、妾の同業の厚化粧ぐみをね、彼奴たちはどうせろくなことはやらないのさ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう暴れて居るうちにも自分は、彼奴何時の間にチヨーク畫を習つたらう、何人が彼奴に教へたらうと其ればかり思ひ續けた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや／＼、彼奴が來て居る、どうして彼奴は自分の先へ先へと廻はるだらう、忌ま／＼しい奴だと大に癪に觸つたが、さりとて引返へすのは猶ほ慊だし、如何して呉れやうと、其儘突立つて志村の方を見て居た。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは面白ろい、彼奴を寫してやらうと、自分は其儘其處に腰を下して、志村其人の寫生に取りかゝつた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう暴れているうちにも自分は、彼奴何時の間にチョーク画を習ったろう、何人が彼奴に教えたろうとそればかり思い続けた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやおや、彼奴が来ている、どうして彼奴は自分の先へ先へと廻わるだろう、忌ま忌ましい奴だと大に癪に触ったが、さりとて引返えすのはなお慊だし、如何してくれようと、そのまま突立って志村の方を見ていた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは面白ろい、彼奴を写してやろうと、自分はそのまま其処に腰を下して、志村その人の写生に取りかかった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実｜彼奴はそう信じて言うわけじゃない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことはない、あやつり人形の所作でも見ているような心地がした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月の鉛の雲さびに〕月の鉛の雲さびに、　　　　　みたりあやつり行き過ぎし、魚や積みけんトラックを、　　青かりしやとうたがへば、松の梢のほのびかり、　　　　霰にはかにそゝぎくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　九官鳥の口まね　せんだって三越の展覧会でいろいろの人語をあやつる九官鳥の一例を観察する機会を得た。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやつり人形の糸の代わりに空気の渦を使っているのだから驚く価値があるのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分などは、往来でけたたましい自動車の警笛を聞いても存外それが右だか左だかということさえわからないことがあるのに、あの小さな蚊は即座に音源の所在を精確に探知し、そうして即座に方向舵をあやつってねらいたがわずまっしぐらにそのほうへ飛来するのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
