        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨模様について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨模様という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨模様の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨模様が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨模様を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨模様について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨模様の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨模様の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨模様が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨模様という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨模様という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨模様についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨模様を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨模様は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨模様について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨模様が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨模様は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨模様の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨模様は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨模様は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "湖上の景色見飽かざる間に彦根城いつしか後になり、胆吹山に綿雲這いて美濃路に入れば空は雨模様となる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的の例を挙ぐれば、東京市民にとりては「明日正午まで京浜地方西北の風晴」と云い、あるいは「本日午後驟雨模様あり」というがごときは多数の世人に有用有意義なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨模様の時化模様、土用としては変に涼しい。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗の怖れる二百｜十日の前一日、二三日来の驟雨模様の空がその朝になって、南風気の険悪な空に変り、烈風強雨こもごも至ってひとしきり荒れ狂うていたが、今思うとそれが何かの前兆でもあるかのように急にぱったり歇んで、気味悪いほどに澄んだ紺碧の空が見え、蒔きずての庭の朝顔の花に眼の痛むような陽の光が燃えた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風雨模様の高浪を追越し追越し、白泡を噛み、飛沫を蹴上げて天馬｜空を駛るが如く、五島列島の北の端、城ヶ島を目がけて一直線。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この、時々ばらばらと来る梅雨模様の雨にもめげねえ群集だでね。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れんとして空は又雨模様である。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨模様で蒸暑かったせいでしたろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨模様だけれど私は晴れつゝある。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ひとりなれば山の水のみにきた・山の仏には山の花　七月十四日曇、まだ梅雨模様である、もう土用が近いのに。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十六日曇、此頃は、日和癖とでもいふのか、午前中は雨模様、午後になると晴、頭痛がして困る。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・すゞしく自分の寝床で寝てゐる・稲妻する夜どほし温泉を掘つてゐる　八月七日まだ雨模様である、我儘な人間はぼつ／＼不平をこぼしはじめた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗夜送つて出て長い尿する　十月廿四日時雨模様、だん／＼晴れて秋日和となる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は雨模様だったので、患者たちは庭へ出されなかった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨模様」と云う字に変ってしまう。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の人生はまた雨模様となってしまった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度上野でデモが解散という刻限、朝から晴れていた空が驟雨模様になって来た。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いくらかになるもんだからね、ひとの分もやってやるらしいんだ」　二人はやや風が落ちたかわりに時雨模様になって来た夜の街へ出て、大きい銀杏の樹が路の真中にある急な坂道を、本郷台に向って行く人混みの中にとけ込んだ。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりごろに少し雨模様になって来る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして九月の下旬に山を下りて紀伊から大阪の方の旅に二、三日を費やして、侘しい秋雨模様の、ある日の夕ぐれに、懐かしい京都の街に入ってきた。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも私は、一昨日雨模様の欝陶しい晩方にこの街にかえって来て、ここの路次を覗いて見た時とちがい、もうここにはいないと思っていた母親に偶然また会ったので、さながら彼女に会ったと同じような喜びを感じたのであった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨模様に曇つた空へ、雄鶏が叫びをあげる。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼頃までは晴れてゐた空が午後から雨模様になつてゐた折柄、一丁目から歩道を歩いてゐるうちに、雨足繁く、夕立になつて来た、露店商人が急に店の取片付けも成らず、テント張りのまゝぬれてゐる午下りの景色は、これまで見かけないものである。",
              "citation": {
                "source": "銀座の柳",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "集まっていた人々は、あるものは津浪が来ると言い、あるものは雷だと言います（沖に出ていると、雷雨模様の時には、折々強い光を見ます。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの晩は雨模様で、六つ半（七時）というと恐ろしく暗かった。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも降り出しそうな村雨模様の空合いです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "忍術指南",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの雨模様の秋の時候を引合いに出されて出張をとめられる危険にさらされたくはない、というだけのためにだった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも四月時分の気候が見舞ったようで、雷雨模様の雲がパリーの上にたなびいていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい日で、太陽は雲にかくれていたが、而も雨模様ではなかった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は時雨模様なのに八重は雨コートも持っていかなかった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
