[
  {
    "uuid": "4633cac5-bcb6-5730-b6ed-d2d595c4616c",
    "entry": "甘える",
    "reading": {
      "primary": "あまえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
