      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to behave like a spoiled child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘えるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘えるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘えるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘えるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘えるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘えるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘えるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘えるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘えるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘えるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘えるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘えるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘えるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘えるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘えるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘えるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘えるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘えるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　尋常一年の男が甘えるやうにいつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘える者と甘えられる者との間には、常に積極的な通路が開けている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甘えてすねて」とか「甘えるすがた色ふかし」などいう言葉に表われている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「何だって斯んな物盗んだりなんぞするんだ」　と叱り付けられてお絹が甘える様に言った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳父の厳訓に服することは慈母の慈愛に甘えるのと同等にわれわれの生活の安寧を保証するために必要なことである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り家台の見物よりも、強飯の御馳走よりも、わたしに取ってはそれが何よりも嬉しいので、すぐにその尾について又いつもの話をしてくれと甘えるように強請むと、また手柄話ですかと老人はにやにや笑っていたが、とうとう私に口説き落されて、やがてこんなことを云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おみちが甘えるように云った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に私は、幼少の頃から礼儀にばかりこだわって、心はそんなに真面目でもないのだけれど、なんだかぎくしゃくして、無邪気にはしゃいで甘える事も出来ず、損ばかりしている。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（それはそばに置いてはいつまでも甘えるから仕方ない。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、娘があたりを兼ねた體で、少し甘えるやうに低聲で言つた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小熊が甘えるように言ったのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝……と云ふがお午ごろ、炬燵でうと／＼して居ると、いつも來て囀る、おてんばや、いたづらツ兒の雀たちは、何處へすツ飛んだか、ひつそりと靜まつて、チイ／＼と、甘えるやうに、寂しさうに、一羽目白鳥が鳴いた。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児が親に甘えるように……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は母に甘える小児のような態度で、飽までもお葉に附纏った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だいいち僕がそんなことをすると、思ってるのか」「だって……」　と、娘は甘えるように、「――男って皆そんなンでしょう……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の門の裏でお友達とテニスをしたのよ……」と甘えるような声で少女は答えた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブカさん……」と水兵服の少女は、もうすっかり晴れやかな様子になっていて、井深君の腕につかまり乍ら一層甘えるような声で云った。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハン……しかし要心せんといかん……」「それほどでもないんですけれど、永いこと丸髷に結わなかったせいかもしれません」　と母親は、お茶をさしながら甘えるような、悄気た声で云った。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えるような……投げ出すような口調で……。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、甘えるように微笑みながらていねいにお辞儀をして、しずかに帰っていった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも、それは申しましたが、「尊敬して居ればこそ、安心して甘えるのだ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はあの母を見たあとにこの規矩男を見、切ない自分の「母子情」を仲介にして自分に近づく運命を持ち、そして自分の心をこれほど捉え、これ程自分に馴れ甘える青年を、自分はもう何処までも引き寄せて愛撫し続けてやり度い心が、胸の底からぐっとこみ上げて来るのを感じた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、つい、ハムレットさまと、こんなになって喜びやら、くるしみやら、意外の思いやら、いろんな事がございましたが、あたしには、失礼ながら王妃さまを母上とお呼びして甘える事が出来るようになるのではないかしらという淡い期待が何にも増して、うれしかったのでございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼御台さまに甘えるやうに、ぴつたり寄り添つてお坐りになり、さうして将軍家のお顔を仰ぎ見てただにこにこ笑つて居られます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か特別なわけがあるに違ひないと考へると、ます／＼そればかりが聽きたいので、翌日も午砲が鳴るまで一緒に寢てゐた上に、女をあまえるままにまかせて、午後の時間を二人で寢ころんで無駄ばなしで送つて、とう／＼家へは歸らなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、痛い」とばかり、かの女はあまえるやうな關西口調でその夜も頻りに泣き訴へてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青木が呼びに来るだろうから、下へ行け」「あの人は今晩来ないことになったの――そんなに言わないで、さ、あなた」と、吉弥はあまえるようにもたれかかって、「今言ったことはうそ、みんなうそ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「持病とあれば左程案じることもなかろう、癒るまで逗留して、それから出発せらるるが宜い」「お詞にあまえるようで、心苦しゅうございますが、どうぞ乳母の病気が癒りまするまで、お助けに預かりとうございます」　壮い女は涙を流した。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふさは揶揄ふ樣なあまえる樣な態度で又妙な聲を出して嫣然した。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで何となくきまりが悪いので、あまえるやうに笑つた。",
              "citation": {
                "source": "香水の虹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
