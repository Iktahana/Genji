        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安眠について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安眠という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安眠の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安眠が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安眠を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安眠について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安眠の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安眠の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安眠が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安眠という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安眠という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安眠についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安眠を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安眠は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安眠について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安眠が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安眠は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安眠の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安眠は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安眠は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一昼夜に五、六回の噴出を、色々な器械を使って観測するのであるが、一回の噴出に約二時間もかかる上に噴出前の準備があり噴出後の始末もあるので、夜もおちおち安眠は出来なかった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の中にガスがたまるからとか、また「生命の呼吸の大部分を分有するから」とか、あるいはまた「食わない方が胃のためによく、安眠が出来るから」とか書いているかと思うと、またアリストテレスの書物を引用して、「豆は生殖器に似ているから、あるいはまた地獄の門のように、ひとりでつがい目が離れて開くから」ともある。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし豆畑へはいるのがいやでわざわざ殺されたというのが本当だとすると、それは胃に悪いとか安眠を害するとかいうだけではなくて、何かしら信仰ないし迷信的色彩のある禁戒であったであろう。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に仕事を途中で中止してのんきに安眠するという事は存外六ケしい事であるに相違ない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は適当な時にさっさと切り上げて床につく、そして仕事の事は全く忘れて安眠が出来ると彼自身人に話している。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勢で夜の町を一歩きし、疲れてぐつすり安眠する。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用がすんだら弛緩してもいいはずの緊張が強直の状態になってそれが夜までも持続して安眠を妨げるようなことがおりおりある。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この墓が七年前に死んだ「並木善兵衛之墓」である、「杉の杜の髯」の安眠所である。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私も輕く會釋して其傍に進み寄り、何となく物淋し氣に見えた春枝夫人に眼を轉じ『夫人、昨夜は御安眠になりましたか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤ／＼、少年にまで寢太郎と見られたかと、私は急ぎ清水に顏を淨め、兵曹の案内に從つて用意の一室へ來て見ると、食卓の一端には、櫻木大佐は二三の重立つた水兵を相手に、談話に耽つて居つたが、吾等の姿を見るより、笑を此方に向け『武村が、とう／＼御安眠を妨害しましたね。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は昨夜雨中を駈廻った上に、終夜殆ど安眠しなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加・おべんとうをひらく雀も何やら食べてゐる・昼寝覚の夕立の水音が鳴りだした　八月十八日昨夜は二人共安眠熟睡だつた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちはもう蒲団の上におろされて、安眠している。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは安眠妨害だよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山以来、毎晩碌々に安眠しない上に、列車のなかに立往生をしたままで、すし詰めになって揺すられて来る。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "血圧を下げて安眠しようとしているのだ。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なほど安眠した。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ハイヒールの靴音が、大またに自分を追うて来たかと思うと寝しずまった町並の家の安眠妨害になりはしないかと思われる大声で、「あら、新子姉さんじゃないの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正九年十一月、渋柿）　　　　　七　ポートセイドからイタリアへ四月二十九日　昨夜おそく床にはいったが蒸し暑くて安眠ができなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年十月十一日）　　　　　　　＊　夜中にからだじゅうの痛む病気に罹って一晩じゅう安眠ができない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夜は夜ふけるまでその話を分析したり総合したりして、最後に、その先輩と自分との境遇の相違という立場から、二人のめいめいの病気に対する処置をいずれも至当なものとして弁明しうるまで安眠しない事もあった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不断からぐっすりと安眠する男で、よくうちで、私はかつがれたって目をさまさないだろうなんて、冗談を云ってるくらいです。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまったく安眠することが出来ない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長も安眠したようには見えない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は普段から安眠する方で、夜中は何があっても起きないというのがうちでのお決まりの冗談でした。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『でも、あたし、姉さんと違って、安眠しちゃうから。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目をおはばかりになって御寝室へおはいりになってからも安眠を得たもうことはできなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わりに、見し夢を逢ふ夜ありやと歎く間に目さへあはでぞ頃も経にける安眠のできる夜がないのですから、夢が見られないわけです。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は近ごろ源氏の手紙の来なくなったのを、安心のできることに思おうとするのであったが、今も夢のようなあの夜の思い出をなつかしがって、毎夜安眠もできなくなっているころであった。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏と大臣との交情は睦まじく行っているのであるが、昔もその傾向があったように、負けたくない心が断然強くて、大臣はそのことが不快であるために朝まで安眠もできなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
