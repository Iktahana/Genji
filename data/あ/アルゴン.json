        "examples": {
          "standard": [
            {
              "text": "私は毎日アルゴンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルゴンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルゴンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルゴンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルゴンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルゴンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルゴンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルゴンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルゴンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルゴンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルゴンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルゴンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルゴンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルゴンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後にアルゴンの発見されたのはこの室であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果がアルゴンの発見となったのは周知の事実である。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空気中の新元素アルゴン」と題する論文が王立協会で発表されたのは一八九五年の正月であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゴンに次いで他の稀有ガスが発見された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばあまりに有名なルヴェリエの海王星における、レーリーのアルゴンにおけるごときものである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちＳは硫黄、Ｂは硼素、Ｆは弗素、Ｐは燐、Ｈは水素、Ｋは加里、Ａはアルゴン、Ｃは炭素、Ｎは窒素、Ｖはバナジウムだ。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では、液体空気をボイラーに入れて、微熱を加えてゆくと、別々のパイプから、酸素ガスやネオンやアルゴンなどの高価なガスがドンドン出てきて、圧力計の針を動かしながら鉄製容器の中へ入ってゆくのが見えた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレルモンといい、レジレットといい、この辺一帯はアルゴンヌの森林地帯の一部で、大戦の時は一時ドイツ軍に占領されていた土地である。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、戦争前はこの辺からかけてアルゴンヌまで巨木の大森林だったということではあるが。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムューズ高原・バリクール高原・ロマーニュ高原及びアルゴンヌの森。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは記念柱の裏の高地に登って、物凄く破壊された寺の跡を見てまわり、ついでにロマーニュの戦跡を訪ねて、アルゴンヌの森を抜けた。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　アルゴンヌの森の彼方に落ちて行く赤い夕日を見ながら、私はそんな取り留めもないことを考えていた。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴールド大使には、しばらく秘密にして置け」　暗涙をのんで、そういったのは、中で一番肩章の立派なアルゴン大将だった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "快速潜水艦隊　キンギン国では、ラヂウム元帥に代り、アルゴン大将が、戦争次官のままで、アカグマ国攻略軍を指揮することとなった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアルゴン大将は、どっちかといえば、幸運児でもあった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "キンギン国の大統領は、彼アルゴン大尉を招き、その成功を絶讃すると共に一躍大将に昇任させた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした例は、この国内にたいへん多く、そういういずれも若々しい能力者によって、この国の国防力や文化はこの二十年間に急速な発展を遂げ　アルゴン大将は、月世界からの帰還後、しばらく空軍研究所長についていたが、ごく最近、戦争次官に新補されたのであった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゴン大将は、即戦即決主義だった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような信念の下に、アルゴン大将は、凡そ太青洋を進攻できる軍団と兵器との全部を動員し、それを集結させ、そしてアカグマ国のイネ州に向けることにした。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アルゴン大将は、官邸のマイクを通じ、すべての根拠地に対して、号令した。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゴン大将の、特に信頼をおいていたのは、二百隻から成る快速潜水艦隊であった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全艦隊、異常なし」　そういう報告が入ると、アルゴン大尉は、ふうッと、鯨のような息をついて、にっこりと微笑するのだった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゴン大将が、期待をかけるのも、無理はなかった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦隊の全将兵の士気｜旺盛なり」　スイギン提督からの報告は、一報ごとに、戦争次官アルゴン大将の顔に、明るい色を増させるばかりだった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その暁の直前において、アルゴン大将は、たいへん気にかかる無電に接した。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度、四軒目のカフェ・アルゴンの前だった。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はドシンドシンと、カフェ・アルゴンの扉に身をぶっつけた。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺されたのは、このカフェ・アルゴンの主人である虫尾兵作だった。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では何物が、天井裏にのぼって、あの節穴からカフェ・アルゴンの大将虫尾兵作を狙い射ちにしたのか。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」帆村荘六は、おみねが驚駭にうちふるえている前に、このカフェ・アルゴンの入口で拾ったライターをさし示した。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
