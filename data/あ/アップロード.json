        "examples": {
          "standard": [
            {
              "text": "プレゼン資料をクラウドストレージにアップロードしておけば、外出先でも確認できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行で撮った思い出の写真をSNSにアップロードした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新作のミュージックビデオが公式チャンネルにアップロードされ、多くの反響を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経費精算のため、領収書のスキャン画像を社内システムにアップロードする必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいファームウェアをデバイスにアップロードする際は、安定した通信環境を確保してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "応募書類は、指定されたフォームからPDF形式でアップロードしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害発生時、現場の状況をリアルタイムでサーバーにアップロードするシステムが活用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "第二部 「夢の物語」からは八話中六話を訳出しアップロード済みです（うち三話を青空文庫で公開しております）。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
