        "examples": {
          "standard": [
            {
              "text": "私は毎日安全第一について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全第一という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全第一の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全第一が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全第一を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全第一について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全第一の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全第一の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全第一が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全第一という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全第一という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全第一についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全第一を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全第一は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全第一について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全第一が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全第一は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全第一の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全第一は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全第一は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そういうものは消極主義の審査官の安全第一という立場から云えば保留した方が無事である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲けた金は方々の銀行にチョクチョク入れて、頭かくして尻かくさず式の安全第一を計るようなケチな真似はしないよ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦機の駈引には安全第一は寧ろ避く可きであり、時少く路長き折は老馬は取るべからずである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして分相応の地歩を占めつつ、これが安全第一だと草葉にすだき、これが最高の自由だと雲に啼き渡り、これが最大の真理だと曠野に吼えまわります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が穏便じゃないんですから、僕も平和第一、安全第一の常識を棄てることにします。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計盗み８・２（夕）「安全第一」といふ事はよく亜米利加雑誌の広告に使はれてゐる文句だが、その発明は米国よりも日本の方がずつと早い。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに第二軍司令官ビューローは古参者であり皇帝の信任も篤い紳士的将軍であったが機略を欠き、活気ある第一軍との意見合致せず、いたずらに安全第一主義のために三軍を近く接近して作戦せんとし、遂に好機を失し敵を逸したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩が安全第一、何よりもよい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七合目附近から暗くなりだしので、安全第一と、この尾根を離れて左へちょっと巻き、宝永山の火口の真上の夏道のついている谷へ入った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六峰は雪ばかりの広い尾根で、ブラブラと登ることができたが、五峰からもう痩せていてところどころ岩も出ているので安全第一とアンザイレンしたため、岩登りの下手な僕が始終ブレーキになって、第三峰のチムニーの下へきたときには予想外にときを経ていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい事をすると、すぐに安全第一の穴へ潜り込もうとする。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ばぬが故に安全第一ではあるけれども。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全第一主義で暮らす現代人には、余計なことではあるけれども、立憲治下の国民としては、私の言ったことは、言いたいことではなくて、言わねばならないことであった。",
              "citation": {
                "source": "言いたい事と言わねばならない事と",
                "author": "桐生悠々",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、人が手を出しかねてゐるやうな冒険が好きで、安全第一は性に合はないんですつて。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村屋はよく売れるには相違ないが、至って地味な経営で安全第一主義であるから、利益率は売上げの増加に反比例してかえって減じているほどであった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の仕事はやめて安全第一にやっていらっしゃる由、そちらにもそのようなおたよりがありましたでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまず、最も自然な安全第一の方法である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、美ちゃんと菊ちゃんを呼んで上げて頂戴よ」「いや、お前のようなのが安全第一で宜い」「私、そんなにお婆さんに見えて？",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父の留守にドラ息子が持ち出そうとしても精一杯で一円余り、この点は安全第一、とはいうものの、当時天保三枚あれば、平民どもは奥山あたり一日ブラブラして昼飯を食って悠々と遊べたものだ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、彼は、秀吉と和すことこそ主家の安全第一と信じていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
