    "definitions": [
      {
        "index": 1,
        "gloss": "seasoning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日塩梅について考えている。",
              "source": "幻辞"
            },
            {
              "text": "塩梅という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は塩梅の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には塩梅が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "塩梅を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは塩梅について学習した。",
              "source": "幻辞"
            },
            {
              "text": "塩梅の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は塩梅の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では塩梅が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "塩梅という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に塩梅という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では塩梅についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "塩梅を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると塩梅は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "塩梅について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では塩梅が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に塩梅は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により塩梅の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "塩梅は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に塩梅は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "然し根が風癲（フーチヤン）だから、何かほかのことが頭を占めてる時は、金なんて忘れてるといつた塩梅だな」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、困った事には父上の外は揃いも揃うた船嫌いで海を見るともう頭痛がすると云う塩梅で。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句これからは落着いて手許に居るだろう、よい塩梅だ位に思っているらしい風が見える、何もかも慈愛の泉から湧いた情と思えば不平も云えない。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋な自由研究と政府の要求に応ずるような功利的研究との融和｜塩梅も最も痛切な困難であったらしい。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくどい蒼蠅さがわりに少なくて軽快な俳諧といったようなものが塩梅されているようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、まあ、いい塩梅にその後再びそんな真似をする奴も出ませんでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ路傍の草いきれが恐しい、大鳥の卵見たようなものなんぞ足許にごろごろしている茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十四「（いい塩梅に今日は水がふえておりますから、中へ入りませんでもこの上でようございます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に崖を、上の方へ、いい塩梅に蜿った様子が、とんだものに持って来いなり、およそこのくらいな胴中の長虫がと思うと、頭と尾を草に隠して、月あかりに歴然とそれ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかしお好み別誂で以て、鳥のブツ切と、玉葱と、凍豆腐を大皿に積んだのを鉄鍋でね、湯を沸立たせて、砂糖と醤油をかき交ぜて、私が一寸お塩梅をして」「おや、気味の悪い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ回しながらまずこの団塊の重心がちょうど回転軸の上に来るように塩梅するらしい。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その祈請の筋を聞いてみると物を誂えるような塩梅で、時間なども気短かに区切って注文してあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、お道どん、こういう訳なんだ、実は、」「はあ、そりゃもう、路で聞きましたよ、飛んだことだったね、でもまあ可い塩梅に。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに降りやんだものですから、可塩梅だ、と然う云つてね、また、お前さん、すた／＼駆出して行きなすつたよ。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小一の顔色が青瓢箪を俯向けにして、底を一つ叩いたような塩梅と、わしども家内なども申しますので、はい、背が低くって小児同然、それで、時々相修業に肩につかまらせた事もござりますが、手足は大人なみに出来ております。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ここがその、少々変な塩梅なのでござりまして、先が盲だとも、盲だからとも、乃至、目あきでないとも、そんな事は一向心着かず……それには、ひけ頃で帳場もちょっとごたついていたでもござりましょうか。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう可い塩梅にうつくしい羽の生えた姉さんがいつでもいるんじゃあありません。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、ただ通懸った者でがんすがその方が強くお塩梅の悪い様子、お案じ申して、へい、故意。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理の塩梅が悪いから、華族様のお口には合ぬとおっしゃるのでございましょ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、夜分になりましてから可塩梅に風もちと凪ぎましてござりますが、朝ッからの吹通しで、そこいらへ針がこぼれましたように、ちくちくいたしますでござります、へい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中腰で四辺を※し、「旦那様はお風呂でござりますか、お塩梅はいかがでいらっしゃいます。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "森々と樹の茂った、お城の森の奥深く、貴女様、高く上りますのでござりますが、またこの石段がこわれごわれで、角の欠けた工合、苔の蒸しました塩梅、まるで、松の鱗が、蛇の幹を攀じますようで、上に御堂、これも大破。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、何事もなくッて可い塩梅だったのね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐いきをしつつ、立寄って、（お塩梅はいかがです。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、お塩梅が沢山悪いんじゃありませんか、何しろお上りなすって、お休みなさいましたら何うでしょう。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目からも、ぶよぶよした唇からも、汚い液が垂れそうな塩梅。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可い塩梅に誰も居ないから。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可い塩梅な酔心地で、四方山の話をしながら、螽一ツ飛んじゃ来ない。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この包丁｜塩梅甚だ心許ない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好塩梅にお天気が続きますね。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
