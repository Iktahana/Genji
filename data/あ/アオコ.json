          ],
          "literary": [
            {
              "text": "青苔が、青粉を敷いたように広い墓地内の地面を落ち付かせていた。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年は無拠、蓬の代りに青粉と申すを買ひまして、舂きまする。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが現在ではだんごに青粉を入れている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "※陰鬱な空気　と□す、あおこけむす、きみ悪き墓場！",
              "citation": {
                "source": "かの日の歌【五】",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあおこぞうさん、大さわぎをやらないのはわけがわかっているのだな。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　加多さん……俺あおことわりしてえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
