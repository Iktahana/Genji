    "definitions": [
      {
        "index": 1,
        "gloss": "powderized green laver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で、「青粉」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "季節の変化とともにこの傾向が顕著になる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からこの風習が形成された。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でこれは欠かせない材料とされている。",
              "source": "幻辞"
            },
            {
              "text": "観光地を訪れる際にこのポイントを押さえておくべきだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で、「青粉」をよく耳にする。",
              "source": "幻辞"
