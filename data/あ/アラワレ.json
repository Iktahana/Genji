        "examples": {
          "standard": [
            {
              "text": "私は毎日現れについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "現れという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は現れの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には現れが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "現れを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは現れについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "現れの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は現れの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では現れが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "現れという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に現れという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では現れについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "現れを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると現れは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "現れについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では現れが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に現れは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により現れの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "現れは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に現れは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の遠い祖先のスペインの血は、その顔にも現れて、はげしい苦闘的なものを印してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは我々の前には近々七十年以前に、急劇にも西洋文学といふ、目新らしい様式の文学がドヤドヤ現れて来たといふことであり、それの消化は未だ甚だ不十分であるといふことである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ドヤドヤと現れた西洋文学は、そのフォルムを迄了得する余裕を我々に与へなかつたのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の御用聞きが現れて、何なりと御手伝ひしませうと云ふと、有難いが「あれを何処これを何処と、片附けるのは却々自分でないと分らないから」と、それをニコ／＼しながら、長々とやるのでその御用聞きはしまひには僕の顔を見て笑つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから猶二三の御用聞きが現れたが、そのたんびにその調子であつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから半年の後、フト僕の下宿に現れて「私はこれから一人また広島に帰る」と云つてニコニコしてゐたが、その後母よりの手紙によるとどうも木村といふ人と折合がわるいのらしいといふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長三代太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）捧げ銃をして。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）工合い-------------------------------------------------------　四月十一日。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私信太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）就いて、-------------------------------------------------------　叔母さん。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度芸術にあつて、表現方法をばかり問題にされることの生活的方面での現れである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この情態が面白からぬことを気付く頃に現れる次の現象は、凡そ私に分る所を以てすれば、心理的に病弊を究明しはじめることであらう。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和五六年の頃より、つまり小林秀雄が文壇に現れて間もなくの頃より、文芸評論は頓に盛んになつて、現今猶益々盛んである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々犬が現れて尾でも振らうものなら、ホツとするのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父に連れられて行つたのだが、父が切符を求めてゐる時、ヒヨイと僕の前に例の弁士の息子が立現れて、神明館と軽業とどつちがよいと思ふかと云ふのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、真底想はなかつたから、判然皺が現れなかつたのだ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちジヤツク・ウオーキイ等によつて映画で紹介されてゐるやうな、歌詞を本位として簡単な音楽を伴奏的につけ、専ら歌詞の滑稽味やエロチシズムやで、大衆を興がらすやうに出来てる「音楽入西洋万才」が、近い未来に於て日本に現れることを予感させる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛尽す鳥ひとつづつ秋の暮　芭蕉の名句「何にこの師走の町へ行く鴉」には遠く及ばず、同じ蕪村の句「麦秋や何に驚く屋根の鶏」にも劣っているが、やはりこれにも蕪村の蕪村らしいポエジイが現れており、捨てがたい俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒夜の凍ったような感じと、主観の侘しい心境がよく現れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鳥や舟に菜を洗ふ女あり　と共に、蕪村の好んで描く水彩画風の景趣であって、薄氷のはる冬の朝の侘しさがよく現れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同じ心は白梅や誰が昔より垣の外　という句にも現れ小鳥来る音うれしさよ板庇愁ひつつ丘に登れば花｜茨　などのロセッチ風な英国抒情詩にも現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも書いた通り、この時代は白樺派の活躍した全盛時代だつたので、自然その影響を受けたらしく、山村君や室生君等やの詩にも、多少人道主義的傾向が現れ、トルストイズムの臭氣が濃厚だつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ、どんな哲學者が彼等の間に現れようと、彼等は現在も飛んでゐるし、また未來も飛んで行くことでせう。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道場の入口から、時々水を飲みに、剣道用の繻絆姿で現れるのは生徒だが、それは選手だから暑中休暇も帰省しないで道場にゐるといふわけである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊の歌中原中也-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）吁！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の風景葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：入力者注　主に外字の説明や、傍点の位置の指定（例）増産競技であった。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セメント樽の中の手紙葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）蔽われていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンとナンバンとが、サロンデッキに現れるや否や、彼は遠方から呶鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
