          ],
          "literary": [
            {
              "text": "やはり人性の善と愛の勝利というようなことが考えられます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし恒川は恋愛の勝利者として得意の色を包み切れないものがあつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の勝利、狂気　二人は愛に勝った。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十七歳の罪のない老女の唖然たる目つきであり、愛の勝利をながめてる空しい生命だった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
