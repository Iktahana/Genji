    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hail (esp. hailballs under 5 mm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日霰について考えている。",
              "source": "幻辞"
            },
            {
              "text": "霰という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は霰の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には霰が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "霰を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは霰について学習した。",
              "source": "幻辞"
            },
            {
              "text": "霰の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は霰の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では霰が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "霰という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に霰という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では霰についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "霰を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると霰は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "霰について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では霰が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に霰は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により霰の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "霰は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に霰は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "玉｜霰漂母が鍋を乱れうつ　漂母は洗濯｜婆のことで、韓信が漂浪時代に食を乞うたという、支那の故事から引用している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ霰が降って来たので、隣家の鍋にガラガラ鳴って当るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから射して來るのか樹蔭のやうな緑色の光線を受けて、模糊と霞んでゐるその萬疊敷とでも言ふべき廣場には、やはり霰のやうな小粒の珠が敷きつめられ、ところどころに黒い岩が秩序無くころがつてゐて、さうしてそれつきりである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも雨と雪は最も普通なものであるが、雹や霰もさほど珍しくはない。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰の降るような日にでも山で働いていると汗が出た。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月の鉛の雲さびに〕月の鉛の雲さびに、　　　　　みたりあやつり行き過ぎし、魚や積みけんトラックを、　　青かりしやとうたがへば、松の梢のほのびかり、　　　　霰にはかにそゝぎくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初冬の時雨はもう霰となって軒をはしった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰はあとからあとへ黒い屋根瓦を打ってはころころ転がった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに八重の淡紅に咲けるが、晴れたる日、砂立つるほどの風の急に吹き出でたるに、雨霰と夕陽さす中を散りたるなど、あはれ深し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが何せ、器械はひどく廻っていて、籾は夕立か霰のように、パチパチ象にあたるのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふまでもなく馬を打つ策は僕の頭上に霰の如く落ちて來た。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は父の脇の火鉢の傍に座って、暫く黙って居ましたが、此時降りかけて居た空が愈々時雨て来たと見え、廂を打つ霰の音がパラ／＼聞えました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思う間もなく園の周囲には霰が篠つくように降りそそいだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い綿雲に閉ざされた闇の中を、霰の群れが途切れては押し寄せ、途切れては押し寄せて、手稲山から白石の方へと秋さびた大原野を駈け通った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰……北国に住み慣れた人は誰でも、この小賢かしい冬の先駆の蹄の音の淋しさを知っていよう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰はいつか降りやんでいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し晴れてゐた空が急に曇ると霰が夕立ちのやうにさあつと激しく音を立てゝ寄せて來る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して見る／＼擴がつた雪雲は、見る／＼霰と共に遠く山の彼方に飛び去つて行く。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂で家鴨の血の汁を掻き立てる匙の音が霰のようだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雪やこんこ、霰やこんこ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰の降つた夜更の事――二　山國の山を、町へ掛けて、戸外の夜の色は、部室の裡からよく知れる。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は暗からう……水はもの凄く白からう……空の所々に颯と藥研のやうなひゞが入つて、霰は其の中から、銀河の珠を碎くが如く迸る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、霰の降る晩には何にも別にないだらうか。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、人の行かない山寺だの、峰の堂だのの、額の繪がね、霰がぱら／＼と降る時、ぱちくり瞬きをするんだつて……」「嘘を吐く……」　と其でも常さんは瞬きした。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からりと廂を鳴らしたのは、樋竹を辷る、落たまりの霰らしい。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「其處へ玉のやうな霰が飛ぶんだ……」「そして、八田潟の鮒と戰をしたら、何方が勝つ？",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あ、又降るよ……」　凄まじい霰の音、八方から亂打つや、大屋根の石もから／＼と轉げさうで、雲の渦く影が入つて、洋燈の笠が暗く成つた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だつて、緋だの、紫だの、暗い中に、霰に交つて――それだと電がして居るやうだもの……其の蔀をこんな時に開けると、そりや可恐いぜ。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨はざあざあ　ざっざざざざざあ　風はどうどう　どっどどどどどう　あられぱらぱらぱらぱらったたあ　雨はざあざあ　ざっざざざざざあ」「あっだめだ、霧が落ちてきた。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいあのまっしろなプクプクした、玉髄のやうな、玉あられのやうな、又｜蛋白石を刻んでこさへた葡萄の置物のやうな雲の峯は、誰の目にも立派に見えますが、蛙どもには殊にそれが見事なのです。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
