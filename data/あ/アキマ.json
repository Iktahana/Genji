        "examples": {
          "standard": [
            {
              "text": "空き間は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き間対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き間に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き間がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き間は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、空き間の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは空き間を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により空き間の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における空き間の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "空き間について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日空き間について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から空き間を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により空き間の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは空き間を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で空き間に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "空き間は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き間対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き間に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き間がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き間は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寝殿の東側になった座敷には桐壺の方がいたのであるが、若宮をお伴いして東宮へ参ったあとで、そこは空き間になっていて静かだった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこういう古い空き間に付きものの、土臭いような、腐ったような臭いにむせながら、しばらく立ち停まっているうちに、わたしの眼はだんだんに暗いところに馴れてきて、乱雑になっている大きい部屋のなかに寝台の据えてあるのがはっきりと見えるようになりました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "節穴、板と板の隙間、雨戸の建てつけにある食ひちがひの大きな空き間に、殘りの明りが部屋の中を刺し違へて、あん子はそれらの殘光の數を算へて見たが、亂雜な光芒はその數の上ではたうてい算へ切れなかつた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手のドア、ソーニャの部屋をゲルトルーダ・カールロヴナ・レスリッヒの住まいとへだてているドアの向こう側には、同じくレスリッヒ夫人の住まいに属する中間の部屋があって、もう長いこと空き間になっていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その空き間のドアの傍には、スヴィドリガイロフ氏がその間ずっとたたずんで、息をこらしながら、立聞きをしていたのである。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスコーリニコフが出て行ったとき、彼はしばらく立って考えたのち、爪先立ちで空き間に隣った自分の部屋へもどり、一脚の椅子を取って、ソーニャの部屋へ通ずるドアの傍へそっと運んだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳兵衛が刀を収めて、Ｔ「先ず二両」　山左が驚いて、Ｔ「捨て売りにしても五十両は」　徳兵衛、Ｔ「この不景気に御冗談を」　と言われて山左が、Ｔ「では三十両」　徳兵衛、あきまへん。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから五日ばかりののちに、この一件もみんな埒があきましたよ」「はあ、どういうふうに解決がつきました」と、わたしは熱心に訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガドルフは眼をあきました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学論も、もう、あきました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れも致しません、あれは秋のなかば、月の非常にいい夜でございましたが、私は十二時すぎに店をしまいまして、それから大いそぎで築地の或る心易くしている料理屋へ風呂をもらいに行きまして、かえりには、屋台でおそばを食べ、家へ来て勝手口をあけようとしても、もう内｜桟をおろしてしまったようで、あきませんでした。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十の手拭はかあいそうに泥がついてところどころ穴さえあきました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまお届けしようと思ってゐましたが手があきませんでね。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていきなりどんと扉へからだをぶっつけましたが扉はあきませんでした。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いきなり奥の扉が、がたっとあきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムはふっと目をあきました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十の手拭はかあいさうに泥がついてところどころ穴さへあきました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぢやてて、貴方はん、梯子がおへんよつて、どないにもあきまへん。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あて、あきまへんのどっせ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、今日は必ず午後八時になぞの女を訪問してやろう」　信吉がそう呟いていると、「新聞があきましたら、どうぞ……」　声を掛けられた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠したかてあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の言うことを信用したらあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまにあんた、警戒せなあきまへんぜ」　警戒とは大袈裟な言い方だと、私はいささかあきれた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の戸があきました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、かぎたばこの箱のふたが、ポンとあきました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方になるとその戸は半びらきにあきました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとたんに、ドアがあきました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、さびついた掛金をおすと、それがうまくはずれて、戸があきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういちど、私の気持を、ゆっくり聞いていただきたいと思って、お宅の前をずいぶん永い間うろついて、とうとう決心して、屋根へあがって、この二階のお部屋の雨戸に手をかけましたら、するするとあきましたので、それで、……。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどさっき、ろうかのつきあたりの、小さなへやがあきましたから、あそこへうつりなさい。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
