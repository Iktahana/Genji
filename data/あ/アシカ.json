    "definitions": [
      {
        "index": 1,
        "gloss": "eared seal (esp. the California sea lion, Zalophus californianus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "室子は頬を撫でても、胸の皮膚を撫でても、小麦いろの肌の上へ、うすい脂が、グリスリンのように滲み出ているのを、掌で知り、たった一夜の中にも、こんなに肉体の新陳代謝の激しい自分を、まるで海驢のようだと思った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（事実海驢はそういう生理の動物かどうか知らなかったけれど）室子は、シュミーズを脱いで、それで身体を拭い捨て、頭を振って、髪の纏れを振り放ち乍ら、今朝の空腹の原因を突き止めた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海驢のように黒くて大きな流木も浮んで見えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豹島、幾万の膃肭獣と、海豹と、海驢。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人か、海驢か、海豚かと、月の光りで海のうえを透かしてみると、どうもそれは人の形であるらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "）手前も海驢の生れ變りぢやああるめえ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学習院に洋画の教師を勤めてゐる岡野栄氏が、ある日の事青山三丁目から電車に乗り込んで吊り皮に垂下つてゐると、直前に腰を掛けてゐる海驢のやうな顔をした海軍大尉が、急に挙手注目して席を譲つて呉れた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには、海豹、海驢、緑海豹など十匹ほどのものが、鰭で打ちあいウオーウオーと咆えながら、狭いなかを捏ねかえすような壮観だ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、膃肭獣でもない、海驢でもない。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその後になって、それが海驢というものであり、全然害をしないものであることを知った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "海驢の皮を重ねて居る王宮の様などに、憧れ心地が仄めいて居る。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海驢の皮畳を重ね敷いた宮殿に居て、歓楽の限りを味ひながら、大き吐息一つしたと言ふのは、万葉歌人に言はせれば、浦島同様「鈍や。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに海の神みづから出で見て、「この人は、天つ日高の御子、虚空つ日高なり」といひて、すなはち内に率て入れまつりて、海驢の皮の疊八重一一を敷き、また※疊八重一二をその上に敷きて、その上に坐せまつりて、百取の机代の物を具へて、御饗して、その女｜豐玉毘賣に婚はせまつりき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで海神が自分で出て見て、「これは貴い御子樣だ」と言つて、内にお連れ申し上げて、海驢の皮八枚を敷き、その上に絹の敷物を八枚敷いて、御案内申し上げ、澤山の獻上物を具えて御馳走して、やがてその女トヨタマ姫を差し上げました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の戸には錠をおろして行ったので、誰も内を覗いて見る人もなかったが、それからあしかけ四日目に阿母が一人で帰って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきましては、お俊儀は今日ただ今より私が世話することになりましたにつきましては早速お宅を立ち退くことにいたします、さようあしからず御承知を願い置きます』と切り口上でベラベラとしゃべり立てました、私は文句が出ないのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雨が深くしみ込んで、よかれあしかれその後の生活に影響したような気がする。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、たとえわたし達二人が明日から饑え死に仕様とも、ああしかしこればかりは、わたしの力にも及ばないことだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあしかし、ここまでは来ないから大丈夫だ。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しり込みするのを右瞻左瞻、「むむ、まあしかしお前方、素直にそうやって、折れてくれて、お互に幸だ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ何から何まで私の手一つでやらなければなりませんので、しかも私は気分屋なので、とかくおくれがちになりますが、あしからず思って下さい。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行員は、あしかけ三年いて呉れた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれひとりの慾望から好き勝手な法を行った場合には、よかれあしかれ身体にくっついてしまって、どうしようもなくなるものだ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生においてすら　私の失つたのは快適だけだああしかし　あまりにひさしく快適を失つてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生においてすら人生においてすら　私の失つたのは快適だけだああしかし　あまりにひさしく失つてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああしかし……にもかかはらず、尚且つ人間の妄執は、その蕭條たる墓石の下で、永遠に生きて居たいと思ふのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と夜具を奪りにかかる女房は、身幹の少し高過ぎると、眼の廻りの薄黒く顔の色一体に冴えぬとは難なれど、面長にて眼鼻立あしからず、粧り立てなば粋に見ゆべき三十前のまんざらでなき女なり。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　以前、あしかけ四年ばかり、相州逗子に住った時（三太郎）と名づけて目白鳥がいた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海で泳いでいる獣には、おっとせい、あざらし、おおあしか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおあしか、などは熊よりも牛よりも大きい海の獣です。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
