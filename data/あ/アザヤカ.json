[
  {
    "uuid": "ecf34174-1681-5905-afea-28c7088c8a82",
    "entry": "鮮やか",
    "reading": {
      "primary": "あざやか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
