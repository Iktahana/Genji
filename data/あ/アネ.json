        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は毎日暑く、今産院にゐる娘は「ブーラ、ブーラ、ブーラブラ」といふ象といふ題の児童唱歌をオルガンで歌ひ、姉娘は夜になるとパウリスタに連れてつてアイスクリームを食べさせてくれた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、読んでごらんなさい。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、あたし知っているのよ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」妹は、澄んだ声でそう呟き、「ありがとう、姉さん、これ、姉さんが書いたのね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、心配なさらなくても、いいのよ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、あの緑のリボンで結んであった手紙を見たのでしょう？",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん、ばかにしないでね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん、あたしは今までいちども、恋人どころか、よその男のかたと話してみたこともなかった。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんだって、そうなのね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん、あたしたち間違っていた。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正子の姉でございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、またひとり、三十ちょっと前くらいの美しい人があらわれ、これもやはり、姉でございます、という御挨拶をなさるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉さんたちは、いろいろと御馳走を運んで来る。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の姉さんには、五つくらいの男の子がまつわり附いている。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の姉さんには、三つくらいの女の子が、よちよち附いて歩いている。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、」上の姉さんは静かに笑って、私にビイルをすすめ、「父にはなんにも出来やしません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、」上の姉さんは、顔をあからめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、でも、」上の姉さんは伏目になって、「決してお気になさらないで下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」下の姉さんが、上の姉さんの背後から美しい笑顔をのぞかせて言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」上の姉さんと一緒に、笑った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒は、その朝、世田谷の姉のところへ行って配給の酒をゆずってもらって来たのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、」と二番目の姉さんを小声で呼んで、「お前のところに、モオニングがあったろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お父さん、」と上の姉さんも笑いながら、「そりゃ当り前よ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう呟いて一瞬、上の姉さんは堪えがたいくらい厳粛な顔をした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の姉さんが君に、家宝のモオニングを貸して下さるそうだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下の姉さんは、貸さなかったが、わかるかい？",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の姉さんも、偉いね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあね……」と彼女は三和土の上で靴を脱いでる夫の肩に手を置いて声だけを難儀らしくして云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあね………」と妻君は俯向いて揃へた指を伸ばして、女優的しなを作つたりしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
