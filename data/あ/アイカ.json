    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lament (song)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀歌は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀歌が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀歌に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀歌が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀歌について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀歌についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀歌について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀歌が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀歌が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀歌は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀歌は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀歌を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀歌をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀歌が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀歌の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀歌を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀歌に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀歌について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀歌は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀歌を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まことに蕪村の俳句においては、すべてが魂の家郷を恋い、火の燃える炉辺を恋い、古き昔の子守歌と、母の懐袍を忍び泣くところの哀歌であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の歴史の恐怖時代といふべき、平家の末路から、鎌倉の執権政治にかけて、悲壮なる運命劇は、何故か東海道の河畔で演ぜられたのが多い、承久の乱に鎌倉に囚はれて、東下りの路すがら、菊川の西岸に宿つて、末路の哀歌を障子に書きつけた中御門中納言宗行卿もさうである。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村……全詩集中の詩大半薄田泣菫……暮笛集・ゆく春蒲原有明……春鳥集・獨絃哀歌三木露風……廢園・白き手の獵人北原白秋……邪宗門・思ひ出（二重圈點◎を附したのは、特に名詩集たるもの。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明詩集中、独絃哀歌あたりの作品は実に名篇であつて、今よんでも涙が出るほど好い。",
              "citation": {
                "source": "蒲原有明に帰れ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿と面罵するより他に仕様のなかった男、エリオットの、文学論集をわざと骨折って読み、伊東静雄の詩集、「わがひとに与ふる哀歌。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑、碑銘、花束、祈祷、哀歌など、死の形式的な半面だけが、美しく哀しい舞臺の上のことのやうに、浮かび上つてくるのである。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、いつか、君と観に行った宮部京子主演の『東京哀歌』で、ステッキガールになった少女がいたろう」「あっ！",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　大正文学へ　藤村の『若菜集』から、泣菫の『暮笛集』有明の『独紘哀歌』――明治三十四五年から六七年にかけては詩と歌とが文壇に大きな勢力を占めて来た。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私は酒に酔ふと稍ともすれば声を挙げて、大昔の酒神頌歌者や哀歌詩人に依つて詠まれた愉快な歌を口にして、余も亦彼等の如く一切の生命を酒と竪琴楽に托して、夢も現もなべて明るく歌ひ暮したいものであるが――などゝいふ嘆息を洩らすのであります。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　斯のやうに私は、その生活を歌のために踏みにぢられ、悲惨な目に遇ひながらも飽かずに往古の哀歌詩人の上を想ひ、羨んでゐたところが、近く私は、村長の頼みに依つて、登場歌――合唱歌――哀悼歌――の三部より成る酒神頌歌を創ることになつたのであります。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も此のまま置くとは何とやら其の人の冥福にも障る様な気がしたから余は手巾を取り出し、骸骨の顔を蔽し、回向の心で口の中に一篇の哀歌を唱えた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る種の眼には実にわがもの顔に文学の領域を踏みあらしていたと思われる左翼の文学が、今やそのような形で自身への哀歌を奏している姿は、一種云うに云えない交錯した感覚であったろう。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイノの哀歌の始めと稱せられ、餘りそれが流行したので、のちには、ヤイシヤマネといふことが直ちに流行唄の意味に使はれるやうになつたことまで附言する。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が遠い国に多くの人がいて口々に哀歌をうたうともきければ、森かげの梟の十羽二十羽が夜霧のほのかな中から心細そうになきあわすとも聞える。",
              "citation": {
                "source": "日光小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一言断っておくが、貴方は舌を動かす前に、まず『マリエンバートの哀歌』でも読まれることだな。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの歌は、敗戦国民の感傷的な哀歌に堕落する恐れが、果してないであろうか。",
              "citation": {
                "source": "文学に於ける構想力",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふこちらの氣のせゐか、大和の山々は、どんなに小さい山々にも、その奧深いところに何か哀歌的なものを潛めてゐる。",
              "citation": {
                "source": "黒髮山",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊21　祖国へ寄せる哀歌。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀歌また鶴が自ら長い線を空につくり、彼等の哀歌をうたひつゝ行くごとくダンテ『神曲』地獄篇第五曲脣、抱擁、ああ八月の花に時ならぬ氷雨の雲の來襲！",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「おたぎの里のあれやはてなむ」の哀歌に耳を傾けざりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル王サウル、ペリシテ人と戰ひて利あらず、ギルボア山上に（パレスチナにあり）自刃して死す（サムエル前、三一・一以下）【雨露】サウルの死を悼めるダヴィデの哀歌に曰く。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三編（家の中、アントアネット、女友だち）は、前編の狂暴な熱中と憎悪に対照する、穏かなしみじみとした雰囲気の中にあって、友情と純愛とへの哀歌である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばせを自序　この集には前集『獨絃哀歌』に續ぎて、三十六年の夏より今年に至るまでの諸作を載せたり。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治卅六年四月著者しるす獨絃哀歌　（十五首）附載三首一あだならまし道なき低き林のながきかげに君さまよひの歌こそなほ響かめ、――歌ふは胸の火高く燃ゆるがため、迷ふは世の途倦みて行くによるか。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に相模の海岸で溺死した矢田部理學博士は尚今居士の號でグレイの『哀歌』を譯した。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀歌同じ昨日の深翠り廣瀬の流替らねどもとの水にはあらずかし汀の櫻花散りてにほひゆかしの藤ごろも寫せし水は今いづこ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ばは哀歌、半ばは皮肉、半ばは過去の餘音、半ばは將來の脅威、そして時には深酷痛烈な批判をもつて、ブルジョアジーの腸を刺すことがあつても、近世史の進路を理解する能力が全く缺けてゐたので、その效果は常にただ滑稽であつた。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "今笄町の方に過ぎし車の音かすかになりて消えたるあとは、寂けさひとしお増さり、ただはるかに響く都城のどよみの、この寂寞に和して、かの現とこの夢と相共に人生の哀歌を奏するのみ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が浪人の処へ茶を持って来ると、酔っ払った遊び人は横あいからお絹の腕を掴みに行って再び振り放された。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やってみると、あいかわらずちっとも聞こえない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
