[
  {
    "uuid": "13a25aee-688c-51eb-bf69-c037a4b036d0",
    "entry": "哀歌",
    "reading": {
      "primary": "あいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
