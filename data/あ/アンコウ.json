    },
    "definitions": [
      {
        "index": 1,
        "gloss": "goosefish (any fish of family Lophiidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日鮟鱇について考えている。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は鮟鱇の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には鮟鱇が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは鮟鱇について学習した。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は鮟鱇の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では鮟鱇が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に鮟鱇という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では鮟鱇についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると鮟鱇は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では鮟鱇が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に鮟鱇は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により鮟鱇の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "鮟鱇は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に鮟鱇は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その大な腹ずらえ、――夜がえりのものが見た目では、大い鮟鱇ほどな燐火が、ふわりふわりと鉄橋の上を渡ったいうだね、胸の火が、はい、腹へ入って燃えたんべいな。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鰤ではたしかにない、あの腹のふくれた様子といったら、まるで、鮟鱇に肖ているので、私は蔭じゃあ鮟鱇博士とそういいますワ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落こちると勢よく三ツばかりくるくると舞った間に、鮟鱇博士は五ツばかりおまわりをして、手をのばすと、ひょいと横なぐれに風を受けて、斜めに飛んで、遥か川下の方へ憎らしく落着いた風でゆったりしてふわりと落ちると、たちまち矢のごとくに流れ出した。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇にしては少し顔がそぐわないから何にしよう、何に肖ているだろう、この赤い鼻の高いのに、さきの方が少し垂れさがって、上唇におっかぶさってる工合といったらない、魚より獣よりむしろ鳥の嘴によく肖ている。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇は腹をぶくぶくさして、肩をゆすったが、衣兜から名刺を出して、笊のなかへまっすぐに恭しく置いて、「こういうものじゃ、これじゃ、俺じゃ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水仙薫る浮世小路に、やけ酒の寸法は、鮟鱇の肝を解き、懷手の方寸は、輪柳の絲を結ぶ。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて見ろ、脂の乗った鮟鱇のひも、という珍味を、つるりだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇坊主と、……唯今でも、気味の悪い、幽霊の浜風にうわさをしますが、何の化ものとも分りません。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、蟹だか蛸だか鮟鱇だか正体の判らぬ魚を眼前へ突き付けて、「さあ、之を旨く食わして呉れ」と云われては、大抵の料理番も聊か逡巡ぐであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逸子、済まないが、仲通りの伊豆庄を起して、鮟鱇の肝か、もし皮剥の肝が取ってあるようだったら、その肝を貰って来て呉れ、先生が欲しいといえばきっと、呉れるから――」　珍しく丁寧に頼んだ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい鮟鱇が、腹の中へ、白張提灯鵜呑みにしたようにもあった。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女四　（同じく公子の背後に）鮟鱇五十袋、虎河豚一頭、大の鮹｜一番。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ほかに鮟鱇がある、それだと、ただその腹の膨れたのを観るに過ぎぬ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鰤ではたしかにない、あの腹のふくれた様子といつたら、宛然、鮟鱇に肖て居るので、私は蔭じやあ鮟鱇博士とさういひますワ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落こちると勢よく三ツばかりくる／＼とまつた間に、鮟鱇博士は五ツばかりおまはりをして、手をのばすと、ひよいと横なぐれに風を受けて、斜めに飛んで、遙か川下の方へ憎らしく落着いた風でゆつたりしてふわりと落ちるト忽ち矢の如くに流れ出した。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇にしては少し顔がそぐはないから何にしやう、何に肖て居るだらう、この赤い鼻の高いのに、さきの方が少し垂れさがつて、上唇におつかぶさつてる工合といつたらない、魚より獣より寧ろ鳥の嘴によく肖て居る、雀か、山雀か、さうでもない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇は腹をぶく／＼さして、肩をゆすつたが、衣兜から名刺を出して、笊のなかへまつすぐに恭しく置いて、「かういふものじや、これじや、僕じや。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、おとのさま」「二十人も三十人も馬に乗って、氏神様のお神行のようじゃ」「藩公が来られたか」「はんこうか、鮟鱇か知らんが、高知の城下から来たそうじゃ」「真箇か。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地に向った右側は魚屋になって、店には鮟鱇を釣し、台板の上には小鯛、海老、蟹。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて見ろ、脂の乗つた鮟鱇のひも、と云ふ珍味を、つるりだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "方なしの皺になりましたが、若い時は、その薄紅に腫ぼッたい瞼が恐ろしく婀娜だった、お富といって、深川に芸者をして、新内がよく出来て、相応に売った婦人でしたが、ごくじみな質で、八幡様｜寄の米屋に、米搗をしていた、渾名をニタリの鮟鱇、鮟鱇に似たりで分かる。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニタリニタリ笑っているのに、どこへ目をつけたか、その婀娜な、腫ぼったいのをなくなすほど惚れましてな、勤めをよすと、夫婦になって、資本を注ぎ込んで米屋を出すと、鮟鱇にわかに旦那とかわって、せっせと弁天町へ通う。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が手玩と見ゆる狗子柳のはや根を弛み、真の打傾きたるが、鮟鱇切の水に埃を浮べて小机の傍に在り。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして食ひつめものの商人は門司、佐世保、大牟田などの新らしい繁華を慕ふて奔り、金齒入れた高利貸は朝鮮にゆき、六騎の活氣ある一團は六十餘艘の小舟に鮟鱇組の旗じるしを翻へしながら遠洋漁業の途にのぼるかして、わかい子弟の東京へゆくものさへ、誰一人この因循な故郷に歸らうとはせぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の紅毛人は、章魚、烏賊、鮟鱇などの魚類を、俗に「｜悪魔の魚」と称して、食膳にのぼすことを厭ふといふ話だつた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は、周子の母を鮟鱇に例へ、己れを或る種の紅毛人になぞらへて見たりしたのであつた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれあのあんこうなさ取り持づ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな友達ができたか」「あんこうというやつがあります。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはそのまむしやフンプンやあんこうがどんな話をしてどんな遊びをしてどんな本を読んでるかまでくわしくきいた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかなの肝で特に美味いのは、たい、はも、かわはぎ、ふぐ、あんこう、うなぎ、たら。",
              "citation": {
                "source": "知らずや肝の美味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
