[
  {
    "uuid": "b827b6dc-45e9-55af-ac42-096add4d738a",
    "entry": "鮟鱇",
    "reading": {
      "primary": "あんこう",
      "alternatives": [
        "アンコウ"
      ],
      "is_heteronym": false
    },
    "grammar": {
