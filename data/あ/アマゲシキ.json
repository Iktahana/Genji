        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨景色について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨景色という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨景色の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨景色が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨景色を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨景色について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨景色の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨景色の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨景色が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨景色という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨景色という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨景色についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨景色を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨景色は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨景色について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨景色が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨景色は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨景色の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨景色は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨景色は興味深い例である。",
              "source": "幻辞"
            }
          ],
