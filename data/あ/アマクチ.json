[
  {
    "uuid": "43de1aab-a02e-5d89-9d95-c91b2ccdfb3d",
    "entry": "甘口",
    "reading": {
      "primary": "あまくち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
