    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sweet flavour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘口について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘口という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘口の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘口が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘口を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘口について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘口の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘口の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘口が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘口という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘口という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘口についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘口を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘口は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘口について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘口が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘口は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘口の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘口は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘口は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すなわち「いき」のうちの「意気地」や「諦め」が存在を失って、砂糖のような甘ったるい甘味のみが「甘口」な人間の特徴として残るのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばごく甘口の行き方をすれば、弦の切れて巻き上がった三味線をちょっと映した次に、上野の森のこずえのおぼろ月でも出しそれに夜がらすの声でも入れておいて、もう一ぺん妹とその情人の停車場へ急ぐ自動車を出すとかなんとか方法はないものかと思う。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とさも聞惚れたる風を装おい、愉快げに問いかくれば、こは怪談の御意に叶いしことと亭主は頻に乗地となり、「いえ世がこの通り開けましたで、そういう甘口な妖方はいたしません。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらぢの野郎が甘口だつて何もお袋まで一緒になつて人の相續人に障るやうなことして呉れねえでもよかんべと思ふんだ。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和州旧跡幽考』に猿沢池は天竺猴池の西の諸猴如来の鉢を持って樹に登り蜜を採り、池の南の群猿その蜜を仏に奉ると『西域記』を引き居るが、仏はなかなかの甘口で猴はそれを呑み込んで人間に転生したさに毎々蜜を舐らせたと見える。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水金のたれはちっと甘口でぞっとしねえが、中くしのほどよいところを二、三人まえいただくのも、いかさま悪くねえ寸法だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し甘口なことをいってやると、じきにおまえはうれしくなるからいけないよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酒はあまり遣らない方だから、すこし甘口ではあるが白葡萄酒の玻璃盃に一ぱい注いであるのを前に置いて、それをすこしづゝ遣つたり、乳色のした牡蠣の汁を啜つたり、それから暖簾の奥の方でコックのさせる物音や脂肪のヂリ／＼煮える音を聞いたりしながら、夢のやうに過ぎ去つた年月のことを胸に浮べて見た。",
              "citation": {
                "source": "犬",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう言いながら、市の恩人であり、商人社会の庇護者であるところの警察部長は、甘口のウォツカと辛口のウォツカで混合酒をこしらえて、まず前菜をつまんでから、それをぐっと一息に呑みほした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな甘口に引っかかって一寸でも躊躇したら、その躊躇がそのまま「有罪の証拠」になる事を逸早く頭に閃めかした私は、老刑事の言葉が終るか終らないかに、憤然として云い放った。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな甘口で易々と貴様は放免しないぞ」「じゃ何んですか」　浅田は不審そうに根岸を見ながら、「私の宅へ松下一郎と云う名で手紙は来ていませんか」「来ていない」「そりゃ可笑しいな」　浅田はじっと考えながら、「そんな筈はないんだが、もう、どうしたって来ているのですがね。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本朝二十四孝』八人の猩々講に――波の鼓の色もよく、長崎の湊にして猩々講を結び、椙村のうちに松尾大明神を勧請中、甘口辛口二つの壺をならべ、名のある八人の大上戸｜爰に集まる。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたしが、そんな甘口に乗ると思って？",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "カビの生えた、それも青々と、そして、やたらに穴のあいているのなどを、これがオツなんだと言われて、口に入れてはみたものの、あんまりオツすぎて、プフッと言っちまって、あわてて、甘口のシャムパンを飲んだことなども思い出す。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生ッ、こんな甘口な判じものがわからないはずがあるものか、六十上とは何んのことだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばかッ、それはなんだ」「ヘエ」　あわててげん固を引っ込めた恰好は、柄にも似ぬ甘口な男らしくもあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ人間は此上もなく甘口だから宜いやうなものゝ」「驚いたね、小言を聽きに來たやうなものだ」「赤羽橋の友吉親分はどうした？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧糸の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のため、最初に死骸を見付けた、小僧の巳代吉を呼んでもらひました、十七といふにしては大柄で、結構力仕事も出來さうですが、人間は少し甘口らしく、顏一面に凄いニキビの吹き出して居るのが氣になります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女臼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銭形の、そんな甘口な弁解を信用しちゃならねえ、――第一金箱には五百両入っていたはずだっていうぜ、あとの二百両をどこへやったんだ」　喜三郎は少し焦れ気味に清松を小突き廻します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お篠姉妹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、今の人々が聞いたら、さぞくすぐったい思いでしょうが、昔の人はこんな甘口な迷信に何んの詮索もせずに易々と引っ掛ったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "が佐々波金十郎のは弱りましたぜ、仕方がないから、お礼さんを拝み倒して、少し甘口な手紙を借りて来ましたよ」　ガラッ八は二三本の手紙を纏めて差出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "敵討果てて",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何しろ小判で三千両と言うから――」　青髯の男は、思いのほか甘口で、ペラペラとやります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "招く骸骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「錢形の、そんな甘口な辯解を信用しちやならねえ、――第一金箱には五百兩入つて居た筈だつて言ふぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お篠姉妹",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の片腕を切られて、それから裏長屋に引込むほどに落ち果て、二十歳娘の手内職で父娘二人細々と暮して居るお秀が、少し人間が甘口に出來た八五郎を捉まへて、愚痴交りに頼むのも無理のないことだつたでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「周太郎は、少し甘口な大膳坊をだまし込み、人に顏を見られちや惡いとか何んとか、姿を變へさせて、ちよつと自分に似せ、三人力を協せて三千兩持出したが、バレさうになつたので、大膳坊を殺して、わざと穴を崩したに違ひない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地中の富",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、紋次郎とお秀は二年も前から許し合ふ心持になつてゐたのを、隣のお組お千勢母娘が口惜しがつて紋次郎が浮氣心で、たつた一度お千勢にからかつたのを質に取り、逃げ腰になると「父親に言ひ付けてやる」と言つたやうな甘口な脅かしで繋いで、到頭お千勢との間を割くことのできないものにして了つたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は少し甘口だが、先刻も御覽の通り、力はありますよ」「どうせあつしは甘口ですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "江戸の夜光石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
