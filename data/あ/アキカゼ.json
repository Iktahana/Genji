        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新聞も読まず、これといつての読書もせず、秋風のやうな気持になつてゐる此の頃であつてみれば、その、女の葉書といふは一大事件であつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのビルヂングの林立する新宿の町々に、かうした多くの人物が生棲してゐることを考へ、都會の隅々に吹きめぐる秋風の蕭條といふ響を聞いた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の直ぐ向ふの笹籔が、サワサワと秋風に吹かれて音立てゝゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の部門を出て故人に逢ひぬ秋の暮　秋風｜落寞、門を出れば我れもまた落葉の如く、風に吹かれる人生の漂泊者に過ぎない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や干魚かけたる浜庇　海岸の貧しい漁村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒には干魚がかけて乾してあり、薄ら日和の日を、秋風が寂しく吹いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や酒肆に詩うたふ漁者樵者　街道筋の居酒屋などに見る、場末風景の侘しげな秋思である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばこの句の場合で、「酒屋」とか「謡」とかいう言葉を使えば、句の情趣が現実的の写生になって、句のモチーヴである秋風落寞の強い詩的感銘が弱って来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句は「酒肆に詩うたふ」によって、如何にも秋風に長嘯するような感じをあたえ、詩としての純粋感銘をもち得るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条たる秋風の音は、それ自ら芭蕉の心霊の声であり、よるべもなく救いもない、虚無の寂しさを引き裂くところの叫である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁金が寒く来鳴き、新治の鳥羽の淡海も秋風に白浪立つ頃ともなれば、女は自分が先に立ち奴たちを率いて、裾わの田井に秋田を刈った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッシー通りで夫婦｜揃って食料品店で働き抜いた五十五、六の男の自然に枯れた声も秋風のなかにふさわしい。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞは正氣に復りて夢のさめたる如く、父樣母樣といふ折のありもやすると覺束なくも一日二日と待たれぬ、空蝉はからを見つゝもなぐさめつ、あはれ門なる柳に秋風のおと聞こえずもがな。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞは正気に復りて夢のさめたる如く、父様母様といふ折の有りもやすと覚束なくも一日二日と待たれぬ、空蝉はからを見つつもなぐさめつ、あはれ門なる柳に秋風のおと聞えずもがな。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞは正氣に復りて夢のさめたる如く、父樣母樣といふ折の有りもやすと覺束なくも一日二日と待たれぬ、空蝉はからを見つゝもなぐさめつ、あはれ門なる柳に秋風のおと聞こえずもがな。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とせ下谷のほとりに仮初の家居して、商人といふ名も恥かしき、唯いさゝかの物とり並べて朝夕のたつきとせし頃、軒端の庇あれたれども、月さすたよりとなるにはあらで、向ひの家の二階のはづれを僅かにもれ出る影したはしく、大路に立て心ぼそく打あふぐに、秋風たかく吹きて空にはいさゝかの雲もなし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情詩社の昔から、僕と手をたづさへて詩壇に出て、最初の出發から今日まで、唯一の詩友として同伴して來た室生君が、最後の捨臺詞を殘して告別したのは、僕にとつて心寂しく、跡に一人殘された旅の秋風が身にしみて來る。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、それらの文学と深い関係のある、或る意味ではその先覚者と目される正岡子規の、日清戦争に従軍した際の句に、行かばわれ筆の花散る処までいくさかな、われもいでたつ花に剣秋風の韓山敵の影もなし　等があるばかりである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味で私は、「春雨」も「秋風」も西洋にはないと言うのである、そうして、こういう語彙自身の中に日本人の自然観の諸断片が濃密に圧縮された形で包蔵されていると考えるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」「秋風」というような言葉は、日本人にとっては決して単なる気象学上の術語ではなくて、それぞれ莫大な空間と時間との間に広がる無限の事象とそれにつながる人間の肉体ならびに精神の活動の種々相を極度に圧縮し、煎じ詰めたエッセンスである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」はビルディング街に煙り「秋風」は飛行機の翼を払うだけの包容性を失わないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間と化合した有機的の「春雨」「秋風」はその言葉の外形は不変であっても、その内容は人間社会とともに進化の歩みを止めることはない。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」「秋風」は日本人には直ちにまた人生の一断面であって、それはまた一方で不易であると同時に、また一方では流行の諸相でもある。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り秋風が立ち始めて黍の葉がかさかさ音を立てるころになると世の中が急に頼もしく明るくなる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親に似て恐ろしかろうといって、親のわるい着物を引きかぶせてやり、秋風が吹く頃になったら来るよとだまして逃げて行ったのを、そうとは知らず、秋風を音にきき知って、父よ父よと恋しがって鳴くのだ」というのである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていると、今に世界の方々の隅から秋風が来る。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は十五夜で、晴れた空には秋風が高く吹いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のひかり煙を青み、　　　　秋風に児らは呼び交ふ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
