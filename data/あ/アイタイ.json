[
  {
    "uuid": "fadcb95e-3079-5e22-8821-7d574469ebfa",
    "entry": "相対",
    "reading": {
      "primary": "あいたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "involving only the parties concerned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "又、之の欠乏する限り、判断といふものもひどく相対的にしか行はれないのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "手短かに云ふなら、私は相対的可能と不可能の限界を知り、さうして又、その可能なるものが如何にして可能であり、不可能なるものが如何に不可能であるかを知つたのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへくらゐのものにまだ相対界を尽滅させられて堪るものかいと空で無頼漢が私にいふ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私自身まだ相対界が好きなのだから私は無頼漢の奴隷になつてなくちやならなくとも仕方がない。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故と云つて神は絶対であり、私の表現は相対的に行はれるのみだからである。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、人の子の謂ふ奇蹟も容易きことなれど、人の子を遣りたる相対の世界には神自らも相対性以外を行ふとも見せられず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし相対原理が一般化されて重力に関する学者の考えが一変しても、りんごはやはり下へ落ち、彼岸の中日には太陽が春分点に来る。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般化された相対論はとにかくとして、等速運動に関するいわゆる特別論などはあまりにわかりきった事であるためにわかりにくいと言われうるかもしれない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の長短という事はもちろん相対的な意味しかない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単になるべく沢山の鳥を殺して猟嚢を膨らませるという目的ならとにかく、獲物と相対してそれに肉薄する緊張が加速度的に増大しつつ最後に頂点に到達するまでの「三昧」の時間に相当の長さのあることだけから見てもこれは決してそれほどつまらないものではないだろうと思われる。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両山脈の相対する間隔は、直径約一里もあろうか、間の岳の頂までは、この河原から一里半で達せられる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "劃時代的な二つの階級間の闘争が、全市から全日本の相互の階級を総動員して相対峙していたのだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "離れたときには山と自分と相対した二つとなり、融ずるときには自分を山となし、或は山を自分とする一致ができた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、文化的存在規定を内容とする一対の意味が、一は肯定的に言表され、他は否定的の言葉を冠している場合には、その成立上における原本性および非原本性に関して断定を下すことができるとともに、その意味内容の成立した公共圏内における相対的な価値判断を推知することができる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "上面および底面上にて対角線によって結び付けられた頂点に位置を占むる趣味は相対立する一対を示す。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、そういう場合は、縦縞と相対的関係をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、場面全体の形状と相対的関係をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう寒い部屋で相対坐している主人に百パーセントの好意を感じようとするのは並々ならぬ意志の力を必要とするようである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアインシュタインは古い昔のガリレーをほじくって相対性原理を掘りだし、ブローイーは塵に埋もれたハミルトンにはたきと磨きをかけて波動力学を作りあげた。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内には、親にあいたい息子がいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻にあいたい夫がいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫にあいたい妻がいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども王さまが王女にあいたいというものですから、さすがにすぐとはそれをすることもできずにいました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちとつながりあいたい」と訴えるその足下で、何をどう結ぶのかという問いかけが、学校の日常の中でぼろぼろと崩れ落ちてしまうことへの恐怖が、痛切な自己批判と共に語られました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度どうしてもゆっくり木部にあいたい気になっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、倭文子にあいたいという心が、はげしい飢渇のように彼の心をおそった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ただ彼女にあいたいという一心で、今日まで生きてきたのです」「この三年の間に、私は絶望して死のうと思ったことが何度あったかもしれません。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたがたの傍まで近づいた上で、互いに十分話しあいたい。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
