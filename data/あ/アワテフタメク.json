    "definitions": [
      {
        "index": 1,
        "gloss": "to get into a panic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日慌てふためくについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は慌てふためくの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には慌てふためくが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは慌てふためくについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は慌てふためくの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では慌てふためくが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に慌てふためくという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では慌てふためくについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると慌てふためくは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では慌てふためくが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に慌てふためくは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により慌てふためくの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "慌てふためくは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に慌てふためくは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……御注進御注進、一大事一大事……ナ、何事じゃ……と慌てふためく動的はした役者よりも、舞台の真中に神色自若としている千両役者の方が、はるかに深い感動を見物に与えるようなものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠が冷い水の中へ放うられて岸に向って慌てふためく。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢやによつて沖を通る廻船さへ、時ならぬ潮のさしひきに漂はされて、水夫楫取の慌てふためく事もおぢやつたと申し伝へた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけの分らないのは馬小屋に十人づゝ並んでゐた連中で、この連中まで人並に慌てる、慌てふためく、全然筋が通らない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々哲学者といふものは常に自らの意志によつて追ひつめられてゐるものであるが、俗物共ときては他によつて追ひつめられるから、慌てふためく。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は徴用を受けたとき、うんざり悲観したけれども、母が私以上に慌てふためくので、馬鹿馬鹿しくて、母の気持が厭らしくて仕方がなかった。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって鼻介の情報は彼の自負通り正確丁寧、水ももらさぬ趣きがあるが、実に出所が厳正、これ以上に真相を語る者の有りうべからざるところから出ているのだから、アンニャもオンチャもアレヨと慌てふためくばかり、口惜しいけれども、どうにもならない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げろ、警視庁の自動車三台が二十分と経たぬ間にここへやってくるぞ※」「そりゃ大変だ、逃げろ、逃げろ※」皆はにわかに慌てふためく。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "智深の行動とともに、楊志や曹正なども、慌てふためく賊の手下どもへ立ち向っていたのはいうまでもなく、また、彼らが手もなく慴伏してしまったのは勿論だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま旅から帰って来ましたよ」死者に口なく、官に正道なく、悲恨の武松は訴える途なき事　武松の訪れを階下に聞きながら、二階では何か慌てふためく物音だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうとき慌てふためくと、後々までの語り草になされる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生のところどころに黒がねの弓伏せて植ゑおき、靴の尖もて押へたる五色の球を、小槌揮ひて横様に打ち、かの弓の下をくぐらするに、巧なるは百に一つを失はねど、拙きはあやまちて足など撃ちぬとてあわてふためく。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生のところどころに黒がねの弓伏せて植えおき、靴のさきもて押えたる五色の球を、小槌ふるいて横ざまに打ち、かの弓の下をくぐらするに、たくみなるは百に一つを失わねど、つたなきはあやまちて足など撃ちぬとてあわてふためく。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "主張をしにきたのだ」と叫び、あわてふためく同僚に「私は、私は……」と叫びつつかつぎ出される光景をもって結んでいるのである。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴さまが、あわてふためく時じゃあねえ――心をしずめて、何とかひとつ方便をめぐらさねえことにゃあ――　しかし、うまい考えも、頓には出ずに、両国広小路の方へうつむき勝ちにやって来ると、フッと、向うに一群の人数――十人ばかり、いそがしげな捕物勢らしい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ松ちゃんが驚いて「敵百五十機が関東北部で廻っていて、こっちへ入ってくる」とあわてふためく。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑怯未練な振舞はもちろんのこと、用意周到を欠いて、いざといふ時あわてふためくが如きは、これみな「不覚」のいたすところで、それぞれの立場に応じ、分に従ひ、何時どんなことが起つても、自若としてこれに立ち向ふことのできる準備ができてゐて、はじめて、「不覚をとらぬ」ことになるのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると　ふたりして　あわてふためく　このウサギたち。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が気でないので、一同があわてふためく中で、医道の用はこの時にありとばかり、長庵は大得意だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しーんとしたあと、また今度はざわざわあわてふためく、「どういうことだ、おめえさん。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しーんとしたあと、また今度はざわざわあわてふためく――「あごを上だ――ブランデーを――つまらせるなよ――どういうことだ、おめえさん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてふためく芳衛さんやトクさんを差図して魔法瓶に熱い紅茶を詰めさせ、厚い毛の下着とブランデーをルックザックにいれて背負うと、キュッと口を結んで玄関からすべりだした。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰天した平家はあわてふためくこと一通りではない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホントに安心して目をつぶるか、シマッタとあわてふためくか、それとも死にぎわの一芝居というんでコケオドカシの大芝居を打つか。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、引く息ばかりになって白眼を出しているのを、自分の子供でもあるまいに、いきなり横抱きにひっ抱え、あわてふためくあたしを叱りつけ叱りつけ、宙を飛ぶようにして呉先生の処へ担ぎ込みました」　涙で咽喉をつまらせながら、声もおぼろになって、「長太郎はそれで助かったんです。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ――ッ」　ふたりの若い召使は、武家の娘ではあり、ご殿づとめで武術の心得もあり、キモもすわっておりましたが、とつぜんのできごとに仰天してわかい娘のおくびょうさにかえり、ただもうあわてふためくばかり。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を襲われて、あわてふためく敵兵のなかを、縦横無尽に駆けまわって、彼はついに敵将の一人をほふり、その首級を提げて、悠々として引きあげた。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に手に太刀をふりかざして、あわてふためく穴山一｜党のなかへ、天魔軍のごとく猛然と斬りこんだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄徳の兵は、一斉に衝いて出で、あわてふためく張宝の部下をみなごろしにした。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪来は、あわてふためくと見せかけて、味方へは、懸れ懸れと下知しながら、自分のみ真ッ先に逃げ走った。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
