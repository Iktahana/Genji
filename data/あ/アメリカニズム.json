        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカニズムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカニズムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカニズムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカニズムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカニズムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカニズムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカニズムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカニズムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカニズムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカニズムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカニズムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカニズムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカニズムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカニズムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アメリカニズムのエロ姿によだれを流し、マルキシズムの赤旗に飛びつき、スターンバーグやクレールの糟をなめているばかりでは、いつまでたっても日本らしい映画はできるはずがないのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所謂「モダン・ライフ」のアメリカニズムは、もと／＼小生の望むところでありました。",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は旅行の用意はなんらしていなかったが、ここにアメリカニズムがあるのだと思ってそのまま同行する事にしました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アメリカニズム５・３東京日日（夕）　Ａといふアメリカ産れの男が、Ｂといふ移民の一人と話し合つたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、僕達は君らにくらべるとよけいにアメリカニズムを持つてると、これでいさゝか自認してるんだよ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アメリカニズムだつて。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルキシズムや唯物思想や、アメリカニズムや、大衆や、エログロや、その他一般に喧々｜囂々として附和雷同する街頭の流行論に附随して僕などが今更チンドン屋の旗持の一人になる必要は毫もない。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の汎アメリカニズムと×××××××の矛盾は益々増大しつつあると、中国国民党の走狗どもは云っているが、これは間違いである。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、無思想であり、無反省でありながら、然も恐しき実行力を、生活力を伝播していくアメリカニズムのジャズ文明に対する批判。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今日、日本のみならず諸国がアメリカ化されつつある点から見て、アメリカニズムは日本人のみならず世界中の人びとにもしたしみ易いであろうから、従ってある点までの普及性は有するであろうが、その翻訳に依る価値の半減はどうにも出来ない事実であろう。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、この科学の加速度的進歩と、思想的混乱――アメリカニズムとボルセヴィズムの無批判な吸収――のさ中にあって、今、将来の文芸こそが夫らを正しく認識し、指導し、方向を示すべく運命づけられているのをひしひしと感ずるのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、アメリカニズムの夥しい氾濫が、無産階級の夢をいかに育んでゐるか？",
              "citation": {
                "source": "続言葉言葉言葉（その一）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に、今日の「新派」は「現代」そのものの如きアメリカニズムにさへ没交渉ではないか！",
              "citation": {
                "source": "歌舞伎劇の将来",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい建築だつたらどこかにアメリカニズムの影響があらう。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝこのアメリカニズムだけはよろしい。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性と雖も、その上、左翼思想の流行に無関心ではゐられず、アメリカニズムの宣伝に耳を傾けないわけにいかぬといふ始末である。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアメリカニズムの系統に見いだす文学として首肯さるるであろう。",
              "citation": {
                "source": "探偵小説の芸術性",
                "author": "――文学のメカニズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ京都派の哲学者の座談会があって、それが気に入らず、また清水幾太郎のアメリカニズムの研究その他が惡い。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "好みとか趣味とかは、単に随意や主観性をしか持たないものではなく、実は各個人に固有な意識形態が、極めて端的で直接な日常的表現を取ったものに外ならないから、この趣味が例えば「アメリカニズム」や「機械文明」（もしそういう概念でも成り立つものとすれば）を象徴するとも云われるのである。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が例えばアメリカニズムは他人がつけたニック・ネームに他ならない）。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたものからモダーニズムは所謂アメリカニズムとして、日本に流れ込んで来ることを、妨げる如何なる「教養」もあり得なかった。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "各種のファシズム（アメリカニズムや自由主義さえ実は之に数えられねばならないのだが）が資本主義の解決でない限り、そうだ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見オッチョコチョイなアメリカニズム・モダーニズム映画もそう考えれば純芸術的映画よりも遙かに批判的な哲学者だということになる。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はアメリカニズムをばローマ主義に歴史的に還元し（之は一種の時間上の反動・反抗・と考えられるべきだ）、このローマ主義に反抗することによってアメリカニズムに反抗するために、「原始キリスト教」の検討を行なう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカニズム（と云うのは、つまり、資本主義文化の普遍性に相当するもののことだが）に対抗するためには氏がアメリカニズムの原型と考えたローマ主義に対抗する必要があるというので、それを動機として「原始キリスト教」の研究が発表される。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのパンジャーマニズムとか、パンスラヴィズムとか、グレーターブリタニズムとか、パンアメリカニズムとかいうの類は、すべてこの民族的国家が帝国主義を行わんとする思想を説明したるものに外ならぬ。",
              "citation": {
                "source": "文明史上の一新紀元",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマイノリティはアメリカニズムを否定し、人間とはいったいなになのかを、原点にできるだけちかいところで考えなおしていこうとする。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
