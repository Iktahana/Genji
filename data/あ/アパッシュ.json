        "examples": {
          "standard": [
            {
              "text": "アパッシュについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアパッシュは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアパッシュについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアパッシュの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアパッシュが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアパッシュを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアパッシュが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアパッシュが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアパッシュは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアパッシュは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアパッシュは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアパッシュについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アパッシュの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアパッシュの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアパッシュの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見せかけのこの親子連が成功するかしないかと楽屋を見抜いた商売女たちや店の連中、定連のアパッシュまでがひそかに興味をもって明るい電気の下で見まもっていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊会の「アパッシュの歌」とその画面は自分にはあまりおもしろくなかった。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンチングをかぶったアパッシュ風の男がズボンのポケットで歩るきながら銭をじゃらじゃらいわせる音。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい、理知だけの操作でない、対象との人間らしい共感においての観察という点の強調が、虫に頬かぶりをさせたり、草叢のアパッシュたらしめたりした。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本にいて銀座をブラつくモダンボーイになるよりはパリのモンマルトルでアパッシュになった方がまだしも気が利いているかも知れない、これはジョークだが、私はまったく駒の出ないことを心から祈っているのだ。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも軽機関銃でアパッシュ連中が撃ち合いをしとる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜中にこのあたりのアパッシュ連中、縄張り争いでやり合うらしいんだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、本郷の街裏で見た、女アパッシュの群達の事が胸に浮んできた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "首に赤ハンカチを巻いたアパッシュの群が、気まぐれに寒子に眄をくれながら「｜今晩は｜お嬢さん」と呼びかけて通つて行く。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒子はその街灯の前で自動車を降りるとアパッシュの門番のゐる、牢屋のキャバレーの中へ、赤いハンカチの男に案内をして貰つた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女アパッシュ　二月×日　あゝ何もかも犬に食われてしまえ！",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアパッシュが好きなのだ。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ子夫人はその日、某デパートへ買いもののため、彼女の郊外の家を出掛けたが、その道すがら突然アパッシュの一団に襲われたのだった。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚の可愛いいレヴィウから、カジノ・フォリー、プペ・ダンサントと進み、北村富子一座などというエロ・ダンスへ移り、アパッシュ・ダンスを観た。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い冷めたい下水道濡れて育ったアパッシュは………　又誰かが唱っている。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巴里アパッシュの唄」が、百貨店装飾工の仕事行進曲になっても別に差支えはない筈だ。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い冷めたい下水道濡れて育ったアパッシュは………　彼は仕事の手を止めた。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黄門」の中には、渡辺篤と二人のアパッシュがある、大変なことになった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスクの怪物と、洋装の美女との、世にも不思議なアパッシュ・ダンスだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
