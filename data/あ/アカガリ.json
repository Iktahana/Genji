        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、彼奴等はえてそんな事件を口実にして、「赤狩り」をやったのだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は須山と会ってみて、「赤狩り」は何も外ばかりでないことを知った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場では外の警察だけではあまり効果がないと云うので、清川や熱田の「僚友会」や在郷軍人の青年団を入れ、内部から「赤狩り」をしようとしたのに、「マスク」やビラなどで、その事さえバク露されて、あせり出したらしい。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッカーシーの赤狩りが極端なかたちで示しえたように、アメリカの国内は、不健康に緊張していた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇年代前半で赤狩りを利用したのとまったくおなじように六〇年代後半で法と秩序を利用し、大統領になっている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にニクソンは、大衆がものごとの根本を見ようとしないでいることに乗じたデマゴーグの産物でもあり、マッカーシーといっしょに赤狩りのときに活躍した前科を思いおこせば、とうてい大統領にできる人物ではないのに、いま現に大統領として、戦争経済をすすめている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次大戦をチャンスに、アメリカはヨーロッパにマーケットを広げ、おかげで、債務国から債権国になり、国内での社会主義（アメリカ民主主義以外のあらゆる思想）の発生をおさえるため、コンフォーミズムを国民に強要し、赤狩りをおこなった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『鼻取相撲』や『文相撲』などに登場する大名と来た日には、力の弱い骨頂で、『栗焼』『太刀はい』『粟田口』『あかがり』などへ現われて来る、お大名衆と来た日には、まことにうってつけに太郎冠者殿に、からかわれるに適した人物でござんす。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
