        "examples": {
          "standard": [
            {
              "text": "私は毎日編み物について考えている。",
              "source": "幻辞"
            },
            {
              "text": "編み物という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編み物の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編み物が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編み物を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編み物について学習した。",
              "source": "幻辞"
            },
            {
              "text": "編み物の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編み物の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編み物が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編み物という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編み物という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編み物についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編み物を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編み物は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編み物について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編み物が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編み物は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編み物の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編み物は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編み物は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "渠は編み物の手袋を嵌めたる左の手にぶら提灯を携えたり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "売り手のじいさんやばあさんも長い煙管を吹かしたり編み物をしているのでありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二、三の蛇、互いに纏うた処を編み物にして戸口に掲ぐる。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ときはもうすつかりよくなつたやうな氣がすると言つて、床を疊んでつれ／″＼の編み物なぞをして坐つてゐた。",
              "citation": {
                "source": "金魚",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌を読んでいたり、編み物をしていたりした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊は沢山の子供にまじって秋の日を浴びながら、嬉しそうに遊びまわっておりましたので、お崎は別に気にも留めず、拝殿に腰をかけて、毛糸の編み物をしておりました。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "編み物に刺繍、そんなことも好きであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから編み物が旨い。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一つ一つの入口に、今朝はだしで魚を呼び売りしてたような女たちが、それぞれ木綿レイスの編み物なんかしながら客を待ってるのを見かけるだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等の不斷の樣子を見れば、縫ひ物や編み物をしたり、髮を解いたり、結つたりして居るので、それに智識上の事を話しても分らない。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）編み物か何かをしてゐました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "）編み物か何かしていました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこし一しょに居て、こうやってファイア・プレェスの前で私がまだいくぶん独身者のように、ときどき一人ごとなど言いながら手紙を書き、女房が心もち物足りなそうな顔をして、編み物をしている傍で、ちょっとの間だけでも、こんな少し淋しすぎる一家｜団欒を賑わせていてくれたら好かりそうなものだのに。",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きられるのですけども――」と編み物をさしおき、襟の乱れを繕いつつ、起き上がらんとするを、姑は押しとめ、　「そ、そいがいかん、そいがいかん。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そ、そ、そ、また編み物しなはるな。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きられるのですけども――」と編み物をさしおき、襟の乱れを繕いつつ、起き上がらんとするを、姑は押しとめ、「そ、そいがいかん、そいがいかん。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "籐椅子に凭れずに、尠し上体を前こごみにすると、隣の部屋に編み物をする弟の妻、ことし三十になる女の半身が見えるのである。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬耳は籐椅子に身をもたせ、女の姿が見えない位置に身を置いたとき、安心して隣室の方をながく眺め、編み物をする白い手頸を想像した。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は編み物をしてゐる。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、好きな裁縫や編み物のような、静かな手芸に飽きることを知らないような娘であった。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはいつも控へ目に隣室の入口で編み物をしてゐたのです。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、アロアはストーブのそばにある背の低い椅子に座って編み物をしていましたが、涙がぽたぽたと編み物に落ちるのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ家の戸口では五、六人の女が編み物をしたり、おしゃべりをしているのを見た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口と周壁の或る部分には席を下げ置きしなるべく、地上には木材を並べ、其上に席、編み物、獸皮、木皮抔敷き列ねて座臥の塲所とせしなるべし。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是製造の始｜敷き物として用ゐたる編み物或は木の葉が偶然此所に印せられしに他ならず。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "布、席、編み物、紐細き棒の小口、貝殼等を押し付けて印したる紋を押紋と云ひ、細き棒或は篦を以て畫きたる摸樣を畫紋と云ふ。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の女はよくあみものにクレージーなのがあるが、やり始めて見ると、面白いものだ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きて下に降りたら栄さんもう大分あみものをすすめている。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ジョウは、大きな声で本を読みながら、あみものをしていました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ、いらっしゃい、あみもの教えてあげるわ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
