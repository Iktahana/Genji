        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内係について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内係という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内係の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内係が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内係を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内係について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内係の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内係の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内係が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内係という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内係という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内係についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内係を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内係は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内係について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内係が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内係は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内係の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内係は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内係は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "正面玄関の上り口では、やっと閑散の身になった案内係の少女達が他愛もないおしゃべりに夢中になっていました。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内係りの少女達は、「名前を告げなければ駄目です」　と言っても、その女は、「それをどうにかして下さい」　と言ってききません。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに旧劇場で案内係をして居た一人の娘の親が英人の娘として米人の使用人に変ることは英国の不節操であると同時に米国への屈従であると云って断然許さなかった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝は自動車の案内係をしている旨を言い、「今日は公休でっけど、明日は……」　勤めがあるから出られないと下向くと、次郎は、「でも、仕事は夕方までで済むんでしょう？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、鶴富組の主人は、一風変った一見識あり、タクシーの案内係の制服のまま見合いに出て来たという点が何よりまず気に入った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ客はまごつき、運転手も余り歓迎せぬ制度ゆえ、案内係は余程の親切・丁寧・機敏が要る。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵はやがて、いそいで、例の案内係りのボーイをさがしに出かけていったので、ホームズと私とは朝飯をたべにブルックストリートに帰って来た。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それから例の案内係のボーイは、証拠不充分と云うので放免された。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもある九等官は、とある小さな局長に任命されると早速自分だけの部屋を仕切って、それを【官房】と名づけ、扉口には赤襟にモールつきの服を着せた案内係を置いて、来訪者のあるごとに、いちいち把手をとって扉をあけさせたものである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなる少年が、案内係のタクマ君でございます。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この町には、貧乏な人が多いと見えるね」　僕は、案内係のタクマ少年にそういった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "手のすいてる子が案内係りもやるというわけで、お客様にも家族的に見ていただこうという、舞台は熱演主義で、熱が足りない時だけは、私が怒ることにしております。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長、従業員、支配人、案内係りなどゝキチンと取り澄まそうたって、このデコボコが承知しやしない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお寺の納所で、案内係であの小坊主を腐らせてしまうのは惜しい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "）電車に乗つても時間のかかる所だから、蕨とりにそこまで出かけた人たちはごく少数で、それに先生が二人ほど案内係りで行つたらしいが、はてしもない高原にその僅かの人数が散らばつて蕨を採つてゐると、ひとりひとりが背負ひきれないやうに沢山とれた。",
              "citation": {
                "source": "軽井沢の夏と秋",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内係との交渉が、望みうすなのを見ると、赧ら顔の支店長は、小柄な体を心配そうに動かしながら、誰にともなく、「この辺に、第一建物会社の事務所ありませんやろか」と云った。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所さえあったら、きっと宿ぐらいなんとかさせますから……ここ動かんと待っとって下さい」　案内係は、没義道につっぱねないが、積極的な助力は出来かねた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男は手振りで許しを与えた）――この人は案内係なんです。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち、つまり役人は、しょっちゅう、しかも第一番目に訴訟当事者たちと接触する案内係は、第一印象をよくするために、身なりもスマートでなければならない、と同じように思っています。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、申上げたとおり、案内係はりっぱな着物がいる、と私たちは等しく思っています。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが突然、一方の腕に案内係の手、他方のに娘の手を感じた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ立ちなさい、お弱いお方」と、案内係は言った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この案内係さんのことをよく思っていただくようにすることが、とりわけ、私の責任なんじゃないかしら。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにつらいわ」「ここでちょっと休みませんか」と、案内係が言ったが、もう廊下に出て、Ｋがさっき話しかけた被告のちょうど前に来た。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきはこの男の前にちゃんと立っていたのだが、今は二人がささえねばならず、帽子は案内係がひろげた指の上にのせており、髪形は乱れ、髪毛は汗ばんだ額の上に垂れていた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、ここで待たしていただけるだろう、今日は日曜日だし、時間があるし、ここでお邪魔にはならない、と思ってまいりました」「そんなに言い訳をおっしゃらなくたってよろしいですよ」と、案内係は言った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋはしばらくじっと立ち止っていたが、懐中鏡で髪を直し、次の踊り場にころがっている帽子を拾い上げ、――案内係がきっとそれを投げ出したのだった――階段を降りていったが、気持があまりにさっぱりし、あまりに大股で歩けたので、この変りかたにほとんど不安を覚えたくらいだった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "高価なブツに目星を付けるために、あとで案内係がキミたちを引き連れて、お宝を教えてくれる。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからは、この人が案内係です。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部を見送った明智は、柵の中にいる旅行案内係に近づいて何か忙しく尋ね始めた。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
