        "examples": {
          "standard": [
            {
              "text": "私は毎日穴あきについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴あきという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴あきの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴あきが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴あきを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴あきについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴あきの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴あきの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴あきが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴あきという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴あきという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴あきについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴あきを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴あきは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴あきについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴あきが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴あきは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴あきの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴あきは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴あきは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中には、青く錆びた穴あき銭を惜しそうにくれる人もあった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌しゆうしゆうと花火ふき出る竹の筒｜幼らすでに勢ひそめにし青銭青銭は穴あき銭よ、字のおもて寛永通宝、裏に波文久永宝、よく数へよく刺し貫くと、手もすまにそろへて締むと、幼な児や息づかし我、青太藺綯ひし小縄の、撚りつよきその緒くくりて、夜々をなげきし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌青銭の穴あき銭をかなしよと父のみ前に貫きて数へつ魚市魚市は師走の市、歳のすゑ、大つごもり前の三日、雪よ霰ふる中を、塩鰤や、我が家の市、競り市や、魚市場、戦や、船に馬に大八車、わさりこ、えいやえいや、かららよ、えいやえいや、人だかりわらわら、はいよ、天秤、担棒、走る走る、えや肩掻きわけて。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の筆跡に穴あきが多いこともかなり特徴的です。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『朱子語類』では、「貫は穴あき銭の貫で、一は縄索である」と語っている。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪穴、巖石に瓢箪を倒さまにしたるが如き穴あきて、つき拔けたるが、金洞の奇にくらべては、物ならず。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂水巖に、蜂巣の如く穴あきたるが面白しと云ふ者もあらむ、それは兒戯的なりと云ふ者もあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、ほら、まだ小粒銀が六つ七つと、穴あき銭が二、三枚ありますよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　穴あき帽子をかむった方が答えました。",
              "citation": {
                "source": "可愛いポール",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも物をいふ時にはこれらの穴あき共は巧みに手をあげ、ちよつと穴を押へて口腔に空気を流すことを怠らない。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其値段は言合せたやうに一皿五厘で、それをあらはすには附木か厚紙に穴あき錢の形を五つ竝べて書いてあつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしるしに　キツネくさいですし、　それどころか　――　えんとつ　がわりの　穴あきバケツから　けむりが　もくもく。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥、葛籠等に納めおきし衣類が、いつの間にか怪しの穴あきて着ることのできぬようになり、柱に掛けておきたる衣類が、故なくして中央より切断してるなど、実に不思議にたえぬとて、主人自ら来たりて余に相談せられた。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "財布の中の穴あき錢の數まで當てるから」　とすゝめられ、ついその氣になつて、人相手相から、身の上運勢を判斷して貰ふと、これが大變でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "秋祭の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米友は緡を取って、穴あき銭をそれに差込んでいると、暫くあってお雪ちゃんがその手を抑えるようにして、「今晩はもうこれだけにしましょうよ、なんだか怖いから、お銭の音をさせないで頂戴な」　お雪ちゃんから哀求的に言われたので、米友も、強いてとは進みきれない心持になりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あツ」　その中から現はれたのは、山吹色の美しい小判の山と思ひきや、悉く青錆びに錆びた穴あき錢ばかり。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持ちたちは潔癖さを示す言葉として「穴あき椅子」を使った。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴元の男が、幾枚かの穴あき銭を両の掌に入れ、振り音を聞かせて、ばっと、場に投げる。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
