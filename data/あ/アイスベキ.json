        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛すべきは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛すべきが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛すべきに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛すべきが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛すべきについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛すべきについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛すべきについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛すべきが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛すべきが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛すべきは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛すべきは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛すべきを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛すべきをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛すべきが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛すべきの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛すべきを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛すべきに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛すべきについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛すべきは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛すべきを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それどころか、所謂さつきの鯉の吹流しの、愛すべき多辯家に過ぎないのではないかと思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは、この子は、父に連れられて近所の井の頭動物園に行つた時、檻の中を絶えずチヨコチヨコ歩きまはつてゐる狸の一群を眺め、愛すべき動物であると思ひ込み、それゆゑ、このカチカチ山の物語に於いても、理由の如何を問はず、狸に贔屓してゐたのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい労働生活で節くれ立った彼の愛すべき掌へ、私は故国から来た親愛なる手紙の封書の切手を何枚もはがして乗せてやりました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はさうした話をきいて、いかにも牧水らしく、自然で、純朴で、愛すべき人物を考へた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れ、愛すべき少女ですな。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その可愛らしいくちばしから造つた巣、一所けんめいでやつた小動物の仕事、愛すべき本能のあらはれ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４「美しい愛すべき珠玉のような‥‥」　これはトルストイがアントン・チェエホフの作品に與へた賞め詞だ。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はお絹を自分の物、自分のみを愛すべき人と、何時の間にか思込んで居たのであらう。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、机のそばに坐って、ひっそりと机に頬杖つき、わが愛読者の愛すべき横顔を眺めた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ見た漫画の中に登場した一匹の犬などは実によく犬という愛すべき家畜の特性を描象してほとんど「犬自体」を映出していると思われた。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物と聞く切干大根の甘いにほひをなつかしんで、手製ののり卷、然も稚氣愛すべきことは、あの渦卷を頬張つたところは、飮友達は笑はば笑へ、なくなつた親どもには褒美に預からうといふ、しをらしさのおかげかして、鴻の臺を向うに見る、土手へ上ると、鳴く、鳴く、鳴くぞ、そこに、よしきり。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、敵機は無残にもこれらの愛すべき地蔵さんを破壊しようとした。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ奉公は奉公に違いなく、町の与太ものの意気もはなはだ愛すべきだが、科学人の白熱的な魂の燃焼も、十分｜讃め称えられるべきだと思われた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、所謂さつきの鯉の吹流しの、愛すべき多弁家に過ぎないのではないかと思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、この子は、父に連れられて近所の井の頭動物園に行つた時、檻の中を絶えずチヨコチヨコ歩きまはつてゐる狸の一群を眺め、愛すべき動物であると思ひ込み、それゆゑ、このカチカチ山の物語に於いても、理由の如何を問はず、狸に贔屓してゐたのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かうした神神を信ずる人は、概して皆正直で、純粹で、最も愛すべき善良な人人である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがキリスト教のことは別問題とし、かうした信仰に生きてゐる人人が、概して皆單純で、正直で、善良な愛すべき人種に屬することは、たしかにヘルンの言ふ如く眞實である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、相手の立場はあまり兄には考へられない一種の愛すべき利己主義と兄はなるのでありました。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は折角素直に生ひ立つた妹の愛すべき性格を知らない他人に、猥りに逆撫でさせたくないといふ真意から、また勇吉は自分が自分とはまつたく性格の反対なこのナイーヴなロマン性の娘を兄に代つて護り育てられる資格と自信を持つたものだから歳子の授受の内容には極めて親切で緊密な了解が働いてゐた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真なるもののみが愛すべきものである、とポアンカレが言っている。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆふ菅の花も微甘でもあり、微気の愛すべきものがあつて宜いが、併し要するに山人のかすけき野饌である。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "能く福を植うるに至つて、人眞に敬愛すべき人たりと云ふ可しである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎島といふ半島的突出の北部の灣形に入り込んだところなどは、何樣見ても茶人的の大庭の池の甚だ寂び古びたやうな感じで、幽雅愛すべきである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處には唯、露西亞の一賤民の愛すべき性情と、明治四十三年五月下旬の某日、私が東京市内の電車に於て目撃した一事件とを、アイロニカルな興味を以て書き列べて見たまでである。",
              "citation": {
                "source": "我が最近の興味",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
