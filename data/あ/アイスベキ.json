[
  {
    "uuid": "2d03ac77-5e69-57a1-90d5-b723786745c3",
    "entry": "愛すべき",
    "reading": {
      "primary": "あいすべき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
