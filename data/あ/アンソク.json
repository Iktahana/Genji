        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安息について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安息という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安息の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安息が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安息を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安息について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安息の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安息の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安息が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安息という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安息という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安息についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安息を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安息は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安息について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安息が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安息は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安息の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安息は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安息は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私が山王山を知つてから、いづれも生活の敗残者であらう、この森の中で、首縊りが二人ばかりあつた、人目を避けるに、都合がいゝとは言ひながら、不思議なことに、死ぬ人は原始的に安息な自然を選ぶ、川や海に身を投げる人と森の中で縊る人と。",
              "citation": {
                "source": "亡びゆく森",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "皺だらけの私の寝室をノックする音がして、暗闇から出た女の手が、楕円形の天井をみつめていた私の目前で葡萄蔓のようにからんで、青いリノリウムのうえにMELINSの扱帯が夜光虫のように円をつくると、私は断截された濡れた頭髪を腕の中に感じて、いつのまにか恋愛のマッフのなかに、ひとときの安息を求めた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし汽車に乗って丸亀や坂出の方へ行き一日歩きくたぶれて夕方汽船で小豆島へ帰ってくると、やっぱり安息はここにあるという気がしてくる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちら此方と安値そうな間を借りては其処から局に通って、午前出の時は午後を針仕事に、午後出の時は午前を針仕事に、少しも安息む暇がないうちにも弟を小学校に出し妹に自分で裁縫の稽古をしてやり、夜は弟の復習も験てやらねばならず、炊事から洗濯から皆な自分一人の手でやっていた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて川に飛び込む鰐は、その飛び込む前に安息している川岸の石原と茂みによって一段の腥気を添える。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し心とからだの安息を与えて、思いのままに彼の欲する仕事に没頭させた方が、かえって本当にこの稀有な偉人を尊重する所以でもあり、同時に世界人類の真の利益を図る所以にもなりはしまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによって、君はやっと生活を凌いで夢の裡に安息することだけは出来た。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしちょっと気を変えて呑気でいてやれと思うと同時に、その暗闇は電燈の下では味わうことのできない爽やかな安息に変化してしまう。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い闇のなかで味わうこの安息はいったいなにを意味しているのだろう。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重要な官衙や公共設備のビルディングを地上百尺の代わりに地下百尺あるいは二百尺に築造し、地上は全部公園と安息所にしてしまう。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから何んの割引もいらぬ静かな安息がひそやかに近づいてくるようにも思いながら。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信心深いイワンは安息日の礼拝に出席するのを怠るようなことはなかったとしても、その他の日は、一日爐ばたに寝そべって独将棋をしたり、遊園地へ行って観覧車に乗ったり、さもなければ二階の窓から遠方の嶺に雪の積っている山を眺めたりして、気儘に暮すばかりでありました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その海こそは、生きているあいだはこの男に食べ物を与え、いまは、死んでから後の安息を与えるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに人間の安息日があります。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一日は、僕たち二人の安息日だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐら／＼と身体に地震が揺れると急な闇は足を掬ってわたしは絶対の安息のようなところへひょな／＼と萎れ込む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店や料理店の軽薄なハイカラさとちがうこのようなしみじみとした、落着いた、ややこしい情緒をみると、私は現代の目まぐるしい猥雑さに魂の拠り所を失ったこれ等の若いインテリ達が、たとえ一時的にしろ、ここを魂の安息所として何もかも忘れて、舌の焼けそうな、熱い白味噌の汁に啜りついているのではないかと思った。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に考えるならば、そのような下手ものに魂の安息所を求めなければならぬところに現代のインテリの悲しさがあり且つ大阪のそこはかとなき愉しさがあるといえばいえるであろう。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなゆかし、ロレンゾか、鐘鳴らし、まめやかに安息の日を祝ぐは、あな楽し、真白なる羽をそろへ鴿のごと歌はまし、わが子らよ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾れに従う人々の安息の地を求むべく、燦たる北斗星の光を心あてに、沙漠をうれいさまようた鼻がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日にして、安息日。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の午後、ベーカー街に行っている間の、俺の安息している姿さ」「それはまたどうしたことなの？",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは聖徒らの安息地が見下ろせた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其時彼等は永久に夜の様な安息の前にあるのであった。",
              "citation": {
                "source": "晩餐",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は、すべてをさとつてるやうに、只夜だけの我に安息を與へて呉れと願ふやうに、朝になれば誰の手にもよろこんで、小さな可愛い手を出した。",
              "citation": {
                "source": "珠",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意深い人なら、毎安息日の朝の八時ごろから十時ごろまでの町の妙にひっそりした様子に気のつかぬはずはない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし市の近辺が週日にさえこんなに混んでいるとすれば、安息日にはどんなにそれがひどいことか！",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼も夜も私はもう安息の恩恵というものを知らなくなった！",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくヨブは人間の弱く、はかなく、汚れおる事を説きし後「その日既に定まり、その月の数汝により、汝これが区域を立てて越えざらしめ給うなれば、これに目を離して安息を得させ、これをして傭人のその日を楽しむが如くならしめ給え」と訴えている。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は絶望中の僅の安息を希ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
