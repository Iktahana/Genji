[
  {
    "uuid": "fcd29d10-1434-5d78-a7cf-cddb67aaba75",
    "entry": "アーク",
    "reading": {
      "primary": "アーク",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
