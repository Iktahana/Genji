    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arc",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アークについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アークという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアークの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアークが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アークを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアークについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アークの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアークの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアークが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アークという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアークという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアークについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アークを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアークは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アークについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアークが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアークは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアークの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アークは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアークは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "円筒の外線には小さいアーク灯があって強い一条の光線を送り、写真の膜を通じて筒中のセレニウムを照らす。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近頃マルコニ氏はアーク灯などは用いず従来の火花式を少し変更すれば容易に規則正しい波を生ずる事を発明したと伝えられる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来電気の応用が盛んになるにつれて色々の事に炭を使う、白熱電灯の細い線も炭、アーク灯の中の光る棒も炭である、電話機の受話口の中の最も要用なものは炭でこしらえた丸薬のようなものである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛岡の電燈は微かにゆらいでねむさうにならび只公園のアーク燈だけ高い処でそらぞらしい気焔の波を上げてゐる。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暗い丸の内の闇の中のところどころに高くそびえたアーク燈が燦爛たる紫色の光を出してまたたいていたような気がする。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川端にはアーク燈が煌めき、涼み客の往来は絶ゆる間もない。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈に弾ね返される夜の蝉のように私の魂は滑り落ちてはにじむような声で鳴くようです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園にはアーク・ライトがともった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　娘は白々とアーク・ライトに濡れながら、不意に泪ぐんだ。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈の光は強いけれど、それで新聞は讀みづらい。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈に弾ね返される夜の蝉のやうに私の魂は滑り落ちてはにじむやうな声で鳴くやうです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、アーク燈のような薄い紫の空気の、遠くは重い匂いの紫となる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してまた公園の昼のアーク燈を、白昼のシネマトグラフの瞬き、或は薄い面紗のかげに仄かに霞む人妻の愁はしい春の素顔を。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくばアーク燈の眩ぶしい光のかげにあるかなきかに飛ぶ夜の蛍の燐光を闇の夜のそれよりも更に哀れぶかくやるせないものに感じなければならないのである。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏、夏、夏の薄暮は何時もアーク燈の光のやうに薄紫の涙に濡れ潤つたやるせない寂しい微光の氛囲気を私の心の周囲にかたちづくる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧、霧、濃密な深い麻酔の雰囲気に新鮮な瓦斯が光り、電燈がぼやけ、アーク燈が濡れた果実のやうに香気を放ち、葉柳のかげに、舗石に、店々の飾窓に、さまざまの光沢と陰影とが入り乱れて息づかひ深く霧が愈ふりそそぐ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底に整然、雑然と並んでいる青白いアーク燈の瞬きが、さながらに興国日本の、冷静な精神を象徴しているようで、何ともいえず物凄い。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりか、次の金曜日にはきつとですよ、」「好いんです、」五　すこし風があつて青葉がアーク燈の面を撫でてゐる宵の口であつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「薄紫きのアーク灯！",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜船へ帰って、甲板でリモナーデを飲みながら桟橋を見ていると、そこに立っているアーク燈が妙なチラチラした青い光と煙を出している。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが急にパッと消えると同時に外のアーク燈も皆一度に消えてまっ暗になった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼつぼつ点いたアーク燈の光に嫩葉の動いているのが見えていた。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來を隔てゝ高くアーク燈が立つて居る。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈の傍に大きな柳が一株すつと立つて枝を垂れて居る。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈の光を翳して見る闇い空は天鵞絨の如く滑かに見える。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈の光を一杯に下から反射する花簪は柱の蔭に居た太夫のよりも立派に見えた。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀からすつくり立つたアーク燈の丸いホヤが白く冷た相に見える。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
