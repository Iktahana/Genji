        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "旅順の城はほろぶともほろびずとても何事か君知るべきやあきびとの家のおきてになかりけり君死にたまふことなかれ××××××は戦ひに××××からは出でまさねかたみに人の血を流し獣の道に死ねよとは死ぬるを人のほまれとは　勝手に数行を引いたのであるが、××は筆者がした。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の上にはみかんの皮やビールのあきびんなどが浮いたり沈んだりして音楽に調子を合わせていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らはよくこれらの小さな虫をつかまえて白粉のあきびんへ入れたりした。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺の街のあきびとの旧家をほこるあるじにて親の名を継ぐ君なれば、君死にたまふことなかれ、旅順の城はほろぶとも、ほろびずとても、何事ぞ、君は知らじな、あきびとの家のおきてに無かりけり。",
              "citation": {
                "source": "恋衣",
                "author": "山川登美子・増田雅子・與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺の街のあきびとの老舗を誇るあるじにて、親の名を継ぐ君なれば、君死にたまふことなかれ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順の城はほろぶとも、ほろびずとても、何事ぞ、君は知らじな、あきびとの家の習ひに無きことを。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今度は常識という平凡きわまる悪魔めが私の耳のそばで、おまえが今見たのは日曜日の晴着を着た金持の菓子屋のおかみさんが、薔薇香水か何かをこしらえるために使ったあきびんを窓の張り出しに置いただけのことだとささやき始めた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲穂又は紙にて作りたる金銭、縮あきびとなどはちゞみのひな形を紙にて作り、農家にては木をけづりて鍬鋤のたぐひ農具を小さく作りてもちばなの枝にかくる。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしいれには、木箱や、あきびんなどが、ゴタゴタいれてあって、それが、だれかに、ふみあらされたように、ころがったり、われたりしているのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
