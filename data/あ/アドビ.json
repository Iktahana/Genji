        "examples": {
          "standard": [
            {
              "text": "私は毎日アドビについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドビという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドビの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドビが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドビを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドビについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドビの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドビの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドビが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドビという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドビという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドビについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドビを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドビは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドビについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドビが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドビは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドビの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドビは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドビは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アドビシステムズという会社を起こしたのは、コンピューターグラフィックスの分野で業績を積み重ねてきた、ジョン・ワーノックです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二年十二月にアドビシステムズを設立した時点では、ポストスクリプトと名付けたこの言語をどう売っていくか、方針は固まっていませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一九八五年一月のレーザーライタの発表に合わせて、アドビは組版システムの専業メーカーであるライノタイプ・ヘル社と共同で、ポストスクリプトに対応した印刷用機器をお披露目します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "写植機メーカーのモリサワはアドビと提携し、自分たちの持っている漢字フォントを、ポストスクリプトで使えるようにする作業の追い込みにかかっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストスクリプトを世に出したアドビシステムズは、これを発展させた技術を電子出版の切り札にしようと大攻勢をかけています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりを払うようなアドビの勢いに、迫力の面では及ばないかもしれませんが、ボイジャーも立ち止まってはいません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでポストスクリプトの開発元のアドビ社が高いことを言って一もめあったが、欧米の市場に関してはやはりこれで蹴りがつく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドビ社のアクロバットという技術を使うと、しっかりレイアウトした文書がインターネットでやりとりできる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像してごらん、レディ・クララ・ビアドビアの欧州一高名な宝石が鉛ガラスだと分かったら。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
