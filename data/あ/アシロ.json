        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は高飛車に人をこなし付ける手を覚え、軽蔑して鼻であしろう手を覚えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち、愛の表現の方針を見失っているのだから、あれもいけない、これもいけない、と言わずに、こうしろ、ああしろ、と強い力で言いつけてくれたら、私たち、みんな、そのとおりにする。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助太刀共に三人共、相当の剣客と見えたのを、羽織も脱がぬ雪駄穿のままあしろうて、やがて一刀の下に斬棄てたまま、悠々と立去る程の御仁のお名前が、江戸市中に聞こえておらぬ筈はないと申しましてな……」「ハハハ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に左にノラリクラリと、どんな文句を唄うて、どんな三味線をあしろうて行ったやら。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば見習いの格で、古参の人たちのあとに付いて、ああしろこうしろのお指図次第に、尻ッ端折で駈けずり廻っていたんですから、時には泣くような事もありましたよ」　　　　　三　徳次に連れられて、半七が日本橋へ出て行ったのは、八月八日の朝であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が今度の七三郎に対しては、才牛をあしろうたようには行かなかった。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈なればこそあしろうたのじゃ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟から見れば、その事業の總括者たる兄の義雄から、渠の出發後は代理となつてああしろかうしろと命令されてゐるので、この兄弟に信用を失つてゐる從兄弟の怪しい行爲は充分注意して、さうさせない樣にしなければならない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代の自白の如く、何人とも知れぬ男が、ああしろこうしろと命令したにちがいない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、お願いだから、こうしろとか、ああしろとか、何とか言ってくれない。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分から唯もう他人様の為に働いて他人様がああしろと言われればその様にし、今度はそれがいけないと言って、身近の人からそむいて行かれ、やっとみんなが帰って来たと思ったら、何も彼もめちゃめちゃにされてしまい、自分て言う者が一体どこにあるんだか……。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたにだつて、ああしろかうしろつていふことはできないかも知れないけど、とにかく、力をつけてよ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの息子は、親たちがなんと云はうが、縦のものを横にもしない息子ですのに、矢代の小母さんがかうしろつておつしやつた、ああしろつておつしやつた――と、まるでどうかしてますのよ」　なかには、こんなことを云ふ細君もゐた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――読者や私なぞがこうしろああしろと命ずるまでもなく、ちゃんと自分のやるべきことを心得ていると云う手合ですよ！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてお殿様のご乱行の、基はと云えば鳰鳥からじゃ、何んでも鳰鳥めがお側から、ああしろこうしろとお殿様を指図するとかいうことじゃ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は正二郎を早く起して、ああしろ、こうしろと指図をすますと、お米とお源はフトンをひッかぶっておそくまで寝ている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様の前でございますが、私達にでもああしろかうしろツて、旦那様よりか、いつそ威張つてるんでございますもの。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論「こうしろ」とか「ああしろ」とかいう規則は拵えない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたくしは十年も十五年も夫がああしろ、かうしろといふ中で寢つづけて來たんですもの。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "口には、歯もあり舌もあり……甘いも酸いもかみわけて、浮世の風のつめたさも、人の情のあついも知って、この舌三寸であしろうて、みんなのみこむわたしの手練。",
              "citation": {
                "source": "狂言『食道楽』",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの身仕度にも、ああしろこうしろと世話をやき、自分で買って来た新しい草鞋をぼくの足へ穿かせてくれた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おるいさんが采配を振るといったが、彼女は亭主や娘たちに向って、ああしろのこうしろのとしいるようなことは決して云わないし、自分が誰よりもよくはたらいた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それには、能登を怒らせず、上手にあしろうて行かねばならぬ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
