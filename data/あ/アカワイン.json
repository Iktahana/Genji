        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "最近、フォーゲル氏は赤ワインで外来性の色を検出するためのテストとして酢酸鉛を推奨している。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "コケモモ（Vaccinium Mirtillus=bilberries）、ニワトコ（elderberries）、ログウッド（Campeach wood）のようにワインに色をつける物質のどれも、このテストにより真の赤ワインで得られる色である緑っぽく灰色の沈殿を生じないからであると彼は言っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ワインの発色物質はブドウの外皮にあるのでフォーゲル氏は大量のブドウの外皮を集めて粉にした。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォーゲル氏は彼の実験のために黒ブドウからかなりの量の赤ワインを作った。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャトー・マルゴーおよびコブレンツの近くからの疑いなく真正な２種類の赤ワインから、彼はまた同じ色のついた沈殿を見つけた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは赤ワインと呼ばれる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って赤ワインはしばしば赤ブドウから作られ、ワインは赤色になる前に取り出される。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒性は弱いし、必須元素であるが、サプリメントや鉄剤の取り過ぎ、鉄鍋の使用、鉄分の多い赤ワインやビールの飲酒、などを原因とする鉄蓄積症が知られている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば二か月以内に東女帝丸をドラガルド川の河口に曳航しますから、あとはお好きなように」　大使があわてて赤ワインをもう一杯飲みほした。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ワインは生命物質である血液の色をしているので生命のシンボルになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレアカラのスロープにあるテデシ・ワイナリーにとっての、最初の赤ワインだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この赤ワインのことを、姉は言っている。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなくアフリカを感じさせるような気もする」「Ｕの字が三つもあるからでしょう」　姉の指摘の正しさに感心する気持ちとともに、僕はワイン・グラスのなかの赤ワインを飲んだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きわめて好ましい赤ワインだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブフアラモードとは赤ワインでマリネした牛肉の蒸し煮。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、赤ワインを愛飲して大酒飲みになった人は、白ワインを飲んだときでも、ほとんど同じく耽溺するであろう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェスタトンはフランスに長期滞在したことはなく、所詮、彼が描き出すものは――赤ワインのグラスを手に日がな一日「マルセイエーズ」を歌い続ける小作農の地といったところ――バグダッドの日常生活に対する「チュー・チン・チョウ」程度のリアリティしか持ち合わせていなかった。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、これを最後に行く前にもう一度楽しい食事をしたいし、見おさめに赤ワインを拝みたいですな。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂のまぶしい明かりがきらきら照らし出しているのは、古い銀器やら超高価なグラス、山盛りの花々、それにボヘミヤン・グラスに注がれた赤ワインであった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、サンドイッチと赤ワインを飲んで、昔話をしましょう」　とバーニ先生がニタニタ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがバーニ先生はサンドイッチをほおばり、赤ワインや水をすすり、昔話に触れない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を見れば、スライトが注いでいる赤ワインの出来に不平を言っている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ワインをひったくり、続けて二杯飲み干した。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラルフは赤ワインも、渡された葉巻も断った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "七四番の赤ワインはどうでしょうか。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽光がステンドグラスを通して差し込み、銀器やグラスや、赤ワインやシャンパンの金箔を照らしていた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に慎重にページを調べていくと、茶色の染みが見つかり、赤ワインをこぼした跡のようだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ある晩の夕食後、叔父と二人で煙草とお酒を飲んでいるとき、うっかり赤ワインをページにこぼしたことだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフがなければ今頃こうして素晴らしい赤ワインの香りを楽しんではおりません。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
