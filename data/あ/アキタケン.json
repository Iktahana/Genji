          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三昼夜かかって、やっと秋田県の東能代までたどりつき、そこから五能線に乗り換えて、少しほっとした。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは、八｜月七｜日の午後、秋田県鹿角郡、生出を駕籠で上つて……これから三｜瀧街道を大湯温泉まで、自動車で一｜気に衝かうとする、発荷峠、見返茶屋を、……なごりの湖から、向つて右に見た、三岐の一｜場面である。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前九年後三年の役だつて、舞台は今の岩手県・秋田県であつて、安倍氏清原氏などの所謂｜熟蝦夷が活躍するばかりで、都加留などといふ奥地の純粋の蝦夷の動静に就いては、私たちの教科書には少しも記されてゐなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一二（明治四十五）年　この頃、秋田県に住む伯母のもとに一〜二年間引き取られ、養育を受ける。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県からも斯の如きものを産する由、複輝石安山岩だそうな）僅々二三町に過ぎぬのだから、大したものではない。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、私は秋田県の石川理紀之助翁の遺跡を訪ねて、無限の感にうたれた。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他は青森県でも秋田県でも同様ウソトキで通っております。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）秋田県北秋田郡荒瀬村地方に残っている口碑。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からほぼ十年ほど前に、慶応の国文科をで、葛西善蔵、宇野浩二らに私淑し、現在では秋田県の女学校教師であるこの作家の特徴は、非常に色彩のつよい、芝居絵のような太い線で、ある意味での誇張とげてものの味をふりまきながら、身振り大きく泣き笑いの人生を描くところにある。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人（秋田県｜樺園子）曰く、万葉の歌は十中八、九まで世道人心に関係あれば善し。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　秋田県小坂鉱山の私の実家でした。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、今度来る番楽の先の候補――今春日本青年館に来た秋田県｜西馬音内の近く――田代にも番楽があるので、此が来なくなつて荒瀬のが来る事になつた。",
              "citation": {
                "source": "根子の番楽・金砂の田楽",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、雄勝・院内を越えて、秋田県の鷹の湯に一夜、引き還して新庄から肱折に這入って一晩を泊りに出かけても見た。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "校歌といふのは、秋田県｜角館中学校の校歌を平福百穂画伯から嘱付して赤彦君に作つて貰ふことになつてゐた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この塩辛煮に用ゆる塩辛は秋田県新屋産を良しとすという。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等品は、台湾海峡でとれたもの、三等品は秋田県地先の日本海でとれたものである。",
              "citation": {
                "source": "蜻蛉返り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾海峡を通過するのは、中支方面の広い海に数多く棲んでいる鰡が、大群をなしてバシー海峡をへて南太平洋の方へ行くのではないかといわれているし、秋田県地先を通るのは日本海の奥や、オホーツク海の方から、くるらしいというのだ。",
              "citation": {
                "source": "蜻蛉返り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県地方の人々は、姫｜柚子などよりも大きい源五郎虫を、強精剤として貪り食うというから、ザザ虫や川百足など、姿の小さいものは恐るるに足るまいと思うが、理屈は抜きにして、ちょっと手が出ないのだ。",
              "citation": {
                "source": "ザザ虫の佃煮",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から奥利根へは、出羽の熊捕り専門猟師が、越後の駒ヶ岳、八海山、牛ヶ岳などをへて入り込んできたのであるから、私は山形県や秋田県の山々が、熊の本場であろうと考えて、一度本場の熊の肉を賞味したいと希望していたところ、今回はからずも友人からの贈りものを得て出羽と越後の国境でとれた熊の肉を、たんのうした。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋田犬というものは大型だけを指すものであるが、これはやや絶滅に瀕していて、秋田県でも大館市という一地域にしか見られない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「要するに秋田県でも大館市だけなんですよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこ以外には秋田県でも秋田犬は見られないのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ式の農家は秋田県にも少くないが、二階に張りだし窓のような独特のフクラミをもった藁屋根の中農家が目立つので、新潟県の農村ほど寒々した感じがない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県の山村で、車窓から見た小学校の建物などは、爆撃直後の半壊の小学校よりも甚しく、正視に堪えないものがあった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども秋田県の全体が、あそこも、ここも、みんなあの人を育てた風土のようにしか思われない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦に於ける巡回書庫は、余等、さきにこれを秋田県に試み、今日、これを本県に施設せるのみなれば、これが成績としては、徴すべきもの多からざれども、これを米国に見るに、巡回書庫は、町村図書館の先駆として、随処に歓迎せられつつあるなり。",
              "citation": {
                "source": "巡回書庫と町村図書館と",
                "author": "佐野友三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先年秋田県の花輪町でそれを染めさせた事があった。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも染める紺屋が偶には無いでもないので、私は以前これを秋田県の花輪町で染めさせた事があった。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツバキは暖い処にばかり在るかと思うと決してそうばかりとも限らなく、我邦の北へ行けば青森県にも秋田県にもあって自生している。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県で私の見たのはかなり高い山地に育っていた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
