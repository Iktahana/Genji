          ],
          "literary": [
            {
              "text": "こういう無意識の口移りは付け句には警戒されたのが三句目四句目にうっかり頭をもたげる例も少なくない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が初対面の挨拶をしたら、頭をもたげるようにして、うなずいて見せた。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まる一月その外科の病院に寝たきりで、頭をもたげることさえようようであった。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと強いものを求めるいまわしい不貞が頭をもたげることさえあって、私は悪者でございます。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をもたげると枕もとに、真白い角封筒が一通きちんと置かれてあった。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、片腕でも水から上げれば、そのためにそれだけの支持を失って、重さを加えて頭全体が水にひたってしまうし、またちょうどよく、ごく小さな木片の助けでもあれば、あたりを見渡せるくらい頭をもたげることができるだろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後はそれまでベッドの上に仰向けに寝て、軽く眼を閉じていたのだが、「オルレアンの少女」の合唱がはじまったら眼をひらいて、こころもち枕から頭をもたげるようにして耳を澄まし、やがてまたぐったりとなって眼をつぶって、ああ、眼をつぶったまま、とても悲しそうに幽かに笑った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで後腰部に鈍重な疼みがむくむくと頭をもたげるのを覚えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく覚えられたじゃん」　慶一の心のなかで、コンプレクスが頭をもたげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "可なりぬきさしもあつたやうですが、あんなに馬鹿気た、いやな私が頭をもたげるのです。",
              "citation": {
                "source": "九州より",
                "author": "――生田花世氏に",
                "note": "青空文庫"
              }
            },
            {
              "text": "事前に方針を明かすことで抵抗の芽が頭をもたげることを恐れた大内は、機構改革の方針を支配人の渡辺和也にも伏せ、この一件に関しては発表の直前になって言い渡す形をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やがて少しづつ頭をもたげると、相手の顔をまじまじと穴のあくほど眺めた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもう、しまいには死の手に押さえつけられてしまって、わずかに首と、弱った頭をもたげるにすぎなくなってしまうのです。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていると、ぬッと頭をもたげる昔の切り口上であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も私の心のなかに頭をもたげる心の芽をいたずらにみずから蹂躙するいわれもないのです。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びヤマ気が頭をもたげる。",
              "citation": {
                "source": "波子",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで勢ひ、頭をもたげるのが、演劇の実際運動だ。",
              "citation": {
                "source": "劇壇左右展望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲壮な善行慾が頭をもたげる。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久美さんは引きしまった顔をうつむけて乾いた土を見て居たが、いきなり頭をもたげると、「大馬鹿よ！",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この精神の状態が、慢性疾患の如く、日常の生活のなかで、時をきらはず頭をもたげるとすれば、これを精神的畸形と名づけるよりほかはないではないか。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は若いころ、学生として自然哲学を勉強して、その講義にも出席しているが、中途から乱暴を始めて、世に出る機会をうしなって、次第に零落して、ついにふたたび頭をもたげることが出来なくなった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "信号手",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、世界大戦以来、わが国一般の経済事情ならびに社会思潮に大変動を生じたため、突如として「法」と「人間」との間に一大溝渠が開かれることになり、ここに先の自由法思想は再びその頭をもたげる機会を見出しました。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとそこで手間どつて――少年の胸には、またしてもあの危懼と不安が、頭をもたげる。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をもたげると、戸口を半ば塞ぐような位置にプリムスの後部が見えた……湖水の分れ道で久美子が拾われた、れいの大池の車だった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそれについての熟練を有し、また多くの仲間とおなじくそれに対する一種の本能をもってそれが時々頭をもたげる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ夢なら、その夢を一番有効に享楽してやろうと言った横着気が頭をもたげると、もう屋敷の名やこの私の名を訊ねて、女中を困惑させることは思い止まってしまったのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ」　絢子は、犬歯のめにたつ口もとを引しめてうつむいていたが、その頭をもたげるなり、「あすこに、女人とありましたでしょう。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は枕の上から頭をもたげるようにして、そのひとの方を見た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然また頭をもたげると、言った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "事物とのもっとも微細な接触だけで、風にもたらされる花粉だけで、すでに内部の萌芽は、無数の萌芽は、頭をもたげる……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
