          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿弥陀について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿弥陀の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿弥陀が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿弥陀について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿弥陀の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿弥陀が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿弥陀という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿弥陀についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿弥陀は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿弥陀が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿弥陀は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿弥陀の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿弥陀は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿弥陀は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "森の中でつくつくほうしがゆるやかに鳴いて、日陰だから人が蝙蝠傘を阿弥陀にさしてゆる／＼あるく。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の方は子供の帽子を気にして直しているが、子供はまたすぐに阿弥陀にしゃくり上げる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無阿弥陀仏」と、丈夫な誰かが云ったようだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は阿弥陀様におすがり申して救うて頂く外に助かる道はない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無阿弥陀仏、南無阿弥陀仏」　僕は懐にあった紙の有りたけを力杖に結ぶ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教では彼岸の中日｜時正の日で、一切の諸仏三世の諸尊および無数万億菩薩説法して衆生に楽しみを与うというので春分の時と同様｜阿弥陀詣などをする。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山高帽を少し阿弥陀に冠った中年の肥大った男などが大きな葉巻をくわえて車掌台に凭れている姿は、その頃のベルリン風俗画の一景であった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああさっきのお百姓がものの間違でも故道には蛇がこうといってくれたら、地獄へ落ちても来なかったにと照りつけられて、涙が流れた、南無阿弥陀仏、今でもぞっとする。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と折から唸るように老人が唱えると、婆娘は押冠せて、「南無阿弥陀仏。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした門構えを入ると、本堂の阿弥陀様と背中合わせの板敷土間に破れ畳の二畳敷、竹瓦葺の板廂、ガタガタ雨戸に破れ障子の三方仕切は、さながらに村芝居の道具立をそのまま。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すたれ釘世をすぢかいになり下る　　　　　　　　底抜け徳利のチリンカラカラ古釘と底抜け徳利の風鈴は　　　　　　　　　　阿弥陀も知らぬ極楽の音　その蒲鉾板の裏表を手に取って引っくり返して見ながらニッコリと笑った良助は、その前の雨戸をガタガタと叩いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無阿弥陀仏と言いたくなるその妖気……その虚無世界……その中にさまよう実さんの芸的ルンペンぶり。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍔広の藁帽を阿弥陀に冠ってあちら向いて左の手で欄の横木を押さえている。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かの句に、身を捨ててまた身を掬ふ貝杓子　他力信仰（他力信仰は浄土宗、浄土真宗の信仰の仕方で、阿弥陀仏のさしのべる手〔本願〕に救われる信仰生活です）のこつをいったものであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時唱える「南無」（「南無阿弥陀仏」を現代語にいい換えれば「光明と叡知よ、今、我に来れ」）は、この時に適した行進曲ともいい換えられます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀如来といい、観世音菩薩というものも、実はこの働き（宇宙の大生命が「道」を私たちに覚らしめようとする働き）を指して名づけたものに過ぎません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お千世は、薄気味悪そうに、お孝の袂に掴まりながら、直ぐ目の前なを、爪立って覗くように、と見ると、比羅紙の、およそ二枚｜凧ぐらいな大きさの真中にぼつりぼつりと筆太に、南無阿弥陀仏、と書いたのが、じめじめとして、さながら、水から這上った流灌頂のごとく、朦朧として陰気に見える。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云う、南無阿弥陀仏の両傍に、あいあい傘の楽書のように、（となえろとなえろとなえろとなえろ、）と蛞蝓のごとくのたくり廻る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、南無阿弥陀仏、南無阿弥陀仏。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は阿弥陀仏の化身親鸞僧正によって啓示されたる本願寺派の信徒である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ遥かにかの西方の覚者救済者阿弥陀仏に帰してこの矛盾の世界を離るべきである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをふびんぢや気の毒ぢやと思召して、罪業の深い我々凡夫をお救ひ下さると云ふのが阿弥陀如来の本願ぢや。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀様のお力にすがりさへすれば、死んで極楽へ行かれる。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいはい南無阿弥陀仏。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と反って飛退り、下駄を脱ぎて、手に持ちはしたれども、腰の骨の蝶番がっくり弛みてただの一足も歩かれず、くしゃりと土下座して、へたへたになり、衣服をすっぽりと引被りて、南無阿弥陀仏南無阿弥陀仏。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無阿弥陀仏南無阿弥陀仏。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帽子をあみだにかぶっても気になるし、まぶかにかぶっても落ちつかないし、ひと思いに脱いでみてもいよいよ変だという場合、ひとはどこで位置の定着を得るかというような自意識過剰の統一の問題などに対しても、この小説は碁盤のうえに置かれた碁石のような涼しい解決を与えている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、おばさんは吐息をして、なむあみだぶを唱えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪狼のうしろから白熊の毛皮の三角｜帽子をあみだにかぶり、顔を苹果のようにかがやかしながら、雪童子がゆっくり歩いて来ました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪狼のうしろから白熊の毛皮の三角帽子をあみだにかぶり、顔を苹果のやうにかがやかしながら、雪童子がゆつくり歩いて来ました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
