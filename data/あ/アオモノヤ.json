        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アナトール・フランスのかいたクランクビュという青物屋と同じ待遇を彼等は世間から受けなければならんのだ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の末に母子はわづかばかりの手※りの荷物をまとめ、その家を出て、下谷初音町のある青物屋の二階に引越して行つた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物屋の二階へ移つて少しおちつくと、順吉はかつて彼が嫌惡の念をこめて輕蔑した小説家の高山や、學者の杉村を訪ねた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋や青物屋の賑やかな店に交って、商売柄でか、綺麗に障子を張った表具屋の、ひっそりした家もある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れのみならず、現在の大連には、肴屋、大工、畳屋、瓦職、左官、下駄屋、青物屋、花屋、人力車夫、馬車屋、下男、女中、給仕等の職業が悉く支那人に占められてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、葬式と通り合し、車は橋袂の青物屋の前に止つた。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は青物屋である、市場の荷が未だ着かぬと見えて、店はヒツソリ寂れて居る。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物屋の葱は日に光つた。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物屋は、野菜の車を停めて手を上げ、その野菜の山の上から、青物屋の伜が手を上げ、軒並みの商店からは、主人と店員が走り出て手を上げ、そして、電車の窓からも自動車の中からも、何本となく手が上がっている。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "拠所なく西黒門町の青物屋八百春へ奉公にだしてやった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヲヤ　栽培する蔬菜にも青物といふ名を延長し、之を鬻ぐ店を青物屋といふことは、東日本一般の風であつたが、東京などはいつの間にか之をヤホヤといふやうになつた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アオヤ　栽培する蔬菜にも青物という名を延長し、これを鬻ぐ店を青物屋ということは、東日本一般の風であったが、東京などはいつの間にかこれをヤオヤというようになった。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな青物屋の店先で、いくらかの果物――いちごの熟しすぎたやわらかなのを買って、歩きながらそれをたべた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、御主人、日曜にロンドン見物に来た田舎者の帽子じゃああるまいし、青物屋の正札が入れ違ってるなあ、一体どうした訳なんです？",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは下の町の青物屋へ買ひにゆくことにしたが伯母さんはなにの苗を見ても瓢箪ぢやないかと疑つて、もし生えてから瓢箪がなつたら瓢箪の木を返しにくるがいいかと　いつて青物屋をきめつけた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その付近には、小さな商店が、かたまっていましたが、小西の家は、その中の青物屋でありました。",
              "citation": {
                "source": "眼鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてふたりは、モンパルナスがやってきたサン・タントアーヌ街の方へ向かって、その時分市場の方へ行く青物屋の長い車の列の間を右左にぬけて、急いで進んでいった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく似た男　青物屋とか酒屋とか、ちょっと其処らへ小買物に出るのでも、彼女は身綺麗な躾みを怠らなかった。",
              "citation": {
                "source": "死んだ千鳥",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『じゃあ、すぐ届けておくれ』　酒屋でも青物屋でも、彼女が鷹揚にそういえば、何処でも、『へい、すぐお後からお届けいたします』　嫌な顔をする店はなかった。",
              "citation": {
                "source": "死んだ千鳥",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋や青物屋へ届け物を吩咐けておいて、家の方へ戻って来ると、露地の曲がり角に、一人の武士が佇んでいる。",
              "citation": {
                "source": "死んだ千鳥",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
