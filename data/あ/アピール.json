    },
    "definitions": [
      {
        "index": 1,
        "gloss": "appeal (e.g. for peace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アピールについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアピールは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アピールの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアピールについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アピールは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアピールの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アピールに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアピールが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアピールを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アピールの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアピールが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアピールが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アピールについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアピールは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアピールは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアピールは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアピールについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アピールの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアピールの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアピールの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こった動画や音が使えるようになると、電子出版物のほとんどは、こうしたマルチメディアの特長をアピールするようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならここで『パソコン創世記』を両方で読めるように作りなおし、作成ツールの対応に合わせて、エキスパンドブックの世界がウインドウズに広がったことをアピールしていこうとなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題設定の切れ味の良さ、訴えたいポイントはどんな荒業を駆使してもアピールしようとする誠実な臆面のなさはほとんど桂枝雀の落語を思わせるものがあり、オレは氏を内心でトッテン師匠と呼ばさせていただいている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ヒロイズムについての私たちの考え方、意思の強固さや死をも厭わぬことは日本の若者には容易にはアピールしないということを思い出すべきであった。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肝心のアップル※自体も、家庭用テレビに六色を使ったカラーの図形を表示し、大いに観客にアピールしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイコン販売部のスタッフはショーに備え、当時としては驚異的だった八色のカラー表示能力をアピールしたデモンストレーションプログラムを用意していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビ画面上に表示された色あざやかな三次元図形、マンガの人気キャラクター「まことちゃん」の以顔絵も、巧みな色の使用によって観客に大いにアピールした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは政治行動の手段としては、うたの持つ連帯促進の働きや、そのアピールするものを推し出すことによって目的を達するかもしれないが、うたの側から言った場合それは非常に危険なことなのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＩＢＭがパソコン市場への参入を狙って打ち出してきた機械では、まず大型コンピューターの端末として使える、要するにシステムに奉仕できるという点が、他機種との差別化のポイントとしてアピールされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトが会社としての体裁を整えはじめた一九七七年の四月、サンフランシスコで開かれた第一回のＷＣＣＦは、パーソナルコンピューター自体もまた、マシンとしての体裁を整えはじめたことを強烈にアピールする場となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホワールウインドは二五〇〇平方フィートを占有してしまうような巨大なマシンだったが、これと同じアーキテクチャーを持つものを、オールセンはごく小さく作ることで腕をアピールしたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにマシンの出荷が本格化した十一月の末段階では、もう一〇〇種類の対応アプリケーションをそろえ、つごう一六〇本を押し立てて新一六ビット機をアピールする作戦を早水は練った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気で明るい印象を与えるウォズニアックだったが、押し出しの強くない彼は、自分の作り上げたものの価値を大声でアピールするようなことは苦手だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラブでの発表に際して、ウォズニアックはアップル※の技術的なアウトラインを説明し、ジョブズはたった一枚の基板に収まったコンパクトさとテレビ画面に表示が出せるというマシンの特長のアピールに努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳ対応のＧＵＩベースのワードプロセッサーなら、間違いなく特長をアピールできる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは国外へのアピールとしてクロポトキンの書いたものだが、その序文はこういう言葉ではじまっている。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は夫人に強くアピール出来るに違いないと思って、出し抜けに情熱的に言ってみた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにおいて彼女は見栄を張れば自分の情熱の勝利をアピールするくらいのことは出来たであろうけれど、それを拒否した。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロツキズムを研究するには、畢竟一つの思想を産んだに過ぎぬトロツキー自身の著作よりも、胡乱なビラや「ソーシャリスト・アピール」といった新聞の方がふさわしい。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
