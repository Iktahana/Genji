        "examples": {
          "standard": [
            {
              "text": "私は毎日アワーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アワーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアワーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアワーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アワーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアワーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アワーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアワーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアワーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アワーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアワーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアワーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アワーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアワーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アワーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアワーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアワーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアワーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アワーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアワーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしこのような訓練が実際上現在のこの東京市民にいかに困難であろうかという事は、試みにラッシュアワーの電車の乗降に際する現象を注意して見ていても直ちに理解されるであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーチアワールでは城を築いたり塔が傾いたり池を掘るも水が溜らぬ時人を牲にした。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまじゃなくて、もっと遅くなってからだ」「ミドナイト・アワーか」「それくらい、知ってるぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はかねて我同胞の人相、特に生死不明の眼付に就いては我事ながら悲哀に感じ、多くの忿懣を懐いてゐるが、試みに毎朝のラッシュ・アワー、これから一日の勤めに出掛けようとする人々が押しあひへしあひしてゐる満員電車に乗つてみれば、この悲しみは忽ち納得ゆく筈である。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄な金髪小悪魔で、ブラジル社提供のヤーバ・マテ・アワーに出ている。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電子本「エキスパンドブック」のコンテンツをネット上に増やしていく――これは、読書の形を変えるパイオニアワークになるんじゃないか。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を精読して、煙草を吸って、魔法ビンのお茶を空っぽにして、ラッシュ・アワーの殺人的な混雑電車で、郊外の巣に帰る、――こういった、平凡無事な、そして限りなく退屈な日が幾日か続きました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "代作恋文",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、夜が明けてから、朝のラツシユ・アワーになる迄の数時間の表情と来ては、早発性痴ほうよだれだ。",
              "citation": {
                "source": "丸之内点景",
                "author": "‥‥東京の盛り場を巡る‥‥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなると元へ戻つて、だれかの趣味で、ハイアワーサとその画文字のように、自分のひそかな通信を木に書いたのではないかという問題になります」ブラウン神父は上きげんで話を進めた。",
              "citation": {
                "source": "ピンの先き",
                "author": "THE POINT OF A PIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもラッシュ・アワーとかちあってひどい混雑だろうとすこし心配です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "家からごく近いし人数もやたら多くないし、三月からならあたたこうなって丁度よい、というし、ラッシュアワーで又バスがひっくりかえったなどと云うのも楽ではないし、きいてよかった、これにしようということになりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方のラッシュ・アワーはすでに終わりだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッシュ・アワーが終わる時間のターミナル駅で、彼女たちは高原へむかう特急に乗った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通の便は雲泥の差、ラッシュ・アワーの混雑など、その頃の悪道路を思えばずんと我慢もしやすい。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッシュ・アワーの地下鉄のホームのはしに手鞄を放り出すと、ある女はそれにつまずいて線路に転落し、車輪に首をちぎりとられた。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "社のＹ氏、Ｈ氏などと、ラッシュアワーの中で、やっと出会う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
