        "examples": {
          "standard": [
            {
              "text": "私は毎日甘酒について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘酒という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘酒の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘酒が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘酒を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘酒について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘酒の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘酒の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘酒が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酒という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘酒という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘酒についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘酒を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘酒は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酒について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘酒が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘酒は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘酒の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘酒は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘酒は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は馬場と上野公園内の甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水寺のすぐちかくに赤い毛氈を敷いた縁台を二つならべて置いてある小さな甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋の相手というのは逢うのに少しばかり金のかかるたちの女であったから、私は金のないときには、その甘酒屋の縁台に腰をおろし、一杯の甘酒をゆるゆると啜り乍らその菊という女の子を私の恋の相手の代理として眺めて我慢していたものであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの早春に、私はこの甘酒屋で異様な男を見た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、いちど落第したものですから」「はあ、芸術家ですな」にこりともせず、おちついて甘酒をひと口すすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯のよろこびだよ」ぐっと甘酒を呑みほしてから、だしぬけに碾茶の茶碗を私の方へのべてよこした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあしたあたり死ぬかも知れないからね」　それからというもの、私たちはその甘酒屋で実にしばしば落ち合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金は憲坊に頼みました）先づ平野屋のいもぼうの缶詰（ッてのがあるそうです）黒のとろろこぶ、花かつを、懐中じるこ、甘酒の素、なるせの漬物とほーじ茶。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "買はん哉、甘い／＼甘酒の赤行燈、辻に消ゆれば、誰そ、青簾に氣勢あり。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞鍮の茶釜の白鳥、出居の柱に行燈掛けて、燈紅く、おでん燗酒、甘酒もあり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒前には、駄菓子｜店、甘酒の店、飴の湯、水菓子の夜店が並んで、客も集れば、湯女も掛ける。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯が啜る甘酒に、歌の心は見えないが、白い手にむく柿の皮は、染めたささ蟹の糸である。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人々を当込みに甘酒屋が荷をおろしている。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穴釣りの鰻屋も、この柳のかげに寄って来て甘酒などを飲んでいることもあった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷水も甘酒も一杯八厘、その一杯が実に甘露の味であった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人の立ちン坊もここを稼ぎ場とし、氷屋も甘酒屋もここで一日の生計を立てていたのである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は昔と違っているであろうが、氷屋や甘酒屋の店も依然として出ていた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷屋も甘酒屋も影をかくした。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒どころか、その頃の日本の飲食店には、既にコーヒーも甘酒も、何も無くなっていたのである。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は馬場と上野公園内の甘酒屋で知り合つた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水寺のすぐちかくに赤い毛氈を敷いた縁臺を二つならべて置いてある小さな甘酒屋で知り合つた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあひまあひまに大學の裏門から公園へぶらぶら歩いて出ていつて、その甘酒屋にちよいちよい立ち寄つたわけは、その店に十七歳の、菊といふ小柄で利發さうな、眼のすずしい女の子がゐて、それの樣が私の戀の相手によくよく似てゐたからであつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の戀の相手といふのは逢ふのに少しばかり金のかかるたちの女であつたから、私は金のないときには、その甘酒屋の縁臺に腰をおろし、一杯の甘酒をゆるゆると啜り乍らその菊といふ女の子を私の戀の相手の代理として眺めて我慢してゐたものであつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの早春に、私はこの甘酒屋で異樣な男を見た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の局閑にして、赤城の下で鷄が鳴くのをぽかんと聞いて、うつとりとしてゐると、なゝめ下りの坂の下、あまざけやの町の角へ、何と、先生の姿が猛然としてあらはれたらうではないか。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんが御奉公に出たころは、家も富貴だったので、市ヶ谷のあまざけや（有名な呉服店）で、好みで染めさせたものばかりだったが、私は子供心にもこの嫁入りの仲人が変だと思った。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
