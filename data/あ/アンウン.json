    "definitions": [
      {
        "index": 1,
        "gloss": "dark clouds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗雲について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗雲という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗雲の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗雲が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗雲を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗雲について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗雲の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗雲の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗雲が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗雲という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗雲という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗雲についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗雲を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗雲は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗雲について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗雲が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗雲は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗雲の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗雲は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗雲は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "○　今迄かつと照り渡つてゐた初秋の空に僅か飛行船程の暗雲が浮んだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして大団円における池田君の運命の暗雲を地平線上にのぞかせるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗雲低迷する空――（Ｆ・Ｏ）　＝（Ｆ・Ｉ）雨の橋　雨の降って居る河面――　ボヤッと橋の影が映ってる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それなのに夜が来れば蛙は鳴き、その声は水面に走つて暗雲に迫る。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は非職海軍大佐某氏の息、理学士の学位あって、しかも父とともに社会の暗雲に蔽われた、一座の兇星であるものを！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい迷信さ」「あたい、『ビッグ・パレード』だの『ウイングス』で随分教養のある青年達が、ただ兵士募集の触れ太鼓を聞いただけで、理由もわからず暗雲に感動して出征するのを見て、男って野蛮人だなあと思って呆れかえっちゃった」「それで大入満員だから困る。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの細君は今はもう暗雲を一掃されてしまって、そこは女だ、ただもう喜びと安心とを心配の代りに得て、大風の吹いた後の心持で、主客の間の茶盆の位置をちょっと直しながら、軽く頭を下げて、「イエもう、業の上の工夫に惚げていたと解りますれば何のこともございません。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お別れといたしまして、其處らの茶店をあけさせて、茶碗酒をぎうとあふり、其の勢で、暗雲に、とんぼを切つて轉げるまでも、今日の内に麓まで歸ります、とこれから雪の伏家を叩くと、老人夫婦が出迎へて、富藏に仔細を聞くと、お可哀相のいひつゞけ。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は今少なくとも有史以来の『得意』の舞台に大踏歩しつゝあり、と共に又｜未だ嘗て知らざる大恐怖の暗雲を孕み来りつゝあり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの赤き瞼の重げに見ゆるが、泣はらしたるとは風情異り、たとえば炬燵に居眠りたるが、うっとりと覚めしもののごとく涼しき眼の中曇を帯びて、見るに俤晴やかならず、暗雲一帯｜眉宇をかすめて、渠は何をか物思える。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下流の右岸には秀麗な角錘形の山（それは夕暮富士だと後で聞いたが）山の頂辺に細い縦の裂目のある小松色の山が、白い河洲の緩い彎曲線と程よい近景を成して、遥には暗雲の低迷したそれは恐らく驟雨の最中であるであろうところの伊吹山のあたりまでをバックに、ひろびろと霞んだうち展けた平野の青田も眺められた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亜の空にはびこる暗雲の乱れそめては、黄海波荒く、残艦哀れ旅順の水寒き影もさびしき故国の運命に、君は起ちにき、み神の名を呼びて――亡びの暗の叫びの見かへりや、我と我が威に輝やく落日の雲路しばしの勇みを負ふ如く。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の暗雲のような重圧にも拘わらず、外には依然陽が輝き青空には白雲が美しく流れ樹々には小鳥が囀っていることを、彼は十年この方始めて発見したように思った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐の暗雲を孕んで物凄いまでに沈滞した前田鉄工場！",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田弥平氏が思い悩んでいる間に、嵐の暗雲はしだいに近づいてきた。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川は三つの瀬を一つに、どんよりと落合つて、八葉潟の波は、なだらかながら、八つに打つ……星の洲を埋んだ銀河が流れて漂渺たる月界に入らんとする、恰も潟へ出口の処で、その一陣の風に、曇ると見る間に、群りかさなる黒雲は、さながら裾のなき滝の虚空に漲るかと怪まれ、暗雲忽ち陰惨として、灰に血を交ぜた雨が飛んだ。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "応召した夫に代わって万事を取り仕切り、敗戦の年の冬も、頭上を覆う暗雲に気丈に向き合っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村泰次郎氏の暗雲の下――（同上）は、現代の青年の身動きのならぬ憂悩に歯ぎしりをして突つかつてゐる逞しい構えが、まつたく冗談事としてゞはなくわれわれの上にまでもひゞいて来る何物かゞ、さうだたしかに何とも指摘も適はぬ何物かゞ感ぜられる。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車馬のように暗雲にかせぐのはいいことなのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体を蔽うものは依然たる暗雲である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず懐疑の暗雲に閉じこめられて天地｜晦冥の間に時々光明の閃光に接し、その光明次第に増すと反比例して暗雲徐々として去り、遂に全光明に接するに至るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも航海者が海上暴風雨に会して船は難破し、身はまさに溺れんとして、「海よ我を記せよ」と叫びて絶望の悲声を発するかと思えば、忽ち暗雲風に開けて雲間に星辰の燦くを見て、そこに微かなる希望を起すが如き状態である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前からこの二人の間には暗雲が低迷していたのである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して二葉亭のいう如くその頃の日露国民間に暗雲が低迷していたか否かは別であるが、国家を憂うる赤誠はこの一場の卓上話の端にも十分現われておる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下流の右岸には秀麗な角錐形の山、（それは夕暮富士だと後で聞いたが）山の頂辺に細い縦の裂目のある小松色の山が、白い河洲の緩い彎曲線と程よい近景を成して、遙には暗雲の低迷した、それは恐らく驟雨の最中であるであらうところの伊吹山のあたりまでバックに、ひろびろと霞んだ、うち展けた平野の青田も眺められた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、古いものは古いほど安心して使える、といわれるが、なるほど尤もな話だなあ」　　　忠魂塔　その当時、極東には国際問題をめぐって、ただならぬ暗雲が立ちこめていた。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "發見後十五分位ノ後ニハ遙ニ南々西ノ方向（附圖ニヨルト、吾妻橋西詰ノ方ラシイ）ニ前ヨリモ高ク上空迄暗雲中ニ象鼻状（見取圖略）ノ白氣ガ搖レナガラ立昇ルヲ見タ。",
              "citation": {
                "source": "寺田先生と僕",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不法なるクーデターの顛末が、自分の口から、生徒控處の一隅で、殘りなく我がジャコビン黨全員の耳に達せられた時、一團の暗雲あつて忽ちに五十幾個の若々しき天眞の顏を覆うた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不法なるクーデターの顛末が、自分の口から、生徒控処の一隅で、残りなく我がジヤコビン党全員の耳に達せられた時、一団の暗雲あつて忽ちに五十幾個の若々しき天真の顔を覆ふた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
