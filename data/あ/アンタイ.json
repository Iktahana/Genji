        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安泰について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安泰という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安泰の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安泰が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安泰を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安泰について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安泰の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安泰の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安泰が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安泰という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安泰という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安泰についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安泰を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安泰は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安泰について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安泰が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安泰は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安泰の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安泰は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安泰は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "個體が死んでも種が榮えれば國家は安泰である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "個体が死んでも種が栄えれば国家は安泰である。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど子供のうちより心の繋りを持つ富士が、自分が死んで、やみやみ後に安泰で残る筈がない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩御帰邸相成りませぬで一統の者の心痛いかばかり、まずは御安泰にて恐悦に存じまする。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府、千年の安泰のためです。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部、呆然たるうちに岸に着き、見れば若殿は安泰、また我が子の勝太郎も仔細なく岸に上って若殿のお傍に侍っている。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは政宗が私に会津を取り且つ小田原参向遅怠の為に罪を得んとするの事情が明らかであったところから、最上義光に誑かされた政宗の目上が、政宗を亡くして政宗の弟の季氏を立てたら伊達家が安泰で有ろうという訳で毒飼の手段を廻らした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して安泰ではない。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理兵衛の妻同様、清太郎にも下町式のいわゆる「出来た嫁」さえ持たして置けば家はいつまでも安泰であろう――「蝶ちゃん。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう見て来ますと、この中老の番頭には危機が危機でなく安泰が安泰でなく、何事も両極が磅※して、それでどっかに中心を取って行く、妙に粘りのある渾沌が見出されて来ます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は当時｜退隠相願い、隈本を引払い、当地へ罷越候えども、六丸殿の御事心に懸かり、せめては御｜元服遊ばされ候まで、よそながら御安泰を祈念致したく、不識不知あまたの幾月を相過し候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時間を使ってその悪党が練習してあなたの真似ができるようになれば、その地位も安泰というもので、なにせ事務所の誰もあなたを直に見たことがないのですから。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯六節はこれを改めて「掠奪う者の天幕は栄え、神を怒する者は安泰なり、彼らは己の手に神を携う」とすべきである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これすなわち悪人の繁栄と安泰を世に通有のこととして述べたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "將來一大戰等ヲ覺悟スルナラバ特ニ非常時ニ安泰ナルベキ改造ヲ要ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "信に女親の心は、娘の身の定りて、その家栄え、その身安泰に、しかもいみじう出世したる姿を見るに増して楽まさるる事はあらざらん。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしおに料簡を切り替えて、もとの堅気の百姓に立ちかえれば、本人も家も安泰である。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その袖にしっかりと取り縋ってさえいれば、身の安泰は恐らく保障されることと信じていながらも、兄と名のつく師冬があくまでも自分を放逐しろと迫って来た時に、小坂部は果たして最後まで自分を庇ってくれるであろうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが本統のあらん限り、越前の家また磐石のごとく安泰じゃ」といいながら、秘蔵の初花の茶入を忠直卿に与えた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば五十四郡も安泰じゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ御領内に鎮守の御社を預かって、御家繁昌御家安泰を御祈願すべき神主が、由々敷一揆の相談うけたときかばさぞかし御不審でおじゃろうが、拙者、ちと変り者でな。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "神意は広大、御神罰もまた御広大、崩れた垣のままでいち夜たりとても棄ておかば、御社預る沼田正守、豊明権現様に御貴殿が御家名安泰の御祷りも出来ぬというものじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごほんものの将軍家と伊豆様は、今ごろご城中でご安泰におくつろぎでござりましょうから、ご安心くださりませい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "洲先は頼朝が石橋山の軍に負けて、安房へ落ちて来たときに初めて上陸したところで、おなじ源氏の流れを汲む里見の家では日ごろ尊崇している神社であるから、庄兵衛がそれに参詣して主家の安泰を祈るのは無理もないことであった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「銅兵衛殿の息のあるかぎり、君尾姫にはご安泰。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた片肩がひどく怒って見えるのは、子供の頃彼の家が、まだ此の村で安泰であった時と同じであった。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あんたいい気になって、あんまり無理しちゃ駄目よ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅字しかえ屋の婆さんは、君枝が返辞せぬので、「君ちゃん、あんたいつまで足｜洗てなはんネ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたいけるね」　と福井さんがしきりにすすめた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆみちゃん、あんたいい人があるんじゃない？",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
