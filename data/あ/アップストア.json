        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「アップストアの新たな利用規約変更が、開発者コミュニティで議論を呼んでいます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ずっと探していたタスク管理アプリが、アップストアのおすすめで偶然見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人に「このゲーム、アップストアで評価高いよ」と教えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のアプリをアップストアに申請する前に、ガイドラインを再確認する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アップストアのランキングをチェックすると、今どんなアプリが流行っているか一目でわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一つのプラットフォームで多様なアプリが提供されているアップストアは、ユーザーにとって非常に便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「アップストアで新しいパズルゲームを探してみようか」と子供に提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
