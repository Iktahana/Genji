        "examples": {
          "standard": [
            {
              "text": "毎日、愛妻家は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛妻家が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛妻家に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛妻家が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛妻家について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛妻家についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛妻家について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛妻家が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛妻家が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛妻家は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛妻家は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛妻家を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛妻家をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛妻家が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛妻家の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛妻家を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛妻家に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛妻家について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛妻家は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛妻家を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども、だいたいは愛妻家の部類なのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はたいへんな愛妻家であつて、妻君に死に別れてからも、短歌や詩に託して妻君を想い偲ぶのであつた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に述べた愛妻家の友人は七十何囘もこの靈媒女を通じて亡妻と語り合つたが、その後半に至つては、靈媒女は指導者を必要とせず自分で無我の境にはいれた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶は特に自分を愛妻家だとは思っていなかったが、外国で一人の女人の皮膚にも触れなかったのを思い浮べると、なるほどその点では愛妻家の中に入れられるところもあるかもしれないと思った。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その土曜日の晩に、会社で、徹夜の仕事をして、翌る日曜日の朝早く、大急ぎで帰って来た愛妻家のロスコー氏は、昨夜、自分自身の手で、たしかに鍵を掛けて出た筈の玄関の扉が、半分ばかり開いているのを遠くから発見してハッとした。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビリング医師はもちろん、クロスレイ夫人も、自分がビリング医師を教えて、ブラドンがそこへアリスを伴れて行ったことを知っているので、彼らのすべてにとって、ブラドンはたいして悪くもないのに花嫁の健康を気にして医者に見せるほどの、おかしいくらいな、代表的愛妻家でしかなかった。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ光線係看護婦として、ロア・グルノウ記念療養院に働いているアン・ルロイは、仕事が済むと直ぐ、矢のように北二丁目の家へ帰って、まるで愛妻家の良人が、病める妻の世話をするように、料理から家事のすべては勿論、まめまめしくサミイの面倒を見る。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛妻家の一例岸田國士　ルナアルの日記を読んで、いろいろ面白い発見をするのだが、彼は自分の少年時代を、「にんじん」で過したゞけあつて、大人になつてからも、常に周囲を「にんじん」の眼で眺め暮した世にも不幸な人間なのである。",
              "citation": {
                "source": "愛妻家の一例",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房と亭主の個性の相対的なものであるから、わが平野謙の如く（彼は僕らの仲間では大愛妻家といふ定説だ）先日両手をホータイでまき、日本が木綿不足で困つてゐるなどゝは想像もできない物々しいホータイだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉がゑぐられる深傷だといふ無慙な話であるけれども、彼の方が女房の横ッ面をヒッパたいたことすらもないといふ沈着なる性格、深遠なる心境、まさしく愛猫家や愛妻家の心境といふものは凡俗には理解のできないものだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人愛妻家よ」　南原杉子はにこやかである。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房と亭主の個性の相対的なものであるから、わが平野謙の如く（彼は僕らの仲間では大愛妻家という定説だ）先日両手をホータイでまき、日本が木綿不足で困っているなどとは想像もできない物々しいホータイだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉がえぐられる深傷だという無慙な話であるけれども、彼の方が女房の横ッ面をヒッパたいたことすらもないという沈着なる性格、深遠なる心境、まさしく愛猫家や愛妻家の心境というものは凡俗には理解のできないものだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術をするんだぞ」　と、大変な見幕であったが、愛妻家の大井広介が奥さんの乳癌にテンドウしたのは当然であろう。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな愛妻家の情ぶかいやり方を聞いて、わたしは微笑を禁じえなかった。",
              "citation": {
                "source": "妻",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのように愛妻家であったって。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春、愛妻家の平野謙が独身者の僕をみつめてニヤニヤ笑いながら、決死隊員というものは独身者に限るそうだね、妻帯者はどうもいかんという話だよ、と仰有るのである。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
