        "examples": {
          "standard": [
            {
              "text": "私は毎日安眠妨害について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安眠妨害の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安眠妨害が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安眠妨害について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安眠妨害の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安眠妨害が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安眠妨害という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安眠妨害についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安眠妨害は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安眠妨害が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安眠妨害は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安眠妨害の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安眠妨害は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安眠妨害は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ここは安眠妨害だよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ハイヒールの靴音が、大またに自分を追うて来たかと思うと寝しずまった町並の家の安眠妨害になりはしないかと思われる大声で、「あら、新子姉さんじゃないの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ大勢がわいわい云って餅を搗き立てるのであるから、近所となりに取っては安眠妨害である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（借りてる以上――とは何たる馬鹿だらう、卑しい法律書生でも云ひさうなことだ、法律書生なら安眠妨害といふ罪を知つてゐる、小田原の漁師のやうだ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……殺さないまでも、彼等の夢を驚かして気の毒だつた、人間が土を耕やすのは、ケラにとつては安眠妨害、蚯蚓にとつては家宅侵入だらう、人間は時として虫にも劣つてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい十二時すぎまでかかりつめていて、近所から安眠妨害だと文句を云われることもあった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この毛虫が成長するに随ってゾロゾロ這い出し、盛んに家宅侵入、安眠妨害を遣るので、人民の迷惑一通りでない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、区がそれを安眠妨害として告発しても差支えなかろうと思われるような、怖ろしい物音を真夜中に立てて、鏈をガチャガチャと鳴らした。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィオロオヌの手がどうかして誰かの枕の端に触れると、こいつは安眠妨害だ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に夜間の訓練は安眠妨害になって、翌日のわれわれの能率を著しく阻礙する。",
              "citation": {
                "source": "抗議する義務",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど安眠妨害に違いない。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
