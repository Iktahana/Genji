        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鏡を、ふたつ對立させると、鏡の中に、また鏡、そのまた奧に、また鏡、無限につらなり、つひにはその最深奧部に於いて、青みどろ、深淵の底の如く、物影がゆらゆら動いてゐる。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつを、あの青みどろを、しかと掴んで計算し、その在りのままの姿を、克明に描寫し、黒白確實に、表現し、それを、やさしい額縁にいれて呈出したい。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして所々に露出した山骨は青みがかつた真珠のやうな明るい銀灰色の条痕を成して、それがこの山の立体的な輪郭を鋭く大胆なタッチで描出してゐるのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして所々に露出した山骨は青みがかった真珠のような明るい銀灰色の条痕を成して、それがこの山の立体的な輪郭を鋭く大胆なタッチで描出しているのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の顔でも手でも青みを帯びた不快な黄色に見え、唇などはまるで死人のようになる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっと目星い品が視野から彼女を呼び覚すと、彼女の青みがかった横長の眼がゆったりと開いて、対象の品物を夢のなかの牡丹のように眺める。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔聖なる窓〕宮沢賢治聖なる窓そらのひかりはうす青み汚点ある幕はひるがへる　Oh, my reverence!　Sacred St. Window!",
              "citation": {
                "source": "〔聖なる窓〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みかかった雲は、東方からさしてくる赤い日の出に、薄紫色に染めぬかれて、ゆるやかに動いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のひかり煙を青み、　　　　秋風に児らは呼び交ふ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月や出でにし雪青み、　　　　をちこち犬の吠ゆるころ、舞ひを納めてひれふしつ、　　罪乞ふさまにみじろがず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづく見れば羽蟻の形して、それよりもやや大なる、身はただ五彩の色を帯びて青みがちにかがやきたる、うつくしさいわむ方なし。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源は秋の日など隅田堤より遠く西の方に青み渡りて見ゆる秩父郡の山※の間にて、大滝村といへるがこの川の最上流に位する人里なれば、それより奥は詳しく知れねど、おもふに甲斐境の高山幽谷より出で来るなるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすけた黄褐色の千切り形あるいは分銅形をしたものの、両端にぼんやり青みがかった雲のようなものが見える。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も、畑も、緑の色が、うれきったバナナのような酸い匂いさえ感ぜられ、いちめんに春が爛熟していて、きたならしく、青みどろ、どろどろ溶けて氾濫していた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は蒼茫として青み亙つた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖臺の二つ置いてある廣やかな解剖室の白壁は眞夏の朝日の光と、青葉の射翠とで青み亙るほどに清々しく準備されてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は、西の屋根瓦の並びの上に、ひと幅日没後の青みを置き残しただけで、満天は、紗のような黒味の奥に浅い紺碧のいろを湛え、夏の星が、強いて在所を見つけようとすると却って判らなくなる程かすかに瞬き始めている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子どもは山羊の首から帯皮をとりながら畑の向うでかげろうにぎらぎらゆれている、やっと青みがかったアカシヤの列を見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青み勝ちに澄んだ眼は、睫毛が長く、鼻筋はきれいに通り、胸を病む少女のようにほっそりと痩せた頬には、深い笑くぼがあり、透きとおるように色が白い。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば紅顔可憐だが、しかしやがて眼を覚まして、きっとあたりを見廻した眼は、青み勝ちに底光って、豹のように鋭かった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺青みたいなもンしたら、母ちゃんに叱られま」「なんぜ叱られるねン」「なんぜ言うたかテ、刺青いうたら、まともな人間のするもんと違いまっしゃろ」　次郎はませた口調だが、さすがに少年らしくぶるぶるふるえた声で言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子の眼は青み勝ちに澄んでいた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳥は元気を取り戻して立ち上がると、のぼりくる太陽のほうへ、空の旅行隊の飛び去った青みがかった岸辺をめざして飛んで行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪と罰をアントとして考えたドストの青みどろ、腐った池、乱麻の奥底の、……ああ、わかりかけた、いや、まだ、……などと頭脳に走馬燈がくるくる廻っていた時に、「おい！",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩の御馳走は、蛙の焼串、小さい子供の指を詰めた蝮の皮、天狗茸と二十日鼠のしめった鼻と青虫の五臓とで作ったサラダ、飲み物は、沼の女の作った青みどろのお酒と、墓穴から出来る硝酸酒とでした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは犬のやうな険悪な目ではなく、円な眼全体が、青みを含んだ黒で、いふにいはれぬ優しさをたたへてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいかっぱ虫に鈍くも腹に穴を開けられて、青みどろの水の中を勝手に引っぱられて行く、脆いだらしのない赤い小布の散らばったものを金魚だと思っていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雪の峰があおみをおびて雲の間にそびえ、人間界のけがれをしずめおさえること幾万。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "どじょう汁、鯨汁、しじみ汁、あおみ汁（野菜のこと）、豆腐汁、ねぎ汁、いずれも五銭で、めしが十銭、十五銭也でめしが食える。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
