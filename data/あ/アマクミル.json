        "examples": {
          "standard": [
            {
              "text": "私は毎日甘く見るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘く見るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘く見るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘く見るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘く見るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘く見るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘く見るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘く見るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘く見るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘く見るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘く見るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘く見るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘く見るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘く見るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを読んで女はこうすれば男に気に入るというような矯飾な工夫を増長して、自然内心では男を甘く見るという事も少くないと存じます。",
              "citation": {
                "source": "産屋物語",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが若い人々に「生」を甘く見る習慣をつける。",
              "citation": {
                "source": "若手歌舞妓への期待",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は口々に――意味はさつぱりわからぬが――多分「顔が黄色いと思つて甘く見るな」とか、「馬鹿いへ、警官に訴へるぞ」とか、「愚図々々せずに早くやれ」とか、「相共に抱いて海に投ぜん」とか云つてゐるのであらう。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、これも日本人の悪い癖ですが、総て仕事を甘く見る。",
              "citation": {
                "source": "二つの答",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイド眼鏡以前のあどけない素顔を思いだして彼女を甘く見る傾向もあって、今日この頃の彼女の威厳に必ずしも全面降伏していたわけではなかった。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくり行っていらっしゃい」「甘く見るな。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを不用と思うのは、自然を甘く見るからである。",
              "citation": {
                "source": "比較科学論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……長い間隱忍して來た獨歩も、小説家としてやうやく世に重んぜらるやうになりかけた頃で、「おれも小説家だ、甘く見るな。",
              "citation": {
                "source": "昔の西片町の人",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし昨日一日一晩嫂と暮した経験は図らずもこの苦々しい兄を裏から甘く見る結果になって眼前に現われて来た。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く見ると承知しねえよつ！",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来すぐ人を甘く見る性だから、校長の古手のような、余りパッとしない真名古の風采を見ると、たちまち舐めてかかって、「おやおやまたお調べですか、助からないねえ」　なんて吐かす。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、何をなさるんです」「おい、甘く見ると、たいへんな間違いだぜ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉公人か近所の人に當つて見たら、見當ぐらゐはつくだらう」「そんなことなら、わけはありませんよ」「あんまり甘く見るな、なか／＼底が深いぞ」「へエ？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱し念佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く見ると、飛んでもねえ目に逢はされる」「へエー、そんなもんですかねえ」　腑に落ちない乍ら、ガラツ八は其日から巣鴨へ詰めることになつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く見ると、とんでもねえ目に逢わされる」「ヘエー、そんなもんですかねえ」　腑に落ちないながら、ガラッ八はその日から巣鴨へ詰めることになったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん孔子は、音楽の道にずいぶん深くはいっている人だから、楽長としても、彼を甘く見るわけには行かない。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり代地の権内を甘く見るなよ」「どうしても、退かねえな」「会わすも会わさぬも親の権利。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前を甘く見るわけぢやないが、どうも氣になつてならねえことがあるよ」「へエ？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "風呂場の祕密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ、そんな深いことまで知っちゃいねえ」「甘く見るなッ」とまたひとつ、鉛玉をビュッとうならせて、源次の顔に血を吹かせた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、どうしてですか、あたし奢りたいんですもの奢らして下すってもいいでしょう」　保馬は「あまくみるな」などと云ってとりあわなかった。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹三郎はひとり息子なのに神経質なよく気のまわる性分で、宇乃に対しても、うるさいほどしんせつにしてくれたが、虎之助のことになると、まるで親身の弟のように熱心で、そのために、却って虎之助は幼ないながら、すっかりあまくみるようになっている。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
