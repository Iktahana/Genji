[
  {
    "uuid": "d03ec442-bab9-5c12-b712-9618fb8050b9",
    "entry": "穴を開ける",
    "reading": {
      "primary": "あなをあける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cause a loss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴を開けるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴を開けるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴を開けるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴を開けるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴を開けるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴を開けるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴を開けるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴を開けるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴を開けるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴を開けるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴を開けるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴を開けるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴を開けるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴を開けるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "軍艦の場合などでは、それをどうして沈めるか、どうして穴を開けるかを、絶えず研究していることは、誰だって知ってることだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管の吸口ででも結構に樽へ穴を開ける徒が、大びらに呑口切って、お前様、お船頭、弁当箱の空はなしか、といびつ形の切溜を、大海でざぶりとゆすいで、その皮づつみに、せせり残しの、醤油かすを指のさきで嘗めながら、まわしのみの煽っきり。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人差指へ唾を付け、窓の障子へ押え付けたのは、小穴を開ける為なのだろう。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に置いて、三吉が何か為ようとすると、お房は掛物を引張る、写真｜挾を裂く、障子に穴を開ける、終には玩具にも飽いて、柿の食いかけを机になすりつけ、その上に這上って高い高いなどをした。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．寒氣が服を通す（現在完了の助動詞は［自］sein,［他］haben）［自］〔Die Ka:lte ist durchgedrungen.〕［他］〔Die Ka:lte hat das Kleid durchdrungen.〕【６】１．彼は壁を破つて大きな穴を開ける。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな大穴を開けるのを、目敏いのが自慢の私が知らない筈はありません」　番頭は妙な事を言ひ出します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな大穴を開けるのを、目敏いのが自慢の私が知らないはずはありません」　番頭は妙な事を言い出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "たぬき囃子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穴を開ける時の彼女の様子は、彼の心を甚だしく喜ばせた。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくらいなら西瓜でもちぎって来た方がまだしも簡便で、床板に穴を開ける手数だけでも省ける。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苟くも大名の北の方でありながら、酔餘の戯れに生きた人間の耳へ刀で穴を開けると云うようなことは、不用意に聞くと、全くその人の徳を傷け、美しい性格に暗影を投げる事件である。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海中に穴を開けるとはよく聞くが、こりゃ見たことない。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この錨が動いたら、甲板に大あなをあけるだろう。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、海のなかの木材や、木の船底を、やたらに食ってあなをあける。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
