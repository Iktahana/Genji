[
  {
    "uuid": "0387235c-e5b9-505e-93c0-39ca0de3ab2b",
    "entry": "相合傘",
    "reading": {
      "primary": "あいあいがさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sharing an umbrella",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相合傘は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相合傘が重要です。",
              "source": "幻辞"
            },
            {
              "text": "相合傘に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相合傘が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相合傘について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相合傘についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相合傘について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相合傘が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相合傘が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相合傘は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相合傘は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相合傘を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相合傘をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相合傘が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相合傘の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相合傘を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相合傘に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相合傘について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相合傘は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相合傘を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "相合傘の下に、　いきち、おるい　その戯書の大写からＯ・Ｌして、７＝元のお類の待っていた処　お類と伊吉のラブシーンです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰り、二人の男が相合傘で歩いている。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、二足つかみの供振を、見返るお夏は手を上げて、憚樣やとばかりに、夕暮近き野路の雨、思ふ男と相合傘の人目稀なる横※、濡れぬ前こそ今はしも、　と前後も辨へず讀んで居ると、私の卓子を横に附着けてある件の明取の障子へ、ぱら／＼と音がした。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に電車に乗って、小金井で降りて、それから雨の降るまっくらい路を相合傘で、ならんで歩きました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は種々な処へ、これから奥は、御堂の背後、世間の裏へ入る場所なれば、何の卑怯な、相合傘に後れは取らぬ、と肩の聳ゆるまで一人で気競うと、雨も霞んで、ヒヤヒヤと頬に触る。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非相合傘にして頂く。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ともう、相合傘の支度らしい、片袖を胸に当てる、柄よりも姿が細りする。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　七「相合傘でいらっしゃいまし、染ちゃん、嬉しいでしょう、えへへへへ、貴方、御機嫌よう。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死出の山辺に燈一つ見える、一つ灯にただ松一つ、一本松こそ場所｜屈竟と、頃は五月の日も十四日、月はあれども心の闇に、迷う手と手の相合傘よ、すぐに柄もりに袖絞るらむ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死出の山辺の灯一つ見える、一つ灯に松ただ一つ、一本松こそ、場所屈竟と、頃は五月の日も十四日、月はあれども心の闇に、迷う手と手の相合傘よ、すぐに柄もりの袖絞るらむ……　被布の抜衣紋で、ぐたりとなった、尼婆さんの形が、散らかった杯盤の中に目に見えるようで、……二階でまだ唄っている。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりに人ッ子一人なし、雨はしきる、相合傘で。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやよってじゃ、相合傘で送って出て、一本松にも居らぬとすりゃ、雨の中を、いつまでも、どこへどう行くもんや、つもっても知れておる。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンと轆轤を切って、外套両名、相合傘でいた私に寄越して「ちょっと骨が折れました、遠い引掛りなんですがね……聾で中風症のお婆さんが一人留守をしているんだもの、驚きましたわ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、相合傘じゃあ凌げそうもありませんぜ」と、善八は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "男同志の相合傘といふものは、女とのそれよりも涯かにもつと親密な感じがするものである、殊に私は彼とこんな機会でなければ、おたがひにかう激しく肩を打ちつけ合ふことはあるまいと考へた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の進まないお光を叱るように追い立てて、栄之丞は妹と相合傘で雪の門を出た。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男同士の相合傘、空しく橋本の前を過ぎて、身を電車に投ず。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、なにしろそんなことで、お金清吉という相合傘が出来たと思ってください。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い二人は其の新らしい樂書の傍に寄り、ニヤ／＼笑つて見てゐたが、軈て定吉は下に落ちてゐた消炭を拾ふと、相合傘の側の「定吉」といふ字を消して、其の跡へ「道臣」と小ひさく書き、ベロリと舌を出して首を縮めた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭一郎は千登世の傘の中に飛び込むと、二人は相合傘で大學の正門前の水菓子屋の横町から暗い路地に這入つて行つた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして両人は、人通りの絶えた街を相合傘で歩いていった。",
              "citation": {
                "source": "フェリシテ",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士春が「庄さん、本当に知っているのかい」「知っているとも――俺、こんなお嬢さんに、嘘を吐くような悪じゃあねえ」「そら、そうだけど」　深雪は、庄吉の、いうこと、することに、腑に落ちぬところはあったが、白昼、町の真中であったから、二人の相合傘を人に見られるほか、安心していてもいいと、考えていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには「雨の夜の相合傘」という見出しで、根も葉もない、あくどい記事が書いてあるじゃあありませんか、あまりのことに、私は真青になって口がきけなくなりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は気持がわるくなったので、うんと馬力をかけて五つ曲り目を駈け上ると、丁度六曲り目というところに、男と女が番傘一本を相合傘にして、上ってゆくのを見た。",
              "citation": {
                "source": "怪談",
                "author": "平山蘆江",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は藍微塵の素袷、三尺をしめて尻を七三に端折り女は単衣の弁慶縞で唐米子の帯を引っかけに結んで、髪をいぼ尻巻にし、片腕を腕まくりしていた、一寸与三郎と切られお富が相合傘であるいているという形ち、而もそれが近江路の鈴鹿峠なんだから、馬鹿馬鹿しいほど似つかわしからぬ人物である。",
              "citation": {
                "source": "怪談",
                "author": "平山蘆江",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪など肩にして芸子と番傘の相合傘で帰って来る若い男等が、「ヨウ、勘平｜猪打の段か」などゝ囃した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お角も、この男にだけは尻尾を押えられていると見えて、しょうことなしに相合傘で歩き出してはみたものの、橋を渡りきってしまえば甚三郎の宿は近いのですから、先へ進む気になれません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、他の一方の橋の袂から、また一組の相合傘が現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
