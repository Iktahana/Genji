      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oil-soaked cloth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油布について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油布は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油布の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油布について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油布は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油布の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油布に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油布が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油布を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油布の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油布が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油布が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油布について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油布は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油布は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油布は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油布について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油布の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油布の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油布の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "可笑しいことには、古来の屋根の一型式に従ってこけら葺の上に石ころを並べたのは案外平気でいるそのすぐ隣に、当世風のトタン葺や、油布張の屋根がべろべろに剥がれて醜骸を曝しているのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油布の支那服なぞ着て、大陸政策の会合なぞへも出た。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宅のことで、夜番の燈火を表にあげる時には、毎朝々々夜明け前の軒行燈の下掃除をして置いて、その油布巾で戸障子の敷居などを拭いたものであつたともいふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒のために荒羅紗を入れ、黒い油布を張った上から鋲をうちつけた、あたりまえのロシアの戸だ。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして事務室の隅から隅へずしずしと足早に歩き廻って、探るような眼つきで書類のはいった古戸棚や油布張りの椅子をじろじろ眺めたり、時には護送人の方をちらりと見たりする。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、型の如く煤けた天井と、同じく煤けたシャンデリアで、それにはカットグラスが沢山ぶらさがっていて、給仕が型の如く、海辺に集う鳥の数ほど夥しい茶碗を載せた盆を、大胆に振り廻しながら擦りきれた油布の上を駈けまわるたんびに、跳ねあがったり、ちりんちりん音を立てたりする。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の旅立ちを見送りに来た親たちに、顔を見せると、すぐに桐油布を被せてしまって、子供たちに里心を起させないようにしたという、みじめさだ。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒油布張りの扉を開けるなり入ったナースチャは、首をのばし、「ヘーイ、シューロチカ！",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓前の油布のかかったテーブルに、グリーゼルがその上で食物を拵えてた石油焜炉とコップが置いてある。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "年長組がこの大きなおとし穴をつくりつつあるあいだに、年少組はバクスターを首領にして、ヴィクンヤなどを入れておく小舎を建てることにむちゅうになった、小舎はサクラ号から持ってきた板をもってつくり、屋根は松やにを塗った油布をもっておおい、小舎の周囲には森からきりだした棒杭をうちこんで柵とした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　間もなく七尺に近い黒人が油布を持った儘のそっと這入って来た。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "油布でくるんだ書類のような包と、触ると金の音のじゃらじゃらするズックの嚢だった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は油布の小包を取り上げながら言った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は言って、油布の包を彼に渡した。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まさしく、私があの船長の衣類箱の底で油布に包んであるのを見つけた、三つの赤い十字記号のついている、黄ろい紙の海図であった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁ぎはに立てた大きな薬戸棚、油布張りの固い患者用の寝椅子、青いビロードのふつくり盛り上つた廻転椅子、縁枠を白く塗つた医療器具棚の中には真新しいメスや鋏、鉗子などがぴかぴか光つて、大事さうに並べてあつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞白な大テエブルの上で、次ぎの氷島の漁期に必要なシラルジュ（油布）と呼ばれてゐる衣服をつくるために、新らしい木綿を裁つてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が縫ひかけてゐた油布は疊まれた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな国防上の重大なものばかりだ」　卓子の上へ展げた油布へ、拇指程の大きさの現像フィルム。",
              "citation": {
                "source": "劇団「笑う妖魔」",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、頭に油布を巻き、大きな船員服を着て、メアリが現れた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田勢は、夜明けもまたず、それへ攀じ登って、銃口を並べ、また焔の枯れ柴や油布へ分銅をつけて、火の鳥のように、大手門の内へ投げこんだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "油布、脂柴などを、壮丁の背に負わせて、陳武も身軽にいでたち、地を這い、草を分けて、敵の城壁下まで忍びよった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
