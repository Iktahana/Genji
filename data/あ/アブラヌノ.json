[
  {
    "uuid": "8cc5220f-f024-594a-9483-a000361c92a6",
    "entry": "油布",
    "reading": {
      "primary": "あぶらぬの",
      "alternatives": [
        "ゆふ"
      ],
      "is_heteronym": false
    },
    "grammar": {
