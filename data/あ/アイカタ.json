[
  {
    "uuid": "bc058695-9d21-53b4-afa2-92d6d5d055b6",
    "entry": "合方",
    "reading": {
      "primary": "あいかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
