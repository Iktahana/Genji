    },
    "definitions": [
      {
        "index": 1,
        "gloss": "accompaniment to a chant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合方は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合方が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合方に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合方が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合方について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合方についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合方について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合方が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合方が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合方は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合方は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合方を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合方をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合方が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合方の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合方を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合方に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合方について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合方は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合方を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……もう、やけになつて、鳴きしきる蟲の音を合方に、夜行の百鬼が跳梁跋扈の光景で。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論叱言を言つたつて、蛙の方ではお約束の（面へ水）だらうけれど、仕事をして居る時の一寸合方にあつても可し、唄に……「池の蛙のひそ／＼話、聞いて寢る夜の……」と言ふ寸法も惡くない。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ男が、或時、小店で遊ぶと、其合方が、夜ふけてから、薄暗い行燈の灯で、幾つも／＼、あらゆるキルクの香を嗅ぐ。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、合方もなしに、此の落人は、すぐ横町の有島家へ入つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……差配さん、合方だ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "フト合方が、がらりと替って、楽屋で三味線の音を入れた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人連　　　　　　　十　午後、宮ヶ崎町の方から、ツンツンとあちこちの二階で綿を打つ音を、時ならぬ砧の合方にして、浅間の社の南口、裏門にかかった、島山夫人、早瀬の二人は、花道へ出たようである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元がどうの、流儀がどうの、合方の調子が、あのの、ものの、と七面倒に気取りはしない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "合方は一中節を奏する。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花咲かば告げ　　　　むといいし山寺の……　ここの合方は、あらゆる浄瑠璃、勝手次第という処を、囃子に合わせて謡が聞える。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつぎの年に藩主が奏者になられて、仲平に押合方という役を命ぜられたが、目が悪いと言ってことわった。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花さんにまず幾らか握らせて、向島あたりへ姐さんをおびき出して、ちょうど浅草寺の入相がぼうん、向う河岸で紙砧の音、裏田圃で秋の蛙、この合方よろしくあって幕という寸法だろう。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、社会と自己とでは、一にして二ならずといふやうな融合方式で深く細かに雑り合つてゐるものである。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その道具立てや、出入りの鳴物や合方のたぐいが、わたしにはちっとも判らないからであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば“さんげさんげの合方にて幕明く”とか、“地蔵和讃の合方になり”とか、“白ばやしにて幕明く”とか、何のことかちっとも判らないのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人たちも道具立や合方などを知っているはずはない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛入りの合方で、好い気持に芝居をしてゐる間に、フト自分は切られた肩先に心づいた。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年の間何でも三百何十通と云う手紙を書きましたが、私が手紙を書放にして家内が校合方になって封じて遣るから、両親の親筆に相違ない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれの見得、幕引くと、九女八起上り合方よろしくあって、揚幕へ入る――　蚊のなくように、何時、どこで、なんの役でかの、狂言本読みの、立作者が読んできかす、ある役の引っこみの個処が、頭の奥の方で、その当時聴いた声のままで繰返してきこえる。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張を出して川合方の様子を見せると、立ちそうだという。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに狼が凄味の遠吠えを打ち込むと谷間の山彦がすかさずそれを送り返し，望むかぎりは狭霧が朦朧と立ち込めてほんの特許に木下闇から照射の影を惜しそうに泄らし、そして山気は山颪の合方となッて意地わるく人の肌を噛んでいる。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "此がまた招き行燈の仄紅い燈火がかもしだす哀愁曲を合方にその路次の溝板踏み鳴らして行く市井風流さは格別なもので、浅草の並木、両国の立花家、本郷の岩本（のちの梅本）概ねこの路次系の寄席に属した。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸演劇は囃子、唄、鳴物、合方、床の浄瑠璃、ツケ、拍子木の如き一切の音楽及び音響と、書割、張物、岩組、釣枝、浪板、藪畳の如き、凡て特殊の色調と情趣とを有せる舞台の装置法と、典型に基く俳優の演技並びにその扮装とこの三要素の綜合して渾然たる一種の芸術を構成したるものなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "出這入の唄合方は俳優が演技の情趣を助け床の浄瑠璃は台詞のいひ尽し能はざる感情を説明す。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は床と囃子の連弾掛合の如き合方を最も好むものなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸演劇に用ひらるる鳴物は独り三絃の合方のみに留まらず本釣鐘、時の鐘、波の音、風の音、雨車の如きを初めとし、谺、碪、虫笛、トヒヨの如き簡単に自然の音響を模したるものも皆それぞれに舞台の音楽的情調を作るに効果あり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日を出せし後にも二、三度｜合方を替へそれにてもなほ落ちつかぬ模様なりけり。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "落合方面から馬籠の町にはいるものは、旧本陣の門前まで出ないうちに街道を右に折れ曲がって行くと、共同の水槽の方から奔って来る細い流れの近くに、その静の屋を見いだすことができる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は漸くカワレリヤ、ルスチカナの幕開きに淋しい立琴を合方にして歌ふシチリヤナの一節を思付いた。",
              "citation": {
                "source": "黄昏の地中海",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "角海老楼という名代の青楼へ上って餓鬼大将は会長の一人々々にあいかたを宛がった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
