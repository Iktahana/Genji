[
  {
    "uuid": "ac4dbbf3-65a9-5d97-888a-ad9021d03358",
    "entry": "朝",
    "reading": {
      "primary": "あさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
