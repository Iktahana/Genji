        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その傘に大きく、たしか赤字で千金丹と書いてあったような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草はたしか「極上国分」と赤字を粗末な木版で刷った紙袋入りの刻煙草であったが、勿論国分で刻んだのではなくて近所の煙草屋できざんだものである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の財政に赤字が多く、外国為替がとても高価いときに、外国品を好んで買うことなぞはいかがなものでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、べつの皮肉屋の言うのには、「七月一日から煙草が値上りになるのは、たびたびの盗難による専売局の赤字を埋めるためだ」と。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし客はそればかりではなく、松島も気が揉めるので、ここへ出てから二年目、前借もあらかた消えたところで、彼女は思い切って足を洗い、母や弟妹たちと一緒に、やがて湯島に一軒家をもったが、結局それも長くは続かず、松島の商売も赤字つづきで、仕送りも途絶えがちになったので、今度は方嚮をかえ公園へ出た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日のために特に刷つた赤字のビラやパンフレット、この日の見物に売捌かうと抱へて来た労働新聞を傍列の赤シャツや黒ヅボンが両側の人波へさあさあと撒く。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙をのんで断裁すれば、帳簿上は資産が失われて赤字が発生します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤字を続けて会社を傾けないことは、出資者と社員と顧客に対する経営者の義務でしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "話によれば、これまではずっと赤字続きで、主催者が頭割りでマイナスを被ってきたと言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップル※をその手で作り上げたスティーブン・ウォズニアックは、会社が軌道に乗って大きくなりはじめるとビジネスにすっかり興味を失ってしまい、ウッドストック以来の大野外ロックコンサートを企画して大赤字をだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤字を入れられた原稿を前に、良心に猿ぐつわをかけて必死の自己弁護を試みるはめにもなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主は般若湯が好き、いつも赤い顔して赤字で苦しんでゐる、山頭火よ、と自から嘲り自から慰める。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月はあれほど緊縮して暮らした、今月もこれほどつましく生活費を切り詰めた、しかし赤字つゞきである（もつともちよい／＼一杯ひつかけるから、それが浪費といへばいへるけれど、私にあつては、酒は米につぐ生活必需品である！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達のふところにすがることがいやになつた、すまないと思ふ、毎日毎月の赤字がたまらなく私を悩ます、私は省みて疚しくない暮らし方をしたいと念じてやまない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・赤字のない生活　　　　身心共に。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、赤字穴埋め策として立てた政府の官吏減俸案に反対し全国的官吏の未曾有の示威が行われている最中である。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の新聞には、月給百五十円の人の家計は昨今五十円ずつ足を出して、それは赤字となっていることが報告されていた。",
              "citation": {
                "source": "家庭と学生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤字は危険信号を鳴り響かせている。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この赤字の中でどうして人々は生きているだろう。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、現実に、預金が干上ってしまった赤字破局だからこそ、モラトリアムはしかれたのではなかっただろうか。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全従業員一万八百人を全部解雇、改めて新規定の四割減給で採用し、八百五十万円を浮かして、永年にたまった八百万円の赤字を一気にうめようと云う整理案である。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市は赤字だといって市電従業員の賃銀を下げたが市会では暴力までふるって市議歳費値上げを決定した。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が赤字やりくりのために思いついて、先ず五十円券をどっさり買わせ、それで第一段儲け、ついで五人のひとに百万円あてさせて、こんどは売れのこりに一本あったから四百万円だけはらって、それが何かの形でまた逆にかえって来て、金まわりを助けてゆく。",
              "citation": {
                "source": "新しい文学の誕生",
                "author": "――若い人に贈る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「所長室はあいているようだから」と、今し方、鬼村博士が習慣的にかえして行ったために、「不在」をあらわす赤字の札になっているのを指しながら彼氏はあとから顔を出した助手に云った。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "身持ちになっても休めばクビであるから辛棒して働き、機械の前に倒れてそのまま赤字を生むことさえ珍しくなかった。",
              "citation": {
                "source": "ロシア革命は婦人を解放した",
                "author": "――口火を切った婦人デーの闘い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤字家計は三千七百円ベースでは支えきれない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、とにかく見ようじゃあないか」　家と云うのは、つい近くの、何々質店、信用、軽便、親切と、赤字で書いた大きなアーチ形の広告門をくぐって行った処に在った。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日赤字が続いた、もう明日一日の生命だ、乞食して存らへるか、舌を噛んで地獄へ行くか。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔のわりあいに耳がばかに大きい、まるでふたつのうちわを頭の両側につけているように見える、きたない着物の、手足があかじみた石太郎。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服やシャツはあかじみ、ぶしょうひげはよくのびており、ことばなども、すっかり村のことばになってしまった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
