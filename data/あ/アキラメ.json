        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼が残るのは、十分諦めてだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが諦めとは思はないでだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまあ未来があつたのだが、それも諦めて、父親のためには田舎へ引籠らなければならなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学を志望しながら、一向に進捗しないＡとして、ありさうなこととは考へられても、然しＡは猶、文学を諦めようとしてゐるのではないし、今は割合よく聴いてさへゐたのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな諦めてくたびれて、グウグウ眠つてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙も何もないので私は遂に諦めて蹲むだけに満足する。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまさら、そんな氣取つたきざつたらしいものを與へなくたつて、人間三百歳にもなりや、いい加減、諦めてゐるよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翔びゆく雲の落とす影のやうに、田の面を過ぎる、昔の巨人の姿――夏の日の午過ぎ時刻誰彼の午睡するとき、私は野原を走つて行つた……私は希望を唇に噛みつぶして私はギロギロする目で諦めてゐた……噫、生きてゐた、私は生きてゐた！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいまではもう諦めてしまつてさへゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とても、言葉の上の皮肉や、自分の行李を放り込む腹癒せ位で、此事件の結末に満足や諦めを得ようとは思っていなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの上にして育たぬようだったら、山よ、わたしは諦める。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉娘に対してはとかく恋々たる山の祖神の翁も弟の岳神に対してはどういうものかこの点は諦めがよかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが河神は肘の雫を啜っていう「私はこの女神のために諦めということを取失わされてしまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片親の父に相談してみても物堅い老舗の老主人は、そんな赤の他人の白痴などに関まっても仕方がないと言って諦めさせられるだけだった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか婚期を失ってしまったお蘭は自分自身を諦め切っている気持に伴って、もはや四郎を生ける人としては期待しなくなった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一時は四郎も死んだことにして思い諦めましたが、なにしろ自分より六つ七つ若いのですからまだ生きているかも知れません。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには諦めて鯉達は斎の鐘に集らなくなりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいっそ、そっとこのままにしておいて時の捌きを待つよりしかたがないと、思い諦めて、楽しいようなはかないような逢瀬を続けています。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや諦めて既に覚悟の態であった昭青年が、この眼に出会って思わず心に湧き出た力がありました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつでも、そのことについては諦めることが出来る。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女は諦めということを知らない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の第三の徴表は「諦め」である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思ふ事、叶はねばこそ浮世とは、よく諦めた無理なこと」なのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「いき」のうちの「諦め」したがって「無関心」は、世智辛い、つれない浮世の洗練を経てすっきりと垢抜した心、現実に対する独断的な執着を離れた瀟洒として未練のない恬淡無碍の心である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の「諦め」は爛熟頽廃の生んだ気分であるかもしれない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも「いき」のうちには運命に対する「諦め」と、「諦め」に基づく恬淡とが否み得ない事実性を示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、流転、無常を差別相の形式と見、空無、涅槃を平等相の原理とする仏教の世界観、悪縁にむかって諦めを説き、運命に対して静観を教える宗教的人生観が背景をなして、「いき」のうちのこの契機を強調しかつ純化していることは疑いない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
