          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安定器について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安定器という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安定器の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安定器が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安定器を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安定器について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安定器の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安定器の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安定器が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安定器という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安定器という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安定器についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安定器を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安定器は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安定器について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安定器が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安定器は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安定器の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安定器は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安定器は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
