    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be superfluous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り余るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り余るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り余るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り余るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り余るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り余るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り余るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り余るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り余るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り余るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り余るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り余るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り余るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り余るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り余るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り余るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り余るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り余るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り余るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り余るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "有り余るほど買溜めしていてもそうなのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに貴方の小説に有り余る程出てくるのは一種独特のムードでしょう。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は青年期の有り余る覇気をもちあぐみ、元来の弱気を無理な非人情で押して、自暴自棄のニヒリストになり果てていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの赤染右衛門に出て来られて、有り余る才を向う側に用立てられて、しかも正しい道理のある方に立って物を云われては、定基たるものも敵う筈は無い、差当りだけでも、如何にも御もっともと、降伏せざるを得ないところであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち我が当面の事情と同じような事情に対する解決は、どの書の中にも何人の教の中にも在るに相違ない、学んで学び得れば、凡常の人が提出するような問題を解決するには有り余るほどの知識が、簿記・計算の書と教える師には備わっていて不足は無いのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "建網に損じの有る無し、網をおろす場所の海底の模様、大釜を据えるべき位置、桟橋の改造、薪炭の買い入れ、米塩の運搬、仲買い人との契約、肥料会社との交渉‥‥そのほか鰊漁の始まる前に漁場の持ち主がしておかなければならない事は有り余るほどあるのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の前に私を私以上に立派に見せようとする虚妄な心は有り余るほど持っていたけれども、そこに埋めることの出来ない苦痛をも全く失ってはいなかった。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに恥ずかしい事を打ち明けるようだけれども、木村さんにもわたしにも有り余るようなお金がないものだから、行きも帰りもその船の事務長という大切な役目の方にお世話にならなければならなかったのよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊富な資力、有り余る語学力、立派な邸宅、美しい夫人、よいものずくめの氏ではあるが、ひとつの病弱という悪いものがあって、氏を不幸に導こうとしている。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜勇にしても色気は有り余る程たつぷり持合せてゐるが、肝腎のお銭といつては一｜文も無かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程聴いてみると、尤もな話で、亜米利加には猶太人の好きな金は有り余る程あるし、口喧しい神様は居無いし、加之に男はみんな女に親切だといふから、猶太種の女が理想郷とするに打つて附けの土地柄だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、心持が有り余るもんですから。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁はこの人達のやうに有り余る程な旅費と閑暇とを持合さなかつたのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方それとは全く反対に、有り余る金はあり、子供の教育に責任を負うに充分な丈の健康と知能とは持ちながら、所謂自由が味えない為、容色が衰えるなどと云う恐怖から、無良心に科学の発達を濫用する者の一群になると思います。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り余る程の精力を持った彼は、これまで散々｜種々なことを経営して来て、何かまだ新規に始めたいとすら思っていた。",
              "citation": {
                "source": "刺繍",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り余るなやみを胸に抱いて禅師の教えを乞いに参じたところ、詰所の人が禅師はお休みだからと断るようでした。",
              "citation": {
                "source": "芸術三昧即信仰",
                "author": "生きることに悶えた四十代",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと違って、スカンクスの奥さんは凄いような美人で、鼻は高過ぎる程高く、切目の長い黒目勝の目に、有り余る媚がある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "米を買ったり下駄を買ったりしただけでは、まだたくさんの金が残るからして、その有り余る金をばことごとく奢侈品に向けて来る。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず話の中で折折吃るのも有り余る感想が一時に出口に集まつて戸惑ひする様で却て頓挫の快感を与へる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かよわき身には、有り余る、幸も重荷となるものを、思ひやりなき運命よ情の過ぎた運命よ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは世間にはピエロを自認するニヒリストは有り余るほどおりますよ。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までは鐘や太鼓で探しても無かつたものが、今日は津々浦々に有り余るほど溢れでゝゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも、お前も、あいつの世話になつてるわけぢやなし、苦労はめいめい、有り余るほどもつてるんだ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り余るお金や耕しきれない広大な土地は財産じゃない、それを羨む必要はないのである。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "其為に肥料として最も佳い馬糞が有り余るほど貯へられてあつた。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの家じゃア有り余る物ですから燃しちゃっても平気のせいもありますけどさ」　寒吉はハッとした。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ二人の間に不足なのは、金銭が有り余るというわけにゆかないだけのことで、他に金銭を山ほど積むお客が幾らあったとて、二人がおたがいに可愛がるほどの愛情は湧いて来るものではないと思っているのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、隱者とは言つても、かの竹林の賢者たちのやうに、ありあまる知識をもてあまして、竹林に逃げ込んだといふやうなものでは無くて、この劍山の隱者の心は甚だ愚である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘も母親のありあまる愛情に堪能していた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の不運の代りに、あなたの恋には神様のお恵みがありあまることと信じます。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
