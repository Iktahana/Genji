[
  {
    "uuid": "15ce8d76-659a-5f8c-8af8-a2f5707984a8",
    "entry": "有り余る",
    "reading": {
      "primary": "ありあまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
