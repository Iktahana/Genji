        "examples": {
          "standard": [
            {
              "text": "私は毎日アンカーパーソンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンカーパーソンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンカーパーソンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンカーパーソンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンカーパーソンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンカーパーソンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンカーパーソンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンカーパーソンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンカーパーソンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンカーパーソンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンカーパーソンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンカーパーソンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンカーパーソンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンカーパーソンは興味深い例である。",
              "source": "幻辞"
            }
