    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese scarlet eggplant (Solanum integrifolium)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（明治四十年十一月十六日『東京朝日新聞』）　　　　　　　　　三十九　　　　　　赤茄子の伝来　洋食に用いるトマトの来歴を調べた人の説によると、この植物は十六世紀の中頃に南米ペルーからスペインあるいはポルトガルに渡りそれから欧洲に拡がったものである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばを説明するよりも赤茄子のようだと話す方が早解りがするようなものであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこの代理になる赤茄子の考が先方の頭のなかになくては駄目で、考がある以上は、その考え次第では、第二段に述べる conceptual な叙述を予想した事になりますが、これはその場合に至ってなるべく不都合のないように説明してみましょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、帰着するところは、perceptual な叙述のもっとも簡便な形式は洋卓は唐机のごとしとか、※は赤茄子のごとしとか、驢は騾のごとしとか、すべて眼に見、耳に聞き、手に触れ、口に味わい、鼻に嗅いで得たる形相をもって叙述する事になります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけならば※を赤茄子で説明したり、洋卓を唐机で説明するのと別段の相違もないようです。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "を赤茄子で説明すると、その説明がうまくできたかできないか、よくと赤茄子が実によく似ている似ないで、はあなるほどと思う程度が大分違います。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "※と赤茄子の例はもっとも簡単なものでありますが、もう少し複雑になると、このはあなるほどだけで一篇の小説ができます。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉菜、赤茄子、葱、玉葱、大根、蕪、人参、牛蒡、南瓜、冬瓜、胡瓜、馬鈴薯、蓮根、慈姑、生姜、三つ葉――あらゆる野菜に蔽われている。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろこの連中のモットオは『野菜をしてことごとく赤茄子たらしめよ。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "マカロニと赤茄子とを共に料理すれば味よし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋には赤茄子をマカロニの附物という。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄酒を加うる時赤茄子のソースを交ぜれば味一層よし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○赤茄子スープは夏ならば生の物、冬ならば鑵詰の物を四十分間煮てバターを交ぜ、曹達を極く少し入れよく掻廻し別にスープかあるいは牛乳を沸してこの中へ注ぎ込むなり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○赤茄子は蛋白質八厘八毛、脂肪一厘、含水炭素三分六厘ありて九割余は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて食べる前にまた火へかけて葡萄酒を少し加えて赤茄子のソースを交ぜて米利堅粉でその汁を濃くするのですが略式にすれば加える物を減しても構いません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等のコロッケには先日お習いになった赤茄子ソースの上等をかけます」広海子爵「そんなコロッケはとても料理屋で食べられませんね」と初めて家庭料理の貴きを知りぬ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉や葱を入れたければ細かく刻んで一度煮たものを今の中へ巻き込むのです」玉江「上等の家庭料理にするとオムレツはどんな風ですか」お登和「家庭料理のオムレツは玉子ばかりで塩の外に少し唐辛の粉が入りまして油はサラダ油か上等のバターを使いますが掛汁が唐辛と赤茄子のソースです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは最初鍋で大匙一杯のバターを溶かしてコルンスタッチ即ち玉蜀黍の粉一杯をいためてその中へ壜詰の赤茄子ソースと牛か鳥のスープを加えて塩と唐辛の粉を混ぜたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茄子のサンドウィッチは大層結構ですが、毎度お話に出るマイナイソースを少し固く拵えてパンへ塗って生の赤茄子へ沸湯をかけて丸のまま皮を剥いて薄く切ってパンの間へ挟んで小さく切ります。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドウィッチへ入れる時はなるたけ固くして赤茄子でもあるいは外の野菜でも挟みます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二百二十五　赤茄子　お登和嬢「それからモー一つは今のようにブラウンソースばかりで和えた肉へ生玉子を入れて混ぜて塩胡椒で味をつけて長さ二寸親指の太さ位に丸めて中身にします。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは生の赤茄子を二つに割って絞ると種が出てしまいます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茄子は畠へ作ると沢山出来ますが食べ馴れない人は知らないで珍重しません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茄子の中をくり抜いて胡瓜や茄子へ肉を詰めた通りに詰めてテンピで焼いても結構です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菜でも赤茄子なんぞは畑へ作ると沢山出来て味も結構ですけれどもまだよくその味を知らない人が多いようです」第二百三十　赤茄子の味　赤茄子の味を知らざれば共に西洋料理を語るに足らず。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お登和嬢は先ほどよりの饒舌続け口の酸くなりしをも厭わず、家庭料理を世に広めたきが熱心とて再び語を継ぎ「玉江さん、西洋の野菜で赤茄子ほど調法なものはありません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川高田あかなすのや（浅茅庵）。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
