[
  {
    "uuid": "3f6d8953-aa04-5984-b85d-d58017612462",
    "entry": "赤茄子",
    "reading": {
      "primary": "あかなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
