    },
    "definitions": [
      {
        "index": 1,
        "gloss": "residue left after making starch syrup",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日飴粕について考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴粕という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴粕の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴粕が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴粕を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴粕について学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴粕の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴粕の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴粕が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴粕という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴粕という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴粕についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴粕を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴粕は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴粕について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴粕が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴粕は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴粕の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴粕は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴粕は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
    ],
