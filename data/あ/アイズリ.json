[
  {
    "uuid": "1ad97203-5fb0-5b01-8c38-162b7ed686e8",
    "entry": "藍摺り",
    "reading": {
      "primary": "あいずり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ukiyo-e print produced with various shades of indigo (and sometimes small amounts of vermilion or yellow)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、藍摺りは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは藍摺りが重要です。",
              "source": "幻辞"
            },
            {
              "text": "藍摺りに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では藍摺りが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で藍摺りについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から藍摺りについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では藍摺りについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では藍摺りが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では藍摺りが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に藍摺りは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において藍摺りは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に藍摺りを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に藍摺りをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で藍摺りが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、藍摺りの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は藍摺りを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は藍摺りに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で藍摺りについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から藍摺りは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは藍摺りを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夢の岩井半三郎は、いつも着つけがはっきりしないのだけれど、絵は、藍摺りの死に絵だった。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすい藍摺りが特色で、この豊春筆岩井半三郎のそれは、白無垢を着て悄然と立っているすがただった。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "千草を染めだした藍摺りの、元禄袖の着物に、葛布らしい、白の奴袴をつけて、素足に半之助のとよく似た、革草履をはいていた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　それでなくッてさえ、掏賊の同類だ、あいずりだと、新聞で囃されて、そこらに、のめのめ居られるものか。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "staining a pattern on fabric or paper by rubbing it with indigo leaves",
        "register": "standard",
