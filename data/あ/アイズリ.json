    "uuid": "1ad97203-5fb0-5b01-8c38-162b7ed686e8",
    "entry": "藍摺り",
    "reading": {
      "primary": "あいずり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
