[
  {
    "uuid": "8890e901-bad1-549d-b59a-e3938a1521c4",
    "entry": "余りにも",
    "reading": {
      "primary": "あまりにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "too much",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日余りにもについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "余りにもという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は余りにもの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には余りにもが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "余りにもを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは余りにもについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "余りにもの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は余りにもの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では余りにもが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "余りにもという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に余りにもという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では余りにもについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "余りにもを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると余りにもは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "余りにもについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では余りにもが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に余りにもは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により余りにもの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "余りにもは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に余りにもは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "事実我々が詩作の場合に、我々の周囲に一杯ある短歌や俳句の影響は余りにも浸入するといふやうな有様なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しきことは余りにも多過ぎます。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しき、余りにも美しきお光の死顔。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎の姓に返ってから死にたいと願っていましたが……、骨は本当は太宰さんのお隣りにでも入れて頂ければ本望なのですけれど、それは余りにも虫のよい願いだと知っております。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "書く方を放棄してから一週間余りにもなっていただろうか。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十二、十三と三日も経っとるのに下手人がわからんとは余りにも手｜緩いちゅうて、大目付から矢の催促じゃ」「ふうん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のかかり合った縁談の底に渦巻いていた極悪地獄のドンデン返しが、余りにも無残な恐ろしいものであった事が、初めて身に泌みてわかったらしく、眼を白くして唇をわななかしているばかりであったが、やがて、やっと心付いたように一心こめて両手をシッカリと拝み合わせた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬにしてもそんなに早く死ぬとは思つてゐなかつたし、案外癒るのだらうとさへ思つてゐた私は、『尿器をとつてくれ』といふ弟の声が、余りにも弱々しい時には腹さへ立てた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子は二十二の歳に、女専を卒業すると西洞院の骨董商へ嫁いだが、生れつき我儘なのと、新しい教育を受けていたために、古い因習の殻に閉じこもっている余りにも京都風の家風にいたたまれず、一年たたぬうちに、到頭婚家を飛び出して、実兄の小郷虎吉の下鴨の家へ、出戻り娘となって転がり込んだのである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何も済まんことあれへん、この家でお前が遠慮気兼せんならんことはない、当り前やという母の言葉に、余りにも謙譲であった以前の母とまるで違ったものを感じ、眼を閉じて、そんな言葉を痛くきいていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間から言っても、これが佐渡だとすると、余りにも到着が早すぎる。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう新潟の砂丘で、私がひどくもったい振り、あれが佐渡だね、と早合点の指さしをして、生徒たちは、それがとんでも無い間違いだと知っていながら私が余りにも荘重な口調で盲断しているので、それを嘲笑して否定するのが気の毒になり、そうですと答えてその場を取りつくろってくれたのかも知れない。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし普通の慣例の如くに然様いう社会事相を進捗させるには定基の愛着は余りにも深くて、力寿は死んで確かに我を捐てたけれども、我は力寿を捐つるには忍びなかった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると多可子は咄嗟の場合だから仕方がなかったとは云え、さっき政枝に云った余りにも自信ありげな自分の極言を顧みて途方にくれてしまった。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、そんなことぐらいで謹慎するには、この「首ったけ」侯爵は余りにも陽子に首ったけであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、問題は都亭の主人の責任といえば無論いえるが、しかし真のそして直接の原因はルンペン崩れの追い廻しの順平にあることは余りにも明白だ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局行きは家人にたのんで、すぐ眠ってしまいたかったが、女に頼むには余りにも物騒な時間である。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りにも感傷的なスタンダールが感じられて、いやなのだ。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、なにかの都合で途中下車をしないとも限らないのであるが、くどくも言う通り、余りにもあわただしい二人の様子が何か子細ありげにも思われた。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は臆病者でないと信じていながら、一時はなんとなく薄気味悪いようにも感じさせられたのは、われながら余りにも愚かであったと、又次郎は声をあげて笑いたくなった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を赧らめ、しばらく孔子の前に突立ったまま何か考えている様子だったが、急に豚の場違いであることを感じ、己と余りにも懸絶した相手の大きさに圧倒されていたのである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の美しさは、この国の人々の間に在っては余りにも稀なので、子路のこの傾向は、孔子以外の誰からも徳としては認められない。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、更に古代支那式なのは、この幼稚な策が、魯国内反孔子派の策動と相俟って、余りにも速く効を奏したことである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りにも彼のしそうな事、言いそうな事だったからである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の三造には、伯父の遺作を図書館に寄贈するのを躊躇する心理的理由が、もはや余りにも滑稽な羞恥としか映らない。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のマターファの場合の厳罰と比べて余りにも不公平である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時「自然詩人」は感興の対象なる事象物象をセンチメンタルに、あまりにも生理作用で書き付ける。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ここに一つ、ささやかな、ともすると埋もれるのではないかとさへ思はせる、あまりにも謙讓の良書が在る。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも腕前の差がひどかつたならば、その時には臥薪嘗膽、鞍馬山にでもはひつて一心に劍術の修行をする事だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にだんだんもの心がつき、比較によって自分と他とを評価する力が生れて、福慈岳の評判を聞いてみると、その秀でさ加減はあまりにも自分の資格とはかけ離れたものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
