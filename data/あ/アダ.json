        "examples": {
          "standard": [
            {
              "text": "毎日、仇について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の仇戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "仇の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "仇という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは仇について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "仇の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "仇に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは仇を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での仇は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、仇は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "仇は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な仇を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「仇」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「仇」という概念について深く考察する必要があります。",
              "source": "幻辞"
