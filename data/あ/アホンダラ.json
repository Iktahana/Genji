[
  {
    "uuid": "314146e8-1e29-5501-aad3-48fe9904edf8",
    "entry": "阿呆陀羅",
    "reading": {
      "primary": "あほんだら",
      "alternatives": [
        "あほだら",
        "アホンダラ"
      ],
      "is_heteronym": false
    },
    "grammar": {
