    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿呆陀羅について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿呆陀羅の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿呆陀羅が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿呆陀羅について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿呆陀羅の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿呆陀羅が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿呆陀羅という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿呆陀羅についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿呆陀羅は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿呆陀羅が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿呆陀羅は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿呆陀羅の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿呆陀羅は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿呆陀羅は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "阿呆陀羅経が人を笑はしてゐる。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがホンマの阿呆陀羅経だよ……スカラカ、チャカポコチャカポコチャカポコチャカポコチャカポコチャカポコ……　　　　　　　二スカラカ、チャカポコチャカポコチャカポコチャカポコ……　▼あ――ア――ああア。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "タタキ出します阿呆陀羅経だよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聾唖の木魚の阿呆陀羅経だよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏代りの阿呆陀羅経だよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世田沼主殿頭が、まことにみじめに失脚した時、それを諷した阿呆陀羅経が作られ、一時人口に膾炙したが、それを作ったのが貝十郎であると、当時ひそかに噂された。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これが彼の作った阿呆陀羅経なのである。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆陀羅経　この間放送局の嘱に応へて聯曲「菊づくし」をかいたとき、その中へ阿呆陀羅曲を配さうとおもつたが、いま果してよくそれを歌ひ得る寄席の音曲があるか否かを考へ、残念ながら中止してしまつた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は太平坊になつて残したかつぽれの名人初代梅坊主の阿呆陀羅経のレコード「ないものづくし」「日露戦争虫づくし」「出鱈目」「鳥づくし」の四種を愛蔵してゐるが、あの馴染深かつた故人の塩辛声が、大正年代の浅草風俗をまざまざ目先に蘇らせて来ていとなつかしい。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、私が親しく見た時代の梅坊主は舞台でたゞの一ぺんも阿呆陀羅経など演らなかつたが、嘗て芝新堀の願人坊主の巣窟に人となり、浪花節草創期にはかつぽれ一座は彼らと芸人の融通もし合ひ、たしか共通で鑑札の下附を願つた時代すらもあつたはずだから、梅坊主が阿呆陀羅経のベテランであつたとて不思議はない。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代木村重松の世話に砕けた道中附のセメの中では必ずや一ヶ所ギヤグを弄するのところがあつたが、それは阿呆陀羅経の切り節直前の手法を踏襲してゐるのである。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆陀羅経、俗にちよぼくれと唱へて、豆木魚には早間の三味線。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和戦前、ジヤズ化された阿呆陀羅経は「笑の王国」が採上げて、渡辺篤三益愛子の両君が歌つた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "二丁目の熊の相撲、竹川町の犬の踊り、四丁目の角の貝細工、その他、砂書き、阿呆陀羅、活惚、軽業なぞのいろいろな興行で東京見物の客を引きつけているところは、浅草六区のにぎわいに近い。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそばに児守や子供や人が大勢｜立止っているので、何かと近いて見ると、坊主頭の老人が木魚を叩いて阿呆陀羅経をやっているのであった。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆陀羅経のとなりには塵埃で灰色になった頭髪をぼうぼう生した盲目の男が、三味線を抱えて小さく身をかがめながら蹲踞んでいた。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "義太夫、清元、常磐津から、団十郎の連詞の口真似、阿呆陀羅経からトッチリトン、安来節から出雲節、芸のない奴は逆立をする。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は別だが、お前のほかじゃ、いっそあの盲目の阿呆陀羅坊主がこの一座じゃ罪がなくていい」　今松は言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十がらみの盲目の大坊主で、小さな木魚二つ持って阿呆陀羅経ばかり歌うこの座でたった一人の色物。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生せず、滅せず、垢つかず浄からず、増さず減らず」　というところへきて、このごろ世間で時花っている阿呆陀羅経のないものづくしの真似をする蝶丸爺さんのあざらしのような顔を次郎吉は思いだした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宮秘戯図といえば、これは東京の話だが、昭和戦前までいた坊主頭で寸詰まりの愛嬌のある顔をした春風亭柳丸という爺さん、売り物はおよそ前代の漫芸ばかりで百まなこ、ひとり茶番、阿呆陀羅経には犬猫の物真似。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで、おれのような阿呆陀羅経ならいざしらず、街中を竿を抜身でかついであるくばかはない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君の耳には阿呆陀羅経のように聞こえたろうが、あれは「還宮楽」という、そう容易くは聞かれない稀代の雅楽なのだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭訓往來なんてケチな事を云はずに、阿呆陀羅經でも何でもやつておくんなさい」　ガラツ八は、殺さば殺せと言つた調子でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿野郎、阿呆陀羅經つて、奴があるか、――こんな解らない野郎でございます、何分宜しく願ひます」　平次は、一所懸命に頼み込んで、マゴマゴするガラツ八を促し、いづれ稽古は明日の晩から、と言ふことにして引揚げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭訓往来なんてケチな事をいわずに、阿呆陀羅経でも何でもやっておくんなさい」　ガラッ八は、殺さば殺せといった調子でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿野郎、阿呆陀羅経って、奴があるか、――こんな解らない野郎でございます、なにぶん宜しく願います」　平次は、一生懸命に頼み込んで、マゴマゴするガラッ八を促し、いずれ稽古は明日の晩から、ということにして引揚げました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "追悼と言つたところで、改まつた催しではなく、阿呆陀羅經見たいなお經をあげ、お互ひに隱し藝を持寄つて、飮んで食つて、花火が打ち止んだ頃お開きにすればそれでよかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亀とろ思てるのや」　と言うと、「あほんだらやな」　と叱られ、それで存分に泣き声を出した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝ齢してよう読みをらん、あほんだらめ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
