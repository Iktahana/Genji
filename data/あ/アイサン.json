        "examples": {
          "standard": [
            {
              "text": "毎日、愛餐は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛餐が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛餐に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛餐が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛餐について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛餐についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛餐について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛餐が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛餐が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛餐は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛餐は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛餐を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛餐をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛餐が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛餐の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛餐を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛餐に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛餐について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛餐は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛餐を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雲雀料理ささげまつるゆふべの愛餐、燭に魚蝋のうれひを薫じ、いとしがりみどりの窓をひらきなむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が卓上に供ふるもの、愛餐酒盃の間、その魚の最も大なるものは正しく汝の所有である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエスの死は多くの人を贖う愛であることの象徴として、最後の晩餐は古今無比の愛餐でありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥で炬燵に当っている爺さんに向って、「おあいさんが来ていなさるというが……家へも来なさるだろう……。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは、外に出ている下駄や、桶などを取り入れて、薪を割っていた爺さんに向って、おあいさんは、もう、来なさらないと見える。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今頃、おあいさんは、山越して行けるだろうか……。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おあいさんが来たのだと思った。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は、おあいさんかと口に言おうとしたが、心に他の暗愁が萌して言葉を出さずにしまった。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おあいさんは今日はおいでじゃありませんか。",
              "citation": {
                "source": "蛾",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "おあいさんは台所の外の日向でお米をほして虫とりをしています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一大事業をやって、ほっとして、今おあいさんに夜具の袋を買いにやったところです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今度は派出婦のおあいさんやあの手つだいの若い娘さんやらだけが相手で、あすこへ引越すとき手つだってくれた人々は誰一人い合わせないのも感じ深うございました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
