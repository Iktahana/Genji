        "examples": {
          "standard": [
            {
              "text": "私は毎日アマチュア無線について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアマチュア無線の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアマチュア無線が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアマチュア無線について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアマチュア無線の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアマチュア無線が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアマチュア無線という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアマチュア無線についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアマチュア無線は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアマチュア無線が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアマチュア無線は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアマチュア無線の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アマチュア無線は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアマチュア無線は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "数年後にはアマチュア無線の人口（現在は約四十万人といわれている）をオーバーするほど、マイコンアマチュアはふえるだろうという人もいる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマチュア無線とマイコンとの組み合わせで友人のプログラムを無線を通して楽しんだり、モールス符号の自動解読やコールサインの判別、アンテナの調整等への応用も始まっているようだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校六年生でアマチュア無線の資格を取り、自作の通信機でコールサインを送りはじめたウォズニアックは、この時期から科学展への応募にも熱意を燃やした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本はやがて、アマチュア無線の専門誌『ＣＱ ｈａｍ ｒａｄｉｏ』を読むようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレクトロニクスのマニアにとって、受信機や送信機をさまざまに工夫して作り上げ、実際に電波を飛ばして作品を使ってみることのできるアマチュア無線は、腕を鍛え、新しい挑戦に打って出る格好の土俵だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "進学した地元の豊受中学校には、アマチュア無線のサークルはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧問を務めている数学部にでも顔を出してくれればと思ったが、アマチュア無線の免許を持ち、生徒たちのあいだではエレクトロニクスの天才と評判の松本は、高校の無線部にも所属していなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "発売日を待ちかねて雑誌を書店の店先で開くと、目次にはなかったが、ハム随想と題した各地のアマチュア無線家からの手紙の欄に自分の名前があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマチュア無線が主体の電気物理だったが、高校三年生にはデジタル回路を突っ込んで勉強している先輩がいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
