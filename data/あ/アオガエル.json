        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "カバレットのキャラバン、酒場から酒場へ近道の建札、夜の美粧院に吊された青蛙の料理写真にしたらんたん、足の化粧法、日本人を日本人らしく見せない整型学、醜いものをグロテスクにするための進歩主義、あわただしい木馬競走に見惚れる観衆の喝采。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹の青蛙がいつもそこにいた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく見ていると、その青蛙はきまったように後足を変なふうに曲げて、背中を掻く模ねをした。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙や青蛙が、そんな離れ業はしなからうと思つたが――勿論、それだけに、蓋も嚴重でなしに隙があればあつたのであらう。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばつたり風がなくなつて蝉の声　すこし風が出てきて青蛙なく・あんなところに網を張り蜘蛛のやすけさは・あすは雨らしい空をいたゞく",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "……△七月のはじめに、――　　葉の青さに青蛙ひつそり△七月のをはりに、――　　草も蛙もあを／＼としてひつそり△自然の推敲改作とでもいはうか。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "青蛙のような色で、疣々が立って、はあ、嘴が尖って、もずくのように毛が下った。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜、フランス製、百にちかい青蛙あそんでいる模様の、紅とみどりの絹笠かぶせた電気スタンドを、十二円すこしで買いました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前編の「青蛙堂鬼談」に幾分の興味を持たれた読者が、同様の興味をもってこの続編をも読了してくださらば、筆者のわたしばかりでなく、会主の青蛙堂主人もおそらく満足であろう。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からさした電燈の光で見ると、蜀黍の葉の兩側には點々として露の玉が宿つて居り、なほよく見るとその葉のまんなかどころにちよこなんと一疋の青蛙が坐つてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "秋風の音",
                "note": "青空文庫"
              }
            },
            {
              "text": "定刻の午後六時までに小石川の青蛙堂へ着到すると、今夜の顔ぶれはこの間の怪談会とはよほど変わっていた。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青蛙堂鬼談が今夜は青蛙堂探偵談に変ろうというのである。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　星崎さんは前回に「青蛙神」の怪を語った人である。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といってかさ高の郵便を青蛙堂主人のところへ持って来た。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『新小説』24年４月号／『岡本綺堂読物選集・４』青蛙房、69・５）",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の男　おまえさん達は青蛙神を知りませんか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "李中行　青蛙神……。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江南のある地方では、青蛙神と云って三本足の青い蝦蟆を祭るということだが……。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、その青蛙神がこの箱の中に祭ってあるのか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の男　青蛙神に酒と肉とを供えて祈祷すれば、どんな願いでも屹と成就するのです。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の男　ここらの人はよく知らないので、不思議に思うのも尤もですが、南の方へゆけば青蛙神を疑う者はありません。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてお近づきになったものだから、私の為にその箱をあけて、青蛙神を一度拝ませてくれませんかね。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い今夜は十五夜で、酒も肉も用意してあるから、それを青蛙神にそなえて、わたしに纏まった金を授けて下さるように祈っては下さるまいか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（李は月を祭りし酒と肉を持ち来りて、青蛙の前に供える。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男は再び呪文を唱うれば、青蛙は跳って元の箱に入る。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "李中行　あれは江南でいう青蛙神だ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あおがえるのように雪の上へ、四郎五郎左衛門が長々とのめったところを――左から小梅が一刀！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
