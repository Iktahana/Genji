        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒壁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒壁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒壁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒壁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒壁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒壁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒壁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒壁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒壁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒壁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒壁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒壁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒壁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒壁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒壁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒壁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒壁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒壁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒壁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒壁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "未だ荒壁が塗りかけになつて建具も張つてない家に無理無體に家財を持ち込んで、座敷の眞中に築いた夜具や箪笥の胸壁の中で飯を食つて居る若夫婦が目に付いたりした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅殻が古びてい、荒壁の塀は崩れ、人びとはそのなかで古手拭のように無気力な生活をしているように思われた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ荒壁が塗りかけになって建て具も張ってない家に無理無体に家財を持ち込んで、座敷のまん中に築いた夜具や箪笥の胸壁の中で飯を食っている若夫婦が目についたりした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見れば、四方は荒壁なる五坪ばかりの土間の中に筵の上に載せられたるものあり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作を忘れたか肥つた農夫よ田舍に飢饉は迫り　冬の農家の荒壁は凍つてしまつた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は掘立小屋にも近く、荒壁や天井の木組がそのまゝ眼につくものゝ、風雪に堪えるためか頑丈な柱や板を使って、それが、幾十年かの榾の煙で黒光りに光っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、牛肉でも、あの牛屋に吊したような赤と白茶の片脚だけのが、内地は百姓屋の軒や周囲の荒壁にぐるりと掛け連らねた唐辛子、唐黍、大根の如く、いや、それを十層倍にしたぐらいの大きさのものが、まるで牛肉の祭礼のようだといいと思えたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "松ヶ根の萩むら、孟宗の影の映った萱家の黄いろい荒壁、機の音、いかにも昔噺の中の鄙びた村の日ざかりであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは荒壁になっていて土の崩れた壁の穴から隣の室の燈火が滲みだしたように漏れて見えた。",
              "citation": {
                "source": "蕎麦餅",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一時ばかりして荒壁の隙から明りが見えだした。",
              "citation": {
                "source": "蕎麦餅",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通された二階はまだ荒壁のまゝで、唐紙もろくに入れてなかつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "業腹ながら爺さんの言葉通りに、荒壁の上塗だけは越してから塗ることにして、九日曉荷物を運び込む故、疊だけは必ず敷いておいて呉れ、と固くも頼んで、看護の片手間にこそ／＼と荷造りにかゝつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には小さな土藏が燒け殘つたといふやうに壞れた荒壁が赤く焦げて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降り続けば沼になり、炎天が続くと、粘質壌土は荒壁のように亀裂が立った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分ぬりかけて放つてある荒壁。",
              "citation": {
                "source": "モウタアの輪",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の傍の、これも矢張荒壁むき出しの休憩所で、かの女が浴衣がけになつたり、帯や何かを信玄袋に入れて明日帰つて来るまでと言つてそこの爺に頼んだり、白足袋をそのまゝ草鞋穿きになつたりするのを見ると、あまりに興に乗り過ぎて女の心を察しすぎなかつたといふやうにも考へられて、「大丈夫かなア！",
              "citation": {
                "source": "山間の旅舎",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野は、後へ下ろうとして、荒壁へ、どんと背をぶっつけたとたん、太股をつかれて尻餅をついた。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "樫の高い生垣で家を囲んだ豪家もあれば、青苔が汚なく生えた溝を前にした荒壁の崩れかけた家もあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "目につくのは、荒壁に干し連ねた瘠大根ばかり。",
              "citation": {
                "source": "湯ヶ島の数日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒壁のうしろに、小さい一枚畑があって蔬菜が作ってある。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の僕は自分の家の納屋の荒壁の汚れた部分を見てもひどく気持悪かつたが、他所の家の惨めな姿など見ると、すぐ夢にまで出て来さうな寒気を感じた。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒壁の乾きぐあい、撒き水の飛沫の形をみて、はたと気づいて、「ああ、あの形をとったら――」　と、そこから仕事がすらすらと運んだことも幾度あるか知れません。",
              "citation": {
                "source": "無題抄",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の前を、白壁や荒壁の家並について曲がって、踏み切りを渡ると、懐古園と呼ばれている城趾の前へ出る。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに荒壁一重のすぐ左隣は馬小屋で、右側は大家との共同便所だったので、不潔この上なしだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまんまその次の部屋だったか、その次の部屋だったか忘れましたが、小さな粗末な部屋へ抱え込まれますと、そこのコンクリートの荒壁に取付けられている一枚｜硝子の小窓から向うの部屋を覗かせられました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、それは、心を冷たく打ち挫ぎ、まるで枯れ尽した菅か、荒壁を思わす朽樹の肌でも見るかのような、妙にうら淋れた――まったく見ていると、その暗い情感が、ひしと心にのしかかってくるのだった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹藪の中の荒壁のままの宿屋（村で一軒しかない日本人の宿）に侘びしく寝た夜もあった。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
