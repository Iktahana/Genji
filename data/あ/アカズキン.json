    "definitions": [
      {
        "index": 1,
        "gloss": "Little Red Riding Hood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "つまり、あなたの上の苔がみな赤ずきんをかぶりました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、この子は、赤ずきんちゃん、赤ずきんちゃん、とばかり、よばれるようになりました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ちょいといらっしゃい、赤ずきんちゃん、ここにお菓子がひとつと、ぶどう酒がひとびんあります。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを赤ずきんちゃん、おばあさんのところへもっていらっしゃい。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、赤ずきんちゃんは、おかあさんにそういって、指きりしました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ずきんちゃんが森にはいりかけますと、おおかみがひょっこりでてきました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、赤ずきんちゃんは、おおかみって、どんなわるいけだものだかしりませんでしたから、べつだん、こわいともおもいませんでした。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤ずきんちゃん、こんちは。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おばあさんのおうちはどこさ、赤ずきんちゃん。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤ずきんちゃんは、こうおしえました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、おおかみは、しばらくのあいだ、赤ずきんちゃんとならんであるきながら、道みちこう話しました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤ずきんちゃん、まあ、そこらじゅうきれいに咲いている花をごらん。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、小鳥が、あんなにいい声で歌をうたっているのに、赤ずきんちゃん、なんだかまるできいていないようだなあ。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういわれて、赤ずきんちゃんは、あおむいてみました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「赤ずきんちゃんよ。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ずきんちゃんは、でも、お花をあつめるのにむちゅうで、森じゅうかけまわっていました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういうがはやいか、おおかみは、いきなり寝床からとびだして、かわいそうに、赤ずきんちゃんを、ただひと口に、あんぐりやってしまいました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ずきんちゃんは、でも、さっそく、大きなごろた石を、えんやらえんやらはこんできて、おおかみのおなかのなかにいっぱい、つめました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、赤ずきんちゃんのもってきたお菓子をたべて、ぶどう酒をのみました。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、赤ずきんちゃんは、（もうもう、二どと、森の中で横道にはいって、かけまわったりなんかやめましょう。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やれやれ、なんということだい、赤ずきん、おれたちといっしょに行くがいいよ。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、この子は、みんなに「赤ずきんちゃん」「赤ずきんちゃん」とよばれるようになりました。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、おかあさんが赤ずきんちゃんをよんで、いいました。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤ずきんちゃん、ちょっとおいで。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、赤ずきんちゃんはおかあさんにいって、約束のしるしに指きりをしました。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ずきんちゃんが森のなかへはいりますと、オオカミがひょっこりでてきました。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、赤ずきんちゃんは、オオカミがわるいけだものだということをちっとも知りませんでした。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんにちは、赤ずきんちゃん。",
              "citation": {
                "source": "赤ずきん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
