  {
    "uuid": "f6de3dce-8ff6-54b3-8921-d3587c037a67",
    "entry": "赤頭巾",
    "reading": {
      "primary": "あかずきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Little Red Riding Hood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今の時代の子供たちは、もはや昔の子供のやうに、フアンタスチツクで荒唐無稽のお伽話――森の妖精の話や、魔法使の話や、赤頭巾の話や、鉛の兵隊の話や、親指太郎の話や、ピノチヨの話や、惡魔が人間に化けた話や――などを悦ばないといふのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその赤頭巾は、苔のかんむりでせう。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、ちっぽけな赤頭巾に、ベゴ石め、へこまされてるんだ。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその赤頭巾は、苔のかんむりでしょう。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラにきいた話だと、これは『赤頭巾ちゃん』の歌らしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "願人坊は赤頭巾、目も鼻もなく、眞白なのつぺらぽんの赤頭巾。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよぼくれちよんがら、そもそもわつちがのつぺらぽんのすつぺらぽん、すつぺらぽんののつぺらぽんの、坊主になつたる所謂因縁きいてもくんねへ、しかも十四のその春はじめて」…………踊り出したる惡玉が願人坊の赤頭巾。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お松さんにお竹さん、椎葺さんに干瓢さんと…………手練手管」が何ごとか知らぬその日の赤頭巾、惡玉踊の變化もの。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神病者を魔者に憑かれたものとして、片端から焚き殺している光景を描きあらわしたもので、中央に居りまする、赤頭巾に黒外套の老婆が、その頃の医師、兼祈祷師、兼｜卜筮者であった巫女婆です。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に御存知とは思ひますが、荒筋を申上げますと、赤い頭巾をかぶつてゐるので赤頭巾と呼ばれてゐた可愛い少女が、いつものやうに森のお婆さんを訪ねて行くと、狼がお婆さんに化けてゐて、赤頭巾をムシャ／＼食べてしまつた、といふ話であります。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルヽ・ペローといへば「サンドリヨン」とか「青髯」とか「眠りの森の少女」といふやうな名高い童話を残してゐますが、私はまつたくそれらの代表作と同様に、「赤頭巾」を愛読しました。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、むしろ、「サンドリヨン」とか「青髯」を童話の世界で愛したとすれば、私はなにか大人の寒々とした心で「赤頭巾」のむごたらしい美しさを感じ、それに打たれたやうでした。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、作家といふものが、芥川の場合のやうに突き放される生活を知らなければ、「赤頭巾」だの、さつきの狂言のやうなものを創りだすことはできないでせう。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤頭巾といふ可愛いゝ親切な少女は森のお婆さんを見舞ひに行つて、お婆さんに化けてゐた狼に食べられてしまふ話が。",
              "citation": {
                "source": "エゴイズム小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に御存じとは思いますが、荒筋を申上げますと、赤い頭巾をかぶっているので赤頭巾と呼ばれていた可愛い少女が、いつものように森のお婆さんを訪ねて行くと、狼がお婆さんに化けていて、赤頭巾をムシャムシャ食べてしまった、という話であります。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ペロオといえば「サンドリヨン」とか「青髯」とか「眠りの森の少女」というような名高い童話を残していますが、私はまったくそれらの代表作と同様に、「赤頭巾」を愛読しました。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、むしろ、「サンドリヨン」とか「青髯」を童話の世界で愛したとすれば、私はなにか大人の寒々とした心で「赤頭巾」のむごたらしい美しさを感じ、それに打たれたようでした。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、作家というものが、芥川の場合のように突き放される生活を知らなければ、「赤頭巾」だの、さっきの狂言のようなものを創りだすことはないでしょう。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の中でブツブツ言うのだが、赤頭巾を食う狼よりも兇悪不逞で、人間の敵だ。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "快天王はまち子に赤頭巾をかぶせると云われましたが、これはフランスに有名なシャルル・ペロオの童話、フランス人なら日本人のカチカチ山と同じように知らない人のない童話です。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤頭巾は森のお婆さんの病気見舞に行って狼に食い殺されてしまうのですが、あの殺人の現場、あの深山の密林のような静かさと藁屋根のアズマヤこそは、赤頭巾の殺された森の中の小屋をいかにも暗示している如くではありませんか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            }
          ]
        }
