    "definitions": [
      {
        "index": 1,
        "gloss": "conger eel (esp. the common Japanese conger, Conger myriaster)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴子について考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴子という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴子の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴子が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴子を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴子について学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴子の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴子の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴子が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴子という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴子という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴子についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴子を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴子は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴子について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴子が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴子は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴子の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴子は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴子は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……　信濃國蒲原郡産の床屋職人で、氣取つたのが、鮨は屋臺に限る、と穴子をつまんで、「む、この鰌はうめえや。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下屋の水窓へ、折から横づけの船から、穴子、ぎんばうの畚、鰈、あいなめの鮹盤臺を、掬ふ、上げる、それ抱き込む、大鯛の溌剌たるが、（大盤臺）から飛び上つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばキスにしても、スズキにしても、鮎や鯛にしても、美しい魚はいくらもあり、又オコゼ、ゴンズイ、鷺穴子、ハモ、ガラ、メバル、ゴリのやうな醜いものもあるが、私達にまで感情や感覚から触れてくるところは、その法悦境の味いかんの好みにある。",
              "citation": {
                "source": "魚美人",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、本場ものの穴子の煮方が旨いとか、赤貝なら検見川の中形赤貝を使うとかで、よしあしはわけもなくわかるが、とにかくまず材料がよくなくては上等寿司には仕上がらない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴子　あなごもいろいろ種類があって、羽田、大森に産する本場ものでなくては美味くない。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、世界地図ほどある大きな大きな青磁のお皿が五つ、マグロの赤や小肌の藍や玉子の黄色や穴子の茶や海苔の黒や、その時分のことにして正しく五円くらいのお鮨が二〇三高地もかくやとばかり、色とりどりにギッチリ盛り上げられているやつを運んできた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチッと穴子だか鱧だかを小さく切って押して四角に御飯の上へ載せているやつを見ると、鰻よりも美味しいトロッとした江戸前の穴子の握りの色を目に浮かべてつくづく恋しがらないわけにはゆかなかった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、東京へ行って、握りの鮨を食べに入ったとき、酒を一本注文すると、鮨の上にのっかっている鮪や穴子を上剥ぎして酒の肴の代わりにした。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目、穴子など食う。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱入りの天ぷら、海老に、はぜ、穴子、そして、はしらのかきあげ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老四、穴子一、はぜ、きすに野菜、ピーマン等。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、あの食べては毒にも薬にもならない様な、おとなしげな蝦が、海中ではどの様な形相を示すものか、又海蛇の親類筋の穴子が、藻から藻を伝って、如何に不気味な曲線運動を行うものか、実際海中に入ってそれを見た人でなくては、想像出来るものではないのです。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "味覚としての「いき」は「けもの店の山鯨」よりも「永代の白魚」の方向に、「あなごの天麩羅」よりも「目川の田楽」の方向に索めて行かなければならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀の子、泳いでいる大｜章魚、あなご、ごんずい……大して面白い見せ物ではありません。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなごの味を知らねえ国から来たんじゃあるめえし、いいかげんにおしなすって、早く草香流の腕まえを貸してくだっせえよ」　しかし、右門は目をほそくしながら、伝六ではなく、そこのおやじに、ごく上のきげんでいったものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなごばかりと思ったら、こっちの蛤のほうもなかなかの味だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それらのいぶかしい右門の態度も、夕がたが来るとすっかりなぞが解けてしまったんですから、やはりこれは、われわれの親愛なる右門にあなごと蛤を二十個平らげさせてゆるゆる昼寝をさせたほうがましなくらいなものでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の郷里にては饂飩に椎茸、芹、胡蘿蔔、焼あなご、くずし（蒲鉾）など入れたるをシツポクといふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなごやえいの籠を背負い、栗の木のある峠を降りてくる漁婦の姿。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、あなごや赤えいを買い入れ、それを持って汽車で鶴岡の街まで出て、そこの親戚から交換で青物を貰って来るのだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かん茂の半ぺん、弁松のあなご、そういうものにも長く長く親しんで来たが、今ではもはやそれを本当に味わうことは出来ないなどと思いながら、また、そういうものがあたりの変遷と共にみんな亡びて無くなって行くことなどを悲しみながら、私は長い間その界わいを彷徨した。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥「矢張あなごなぞは長いのを二つに切りますよ。",
              "citation": {
                "source": "にゆう",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなごも、てんぷら、すしだねには向かない。",
              "citation": {
                "source": "美食多産期の腹構え",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝魚河岸からもってくる魚、あなご、貝等にはいろいろ手のかかる仕事が多い。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、代用品というのも当たらないかも知れないが、あなごとか、うなぎとかが同じ用に役立つ。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、はもと違って、あなごでもうなぎでも少々｜臭みがあるから、すりしょうが、または粉山椒を、茶をかける前に、箸の先にちょっと付けるくらい入れた方がいい。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなごの美味いのは、堺近海が有名だ。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、はも、あなご、うなぎの茶漬けを美味く食べようというようなことは、もとよりぜいたくな欲望であり、これを賞味する味覚の働きもデリケートなものであるから、これを志すほどの者は、材料のよしあしを充分注意してかからなくてはならぬ。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、はも、あなごの材料選択の際、馬鹿に大きいのは買わないように注意することである。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの大串はまだしも、あなごの大串に至っては、絶対におもしろくない。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
