    "definitions": [
      {
        "index": 1,
        "gloss": "Gate of the Celestial Rock Cave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天の岩戸について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天の岩戸の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天の岩戸が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天の岩戸について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天の岩戸の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天の岩戸が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天の岩戸という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天の岩戸についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天の岩戸は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天の岩戸が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天の岩戸は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天の岩戸の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天の岩戸は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天の岩戸は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "旅順の要塞が陥落すると、日本の国内は、もったいないたとえだが、天の岩戸がひらいたように一段とまぶしいくらい明くなり、そのお正月の歌御会始の御製は、　　富士の根ににほふ朝日も霞むまで　　　　　としたつ空ののどかなるかな　まさに日本は、この時、確実に露西亜を打破ったのだといってよい。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸の昔よりという意気組であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、天の岩戸扇石、一名辨慶七戻り、高天の原、紫雲石、天の岩戸胎内潜り、國割石、神樂石、大黒石、北斗石、寶珠石、大神石など是れなり。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『知識』でも、『力』でも、『眞』でも、『徳』でも、『淨化』でも、『豫言』でも、いかなる神の力でも開かれなかつた天の岩戸が、『笑』の女神の力によつて開かれた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照という女酋長が、出来上ることをたのしみにして織っていた機の上に弟でありまた良人であって乱暴もののスサノオが馬の生皮をぶっつけて、それを台なしにしてしまったのを怒って、天の岩戸――洞窟にかくれた話がつたえられている。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中将は、「腹をたててあなたが天の岩戸の中へはいってしまえばそれが最もいいのですよ」　と言って立って行った。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "十和田湖前より別路を取り、大黒天、天の岩戸、金の神、山の神、火の神、風の神などの巖窟を見て、西海の濱に出で、近く惠比須島を見て歸途に就き、織田氏の家に小憩して、黄昏の頃、宇樽部に歸りぬ。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸一貫のお酌は天の岩戸以来初めてだろう」「妾にもお盃を頂かして下さい」「オイ来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく、天照大神が天の岩戸に隱れ給うたときのやうに、まつたく蒼蠅なす、もろ／＼のまがつみが國内にみちたのでした。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角その暴行のために天照大神が天の岩戸の中に隠れてしまはれたので世間が暗闇となりました。",
              "citation": {
                "source": "農民自治の理論と実際",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久作は怒って天の岩戸へ駈けこむように石室へもぐったが、意外にもジッとこらえて坐禅をくんでいた。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには岩戸村があったり、天の岩戸があったり、高天原も天安河原もみんな揃いすぎるほど揃っている。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "高天原の伝説なぞというものはこういうノンキでクッタクのすくない連中が、いつのまにか自分のふるさとの伝説につくりあげてしまったばかりでなく、一々地名をつくりあわせ、天の岩戸をつくったり、念には念を入れて悦に入っていた連中の残した仕業のような気がするのだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの有りがたい神様を自分の里へ降りてきた神様に見立てて、天の岩戸だ、高天原だ、国見の丘だとせっせと聖地を仕立てながら、その聖地ともあろうところでカッポ酒をのませ小便をたれさせる。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして岩戸村もあれば天の岩戸神社もあって岩戸神楽ならば岩戸神社で演ずるのが何より適していそうなものであるが、そういうことは行われた例がないのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸のような入口をしめると、足の下の格子の下から四十八度の蒸気が音もなく人間をつつむ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、九州から奥州の果まで至るところにタカマガ原だの天の岩戸だの天孫降臨の地があるばかりか、特にその土地の名が古代史にも現れて土地の国ツ神と天ツ神の交渉が若干国撰の神話に残っていると、それに尾ヒレをつけて伝説をつくり、郷土の地名などにムリムタイにコジつけてあの神話もこの神話もとりいれる。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "よその国にはタカマガ原だの、天の岩戸だのと、方々に見られますが、ヒダには国史にツジツマを合せようとしたような跡はミジンもありません。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸の物語と結びつけられているあの「踏みとどろかす」ところの踊りであろう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸の前で、ウズメノミコトが神がかりの状態になって踊り狂ったと、古事記に書いてある。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればこのまっ暗に見える『天の岩戸』の中にどれほどの光がたたえられてあるか、あなたはびっくりなさるでしょう。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすれば此の真つ暗に見える『天の岩戸』の中にどれ程の光りが湛へられてあるか、貴方は喫驚なさるでせう。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、よいはさつさ――天の岩戸も押開く、神の社に松すゑて、すは三尺の剣をぬいて、神代すすめて獅子をどり……　御自慢の獅子舞をここへ持ち込むものもある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六区は岩見重太郎、七区は天の岩戸、十一区は羅生門、三区は提灯山じゃ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔天の岩戸〕　ここに速須佐の男の命、天照らす大御神に白したまひしく、「我が心｜清明ければ我が生める子｜手弱女を得つ一。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この五神以下多くは皆天の岩戸の神話に出て、兩者の密接な關係にあることを示す。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸――祓によつて暴風の神を放逐することを語る。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで天照らす大神は怪しいとお思いになつて、天の岩戸を細目にあけて内から仰せになるには、「わたしが隱れているので天の世界は自然に闇く、下の世界も皆闇いでしようと思うのに、どうしてアメノウズメは舞い遊び、また多くの神は笑つているのですか」と仰せられました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
