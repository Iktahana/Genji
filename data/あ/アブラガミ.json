        "examples": {
          "standard": [
            {
              "text": "油紙について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油紙は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油紙の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油紙について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油紙は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油紙の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油紙に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油紙が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油紙を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油紙の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油紙が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油紙が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油紙について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油紙は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油紙は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油紙は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油紙について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油紙の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油紙の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油紙の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "猟師は楓の細木を伐り朴し、枝葉を払わないままで、柱を立て、私たちの用意して来た、二畳敷ほどな油紙二枚を、人字形に懸けて、家根を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火の烟は、油紙の屋根の継ぎ目から洩れて、白い柱が立っては崩れ、風に折れて地を這いながら、谷中を転げてゆく。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が、ぴしぴし、音を立てて、盛に燃え出すと、樺の立木の葉が、鮮やかに、油紙の屋根に印して、劃然とした印画が炙り出される。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私は嘆息する、天地の間には、風が吹くのでなければ、霧が流れるのだ、そのたびに、天幕の中へ、ザアと小粒の雨がそそぎ入る、柱代りの金剛杖が、キュッと呻る、杭に纜われた小舟が、洪水に飜弄されるように、油紙の屋根が、ペラペラ動く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕が霧の中に、小さくぼんやり見える、四ツ柱に、油紙がぺらぺらとして、田舎の卵塔場のようだ、今まで、あそこに寝ていたのか知ら……この霧と雨の中を、たった紙一枚の下に……火光がパッとさす、霧の水球が、美しい紫陽花色に輝いたかとおもうと、消えた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石・苔・偃松（白河内岳に登る記）　野営を撤して、濡れそうなものは油紙で包み、岩伝いに北を向いて、大籠山と後で名をつけた一峰に達した、三等三角測量標が立っている、霧が吹雨を浴びせかけて、顔向けも出来なかったが、白峰山脈で、初めての三角標に触れたのだから、ちょっと去りにくい気がした。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉代吉と人夫が荷を卸して、油紙で庇を拵えてくれるのを、待ち兼ねて、石の中へ潜って寝た、雨はざんざ降りになって、庇から岩を伝わっては、ポタポタ雫が落ちる、防水布の外套に包まれて、ココアを一杯興奮剤に飲んだまま、飯も喰わずにたわいもなく痲痺したようになって寝た。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙の天幕には、チロチロと漣の刻むような光りがする、岩石の間に、先刻捨てた尻拭き紙までが、真赤にメラメラと燃えている、この窪地一帯に散乱する岩石の切れ屑は、柔らかく圭角を円められて、赤い天鵝絨色が潮しはじめた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻も早く修理したくて、まだ空襲警報が解除されていないのに、油紙を切って、こわれた跡に張りつけましたが、汚い裏側のほうを外に向け、きれいなほうを内に向けて張ったので、妻は顔をしかめて、あたしがあとで致しますのに、あべこべですよ、それは、と言いました。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏と陰部とを小さなガーゼで被うてある外は、死體にのみ特有な支那の桐油紙のやうに鈍い冷たい青黄色い皮膚が溢れるやうな朝の光線の下に曝されてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦に、横に、仰向けに、胴油紙の上に乗せた。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と一言、婦の聲で言ひましたさうです……　おやと思ふと、灰色の扉が開いて、……裏口ですから、油紙なんか散らかつた、廊下のつめに、看護婦が立つて、丁ど釣臺を受取る處だつたんですつて。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、それはともかくも、話説をせんけりゃ解らん」　馭者は懐裡を捜りて、油紙の蒲簀莨入れを取り出だし、いそがわしく一服を喫して、直ちに物語の端を発かんとせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その男を、年配、風采、あの三人の中の木戸番の一人だの、興行ぬしだの、手品師だの、祈祷者、山伏だの、……何を間違えた処で、慌てて魔法つかいだの、占術家だの、また強盗、あるいは殺人犯で、革鞄の中へ輪切にした女を油紙に包んで詰込んでいようの、従って、探偵などと思ったのでは決してない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の山を越え、沼津に到り、四方八方捜しまはり、やつと一つ、二つの美事な苗を手に入れる事が出来、そいつを宝物のやうに大事に油紙に包んで、にやりと笑つて帰途についた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、私の結婚式の時に用いただけで、家内は、ものものしく油紙に包んで行李の底に蔵している。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙で包んでそれから油紙で包んで紐でゆはへて差し上げろ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "床にはずっと渋色の油紙が敷かれていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中は全部油紙を敷詰めた温突になっていて、急に温い気がむっと襲った。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙に火が附いた以上の雄弁の大光焔がどうして燃上らずにおられよう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天婦羅が揚るのも忘れて、何を取りに行ったのかと思っていると、やがて油紙に包んだものを持って降りて来た。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして襤縷に包み、更に油紙に包んで八つの小包にしてリヤーカーの箱の底に詰め、その上へ三尺ばかりの高さの四体の人形を積んで掩隠した。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引出して見ると一箇の黒い油紙包である。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはその屍体を診察した養父の話ですがね……」「成る程……しかし屍体以外には……」「屍体以外には、ポケットの中に油紙に包んだ巻煙草の袋と、マッチと、焼いた鯣が一枚這入っていたそうで、弁当箱の中味や、水筒の酒も減っていなかったそうです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」四十七　愛吉は店の箱火鉢を引張り寄せ、叩き曲げた真鍮の煙管を構え、膝頭で、油紙の破れた煙草入の中を掻廻しながら少し傾き、「ト、おもしろい談？",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は庭場の上がり口へ回ってみると煤けて赤くなった障子へ火影が映って油紙を透かしたように赤濁りに明るい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ押借りであると見きわめた番頭は、彼等が何を取り出すかと見ていると、その風呂敷からは血に染みた油紙が現われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に油紙を取りのけると、その中から一つの生首が出たので、番頭もぎょっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
