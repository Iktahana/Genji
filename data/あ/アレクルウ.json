[
  {
    "uuid": "c4587d91-7bb7-52bc-8895-8763e377104d",
    "entry": "荒れ狂う",
    "reading": {
      "primary": "あれくるう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to rampage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒れ狂うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒れ狂うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒れ狂うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒れ狂うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒れ狂うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒れ狂うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒れ狂うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒れ狂うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒れ狂うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒れ狂うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒れ狂うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒れ狂うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ狂うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒れ狂うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "印度人の小作りなのが揃って、唯灰色に荒れ狂うスクリーンの中で、鑿岩機を運転しているのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして新約の時代に到って、サタンは堂々、神と対立し、縦横無尽に荒れ狂うのである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは舟の上に立っていて、御台場に打付ける浪の荒れ狂うような処へ鉤を抛って入れて釣るのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の血はさらに逆流し荒れ狂う。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "列仙の集まる蟠桃会を擾がし、その罰として閉じ込められた八卦炉をも打破って飛出すや、天上界も狭しとばかり荒れ狂うた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗の怖れる二百｜十日の前一日、二三日来の驟雨模様の空がその朝になって、南風気の険悪な空に変り、烈風強雨こもごも至ってひとしきり荒れ狂うていたが、今思うとそれが何かの前兆でもあるかのように急にぱったり歇んで、気味悪いほどに澄んだ紺碧の空が見え、蒔きずての庭の朝顔の花に眼の痛むような陽の光が燃えた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の葉を叩くスコールの如く、麺麭の樹に鳴く蝉時雨の如く、環礁の外に荒れ狂う怒濤の如く、ありとあらゆる罵詈雑言が夫の上に降り注いだ。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下には荒れ狂う白浪が野獣が牙をむいたようになっていた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、この辺から、文脈がますます奇怪に荒れ狂う。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、鎮めたまえ、荒れ狂う流れを！",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メロスは、ざんぶと流れに飛び込み、百匹の大蛇のようにのた打ち荒れ狂う浪を相手に、必死の闘争を開始した。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に彼の心は、荒れ狂うて風雨の響の中に溶けて行つた虚無が彼の胸に扉を開いてゐた。",
              "citation": {
                "source": "ランプの明滅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこうした懸命な努力は、降りしきる雪と、荒れ狂う水と、海面をこすって飛ぶ雲とで表わされる自然の憤怒の中で行なわれたのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは丁度鏡を取り上げた船の上の景色で、荒れ狂う波の上には、月の光りが物凄く輝いて、化物の姿を照しておりました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、わがホ型十三号潜水艦は、風雨はやや治りかけたが、まだ意地わるく荒れ狂う波浪にもまれながら、じっと海面に浮かんでいた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島戦隊は、この騒をよそに、風雨荒れ狂う暗闇の南シナ海をついて、ぐんぐん北上してゆくのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそういう盲目的な意志を貫ぬこうとして荒れ狂う現実を、人間の打ち立てた一定の法則の下にしっかと組み伏せようとする、それこそが共産主義者の持つ大きな任務ではなかったか。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイドは、この「アンドレ・ワルテル」の中に、青年のうちに荒れ狂う肉的なものに対する戦いを表現しようとした。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威どころか、荒れ狂う姿を呆然として袖手傍観して居るという有様です。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言って、できるだけ我が儘を言って、少しでもそれが容れられないと荒れ狂うようにして乱暴した。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また向う側の監房で荒れ狂う音がする、怒鳴り声がする、歌を歌う、壁板を叩いて騒ぎ立てる。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "成経　わしは昨日巌の上に立って、一そうの船も見えない、荒れ狂う海を見ていたとき、強い強い誘惑を感じた。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れ狂う海の上に利鎌のごとき月かかる。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外に雨は車軸をながし海から荒れ狂う風は鳴れど私の小さい六畳の中はそよりともせず。",
              "citation": {
                "source": "海辺小曲（一九二三年二月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空漠としたなかにあって、荒れ狂うものに攫われまいとしているし、径や枯木も鋭い抵抗の表情をもっていた。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何がこのように荒れ狂うのだろうか）今迄に感じたことのない不思議な新鮮な疲れだ。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は一刻も娘のことが忘れられなくて、その日その日の天候と一緒に、荒れ狂うような気持ちだった。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年夏、荒れ狂う暴圧のもとに、最初の＊＊＊＊＊が＊＊停止に会い、関係者全部が検挙投獄されたことは、日本のプロレタリアートの＊＊＊＊史上に特筆さるべき有名な重大事件であるが、丁度、彼等の結婚もその時期に当たっていた。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな船は、あれくるう海の上を、ゆれながらも、矢のように速くつき進んでいます。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、もうこれ以上あれくるう海の中をおよぐことはできなくなっていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
