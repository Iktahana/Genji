[
  {
    "uuid": "d90e281e-18f0-51c3-9e0b-a5f7edce0aaa",
    "entry": "天路",
    "reading": {
      "primary": "あまじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deva realm (svarga)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天路について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天路という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天路の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天路が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天路を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天路について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天路の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天路の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天路が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天路という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天路という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天路についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天路を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天路は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天路について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天路が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天路は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天路の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天路は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天路は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かしこを高く天路を翔けさる鳥のやうにひとつの架橋を越えて跳躍しよう。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天路巡歴おれはかんがへるおれの長い歴史からなにをして來たかなにを學問したかなにを見て來たか。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだんとおれは天路を巡歴した異樣な話だがおれはじつさい　獨身者であつた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよに紅く紅く、ひようひようと立ちのぼる雪の焔の天路さしいよよ尽きせね、消えてつづき、消えてつづけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――プラトオ、汝が浄きを高きを天路の栄と云ひし霊をぞ守りて、この森不断の糧、奇かるつとめを小さき鳥のすなる。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて大路の北の涯、天路に聳る層楼の屋根にとまれり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天路を聞けばなつかしや、千鳥｜鴎の沖つ波、行くか帰るか、春風の――　そのあたりからは、見物の声が章句も聞こえて、中には目金の上へ謡本を突上げるのがあり、身動きして膝を敲くのがある。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はプラトンの本もまたアリストテレスの本も読んだことはない、ただイエス・キリストの恩恵にあずかった憐れなる罪人であるから、ただわが思うそのままを書くのである」といって、“Pilgrim's Progress”（『天路歴程』）という有名なる本を書いた。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はプラトンの本もまたアリストテレスの本も読んだことはない、ただイエス・キリストの恩恵にあずかった憐れなる罪人であるから、ただわが思うそのままを書くのである」といって、\"Pilgrim's Progress\" （『天路歴程』）という有名なる本を書いた。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・バンヤンの作たる The Life and Death of Mr. Badman（悪人氏の生死）は、ある意味において『天路歴程』以上の傑作であると思われるが、英人自身は余りこの書を貴まないのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こかげいづる鶯を、春の愛子にたとへば、汝は寵なき鄙の少女、行方の西を慕ひて、薄月させる野の空、はてなき天路を走り去りぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなた天路のはづれに、白衣の靡きゆららに、今宵し六日のかたわれ月、（さはあえかなる病女の夕眺めするなよびや、）さ青のまなじり伏目がちに。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた右手なる側、圓葉柳のしげみに、夏野の色鳥ねぐらさすや、夢かの心地こそろと忍び羽振のささめき、――響きよさながら消ぬる程に、深まりわたる靜けさ、天路の足音も聞きや得まし。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはバンヤンの『天路歴程』や、ダンテの『神曲』に比して、優るとも決して劣らぬ感銘を、この求道物語からうけるのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "やをれ、今天路に虹を、野に花を、眞闇に星を、黎明の空を、あからめ、わだつみの浪をいろどる選人を召せよ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七『ひたぶる心――汝が眼には、花は天路の※惑星明日は莖葉の三の座に、巖のひかりも見るわいな、『淨まる戀のゆるされ』を。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月三十日）　　　　　＊　　　＊　　　＊　　　　　天路歴程　Pilgrim's Progress を天路歴程と翻訳するのは清の同治八年（西暦千八百六十九年）上海華草書館にて出版せる漢訳の名を踏襲せるにや。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば生命水の河の詩に「路旁生命水清流、天路行人喜暫留、百菓奇花供悦楽、吾儕幸得此埔遊」と云ふが如し。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "天路歴程　僕は又漢訳の Pilgrim's Progress を持つてゐる。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピルグリムス・プログレスは、日本でも訳して天路歴程と云ふが、これはこの本に学んだのであらう。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「路旁生命水清流　天路行人喜暫留　百果奇花供悦楽　吾儕幸得此埔遊」――大体こんなものと思へば好い。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "天路歴程の読者の中にも、あんな麗人があつたかも知れない。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が行く天路に入らぬものなれば長きかひなし武蔵野の路　何時の日であつたか、皆で多摩墓地へ詣でた事がある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の辿られる天路へ之が通ずるものならこの長い長い武蔵野の路もその甲斐があるのだがと、この一些事さへ立派な歌材を提供したわけであつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高いバンヤンの「天路歴程」なども到底この「西遊記」の敵ではない。",
              "citation": {
                "source": "愛読書の印象",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんななまやさしいあまじゃありません」と卯兵衛は吐き出すように云った、「それができるくらいならとっくにやってますよ」　おきぬという女の、臼のような頑丈な躯つきや、油で光る赤毛の小さな髷や、まっ白に塗りたてた平べったい、頬骨の尖った顔や、露骨なながし眼を思いだして、登は背中がぞくぞくするのを感じた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
