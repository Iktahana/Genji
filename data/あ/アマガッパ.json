        "examples": {
          "standard": [
            {
              "text": "私は毎日雨合羽について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨合羽の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨合羽が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨合羽について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨合羽の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨合羽が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨合羽という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨合羽についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨合羽は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨合羽が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨合羽は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨合羽の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨合羽は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨合羽は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同一早饒舌りの中に、茶釜雨合羽と言うのがある。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナイアガラ見物の際に雨合羽を着せられて滝壺におりたときは、暑い日であったがふるえ上がるほど「つめたかった」だけで涼しいとはいわれなかった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、雨合羽着た郵便屋さんと、ふと顔を見合せ、「あ、ちょいと。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば島田｜髷の娘の、紫地の雨合羽に、黒｜天鵝絨の襟を深く、拝んで俯向いた頸の皓さ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、かし本屋の店頭でもそうだし、ここでの紫の雨合羽に、塗の足駄など、どうも尋常な娘で、小説家らしい処がない。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき二見雨合羽にて抜き足、差し足、来て戸の隙より覗く。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした自分たちの、または農場から借物のレインコート、雨合羽、軍人マントの一行五人が、案内の技手君を先きに立てて、全くの濡れしずくになって飛び込んだが、其処がイワン・クリロフの家の入口であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか家にいてくれと、ちょうど雨が窓を打つ音を聞いた細君は頼むのだが、いくら言っても聞かずに大きな雨合羽を引っかけて外へ出て行ってしまった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただ松の下で、行李を解いて、雨合羽を引絡ううちも、袖を絞ったというのですが。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "体格の立派な方は、雨合羽を羽織っているので、服装は見えなかった。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が車を並べて停車場に着いた時、プラットフォームの上には雨合羽を着た五六の西洋人と日本人が七時二十分の上り列車を待つべく無言のまま徘徊していた。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、余程過ぎてから、雨合羽を着た監督が、漁夫の寝ているところへ入ってきた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――浅川が雨合羽を着たまま、隅の方の椅子に大きく股を開いて、腰をかけていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "当直下士官は、すっかり雨合羽に全身をつつみ、胴中を鉄索にしばりつけて、すっくと立っている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたのか、制帽を耳のところまで被り、服の上にひっかけている雨合羽は襟を立てていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨合羽など着こんで、雨なんかちっとも降っていないじゃないか」　全くそのとおりであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、雨合羽を着た男がこっちへ逃げたのだろう」　番兵は眼をぱちくりさせながらいった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "点燈夫の雨合羽の襞が遠くへきらと光りながら消えていった。",
              "citation": {
                "source": "赤い着物",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ通う飛脚の荷車の上には破れた雨合羽がかかっていた。",
              "citation": {
                "source": "赤い着物",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども本当に考えてみますと、実際に私達のいるものは五時間ですから、どこかの織物工場で五時間働いて織物をつくるなり、どこかのゴム工場で五時間働いてわれわれのはく靴や雨合羽をつくって、それらのものがお互いの等しい価値で運転するならば、あとの五時間は誰かのために働いていることになる。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリーヴ色の雨合羽が袖だたみにして前においてある。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表門から、往来へ出ると、雨合羽、饅頭笠の人々が、急ぎ足に行き通っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雨合羽を着て「まごまごしておったなら、打った斬るか。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みさかいもなく兵隊式の帽子を彼の頭にのせ、彼の着ていた外套を無理に脱がせ、青年団式の雨合羽を着せた。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい雨合羽をまとい、魚籠をさげて、朝食後出かけてゆき、八丁滝の急坂を登り、菅沼尻から小舟で山の家まで漕いでゆく。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も雨が今にも降りそうに見え、私は鎌倉に雨合羽も置いてあるから止めましょう、と云ったのに、Ａはガン張り、途中から雨に降られて少しは困り乍ら、雨中の風景を美しく眺めて来た。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸、それには好適の古羽織が一枚ある、これは全部三味線糸で織ったもので、重さは普通木綿の二三倍もある、雨合羽代用などにしながら持て余していた。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、厩の前へ行つてみると、雨合羽に似たものが一枚棄ててある。",
              "citation": {
                "source": "河童酒宴",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
