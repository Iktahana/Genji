        "examples": {
          "standard": [
            {
              "text": "毎日、愛情深いは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛情深いが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛情深いに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛情深いが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛情深いについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛情深いについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛情深いについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛情深いが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛情深いが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛情深いは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛情深いは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛情深いを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛情深いをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛情深いが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛情深いの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛情深いを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛情深いに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛情深いについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛情深いは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛情深いを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御前様は実に善良で愛情深い女性で、現在不当な扱いを受けております。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情深いものであろう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は恐らく誰よりも愛情深い態度でいつも彼に臨んだ。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ氏夫妻はお子さんがなく愛情深い方々でした。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は愛情深い男であった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はパウル・フレミンクという愉快な詩人で、コーカサスやイスパハンへ自由な旅を試み、戦争の野蛮や生活の悲哀や時代の腐敗などの中にあって、純潔な愛情深い清朗な魂を失わなかった人である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのつまらない事柄も、彼の愛情深い心にとっては非常に大事なことだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の挙措と同じように愛情深い慎ましい手紙だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情深い父親を傍に伴ってる娘のもとにきて秋波を送るということは、一つの卑劣なる行ないではないか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に、側にハッピーで愛情深い存在がいるような、温かく愉快な感じがした。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
