    "entry": "合い口",
    "reading": {
      "primary": "あいくち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chum",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合い口は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合い口が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合い口に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合い口が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合い口について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合い口についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合い口について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合い口が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合い口が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合い口は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合い口は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合い口を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合い口をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合い口が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合い口の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合い口を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合い口に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合い口について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合い口は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合い口を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "関さんは例の通りの好人物、大島さんは話し好きの合い口――清三にとってこの小学校はあまりいごこちの悪いほうではなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎共やっちまえ」「合点だ」　と、児分の面々、あいくち、長ドスをひらめかして斬ってかかる。",
              "citation": {
                "source": "花模様女剣戟",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "結末は、二人が解けがたく抱擁し合っていて、二人の唇が相触れているのに、一人が相手のからだの帯の上あたりへ、広刃のあいくちを、しかも充分な理由があって刺し通すというほどに、ごく悲しいものだった。",
              "citation": {
                "source": "衣裳戸棚",
                "author": "DER KLEIDERSCHRANK",
                "note": "青空文庫"
              }
            },
            {
              "text": "この母子の短かい対話そのものが、疑問の余地のないほどあからさまに事情を語っているのであって、しかも十二月であるということは、こちらにとって心臓へあいくちを突込まれるかに似た思いを致させられるのである。",
              "citation": {
                "source": "年の瀬の音",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし刹那、おばさんの※大虫は、包のふところへ深く入って、そのワキ腹へ明晃々のあいくちを一ト突き加えていたし、解宝は後ろから抱きついて動かさず、また解珍は、包の佩剣を抜いて包の胸元を刺しつらぬいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
