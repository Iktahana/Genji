        "examples": {
          "standard": [
            {
              "text": "私は毎日甘鯛について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘鯛の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘鯛が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘鯛について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘鯛の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘鯛が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘鯛という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘鯛についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘鯛は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘鯛が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘鯛は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘鯛の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘鯛は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘鯛は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おじいさんは、甘鯛と、鮪と買って、お酒を提げて戻ったんです。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春葉はこれより先、ぐぢ、と甘鯛の區別を知つて、葉門中の食通だから、弱つた顏をしながら、白い差味にわさびを利かして苦笑をして居た。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯端で、日くれ方、ちょっと釣をすると、はちめ（甘鯛の子）、阿羅魚、鰈が見る見るうちに、……などは羨しい。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘鯛、いとより鯛、魴※の濡れて艶々したのに、青い魚が入交って、鱚も飴色が黄に目立つ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○本文の如く魚類をシタフェと為すには鯛、黒鯛、鱸、甘鯛等淡泊なる魚をよしとす。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しろ私達は甘鯛を釣つて居たんですからな、その甘鯛仕掛にかゝつたぶりですから、仕掛をきられぬやうに引つぱり上げる迄の苦心は……」　草人さんは身振り豊かに冷々しながら釣り上げる迄の苦心を説明し初めた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山田なんざあまだいいわ。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに漬け込む魚類は大体決まっていて、まながつお、あまだい、太刀魚が最適である。",
              "citation": {
                "source": "生き烏賊白味噌漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと熱海の漁場に揚がるあじ・いか・かれい・あまだいなど、さかなの種類も相当のものだが、干上がりの条件として、もってこいの浜風と気温に恵まれている点が、味をよくする最大原因となっているらしい。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あじ・かれい・うるめ・きす・あまだい、いずれも本格の干し加減で食わしてくれるとすばらしく美味い。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまだいの干もの、これは乾し切ったものが特殊な味を持ち、素敵な美味さを発揮している。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまだいを上方ではぐちと言って、若狭小浜産を第一と称賛しているが、ぐちとやなぎがれいだけは、むしろ興津地方が優っている。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ興津のあまだいは若狭ものに較べて、ウロコが食えない恨みがある。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウロコごと焼いて食べるあまだいは、また格別の風味を持つものであるが、興津にはそれが期待できない。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方で一流のきすの醤油干し、若狭の松葉がれい、興津、熱海のあまだい、静岡のやなぎがれいなどが、なんと言っても干もの中での高級に属し、他はやや下手ものに属するものであるかも知れない。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に忘れてならないものに、関西のうるめ、関東のあまだいの干ものがある。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああまだいるわ」「いったい何なんですか」「御覧なさい。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
