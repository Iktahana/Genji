              }
            },
            {
              "text": "（「ユーモアクラブ」昭和十五年二月号）",
              "citation": {
                "source": "睡魔",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「ユーモアクラブ」昭和十四年十月号）",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「ユーモアクラブ」昭和十六年五月号）",
              "citation": {
                "source": "火星の魔術師",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八（昭和三年）五月二十一日、西アフリカのゴールド・コースト州アクラ港で研究中の黄熱病にかゝり殉道の死を遂げた時は全世界が哀悼した。",
              "citation": {
                "source": "野口英世博士の生家を訪ひて",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビヤの沙漠をわたる熱風を満面に浴びて遠くシナイの山顛を眺め、火のような阿弗利加の、空にはアクラブ Akrab, 10000ft. の英姿を仰いで、いくたび船の上で山を讃美したろう。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（〈ユーモアクラブ〉昭和十四年八月号発表）",
              "citation": {
                "source": "昆虫図",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い東京……近い東京……近い東京……遠い東京……その東京の街々が、アアクライトや、ショウヰンドウや、おひおひとシイズンになつてくる劇場の廊下や、楽屋や、それらが眠らうとして居る彼の女の目をゆつくり通り過ぎた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、カレタのやや北方に設けられたアクラの港から、地峡を横ぎって造船材料を太平洋岸に運ぼうとしたのであるが、それが実に難事業であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず第一に、バルボアがアクラまで行って見ると、土人の襲撃によって小舎は破壊され守備兵は全滅していた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に第三に、太平洋まで運んで見ると、船材はあまりに永くアクラの海岸に放置してあったために、虫に穴をあけられて、船材として用いられなくなっていた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "火燵にあたりながら、「ユーモアクラブ」へ随筆五枚書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
