[
  {
    "uuid": "46f27259-10fc-50b5-8bf4-a412ba559a5b",
    "entry": "行灯",
    "reading": {
      "primary": "あんどん",
      "alternatives": [
        "あんどう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paper-enclosed standing lantern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日行灯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "行灯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は行灯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には行灯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "行灯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは行灯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "行灯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は行灯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では行灯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "行灯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に行灯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では行灯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "行灯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると行灯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "行灯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では行灯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に行灯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により行灯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "行灯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に行灯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "博覧会のイルミネーションを観て昔の行灯時代の事を想えば、今更のように灯火の進歩に驚かれる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "褄は花の如く開かねば趣ないといふ廃頽的の江戸趣味も困るが、この理由をもつて、だからこそ和服も行灯式のスカートにせよといふ改良論者はまた行き過ぎる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この条件に最も適合したものは行灯であった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」な空間に漂う光は「たそや行灯」の淡い色たるを要する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは堤に桜を植え付けて、行灯をかけたり、雪洞をつけたりして、新小金井などという一つの名所になってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "内の人は唯今留守ですと答えると、それではおかみさんに逢わせてくれというので、お徳はともかくも表の戸をあけると、ひとりの痩形の女が夜目にも白い顔をそむけて、物思わしげに悄然とたたずんでいるのが薄暗い行灯の火にぼんやりと照らし出された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはその夢ばなしは作り事で、この女はかのむらさき鯉に何かの因縁のあるものではあるまいかという疑いも湧き出して、かれは更に薄暗い行灯の灯かげで女の姿をよく視ると、女の髪は水を出て来たように湿れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても亭主はどこへ行ったのであろう、もしや留守のあいだに帰っているかも知れないと、急いで内へはいってみると、内は行灯を消したままで藤吉はまだ帰っていなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町は知らず、我々の住む山の手では、商家でも店でこそランプを用いたれ、奥の住居では大抵行灯を点していた。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても勿論長屋の行事のこと故、戸毎に絵行灯をかゝげ、狭くるしい路次の中で界隈の男女が、トテテラチンチン、トテテラチン、チンテンホイトコ、イトハコト、ヨヨイトサッサと訳の分らぬ唄にあわせて踊るだけの事だが、お君は無理をして西瓜二十個を寄進し、そして踊りの仲間に加わった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "行灯や蝋燭の微かな灯りが、唯一の照明であつた昔は、平安朝の京都や唐の長安の都でさへ、おそらく今人の想像ができないほど、寂しく真闇なものであつたらう。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内で私は歴史的に読者の過去を蕩揺する、草双紙とか、薄暗い倉とか、古臭い行灯とか、または旧幕時代から連綿とつづいている旧家とか、温泉場とかを第一に挙げたいと思います。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜垣の主人は、鼈四郎を連れて、鴨川の夕涼みのゆかから、宮川町辺の赤黒い行灯のかげに至るまで、上品や下品の遊びに連れて歩るいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた梁や柱に黒光りがするくらい年代のある田舎家の座敷を、そっくりそのまま持ち込まれた茶座敷には、囲炉裏もあり、行灯もあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気行灯の灯の下に、竃河岸の笹巻の鮨が持出された。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰元は驚き恐れつゝ件の部屋を覗けば、内には暗く行灯点りて、お村は脛も露に横はれる傍に、一人の男ありて正体も無く眠れるは、蓋此家の用人なるが、先刻酒席に一座して、酔過して寝ねたるなれば、今お村が僵れ込みて、己が傍に気を失ひ枕をならべて伏したりとも、心着かざる状になむ。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒行灯に「金之助」といふ名が見えたから、多分今のも、あのもう年増の女の三味線弾の長唄であつたらう。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、風が来て有明の行灯の灯を消した。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ますます驚いて手探りに行灯に灯を点けて見ると、畳は皆室の隅に積み重ねてあった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の者は行灯の前で、妖怪に対する意見を戦わしていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、見る間に行灯がまた浮きあがって人が持って歩くように室の中を廻りだした。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶碗や行灯が、自然に浮きあがるものではない、眼に見えなくても、其の周囲には妖怪がいて、持ちあげているから、其処を捕まえさえすれば好い」と、云うようなことを物知り顔に説明する者もあった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平太郎は行灯の前に一人ぽつねんと坐って前夜のことを考えていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行灯の光がほっかりと膝の上にありました。",
              "citation": {
                "source": "薬指の曲り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来てその猿を庭の鉤に吊し、手足を洗って明るい行灯の下で暖かな夕食を喫っていた。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはひとつのあんどんをもっていました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙ではった四角な小さいあんどんでありました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がくると、みんなはこのあんどんに灯をともしたのでありました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるひの夕方、みんなはあんどんの油がもうなくなっていることに気がつきました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは、こんやはあんどんがともりません。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
