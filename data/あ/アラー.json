        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "最も普通ないわゆるコヒアラーと称するものは金属の粉が電波を受けると電気をよく通すようになる性質を利用したもので、広く用いられている。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に女訓導は、　　　　　ショールを面に被ふれば、アラーの守りあるごとし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャルソンのステファンが、「ヴォアラー・ムシウ」と言って小卓にのせて行く朝食は一日じゅうの大なる楽しみであったことを思い出す。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、ケリムのほかの三人はタンブーリンをひざの上におき、れいの薄荷のやうなにほひの出る薬の草を口にふくんで、「アラー、／＼、／＼。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、三人のものは、アラー／＼／＼と烟をはきながら、タンブーリンをヂャリン／＼ポン／＼ならしました。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "原注一八　ニューヨーク、『クーリア・アンド・インクァイアラー紙』。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "原注二〇　ニューヨーク、『クーリア・アンド・インクァイアラー紙』。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラー」　先に気のついた仙二の娘はとび出した様な声で叫んだ。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラ厭ですよ……アラー御新造さアん引」　ト大声を揚げさせての騒動、ドタバタと云う足音も聞えた、オホホホと云う笑声も聞えた、お勢の荐りに「引掻てお遣りよ、引掻て」ト叫喚く声もまた聞えた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "逝去の報知を手にした時、自分の心に衝上って来た、驚き竦え、考えに沈んだ心持は、恐らく、これ等の見えない原因を背後に持った私自身へのアラームであったのだと思われます。",
              "citation": {
                "source": "偶感一語",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、重錘初期以来のものは二十にあまるけれども、特に目立ったのは、巨大な海賊船の横腹に、時計や七曜円を附けたもので、刻字文によると、マーチャント・アドヴェンチュアラーズ会社からウイリアム・シシル卿（エリザベス朝に入ってから、ハンザ商人に弾圧を加えた政治家）に贈ったものであった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラー、チブスになるわよ、とスエ子［自注９］等は恐慌的な顔付をしたが、まさかそれは大丈夫でしょうから、どうぞ御心配なさらないで下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギルボアの山々よ、願はくは汝等の上に露も雨も降らざれ（サムエル後、一・二一）四三―四五第七例は神話にいづるアラクネ（アラーニエ）の物語なり（地、一七・一六―二四註參照）【截餘】アテナは己が技のアラクネに及ばざるをみて怒り織女の織りたる布帛を斷てり四六―四八第八例。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能がアラームを発する。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯女という中のの赤ちゃんの名の話をしたら、アラー、それ、吉屋信子の「家庭日記」の主人公の名ですよ、という。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへセラダが本日こそはと意気高らかに乗りこんできて、寝みだれ姿も物かは、いきなり哀願泣訴の意気ごみを見せたものですから、小夜子サンはアラーッ、キャーッと部屋へ逃げこんで障子をバッタリしめて、「待ってね。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　熱狂して喚く叔父の様子は、その動作表情を一途に圧し殺してゐた殆んどアラーを祈る回教徒の激しい身振りを見ることと同じ印象を私に与へた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲロチは同じく蛇の尊称であるチアム語のアラーチェイ（Ala※ei）がヲロチとなって残ったともいえるし、又国語では、霊妙な感じを起させるものを古代人はチと呼んでいた。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿良、烏礼等は孰れもアラー、ウラーの韓音を示す為に借用された漢字で、大蛇即ち竜王に外ならない。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行政系統は、次官、局長、部長、課長、係長というように既成のハイアラーキイ秩序ができているので、わかりやすいらしいが、調査系統となるとこれがはっきりしない。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して更に友二人、一はエキオス生める息、＊メーキスチュウス、又一はアラーストール、近よりてはげしくうめく負傷者を兵船中に搬び去る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はマホメット教の指導者たちと文通して、とうとう或る優秀なマホメット教徒（その名前の一部はアクバールであつたが、あとは何とも飜訳しようのない形容タップリのアラーへのうなり声みたいな名前であつた）を説き伏せて、古代マホメット教の禁酒命令についてイギリスで講演してもらうことになつた。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、もしかしたら盲腸ぐらいもっていてアラームベルの役をさせた方がいいかもしれない、夜更しをするとジリジリ！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一水会の出品に十五日以後出京とハガキが来ていたし、往来に立って見ていたら、体つき反っぱのところ黒くてやせて、しかし何か美しいところ、まごうかたなしだから入って行って、知らん顔して並んで立っていたら、額ぶちから顔をあげて、アラーとかじりついた。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この卯女という名は吉屋信子の「家庭日記」という小説の主人公の名だそうで、稲ちゃんもアラーと云ったのですが、お父さん氏の意見ではあの小説はそう永生するものではないからいいのだそうです（勿論その小説はよまないでの話）。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラーつい見なんだと目の前にあるものも見ない、そういうところあり。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラームの意味です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああ、今のおれはよくわかった――馬上に剣をふるいながら、アラーの神これを命じたまう。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "リアリアリーアリアリアラー　それはもう、さっきからくりかえされ、節をおぼえた歌だった。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
