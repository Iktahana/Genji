    "definitions": [
      {
        "index": 1,
        "gloss": "(something) one never tires of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ジヨゼフイインはまことに天使の如く歌ひしが、一たびアヌンチヤタを聞きし耳には、猶飽かぬ節のみぞ多かりし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山に登り仰ぎ見たか山の高き知るとふ言のよろしさ天地の霞みをどめる春の日に聳えかがやくひとつ富士が嶺わが登る天城の山のうしろなる富士の高きは仰ぎ見飽かぬ　山から見た富士ばかりを書いた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽かぬ美人は三階を去つてしまつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園のみは寒気強きところなれば樹木の勢いもよからで、山水の眺めはありながら何となく飽かぬ心地すれど、一切の便利は備わりありて商家の繁盛云うばかり無し。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八洲もる国つ御神もこころあらば飽かぬ別れの中をことわれどう考えましても神慮がわかりませんから、私は満足できません。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕に見て見飽かぬ源氏と稀に見るのを得た尚侍の喜びが想像される。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "月影の宿れる袖は狭くともとめてぞ見ばや飽かぬ光を　こう言って、花散里の悲しがっている様子があまりに哀れで、源氏のほうから慰めてやらねばならなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ても見ても見飽かぬこの人と別れ別れにいるようなことは何がさせたかと思うと今さらまた恨めしかった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいい姿で、毎日見ている人さえだれも見飽かぬ気のするこの人を、別れた日から今日まで見せてやっていないことは、真実の母親に罪作りなことであると源氏は心苦しく思った。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のはじめから終りまで、そのときどきに見て見飽かぬのは薄であらう。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なう古鏡、このあした、汝を抱きて歎く身の述懷は夢か、蜃氣樓、それにも似つる幻か、いずれ覺むべきものならば、儘よ、短かき晝の間を、飽かぬ睦びにあくがれて、悲しき闇を忘れまし。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボタ山の間から昇る日だ・ラヂオでつながつて故郷の唄香春岳は見飽かぬ山だ、特殊なものを持つてゐる、山容にも山色にも、また伝説にも。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる花は皆此處に集まりながら薊の缺けたるぞ飽かぬ心地する。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の上から飽かぬ街景色を見て行く中に、長い橋を渡つて、車は病院の鐵門の前に着いた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれの伝記とあらわに言ってなくても、善いこと、悪いことを目撃した人が、見ても見飽かぬ美しいことや、一人が聞いているだけでは憎み足りないことを後世に伝えたいと、ある場合、場合のことを一人でだけ思っていられなくなって小説というものが書き始められたのだろう。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろづ代をかけてにほはん花なれば今日をも飽かぬ色とこそ見れ　これは御製である。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ二人きりでおいでになって、春の一日の間見ても飽かぬ恋人を宮はながめてお暮らしになったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折にあへば如何なる花か厭はれん時ならぬこそ見劣りはすれ」、「憂きことよ猶身に積れ老いてさへまだ世に飽かぬこころ知るべく」、かかるは如何でか無為空寂をよろこぶ世捨人の歌ならんや。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲望彼れも取りたし、其れも欲し、飽かぬ心の止み難し。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが「松浦あがた」の記はまさに了るといへども、なほ私かに飽かぬここちの禁めがたきものあり、そは人の未だこの地に遊びて、爽快なる大気のうちに嘯きしことを聞くの少なきを悲むがために。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふゆごもり　春の大野をやく人は、やき飽かぬかも。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『久方のアメリカ人のはじめにしベースボールは見れど飽かぬかも』。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一首の中に、洋語系統のアメリカビト、ベースボールといふ二つの言葉を入れ、そのため、結句には、『見れど飽かぬかも』といふやうな、全くの万葉言葉を使つて調子を取らうとしたものである。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○あられうつ安良礼松原住吉の弟日娘と見れど飽かぬかも　〔巻一・六五〕　長皇子　長皇子（天武天皇第四皇子）が、摂津の住吉海岸、安良礼松原で詠まれた御歌で、其処にいた弟日娘という美しい娘と共に松原を賞したもうた時の御よろこびである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見れど飽かぬかも」の句は万葉に用例がなかなか多い。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若狭なる三方の海の浜｜清みい往き還らひ見れど飽かぬかも」（巻七・一一七七）、「百伝ふ八十の島廻を榜ぎ来れど粟の小島し見れど飽かぬかも」（巻九・一七一一）、「白露を玉になしたる九月のありあけの月夜見れど飽かぬかも」（巻十・二二二九）等、ほか十五、六の例がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は、万葉の秀歌に随処に見あたるので、「その草深野」、「棚無し小舟」、「印南国原」、「厳橿が本」という種類でも、「月かたぶきぬ」、「加古の島見ゆ」、「家のあたり見ず」でも、また、詠歎の入っている、「見れど飽かぬかも」、「見れば悲しも」、「隠さふべしや」等でも、結局は同一に帰するのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○昼見れど飽かぬ田児の浦大王のみことかしこみ夜見つるかも　〔巻三・二九七〕　田口益人　田口益人が和銅元年｜上野国司となって赴任の途上｜駿河国｜浄見埼を通って来た時の歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩れたる土塀、歪みたる衡門、あるいは掌のくぼほどの瘠畠、形ばかりなる小社などの、常は眼にいぶせく心にあかぬものも、それ近くにこの花の一ト木二タ木咲き出づるあれば、をかしきものとぞ眺めらるゝ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これならば立退くであろう、と思うと、ああ、埒あかぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
