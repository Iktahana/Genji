[
  {
    "uuid": "1f260f8b-c288-59d7-a504-bc4ee8a2d411",
    "entry": "飽かぬ",
    "reading": {
      "primary": "あかぬ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
