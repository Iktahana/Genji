        "examples": {
          "standard": [
            {
              "text": "私は毎日有難うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有難うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有難うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有難うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有難うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有難うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有難うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有難うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有難うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有難うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有難うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有難うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有難うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有難うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有難うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有難うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有難うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有難うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有難うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有難うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は、ふんと笑って、いや有難う、と言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気よく小僧を呼んで、手に取り上げた一枚の皿と五円札とをつき出すと、小僧は有難うといって竹村君の顔をじろじろ見た。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂書きの御婆さん「ヘー有難う、もうソチラの方は御済になりましたかなー、もうありませんかなー。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ヘー有難うこれから当世白狐伝を御覧に入れる所なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰吹の口が奇麗に擦れて父の気に入ったときは、父は有難うと言ってそれを莨盆にさし込み、煙管を燻らしながら言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのおっかさんがきまして、民や、決して気を弱くしてはならないよ、どうしても今一度なおる気になっておくれよ、民や……民子はにっこり笑顔さえ見せて、矢切のお母さん、いろいろ有難う御座います。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御親切に有難うございますですが今度は所詮癒るまいと思ひます。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「石松の奴が今に帰るかと思って……」　「そうかい……妾もね、あんな親不孝な伜だけれど、今夜の様に何時までも帰りが遅いと、つい心配になってね」　「おばさん、まあお這入ンなさいよ」　「有難う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩か、遅くとも明日の晩だから、そのつもりで……」　「御親切に有難う御座いました。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ァそれだけ言いに来たんだ」　「わざわざ有難うございました」　「じゃ帰るよ」　「親分様によろしく仰しゃって下さいね」Ｓ＝二階　お半、上って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六「御助勢申すとも」　雪枝「有難う存じます」と其の場に嬉し泣きに泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、二人の叫びは、露西亜人には、「有難う！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも色々有難う御座いました。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度持合せていたＭＣＣかなんかを進呈してマッチをかしてやったら、「や、こりゃあ有難う有難う」と何遍もふり返っては繰返しながら行過ぎた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有難うございました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイ、ハイ、御親切に、有難うございます。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、急に無言になって、ポックリちょっと頭を下げて有難うという意を表したまま、竿を持って前の位置に帰った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の友人と、佐吉さんと、私と五人、古奈でも一番いい方の宿屋に落ちつき、いろいろ飲んだり、食べたり、友人達も大いに満足の様子で、あくる日東京へ、有難う、有難うと朗らかに言って帰って行きました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小学生が復習の日課を許して貰ったように、お叩頭をして、つい、「有難うございます」と云って仕舞いました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――有難う存じます。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）無名の青年　――有難う。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――有難う御座います、では差し上げさして頂きます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈尊　――有難う、わしは別段に異常も無い。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目※連　――有難う御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんつお有難うごあんすな。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「どうもお有難うごあんした。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ有難うござりました、」と云つて二歩三歩お糸さんはあるいたが、「今夜いらつしやらないの、」と云つた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有難うございます。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」妹は、澄んだ声でそう呟き、「ありがとう、姉さん、これ、姉さんが書いたのね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
