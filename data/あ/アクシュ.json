          ],
          "literary": [
            {
              "text": "それから握手するか、ヒツパタクか、分つたものか。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし芥川君が、實に自分の同感者であり、同病者であるならば、我々の會話は魂の深い所で、親友としての握手を交換すべきだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の心の中では固くその人物と握手をし、「私の愛する親友！",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新入生一人一人に総長が握手をするというので、一列に並んで順々に繰出して行った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール総長の握手の力の強いのにびっくりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくの別れを握手に告ぐる妻が鬢の後れ毛に風ゆらぎて蚊帳の裾ゆら／＼と秋も早や立つめり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粋の精神はまた一面において俳諧の精神と握手するところがある。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸途に再度大船で別れる時には、もはや心から諸君に握手して禮をのべた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまたすつかり感激し、「おお兄弟」と呼んで握手をする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴夫人の己れと握手する事はあり得べからざるように思いおるゆえ驚きしなり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそうと姉さんはマッシャに握手をしておやりなさいましたね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（医学士に進み近付き握手せんとす。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ゾフィイと握手す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に画家と握手し、鼻眼鏡を外しつつ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学士と握手せんとす。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（握手せんとして手を差伸ぶ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家が握手せんとして手を差伸ぶるを見て、徐に右だけの手袋を脱ぎ、指輪を嵌めたる、細長き、優しき手を出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "イサックが悲しげに彼に握手して、　――メラ、君に贈る親愛、古いスグヤムグラの誓をもって！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコは、小さなワニ皮の旅行鞄に少時の憂愁をかくして、皮手袋を脱ると見送りの人々と握手をかわした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、始め、握手することを知らなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、握手をしたことがなかったのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、相手がこちらの手を強く握りかえした時には、それは、何を意味しているか、握手と同時に、眼をどう使うと、それはこう云っているのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "握手と同時に現われる、相手の心を読むことを、彼は心得てしまった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ諸君ハ、支那ノ労働者、農民、兵士達ト手ヲ握レ、諸君ガ革命的連帯ノ固キ握手ニ達スルタメニハ、如何ナル犠牲ヲモ辞スルナ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君が、革命的連帯の固き握手に達するためには、如何なる犠牲をも辞するな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、歩哨への面あてに、特に、山崎と親しいことを見せつけようとして、蠢めく兵士達を横柄にまたいで握手した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "福隆火柴公司の工人達は、その後兵士と握手して立ちあがった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、にこにこしながら、人々とあくしゅしていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　園井さんがうれしそうにいいますと、正一君も、小林少年と、なつかしそうにあくしゅをして、明智探偵には、ピョコンとおじぎをしました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
