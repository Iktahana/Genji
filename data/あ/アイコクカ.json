[
  {
    "uuid": "e8a4c88d-b7ac-55c2-94b2-27a200a58f3f",
    "entry": "愛国歌",
    "reading": {
      "primary": "あいこくか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patriotic song",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛国歌は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛国歌が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛国歌に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛国歌が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛国歌について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛国歌についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛国歌について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛国歌が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛国歌が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛国歌は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛国歌は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛国歌を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛国歌をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛国歌が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛国歌の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛国歌を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛国歌に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛国歌について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛国歌は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛国歌を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはなぜです」「あの肉体も精神も弱いルナミは、音楽浴にすっかりのぼせ上ってしまって、観測などをするどころか、咽が裂けるような声で愛国歌を唄っては天文部の貴重な器機を片ッ端からスパナーでガチャンガチャン壊しては暴れ廻っています。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵にはたりて久しくてのめる支那茶の、かをりたつ夜半の思ひの　かそけかりけり三日にわたりて、東京より「愛国歌」放送講演あり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然トリタイアが半分ふてくされてトレローニ愛国歌を歌い出したが、もし死んだら、どうなるんだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全な終わりじゃなかった、というのも近くであの陽気な巨漢ノーザンブリア人のプレストンというセントオシスの牧師が鳩の世話をしており、トリタイアが倒れるとき叫んだトレローニ愛国歌が聞こえたからだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリタイアはまだトレローニ愛国歌にご執心だが、もっと早く救助されていたらどうなったか。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆が愛国歌を怒鳴り、四方八方へどっと繰り出した。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
