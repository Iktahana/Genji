        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "瘠せてオーバアコートを着てわらじを穿いた男が青光りのさるとりいばらの中にまっすぐに立ってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双子のお星様たちは悦んでつめたい水晶のような流れを浴び、匂のいい青光りのうすものの衣を着け新らしい白光りの沓をはきました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な、薄い、小さな髷に結つたのが、唐銅の大な青光りのする轆轤に井戸繩が、づつしり……石築の掘井戸。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　空には今日も青光りが一杯に漲ぎり、白いまばゆい雲が大きな環になって、しずかにめぐるばかりです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとへ、竹槍の青光りに艶のあるのを、柄長に取って、明が続く。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも弟はリュウとした紺と茶縞の――彼の好きだと云っていた柄のサックコートに青光りするカンカン帽を冠っていた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、たちまち眼の前の、ぼーっとした仄暗い空を切り裂いて、青光りのする稲妻が、二条ほどのジグザグを、竪にえがいた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは素晴らしく大きな青光りのダイヤと、黄金の薔薇の花束から出来ていた。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精巧な彫刻の施された二束の薔薇には、その蕾や花として無数の真珠と青光りのダイヤが鏤められ、その両尖端の五六枚の葉先が、何の意味もなく、その素晴らしく大きな青光りのダイヤを支えているのだった。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その靭かな白い指の先に、素晴らしく大きな青光りのダイヤが、街燈の光線を受けて、青く赤く紫に、きらきらと光った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は相手の手応のないのを悟ると唇の端にわらひを浮べながら、ゆるゆると盃を執りあげてゐたが、私が瞥見する彼の姿は真に近寄り難い青光りの中に途方もない殺気を含んで蜂のやうに身構えてゐた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――太郎は、いつもその視線が何故ともなく青光りを堪えてゐて怕く、何う答へたら母の機嫌を害はずに済むだらうか？",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "色も鋼鉄のやうな光りをもつてゐて、真黒といふよりは青光りのする美しさである。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子は山形の五色の温泉へ祖母と一緒に行った時、湯殿をのぞいて居た青光りのする眼玉を思い出して身ぶるいの出る様な気がした。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬一つ出来ず、唾液一つ呑み込み得ないままに、その臙脂色の薄ぼけた頬から、青光りする珊瑚色の唇のあたりを凝視していたのであった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切れ目の長い眼と、濃い睫毛を伏せて、口紅で青光りする唇を軽く閉じた、温柔しそうなみめかたちを凝視していると、夫のために死んだ神々しい喜びの色が、一パイにかがやき出しているかのように見えて来る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三十四五かと見える前髪を縮らした美しいマダムで、全身が刺青のように青光りする波斯模様の派手な寝間着を着た、石竹色のしなやかな素足に、これも贅沢な刺繍のスリッパを穿いていたが、その顔は大理石を彫んだように真白く硬ばって、大きな美しい二つの瞳には真黒い怒りがみちみちていた。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台の曳出を皆開け放して、固練の白粉で胸から上を真白に塗りこくり、首筋の処を特に真白く、青光りする程塗上げた。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が駈けつけるともう一度、御影の狛犬が並んでいる河岸の空からふわりと来て、青光りのする翅と翅とがもつれ合ったと思う間もなく、蝶は二羽とも風になぐれて、まだ薄明りの残っている電柱の根元で消えたそうです。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れあがった夜空には明滅する星の青光りが一またたき毎に増した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがガスのように青光りがする。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋」とは、米へんの、精とか粋とかいう言葉があるように、米がその「もみ」をとり「かわ」をとり、青光りするほどその「ぬか」をとって、真裸かのもの、裸々堂々と、すべての飾りを脱ぎ去ることなのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の空には青光りのある星一つあらわれた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、その部屋の古い床の間には青光りのする美しい孔雀の羽なぞが飾ってある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、空に輝く、大きな青光りのする星を連想させるのであります。",
              "citation": {
                "source": "海ぼたる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈火に反射した鉞の刃は、蛍合戦の時数千の蛍が、塊まって巨大な球となり、それが虚空に渦巻くがように、青光り閃き渦をまいた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジル・ド・レェヌは、青光りのする楔型の黒い顎髯とともにペロオの妖精物語に取込まれて、「青髯と七人の妻」のモデルになった。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の側に繁った桂の大木の枝に、ブツリと突立ったのは、青光りのする錐へ、真新らしい紙を巻いた真物の吹矢です。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに立ちてあれば、吾側なる桑の葉、玉蜀黍の葉は、月光を浴びて青光りに光り、棕櫚はさや／＼と月に囁やく。",
              "citation": {
                "source": "良夜",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
