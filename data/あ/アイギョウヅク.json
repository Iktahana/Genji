        "examples": {
          "standard": [
            {
              "text": "成長とともに表情が豊かになり、近頃ではすっかり愛敬付いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの子も言葉を覚え始めてから、いよいよ愛敬付いてきたね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "以前は無愛想だった彼も、孫ができてからは随分と愛敬付いた顔つきになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女のハスキーな声は、どこか愛敬付いた響きがあって、聴く者の心を和ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「近頃は少しは愛敬付いてきたじゃないか」と祖父が目を細めて笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳格な教師の横顔が、教え子の活躍を喜ぶときだけは不思議と愛敬付いて見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
