          ],
          "literary": [
            {
              "text": "この男は真っ白なリンネル〔亜麻織物〕の背広を着て、きれいに手入れをした白靴を穿いていた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木綿及び麻織物｜洗濯。",
              "citation": {
                "source": "たね子の憂鬱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真っ紅な亜麻織りに黄金を輝かせた荘厳な衣服にあらためて、かれらを迎えた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "（b）いかに忽ちに、わが軍隊の間に羚羊の革や麻織の垢じみた胴衣＊が珍重されるようになったか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
