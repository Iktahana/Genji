        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛嬌は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛嬌が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛嬌に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛嬌が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛嬌について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛嬌についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛嬌について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛嬌が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛嬌が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛嬌は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛嬌は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛嬌を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛嬌をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛嬌が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛嬌の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛嬌を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛嬌に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛嬌について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛嬌は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛嬌を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
