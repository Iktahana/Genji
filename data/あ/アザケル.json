        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」さう嘲るやうに先刻の言葉を言つてみたが、何だか気懸りな言葉だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで朝飯かき込み岡崎氏と停車場に馳けつくれば用捨気もなき汽車進行を始めて吐き出す煙の音乗り遅れし吾等を嘲るがごとし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを嘲る悪魔の声も聞えるような気がする。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人が差向いにて夕餉につく様こそ見たけれなど滑稽芝居見まほしき心にて嘲る者もありき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の眷族はゆうべのうちに皆帰って来たらしく、さながら人間の無智を嘲るように家中いっぱいに啼いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつのこったから、悪いものでも食って中ったのか」と、半七は嘲るようにささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と嘲るがごとく言い棄てたが、やがて岩の陰に入って高い処の草に隠れた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにてもなおものありげにわが顔をみつつ行くが、冷かに嘲るがごとく憎さげなるぞ腹立しき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と平生から嘲るものは嘲るが、心優しい衣絵さんは、それでも気の毒がつて、存分に沸かして飲むやうにと言つた厚情なのであつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんですか」「さぞ、うらやましかったろうの」という声は嘲るごとし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と岡本は嘲るような、真面目な風で言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と綿貫は嘲るように言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを嘲るのはその心霊の麻痺を白状するのである。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って苦しそうな嘆息を洩し、冷かな、嘲るような語気で、「けれども、実は其方が幸福なのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘲るように、（病人なら病人らしく死んじまえ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛惡なる猴の本性として、容易に手を出さない、恰も嘲る如く、怒るが如く、其黄色い齒を現はして、一聲高く唸つた時は、覺悟の前とはいひ乍ら、私は頭から冷水を浴びた樣に戰慄した、けれど今更どうなるものか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一〇）非國民を葬れ▲殊に英雄主義を蔑視し、豪傑道を嘲るに至つては、言語道断と云ふの他はなし。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お杉は嘲るように高く笑った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの梢では大きな山猿が、他を嘲るように笑っていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と嘲る言葉は当のお君より傍できいている豹一の胸にどきんとこたえ、豹一の眼は安二郎に挑みかゝるようにギラ／＼光るのだったが、安二郎はそんな彼には眼もくれず、たゞお君の連れて来たこぶ位に思って、問題にしなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までに幾人となく引き裂かれ、切り千切られ、タタき付けられた女工や、幼年工の亡霊を嘲る響き……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　やす物買ひの銭失ひ西　やみに鉄砲　低価の貨物を買ふ勿れとは江戸の人の気象をあらはし、闇夜に鉄砲を放つがごときことを為すを嘲るも亦、京坂地方の人の気象をあらはせり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中でリップ・ヴァン・ウィンクルが元気よく自分の名を叫ぶと、反響がおおぜいの声として「リーッウ・ウァーン・ウィーンウール」と調子の低い空虚な気味の悪い声であざけるように答えるのが、いかにも真に迫っておもしろかったのを記憶する。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは近代物理学の大家が、生命の種子を天来の発生物に帰せようとしたつたない説をあざけるようにも聞こえる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれをあざけるのはさもしいことである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、わたしはあざけるように笑った。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもよく自分をいじめた年上の者らは苦もなく駆け上がって上から弱虫とあざける。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアきれいな稲刈りだこととほめるものもあれば、いやにつくってるなアとあざけるものもある。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは推量さ」「向うへ行って、もし間違っていたら引っ込みが付くめえ」「そりゃあ段取りがありまさあね」と、彼は半七の無経験をあざけるように答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
