        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で、「和え」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "季節の変化とともにこの傾向が顕著になる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からこの風習が形成された。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でこれは欠かせない材料とされている。",
              "source": "幻辞"
            },
            {
              "text": "観光地を訪れる際にこのポイントを押さえておくべきだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で、「和え」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と自分は答えたが、まだ余っている餌を、いつもなら土に和えて投げ込むのだけれど、今日はこの児に遺そうかと思って、　餌が余っているが、あげようか。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ和えものの和え方は、女の化粧と同じで、できるだけ生地の新鮮味を損わないようにしなければならぬ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掻き交ぜ過ぎた和えものはお白粉を塗りたくった顔と同じで気韻は生動しない。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは髪毛と血の和え物みたようになったのが、線路の一側を十間ばかりの間に、ダラダラと引き散らされて来ている。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この觀察にはいまだ徹底せざる不十分さがあるかも知れぬが、日本が獨立國家として再出發するに當つては、共産黨を斷然壓倒し得るごときイデオロギー中心の新政黨を結成し、正しき統制主義國家として獨立するのでなければ、國内の安定も世界平和えの寄與も到底望み得ざるものと確信する。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　であり、『白和え出来ますか。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら漬物で和えろ……」「でも魚スープか蒸焼を注文されたら？",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか私の発明でうまいと思ったものに、パセリの揚げたのをパンに挟むのや、大根の芽立てを摘んだつみな、夏の朝々百姓が売りに来るあれを、青々と茹でピーナツバタに和えてパンに挟む。",
              "citation": {
                "source": "朝御飯",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄黒いドーナツ面へ蒟蒻の白和えみたいに高価いお白粉をゴテゴテと塗りこくる。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、晩に和えようじゃあるまいか、懸けといてつかあせ」　持って来たちさの籠をお縫にわたした。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌はそれに感傷して和えられた歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○秋山の樹の下がくり逝く水の吾こそ益さめ御思よりは　〔巻二・九二〕　鏡王女　右の御製に鏡王女の和え奉った歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもこの歌だけについて見れば恋愛情調であるが、何処か遜ってつつましく云っているところに、和え歌として此歌の価値があるのであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○わが岡の※神に言ひて降らしめし雪の摧し其処に散りけむ　〔巻二・一〇四〕　藤原夫人　藤原夫人が、前の御製に和え奉ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌としては御製の方が優るが、天皇としては、こういう女性的な和え歌の方が却って御喜になられたわけである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に石川郎女の和え奉った歌は、「吾を待つと君が沾れけむあしひきの山の雫にならましものを」（巻二・一〇八）というので、その雨雫になりとうございますと、媚態を示した女らしい語気の歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "額田王は右の御歌に「古に恋ふらむ鳥は霍公鳥けだしや啼きしわが恋ふるごと」（同・一一二）という歌を以て和えている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ皇子の歌に比して遜色があるかというに、和え歌は受身の位置になり、相撲ならば、受けて立つということになるからであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "贈り歌の方は第一次の感激であり、和え歌の方はどうしても間接になりがちだからであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の歌は嫗の和え奉った歌で、もう御話は止しましょうと申上げても、語れ語れと御仰せになったのでございましょう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此御歌に対して、春日王は、「大君は千歳にまさむ白雲も三船の山に絶ゆる日あらめや」（巻三・二四三）と和えていられる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の、「白雲の棚引く山を越えて来にけり」も、近江で詠んだのだから、直接性があるし、旅人のは京にあって筑紫を詠んだのだから、間接のようだが、これは筑紫に残っている沙弥満誓に和えた歌だから、そういう意味で心に直接性があるのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し万葉集には、妹に和えた歌とは云っていない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに和えた歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに旅人の和えた二首中の一首である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎人娘子の伝は未詳であるが、巻二（一一八）に舎人皇子に和え奉った歌があり、大宝二年の持統天皇｜参河行幸従駕の作、「丈夫が猟矢たばさみ立ち向ひ射る的形は見るにさやけし」（巻一・六一）があるから、持統天皇に仕えた宮女でもあろうか。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此歌の次に舎人親王の和え奉った御歌が載って居り、親王は聖武天皇の天平七年に薨去せられたから、此行幸はそれ以前で元正天皇御在位中のことということになる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎人親王の和え御歌は、「あしひきの山に行きけむ山人の心も知らず山人や誰」（巻二十・四二九四）というので、前の「山人」は天皇の御事、後の「山人」は土産をくれた山の仙人の事であろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで胡桃を使う代りに南京豆、胡麻を使う代りにも南京豆、胡麻｜和えという所も南京豆和えという風にしますが南京豆の方が胡桃よりも淡泊で或る場合には胡麻よりもよほど美味しゅうございます。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって自ら筆を取り、あえて大胆にこの書をあらわし、著者の見たる「新しき蕪村」を紹介しようと思うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
