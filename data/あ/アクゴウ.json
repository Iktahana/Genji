          "literary": [
            {
              "text": "そんな面の皮の厚さが、二寸も三寸もありそうなゴツイ彼等も、自分自身の悪業のため、満洲がいにくゝなる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは自分の悪業を蔽いかくそうとする者は一人もなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら晒し首にしたところで、彼等の悪業のむくいとしてはやり足らぬかもしれなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青｜瓊玉かゞやく天に、　　　　　れいろうの瞳をこらし、これはこれ悪業乎栄光乎、　　　かぎすます北斎の雪。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ気の毒な悪業である。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち説いて曰く、　汝等審に諸の悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如きの諸の悪業、挙げて数ふるなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪業を以ての故に、更に又諸の悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今このご文は、この大菩薩が、悪業のわれらをあはれみて、救護の道をば説かしゃれた。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等｜審に諸の悪業を作ると。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪業といふは、悪は悪いぢゃ、業とは梵語でカルマというて、すべて過去になしたることのまだ報となってあらはれぬを業といふ、善業悪業あるぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは悪業といふ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち説いて曰く、　汝等｜審に諸の悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で前の晩は、斯の如きの諸の悪業、挙げて数ふることなし、まで講じたが、今夜はその次ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪業を以ての故に、更に又諸の悪業を作ると、これは誠に短いながら、強いお語ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻人間に恨みを返すとの議があった節、申した如くぢゃ、一の悪業によって一の悪果を見る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悪果故に、又新なる悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
