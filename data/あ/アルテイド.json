    "definitions": [
      {
        "index": 1,
        "gloss": "to some extent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日ある程度について考えている。",
              "source": "幻辞"
            },
            {
              "text": "ある程度という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はある程度の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはある程度が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ある程度を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはある程度について学習した。",
              "source": "幻辞"
            },
            {
              "text": "ある程度の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はある程度の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではある程度が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ある程度という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にある程度という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではある程度についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ある程度を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとある程度は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ある程度について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではある程度が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にある程度は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりある程度の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ある程度は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にある程度は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある程度の高さを、いつまでも変らずに持ちつづけている芸術家はよほどの奴です。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある程度の不連続な生理的変化がある時期に起る事もよく知れ渡った事実である。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが肉体の変化の直接の影響であるか、あるいは精神的変化が外界の刺戟に誘発されてそれがある程度まで肉体に反応しているのだか分らない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言語学上の事実は私もある程度において認めはするが、この事実を理由として外来語の統制に反対する自由主義の立場に賛意を表することは私にはできない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれがある程度の普遍性をもつものでなければならない。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは要するに適当に選ばれたる有限の独立変数にてある程度までいわゆる原因を代表し、いわゆる方則によりて結果の一部を予報し得るに依る。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず現に天気予報がその科学的価値を認められ、実際上ある程度まで成効しおるは如何なる理由によるべきか。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の歪みの程度を測知する事はある程度までは可能なるべく、また主なる第二次原因を知る事も可能なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかくも歪みが増すに従って現象の発生を期待する公算の増加するは勿論にて、従って歪みがある程度に達するまでは現象は起らずと安心すべき根拠を与うべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に上の仮想的の場合において現象の発生する時期がある程度まで知られたりと仮定せよ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう試みがある程度まで成効した結果が今日の科学である。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは自然界の現象が有限な項から成る方程式である程度まで代表され得るというのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定の位置並びに寒暖計の示す温度において測った金属棒の長さは、不可測的の雑多な微細な原因のために、種々異なる価を与えても多数の測定の平均はある程度まで一致すると考えられるのはやはりこの偶然の御蔭である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目はまぶたによって任意に開閉され、また頭を動かすことなしにある程度までは自由に左右上下に動かされる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある程度までは生理的効果でだれにでも共通なものである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが云わば敵国の英国の学者の日蝕観測の結果からある程度まで確かめられたので、事柄は世人の眼に一種のロマンチックな色彩を帯びるようになって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身も後者の類例をある程度まで承認している。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字の方はその意味を覚えるまでの練習を要する代りに、一度覚え込んでしまえばその意味の内容はある程度までははっきり規定されてしまう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もどの画家でも相当な人ならばある程度まではそういう事を考えぬ人は無いかもしれないが、しかしそう考えるばかりで何時までも同じ谷間の径路を往復しながら対岸の自然を眺めているのでは到底駄目であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の絵からはある程度の真面目さがうかがわれ、ある程度の同情が誘発される。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校時代に、鮨屋の娘ということが、いくらか恥じられて、家の出入の際には、できるだけ友達を近づけないことにしていた苦労のようなものがあって、孤独な感じはあったが、ある程度までの孤独感は、家の中の父母の間柄からも染みつけられていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早生の節成胡瓜は、六七枚の葉が出る頃から結顆しはじめるが、ある程度実をならせると、まるでその使命をはたしてしまったかのように、さっさと凋落して行ってしまう。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句を研究してある程度まで理解しているあるフランス人に言わせると日本人は一人残らずみんな詩人であるという。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう方法によれば少なくも一時的の効果はある程度まで得られるに相違ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそのある程度はこんな試みとして避け難い。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし恐怖というようなものもある程度自分で出したり引込めたりできる性質のものである。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも寒暑の往来によって昼夜季節の変化を知る事はある程度までできる。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不可能でないのみならずある程度までのある意味での理解はかえってきわめて容易な事かもしれない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある程度まで近代的に翻訳する余地があるかと思われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより寄席ではない見世ものだから、その曲芸は客を誘うために、あるていどまで、外に立見する客へも見せるから、人気はすばらしかった。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
