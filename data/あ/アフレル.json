        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "溢れるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この溢れるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "溢れるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が溢れるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "溢れるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は溢れるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "溢れるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では溢れるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から溢れるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "溢れるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも溢れるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では溢れるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "溢れるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも溢れるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも溢れるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で溢れるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に溢れるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "溢れるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する溢れるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では溢れるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が草木が洗われて、富士山と釜無川の大断層と、南アルプスや、関東山脈の高屏風に囲まれた日本最大の裾野が、大空を持ちあげるばかりの力をみなぎらして、若い力から溢れる鮮新味で輝きわたるのを見たことを悦ぶ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎの小説が、中途までくると、私は、仰向けに寝転がつて、溢れる涙をそうつと、たもとでふいた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も勿論愉快が溢れる……、宇宙間にただ二人きり居るような心持にお互になったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の推察通り、棉は末にはなっているが、風が吹いたら溢れるかと思うほど棉はえんでいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花へ、顔を押つけるやうにして、ほろ／＼溢れる目をごまかしましてね、「西洋のでございますか、いゝ匂ですこと。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに唇から口紅が溶けたやうに、真赤な血が溢れるんですものね。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜人では第一｜乗溢れる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂然して溢れる計り坐ったり立ったりして居るのが皆んなかんかん虫の手合いである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏と陰部とを小さなガーゼで被うてある外は、死體にのみ特有な支那の桐油紙のやうに鈍い冷たい青黄色い皮膚が溢れるやうな朝の光線の下に曝されてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、いくら因の電気が溢れるほどスタンドの口元まで来ていましても、私が知らん顔をして縁のスイッチを捻らなければ、永久に灯は点りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そういう人が一人でも世間に多くなれば、智慧に溢れ、慈悲に溢れ正義に溢れる世の中になりますから、万人の幸福でもありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋を向うへはづすと、水も溢れるまで、手桶の中に輪をぬめらせた、鰻が一條、唯一條であつた、のろ／＼と畝つて、尖つた頭を恁うあげて、女房の蒼白い顏を、凝と視た。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋を向うへはづすと、水も溢れるまで、手桶の中に輪をぬめらせた、鰻が一條、唯一條であつた。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の手は溢れる許りに詰め込まれた函の手紙を一一とり出してゐる。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」桑野は溢れるやうな熱心を以て畳を叩くやうな手付をして云ふのである。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から見る松原の葭簀茶屋と酸漿提灯と、その影がちらちら砂に溢れるような緋色の松葉牡丹ばかりが、却って目に涼しい。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水柱は高く六尺に昇つて、潺々と落ちて小波を立てて溢れる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこに屋根囲した、大なる石の御手洗があって、青き竜頭から湛えた水は、且つすらすらと玉を乱して、颯と簾に噴溢れる。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　と、御手洗は高く、稚児は小さいので、下を伝うてまわりを廻るのが、さながら、石に刻んだ形が、噴溢れる水の影に誘われて、すらすらと動くような。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その掛稲は、一杯の陽の光と、溢れるばかり雀を吸って、むくむくとして、音のするほど膨れ上って、なお堪えず、おほほほほ、笑声を吸込んで、遣切れなくなって、はち切れた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時入浴して座敷に帰ると、桂川も溢れるかと思うような大雨となった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流れるように句心は湧いて溢れるのだ。",
              "citation": {
                "source": "述懐",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ、飲みすぎ食べすぎのたたりてきめん、身心がだるい、熱い溢れる湯にはいりたくなり湯田へ行かうかとも思つたが止めにして戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちはこんなにも大人に育って女性の漿液の溢れるような女になって、ともすれば身体の縒り方一つにも復一は性の独立感を翻弄されそうな怖れを感じて皮膚の感覚をかたく胄って用心してかからねばならなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子の無性格――彼女はただ美しい胡蝶のように咲いて行く取り止めもない女、充ち溢れる魅力はある、しかし、それは単に生理的のものでしかあり得ない。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝の水は増したが、溢れるほどでもなく、ふだんのせせらぎはなみなみと充ちた水勢に大まかな流れとなって、かえって間が抜けていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑も樺も橙も黄も、その葉の茂みはおのおのその膨らみの中に強い胸を一つずつ蔵していて、溢れる生命に喘いでいるように見える。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、そんな、あまったるい通俗小説じみた、――腹立たしくさえなって、嘉七は、てのひらから溢れるほどの錠剤を泉の水で、ぐっ、ぐっとのんだ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花や莟をチョイチョイ摘取って、ふところの紙の上に盛溢れるほど持って来た。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……湯気に山茶花の悄れたかと思う、濡れたように、しっとりと身についた藍鼠の縞小紋に、朱鷺色と白のいち松のくっきりした伊達巻で乳の下の縊れるばかり、消えそうな弱腰に、裾模様が軽く靡いて、片膝をやや浮かした、褄を友染がほんのり溢れる。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
