        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浅ましいの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "口小言を云いながら窓をあけると、まず眼にはいったものは娘の浅ましい亡骸で、おちかは腰のぬけるほど驚いたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは水死の浅ましい亡骸を品川の海に浮かべたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と妹の浅ましい堕落を知りつつも思い切って言いだし得ず、言いだしても争そうことの出来なかったも当然。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどうしてそんな浅ましい心を起したのだろう……」　自分は涙を止めることが出来ない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が百円持って銀行に預けに行く途中で、掏児に取られた体にして届け出よう、そう為ようと考がえた、すると嫌疑が自分にかかり、自分は拘引される、お政と助は拘引中に病死するなど又々浅ましい方に空想が移つる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには真面目にお政のことを想う時は決してその浅ましい姿など眼に浮ばないで現われる時は何時も突然である。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上このような浅ましい姿で尊いおん眼に触れました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも先ず、その、世に浅ましい、鬼畜のありさまを見しょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは浅ましい、むさくるしい、かつては恥を感じたと云ふことのない盲目的のものであつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）姥　もし、お前様、その浅ましい人間でさえ、約束を堅く守って、五百年、七百年、盟約を忘れぬではござりませぬか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室には、しばらく賤げに、浅ましい、売女商売の話が続いた。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の父も矢はり彼のような浅ましい姿になって、人の知らぬ山奥か谷間に倒れているのではあるまいか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から魔所と伝えられた虎ヶ窟の前に、斯る浅ましい姿の者が四個までも列んだのを見た人々は、抑如何に感じたであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな人とは絶対に結婚なんかするものかと、かたく心に決め、はたの人にもいっていたくらいだのに、まるで掌をかえすように――浅ましい。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋でもよいからと、頭を下げた客もあるほどおびただしく正月の入湯客が流れ込んで来たと耳にはいっているのに、こんな筈はないと、囁きあうのも浅ましい顔で、三人の踊子はがたがたふるえていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見料一人三十銭、三人分で……と細かく計算するのも浅ましいが、合計九十銭の現金では大晦日は越せない、と思えば、何が降ってもそこを動かない覚悟だった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、浅ましい」　と手を離した途端、男は千枝子の体をベッドの上へ倒すと、パチリとスタンドの燈を消した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　宮子は兄の小郷虎吉と同じ淫蕩の血を持っていたが、しかし、さすがに女であったから、少しは自分を浅ましいと思う気持は残っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔は乞食もこんな浅ましい真似はしなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、どれだけ時間がたったのか、二人はがっくりとして、お互い浅ましい顔をそむけた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、伊都子の匂い……というよりもむしろ、人間の浅ましい交渉の匂いのかすかな残り香を嗅いでいると、女のあわれさが、はや信吉を憂愁の感覚でとらえてしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町の間に八つも路地裏のある貧乏たらしい町で、子供たちは母親にそそのかされてか、何遍も何遍も浅ましい手を出したが、そんな二度取り、三度取りをいちいちたしなめておれぬ忙しさだった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄とは、あさましい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸の働き振りを見ると、一心不亂どころか、ほとんど半狂亂に近いあさましい有樣である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はしゃぐ」が笑い騒ぐ事で、「あさましい」も場合によると「笑ひ事」であるのもおもしろい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "セミティックの方面でも (Ar.)basama は「微笑する」で「あさむ」「あさましい」と似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あさましい」はまた (Skt.)vismayas で「驚く」ほうにも通じるが、それよりも元の smi, smaya で微笑にもなる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人のいうようにあさましいなどという感じは自分には起こらない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば白粉ははげ付け髷はとれた世にもあさましい老女の化粧を白昼烈日のもとにさらしたようなものであったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子大の校庭のあさましい垣のぞきをしたり、ミス何とかの美人競争の会場にかけつけたり、映画のニューフェースとやらの試験場に見学と称してまぎれ込んだり、やたらと歩き廻ってみたが、いない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
