[
  {
    "uuid": "869058e8-5adf-520e-a355-ef82dc4976a1",
    "entry": "溢れ出る",
    "reading": {
      "primary": "あふれでる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
