    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to overflow from something full",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "溢れ出るについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この溢れ出るは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が溢れ出るについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は溢れ出るの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では溢れ出るが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から溢れ出るを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも溢れ出るが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では溢れ出るが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも溢れ出るは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも溢れ出るは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で溢れ出るは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に溢れ出るについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出るの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する溢れ出るの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では溢れ出るの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押當て其端を喰ひしめつゝ物いはぬ事小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり聲のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押当てその端を喰ひしめつつ物いはぬ事｜小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり声のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中からシャリアピンの悲しくも美しいバスのメロディーが溢れ出るのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シユウとあわが立つて、黒いしるの溢れ出るのを匙でかきまはす代ものである。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の世相が書ける唯一の作家としての、武田さんの新しいスタイル――混乱期の作品らしいスタイル――「雪の話」の名人芸を打ち破って溢れ出るスタイルを待望していた。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め、赭顔・鬚面のその容貌を醜いと感じた俺も、次の瞬間には、彼の内から溢れ出るものに圧倒されて、容貌のことなど、すっかり忘れてしまった。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等よりもより雑然たる諸相の中から、湧き出る、溢れ出る、転がり出る、飛び出る、それらの如く、蠢々として、哀々として、莞爾として、突兀として、二人三人五人の青年たちがむくりむくりと起き上って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから溢れ出る暗い…………腥いにおいにすべては溺れ込んでゆく。",
              "citation": {
                "source": "月蝕",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院の内部は闇で、その闇は戸の外に溢れ出るかと思うほど濃かった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の湯の中に動いてゐる微塵に似た湯垢の一つ／＼にはかすかに虹の樣な日光の影が宿り、湯槽の縁から溢れ出る湯は同じくほがらかに日が當つて乾き切つてゐる流し場の一端に細い小波をたてゝ流れて行つてゐます。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気品、水ぎわ立った恰幅、直参なればこそ自ら溢れ出る威厳です。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その風｜薫る橋の上、ゆきつ、もどりつ、人波のなかに交つて見てゐると、撫子の花、薔薇の花、欄干に溢れ、人道のそとまで、瀧と溢れ出る。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "煩わぬようにしろ」「いっそ煩うて死にとうござります」　言ううちにも、止めどもなしに突っかけて溢れ出る涙は、白粉の濃い彼女の頬に幾筋の糸を引いて流れた。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、今日でもハッキリ記憶をしておりますが、万年屋の前で荷物の番をしている時、持ち出してある大酒樽の飲み口が抜けて、ドンドンと酒が溢れ出る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は溢れ出る涙を夜着の袂で覆い、今も地上に、こうした悲境に突き陥されてゆく人々の悶えを悶えるのであった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、自ら著く進歩しつつあるが如く感じたる時、あるいは何とはなけれどただ無闇に趣向の溢れ出るが如く感じたる時は、その機を透かさず幾何にても出来るだけものし見るべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども溢れ出る生命の過剰を現すことが出来ない。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頻りにこすつたり瞬きしたりするのだつたが、徒らに涙のみぽろ／＼と溢れ出るばかりだつた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち列車から溢れ出る人波に視野を遮られた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自然に溢れ出る微笑であった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "停学の三週間にも処分しなくってはとてもいけません」　溢れ出る涙を腕で抑えている平一郎と、忌々しそうに眺めている体操の教師と、沈黙している校長と国語の教師とに朝の秋光が薄らに射していた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え※」　平一郎は深井の白い顔に溢れ出る涙を見た。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳はひとりでに滿ち溢れ出る赤ん坊はむせかへつて怒る、母親はどうする事も出來ないで氣を揉むが、乳は出過ぎる。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしがほしいのは、本当の愛情、人情の流れ、心から自然に溢れ出る温かみです。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして由良は泣きながら堅く窓にかぢりついて、激しく手巾をふつてゐたが、凡太も亦、彼はデッキのステップに身を出して龍然に目礼を送りながら、目に光るものの溢れ出るのを、どうすることも出来なかつた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　霓博士は暗澹とした顔をヂッと僕に向け合せて、殆んど同情のあまり今にも涙の溢れ出るやうな親密な表情をした。",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式だけは北魏に則って造られているが、この破天荒とも言うべき表現の直接性は決して様式伝習の間から生れているのではなく、却て様式｜破綻から溢れ出る技術と精神｜気魄との作ったものである。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸にあふれでる想念は子供の頃母に叱られたその怖しさばかり、七ツの恐怖をどうすることもできないのである。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身から歓喜があふれでるほど、快感がたかまっているのだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼球を抜かれた一眼の窪からあふれでる鮮血は止まらない。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
