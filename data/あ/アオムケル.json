        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「…………」　清水は、ふと気を換えるように、「この詩を知っていますか」と、イガグリ頭を仰向けるように眼を瞑り、節をつけて何かの漢詩を吟じた。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく口をあけ、顔を仰向けるようにして笑うのであったが、笑いの輝やいているのは瞳だけで、その口元は泣くようにも見えるのであった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煙草あがりたいのじゃないの、代りましょうか」　今度は峯子が子供をうけとると足どりは益々ゆるやかになり、慎一はすこし顔を仰向けるようにして心持よさそうに煙草の烟をはきながら歩いていたが、いきなり何の前おきもなく、「どうだい峯子、おれの信用はなかなか大したものだろう」と云った。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大河ぶちの桟敷を一ぱいに埋めた見物客がその顔を空へ仰向ける。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やや上気した例の団扇形の白い顔を仰向けると、上眼づかひに少年をちらと睨んだ。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の少女が、少し顔を仰向けるようにして、コバルト色の青年に向って何か言いながら、賛成しないような身ぶりで日やけした手をふった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い鍔の陰から、丸い顎を仰向けるようにして朗らかな天を仰だ眼を落すと、彼女は、ちょっと眉を顰めるようにして、彼方に光っている鈍銀の窓々を見た。",
              "citation": {
                "source": "美しき月夜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法師は大ゲサに蛙腹を仰向ける。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
