        "examples": {
          "standard": [
            {
              "text": "私は毎日ＲＶについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＲＶの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＲＶが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＲＶについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＲＶの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＲＶが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＲＶという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＲＶについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＲＶは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＲＶが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＲＶは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＲＶの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＶは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＲＶは興味深い例である。",
              "source": "幻辞"
            }
