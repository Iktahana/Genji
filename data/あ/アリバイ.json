        "examples": {
          "standard": [
            {
              "text": "私は毎日アリバイについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アリバイという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアリバイの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアリバイが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アリバイを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアリバイについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アリバイの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアリバイの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアリバイが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アリバイという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアリバイという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアリバイについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アリバイを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアリバイは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アリバイについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアリバイが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアリバイは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアリバイの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アリバイは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアリバイは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「――ちゃんと、アリバイが出来ています」「もし、あなたのおっしゃったことが、本当だとすれば、そうですね」　と、司法主任は言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全なアリバイでしょう」「そうですね」　司法主任の言葉を聞いて小田はほっと安心して、「これで梶鶴雄に掛った嫌疑は晴れたのだ」　と思わず表情も明るくなったが、ふと、「――じゃ、犯人は君勇なのか」　と、思うと、急にまた眉が曇った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してアリバイにはならないけれども、稍それに紛らわしい効果を持たないでもない。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリバイも知らないで……」　玄関に近いので母親はハラハラした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもいいから巡査さんにそう云って頂戴……妾にはチャンとしたアリバイがありますから、心配しないでお帰んなさいッテ……」　母親はオロオロしながら玄関に引返した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのアリバイとは何ですか」　母親はふるえ上った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来この部落ではアリバイという言葉が全く別の意味で流行している。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆの家はＦの母と姉と、私の妹であるＦの妻と、Ｆの若い妹二人という家庭でしたが、老母と姉とを除いた全部がとても探偵小説好きで、「トリック」だの「ウイット」だの「アリバイ」だのと、中学卒業程度の私にはわかりかねる術語を使ってすごい話ばかりしているのです。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその少数者は結局「一人二役」「探偵即犯人」「偽アリバイ」等々の極めて少数トリックが存在し得るだけの数だけしか探偵小説は書けない事に理論上なっている。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇器も出て来ないし、陳述そのものがアリバイになっているくらいである。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の日曜日のアリバイについての口供書が正確であるかどうかを、我々はよく確かめてみよう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見ると犯人のために立派にアリバイが成立しているですね。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしとけば今村のアリバイがたたぬからね。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流社会のお偉さんに傷を付けたら困るから、アリバイを証明しなかったって言うのか？",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、被害者はどうしても四時二十分以後、たぶん四時二十五分から四時半までというきわどい時刻に殺されたと考えねばなりませんが、そうすると北川には完全なアリバイが立っているわけです。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "達次郎にはアリバイが出て来た。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のアリバイは、彼の当初の声明を裏切って、遂に立証すべき何ものも見つからず、遂に彼は恐れ入ってしまった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、杜のアリバイは確実であった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有力な嫌疑者として、娘よし子の情夫が拘引されて取り調べを受けたが、彼は疑うべき余地のないアリバイを示したので、警察はにわかに方針を変えねばならなくなりました。",
              "citation": {
                "source": "新案探偵法",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "手のこんだアリバイの示しかたです。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが事件の十五日夜アリバイがはっきりしているために「やや焦燥の色濃い東京地検堀検事正、馬場次席検事は」「教唆罪もあり得る」と語っている（七月十九日『東京新聞』）。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のアリバイを立証する事が出来ます。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、僕が伊達と別れてから例の事件が起つてそれから女中が迎いに行くまでは十分か十五分位しかないのだから、迎えの女中が行つた時彼がちようど服の上衣をつけていた、というのに不思議はないがね」「しかしともかく、伊達のアリバイは決して完全ではないな。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからどうも家族の中では皆が皆完全にアリバイをもつている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が皆完全にアリバイをもつていることすでにいつた通りだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論伊達が殺人を自白すれば別だが……ただ本人がアリバイを立証できぬというだけでは意味がないからね。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの理由で、さだ子の為にアリバイを立ててやつていらつしやるのではないかと存じますの」「林田がさだ子さんを庇つている？",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると第二の事件でひろ子自身のアリバイが完全に立つているため、事は彼女の思いもうけていなかつた位、安全にはこんでしまつたのだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
