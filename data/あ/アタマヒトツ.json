          ],
          "literary": [
            {
              "text": "とある杉垣の内を覗けば立ち並ぶ墓碑｜苔黒き中にまだ生々しき土饅頭一つ、その前にぬかずきて合掌せるは二十前後の女三人と稚き女の子一人、いずれも身なり賤しからぬに白粉気なき耳の根色白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんぐりの背比べの中から物の弾みでひょいと頭一つ飛び出せば、後はこの空間を支配する標準化の力学が、あれよあれよというまに絶対的な強者に押し上げてくれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の頭一つも見えなかつたのである。",
              "citation": {
                "source": "濱の冬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな男に、あんな卑しい人間に、謝罪はおろか、頭一つ下げることさえ、俺に取ってどんな恥辱であるか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は到頭一つの場所へ居据るようにさせられた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで到頭一つの企を考へた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな男に、あんな卑しい人間に、謝罪はおろか、頭一つ下げることさへ、俺に取つてどんな恥辱であるか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふのおひるは饅頭一つだつた、昨日のそれは飴豆二つだつた（いづれもおせつたい）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……頭一つで考えるんだからな。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初戦でＰＣ―１００を退けたＰＣ―９８０１が、他社の一六ビット機から頭一つ抜け出してから、ソフトハウスは新しいアプリケーションをまずＰＣ―９８０１用に書くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにこの頭一つが資本だがね。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛之介は人々のその輪の間へ、や、と頭一つ下げてわり込んで行った。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぁこの頭一つで首尾よくやっつけて来て見せるさ。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と怒鳴りつけたきり、しおしおとその男が出て行くまで、くるりと後を向いたまま頭一つ動かさなかった。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平田は、北京で頭一つ叩かれては五円借りて歩いている由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャヴェルは柱に縛られたまま、防寨が攻撃されてる間頭一つ動かさず、殉教者のような忍従と審判者のような威厳とで、周囲にわき立ってる反乱をながめていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
