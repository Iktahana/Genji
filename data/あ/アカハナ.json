        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あら、こう云ったからって妾は打算と赤鼻が好きさ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　英国金融資本が、米国産業資本に強靭な波瀾をまきおこしたために、米国資本を背景とした商工都市大阪は、ウォール街を恐怖がおそうと同時に、赤鼻女の野暮なアメリカの衣裳をつけて財界の迷路に立った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の紅殻色の壁に天狗の面が暴戻な赤鼻を街上に突き出したところは、たしかに気の弱い文学少年を圧迫するものであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩大学士の小さな家へ、「貝の火｜兄弟商会」の、赤鼻の支配人がやって来た。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして「貝の火｜兄弟商会」の、赤鼻の支配人は帰って行った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大学士の小さな家「貝の火｜兄弟商会」の赤鼻の支配人がやって来た。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」貝の火｜兄弟商会の赤鼻の支配人は云ひながらすばやく旅費の袋をさらひ上着の内衣嚢に投げ込んだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」たうとう貝の火兄弟商会の赤鼻の支配人は帰って行き大学士は葉巻を横にくはへ雲母紙を張った天井を斜めに見ながらにやっと笑ふ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして「貝の火兄弟商会」の、赤鼻の支配人は帰って行った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」貝の火兄弟商会の赤鼻の支配人は云いながらすばやく旅費の袋をさらい上着の内衣嚢に投げ込んだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とうとう貝の火兄弟商会の赤鼻の支配人は帰って行き大学士は葉巻を横にくわえ雲母紙を張った天井を斜めに見ながらにやっと笑う。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中に脂肥りのした體を紺の背廣服に包んだ中年の紳士、赧ら顏に赤鼻、厚い唇、白チヨツキの胸にからんだ太い金鎖の感じからが、どう見ても黨の有力者とでも云はれさうな代議士らしかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は取り巻きらしい態度で絶間なく赤鼻の男に話しかけるのである。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、赤鼻の男の口元を過ぎた卑しい微笑に氣が附くと、私は譯もなくはつとして顏をそむけた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、同じやうに笑ひ忍びながら女の寢姿の上に淫らな視線を注いでゐる赤鼻と、和服の男の顔に、私はふと氣が附いた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふふふふ……」　「へへへへへ……」　赤鼻と和服とが今度は抑へきれないやうな高聲で笑ひ合つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまる處、お前達の注意不行届なからぢや……」　と呶鳴りつけた赤鼻の聲が耳に響いた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤鼻はいきり立つた樣子で答へた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鼻と和服とは小聲に何かを車掌に答へた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤鼻が同情を求めるやうに相槌打つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紙入や時計はどうでも好いが、さしづめ困るのは手鞄だ……」　赤鼻はふと和服を振り返つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――不埓きはまる……」　やがて赤鼻は、それが精一杯の欝憤だといふやうな聲で毒毒しく呟いた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三日間、夕食後に全員で〈きよしこの夜〉〈ジングル・ベル〉〈赤鼻のトナカイ〉を英語で歌う練習をしたのに、じっさいに晩餐まえにやったのは、〈ジングル・ベル〉だけなのは不満だが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとから村の若者、子供、女、赤い蹴出しやら、大縞の絆纏やら、時計の鎖を絡ませた縮緬のへこ帯やら、赤鼻緒の黒塗り下駄やら、ぞろぞろとその細い畠道には、人が続いて、その向こうの林の中に巡査の制服が見え、おりおりけたたましく泣く女の声がきこえた。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝眼を覚ますと、お婆さんは先ず坊主になった箒で床を掃き、欠けた瀬戸物鉢で、赤鼻の顔を洗いました。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな眼鏡を赤鼻の先に掛け、布の張った枠に向うと、お婆さんは、飽きるの疲れるのということを知らず、夜までチカチカと一本の針を光らせて、いろいろ綺麗な模様を繍い出して行くのでした。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鼻の、大眼鏡の、青頭巾の婆さんは、朝から晩までその裡で繍をしているのです。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗は既に烏天狗の域を脱して凄い赤鼻と、炬火のような眼をもった大天狗だ。",
              "citation": {
                "source": "ブルジョア作家のファッショ化に就て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
