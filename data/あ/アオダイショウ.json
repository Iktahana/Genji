    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese rat snake (Elaphe climacophora)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一寸、そんな気がした、すると、誰れかゞ、「今度ア、伊三郎の田を入れるとて、わざと、あんな青大将のようにうね／＼とうねらしてしまったんだぞ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには、四五匹の青大将が畳のうえを這いまわる。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠や青大将が寝床のなかにまではいって行くのであるが、おとなたちは知らない。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、青大将なんです。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは些と調子はずれだったので、聞き返すように、「ええ、」二十七「先刻の、あの青大将の事なんでしょう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃあ、私が青大将を見た時に、」「貴下のお姿が楯におなり下さいましたから、爾時も、厭なものを見ないで済みました。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　棄て身に衝と寄り進んで、「じゃ青大将の方が増だったんだ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、青大将の顔に似た顔つきの、丸坊主のおやじが、首を振り振り、いかにも上手みたいにごまかしながら鮨を握っている様も、眼前に見るように鮮明に思い出され、後年、電車などで、はて見た顔だ、といろいろ考え、なんだ、あの時の鮨やの親爺に似ているんだ、と気が附き苦笑した事も再三あったほどでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まむしなら、生捕りにしますが、いまのは、青大将でした。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ね、此処らじゃ、蛇なんか何でもないのかも知れないけれど、」「はあ、青大将かね。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲角の青大将と、この傍なる菜の花の中の赤楝蛇と、向うの馬の面とへ線を引くと、細長い三角形の只中へ、封じ籠められた形になる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八戒の姿が消え、五尺ばかりの青大将が現われた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "青大将にしかなれないのか！",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "青大将が消えて八戒が現われた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ、麟を改めて鱗とすればいい、青大将め。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの青大将が、横笛を、臭を浴びても頬が腐る、黒い舌に――この帯を、背負揚を、襟を、島田を、緋の張襦袢を、肌を。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただただ、青大将の女房にはしたくないんです。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る見る、黒髪に散る雪が、輝く膚を露呈して、再び、あの淡紅色の紗綾形の、品よく和やかに、情ありげな背負揚が解け、襟が開け緋が乱れて、石鹸の香を聞いてさえ、身に沁みた雪を欺く肩を、胸を、腕を……青大将の黒い歯が、黒い唾が、黒い舌が。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物が鳥に不安を与えているのかと思って好く見れば、大きい青大将が首を籠の中に入れているのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな青大将である。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは俗に云う青大将だ。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど精巧には出来てはいるが、それは確かに拵え物の青大将であるので、わたしも思わず笑い出した。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の末に、下の八畳で多代子さんと娘が机にむかって勉強していると、肱かけ窓から一匹の青大将を多代子さんの顔へ……きゃっという騒ぎのうちに、相手は逃げてしまったのですが、なんでも横手の生垣を破って忍び込んだらしいのです。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "綽号を青大将というのだが、それを言うと怒る。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、しばらくして、青大将という眼つきの凄い三十男が僕に尋ねた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭３・11愛国婦人）------------------------------------------------------------------豚と青大将　田舎で豚飼をしてゐた男が、その豚飼に失敗して、何か仕事を見つけようと、都会にやつて参りました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一匹の青大将でした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "母豚が青大将を、尻尾まで、喰べてしまふまでには、子豚が、ピー、ピー、何匹産れたか、この豚飼の男には、おぼえがない程、たくさんに産れました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "――実は、お伽堂の女房の手紙が糸七に届いたのは、過ぐること二月ばかり、お京さんと、野土青鱗（あおだいしょうめ）画伯と、結婚式の済んだ後だったのだそうである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
