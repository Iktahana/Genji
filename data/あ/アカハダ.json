        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "）果樹園に取巻かれて、土の赤肌をポカンと開けて居るポロ競技場もかすかに見える。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤肌か」と口々にささやかれる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光と霧と松脂のしずくとが細かく降注ぐ山土の傾斜、ふやけた落葉の堆積のなかから踊り出して来たこの頭の円い菌こそは、松山の赤肌に嗅がれる体臭を、遺伝的にたっぷりと持ち伝えた、ちゃきちゃきの秋の小伜である。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういってたぬきが火ぶくれになって、赤肌にただれている背中を出しますと、うさぎはその上に唐がらしみそをところかまわずこてこてぬりつけました。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の魂は皮膚を剥がれた赤肌である。",
              "citation": {
                "source": "情意の干満",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨峨温泉展望青灰色の岩壁の外輪をあんなにもうねうねと帆走する白雲の塊り峽中は西風をめぐらした城のやうに今にも霧をはなち、雨を吹き入れよう下には阿羅漢の如く浴する赤肌の農人が物見臺の上にゆつたりと歩みいで衣をかかへて、遠く陰りゆく日を惜しげにその青青とした髯を風にすりつけては仰ぐ。",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めはところどころがぽくぽく穴のように落ち込んで見えたが、後には赤肌に脱け広がって、見るも気の毒なほどにだらりと垂れていた。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　赤裸今一人の逆語序論者金沢庄三郎先生は、裸（はだか）は赤肌（あかはだ）と言ふ旧来の説によつて、語序の逆になつたものとしてゐられた。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ひどれ船私は不感な河を下つて行つたのだが、何時しか私の曳船人等は、私を離れてゐるのであつた、みれば罵り喚く赤肌人等が、彼等を的にと引ツ捕へ、色とりどりの棒杭に裸かのままで釘附けてゐた。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　きょうはまるで朝から日射しものぞかせない灰色の冬空がますます低くおりてきて、ふきあげるひどい空らッ風が、腰かけている赤肌の松の巨木をユサユサと揺ぶった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "明月院の相手は、羽着きの薄い枯笹色の貧相な鶏で、いくどかの戦いで背中のあたりまで羽毛をむしられ、ぞっとするような赤肌をむきだしているのは悲惨だが、鶏冠を半分以上も剃り落してあるので、頭だけ見ると、鸚鵡のお化けのようで滑稽だった。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体を運搬する途中、瓦礫の上を手荒に引摺り廻されたものと見え、顔面はすっかり赤肌になり、人相が識別出来ぬほどに破壊されているのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの驚くべき勇士の決心は、赤肌をした松の幹の高い所に、二本の青い人間の足がブーラ、ブーラとしているのを見出した瞬間、何の役に立ったろう！",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、早い奴に褒美をやる」　赤肌の大地に、明るく銀貨が音を立てて飛ぶと、坑夫達は大人も子供も仕事を放り出して群がって来た。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "行者ものぼらないという鷲ヶ岳の赤肌へ、武蔵は、抱きついていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "めくれた皮の下から、黒血がほとばしって、ベロベロの、見るも無悪な赤肌が現れて来ることを、想像したからだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな日の激流に削られたような切岸が、足利の町屋根から数町東の岩井村の辺で赤肌をむいていた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "傑作のお手本、あかはだか苦しく、どうか蒲の穂敷きつめた暖き寝所つくって下さいね、と眠られぬ夜、蚊帳のそとに立って君へお願いして、寒いのであろう、二つ三つ大きいくしゃみ残して消え去った、とか、いうじゃないか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、すこしずつ大きくなるにつれて、だいいち私が自身いやらしくなって、私の特権はいつの間にか消失して、あかはだか、醜い醜い。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "褐色がかった火星兵の、あかはだかの死体が、あたり一面に、ごろごろころがっている。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
