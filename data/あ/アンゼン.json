        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安全について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "設計者が日本に地震という現象のあることをつい忘れていたか、それとも設計を註文した資本家が経済上の都合で、強い地震の来るまでは安全という設計で満足したのかもしれない。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、うかうかとそういうものに頼って脚下の安全なものを棄てようとする、それと同じ心理が、正しく地震や津浪の災害を招致する、というよりはむしろ、地震や津浪から災害を製造する原動力になるのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、颱風は大陸と日本との間隔を引きはなし、この帝国をわだつみの彼方の安全地帯に保存するような役目をつとめていたように見える。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし有害菌が沢山附着していれば何か適当な殺菌剤でも塗布した方が安全である。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "造船学者の方から見れば汽船の改良すべき点は色々あろうが、乗客の側から云えば船体の構造、機関の種類はどうでもよい、ただ安全で、動揺が少なくて、そして速力が大きければよいのである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は日露戦争中負傷の際に気が狂って以来ずっと茲の病房の患者であるそうですが、病状は慢性な代りに挙措は極めて温和で安全であると聞きました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうが安全だよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立っていた中年の下町女が何気なしにバスの間を覗いていたがふと自分の前の少女を見付けてびっくりしたような顔をして穴の明くほど見詰めていたようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうものは消極主義の審査官の安全第一という立場から云えば保留した方が無事である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとすれば、この最大限の地震に対して安全なるべき施設をさえしておけば地震というものはあっても恐ろしいものではなくなるはずである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄棒がこんな目に遭うくらいだから人間にとってはあまり安全な地帯でないのである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし安全も危険も実は相対的の言葉である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯の危険率も、危険地帯の安全率もゼロではない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度安全地帯の脇の狭い処で、車をかわす余地がない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は二つの品を丁寧に新聞紙で包んでくれて、そしてその安全な持ち方までちゃんと教えてくれた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険の時には汽笛、安全の場合には鐘を鳴らす事になっている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険どころかこれほど安全な道はないであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同後追うと、　大吉は仲蔵を境内の安全な場所へ置き、再び戻って来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして俺が毎晩家へ帰つて来る道で、俺の部屋の数ある道具のうちの、選りに選つてちつぽけな薄つぺらいもの、安全｜剃刀の刃なんぞが、千里眼のやうに思ひ浮んで来るのか――お前はそれがわからないと云つたが――そして俺にもやはりそれがわからないのだが――それもこれもやつぱり同じやうなことにちがひない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総師として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総帥として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全装置を直すのを忘れていたのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は黙って安全装置を戻し、銃をかまえた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、夢中に馳せまわっていながら、崖端に近づくと、一歩か二歩のところで、安全な方へ引っかえした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれがいちばん安全な環境でもあるであろう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこんなところに蜂の巣があってはあぶないから、落してしまおうと思ったが、蜂の居ない時の方が安全だと思ってその日はそのままにしておいた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならばまだまだ安全であるが、排泄物をなくするために食物を全廃すれば餓死するより外はない。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくは安全だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はあんぜんとして溜息をついた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
