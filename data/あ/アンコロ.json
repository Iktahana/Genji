        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日餡ころについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "餡ころという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は餡ころの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には餡ころが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "餡ころを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは餡ころについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "餡ころの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は餡ころの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では餡ころが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "餡ころという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に餡ころという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では餡ころについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "餡ころを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると餡ころは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "餡ころについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では餡ころが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に餡ころは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により餡ころの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "餡ころは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に餡ころは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "最も得意なのは、も一つ茸で、名も知らぬ、可恐しい、故郷の峰谷の、蓬々しい名の無い菌も、皮づつみの餡ころ餅ぼたぼたと覆すがごとく、袂に襟に溢れさして、山野の珍味に厭かせたまえる殿様が、これにばかりは、露のようなよだれを垂し、「牛肉のひれや、人間の娘より、柔々として膏が滴る……甘味ぞのッ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "力餅　力餅といふものは大福に製して賣るところもあるが、多くは餡ころに造つて、旅する人の助けとする。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一わたり上戸と下戸の口にあう鮨と餡ころの月旦を試みように、弥助は両国の与兵衛、代地の安宅の松、葭町の毛抜鮨とか、京橋の奴や緑鮨、数え立てたら芝にも神田にも名物は五ヶ所七ヶ処では利かないが、何といっても魚河岸のうの丸にとどめを差す。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父さんは西洋料理の進歩した食物を食べる癖に小児は天保度以来少しも改良せざる塩煎餅や餡ころ餅を食べる有様だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の中ほどに掛け茶屋があって、そこでは、いつも、うまそうな餡ころもちを造って、店に並べておきました。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、酒呑みで、餡ころもちはほしくなかったが、牛が、たいそうそれを好きだということを聞いていましたから、やがて、その家の前へさしかかると、「どうか、この荷物を無事に先方へ届けてくれ。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば帰りに餡ころもちを買ってやるぞ。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、牛を引いて、やがて餡ころもちを売っている店の前へかかりますと、その時分から、ゴロゴロと雷が鳴りはじめました。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は、きっと餡ころもちを買ってやるから。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、餡ころもちを売る店の前へさしかかると、男は、ちょっと店の方を横目で見て、「今日は、帰りに餡ころもちを買ってやるぞ。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、餡ころもちを売る店の前へさしかかりました。",
              "citation": {
                "source": "ある男と牛の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はどこの家にもあったハンボウという、強飯を冷やしたり、餡ころ餅を作るのによく使うくりものの器も木地屋の作であるが、丹波や丹後の奥にゆくと、今でも使っている家があるとか、なつかしいことである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中どころにごろごろして竹の皮包みの餡ころかなにかを頬張りながら、下卑た話をしてゲラゲラ笑っているのもあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらで寝転んで、餡ころを頬張りながらゲラゲラ笑って下卑た話をしているのが、米友の耳によく入ります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人とも化かされてるんだから、糞を御馳走のつもりで喰べるんだよ」光子は面白くて堪らぬようにゲラゲラ笑いながら、自分の口で喰いちぎった餡ころ餅だの、滅茶滅茶に足で蹈み潰した蕎麦饅頭だの、鼻汁で練り固めた豆妙りだのを、さも穢ならしそうに皿の上へ堆く盛って私達の前へ列べ、「これは小便のお酒のつもりよ。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　牛｜部屋のかげで、さざんかが白くさくころに、松吉、杉作のうちでは、あんころ餅をつくりました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園寄の辻に、屋台にちょっと毛の生えたくらいの小さな店で、あんころ餅を売っている娘だそうです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その框へ腰をお掛けなされまして、盆にあんころ餅寄越せ、茶を持てと、この美津に御意ござります。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はッ、」「き様、逢阪のあんころ餅へ、使者に、後押で駈着けて、今帰った処じゃな。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろ狸のきぬた巻でも、あんころ餅でも、鹿子餅でも、何でもございじゃ、はい、何でもござい、人気おこし、お菓子はよしか。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんころ餅　松任のついでなれば、そこに名物を云うべし。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餅あり、あんころと云う。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下金沢より約三里、第一の建場にて、両側の茶店軒を並べ、件のあんころ餅を鬻ぐ……伊勢に名高き、赤福餅、草津のおなじ姥ヶ餅、相似たる類のものなり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松任にて、いずれも売競うなかに、何某というあんころ、隣国他郷にもその名聞ゆ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けえりにあんころもちでも大福もちでもたんと買ってね、子どもたちのその落ちくぼんだ目玉をもとどおりに直させておやんなせえましな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――売っただけの金で襦袢や腰巻の切れを買ったり、餅屋に寄って「あんころ」などの買い喰いをした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "くず餅、あんころ、すあまなどが好物で、月給のおりた時には、清三はきっと郵便局に寄って、荻生君を誘って、角の菓子屋で餅菓子を買って来る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の宿直室に先生のとまっているのを知って、あんころ餅を重箱にいっぱい持って来てくれるのもあれば、鶏を一羽料理して持って来てくれるものもある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに僕のは、しるこ屋の前を通る、いろんな色の餅菓子やあんころ餅などが店にならべてある、堪らなくなって飛びこむ、片っ端から平らげて行く、満腹どころかのどにまでもつめこんでうんうん苦しがる、というようなすこぶる下等な夢だ。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体をこきつかわれた疲れを、せめて甘いものでいやしたくて、「上品」だった筈の女学生たちは寄宿舎で、ぼた餅やあんころの話に羨望した。",
              "citation": {
                "source": "砂糖・健忘症",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
