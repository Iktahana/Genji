[
  {
    "uuid": "89a929b3-5f04-545f-bfc7-f81d97fc661d",
    "entry": "相酌",
    "reading": {
      "primary": "あいじゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drinking alcohol while pouring it for each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相酌は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相酌が重要です。",
              "source": "幻辞"
            },
            {
              "text": "相酌に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相酌が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相酌について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相酌についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相酌について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相酌が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相酌が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相酌は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相酌は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相酌を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相酌をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相酌が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相酌の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相酌を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相酌に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相酌について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相酌は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相酌を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこでおれは時々自分の家で飲む時には必らず今の太郎坊と、太郎坊よりは小さかった次郎坊とを二ツならべて、その娘と相酌でもして飲むような心持で内々人知らぬ楽みをしていた。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐ろに相酌みつつ終にまた深更まで飮んでしまつた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりの悪いのは初めのうちだよ」　猫板をチャブ台にして、鶴吉とお千代という年増が、相酌でちびちび飲んでおりますと、この夜更けだというのに、ここの家はそれからが繁昌で、妙な女がぞろぞろと帰って来る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
