        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かの子　ただ何となく垢抜けした感じがします。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　昔の新しい女は勇気はあったが、垢抜けしていなかった。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこれからの女は今までの新らしさを土台にして垢抜けすることが一特色になるのかね。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人、随分得手勝手な、無責任極まる与太を飛ばしましたが、結果に於ては出来上ったシナリオが想像以上に明るく面白く、ギャグなぞも案外垢抜けのした奴がありました。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ、」「骨のあるがんもどきかい、ほほほほほほ、」と笑った、垢抜けのした顔に鉄漿を含んで美しい。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一組は、六十くらいの白髪の老爺と、どこか垢抜けした五十くらいの老婆である。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックだが、安っぽい荒削の木材の生なましさや、俗々しいペンキ塗り立ての感じはなく、この界隈では垢抜けした装飾の店だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンを閉める――そしてそれから……そんな昨日と同じコースを、再び、くりかえすほど信吉は垢抜けしない男ではなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "井葉子さんもずゐぶん年が寄つたと思ふ、それだけまた、その接待振が垢抜けしてうれしい、感謝合掌。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリッジの上ったり降りたりは、自分にはむしろ、ずいぶん垢抜けのした遊戯で、それは鉄道のサーヴィスの中でも、最も気のきいたサーヴィスの一つだと思っていたのですが、のちにそれはただ旅客が線路をまたぎ越えるための頗る実利的な階段に過ぎないのを発見して、にわかに興が覚めました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五年間、私は故郷から離れていたが、故郷も変らないし、また、私も一向に都会人らしく垢抜けていないし、いや、いよいよ田舎臭く野暮ったくなるばかりである。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の児の母親で、その燃立つようなのは、ともすると同一軍人好みになりたがるが、垢抜けのした、意気の壮な、色の白いのが着ると、汗ばんだ木瓜の花のように生暖なものではなく、雪の下もみじで凜とする。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや垢抜けしている筈の芸人同志である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は日本で言うとそれ者上りのように垢抜けのした、白ちゃけた感じのする面長の美人で白髪交りの褐色の頭髪を後で手際よくまるめて居る。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目色に凛と位はあるが、眉のかかり婀娜めいて、くっきり垢抜けのした顔備。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は年ごろ二十二、三で、顔にうす痘痕はあるが垢抜けのしたいい女。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ転がり込んだ紋作は年も若い、芸人だけに垢抜けもしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後か信州者だろうが、米搗きにしちゃあ垢抜けのした野郎だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "父に似て細面の彼女は函館の生活に磨きをかけられて、この辺では際立って垢抜けがしていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壱岐殿坂時代の緑雨はまだこういう垢抜けした通人的気品を重んずる風が残っていた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは平々淡々のうちに人を引き着ける垢抜けのした著述を推すもいい。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにちょっと眼に立たないで、よく見ると垢抜けがしている……というのが最も平たい言葉であろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二幕ぐらいで閉場になるという頃に、背の高い、四十以上の垢抜けのした人が我々のところへ廻って来て、二十五銭ずつを集めていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに第一『私が』だの、乃至は『俺が』だのをブラ下げると、ひどく垢抜けないことになり、田舎者が愈々田舎者になります。",
              "citation": {
                "source": "大衆文芸問答",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、次郎吉を調べるのほかは無いので、庄太に案内させて聖天下へ出かけて行く途中、二十七八の垢抜けのした女に逢いました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は三十五で、垢抜けのした女ですよ」「番太郎へ次郎兵衛をたずねて来たのは、そのお葉だな」「それに相違ありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "年上ではありますが、お葉もちょいと垢抜けのした女ですから、もしや若主人とどうかしているのではないかと思いまして、それもいろいろ詮議したのでございますが、決してそんな覚えはないと若主人は申します。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥坐舗の長手の火鉢の傍に年配四十｜恰好の年増、些し痩肉で色が浅黒いが、小股の切上ッた、垢抜けのした、何処ともでんぼう肌の、萎れてもまだ見所のある花。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸親子の愛情に譬えて見れば、自分の児は他所の児より賢くて行儀が可いと云う心持ちは、濁って垢抜けのしない心持ちである。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに垢抜けのした精美された心持ちで考えると、自分の児は可愛いには違いないが、欠点も仲々ある、どうしても他所の児の方が可い、併し可愛いとなる。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
