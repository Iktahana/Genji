    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rain hat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨笠について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨笠という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨笠の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨笠が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨笠を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨笠について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨笠の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨笠の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨笠が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨笠という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨笠という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨笠についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨笠を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨笠は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨笠について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨笠が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨笠は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨笠の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨笠は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨笠は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……大な雨笠を、ずぼりとした合羽着た肩の、両方かくれるばかり深く被つて、後向きにしよんぼりと濡れたやうに目前を行く。",
              "citation": {
                "source": "雨ばけ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雨具、雨笠を手に、門から一足出た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど狭く限定しないで、「夜鰹はつ鰹」は「富士の霧笠時雨笠」というような、一種の調子を取った言葉と見ても差支ない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがさきの　こうとくじ　と　いう　おてらの　じゅうしょくの　じゅうちゅう　と　いう　おしょうさんが　ごつちみかどてんのうの　つかいと　して、この　しょうおんあんに　きました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
