              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中には雨傘の用意までして来た郊外の人もある。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董屋は、今朝、戦線へ出動した山東兵が、雨傘を持ったり、石油罐の一方をくり抜いて太い針金を通したバケツをさげていた、と笑っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は通らず、雨傘も威勢よくポンと轆轤を開いたのでは、羽目へ当って幅ったいので、湯の帰りにも半開、春雨｜捌きの玉川｜翳。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は重い雨傘をかたむけて、有楽町から日比谷見附を過ぎて堀端へ来かかると、俄にうしろから足音がきこえた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、歌舞伎座にて「侠客春雨傘」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより渋蛇の目の雨傘が暫く流行す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は桜痴居士の著作のみを択みて、「春日局」「義士誉」「春雨傘」「新七つ面」。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンス、本箱、机、椅子、座蒲団、水屋、雨傘、洗面器の類まで買い与えたので、へそ繰りを全部投げ出した上に、借金が出来る始末だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この上天気に雨傘を携えた丈の高い西洋人が私共の方へ近づいて来た。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の雨傘とそれから灰色の立派な顎髯とに見憶えがあった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、外出の時には、ステッキの代りに、どんなお天気の日でも木綿の雨傘を携帯する位の技巧を会得した。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、雨傘をこっそり開く音である。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫、雨が降らないとは思うけれど、それでも、きのうお母さんから、もらったよき雨傘どうしても持って歩きたくて、そいつを携帯。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実は、この古ぼけた奇態な、柄のひょろ長い雨傘一本。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のけさ持参した古い雨傘が、クラスの大歓迎を受けて、皆さん騒ぎたてるものだから、とうとう伊藤先生にもわかってしまって、その雨傘持って、校庭の隅の薔薇の傍に立っているよう、言いつけられた。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は葭壁に凭せかけた客の雨傘を取つた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "簷端には古衣、雨傘その外骨董どもを、懸けも陳べもしたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天候の変化は群集に奇妙な影響を与え、群集全体はたちまち新しい動揺を起して、無数の雨傘に蔽われてしまった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "）夫人、雨傘をすぼめ、柄を片手に提げ、手提を持添う。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雨傘にて三つ四つ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家　（つかつかと出で、雨傘を開き、二人にさしかく）お持ちなさい。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹がいなくなってから、独り者の気楽さと不自由さとを一つに味わった彼は、火鉢の火をうずめて、窓を閉めて、雨戸を引き寄せて、雨傘を片手に門を出ようとすると、出合いがしらに呼びかけられた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたばたと風になぶられる前幌を車夫がかけようとしているすきから、女将がみずみずしい丸髷を雨にも風にも思うまま打たせながら、女中のさしかざそうとする雨傘の陰に隠れようともせず、何か車夫にいい聞かせているのが大事らしく見やられた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居はつひ構内の長屋の一つであるけれど、『せい／″＼氣を利かしてお役に立つてみせます』と言つてるやうな娘の心をいぢらしく思ひながら、彼女はぱちりと雨傘をひらく。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは重い雨傘をかたむけて、有楽町から日比谷見附を過ぎて堀端へ来かかると、俄かにうしろから足音が聞えた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台の軒にも牡丹のような紅い提灯がゆらめいて、「それおぼえてか君様の、袴も春のおぼろ染……」瀧夜叉がしどけない細紐をしゃんと結んで少しく胸をそらしたときに、往来を真黒にうずめている見物の雨傘が一度にゆらいだ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは雨傘をかたむけてお玉さんの窓ぎわを通ると、さながら待ち設けていたかのように、窓が不意に明いたかと思うと、柄杓の水がわたしの傘の上にざぶりと降って来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台の軒にも牡丹のような紅い提灯がゆらめいて――それおぼえてか君さまの、袴も春のおぼろ染――滝夜叉がしどけない細紐をしゃんと結んで少しく胸をそらしたときに、往来を真っ黒にうずめている見物の雨傘が一度にゆらいだ。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは雨傘をかたむけてお玉さんの窓ぎわを通ると、さながら待ち設けていたかのように、窓が不意にあいたかと思うと、柄杓の水がわたしの傘の上にざぶりと降って来た。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがさきの　こうとくじ　と　いう　おてらの　じゅうしょくの　じゅうちゅう　と　いう　おしょうさんが　ごつちみかどてんのうの　つかいと　して、この　しょうおんあんに　きました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
