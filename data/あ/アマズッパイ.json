    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sweet and sour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘酸っぱいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘酸っぱいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘酸っぱいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘酸っぱいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘酸っぱいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘酸っぱいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘酸っぱいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘酸っぱいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘酸っぱいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘酸っぱいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘酸っぱいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘酸っぱいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘酸っぱいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘酸っぱいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから尾根を伝わって、下り気味になる、ちょいちょい小さく尖った山稜は、大波の間に、さざ波をだぶだぶ打ち寄せたようで、爪先が上ったり下ったりする、石の皺には、黄花の石楠花が、ちらほら咲いている、この花の弁で承けた霧の雫を吸ったときは、甘酸っぱい香気で、胸が透いた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "錐を引いたと同時に去って行く痛みの尾のいおうようない甘酸っぱいひりひりした感覚の中に、うっかり閃いて来る心象は橘屋の娘のことでなければ富士の白い姿であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イッチのラジオが、やっとスウィッチを入れたバイ」　と青年達は甘酸っぱい顔をして笑った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の隅に、その一升瓶があるばっかりに、この狭い家全体が、どろりと濁って、甘酸っぱい、へんな匂いさえ感じられ、なんだか、うしろ暗い思いなのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどこに残って溜っていたのでしょうか、悲しみに少し甘酸っぱい味がついて、それが胸を蜜柑の房のように絞るとその悲しみは嵩を増して来て、くいくいとまた泣き歔欷りが二つ三つ立て続けに出ます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと御影石の滑かな石垣に手を触れると、甘酸っぱい花弁の腐りかけたのが指先きに喰っついて来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちい――やらまたたあ――んぐろえ　山子の実は甘酸っぱい味がして、左程まずくもないそうだけれど、その埃だらけなのに怖毛をふるって、私達はとうとう手が出なかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は、空と港が一つに煙って、へんに甘酸っぱい大気のなかを黄塗りの電車がことこと揺れて通った。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど、遠い流れの向うから聞えて来る草笛の音のような、甘酸っぱい感傷の情のおもむきで、ひたひたと身に迫って来る水に似た愁いさえ伴うのだった。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酸っぱい実を、よく眺めては、食べているうち、ふっと瞼の裏が、熱くなりました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酸っぱい湯気を立てている鮨屋（此湯気は甘酸っぱくないかもしれぬが、そうしておかぬと気持が出ない）、これらの店の連続は、近代都市、経済都市の玄関ではなく、朱判を押した白衣の、団体客によってその繁栄を保持している町のステーション風景である。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばんだ電灯の下に、がたがたの床を踏みならし、酔い痴れたピエロが踊り出すと、いつか印袢纏の兄いが、シルクハットの紳士が、甘酸っぱい体臭を持った、肉襦袢の女たちが、思い思いに捻子をまかれた泥人形のように、がらっとした小屋一杯、猥褻な悲鳴をあげながら、地獄絵巻を展開していった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを割ると中からソーダ水のような甘酸っぱい水と、豚の脂のかたまったようなコプラというものが出て来ます。",
              "citation": {
                "source": "椰子蟹",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側は、アパアトメントをずっと下等にした、いわゆる貸間長屋というやつで、一様に同じ作りの、汚点だらけの古い煉瓦建てが、四六時中｜細民街に特有な、あの、物の饐えたような、甘酸っぱい湿った臭いを発散させて暗く押し黙って並んでいる。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もしらぬ夫人は、灼けつくような渇きを医すため、夢中になってその甘酸っぱい水をゴクリと咽喉にとおしたとき、青酸加里のカプセルは笛吹川の口を離れて夫人の胃の腑に運ばれてしまったのです。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若々しさのうちに何処か緊りのない爛熟した肉付で、甘酸っぱい匂い――匂いとも云えないほどの風味が、その全身に漂っていた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甘酸っぱいような妙な匂ですよ。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その甘酸っぱいのに、汗の匂を交えたのもあるし、黴の匂を交えたのもあるし、薄荷の匂を交えたのもあるし、レモンの匂を交えたのもあって、いろいろです。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "張りきったくりくりした肉付が、何となく甘酸っぱい肌の匂いと共に、彼の胸の中に泌み通ってきた。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酸っぱい汁――たしかに地上でおなじみの蜜柑にちがいなかった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酸っぱいような水薬をつくって、その飲み方や、病児の扱い方などを細々と説明して、やがて医者は帰って行った。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白な頸筋から甘酸っぱい匂いが洩れてきた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内には、はぎの花が盛りなばかりか、どこからともなく、もくせいの甘酸っぱいような香りがただよってきました。",
              "citation": {
                "source": "子供は悲しみを知らず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "高岡のひとりぼっちの叩き廻っても後の沼地一ぱいがらんどうな響きしかはね返してこぬ豚箱の中で僕はしみじみと生のうどんの皮をひっぺかしながらそう思ったそれは青い蚊帖が雨上りの甘酸っぱい臭いをたてながら差入れの風鈴と一しよにゆさ／＼揺れていた時だった！",
              "citation": {
                "source": "餅の歌",
                "author": "――全農の林延造氏に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いているうち、だんだん唄の世界へ魅き入れられて、甘酸っぱい哀愁に、キューッと小助六は胸をしめつけられてきた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「す、すみません」　ピョコピョコお辞儀をして辺りを見廻すと、甘酸っぱいようなものの立ちこめている晩春の暮れ方。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から、旅姿の娘に肩を貸して、同じ茶店の奥へ入って来る、八五郎の甘酸っぱい顔というものは――　何しろ娘の可愛らしさは非凡でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣の浪人ものは、その体を見て、あまずっぱいような微笑を湛えたかと思うと、ほどなくこれも匆々として釣道具をおさめて、つないでおいた小舟へ飛び乗ると、自ら艪を押してさっさと南浜の方へ向けて漕ぎ出し、忽ち葦の間に隠れて影も形も見えません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
