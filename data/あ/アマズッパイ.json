[
  {
    "uuid": "522d4ea9-913d-5c41-9e31-224603e1155b",
    "entry": "甘酸っぱい",
    "reading": {
      "primary": "あまずっぱい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
