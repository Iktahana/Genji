        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　「子供が生れるんだって」　「まァ赤ちゃんが」　二人、笑い出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「それで今度、赤ちゃんが出来るんですって」　「なーンだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍のお静が、　「兄さん、昨日帰ったのよ、お父っつあんもう一日早く帰って来ればよかったのに……」　「そうか、そりゃ惜しい事をしたな」　「赤ちゃんどうだった？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀橋の区役所に勤めていて、ことしは三十四だか五だかになって、赤ちゃんも去年生れたのに、まだ若い者のつもりで、時々お酒を飲みすぎて、しくじりをする事もあるようです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よその人も、ご自分の赤ちゃんが可愛くて可愛くて、たまらない様子で、お湯にいれる時は、みんなめいめいの赤ちゃんに頬ずりしている。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですがまだ、生れたばかりの赤ちゃんですから、あんまりおさわぎになるとびっくりいたしますよ」と申しました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、お、お」とそれをおいたわりになってからお母様は、「だがね、これはまだ親のひばりのお乳をほしがっている赤ちゃんひばりですよ。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんになって、赤ちゃんを生んで……そうすれば、あたしは祖母さんなのかしら――おかしいわねえ。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『実はね、先刻から訊こう／＼と思っていたんだけど、此の頃エミちゃんの処で、誰か赤ちゃん生んだ人ない？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月一日には誕生祝賀会をやるから是非出席してくれたまえって、云っていたんです……それで、「赤ちゃんが生まれたんですか？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この赤ちゃんは。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『だけど、そんなら赤ちゃんはどこから来るの？",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、かわいい、小さな赤ちゃんを連れてくる、コウノトリについてのお話もしました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、おばあさんは、赤ちゃんの言葉だってわかるのよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは、ちっちゃな人間の赤ちゃんたちのいる、お池のあるところを知っているの。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の赤ちゃんたちはね、コウノトリが行って、おとうさんやおかあさんのところへ連れていってあげるまで、そこに寝ているんですよ。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいらしい、ちっちゃな赤ちゃんたちは、そういうふうに、そこに寝ていて、大きくなってからは、もう二度と見ることのない、楽しい夢を見ているのよ。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんやおかあさんは、だれでも、そういうちっちゃな赤ちゃんをほしがっているし、子供たちは子供たちで、みんな、妹や弟をほしがっているんですよ。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、あたしたちは、みんなでそのお池へとんでいって、わる口の歌をうたわなかった子や、コウノトリをからかったりしなかった子のところへ、かわいらしい赤ちゃんをひとりずつ、連れていってやりましょうね。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そのお池には、死んだ夢を見ている、死んだ赤ちゃんもいるのよ。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あの子のところへは、その死んだ赤ちゃんを連れていってやりましょう。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、アンネ・リスベットは、伯爵さまの、赤ちゃんの、うばなのですから。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ちゃんは、王子のようにじょうひんで、天使のようにきれいでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットは、この赤ちゃんを、心から、かわいがりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットは、赤ちゃんのときに、だいてあげてから、ぼっちゃまには、一度も、会ったことがありませんでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラプンツェル、お前は、もう赤ちゃんを産んだのだよ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのお嫂さんは、ことしの夏に赤ちゃんを生むのよ。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなかに赤ちゃんがいると、とてもおなかが空くんだって。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って、摩耶夫人の影像――これだと速に説教が出来る、先刻の、花御堂の、あかちゃんの御母ぎみ――頂餅と華をささげたのに、香をたいて、それから記しはじめた。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかちゃんや、あかちゃんや、うまうまをあげましょう、其処を出ておいで。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
