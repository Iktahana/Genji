        "examples": {
          "standard": [
            {
              "text": "私は毎日アニミズムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアニミズムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアニミズムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアニミズムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアニミズムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアニミズムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアニミズムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアニミズムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアニミズムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアニミズムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアニミズムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアニミズムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アニミズムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアニミズムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これは一時學界を風靡したアニミズムが、又それに從つてローデが、原始人共通の觀念として説いた「魂ひ」（プシュケー）の觀念に當るものである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い時代のアイヌは、アニミズムといって、山でも川でも沼でも人間同様に考えて、大小二つの沼が並んでいれば、それを親子連れと考えて「親の沼」「子の沼」と呼んだのであります。",
              "citation": {
                "source": "アイヌ語学",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一では、アニミズム・トーテミズム、から始まって民族宗教・世界宗教・への発展を、実証的に又歴史的に更に又哲学的に解明している。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に又之は一種のアニミズムともなって現われる。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の生成化育は草木の生命霊魂と共に、農業中心主義と結びついた場合のアニミズムの信仰対照だと見ることが出来よう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って之は、宗教が何等か宗教的な観念――アニミズムや況して又神学的教義――によって発生して来るのではなくて、正に社会生活の諸条件との交渉――例えばトーテミズム――によって成立する、ということを告げていた筈のものなのである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国人は全自然界のアニミズムを信じ、すべての部分は神および幽霊によって生命を与えられており、悪魔は至る所に無数に群をなしている、と考えている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学は理論、学派および体系、たとえばイアトロ力学、イアトロ化学、体液学、シュタールのアニミズム、ファン・ヘルモントおよび追随者の生気論学説、によって文字通り荒廃していた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで原始的な人のもつ宇宙の概念を論ずると、呪物崇拝と兆候信仰から、アニミズムと多神教への移行を伴うことにより、非常に遠くまで我々を導くことになり、魔神崇拝と医学のあいだの興味深い関係を細かく追求することになり、原始的医学とその心理的な源におけるいろいろな神秘主義の主な種類を示すことになるであろう。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "この運動をもっとも激しく表現していたのは医学ではハレ大学教授シュタールのアニミズムであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学の領域においてもかなりの数の信奉者を持ったのは彼の病気についての一般的概念が主としてシデナムが引いた線上にあったからであり、シュタールのアニミズム学説は唯物主義反対の医師たちと同じ考えを病気の概念に与えていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
