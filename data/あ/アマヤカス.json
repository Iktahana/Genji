        "examples": {
          "standard": [
            {
              "text": "私は毎日甘やかすについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘やかすの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘やかすが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘やかすについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘やかすの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘やかすが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘やかすという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘やかすについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘やかすは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘やかすが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘やかすは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘やかすの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘やかすは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘やかすは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "人の云うことを聞けば宜いと云って人を甘やかすばかりが慈悲ではありません。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母というはお豊といい、言葉の少ない、柔和らしく見えて確固した気象の女でしたが、僕を叱ったこともなく、さりとて甘やかす程に可愛がりもせず、言わば寄らず触らずにして居たようです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいうことを聴けば宜いといって人を甘やかすばかりが慈悲ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら民衆は、彼等を甘やかすことによって益々堕落し、鞭撻することによって向上してくるからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、孫の久助君を甘やかすのが癖だつたので、「そげん慌てて出かけでもええだ。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "断乎たる強制一点張が、へんに彼等を甘やかすよりも効果的であるのは言う迄もない。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が甘やかすのだ。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「辛くて仕やうあんめえなよきは」おつぎは甘やかすやうにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝ツ等知りもしねえで」勘次は與吉を甘やかす樣にしていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の猫におけるや、丁度若い母親が初めて産んだ子を甘やかすように、始終｜懐ろに入れたり肩へ載せたり、夜は抱いて寝て、チョッカイでも出せば溶けるような顔をして頬摺したり接吻したりした。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いこみが強いんだから」「どうしておまえは、そういうふうに、慶一を甘やかすんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが父が先に立つて此方を甘やかすのに乗ずると、後になつて蔭で面白がつて彼の行為を吹聴することがあるので、彼はそれを一寸憂慮した。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くともそれは彼を甘やかす、もしくはただいたはるだけのものではなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると私は弘の顔を見てるうちに、この児にはあんまり勉強させない方が好い、田舎へでも遣って育てた方が好い、そう思うことも有りますよ」「そのくせ、父さんは一番物を教えたがってるくせに――一番甘やかすくせに」と言って細君は笑った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "友情に甘えるな、自分を甘やかすな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えるなかれ、甘やかすなかれ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えるな、甘えるな――媚びるな、媚びるな――自分を甘やかすな、他人に媚びるなと自から戒める言葉である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "※友情に甘えるな、自分を甘やかすな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘やかせば甘やかすほど附けあがる咲子の性質も気に入らなかつた。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり病人扱いにし、涙でぬらし甘やかすだろう。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は温泉宿の燈火が美しく、三味線をひいて街を流して歩く女なども多く、昨夜も海岸を散歩してみましたら甘やかすような春の月のおぼろな光のなかを男と女と戯れながら歩いてるのを幾組も見受けました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘やかすことは弱くむなしくさせるばかりですからね。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己を懺悔する言葉のうちにいかに容易に他に対してかえって自己を誇示する心が忍び込み、またいかに容易に罪に対してかえって自己を甘やかす心が潜み入ることであるか。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私の云つた自他の区別が出来ない人達だから、本当の意味の正しい個人主義だとか自己本位とか云ふことゝ自分を甘やかすわがまゝとか傲慢な専横との区別がちつとも分らないのです。",
              "citation": {
                "source": "従妹に",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいうちに院とお別れになって、お母様の宮様が甘やかすばかりにしてお育てになった方だけれど、光った将来が今から見える人になっていらっしゃる」　などと尚侍は言って、自分の息子たちの字の拙さをたしなめたりした。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、今、子供を甘やかす事は当人にとってかえって不幸に違いない。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ教育的で厳しいだけで、ちっとも子どもを甘やかすというところのない母親は美しいものではない。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことが、私の感傷を甘やかすのである。",
              "citation": {
                "source": "孤独者の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "揶揄するような甘やかすような、そしてこちらでちょっと極り悪く思うような眼差しで、人中も構わず、彼女はじっと彼を眺めました。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、年とつたお母さんはお母さんで、嫁ごは子供をあまやかしすぎる、子供と猫はあまやかすほどぞうちやうする、とひびのはいつた金だらひを叩くやうな声で、いひはつてをりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
