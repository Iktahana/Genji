        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安全弁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全弁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全弁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全弁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全弁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全弁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全弁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全弁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全弁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全弁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全弁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全弁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全弁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全弁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全弁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全弁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全弁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全弁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全弁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全弁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これが、いわば安全弁のような役目をして気持ちよく折れてくれるので、その身代わりのおかげで肋骨その他のもっとだいじなものが救われるという話である。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも何か、もっとずっと悪い影響を救うための安全弁の作用をしているに相違ない。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば高圧釜の安全弁のように適当な瞬間に涙腺の分泌物を噴出して何かの危険を防止するのではないか、そうでないとどうも涙の科学的意義がのみ込めない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には猫の事をかくのがこの上もない慰藉であり安全弁であり心の糧であるような気がする。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セーフティーバァルプ」（安全弁）という綽名がついていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　宮島資夫氏の「安全弁」（「解放」）は結末で、全体が生き返つてゐる。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから安全弁をひらくやら、給水パイプのコックをひねるやら大騒ぎをして、やっとエンジンの壊れるのを救った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾の安全弁を外すことを忘れるな」　敵と引組んだまま甲板に転んでいる川上機関大尉は、フランク大尉の鉄拳の雨に叩かれながら、喉もはりさけるように叫んだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は爆弾の安全弁を外すと、そこへ飛びだした敵の水兵を片手で殴り倒すが早いか、爆弾を抱えたまま、爆弾庫の中に身をおどらせてとびこんだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、中国人と英国とが馬来で結束していくということは、ヨーロッパ人をして、ますます中国本国や、印度で、彼らの主権を振わすに都合よくなっていくばかりでありますから、馬来の中国人の性格というものは、これは東洋の安全弁です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何より印度を苦しめている安全弁は、事実上、シンガポールを中心として生活している馬来半島の中国人です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、統制主義は余りに窮屈で過度の緊張を要求し、安全弁を欠く結果となる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん一つは、アラビヤ人との混合血液による国民性だが、毒を征するに毒をもってすという為政的見地から、皮肉に言えば、闘牛は、夏のすぺいん人の一時的錯乱に対する安全弁かも知れない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘争が激化しないやうに安全弁の役目をつとめることが一つ、それからもう一つの必要は、全然、彼の個人的な問題だが、その常設館の営業主任がどうも彼とは合はないので、争議をここから始めるならば、主任はその責任上解職又は他の館へ転任させられるだらう。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が何も知らぬ間に、私がお寺のおかみさんに適当するかしないかを考うることもなしに、ただ、一人は私をおもちゃにするために、一人は私を自分の生活の安全弁にせんがために、勝手に夫と定め、妻と定めたことに、何らの責任がないと言うのであろうか。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――哀れなる祖母よ、あなたはただ叔父の安全弁として連れて来られたのです。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全弁があんなに白いスチームを吐いているだろう……ブーブーいってるのが聞えるかい。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は機関室へ帰ると直ぐに、汽鑵の安全弁の弾条の間へ、鉄の切っ端を二三本コッソリと突込んで、赤い舌をペロリと出したものだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八千｜磅の証文をタタキ返して、安全弁の鉄片を引っこ抜いてしまった。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全弁が夜通しブウブウいっていたんですから」「……弱ったな……」　この船長が、コンナ弱音を吐いたのを俺はこの時に初めて聞いた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五歳の未亡人の彼女と、世間に名を知られてる五十歳の文士、それが却って安全弁だった。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に「生」への安全弁でもありました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の詩が安全弁的役割から蝉脱して独立の生命を持つに至るかどうか、それは恐らくもっと後になってみなければ分らない事であろう。",
              "citation": {
                "source": "自分と詩との関係",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、江州柏原駅にあらかじめ道庵を入れて運ぶために備えつけられていた長持が無い限り、道庵の呼吸のために安全弁が特設されてあろうはずもないから、いたずら心はいたずら心として、中に納まった道庵は蓋をされる瞬間に、そこは心得て、なんらか空気流入の調節方法を講じて置いたものと見なければならぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚こそは日本の地底の烈火を調節してくれる安全弁ですかね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『噴火口は、地球の内部を外部と通じてくれる、大事な安全弁だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　これはすべての探偵小説について考えることであるが、探偵小説又は捕物小説はしばしば人間の猛烈な本能の発動を抑制するための安全弁をなすことである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説というもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは攻撃用の武器ともなれば防御用の安全弁ともなる（こうして新聞紙対新聞社の社会機能上の連関は、新聞紙対読者の連関にまで移行する――前を見よ）。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「心」の為に完全なる安全弁の役目を努めるものは、結局近代劇を措いて外のものではあり得ない。",
              "citation": {
                "source": "吉右衛門の第一印象",
                "author": "小宮豊隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも、自分というものがおれば、いくらかその間に緩和剤ともなり得るが、自分が去ってしまえば、安全弁を抜きっぱなしで行くようなものだから、心もとない限りだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
