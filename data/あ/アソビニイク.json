          ],
          "literary": [
            {
              "text": "」　その声は街へ遊びに行くのがおじゃんになったのを悲しむように絶望的だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、ロシア人の家へ遊びに行くひまが、偸まなければできなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは或機會から、この半七老人と懇意になつて、赤坂の隱居所へたびたび遊びに行くやうになつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると二番目の兄さんの二郎が「お前たちは狐のとこへ遊びに行くのかい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は、よほどの事でもない限り、私のほうからお友達の所へ遊びに行く事などは致しませんでした。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女の内へ遊びに行くと、いつも帰りが遅くなって、日が暮れちゃ、あの濠端を通ったんですがね、石垣が蒼く光って、真黒な水の上から、むらむらと白い煙が、こっちに這いかかって来るように見えるじゃありませんか。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は伊都子にその部屋に遊びに行くように、すすめるらしかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いや、実はあの「星の花」と今晩一緒に遊びに行く約束をしたのです。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも――井深君は殊の外内気な性向で、かつ多分それ故に謹直で、ついぞ遊びもしないし、酒も飲まないし、女の噂さえも滅多に口にすることのない人間なのだが、どう云う事のはずみか井深君が屡々遊びに行く友だちの妹で、やっと十八位にしかならない少女に生まれてない恋慕の情を覚えそめていたのである。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "上諏訪へ遊びに行くというから、連れて来たんだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひとは、私が遊びに行くと、いつでもその時の私の身の上にぴったり合った話をした。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「北さんが、青森へ遊びに行くと言ったら、兄さん喜んだでしょう。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の邪魔になるから、宿へ来るなって言われたので、そのうちお仕事がすんでから、みんなで御岳へ遊びに行くんだ、とそう言っていましたよ。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても早瀬へ遊びに行くと云う君に、よく故障を入れなかったね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、主税さんが帰って来たら、日曜に遊びに行くから、そうしたらば、あの……」　と蓐の端につかまって、お蔦の顔を覗くようにして、「貴女も、私を可厭がらないで、一所に遊んで頂戴よ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかいうちに遊びに行く。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々姉がその宿へ遊びに行くことを知つてゐる。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、なにぶんにも狭い町だから遊びに行くような場所もない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日の午後、そこへ遊びに行くと称して家を出て、その時、ひょっとしたら今晩は泊ってくるかも知れない、と言って置く。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気の好い休日には娘の操る車に、村のあらゆる階級の若者、主に娘達が乗り込んで、屹度何処かへ遊びに行く。",
              "citation": {
                "source": "一九三〇年型",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は、幾度も寺へ遊びに行くたびごとに繰り返すのだった。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人声は夜遊びに行くらしい村の若者のそれであつた。",
              "citation": {
                "source": "小川芋銭",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今朝は友だちが農園の小川のほとりに遊びに行く為めに、誘いに来るだろうと思いながら、少女は肩のあたりから落ちそうになった、赤いリボンをむしり取りながら、茫然と目の前を見つめた。",
              "citation": {
                "source": "咲いてゆく花",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあちゃんはお力ちゃんのところへ始終遊びに行くので、姉さんのお紋さんともよく識っています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲州屋でお嫁に貰うのを見合わせたのも、つまりはそのせいなんですが、それがやっぱり身贔屓で、自分の娘の悪いことは棚にあげて、ふだん遊びに行くなあちゃんが、家へ帰って何か讒訴でもしたように思い込んでいるらしいんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは或る機会から、この半七老人と懇意になって、赤坂の隠居所へたびたび遊びに行くようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のように、汽車に乗るにも気違いのような騒ぎじゃあ、遊びに行くのか、苦しみに行くのか判りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
