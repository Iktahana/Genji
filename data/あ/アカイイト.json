        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "秋のはじめの或る月のない夜に、私たちは港の桟橋へ出て、海峡を渡つてくるいい風にはたはたと吹かれながら赤い糸について話合つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつか学校の国語の教師が授業中に生徒へ語つて聞かせたことであつて、私たちの右足の小指に眼に見えぬ赤い糸がむすばれてゐて、それがするすると長く伸びて一方の端がきつと或る女の子のおなじ足指にむすびつけられてゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の手から長い赤い糸が筋を引いている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはそれから坊ちやんに赤い糸の束を手頸にかけてゐて貰つて、糸巻へ二つばかり巻き取つた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸切糸切虫にどの糸切らせうほぐれた糸をよりより切らせう糸切虫は赤い糸切つた小さな口でぽきんと切つた。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチミの白い脛の上から赤い糸のようなものがスーっと垂れ下ってきて、脛を伝わって、やがてスーっと踝のうしろに隠れてしまった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の例としてひとつ「赤い糸紡織工場」の托児所をのぞいて見よう。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がソヴェト同盟にいた時分のこと、ある日「赤い糸」という紡績工場を見学に行って、元気な女工さんたちとしゃべっていたら、二十ばかりの一人の女工さんが、鉛筆と手帖をもって大いそぎでやって来て、「私はここにいる婦人通信員です。",
              "citation": {
                "source": "婦人読者よ通信員になれ",
                "author": "――メーデーきたる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か十一二歳のお下髪に洋装の小学生が二人店の外に立っていて通る女をよびとめ、白木綿に赤い糸で一針ずつ縫って貰っている。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきらめ」につづいて、「誓言」「女作者」「木乃伊の口紅」「炮烙の刑」と進むにつれ、田村俊子の気質と作品とは、益々あますところなく当時のロマンティックな文学の潮流に谺しながら、その流れのなかでも、まことに際だった一筋の赤い糸となって行った。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "拊石は先ず、次第にあらゆる習慣の縛を脱して、個人を個人として生活させようとする思想が、イブセンの生涯の作の上に、所謂赤い糸になって一貫していることを言った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの繪馬に混つて、女の長い黒髮の根元から切つたらしいのが、まだ油の艶も拔けずに、恭やしく白紙に卷かれて折敷に載せられ、折敷の端に『大願成就寅の歳の女』と書いて、髮と折敷との離れぬやうに赤い糸で確と結び付けてブラ下げてあるのを、お光は一心に見入つてゐた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに濛々と渦巻く熱気と、石炭の粉の中に、臨時に吊した二百｜燭光の電球のカーボンだけが、赤い糸か何ぞのようにチラチラとしか見えていない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイは謂わば千人針の東京へ出て来て暮すようになったのだったが、赤い糸を縫いつける黄色い布地も、きのうあたり頼まれて手にとったのは木綿でなく、妙なレーヨンの綾織のようなものになっていた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重の赤い糸を二重に針にからめながら、こんな布地ではじき糸のたまだけのこるようになってしまうのじゃないかと思われた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "押えを赤い糸でとめたので、鼻の峯やこめかみが野蛮人のような隈どりになってしまう。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はあの方の乳母に対してあの御方の部屋に御つれ申すことは出来ませんが、道導べに柱に赤い糸を結びつけて置きますからそれをたよって御出になれる様にいたして置きましょう」　乳母はようやっと答えた。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人様の手に渡っても、一旦私たちがつけてやった名前は、ぜひ名のらせたいと思い、メリンスの袷の裏に、娘の名を赤い糸で縫いとっておきました。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その袋の裏には、赤い糸で「小雪」という字が縫いとってあった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の手から長い赤い糸が筋を引いてゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度シャツの襟下に縫いつけてある製造者の商標に似て、大きさは三センチ四方の青い小布で、中央に白い十字架を浮かし、その十字架の上に重ねて赤い糸で、横向きの髑髏の縫いがあった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして口から頤にかけて、赤い糸のようなものがスーッと跡をひいていた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや、赤い糸が、きれいでいゝでせう。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さういつて、十五になる小さい女中のお君は、針箱から赤い糸を出すと、有一君についてお縁に出て来ました。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お君はさう言ひながらお縁に坐つて、箱の中をガサゴソとはひまはつてゐる甲虫をつまんで、すぐ一匹づゝ、赤い糸で首のところをくゝつてしまひました。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで真奈ちやんは、すぐ自分の応援してゐる甲虫の車をみんなはづし取つて、その代りに、自分の指にはめてゐたあはびの貝殻で作つたきれいな指環をぬいて、赤い糸の端つこにむすびつけました。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで鉛筆とナイフを持つて来て、甲虫の赤い糸にくゝりつけましたが、真奈ちやんの甲虫には勝てません。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真奈ちやんの大切な小さい指環を、赤い糸の先にブラ下げたまゝ。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
