        "examples": {
          "standard": [
            {
              "text": "私は毎日あぶり出しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあぶり出しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあぶり出しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあぶり出しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあぶり出しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあぶり出しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあぶり出しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあぶり出しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあぶり出しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあぶり出しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあぶり出しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあぶり出しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あぶり出しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあぶり出しは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さーっと鏡の中の顔が消えて、あぶり出しのようにまた現われたりする。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辻占は、あぶり出し式になって居ります。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが新聞では駆落が平面になって、一枚の紙に浮いて出るだけで、云わばあぶり出しの駆落だから、食べたって身にはならない。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い頃より地質学、天文学、化学における赫赫たる奇妙な新発見を学び、大自然が懐中に隠す幽かな秘密をあぶり出し、天と地に記された言葉を見いだして愛読してきた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、あぶり出し、隠顕インクの使用による秘密通信、音楽による代用法、楽譜の暗号、縄や紐の結び目による代用暗号法、暗号としての神代文字など、いろいろあるが、大体の種目は以上につきると思う。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか二日まえに――あの蜻蛉売りの久助の家に泊った晩――そこの行燈に書き残してあった日本左衛門の文字が、ともすると、お蝶の胸に、あぶり出しのようにういて出ます。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、ある薬品をかけてあぶりだしたら、こんな絵があらわれたのです。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍と薄曇美しき水だしあぶりだしの包装紙、縁日の葡萄餅屋が絵行燈の朱と萌黄と薄むらさき、大経師が店先の組上燈籠三枚続きのいのちにも似ると云つたら分るか。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更、師匠の底知れぬ心づくしのほどがあとからあとからあぶりだし玩具にあらわるる絵のごとくマザマザと眼先に描かれてきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
