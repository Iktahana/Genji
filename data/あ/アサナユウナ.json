          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝な夕なの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いまだこの事を知らざりし折、庭の中にいささかこの花を生し立てしが、其紅の色の濃からぬを訝しみつゝ朝な夕な疑ひの眼を張りて打まもりたりしをかしさ、今に忘れず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝な夕な、琴弾きたまうが、われ物心覚えてより一日も断ゆることなかりしに、わが母みまかりたまいし日よりふと止みぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美くしきソフィヤの君、われ泣けば、朝な夕なに、悲しくも静かにも見ひらき給ふ青き華――少女の瞳。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕の運動の話をつけ加へますが、僕は昨年の春あたりから「フエンシング」に興味をもつて、人知れず朝な夕な軽い剣を打ち振つてゐます。",
              "citation": {
                "source": "僕の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時頼殿の庵室へ朝な夕なに押し掛けて、いつまでも悟道の邪魔をして見しょうぞ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物道楽の流行で、震災前よりも一層デカダン式にリファインされた男性の姿は、彼女達を朝な夕な眩惑した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何時の時でも朝な夕な不思議に勇壮な運動を試みずには居られない習癖があるのだつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前述の如く充分な武装を施してゐるので彼等の来襲は怕れなかつたが、朝な夕な私は蜂と同じやうに営々と此処に通つてこれらの状態を観察することを、近頃の生甲斐としてゐたのである。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此目付で朝な夕な胸を刺されたる校長閣下の心事も亦、考へれば諒とすべき點のないでもない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此目付で朝な夕な胸を刺される校長閣下の心事も亦、考へれば諒とすべき点のないでもない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私に万一のことがあったら、朝な夕な、この鏡を覗いてご覧なさい。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "君よ、青簾の中なる美しき人の姿を見んとて朝な夕なの漫歩きに、その門をさまよいたもうな。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼女はそを見て愛でいつくしみ、下へも措かで、朝な夕な打まもらへり。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きてあらんほどの自覚に、生きて受くべき有耶無耶の累を捨てたるは、雲の岫を出で、空の朝な夕なを変わると同じく、すべての拘泥を超絶したる活気である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ運命が朝な夕なに動けと云う。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の海の湧き返る薄黒い倫敦で、朝な夕なに回り合わんと心掛ける甲斐もなく、眼を皿に、足を棒に、尋ねあぐんだ当人は、ただ一重の壁に遮られて隣りの家に煤けた空を眺めている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四に、自分の描いた絵を、一々、壁にかけて置いて、朝な夕な、煙草を吹かしながらそれを眺め暮せるといふことである。",
              "citation": {
                "source": "アトリエの印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして朝な夕な、誰がするともなく、白紙に塩や白米を盛ったのが、身禄さんの前に供えられています。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "正岡先生はこの絵ハガキを『仰臥漫録』と簽した帳面に張りつけて朝な夕なにながめておられたのであった。",
              "citation": {
                "source": "呉秀三先生",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の、「朝に」は時間をあらわすので、「朝に日に出で見る毎に」（巻八・一五〇七）、「朝な夕なに潜くちふ」（巻十一・二七九八）等の「に」と同じい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝な夕な波は哀音を送って、蕭瑟たる秋光の浜に立てば影なき人の姿がつい眼前に現われる。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにそこの貧乏オヤジは泥棒きたるべしとダンビラを買いこみ朝な夕なネタバをあわせ、そのために十八人の子供のオマンマは益※半減し、豊富なのは天井のクモの巣だけ、そのクモの巣をすかして屋根の諸方の孔から東西南北の空が見えるという小屋の中でダンビラだけ光ってやがる。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼母木は書生であったから朝な夕な、葦城邸の掃き拭きから水汲み、使い走り身の労苦を惜しまなかった。",
              "citation": {
                "source": "春宵因縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は嫁にきた当時、朝な夕な東の田んぼへ出ては利根の大きな流れを挟んで、遠く霞む自分の生まれた村の林を望んでは涙ぐんだ。",
              "citation": {
                "source": "利根川の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい水が漫々と張り切って鏡のようになっていると、そこへ富士の山が面を出しては朝な夕なの水鏡をするのでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親が、この上新田の農村に私を生んでくれただけに、先祖の顔もあり、村人の温情もあり、朝な夕な、やれほうれん草はどうか、葱だ、にんじんだ、牛蒡だ、といった風に、人々が私の勝手許へ提げ込んできてくれる。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝な夕なに草木を友にすれば淋しいひまもない」　というのが私の気持である。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝な夕なに草木を友に　　　すればさびしいひまもない植物に感謝せよ　植物と人生、これはなかなかの大問題で、単なる一篇の短文ではその意を尽すべくもない、堂々数百頁の書物が作り上げらるべき程その事項が多岐多量で且つ重要なのである。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二年間、私はひとり浦上の廃虚に寝て朝な夕な友のめい福を祈っていた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
