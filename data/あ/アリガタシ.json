        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り難しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り難しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り難しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り難しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り難しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り難しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り難しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り難しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り難しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り難しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り難しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り難しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り難しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り難しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り難しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り難しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り難しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り難しは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかれども、おもふが如く助けとぐること、きはめて有り難し。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く持って行って飲ませ給え」と二包の薬を与えけるに大原は有り難しとて帰り去りぬ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいま、葛原しげる氏の原稿を拜讀して、そんなに、嚴しいお叱りも無いので、狡猾の小文士は思はず、にやりと笑ひ、ありがたしと膝を崩さうとした、とたんに、いけませんでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ありがたし、かたじけなし、この日、この刻、この術を、許されたとは、鬼に金棒」　と、佐助は天にも登る心地がした途端に、はや五体は天に登っていた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が生ける間の「明」よりも、今ま死する際の「薄闇」は我に取りてありがたし。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中、老母は我が元来の虚弱にて学道に底なき湖を渡るを危ぶみて、涙を浮べて我が健全を祈るなど、都に多き知己にも増して我が上を思ふの真情、ありがたしとも尊ふとしとも言はん方なし。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "室は紙障子引きたてしのみにて雨戸ひくということもせず戸の後鎖することもせざる、さすがに御神の御稜威ありがたしと心に浸みて嬉しくおぼえ、胸の海浪おだやかに夢の湊に入る。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "としよりの喜ぶ顔はありがたし残りすくなきいのちを持ちて　余りに疲れ過ぎたせいかその夜私はなかなかに眠れなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとはすつかり葉桜のまぶしさ・やつと戻つてきてうちの水音・わらやしづくするうちにもどつてる・雑草、気永日永に寝てゐませう（病中）　四月三十日久しぶりにようねむれた、山頭火は其中庵でなければ落ちつけないのだ、こゝならば生死去来がおのづからにして生死去来だ、ありがたし、かたじけなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋園の田中さんから、たくさん薬を送つてきた、ありがたし、さつそく服用する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼ありがたし、田中耕三君から心臓の薬、青蓋人君から静岡茶、黎々火君から豆腐の本、その他。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君から白米を貰ふ、ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼、澄太君の温情、ありがたしともありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕、樹明来庵、酒と煙草とありがたし、そして玉ころがしとはおもしろし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の店員、米屋の主人、来庵して閑談暫時、米と炭とを買ふた、ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "家いつぱいの朝日影、ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたし、緑平老。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑平老からの手紙まことにありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼、ありがたし、かたじけなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいたよりいろ／＼、ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たより、それ／″＼にありがたし、一つのたよりには一つの性格がある、人生がある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々から見舞状、ありがたし／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼、しみ／″＼ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月七日樹明来、酒と魚とありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三洞君がしんせつにも浅川まで送つて下さつた、君の温情まことにありがたし、私はその温情に甘えたやうだ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたしかたじけなし。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "比古君黙壺君からの来信ありがたし、ありがたし。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山、山、山、うつくしい山、好きな山、歩き慣れない雪の山路には弱つたが、江畔おくるところの杖で大いに助かつた、ありがたし／＼。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たよりいろ／＼ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉はありがたし、酒と飯とがあればいよ／＼ありがたし、銭があればます／＼ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
