        "examples": {
          "standard": [
            {
              "text": "私は毎日案内記について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内記という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内記の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内記が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内記を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内記について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内記の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内記の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内記が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内記という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内記という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内記についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内記を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内記は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内記について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内記が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内記は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内記の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内記は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内記は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "案内記に「四壁｜屋蓋畳むに石をもってし」とある通りで、奥宮を中心とする山の町である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間神社の主典、富士武雄氏の好意ある接待に預かり、絵ハガキや案内記を頂戴する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデルベルクでもベデッカーの案内記にはグランド・ホテルとなっている旅館もハイデルベルゲル・ホーフと改名していた。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "某氏はベデカの案内記と首引で一々引き合わして説明してくれたので大いに面白かった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝捜しの案内記のようなものである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に旅行案内記の類をあけて見ると、あるいは海浜、あるいは山間の湖水、あるいは温泉といったように、行くべき所がさまざま有りすぎるほどある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとまずぼんやりとおおよその見当がついて来るが、いくら詳細な案内記を丁寧に読んでみたところで、結局ほんとうのところは自分で行って見なければわかるはずはない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして案内記などにはてんでかまわないで飛び出して行く。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがためにせっかくわざわざ出かけて来た自分自身は言わば行李の中にでも押しこめられたような形になり、結局案内記や話した人が湯にはいったり見物したり享楽したりすると同じような事になる、こういうふうになりたがる恐れがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう変わり者はどうかすると万人の見るものを見落としがちである代わりに、いかなる案内記にもかいてないいいものを掘り出す機会がある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜撰な案内記ででもあればそういう失敗はなおさらの事である。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こういう意味で完全な案内記を求めるのは元来無理な事でなければならない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで結局案内記がなくても困るが、あって困る場合もないとは限らない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校教育やいわゆる参考書によって授けられる知識は、いろいろの点で旅行案内記や、名所の案内者から得る知識に似たところがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記が詳密で正確であればあるほど、これに対する信頼の念が厚ければ厚いほど、われわれは安心して岐路に迷う事なしに最少限の時間と労力を費やして安全に目的地に到着することができる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれと同時についその案内記に誌してない横道に隠れた貴重なものを見のがしてしまう機会ははなはだ多いに相違ない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう損失をなるべく少なくするには、やはりいろいろの人の選んだいろいろの案内記をひろく参照するといい。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ困るのは、すでに在る案内記の内容をそのままにいいかげんに継ぎ合わせてこしらえたような案内記の多い事である。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、むしろ間違いだらけの案内記でも、それが多少でも著者の体験を材料にしたものである場合には、存外何かの参考になる事が多い。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいくら完全でも結局案内記である。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記が系統的に完備しているという事と、それが読む人の感興をひくという事とは全然別な事で、むしろ往々｜相容れないような傾向がある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで案内記ばかりにたよっていてはいつまでも自分の目はあかないが、そうかと言ってまるで案内記を無視していると、時々道に迷ったり、事によると滝つぼや火口に落ちる恐れがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の扉の事はいかに権威ある案内記にも誌してないのである。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と勇ましくいいかけたが、フトそのお転婆を極りの悪そう、お鶴が面はゆげに見えたのは、案内記には記さぬ不思議。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名の由來を知りたい方々は、案内記の類を讀まるゝがよい。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に帰って主人から借りた修善寺案内記を読み、午後には東京へ送る書信二通をかいた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道の案内記によると、今日では金谷からゆくのを便利とするらしい。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記には、小夜の中山｜夜啼石、西三十二｜町、菊川、西廿二町とある。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）内からの爆発であなたのやうに、あんないきいきした新しい世界を命にかけてしんから望んださういふ自力で得たのでないことがあなたの前では恥しい。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年も一緒に暮した男と、あんないきさつから、別れたばかりだつたし、これから、一人で食べて行くんだつていふ気持の張りから、仕事にもうんと熱を入れ出した時分だわ……。",
              "citation": {
                "source": "モノロオグ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
