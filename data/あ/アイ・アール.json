        "examples": {
          "standard": [
            {
              "text": "これはＩＲの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "よく見ると、歌舞伎俳優で有名なＩＲ氏である。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にＣＩＲＯ真珠飾りがちらちらと鳴いて、彼女は歯を見せずに笑った。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はみんなオテル・ドュ・パリやＣＩＲＯやアンバサドウルの食堂で皿や給仕人や酒表と戦ってる最中だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにを考えてＩＲＣ（万国赤十字）の仕事なんか手伝っていたのか気がしれない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のパァティって、赤坂のＫ会館前であるＩＲＣの主催の、日本代表の送別会のことではございませんか。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もお手伝いにまいりますんですが」「あたしよく知らないのよ」「ＩＲＣの主催ということになりますと、治外法権ですから、いくら憲兵でも踏みこむわけにはいきませんでしょう」「そういうものなの。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の脇間の柱にびっくりするほどたくさん花をつけた、繁みのような薔薇の大枝が飾ってあって、白髪の、知的ないい顔をしたＩＲＣのグルネルさんとルロォさんが立っていて、ていねいにお辞儀をした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣの日本代表の下で働いていたひとに逢うために来た」「そのひとは雄か否」「否。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさんあたりから今夜のパァティのことを聞いて、満寿子さんが来ていると思って、誰かのタクシードを借りてそっと見にきたというわけなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＲＣのグルネルさん、ペン・クラブの人達、モギレフさん、Ｍ・Ｊ博士、ローマン・カラーのいつかのカトリックのお坊さんなどの顔が見える。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ゲルハルトがニキシュの伴奏で歌った有名なＩＲＣＣのレコードのことについては、『巨匠の回顧』の項に書く）　ゲルハルトの声は万人に優れたものであった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブの国家主義、ポーランドの国家主義、フィンランドの国家主義、インド国民議会派、回教同盟(*5)、シオニズム、ＩＲＡ、これらは全てファシストと呼ばれるが、斯く呼ばわるのはそれぞれ別の人々だ。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
