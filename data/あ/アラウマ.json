        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒馬について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒馬という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒馬の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒馬が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒馬を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒馬について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒馬の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒馬の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒馬が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒馬という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒馬という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒馬についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒馬を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒馬は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒馬について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒馬が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒馬は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒馬の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒馬は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒馬は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "十一　荒馬スモーキー　この映画も監督は馬に芝居をさせているつもりでいるが、馬のほうでは、あたりまえのことながら、ちっとも芝居気はなくて始終真剣だから、そう思ってこの馬のヒーローを見ていると実に愉快である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも荒馬のいきり立って躍り上がる姿にはたとえるもののない「意気」の美しさが見られるのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島野は狼狽えて両手を上げて、「若様どうぞ、そりゃ平に、」とばかり、荒馬を一頭背負わされて、庄司重忠にあらざるよりは、誰かこれを驚かざるべき。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の眞面目な人間の動いて行く中を、痩ツこけた犬が大地を嗅ぎながら、また何うかすると立停ツて人の顏を瞶めながら、ヒヨイヒヨイ泥濘を渉ツて行く……さもなければ、薄汚ない馬が重さうに荒馬車を曳いてヒイ／＼謂ツて腹に波を打せてゐるのが眼に映る。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんが毎年その都に行はれる荒馬馴らしの競技場へおかあさんの美丈夫を出し度くなつたんだ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど恐れ入った馬も暫く見馴るれば何ともなくなり、今度は南北米の土人ほど荒馬乗りの上手はなしというほどその業に熟達し、ダーウィンの『探検航行記』に南米土人が幼子を抱え裸で裸馬を擁して走り去る状を記し、真に古ギリシアの大勇士の振舞いそのままだと言い居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人のなかでは荒馬のように粗暴な甚斎も、和尚の前へ出ては猫のようにおとなしかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の馬術はなかなか大したもので、レーリ氏などよりずっと早くから、どんな荒馬をも馴らすのに妙を得ていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらりと細長い首をして、よく伸びた脚をして、疲れを知らぬ荒馬だった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ乘り馬が荒馬なので、道を左右にそれて、なか／＼すすきの間を出ない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画の趣向は十分にわからぬけれど、馬には腹帯があつて、鞍のない処などを見ると、侍が荒馬を押へて居る処かと思はれる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "『八島』と『秋津洲』は、荒馬のように、敵の根拠地めがけて突進する。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の口から口に伝えられたことは、その大きな真黒な荒馬は地上の産ではなく、あやしい恐しい海獣の種だということであった。",
              "citation": {
                "source": "髪あかきダフウト",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のすぐれた美しさをグラッドロンの眼が見つけた時に、彼は荒馬の手綱をひかえた。",
              "citation": {
                "source": "髪あかきダフウト",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍耐修行がしたくなったら、僕なら唖鈴か荒馬を買う。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬ならいくらもある」「私、駻馬を好みます」「荒馬がよいか。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の手綱と荒馬の鬣はつかみ難いと申しますが、わたくしのこの恋心も、たとえばどのように上手な運転手が制動機を掛けたとて、きっと停めることはできないと思うのでございます。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中の一人に河内の日下党の加賀房というものがいたが、彼の乗る馬は月毛の荒馬、口力強くて御しにくいことおびただしい。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、屈強の荒馬乗りで如何なる難所といえども馬より落ちることはなく、弓矢打物とっては、鬼神にも平然と立向おうという一騎当千の類まれな女丈夫であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が汗をかき塵にまみれてお稽古から帰って来たり、（c）熱いものを飲んだり冷たいものを飲んだり、（a）また荒馬に乗っているところや、竹刀を持って荒っぽい相手と相打つところや、始めて火縄銃を扱うところなどを、じっと見ているのに堪えられないのでございます。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの子供の頃であったが、ナポリのスルモナ公は荒馬をさまざまに乗りこなした。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "利家始め、何事かと俯瞰してみると、味方の後方から一頭の荒馬が繋ぎを離れて陣中を駈け狂っているのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
