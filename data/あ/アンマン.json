          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日餡饅について考えている。",
              "source": "幻辞"
            },
            {
              "text": "餡饅という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は餡饅の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には餡饅が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "餡饅を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは餡饅について学習した。",
              "source": "幻辞"
            },
            {
              "text": "餡饅の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は餡饅の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では餡饅が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "餡饅という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に餡饅という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では餡饅についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "餡饅を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると餡饅は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "餡饅について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では餡饅が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に餡饅は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により餡饅の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "餡饅は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に餡饅は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
