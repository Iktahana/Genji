        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日侮るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "侮るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は侮るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には侮るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "侮るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは侮るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "侮るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は侮るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では侮るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "侮るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に侮るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では侮るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "侮るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると侮るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "侮るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では侮るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に侮るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により侮るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "侮るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に侮るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "で、その尻上がりの「ですか」を饒舌って、時々じろじろと下目に見越すのが、田舎漢だと侮るなと言う態度の、それが明かに窓から見透く。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飽くまで侮る一言に、年齢少にて気嵩の照子は、手巾を噛占めて、口惜涙を、ついほろほろ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども芸は大事です、侮るまい、と気を緊めて、そこで、膝を。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つには、こっちが相手を小身者と侮ると同時に、相手の方では大身に対する一種の妬みと僻みがあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるものとて侮るべからず、無用に似たる人をも物をも浪に棄てずば、また益をなすことあるべし。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ女性の及ぼす勢力はいつの時代にも侮るべからざるものなり、別して所謂｜紳士風なる者を形成するには、偉大なる勢力ある事｜疑べからず。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春彦が明日にもあれ、稀代の面をつくり出して、天下一の名を取つても、お身は職人風情と侮るか。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人と思うて侮るか。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、それは油断をせられないな、小敵と見て侮ることなかれ、か」　三左衛門はあっちこっちに石を置いている主翁の指端の顫えを見ていた。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾千の人か、これによりて我を嘲り我を侮るべけれど、猶良心に責められんには※に優れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として我を輕んずるやうなる詞、我を侮るやうなる行なきにしもあらねど、そはわが爲め好かれとて言ひもし行ひもし給ふなれば、憎むべきにはあらざるなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ実に侮るべからざるハイカラですよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその死なぬはずのおれが死んだら、お許しのなかったおれの子じゃというて、おぬしたちを侮るものもあろう。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、単に経済上より観察を下しまして、この小国のけっして侮るべからざる国であることがわかります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千年前の天文学の侮るべからざると共に、ヨブが信仰家なる外にまた天然学者なりし事を知るのである）。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式呼ばわりして之を侮るのは、学ばない者の常であるが、殆いことである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人に狎れ、聖人の言を侮る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして彼女の力を侮る事が出來よう。",
              "citation": {
                "source": "日の光を浴びて",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の眼から観れば、みずから侮ること甚だしいようにも思われるかも知れないが、なんと理窟を云っても劇場当事者の方で受付けてくれないのであるから、外部の素人は田作の歯ぎしりでどうにもならない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春彦が明日にもあれ、稀代の面をつくり出して、天下一の名を取っても、お身は職人風情と侮るか。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その俳優は旅役者の果てもあれば、小芝居｜根生いの者もあったが、またそのうちには何かの事情で大芝居から小芝居へ流れ落ちた者もまじっていて、そこに侮るべからざる腕利きを見出だすこともあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、この老政治家を手古摺した婦人の勢力もまた侮るべからざるものであったということを知らなければなりませぬ。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕を組んで漫歩する紳士が、枝に止まった小鳥のように目白押しする彼等の、その真正面で、ペッと地面に不作法な唾を吐く――　其でも彼等は体を揺って、ハハと笑う、ハハと笑う……　皆が侮る黒坊、泣いても笑っても、白くは成れない黒坊……南の国で卿の仲間が火で燃き殺される、その煙、その臭い――。",
              "citation": {
                "source": "一粒の粟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が侮る黒坊、皆が厭がる黒坊、誰が卿を黒くした？",
              "citation": {
                "source": "一粒の粟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話をしたら義男はきつと自分に向つて、口ばかり巧者で何も遣り得ない意氣地のない女と云ふ批判を一層強くして、自分を侮るに違ひないとみのるは思つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国民みなその兵力富力に差等あるは事実なり、日本国民は欧州の諸国民に比して貧弱たることを免れず、しかれども一国民として世界に立つの間はこの無形上の差等に驚きて自ら侮ることを得ず。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "年月に添って私を侮ることがひどくなるのは困ったものだ。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年月に添って侮るなどとは、あなた御自身がそうでいらっしゃるから、私のことまでも臆測なさるのよ」　夫人は良人があまりにまじめな顔をしているのに気おくれがして、若々しく甘えてみせた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡き夫左衞門と、先祖との光りが見る影もない後家の上にまで輝いて、蔭では何んと言はうと、面と向つて文吾の母を侮るものはまだなかつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方文化あなどるべからずだ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
