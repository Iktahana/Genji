        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「奧さん、氣を確かに持つて、……」と、今度は京子があかんべえをした。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして部屋の隅の洗面器の前に立って、鏡に顔をうつして、あかんべえをやった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、左眼の瞼がひどく損傷して、全くあかんべえの眼になっていました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この火傷の跡に対して、殊にあかんべえの眼に対して、人々が取る三つの態度に、笠井直吉は気付きました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ってくると、直吉の顔は赤くなると共に、その火傷した半面が光沢を浮き出させ、あかんべえの眼が細工物のように見えました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "反撥とか敵意とかそういう気持ちではなく、なにか下らない忌々しいものにぶっつかった気持ちで、それが、あかんべえの眼玉を更に大きくむき出させるようなのを意識しながら、へんにじっと見やりました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中に、自分の火傷の跡、ひきつった皮膚や、ちぢれた耳や、赤光りの禿げや、殊にあかんべえの大きな眼が、まざまざと浮き上ってきました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように考えながらなお様子をうかがっていると、それとも知らぬ主人は思う存分あかんべえをしたあとで「大分充血しているようだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が重なると、赤裸になって陣門の近くに群れ、尻振り踊りをしたり、瞼をむいてあかんべえをしたりして、蜀兵を憤らせた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
