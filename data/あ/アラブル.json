    },
    "definitions": [
      {
        "index": 1,
        "gloss": "savage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒ぶるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒ぶるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒ぶるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒ぶるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒ぶるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒ぶるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒ぶるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒ぶるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒ぶるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒ぶるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒ぶるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒ぶるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒ぶるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒ぶるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "霜に、雪に、長く鎖された上に、風の荒ぶる野に開く所為であろう、花弁が皆堅い。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不羈奔放な、荒ぶる青春の遊び友だちが一人また一人と次ぎ次ぎに世を去つて、つひにはただひとり彼等の仲間を置き去りにするのも、ちやうどこれと同じではなからうか？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三弦は暴風雨を招んで、相模の海に荒ぶる、洋のうなりと、風雨の雄叫けびを目の前に耳にするのであった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう自分の背後にある陸の生活のことなぞは考えない、又考えたらそんな冒険的な行為が恐ろしくなるが、只この健康、この荒ぶる感情、その行動というものが、得も云われず一種の壮快さを齎らすのだ。",
              "citation": {
                "source": "荒磯の興味",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくよさしまつりし国内に、荒ぶる神たちをば、神訊はしに訊はし給ひ、神掃ひに掃ひたまひて、発言ひし磐根・木根立ち、草の隻葉をも言封めて……天｜降しよさしまつりき。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手児呼坂・筑紫の荒ぶる神・姫社の神などの、人｜殺る者は到る処の山中に、小さな常夜の国を構へて居たことゝ察せられる。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫社郷の山途川の門（川口か）の西に、荒ぶる神が居て、道行く人をとり殺すので、其訣を占ふと、筑前宗像郡の人｜珂是胡に、自分を斎はせれば、穏かにならうとあつた。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがつい先日のことだが、人見角造と云って平作の長女のムコで三百代言をしている奴が訪ねてきての話によると、どうやら近ごろは平作のこの心境までぐらついてきたらしいぞ」　天心堂は荒ぶる神がゴセンタクをくだすようにカッと目をむいて語りつづける。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生蛮人を畏き神と称した例はあるから、神とおにとの区劃がはつきりすれば、かう言ふ荒ぶる神は、やはり鬼の部に這入つて来る事になつたのであらう。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら、火を親しんで「火のお婆さん」と呼ぶことは、日常取扱われる火であるなら格別、荒ぶる火の山に対して、古代の人がそういう感情を抱いていたかどうか頗る疑わしいもので、寧ろ惶み恐みて崇め尊んでいたと考える方が相応しくはないだろうか。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一説に赤裂地尊の荒ぶる姿であると申しますが、それも臆測にすぎません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の前まで達也さんに送っていただきましたが、帰ってみると零時ちょッと過ぎていました」「庭に物音をおききになりませんでしたか」「疲れてグッスリねましたので、目がさめるまで何一つ覚えがありません」　これも亦荒ぶる神の親類筋のようなすさまじさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるにこの時代にあっては悪疫の流行も思わぬ怪我も、この死霊や凶霊の為す仕業と考えていたのであるから、その死霊の発散して疎び荒ぶることを恐れて、かくは屍体を緊縛するようになったのである。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれこの國にちはやぶる荒ぶる國つ神五どもの多なると思ほすは、いづれの神を使はしてか言趣けなむ」とのりたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに諸の神たちまた思金の神答へて白さく、「雉子名鳴女一一を遣はさむ」とまをす時に、詔りたまはく、「汝行きて天若日子に問はむ状は、汝を葦原の中つ國に遣はせる所以は、その國の荒ぶる神たちを言趣け平せとなり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれその横刀を受け取りたまふ時に、その熊野の山の荒ぶる神おのづからみな切り仆さえき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒ぶる神いと多にあり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　荒ぶる神が熊になつて現れたのでその毒氣を受けたとする。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれかくのごと、荒ぶる神どもを言向けやはし、伏はぬ人どもを退け撥ひて、畝火の白檮原の宮四〇にましまして、天の下｜治らしめしき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "小碓の命は、東西の荒ぶる神、また伏はぬ人どもを平けたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔倭建の命の東征〕　ここに天皇、また頻きて倭建の命に、「東の方｜十二道一の荒ぶる神、また伏はぬ人どもを、言向け和せ」と詔りたまひて、吉備の臣等が祖、名は御※友耳建日子を副へて遣す時に、比比羅木の八尋矛二を給ひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち婚はむと思ほししかども、また還り上りなむ時に婚はむと思ほして、期り定めて、東の國に幸でまして、山河の荒ぶる神又は伏はぬ人どもを、悉に平け和したまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこより入り幸でまして、悉に荒ぶる蝦夷ども一四を言向け、また山河の荒ぶる神どもを平け和して、還り上りいでます時に、足柄の坂｜下に到りまして、御｜粮聞し食す處に、その坂の神、白き鹿になりて來立ちき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに血は荒ぶる。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "微吟、風流、おのずから荒ぶる男たちをも優しくなだめた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――斬って斬って斬りまくれ」　夏侯惇は、荒ぶる兵へ、なおさら気負いかけた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらぶる神」の「アラブル」がＬに rabere = to rage に似ていることも事実である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三、四年は疫病神もどこへか封じ込められて、そのあらぶる手を人間の上に加えなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "海のさち（青木繁氏作品）あらぶる巨獸の牙の、角のひびき、――（色あや今｜音にたちぬ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "万作夫婦は朝夕涙に暮れて、茶断塩断して、いつもお光が腰かけた柳の根株にしめなわかけて筑波さまあらぶる神さまに願をかけても、一向に帰って来ぬ。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
