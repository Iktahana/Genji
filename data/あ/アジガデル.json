    "definitions": [
      {
        "index": 1,
        "gloss": "(for the taste of something) to become apparent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そういう下地がある上に、彼は一旦物事を遣り出すと、その成績に冴えて凄味が出るほど徹底した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗の果は固い、けれども噛めば噛むほど滋味が出る、純白だ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからが本当の味が出るのだとか申しますが、そんなものかも知れませんよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かむと味が出る」「味が出るまでかんでいちゃ、歯が疲れてしまう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "又味わえば味わう程味が出る。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎさんから露西亜三人集を借りる、チヱーホフを読み返すために、――私は彼の作品を愛好してゐる、何度読んでも面白い、読む度に味が出る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "学んだものは、実地に応用して始めて趣味が出るものだからな」「左様です」と代助は答へてゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日にでもなれば、きっと味が出るだろう」　父親と二人になった時、なほ子は本気になって専門医に見せることを勧めた。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半月前の狂暴を思ふと、同じ水脹れのやうな身體から、どうしてこんな人を泣かせる優し味が出るのであらうかと、流石に道臣は鼻を詰まらして、折角の醉を内攻させることもあつた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "カツレツにして食べると結構牛肉の中どころの味が出るという。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちガラスの一方から描いて裏へ絵が現れるのであるから、そこに思いがけない味が出るのである、その味を味わうのがすなわち毎日の食事に飽きた場合の慰めだと考える。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ガラス特有の味が出るものです。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、わたしの舞台に、そんな凄味が出るようでは、芸が未熟な証拠です。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学んだものは、実地に応用して始めて趣味が出るものだからな」「そうです」と代助は答えている。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛むと味が出る」「味が出る迄｜噛んでゐちや、歯が疲れて仕舞ふ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、lift「揚げること」といふ行爲から「揚げるもの（昇降機）」といふ意味が出るやうなものである。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度を通り過ぎると今度は本当に心から軟くなって味が出るのです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中から味が出るとか出ないとか言うには及ばない。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、どうしたらその味が出るか、本筋なうえに面白おかしい味が出て、皆さんによろこんでいただくことができるか。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で堀主水の三百余人に、追いつくか知らないが華々しく闘って、骨細者の非力とうたわれた腕から、どのくらいの斬れ味が出るかを見せつけてやろうと思った。",
              "citation": {
                "source": "討たせてやらぬ敵討",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統に忠義だからこそかくも素朴な味が出るのである。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本は特に面白くて、かめばかむほど味が出る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
