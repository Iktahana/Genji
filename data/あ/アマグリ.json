        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘栗について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘栗という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘栗の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘栗が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘栗を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘栗について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘栗の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘栗の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘栗が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘栗という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘栗という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘栗についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘栗を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘栗は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘栗について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘栗が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘栗は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘栗の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘栗は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘栗は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あ、そんなら、あたし、甘栗を買って行かなくちゃ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かず枝は、甘栗を買い求めた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国でも、甘栗太郎の店頭にはノンキナトウサンの人造人間が、このような所作をして甘栗の宣伝をしていた。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、大きな甘栗屋の曲り角まで来ると、連れの女の方がひたと歩みを止めてしまった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝殿の百歩の地にて末の世は油煙をあぐる甘栗の鍋　昭和十年作者夫妻は鎌倉の海浜ホテルで最後の正月を過ごされた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日鶴が岡八幡に参詣して　み神楽を征夷将軍ならずしてわが奉る鶴が岡かな　と歌ひ上げたが、その帰りにその征夷将軍の殺された石段を降りて来ると直ぐその下に甘栗屋が店を出してゐた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から外を眺めたら、甘栗屋があり、丁度その店頭の燈火で、市営自動車停留場の標識が見えた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も自分の隣にゐた、どこかの御店者らしい、鳥打帽をかぶつた男が、甘栗を食ひながら、熱心に舞台を見てゐる方が、天下の名優よりも興味があつた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は熱心に舞台を見てゐると云つたが、同時に又甘栗もやはり熱心に食つてゐた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが懐へ手を入れたかと思ふと、甘栗を一つつまみ出して、割るが早いか口へ入れる、口へ入れたと思ふと、又懐へ手を入れて、つまみ出すが早いか割つて食ふ。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、隣の御店者は、久米の「橘屋」も耳にはいらないやうに、依然として甘栗を食ひながら、食ひつくやうな眼で舞台を眺めてゐる。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "お留さんが帰ってきて、甘栗の袋をあけながら言う。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都を去るとき、主婦はたしか甘栗と八橋を汽車の窓から投げこんでくれたやうだ。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘栗なんかを袋のまゝ投げ出して、一緒に食べようなどと云ふこともありました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "街々には、まだ東京には復活しない甘栗があった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘栗ではなくて、ユデ栗の皮だけが甘いだけの話だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屑、南京豆、甘栗の殻に、果物の皮や竹の皮、巻煙草の吸殻は、その日当番の踊子の一人や二人が絶えず掃いても掃いても尽きない様子で、何も彼も一所くたに踏みにぢられたまゝに散らばつてゐるのだ。",
              "citation": {
                "source": "勲章",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お照は約束たがえず翌日の晩、表通の酒屋の小僧に四合壜の銀釜正宗を持たせ、自身は銀座の甘栗一包を白木屋の記号のついた風呂敷に包んで、再び兼太郎をたずねて来た。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘栗は下のおかみさんへの進物にしたのである。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみさんとお照はかき餅と甘栗をぼりぼりやりながら酌をする。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間桟敷に手あぶりを持運び酒を飲み弁当鮓を食い甘栗カキ餅煎餅煎豆の類を終日ボリボリ食う事差支なくんば煙草の如きは更に差支なき筈なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが元来栗というのは中国産のもので、今それを学名でいえば Castanea mollissima Blume であり、西洋での俗名は Chinese Chestnut であって、あの町で売っているいわゆる甘栗がすなわちそれである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私の庭の木は前年市中で生の甘栗を買い来って播種したものである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのおもひたちの、決して無理でも、ないものねだりでもたかつたことは、紫の事務服、白いエプロンをかけた売店の女たちの、甘栗のふくろをさげたり、水菓子のはんだいをかゝへたりして桟敷の間をまご／＼するのとゝもに、わたしは、呼出しのたッつけのかげにかくれた白ちりめんの兵児帯。",
              "citation": {
                "source": "角力",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘栗　清之介君が支配人の令嬢妙子さんを貰ったのである。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、今日は甘栗を買って、五時半きっかりにお帰り下さいましな」　と命じられゝば、清之介君は雨が降っても銀座へ廻って、電車で人を突き退けても時間の正確を期した。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし甘栗が四日続いた時妙子さんは、「私、もう飽きたわ」　と言って顧みなかった。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエは甘栗の大きな包みを買って私に持たせ、「お師匠さんによろしく。",
              "citation": {
                "source": "前途なお",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "たっぷり食って、甘栗、蜜柑を食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
