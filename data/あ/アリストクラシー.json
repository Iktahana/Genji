    "definitions": [
      {
        "index": 1,
        "gloss": "aristocracy (societal class)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アリストクラシーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアリストクラシーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアリストクラシーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアリストクラシーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアリストクラシーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアリストクラシーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアリストクラシーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアリストクラシーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアリストクラシーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアリストクラシーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアリストクラシーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアリストクラシーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アリストクラシーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアリストクラシーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アリストクラシーないしブールジョアジーと芸術とのある関係を想わせる。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ヴィナスのアリストクラシーは永遠のものである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自壊作用の後に、活力ある生活を将来するものは、もとよりアリストクラシーでもなければ、富豪階級でもありえぬ。",
              "citation": {
                "source": "広津氏に答う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、デモクラシーは宿昔の長夢を攪破せんとのみ悶き、アリストクラシーは急潮の進前を妨歇せんとのみ噪ぐにあらずや。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
