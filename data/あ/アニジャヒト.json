        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄者人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄者人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄者人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄者人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄者人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄者人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄者人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄者人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄者人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄者人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄者人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄者人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄者人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄者人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄者人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄者人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄者人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄者人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄者人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄者人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三郎はそれを聞いてしばらく考えごとをしてから、なんだか兄者人のような気がすると前置きをして、それから自身の半生を嘘にならないように嘘にならないように気にしいしい一節ずつ口切って語りだしたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰のお庇だ、これも兄者人の御守護のせい何ぞ恩返しを、と神様あつかい、伏拝みましてね、」　と婆さんは掌を合せて見せ、「一年、やっぱりその五月雨の晩に破風から鼻を出した処で、（何ぞお望のものを）と申上げますと、（ただ据えておけば可い、女房を一人、）とそういったそうでございます。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲みぬけの父と銅鑼打つ兄者人の中に泣くなる我が思ふ人　サアカスの娘の歌である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚証書を三通｜新婦の兄者人に書いてもらって、新郎新婦をはじめ其｜尊長達、媒妁夫妻も署名した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馨さんの兄者人からである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は十二年前に勘当された加十に兄者人としてのナジミがないから、他人に財産をとられるような怒りや呪いがあったかも知れません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺はもう心を決めているのだが、兄者人が右顧左眄、家のことを思ったり、大逆になるのを恐れたりして……」「お父上のお心を推し計るとのう」　と、やはり左源太は二の足ふむように、「妹の心根を思いやってものう」「では、最初から云い出さねばよいのじゃ」　と、弟の右源次は歯痒そうに云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来る道々宮家に対し、討とうか討つまいか考えものじゃの、宮家方に附いては家が持たぬのと、云い出したのは兄者人じゃ」「それもさ家のことを思えばこそじゃ」「それそれ」　と、大弥太はけしかけるように云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やがては……すぐにも……兄者人の命も……」「死なぬの、なかなか、それどころではない、車の庄の主として、長く栄えて冥加得る気じゃ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっくらちょっとあるまいと、源三郎以上に剣腕の立つ人を立ちあいに……と、こっちが申し出たのに対して、望みどおりに、剣の上でも兄者人たる柳生対馬守が、判定者！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "律気な兄者人はどんなに怒っていることであろう！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳にたこができております」「またかかることは、拙者の口から申したくはないが、拙者が亡師の意にそむき弥生どのに嘆きをかけて今また鳥越の兄者人を怒らせて、かような陋巷に身をおとしおるのも……」「おッと！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄者人っ」「ええ？",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お……おう……四郎か」「高綱です」「弟」「兄者人」ふたつの体は、かたく抱き合った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて――「兄者人、どうしてここには？",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……兄者人、西仏房、どうかこのことを、上人へお取次をたのむ、残水の小魚を、宏大無辺の慈泉にすくい取らせたまわるよう、二人から、おとりなしの程をたのむ」真実が声にもあふれていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも兄者人は線がほそくて、神経質で、いわゆる剣人らしい線の太さがない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや後ろに離れて、わたくしどもまで、涙にむせびつつ、俯目に兄者人のほうを見てありましたところ、母うえが着せてあげた赤地錦の小袖、萠黄縅の鎧、太刀のこじり、いつまでも、石のように、ひれ伏してありましたが、微かに顫いていたように見られました」「欣しさに。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――死んだ、兄者人にも、相すまぬ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎も、六郎も、ほかの叔父御の郷へ、それぞれ、手分けして、兄者人のお帰宅を、知らせに、旅立ちました」「なんだ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと、泊って、兄者人のお帰りを、豊田の館で、待っておいでです」「ばか。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まさか、兄者人、そんな、おねだりはしません」「よいから、いえ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄者人が、お好きな方なら」「兄者人も、御決意なのでございましょうが」「うすうすは、将頼兄から、聞いていました。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄者人、恋に負けてなるものですか。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手があると聞けば、私たちも、兄者人を、失恋の人にはさせられません。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――愛娘の桔梗どの可愛さに、あわれ、野霜の翁も、子ゆえに迷う夜の鶴という諺どおり、何かにつけて、おれを訪ねて来る」「それでは、親御の伏見掾も、兄者人へ、嫁がせたいと希い、桔梗どのも、兄者人を、想うているわけでございましょうに」「ま。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扶や隆へ、うまく、いいわけのつくように、翁が、考えた通りの手段を、兄者人が、さっそく、実行しておしまいになれば、それまでの事でしょう」「いや、おれの惧れるのは、それから先だ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂東一帯にも、数少ない大族ではあり、嵯峨源氏の与党も各地にもっている」「だって……兄者人。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
