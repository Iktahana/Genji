        "examples": {
          "standard": [
            {
              "text": "私は毎日安着について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安着という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安着の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安着が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安着を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安着について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安着の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安着の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安着が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安着という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安着という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安着についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安着を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安着は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安着について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安着が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安着は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安着の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安着は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安着は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "故郷の朋友親籍兄弟、みなその安着の報を得て祝し、さらにかれが成功を語り合った。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音丸は直江津に安着せるなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年は暗涙を浮べて『私は本當にお前と別れるのが、悲しいよ、けれど運命だから仕方が無いのだよ、それでねえ、お前が幸に、大佐の叔父さんの家に安着して、萬一にも私共の生命が助かつた事なら、再び、あの景色のよい海岸の砂の上で、面白く遊ぶ事が出來ませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらからお鳥に對して長い手紙を三つも出してから、やうやくかの女から、「無事安着」の通知が來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼國の車主は例として前金を受けず、途中の旅籠一切をまかなひくれたる上、小使錢さへ客に交付し、安着の後決算するなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く英国にも、友人バサー博士ら、人民をして土地に安着せしめんとならば、その土地の事歴と天産物に通暁せしむるを要すとて、野外博物館を諸地方に設くるの企てありと聞く。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに窕子に取つて嬉しかつたのは、遠くに行つた父の許から安着の報知の來たことだつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一ツには冥土への安着を報せ、二ツには娑婆に債権者でもあれば今の内に申し出て、何とか解決方法をとらせるためである……」「一寸待ったＡさん。",
              "citation": {
                "source": "十年後のラジオ界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日御別れ致候後、途中腹痛にて困難を極め、午後十一時頃漸く當市に無事安着仕候。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ故郷に安着の上にて letter を差し上げます、末筆乍ら I wish yuo a happy　六月二十八日午前六時○○市出發に臨みて。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日御別れ致候後、途中腹痛にて困難を極め、午後十一時｜漸く当市に無事安着仕候。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ故郷に安着の上にて Letter を差上げます。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "周旋屋の手を経て募集された漁夫たちが、津軽及道内の各地から全部あつまった夜、大丸の旦那の家の大広間では安着祝があった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵の旦那の家での安着祝の席上で、監督の話の最中に、ほほう、えれえこった、と途方もない大声を出したのはこの男だった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事に投網を終え、――その夜は安着祝のときと同様、酒のふるまいがあった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "腮別れ（終漁祝）には安着祝のときよりも少しは多く酒が出、漁夫たちはよっぱらってだみごえでうたをうたった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌々日かなりしっかりした手蹟で安着の知らせと行く先の在所と両親の言伝を書いたさきの手紙がとどいた。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時半広島安着、黙壺居を訪ねて、また甘やかされた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "安着の端書、向ふで世帯を持つた報知、それが済むと、支店勤務の模様、自己将来の希望、色々あつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "神仏どっちでもいいから、絶えず安着を祈ること。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冥土より郵電報があるのなら　早く安着申し送らん」（２）　そして、喉をりっぱにかき切った。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次ぎのは、十日間ほど經つてから書いたもので、樺太安着を本妻の方へは電報で知らせながら、自分へは手紙でよこしたといふ恨み言がある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、義雄には輕重の意味があつたのではなく、弟の病氣が餘り惡い状態であつたので、その入院を電報で知らせるついでに、安着をも書き加へたのであつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "源一から安着の報知が届いたのは、出発以来やがて一ヵ月も経とうとする頃であった。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をあげて――そのなかにはシャツ一枚の阿賀妻もいた――材料の安着を祝うのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりしまへおあがりなされて一と夜｜参籠あそばされ、あくる日｜佐和やまへおわたりになりまして、いちにちふつか御きゅうそくなされましてから御ほっそくあそばし、どうちゅうつゝがなく清洲のおしろへ御あんちゃくになりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
