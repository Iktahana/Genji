        "examples": {
          "standard": [
            {
              "text": "私は毎日有ろう事かについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有ろう事かの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有ろう事かが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有ろう事かについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有ろう事かの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有ろう事かが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有ろう事かという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有ろう事かについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有ろう事かは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有ろう事かが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有ろう事かは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有ろう事かの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有ろう事かは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有ろう事かは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "われを忘れて仰いでいると、あろうことか、いびきの音がきこえて来た。",
              "citation": {
                "source": "星の劇場",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が言うと、「あろうことか、署名までタイプ打ちだ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すぐ思いついたのは、あろうことかバニスタが問題を勝手に見てしまったのではということで。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "他方で、ある人物があろうことか部屋に立ち入ってしまい、そしてその日に限ってたまたま問題が机の上にあった、こんな偶然も考えられない。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夫を、あろうことか、あるまいことか――」「よし、それでわかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "においをかいでみましたら、娘が好んで日ごろ使っておりました丁子油の髪油がかおりましたゆえ、こりゃ、どっちにしてもただごとではあるまいというので、急に騒ぎだしましてな、所々ほうぼうと人を派して、だんだんと捜すうちに、あろうことかあるまいことか、深川の先で死体となって揚がったのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はタイを締め、あろうことか、上着まで着ている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちが学校の看板をとって投げすてたその溝川へ、あろうことかＡ部隊と大書した板が投げこまれているではないか。",
              "citation": {
                "source": "結集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼犬を殺して、あろうことか、この尊い仏地を穢して煮て喰おうというのだ。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は＊10コチリオンの真最中に床へ坐りこんで、あろうことか、踊っている女の着物の裾をつかまえたりし始めたものだ、それは婦人連の言葉によればまったく言語道断の所業であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜儂の血でこの裁きをしたら、いつか、その舌の根から聴くことがあるでしょうから」と異常な決意を泛べて、あろうことか、護衛を断るのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その指差している手の形をした血の溜りが、あろうことか指頭の方向を、右方の壇上――すなわち伸子の位置に向けていたからである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、殯室の鍵は勿論のことで、それにあろうことかレヴェズの姿が、曲目の第一を終って休憩に入ると、同時に消えてしまったというのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、扉に押された拳銃が動いていった線が、あろうことかＳの字を描いているんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その腕を広げて、あろうことか、私に淫らしい挑みを見せてまいったのです。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその後、四時間ほど経つか経たぬかの間にあろうことか、艇長の死体が烟のように消え失せてしまったのです。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、結局にはそれが禍いとなって、あろうことか正室｜薄雪の方が、上方役者里虹と道ならぬ褄を重ねたのである。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、若し彼をよろこばすような便りでも来れば、あの男には、とても私に話し誇らずにはいられないであろうことからも、容易に想像出来た。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、同時に、トン、トンと、二あしばかり退って、踏みしめると油断なく構えて、刀に、手をかけた容子――　雪之丞も、相手が、本気になって、身を固めたので、屹ッと闇を透かしてみつめると、あろうことか、それが、昔の兄弟子、今はあきらかに、敵とみとめずに置けぬ、門倉平馬なのだ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あろうことかあるまいことか、自分を殺人犯だとうたがうなんて、そんな仕打があるであろうかと、日頃の好意が、すっかり消しとんでしまった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男でもあろうことか若い女だ。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼でもあろうことか更けた夜だ）　茅野雄は、苦笑を笑いつづけながら、下谷の方へ歩き出した。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人百姓でもあろうことか、両刀さした武士の身分で、この賤業にたずさわるとは、よくよくの事情があるからであろう。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察では、真犯人の私のことを、あろうことかあるまいことか、常習万引罪で刑務所に封鎖してしまったので、いくら巷を探したって、犯人が網に懸る筈がなかった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、通って行きました、男衆に、お気づきになりましたか、あの人は、私たちが、出帆いたします時、伯母さまと話していられた、ご親類の方に、そっくりでございます」　と、こんなに申しまして、口の中で、いくら似ているとは言え、あれほど、似ている方があろうことか、と独白いたしました。",
              "citation": {
                "source": "両面競牡丹",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、あろうことかあるまいことか、こんどはあべこべに後方へぶうんと艇が走りだしたではないか。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩くうちに切れそうだ」「気をつけて歩きましょうね」　ところが、あろうことか、吊橋の上で梅玉堂の鼻緒がプッツリ切れたのである。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの幻影というのは、そこへ、赤髯の大きな脂ぎったでぶでぶの洋服男が一つ現われて、いきなり、裸体婦人の後ろから羽掻じめにして、その髯だらけの面を美人の頬へ押しつけて、あろうことか、その口を吸いにかかったのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗まれたなどと申したら……」「お家の瑕瑾にござります」「それも一品ででもあろうことか、幾品となく盗まれたなどとあっては……」「家事不取り締りとして重いお咎め……」「拝領の品であるが故に、他に遣わしたとは言われない」「御意の通りにござります」「頼母！",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常な品物であろうことか、代々の将軍家より賜わった、当家にとっては至極の宝物ばかりを、選りに選って盗んだは、単なる女の利慾からではない。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
