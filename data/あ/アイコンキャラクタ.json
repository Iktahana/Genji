        "examples": {
          "standard": [
            {
              "text": "新しくリリースされた通話アプリのアイコンキャラクタには、親しみやすい柴犬のイラストが採用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "企業の認知度を向上させるため、自社サイトやSNSのプロフィール画像に専用のアイコンキャラクタを設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "デスクトップ画面の隅に常駐する案内役のアイコンキャラクタが、システムの更新情報を吹き出しで知らせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その教育向けソフトウェアでは、フクロウを模したアイコンキャラクタが児童の学習進捗に合わせて励ましの言葉をかける仕組みになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スマートフォンのホーム画面で、お気に入りのゲームのアイコンキャラクタをタップしてアプリを起動する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
