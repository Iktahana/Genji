        "examples": {
          "standard": [
            {
              "text": "この言葉は日常会話で頻繁に使用されます。",
              "source": "幻辞"
            },
            {
              "text": "文脈によって意味が変わることがあります。",
              "source": "幻辞"
            },
            {
              "text": "古典文学にも同じ用法が見られます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス会話では特に重要な表現です。",
              "source": "幻辞"
            },
            {
              "text": "日本の伝統文化に関連する言葉です。",
              "source": "幻辞"
            },
            {
              "text": "学校教育で教えられる基本的な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "医学分野でも使用される専門用語です。",
              "source": "幻辞"
            },
            {
              "text": "法律文書でこの表現がよく見られます。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ界でも一般的な言い回しです。",
              "source": "幻辞"
            },
            {
              "text": "環境問題に関する文脈で使用されます。",
              "source": "幻辞"
            },
            {
              "text": "料理や食文化の説明に用いられます。",
              "source": "幻辞"
            },
            {
              "text": "旅行会話で役立つ重要な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "日本の歴史的背景を反映しています。",
              "source": "幻辞"
            },
            {
              "text": "社会問題の議論で言及されることが多いです。",
              "source": "幻辞"
            },
            {
              "text": "技術用語としても広く認識されています。",
              "source": "幻辞"
            },
            {
              "text": "地域によって方言的な変形があります。",
              "source": "幻辞"
            },
            {
              "text": "若い世代も自然に使用する一般的な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "文語的表現として古典に登場します。",
              "source": "幻辞"
            },
            {
              "text": "その語源は興味深い歴史があります。",
              "source": "幻辞"
            },
            {
              "text": "現代でも使用頻度が高い重要語彙です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あああ」と私は、椅子から起つて、欠伸をした。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ」馬場は溜息ついて縁台にごろんと寝ころがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああ、舌打ちの音まで馬場に似て来たようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はむしろに座って、「わあああああああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが不思議なことは、「わああああんああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしはゆっくりでいいんだからお前さきにおあがり、姉さんがね、トマトで何かこしらえてそこへ置いて行ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしもそう思う。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああの白いそらの帯がみんな星だというぞ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああれ工兵の旗だねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ大きな落日が見たい」　彼は家を出て遠い展望のきく場所を捜した。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああああ本道じゃ、何ね、この間の梅雨に水が出て、とてつもない川さ出来たでがすよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああありがとうございます。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがとうございます。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがたい、山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがたい山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はますますよろこんで、「ああありがたや、山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしはゆつくりでいいんだからお前さきにおあがり。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしもさう思ふ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
