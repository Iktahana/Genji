          ],
          "literary": [
            {
              "text": "高森は今宮崎県の中学で英語の先生をしてゐる。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから半年ばかり上京して牛込あたりの下宿にゐたが、就職口があつたんだと云つて宮崎県に行つた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬儀は郷里兵庫県で行ふとあり、息を引取つたのは、東京に於てだとあつた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三昼夜かかって、やっと秋田県の東能代までたどりつき、そこから五能線に乗り換えて、少しほっとした。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年前、千葉県船橋の映画館で「新佐渡情話」という時代劇を見たが、ひどく泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその前は、千葉県、船橋の町はずれに、二十四円の家を借りて住んでいたのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあこれから、俺はこれを改めなくちや……」　だが今迄のやうに、自分のすることは直ちに郡視学の耳に入り、県視学に聞達するやうなことは、都会ではあるし、それに私立中学のことだからないだらうと思はれた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは嘗て旅行の途立寄つた兵庫県は御影師範の記憶である。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、青年団、消防組の応援による、県警察部の活動も、足跡ほどの証拠をも上げることが出来なかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪であり、大地主であり、県政界の大立物である本田氏の、頭蓋骨にひびが入ったと云う、大きな事実に対して、証拠は夢であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人目の子供を産むために、下の児を連れて県病院の施療病室にいる女房は？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクリートの橋があつて、そこで県道に出て、そこから私たちの家まで、約一里あつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人、一緒になつたので、「お前たちはお父さんの先きにお歩き」　さう云つて、私たちは県道を歩き始めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "県道は、電話線の埋設工事で掘り起されてあつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この工事を県当局で認可する交換条件として上高地迄の自動車道路の完成を会社に課したといふ噂話を同乗の客一人から聞かされた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰つて聞いて見ると、県から水電会社への課税のやうな意味で大正池の泥浚へをやらせてゐるのだといふ。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この工事を県当局で認可する交換条件として上高地までの自動車道路の完成を会社に課したという噂話を同乗の客の一人から聞かされた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰って聞いてみると、県から水電会社への課税のような意味で大正池の泥｜浚えをやらせているのだという。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔以下原稿なし〕　　　　　　　　　＊蒼冷　〔〕いや岩手県だ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二はみんなと一緒に、たそがれの県道を歩いていたのです。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無闇に井戸を掘って熱泉を噴出させたために規則正しい大湯の週期的噴泉に著しい異状を来したというので県庁の命令で附近の新しい噴泉井戸を埋めることになった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに科学的に信憑すべき根拠よりして、来る六十年ないし七十年間に某火山系に活動を予期し得るとせば、個人に対してはともかく、一県一道の為政者にとりては多大の参考となるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この両種の音は、現代の新潟県の或る地方の方言には残っている。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふ人を遠き県などにやりて、明くれ便りの待わたらるゝ頃、これを聞たらばいかなる思ひやすらんと哀れなり。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこにもまた、いろいろな手段がとられていて、先日東京から来たある友達の話によると、外米の入っていない県にいる親戚に頼んだり、女中さんの田舎へ云ってやったりして、送ってもらっている者がだいぶあるとか。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旱魃を免れた県には、米穀県外移出禁止というような城壁が築かれてはいるが、表門は閉っていても、裏のくゞり戸があいているので、四斗俵ならぬ三斗五升いりの袋ならその門を通過させてもらえるのだと笑っていた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "香川県は、全国で最も弾圧のひどい土地だ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十三夜に月めでんとて、したしき人々集ひて歌よみけるついでによめるこほろぎの鳴やあがたの我宿に月かげ清しとふ人もかな縣居のちふの露はらかきわけて月見に成つる都人かな野わきしてあがたの宿はあれにけり月見にこよと誰に告まし　本居宣長、橘千蔭、平春海もこの縣居へ訪れもしたであらう。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
