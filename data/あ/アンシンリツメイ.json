    "definitions": [
      {
        "index": 1,
        "gloss": "spiritual peace and enlightenment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安心立命について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安心立命という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安心立命の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安心立命が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安心立命を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安心立命について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安心立命の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安心立命の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安心立命が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安心立命という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安心立命という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安心立命についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安心立命を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安心立命は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安心立命について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安心立命が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安心立命は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安心立命の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安心立命は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安心立命は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分の感覚を通して這入つて来るものの中に安心立命してゐるのである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "引用された大福長者の言葉は現代の百万長者でもおそらく云うことであろうし、金持になりたい人々の参考すべき「何とか押切帖」の類であろうが、またこれに対する著者の評は、金のたまらぬ人間の安心立命の考え方を示すものである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と哲学と宗教とはこれを研究し闡明し、そして安心立命の地をその上に置こうと悶いている、僕も大哲学者になりたい、ダルウィン跣足というほどの大科学者になりたい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならどこに安心立命はあるか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に当って、この窮乏に堪え、かつこれを打開するものは、ただ人々の仏教信仰によっての安心立命と、慈悲の円融なる救済力とに待つのが適切と思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに仏教のいわゆる「安心立命」（悟り）があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さとった人は、この有限で生き死にする私たち個人の精神肉体が、取りも直さず永劫不滅なるものの現れと知って、もはや人生上に煩悶するものもなく安心立命のその日その日を送れるというのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに信仰によってさとりと同価値の安心立命を得るがよいというのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の平安朝時代から伝統が続いて来ている伝教大師の天台宗、弘法大師の真言密教は、さとりの修業と信仰の安心立命と兼用であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙を、種子が仕込んである未製品の仏陀と見て、もしその中の一部分でも、迷妄の分子が残っていたら、宇宙全体の連帯責任上から諸仏諸祖も遺憾なき安心立命は得られないのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞聖人の教義は、まず安心立命を得るのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）は、人生に安心立命の道を教へる。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの安心立命に至る手段は、要するに欲望を捨て、義務感を去り、生活に対する一切の責任感をあきらめてしまふことにあるのだ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち所謂「悠々自適」の境に達し、安心立命して暮すことができるのだ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまた一方には、学問によって生活上の懐疑を釈き、安心立命を得ようとする人々もあるであろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、安心立命するものを捉えさえしたらいいのだろう。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の天子様は、たとえ若崎が今度失敗しても、畢竟は認めて下さることを疑わない」と、安心立命の一境地に立って心中に叫んだ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして、安心立命が得たいと悶えてますよ。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんという英雄的な、しかも哲学的な安心立命であろう」　提督は深い溜め息とともにそう呟いた。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、芸術家としての彼が遂に一大勇猛心をふるいおこして、小さい囲炉裏のような私一個の安心立命は思い捨て、この人生が彼にとって根本に寂しと観じられているならそれなり刻々の我が全生活をかけて、感覚と形象の世界へ突入してゆくことで天地の生気の諸相を捉えようと歩み出した。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも自分に注意を与えるその宗教家などの様子を見ると、かえって何だか不安心なような顔付が見えて居て、あべこべに此方から安心立命の法を教えてでもやりたいと思うのがある。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、私は自から省みて考へる、――私は節度ある生活をうち建てなければならない、ワガママを捨てて規律正しく生きなければならない、私はあまりに気随気儘だつた、私の生活にはムラがありすぎた、省みて疚しくない生活、俯仰天地に恥ぢない生活、アトクサレのない生活――さういふ生活にこそほんたうの安心立命がある。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の安心立命の出来るものを発見しようとした時、初めて時代と自分というものの本当の交渉が理解されるようになり、或はまたその時代の標準、方法、理想に満足するかも知れません。",
              "citation": {
                "source": "今日の女流作家と時代との交渉を論ず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々のいのちが不滅でなくては安心立命は出来ない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この限りなきいのちの自覚がなくては安心立命は出来るものでない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も幾度か「歎異抄」という書をくりかえして読んで、親鸞の説に傾倒しているのだが、いかんせん未だに親鸞のような絶大な信仰を獲得することが出来ないから、自分ではなさけないことだと考えているばかりで、どうかしてそのような「安心立命」を得たいものだとひそかに念じてはいるのである。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体青い鳥の幸福という奴は、煎じ詰めて見れば、内に安心立命を得て、外に十分の勢力を施すというより外有るまいね。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神がもし安心立命の境地に立っていなかったならばどれだけお金があり立派な住家に住んでいてもそれは何もならないのであって、やはり苦しい暮しをしなければならないのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女はあらゆる望みを胸中より退いて、終生の願いを安心立命しなければいけない。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
