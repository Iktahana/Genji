[
  {
    "uuid": "47b9102b-ed51-5adf-b6b5-10816a602407",
    "entry": "過つ",
    "reading": {
      "primary": "あやまつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
