    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to make a mistake (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日過つについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "過つという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は過つの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には過つが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "過つを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは過つについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "過つの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は過つの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では過つが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "過つという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に過つという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では過つについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "過つを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると過つは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "過つについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では過つが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に過つは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により過つの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "過つは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に過つは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "貴樣達も知つとる通り中根はあの行軍の途中過つて川へ落ちた‥‥」と、軍曹はジロりと中根を見た。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も猶、一寸立つて便所に行かうとすると、途中で曲つてゐる梯子段を踏み過つて、私は四五段も辷り落ち、肘をしたたか磨り剥いたのだが、驚いてとんで来た医者に、抱き取られながらも、いい気味だいい気味だ、死んだ弟を忘れてゐたから罰が当つたのだと、急にまた千万無量な思ひをするのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "察せずして是を謂ふ、いづれも世道に執着して、其の眞相を過つなり。",
              "citation": {
                "source": "怪談会　序",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の人たちは直助が過つて河へ墜ちて死んだと信じ切つてゐるやうだ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　よしのずゐから天を覗く西　よめとほめ　葭管より天を窺ふは、管小に過ぎ天大に過ぎて尽す可きにあらず、夜眼遠眼、凡を過つて美となすことあり信ず可からず、二者意相似て聊か異なり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に慣るゝも猶且つ過つ有らんと云ふは西のなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、つい一月ほど前、夫婦でスケイト遊びの最中に細君は過つて薄氷の割れ目に落ち込み、幸ひ老人の手に救ひ上げられたが、その時足をひどく挫いたのだつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の一階目の床は、今過つた野に、扉を建てまはしたと見るばかり広かつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪を悪なりとし、善を善なりとし、不徳を不徳とし、非行を非行とするは、俗眼だも過つことなきなり、但夫れ悪の外被に蔽はれたる至善あり、善の皮肉に包まれたる至悪あるを看破するは、古来哲士の為難しとするところ、凡俗の容易に企つる能ざる難事なり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが正直一遍、忠義一途に世の中を貫いて行く武士のまことの心がけじゃまで……さもないと不忠不義の輩に欺されて一心、国家を過つような事になる。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ平生より人の骨相を見るに長け、界隈の人に請はるゝまゝに、その吉凶禍福を占ひ、過去現在未来の運命を説くに一度も過つ事なし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人は過つもの、少なくとも君を人でなしの罪人と責め立てる者はここにいない。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の古戦場を過つて、矢叫の音を風に聞き、浅茅が原の月影に、古の都を忍ぶたぐひの、心ある人は、此の媼が六十年の昔を推して、世にも希なる、容色よき上※としても差支はないと思ふ、何となく犯し難き品位があつた。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七郎は一時逆車輪を過つて機械体操からすべり落ち、気を失つた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "デパート展には制作良心なしといふ所まで徹底し生じつかな芸術良心を働かして無意識の間にこのデパート展の販売政策に絵の本質を売り渡す事がないやうに『デパート展の絵』の劃然たるものを一般出品画家が心構へして過つもデパート展の場内芸術意識のせり合ひなどをやらない様にした方がよい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に飽きて富山に惚れてお前が嫁くのなら、僕は未練らしく何も言はんけれど、宮さん、お前は唯立派なところへ嫁くといふそればかりに迷はされてゐるのだから、それは過つてゐる、それは実に過つてゐる、愛情の無い結婚は究竟自他の後悔だよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一婦女子の詐如きに憤つて、それが為に一身を過つたと知りながら、自身の覚悟を以て匡正することの出来んと謂ふのは、全く天性愚劣の致すところと、自ら恨むよりは無いので、僕は生きながら腐れて、これで果てるのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年程前迄は活動写真に凝つて身を過つてゐる妻の弟が助手だつたが、不定な給料に関して不平を抱いて出奔してからは、そのまた弟の受験生であるＮが代つてゐたが、私の仕事がすゝむに伴れてＮだけでは手不足だつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものが現れると屹度僕は大事な自分の仕事を過つてしまふ。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでまだその年齢が自分の片手の指の数しかない、兄の方が、ある時過つて畳の上にお尿を洩らした。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、白昼の、かほど、けざやかな太陽の下の遭遇でなかつたならば、彼はそれを不慮の死を遂げた青年の亡霊と思ひ過つたかも知れなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お前ばかりではない、お前の肉親の兄も、あの女に弄ばれて、身を過つたのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に父の言葉は、理解の不充分といふことではなく、明白に過つてゐるとさへ云へた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてほかの事では理解のよく行き屆いてゐる父が、子に就て過つてゐるのは、子に對する大きな期待が裏切られたことから來てゐると駿介には思はれた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上原が哲造についていふ不滿や哲造を過つて見てゐるかに見える根本は、さういふものであると考へられた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この食糧品の暴騰から来る生活難を済ふには、朝鮮米を行き渡らせるのもよからうし、方針を過つた仲小路氏を農相の椅子から引きずり下すのもよからうが、今一つそれよりもずつと良い方法が残つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本阿弥光悦は、器物の貴いものは、過つて取毀したときに、誰でもが気持よく思はないものだ。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "（されども考証家の説に拠れば真の秋色桜の位置は此処にあらずして摺鉢山に近き方なりと）この意は井戸端に桜の咲きたるを見んとて酔どれし人の何の気もなくその木の下に近よるにぞ、もし過つて井の中に落ちもやせんと気遣ひたるなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は一寸怒つたやうな顏を見せたが、驚いてあやまつたらすぐに心が解けたやうである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやまつた／＼今のはみんな嘘何うして中村の令嬢千代子君とも云れる人がそんな御｜注文をなさらう筈がない良之助たしかに承はつて参つたものは。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
