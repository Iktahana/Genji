    "definitions": [
      {
        "index": 1,
        "gloss": "avatar (incarnation of an immortal being in Hindu)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アバターについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアバターは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アバターの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアバターについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アバターは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアバターの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アバターに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアバターが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアバターを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アバターの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアバターが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアバターが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アバターについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアバターは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアバターは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアバターは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアバターについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アバターの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアバターの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアバターの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
