        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "田端や雜司ヶ谷にあるものの如く赤紙の貼りつけられざるは、こゝには御利益なきにや。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川淳庵の私宅から、小者が赤紙の付いた文箱を持って、駆けつけてきた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手の障子をあけ、宗清の女中赤紙の付いた文箱を持って出る）女中　藤十郎様にお文がまいりました。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレンダーは四月六日で、赤紙の日曜日となっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争へ召集する一枚の赤紙はその絶対命令によって、日本のあらゆる家庭から良人と父親、愛人、兄弟たちを奪い取りました。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の赤紙は、幾千万の日本の家庭を片はじから破壊しました。",
              "citation": {
                "source": "国際民婦連へのメッセージ",
                "author": "――「女性を守る会」から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "禹徳淳　（手の赤紙を読み続ける）究凶究悪惨たる手段十強国を欺きて内臓を皆抜き取りながら青年Ｎ　それは誰の作だ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "清国に対する日本帝国の宣戦布告（ａ）は、地元新聞紙が赤紙に印刷して公にされた。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本から赤紙一枚で前線に送られた兵士たちは、平和な日常生活の習慣から切りはなされ、国家の権力で殺すことを命じられ、その方法を教えられ、人を殺すことについて人間の当然感じる恐怖心を麻痺させる訓練を日夜つまされた。",
              "citation": {
                "source": "戦争でこわされた人間性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中の婦人は赤紙一枚で自分たちの平和をうちこわし運命をかえてしまったものが、そういう性質の戦争を強引に行った権力であったことを知りました。",
              "citation": {
                "source": "本当の愛嬌ということ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦「国宝」にしたら、もう官僚機構の腐敗のままに薄情きわまる扱いをして恥も知らないやりかたは、何と「赤紙一枚」を思わせるだろう。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の幼き時に僅かに記憶して居るのは、これと少し違つて黍殻に赤紙の着物などを着せて人形として、それを板の上に沢山並べるのであつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四行は即ち本文の第一行で、上半は後の黄紙に、下半は前の赤紙に書かれてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、銅貨で五十カペーカに、麦粉の一袋もやればまあよかったものだが、当節じゃあ、搗麦を荷馬車にまるまる一台と、おまけに赤紙幣の一枚もつけてやらなくちゃなりません、――まったく、欲張りったらない！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙幣の色により、当時五ルーブル紙幣を青紙幣、十ルーブル紙幣を赤紙幣と称した。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊７　赤紙幣　十ルーブリ紙幣のこと。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも合戦と云う日には、南無阿弥陀仏と大文字に書いた紙の羽織を素肌に纏い、枝つきの竹を差し物に代え、右手に三尺五寸の太刀を抜き、左手に赤紙の扇を開き、『人の若衆を盗むよりしては首を取らりょと覚悟した』と、大声に歌をうたいながら、織田殿の身内に鬼と聞えた柴田の軍勢を斬り靡けました。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートを借りて来た職業組合ボート繋留場の赤紙の下では、後から来た一団の男女が、手前へかきよせられるボートを見てる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩も、隣村の同年兵のところへ赤紙が来たという知らせで、そっちへ出かけていた間に源一の召集もかかったのであった。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと、赤紙よ」　息をつめた囁き声なのに、弾かれたようにまわりの顔がいくつかこちらに向いた。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤紙のことがみんなの気をはなれて暫くしたとき、伍長の飛田が入って来た。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が、廊下を走って来て「赤紙どすえ」　と、障子を開けた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎太が、赤紙へ印判を押して、女中に戻した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん、赤紙付の手紙だよ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「おい」　と、赤紙を、富士春に渡して、封を切って読んで行くと、微笑して「あはははは、西郷め、大きな図体を、持て余して、居やがるぞ」　そう云って、披げたままの手紙を、二人の前へ投げ出した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが赤紙の画扇の陰に、何か筐を隠してゐるのは、きつと侍従のした糞を捨てに行く所に相違ない。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上には『極秘』の赤紙が貼られた怪潜水艦『富士』の青写真が、ものものしくひろげられている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢島に赤紙がきて、神尾の家へ惜別の宴に招かれたとき、かねて借用の本を返そうというので、数冊持って帰ってきたが、その一冊がこの本だ。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、志岐のところへ赤紙が来たの、知つてる？",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直云ふと、赤紙をみて、わしや、ギョッとした。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
