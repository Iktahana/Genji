        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし僕は内緒で、片隅の赤髪の女に色眼をつかった。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の上着に野やまを越えて（※‥‥‥　※‥‥‥　コロナは三十七万二千　※‥‥‥　　　　　　　　　　　　　　　　　　　　）　そこの角から赤髪の子供がひとり、こっちをのぞいてわらっています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はすっかりもとのような、赤髪の立派なからだになりました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はすつかりもとのやうな、赤髪の立派なからだになりました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気の毒なそらか、すきとほる風か、それともうしろの畑のへりに立って、玉蜀黍のやうな赤髪を、ぱちゃぱちゃした小さなはだしの子どもか誰か、とにかく斯う歌ってゐます。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の途中の小さな段を一つ越えて、ひょっと上の栗の木を見ますと、たしかにあの赤髪の鼠色のマントを着た変な子が草に足を投げ出して、だまって空を見上げているのです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無産思想を通じての有色人種と白人との国際的提携を象徴しようとして赤髪の美婦人は灰面の埃及人と腕組みして行く。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌黄色の「キッテル」といふ衣短く、黒き臑をあらはしたる童、身の丈きはめて低きが、おどろなす赤髪ふり乱して、手に持たる鞭面白げに鳴らしぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌黄色の「キッテル」という衣短く、黒き臑をあらわしたる童、身の丈きわめて低きが、おどろなす赤髪ふり乱して、手に持ちたる鞭おもしろげに鳴らしぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤髪にして心身ともに健全な二十一歳以上の男性は誰でも資格あり。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗色髪のひとなるか、赤髪のひとか、金髪か、名をだに知らね、唯思ふ朗ら細音のうまし名は、うつせみの世を疾く去りし昔の人の呼名かと。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に読んだのは佐川春水氏が「銀行盗賊」と改題して訳述した「赤髪組合」か、それでなければ訳者を失念したが、太陽か又は太陽と同型の雑誌に発表された「青い宝石」で、どっちが先だったか確かな記憶はない。",
              "citation": {
                "source": "ドイルを宗とす",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏は皆｜藍面赤髪、背中に何本も手を生やし、無数の人頭を頸飾にしたる醜悪無双の怪物なり。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い赤髪を、モシャモシャさせながら、何だかペチャクチャ喋くっては、私達に笑いかけた。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて、弱電気に感電死を書いて得々としていた事があるが、同じ月の或る雑誌に小酒井不木氏の同じ弱電気死を扱ったのを発見して、胆をつぶした事がある、すべての物を読むのは、人間業として出来ないことであるが、少なくも「赤髪組合」や「まだらの紐」は出来るだけ避けなければならない。",
              "citation": {
                "source": "銭形平次打明け話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけは六尺ばかり、赤髪、裸身、通身灰色にて、毛の脱たるに似たり、腰より下に枯草をまとふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "人さんからは、この赤面のため、赤馬だの赤髪鬼などとアダ名されております。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やるかやらぬか、おれも思案の腹をきめ、その上での相談としようじゃないか」　ぜひなく、赤髪鬼の劉唐は、一応、客間へ引きさがり、あてがわれた酒の膳について、独りがぶがぶ飲んでいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷横に追ッついて、野郎の詫び証文か片腕でも奪ってきて見せたら、晁蓋もおれを見直すだろう」　どんな自信があるのか、赤髪鬼はヒラとそこを跳び出すやいな、荘院の裏門から県の街道を馬で矢のごとくすッ飛んでいった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷横の刀術に、鳳の概があれば、赤髪鬼の野太刀にも、羽を搏つ鷹の響きがあった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤髪の影が旋風に沈めば、迅雷の姿が、彼の上を躍ッて跳ぶ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と待ちうけていた晁蓋その人と、食客の赤髪鬼｜劉唐のすがたが、はやそこに見いだされてきた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤馬赤馬と呼ばれている赤髪鬼｜劉唐は、呉先生や晁蓋のあいだにあっては、見劣りすることぜひもないが、これも精悍にして邪悪ではない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――東渓村の晁蓋、居候の赤髪鬼｜劉唐、同村の呉用先生および、その呉先生が一味に引き入れた石碣村の江の漁夫、阮の三兄弟とかの公孫勝の一清、以上あわせての七人にほかならない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙に、べつの、も一ツの桶のフタを開け、無断で椀に半分飲んだのが、赤髪鬼の劉唐だ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより前に、寺小屋先生の呉用と赤髪鬼、劉唐が先発して、石碣村の阮ノ三兄弟の家で落ち合い、梁山泊へ入ろうという相談でした――ということまで、すっかり口書に取られてしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤髪鬼の劉唐でございますが」「あ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあいっ、待てーえっ」　舳から呼ばわったのは、梁山泊の一将、豹子頭の林冲、もうひとりは赤髪鬼の劉唐だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
