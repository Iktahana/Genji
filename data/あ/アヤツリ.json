        "examples": {
          "standard": [
            {
              "text": "私は毎日操りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "操りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は操りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には操りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "操りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは操りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "操りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は操りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では操りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "操りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に操りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では操りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "操りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると操りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "操りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では操りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に操りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により操りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "操りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に操りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だがそんなことは眼と筆の或る種の技能を巧みに操りさへすればよろしい。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上つ瀬には桜皮の舟に小※を操り、藻臥の束鮒を漁ろうと、狭手網さしわたしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間を胡麻化す或る操りの糸に過ぎないんぢやないかね……」　私はそれには何故か答へる事が出來なかつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、そんな操りの糸にでも操られ得る人はまだ幸福だよ。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲自動車の操り方を習っておくのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "璧を齎ちて河を渡りける時、河の神の、璧を得まくおもふより波を起し、蛟をして舟を夾ましめ其を脅し求むるに遇ひしが、吾は義を以て求むべし、威を以て劫すべからずとて、左に璧を操り右に剣を操り、蛟を撃ちて皆殺しにしけるとぞ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を運び、物を操り、作り、投げ、又は受取る……なぞいう稼働者の態度を。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の石段を下りるや若き女は先僕を乘らして後、纜を解いてひらりと飛び乘り、さも輕々と櫓を操りだした。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば結局互に何んの結果に来るものではないのを知り抜いていながら、しいて不意な結果でも来るかのごとくめいめいの心に空想を描いて、けち臭い操りっこをしているのが多少ばからしくなってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほい畜生」と云って平太郎は巧に操りながら、噛みつかれないように翅を延して避ける。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（娘、舞台から引き去らるる操り人形のように、畸形に身を浮かして去る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "果せる哉、長なりて荊州の刺史となるや、潛に海船を操り、海を行く商賈の財寶を追剥して、富を致すこと算なし。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――九月の二十日前後に、からりと爽かにほの暖かに晴上つた朝、同じ方角から同じ方角へ、紅舷銀翼の小さな船を操りつゝ、碧瑠璃の空をきら／＼きら／＼と幾千萬艘。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼處のは、横に靡いて婉轉として流を操り、此處のは、縱に通つて喨々として瀧を調ぶる。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……幕へ衝と消える時は、何ものか居て、操りの糸を引手繰るように颯と隠れた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、毀れてしまった操り人形のように、あわれにも精も根も尽き果てた様子で、明るい真昼間の日ざしの中で眠りこけている姉の寝姿を見ていると、自分もつい悲しくなるのだが、しかし私は姉をそんなに不幸にしてしまったとしても、それはあくまで自分の罪でないことを、自分の胸に幾度も云いふくめた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく結んだ背中の帯と、両方へ捌き拡げた両袖とが、ちょっと三番叟の形に似ているなと思う途端に、むくりと、その色彩の喰み合いの中から操り人形のそれのように大桃割れに結って白い顔が擡げ上げられた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほい畜生」と云つて平太郎は巧に操りながら、噛みつかれないやうに翅を延して避ける。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福多かるべきかな舟の上の活計や、日に／＼今朝の如くならんには我は櫓をとり舵を操りて、夕の霧、旦の潮烟りが中に五十年の皮袋を埋め果てんかなと我知らず云ひ出づれば、父上は何とも応へ玉はで唯笑ひ玉ふ、弟はひたすら物食ふ、舟子は聞かざるが如く煙草管啣みて空嘯けり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの老人の身に降りかかつた不幸、また僕がＳを却けてＩ子を羸ち得た幸福、それも同じやうなただ一つの運命の操りの糸か知ら……」と、明るい電車通に出た時、ふとＫが口を切つた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　礼之進は提革に掴りながら、人と、車の動揺の都度、なるべく操りのポンチたらざる態度を保って、しこうして、乗合の、肩、頬、耳などの透間から、痘痕を散らして、目を配って、鬢、簪、庇、目つきの色々を、膳の上の箸休めの気で、ちびりちびりと独酌の格。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "独木舟を操り、水狸や獺を捕える。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の食堂で、黄色い袈裟を着た日本の老いた坊さんが、剃りたての真蒼な頭をした小僧をつれて、巧みにナイフとフォオクを操りながらビフテキを喰べていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨木舟を操り、水狸や獺を捕へる。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小宮山は冷たい汗が流れるばかり、南無阿弥陀仏南無阿弥陀仏、南無阿弥陀仏南無阿弥陀仏、と隣で操り進む百万遍の声。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそんなことが正勝の耳へでも入ったら、きゃつはどんなことをするか分からないよ」　敬二郎は驚きのあまり、手綱を手操りながら言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズ独特の強烈な威厳がこの悲劇の場を圧倒してしまい、誰もが等しく操り人形であった。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことはない、あやつり人形の所作でも見ているような心地がした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月の鉛の雲さびに〕月の鉛の雲さびに、　　　　　みたりあやつり行き過ぎし、魚や積みけんトラックを、　　青かりしやとうたがへば、松の梢のほのびかり、　　　　霰にはかにそゝぎくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやつり人形の糸の代わりに空気の渦を使っているのだから驚く価値があるのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
