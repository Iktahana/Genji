          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一、集中二、三の旧作は目下の著者の芸術的信念や思想の上から見て飽き足らないものである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく聡明な彼の目には、なお飽き足らない点、補充を要する点がいくらもありはしないかという事は浅学な後輩のわれわれにも想像されない事はない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多くの科学の探究者はそれでは飽き足らないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら人間がその存在の中にさぐり求めるあらゆる手段の中、死のみが辛うじて、凡てを撥無してもなほ飽き足らない戀人の熱情を髣髴させるのだ。",
              "citation": {
                "source": "詩への逸脱",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は熱に燃える眼を見開いて、見入つても／＼飽き足らないやうに彼れの顏を凝視した。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾われは今でも、先生が彼のために歿くなられたことを思うと、実に彼の肉を喫っても飽き足らない程に思います」「おい、おい、山田君、君は何を云ってるのだ、もう帰ろうじゃないか」　伊沢の声がするので山田はびっくりして眼を※った。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、仏具のなかでも金目になりそうな物を手あたり次第にぬすみ取り、風呂敷につつんで背負い出そうとしたが、それでもまだ飽き足らないで、仏前にそなえてある餅や菓子を食い、水を飲んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし性欲を主にして書いたものではないから飽き足らない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ自分は長い間この人を飽き足らない感情を持って見ていたのであろうかと、不思議なほど長くじっと源氏は妻を見つめていた。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は明かに自己の保存が保障されただけでは飽き足らない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一日あなたに書き続けていてもなお飽き足らないのです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱きしめても抱きしめても飽き足らないほどの愛着をそのまま裏返したような憎しみが、葉子の心を火のようにした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの種の研究について私の飽き足らないところを云うと、あるいは下のような弊がありはすまいかと思われます。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "内大臣と源氏は大体は仲のよい親友なのであるが、ずっと以前から性格の相違が原因になったわずかな感情の隔たりはあったし、このごろはまた中将を侮蔑して失恋の苦しみをさせている大臣の態度に飽き足らないものがあって、源氏は大臣が癪にさわる放言をすると間接に聞くように言っているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その原因がどこにあるかは別問題として）大衆文芸が盛んになつたのはほんたうに小説に飽き足らないよりも、講談に飽き足らない読者を開拓した為だ。",
              "citation": {
                "source": "亦一説？",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを世間は、殺しても猶飽き足らないように、思っているらしい。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こういう平和な土地に住んでも飽き足らない者があると見える」　藤作は呟いたものである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何となく飽き足らないところがあるような気がして、それは何であろうかと、若松屋惣七は考えていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生から兄に対する嫂の仕打に飽き足らない顔を見せていた母でさえ、この時は彼女についてついに一口も訴えがましい言葉を洩らさなかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも飽き足らないと見えて、今度は袋を裏返しにして、薄汚ない棉フラネルの縞柄を遠慮なく群衆の前に示した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宅でも彼子がいると少しは依怙になるんだがね」六十八　姉の言葉には昔し亡くしたわが子に対する思い出の外に、今の養子に飽き足らない意味も含まれていた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "神尾主膳は、あれだけでは飽き足らないで、あらゆる流言を放ってこの機会に、駒井能登守というものを士民の間の憎悪と怨府とにしてしまおうという策略のように見えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに新興織田勢力の赫々たるものを眺め、中国の毛利にも飽き足らないものを覚えていたところへ、昨年、黒田官兵衛の説破に会って、断然、織田へ款を通じたものであった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターにルービンシュタインの「スケルツォ曲集」（ＪＤ一九一―四）というまとまったレコードがあるが、この人は見事な技巧家ではあるが、なんかしら飽き足らないものを持っている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、ブルメスターの手堅い、典雅な演奏は、相踵いで日本を訪ねたアウアー門下の提琴家たちの派手な華麗な演奏に飽き足らない人たちを喜ばせたことは一通りでなかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二人は未だ飽き足らない。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や自分は、この自力難行道の床を捨てただけに飽き足らないで、さらに、すべての僧人が鉄則としている持律戒行のすべての古い殻を蹴破ろうと決意しているのだ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな私のような大きい愛であなたを包もうとしている者はこの世にないはずなのですから、私が他の求婚者たちの熱心の度にあきたらないもののあるのはもっともでしょう」　と源氏は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で言つて見ても、硯友社あたりの型にはまつた文章にあきたらないで、ホトヽギス一派は、写生に引返して、そしてあの自由な新しい文章を始めた。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の『名和長年』といひ、これといひ、頗るあきたらない作者の態度だ。",
              "citation": {
                "source": "初冬の記事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
