        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝日の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "孤高｜狷介のこの四十歳の天才は、憤ってしまって、東京朝日新聞へ一文を寄せ、日本人の耳は驢馬の耳だ、なんて悪罵したものであるが、日本の聴衆へのそんな罵言の後には、かならず、「ただしひとりの青年を除いて」という一句が詩のルフランのように括弧でくくられて書かれていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の窓から差込む朝日が、それ等の机の上の硝子で出来た印肉皿や、罫紙の上を薄く班らに流れてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草が生ひ茂つて、出たばかりの朝日は露にキラキラ光つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の姿のちらちらする日には竹村君は面白そうに一時間の余も話し込んでいるが、娘の顔を見せぬ日は自然に口が重くてそうかといって急に帰るでもなく、朝日を引切りなしに吹かして真鍮のしかみ火鉢の片隅へ吸殻の山をこしらえる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで行く船に苅谷氏も乗り居てこれも今日の船にて熊本へ行くなりとかにてその母堂も船窓より首さしのべて挨拶する様ちと可笑しくなりたれど、じっとこらゆるうちさし込む朝日暑ければにや障子ぴたりとしめたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸派では、饗庭篁村が先達で、八文字舎風の軽妙洒脱な紀行文を書き『東京朝日』の続きものとして明日を楽しませた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日支局の大山為嗣さんに迎えられて、大宮まで自動車を走らせた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日を反映さする金茶色の唐松と、輝やく紅葉――そのくせ、もう枯れ枯れに萎び返って、葉の尖はインキを注したように、黒くなって、縮れている――で、夏ならば緑一色のちょんぼりした林が、今朝は二、三倍も広くなったような気がする。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和四年一月『東京朝日新聞』）",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に朝日夕日は一万三千五百五回ずつ平和な浜辺の平均水準線に近い波打際を照らすのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月二十四日『東京朝日新聞』）",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月十四日『東京朝日新聞』）",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月十八日『東京朝日新聞』）",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年八月三十日『東京朝日新聞』）",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月七日『東京朝日新聞』）",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月二十八日『東京朝日新聞』）",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月二十六日『東京朝日新聞』）",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月二十一日『東京朝日新聞』）",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月一日『東京朝日新聞』）",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月二十八日『東京朝日新聞』）クロロホルムの作用　近頃英国で犬にクロロホルムを種々な方法で与えてその作用を試験した人がある。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月三十日『東京朝日新聞』）発電所は難破船　メキシコの南隣グァテマラの西海岸の一小市で近頃電灯を点ずるようになったが、その中央発電所は同市の海岸近くに坐洲したドイツの汽船である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月六日『東京朝日新聞』）狐と鱗片　四足獣で鱗のあるものは珍しい。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月七日『東京朝日新聞』）空中飛行の将来　フランスから英国まで海を超えて飛行する事の出来たものには一千ポンドの賞金を与えると申し出した人がある。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月十六日『東京朝日新聞』）",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月十七日『東京朝日新聞』）",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年四月十日『東京朝日新聞』）",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月一日『東京朝日新聞』）",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年七月十五日『東京朝日新聞』）二　室内用として最も広く用いられるのはやはり白熱灯である。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年七月十六日『東京朝日新聞』）",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その花達に夜の間宿った露、朝日が射せば香わしいほのかな靄となって私達のもすそをしめらす。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
