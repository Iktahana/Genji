        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして、いちばんしまいに、とかげの形をした、いちばん大きな本州をおこしらえになって、それに大日本豊秋津島というお名まえをおつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は今迄の母に窺はれた陰気な気色が、いつの間にか消え去つて、母ともおもへぬ程若々しく、「四面海モテ囲マレシ　ワガ敷島ノ秋津島……」　斯んな唱歌をうたひながら、元気づいた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋津島やまとの民は外国と戦へば勝つ神随ならし雪ふかき荒野の上に御軍の臥すと思へば我も寒けしおなじ年、わが子大圓の征清軍隊慰問使として真言宗より遣され行くに。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ざかる鄙の長路ゆ恋ひ来れば、明石の海峡より大和島見ゆ（万葉巻三）といふ歌の、一番進歩した説明では、大和の国を、島と称したと云つてゐるが、秋津島その他が、水で取り囲まれてゐるからだと云ふのは、逆の考へ方である。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……玲瓏と云うか崇厳と云うか、とにかく、あれは日の本の秋津島の魂の象徴だ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に大倭豐秋津島一九を生みたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔孝安天皇〕　大倭帶日子國押人の命一、葛城の室の秋津島の宮二にましまして、天の下治らしめしき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に大倭豐秋津島（本州）をお生みになりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝安天皇　オホヤマトタラシ彦クニオシビトの命（孝安天皇）、大和の葛城の室の秋津島の宮においでになつて天下をお治めなさいました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "“日本秋津島ハ、ワヅカニ六十六ヶ国、平家｜知行ノ国三十余ヶ国、スデニ半国ヲ超エタリ――”と古典のいうほどでもありませんが、とまれ藤原氏など、昔日の面影もなく、ただ上皇後白河の威と才略を恃んで、ひそかに他日をうかがう蠢動をちらちら見せているだけに過ぎない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきつしま・しきしま・やまとしまは、水中の島から出た語尾でなく、却つて村の意味の分化したものと見るがよからう。",
              "citation": {
                "source": "万葉びとの生活",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
