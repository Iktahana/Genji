        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安定性について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安定性という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安定性の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安定性が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安定性を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安定性について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安定性の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安定性の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安定性が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安定性という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安定性という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安定性についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安定性を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安定性は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安定性について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安定性が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安定性は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安定性の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安定性は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安定性は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "稀には科學上に所謂安定性の物質のやうに、十年一日の如くして晏如たる人も有るが、多くは新を追ひ舊を棄てんとするの傾が有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、われわれの本を本たらしめる三つの条件のうち、「明朝体の文字をタテヨコきちんとそろえて組む」という※の条件が、やや安定性をうしないはじめてきたことだけはたしかなようだ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また換言すれば、精神に安定性を与えるものがこれ形式で、形式を揮発性にしたものがこれ精神である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに一定の出来上った風格があって、之は安定性を有った強靱なものだ。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録文学の流行は、出版界の不安定性とまじり合って、各出版社を記録文学のヒットさがしに熱中させた。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生たちが苦痛とするところは、これらの労働が安定性をもたないことである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "失業と生活難をよそに有産有閑の男女には戦後の経済変調によって失われてゆく従来の家庭の安定性の崩壊があり、不良良人のためには、慣れっこになった芸者ではないステッキ・ガールと呼ばれた若い街の女たちがあらわれた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにより、マイクロコンピューターを使う側にしてみれば仕入れ先が複数になって、供給の安定性が高まる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちある構造は安定性に於て相違するから、ある構造の部分は他の構造の部分よりも遙かに分離され易く、而して新な全體の部分になりて安定を得るといふのであるが、ソーンダイクが結合する反應又は状態の質によりて結合が容易であり又は困難になるといつたことゝ相似て居るやうに思はれる。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "又構造の安定性は經驗の多少有無によりて影響されるものでないとのゴットシャルトの結論は、ソーンダイクと同一の事を考へてゐるともいへよう。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "構造の安定性に變化が生ずると、一定の反應がその全體から分れて表はれてくる。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち構造の安定性が新しい反應の出現を規定するもので、一定の状態に學習又は習慣構成を生ずるか否かはこの安定性に基づくものである。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして有用といふことは構造の安定性と關係があるといへる。",
              "citation": {
                "source": "教育心理に關する現下の問題二三",
                "author": "久保良英",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間性の根源的性格をなす存在の可滅性・無常性・不安定性・斷片性・不完成性は、かくの如くにして果てしなき連續即ち無終極性として發現を遂げる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主體も他者も衝突や侵害によつて互の存在を壞滅に陷れるを止め、かくして兩者の間に一致和合の完成を見るに至つたならば、生のあらゆる不安定性未完成性斷片性はおのづから跡を絶ち、永遠性はそれの充ち足る姿を現はすであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間性の缺陷である可滅性・斷片性・不安定性等の如きは現在が將來との合一を企てて失敗にをはるより來ると解すべきである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中がいつどう変るかも知れぬといふ不安が、今までは確かにあつたので、青年に本当に自信をもつてやれと云つても無理だつたかも知れませんが、問題としては、政治自体に安定性を与へるといふところまで青年に奮起して貰はねばならないのです。",
              "citation": {
                "source": "勤労と文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「尺度」（物指し）のごとく、空間の量測定において人の感覚ならびに判断の不安定性ならびにその有限性に関して、それを補充修正するの「道具」である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「時計」はその時間的量において、人の感覚、判断の不安定性および有限性の補充修正の「道具」である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚領域において空間的量測定について示す不安定性はすでに説明は要すまい。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「近代国家の国家活動は、あらかじめ国民に公示された成文法秩序のもとに、専門的かつ無私的な官僚によって、計画性と安定性とをもって執行される」。",
              "citation": {
                "source": "法学とは何か",
                "author": "――特に入門者のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは、たとへ逆立ちしたつて、もはや古代の建築や彫刻のあのゆたかな安定性には達しられないだらう。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "エノール性の準不安定性の特性はコレステノン（）産物は常水中の沸騰アルカリ溶液で処理すると重水素原子のうちの１つだけが交換した。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "［校正者による追加］　エノール化による不安定性という原理の理論応用は、重水素酪酸を酸化する代謝過程のシェーマ（※）によって示される(6)。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムソンは既にこれを測定しておるから申すまでも無いが、たゞ原子の安定性に對しては申分ない模型である。",
              "citation": {
                "source": "原子核探求の思い出",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にアダムス賞を授與せられた土星の輪の安定性に關する議論は、模範的論文であるを覺えた。",
              "citation": {
                "source": "原子核探求の思い出",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常人ならば直ちに掃除したでありましようが、彼は砂に塗みれたナイトロ・グリスリンの爆發性を試驗しましたところ、液體に比して著しく安定性を帶びましたので、これまで苦心したこの爆藥の運送に關する謎が解かれ、ダイナマイトが生れたのであります。",
              "citation": {
                "source": "湯川博士の受賞を祝す",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
