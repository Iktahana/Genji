        "examples": {
          "standard": [
            {
              "text": "顎紐の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのうちに背後の扉が開いた音がしたので、ハッとして振向くと、顎紐をかけた警官が二三人ドヤドヤと這入って来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帽子の顎紐をかけている！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の汽艇からも、やっぱり銃の先きに、着剣した、顎紐をかけた水兵！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎紐をかけた警官が、物々しく一列に延びて、入り損った聴衆を制止していた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――顎紐をかけた警官だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　次號完結　――五　××日の夜明、警察署からは帽子の顎紐をかけた警官が何人も周章た樣子で、出たり入つたりしてゐた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いながら、まだ決まらず歩いていると、交番のところにも巡査が二三人立っていて、驚いたことには顎紐をかけている。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白な雪の肌に黒血のにじんだその頭部の近くには、顎紐の千切れた従業員の正帽がひとつ、無雑作に転っている――。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内に五十万の顎紐をかけた警官と二百万の「消防」、復員軍人、旧戦犯、悪質の「民同」がうようよしていて、「高度武装」たる計画的な犯罪の挑発、捏造事件で人民の民主化を抑圧するために活躍している。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方を見ると、行列は顎紐をかけゲートルを巻いた警官の黒い群に雪崩れこまれ、警官が列の中から検束しようとする同志を守ってかたまりとなり、大揉みに揉んでいる。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "険相な眼と口を帽子の顎紐でしめ上げた警官たちが、行列の両側について歩いて寸刻も離れないばかりか、集合地点には騎馬巡査がのり出した。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにも、さっきむこうへ行ったのにも白い警官が顎紐をおろしてのりこんでいるのであった。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×元村の駐在と××町の警部補が先頭に立って、巻キャハンに顎紐といういでたちだ。",
              "citation": {
                "source": "共同耕作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "非番巡査まで非常召集され顎紐をかけ脚絆をつけた連中が内庭と演武場に充満して佩剣をならしている。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎紐をかけた巻ゲートルの警官が一人は運転手の窓のところから内部をのぞき込み何か云った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆大福を売るおばあさんや、焼鳥屋の店が出て、顎紐をかけたお巡りさんが整理にあたっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭熊は伸び上ってその方を眺めていたが、あわてて花の腕を執ると、「花ちゃん花ちゃん、顎紐をかけたお巡査さんがトラックで沢山やって来たよ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると西門の前に停ったトラックから、物々しく顎紐をかけた警官がドヤドヤと跳ね降り、群集を押返しながら公園の中へ走り込んで行く。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも帽子の顎紐をかけ、手には白い手袋をはめていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランチには、帽子の顎紐をかけた警官が、鈴なりに、満載されている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おい」と、巡査に呼びかけ、自分も勝則の腕をつかみ、「こいつを、検束しろ」　帽子の顎紐をかけた黒衣の警官が、三人がかりで、勝則を引き立てて行った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻田博士のその後の消息は、わかりましたか」　大江山課長は、帽子のあごひもをしめ直しながら、「その蟻田博士のことなんだが、我々も、一生懸命にさがしているんだが、手がかりなしでね、全く残念なんだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはしごを、帽子のあごひもをかけ、靴をぬいで靴下ばかりになった警官が、つぎからつぎへとよじのぼり、懐中電燈をふり照らしながら、屋根の上の大捕り物がはじまりました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
