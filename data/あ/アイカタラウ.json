    "definitions": [
      {
        "index": 1,
        "gloss": "to talk together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相語らふは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相語らふが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相語らふに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相語らふが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相語らふについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相語らふについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相語らふについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相語らふが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相語らふが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相語らふは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相語らふは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相語らふを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相語らふをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相語らふが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相語らふの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相語らふを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相語らふに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相語らふについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相語らふは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相語らふを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
