[
  {
    "uuid": "96e315b4-aa63-561c-bd29-8c686d027691",
    "entry": "相語らふ",
    "reading": {
      "primary": "あいかたらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-四段-ハ行-古典",
