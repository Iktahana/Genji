          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイオリは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイオリが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイオリに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイオリが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイオリについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイオリについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイオリについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイオリが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイオリが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイオリは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイオリは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイオリを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイオリをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイオリが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイオリの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイオリを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイオリに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイオリについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイオリは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイオリを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "僕は一度ヴアイオリン彈きのクライスラーが舞臺にあらはれたのを見て、まるで狼が洋服を着て出て來たやうな大變「エトランジエ」の感じを起したことがあるが、こんどの感じもそれで、プルウストが彼の祖父さんや祖母さんをより生き生きと書けば書くほどその同じ「エトランジエ」の姿がくつきりして來る。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲテイといふブダペスト生れのヴアイオリンの名手が日本へやつて來て、日比谷の公會堂で三度ほど演奏會をひらいたが、三度が三度ともたいへんな不人氣であつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑ひだすと果しがないけれども、いつたい、彼にはどのやうな音樂理論があるのか、ヴアイオリニストとしてどれくらゐの腕前があるのか、作曲家としてはどんなものか、そんなことさへ私には一切わかつて居らぬのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴアイオリンケエスを左腕にかかへて持つて歩いてゐることがあるけれども、ケエスの中にはつねに一物もはひつてゐないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言葉に依れば、彼のケエスそれ自體が現代のサンボルだ、中はうそ寒くからつぽであるといふんだが、そんなときには私は、この男はいつたいヴアイオリンを一度でも手にしたことがあるのだらうかといふ變な疑ひをさへ抱くのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もまたヴアイオリンよりヴアイオリンケエスを氣にする組ゆゑ、馬場の精神や技倆より、彼の風姿や冗談に魅せられたのだといふやうな氣もする。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴアイオリンを手にしたのを見たことがない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘蔵のヴアイオリン時として此等の上に投げ出されてある事あり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの室にて、日毎に心耳を澄まして聞くをえしヴアイオリンは、この新居にても亦聞きえざるにあらず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "気軽な連中は、階下の客の迷惑も心づかず、その一人が弾くヴアイオリンの音に伴れてダンスを始めた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣輕な連中は、階下の客の迷惑も心づかず、その一人が彈くヴアイオリンの音に伴れてダンスを始めた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何時だつたか、清朝の光緒皇帝がまだ達者でゐた頃、波蘭の或るヴアイオリン弾きが聘ばれて御前演奏をやつたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凹凸の小路をヴアイオリンのケースを提げた若者たちがいそいそと通つてゐた。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは地上に落ちてゐたヴアイオリンを拾ひあげると、それを弾きながら歩いてみたが、わたしの霊感は緊張しながら遅緩し、痙攣しながら流動し、どこへどう伸びてゐくのかわからなくなる。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず音楽家のクラバツクにもヴアイオリンを一曲弾いて貰ひました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時惡魔がヴアイオリンを手にとつていとも巧に彈奏し出したのは到底彼の企て及ばざりし奇しき一曲。",
              "citation": {
                "source": "鳥料理",
                "author": "A Parody",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は余のヴアイオリンを取り出でて余が聞きたる音調をそれに止め置かんと試みたり。",
              "citation": {
                "source": "鳥料理",
                "author": "A Parody",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡者甲　　ヴアイオリンです。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼　　（我が意を得たりといふやうに）へえ、さうですか、君がヴアイオリンをね。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも、ヴアイオリンを少しばかり……。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷には瀬戸の丸火鉢が一つと、床の間にヴアイオリンのケースが置いてある。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の夕方、下宿で、何時ものやうにヴアイオリンの練習をしてゐると、女中に案内されて、若い女が僕の部屋へ訪ねて来たんです。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（紅子が笑ひたいのを我慢してゐる）実は、わたくしは、この裏に住んでゐるものですが、先日来、母が重病で寝んでをりますのに、どうも、こちらのヴアイオリンの音が耳について眠られないつて申します。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（紅子、危ふく吹き出さうとする）自分は、ヴアイオリンが好きで、毎日、あなたのお部屋から漏れる音を楽しみにして聴いてゐるんだなんて、お世辞を云つてました。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の病気がよくなつたからと報らせに来て、その序に、これからヴアイオリンを教へてくれと頼まれた時、僕は、それを断る勇気がありませんでした。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なにか妄念を払ふやうに、頭を振りながら、床の間のヴアイオリンを取り上げ、無暗に弾きはじめる）紅子　　兄さんも、お気の毒よ。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪次郎　　（ヴアイオリンを投げ出し）畜生！",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢現に聞えて来るあのヴアイオリンのメロデイーが、おれを、果して、幸福の絶頂に押し上げた。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『其れとも物質の變換……物質の變換を認めて、直に人間の不死と爲すと云ふのは、恰も高價なヴアイオリンが破れた後で、其明箱が換つて立派な物となると同じやうに、誠に譯の解らぬ事である。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
