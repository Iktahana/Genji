    "definitions": [
      {
        "index": 1,
        "gloss": "very messy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第一、床の間や置戸棚の上は勿論畳の上まで、書きつぶし、原稿用紙や新聞や雑誌や手紙がまるで紙屑屋の家のように、置きっ放しにしたまま、うず高く積まれているし、蒲団はしきっぱなしだし、足の踏み場もない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋は下座敷の八畳と六畳をぶちぬいて、踊り子全体をともかくもそこへ割り込ませることにしたのであるが、何をいうにも子供が多いのに、又その世話をする女や子供が大勢詰めかけているので、ここは二階以上の混雑で殆ど足の踏み場もないくらいであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその男どもが其處で寢起きしてゐるのか、昔私が人生の絨毯の一部を見て樂しんだホテルの廣間には、ベッドやら臺所道具やらが足の踏み場もないくらゐに散らかつてゐた。",
              "citation": {
                "source": "四葉の苜蓿",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の踏み場もないほど、こわれた物の破片で、いっぱいであった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――フォルチャ・ヘテロフィラと呼ばれる三畳紀の松柏類やポトザミテスという中世代の蘇鉄類がしんしんと繁り、その根元には、網羊歯や土筆のたぐいが足の踏み場もないほどはびこっている。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何がさて、足の踏み場もないほどに積込まれた上に、荒天続きの後を受けて、決して穏かな海ではない。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うづ高いほど積まれてゐた屍体からいつのまにか泌みだした血あぶらで、床はいちめん足の踏み場もない有様だつたといふことです。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の入口に近いところに、これもやはり油じみて黒光りのしてゐる冷飯草履が丁寧に揃へてあり、身の廻りのものといつたら唯それだけ、あとは足の踏み場もないほど、ぎつしり画架やカンヴァスで埋まつてゐるのでした。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず雑誌やパンフレットが散乱して足の踏み場もない院長の書斎と、狭い納戸としか表の方にはない。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれ鼠の守人が、そっと裏口の腰高障子をあけると、乱雑に脱ぎ捨てたおびただしい高下駄で、土間は足の踏み場もない。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭土の土間の上には、青痰やら、煙草の吸殻やら、魚の頭、豚の軟骨、その他雑多なものが参差落雑していて、ほとんど足の踏み場もない。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "離れになつてゐる書斎の六畳は、書籍や、標本や、新たに書き入れをした分布図のやうなもので足の踏み場もないくらゐであつたが、儀礼的な訪問でないとわかると、幾島は妹に手伝はせて二人の坐る場所を急いでこしらへた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく行くと、断層と曲流がいりまじって、足の踏み場もないようなむずかしいところへ出た。",
              "citation": {
                "source": "白雪姫",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯が入った時は、もう玉山崩れて、足の踏み場もないほどの有様です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯が入つた時は、もう玉山崩れて、足の踏み場もないほどの有樣です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表構えよりは小綺麗で、世帯道具も一と通り揃っておりますが、家の中はひどく乱雑で足の踏み場もないといった感じです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは常に一個とか二個とかに限られていなくて、見るものがほしくなり、彼の書斎は足の踏み場もないくらいに、壺とか花生とかが併んでいる、財力のない人間が自分の財力の程度を知りながら、なお、そこで※きながら慾望を満たそうとするのは、手のつけようのないものである。",
              "citation": {
                "source": "陶古の女人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "床一面に足の踏み場もないほどのざりがにがうごめいている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちどきに何千何萬の、何十萬の人間が死に、足の踏み場もないその野ざらしの死體のなかを、踏みつけないように氣をつけ、泣きながら歩いたことも始めてであつた。",
              "citation": {
                "source": "「屍の街」序",
                "author": "大田洋子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つてみると、まるで足の踏み場もないやうな市場的風景で、何萬圓などゝいふ銘品が顏を出してゐる展觀ではない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のはいった小屋はかなりに広かったが、ごたごたした道具や家族の人たちで、足の踏み場もないくらいであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち葉はじめじめと朽ちて厚く散り重なって、白茅青萱の足の踏み場もないまでにはびこり放題｜蓬々とはびこっていた。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺の土間には蓑や合羽が掛けてあり、四｜帖半だけ畳の敷いてある部屋も、納戸がないとみえ、隅には夜具がつくねてあるし、脱ぎっ放しの仕事着だの、なにかの包だのがごたごたして、足の踏み場もないようなけしきであった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の開票時から、七〇票くらいまで出たときには、足の踏み場もないほど、人間で埋まっていた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生や中学生の頃の美代子さんの部屋は、足の踏み場もないほどだったのですって。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた間、三間ほど、家捜しして、足の踏み場もないほど家財調度のちらかっている中に、一個の鎧櫃のふたを開けて、佐々介三郎と江橋林助のふたりで、古手紙の束や、書類を選りわけていた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間の見物や中売りの声が、にわかにガヤガヤしはじめると共に、楽屋の内でも足の踏み場もないような混雑。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その附近は、おびただしい血しおで足の踏み場もないほどだった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
