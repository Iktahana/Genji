          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンドロイドについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンドロイドの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンドロイドが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンドロイドについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンドロイドの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンドロイドが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンドロイドという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンドロイドについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンドロイドは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンドロイドが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンドロイドは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンドロイドの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンドロイドは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンドロイドは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『ターミネーター２』の液体金属アンドロイドの特殊効果は同社のワークステーションによるもので、３Ｄという専門性はあるもののこれを武器に自らの世界を拡張しようとする一ワークステーション・メーカーの傘下に入ったのでは、ライバルとなる他のハードウエア・メーカーとしては実際気が気ではないだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミノタロウスは大魔王ミノスに仕える大量生産タイプのアンドロイドで、首から上が牛で首から下が人間という不気味な恰好をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
