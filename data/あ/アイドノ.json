    "definitions": [
      {
        "index": 1,
        "gloss": "enshrinement of two or more deities in one building of a shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なるほどここは三条の宰相殿といって、羽ぶりのいい大臣のお屋敷でした。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とどなった時、ちょうどどこかへおでましになるつもりで、玄関までおいでになった宰相殿が、その声を聞きつけて、出てごらんになりました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相殿はびっくりして、「お前か、今呼んだのは。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相殿は笑いながら、「おもしろい小僧だ。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　一寸法師は宰相殿のお屋敷に使われるようになってから、体こそ小さくても、まめまめしくよく働きました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相殿はなおなおおおこりになって、一寸法師にいいつけて、お姫さまをお屋敷から追い出して、どこか遠い所へ捨てさせました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三条の宰相殿の姫君だぞ。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　一寸法師が宰相殿のお姫さまを連れて、鬼が島から宝物を取って、めでたく帰って来たといううわさが、すぐと世間にひろまって、やがて天子さまのお耳にまで入りました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀河の少将は、改めて三条宰相殿のお許しをうけて、お姫さまをお嫁さんにもらいました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "字は禄所が正しいという説もあるが、本社祭神は大己貴命、相殿として素盞嗚尊、伊弉冊尊、瓊々杵尊、大宮女大神、布留大神の六座（現在は大国魂神社）。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前宰相殿、駿河大納言殿の先例も近いこと。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この老獪な宰相殿と、あの清浄な簾子姫との間に、どんな関係があったのだろう？",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち大室権現、長幡正八幡相殿竹ノ本ニアリ。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（青根村）大室社二　一ハ村ノ鎮守、例祭九月廿日、相殿ニ八幡山神ヲ置。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の北の方と云うのは故藤の刑部卿教賢の御女で上西門院に宮仕えして小宰相殿と申して居た。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "小宰相殿は「今此の手紙を車の内になげ込んだのはどんな人でしたか」と御たずねになったけれ共、お供をして居たものがみんな知りませんと云ったので車の内において置くのもはずかしいからと袴の腰にはさんで御所にいらっしゃった所が、所もあろうに女院の御前に其の文を落してしまった。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "みめ形の美しいのは幸の花だと云うとおりで小宰相殿を女院から賜って今度のように西海の旅にまでもつれていらっしゃって、終には死んで同じ道に行かれるのも哀な事である。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、宰相殿から、何ともいってこないのは変だ、と思っていた矢先、宰相からも使いの者がとんできた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝ほどから腑におちぬご容子を見ておりましたところ、果たして賀相殿には、何とかして生命を助からんものと思われたか、お櫓の下に火を放けておられるのです。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして唐神という神を、相殿として共に祭られている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
