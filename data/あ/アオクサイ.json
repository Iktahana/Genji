        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
