        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なまで噛むと特徴ある青臭い香がする。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘蔗のひと節を短刀のごとく握り持ってその切っ先からかじりついてかみしめると少し青臭い甘い汁が舌にあふれた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホホホ」　彼女は又もフーッと青臭い息を私にマトモに吹きかけた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘って青臭い護謨の匂いが、何か揮発性の花の匂いに混って来る。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭い厚ぼったいゴムの匂いがする。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は止んで、日ざしが黄薔薇色の光線を漏斗形に注ぐと、断れ／＼に残つてゐる茨垣が、急に膠質の青臭い匂ひを強く立てた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの東鶴あるいは北亀は、西鶴にくらべて甚だ青臭い。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉蝶々やきりぎりすの手合の、免職されたア、失恋したアなどという眼から出る酸ッぱい青臭い涙じゃ無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一帯に青臭い草や樹の葉のいきれが満ちて、其の中に這入って行く者を重苦しく落ち付かせた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "影のふかい蚕豆、青臭い蚕豆、蚕豆に触れば、睾丸の下から、リリリリ……鈴虫が鳴きしきる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭い蚕豆、鬱陶しい蚕豆。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い青い青い青い、青臭い。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭い草の匂がむんむんして、暑い。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "概念の青臭い殻が実生活の錯綜の中に多少は脱ぎ棄てられた（と思われた）後も、なお、かつての不安の気持だけが、それだけ切離されていつまでも残っている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「今や大企業となったアップルはきっと恥ずかしくて青臭い論議を全面に押し立てられないのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんぞはそんな意気な者が有れば、何為にこんな青臭い山の中へ遊びに来るものか」「おや！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ青臭い山の中で御座います」「青臭いどころか、お前、天狗巌だ、七不思議だと云ふ者が有る、可恐い山の中に違無いぢやないか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けば行くほどその青臭い、物狂おしい太陽の香気が高まって来た。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも自分の持つてゐる青臭い若さが、正しい言葉を相手に受け入れしむる障碍となると思はれた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の町には、柿の葉などが道に落ち散って、生暖かい風に青臭い匂いがあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は、一日のうちに、必らず一度づつは、青臭い妓樓と藥臭い病院とのにほひを嗅ぐわけだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、如何に渠自身の所謂浪人はしてゐるにせよ、細君がもとの勤めをしてゐた時代の青臭い部屋ではなし、朝から酒に醉ツ拂つてゐる北劍の状態を氣の毒に思はざるを得ない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭いにおいが、ひとしきり鼻を打つ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の相手となる、男という男に、あの世から投げる父の嫉妬が、あまねく影を映すとすればいつか彼女に黴が生え、青臭い棺に入れられても、その墓標には、恋の思い出一つ印されないに相違ない。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのように、最後の幻までも奪い去られたとすれば、いつか彼女には黴が生え、樹皮で作った青臭い棺の中に入れられることもあろう。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども田口ほどの老巧のものに、何で学校を出たばかりの青臭い自分が、それほど苦になるのか、敬太郎は全く合点が行かなかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青臭い匂い、辛い匂い、薄荷めいた匂い、それらが一緒になって、彼を誘いました。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
