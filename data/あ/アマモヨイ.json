        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨もよいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨もよいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨もよいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨もよいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨もよいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨もよいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨もよいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨もよいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨もよいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨もよいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨もよいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨もよいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨もよいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨もよいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "時に雨もよいの夏雲の閉した空は、星あるよりも行方｜遥かに、たまさか漏るる灯の影は、山路なる、孤家のそれと疑わるる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨もよい雨よぶ声の寒けども寒しともなし、寂しけどなにか笑へり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四一八九三年十一月×日　いやな雨もよいの朝、巨きな雲。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月のはじめ、永い日も、午から雨もよいの、曇り空で、長屋建の平屋には、しかも夕暮が軒に近い。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならば月の明るい頃であるが、今夜は雨もよいの暗い空に弱い星の光りが二つ三つひらめいているばかりであった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月に入ってから雨もよいの日が続いたのは、月夜を嫌う馬狩りのためには仕合せであった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――定例の十日の朝はまちがいなく参りましたが、あいにくとその日は朝から雨もよいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た煙はじゅくじゅくした雨もよいに、真直ぐ空にものぼれず、ゆっくり横ひろがりになびいて、野面をすれずれに広がって行った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十日　雨もよいの湿っぽい午後　五時前　曇天の下に目の前の新緑はぼさぼさと見えた。",
              "citation": {
                "source": "窓からの風景（六月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨もよいの空はもう刻々と薄暗くなっていた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨もよいの夕に春日の森で若い二人の巫女にあったことがある。",
              "citation": {
                "source": "日光小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒々とした雨もよいの空がぼんやり眼にうつる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある蒸し暑い雨もよいの夜、舞台監督のＴ君は、帝劇の露台に佇みながら、炭酸水のコップを片手に詩人のダンチェンコと話していた。",
              "citation": {
                "source": "カルメン",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所に灯がついているから朝の支度をしているのかとも思えたが、雨もよいの空は真暗で、遠い山脈の方にうすら明りが見える。",
              "citation": {
                "source": "西南北東",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月の或小雨もよいの午後四時。",
              "citation": {
                "source": "情景（秋）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きに引かえ、帰りは少し雨もよいの涼しい天気に成ったので、ずうっと、野沢の方から千駄木の奥あたりを散歩した。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二日（木曜）曇　○ちらちらと雨もよいなので、風呂の火を早く入れる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨もよいの空、私は、怒りのかたまり見たいになって、須磨子の家の門を押した。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い雨もよいの午後である。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思いもよらない事と申しますのは、もう花橘の※と時鳥の声とが雨もよいの空を想わせる、ある夜の事でございましたが、その夜は珍しく月が出て、夜目にも、朧げには人の顔が見分けられるほどだったと申します。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす寒い、雨もよいの日で、彼は暗くなってから、雨にぬれながら、重い荷を負って家へもどりました。",
              "citation": {
                "source": "万の死",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つことの周りを堂々めぐりするだらだらともの憂い想念が、雨もよいの秋の夕暮を行く荷馬車の行列のように、彼の脳裡を繋がって通る。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数日の日が経った雨もよいの寂しい夕暮れであったが、桂子の館の前庭で、幽霊女と鶏娘とが、鶏頭の葉をむしりながら、しょんぼりとして話していた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日雨もよいの悪天候で、女たちはアブレがちであった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は、雨もよいの陰気なくらい晩でありました。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「加賀さまのほうで花火を上げているそうでござんすよ」　車夫の音松はそう言ったが、俥の上で振り返って見てもそれらしい光は見えず、雨もよいの風はひいやりと涼しく、夜空がいたずらに赤茶けていた。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸にひろがる八百八町を押しつけて、雨もよいの空はどんよりと低かった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨もよいの空は、暗く低く、何となく気の滅入りそうな空模様である。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ムンティンルパでは、レガスピーから来た避難民にも会いましたが、その人たちの話によると、日本軍の先遣部隊が上陸を敢行し、海岸地帯を占拠して後続部隊の来着を待っているそうです」　午後から雨もよいの空に変ったと思うと、爆音が層雲の中からひびいてきた。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にみくみ町へいったのは、まえの日から七日めに当る、雨もよいの午後のことであった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
