    "definitions": [
      {
        "index": 1,
        "gloss": "to match (rhythm, speed, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日合わすについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "合わすという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は合わすの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には合わすが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "合わすを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは合わすについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "合わすの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は合わすの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では合わすが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "合わすという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に合わすという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では合わすについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "合わすを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると合わすは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "合わすについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では合わすが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合わすは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により合わすの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "合わすは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に合わすは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｓ＝横丁の角　角を曲って立ち止って絵と印籠を照し合わす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "側の門弟の一人が、さては、と意味あり気な顔で見合わす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次も五郎蔵も「可笑しな具合」と顔見合わす。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤等も「何で厶ろうな」と顔見合わす。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室から運ばれる頭付軸木を手ごころで一定の分量だけ掴んで小函の抽斗に詰め、レッテルを貼った外函にさす、それを、手を打ち合わす、拍手のような動作のように、一瞬に一箇ずつ、チャッ、チャッとやってのけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全世界に於て、プロレタリアートが、両手を合わすことをやめて、それを拳に握り締めだした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山火事の場合は居合わす人数の少ないだけに、損害は大概｜莫大ではあるが、金だけですむ。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事とすべに依ればお光も呼んで立合わすよ」という剣幕。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時いずこともなく遠雷のとどろくごとき音す、人々顔と顔見合わす隙もなく俄然として家振るい、童子部屋の方にて積み重ねし皿の類の床に落ちし響きすさまじく聞こえぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より石級の方を望めば理髪所の燈火赤く四囲の闇を隈どり、そが前を少女の群れゆきつ返りつして守唄の節合わするが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからシベリアの一地方でコムスというのは、ふくれた胴に皮が張ってあるが、弦は二本で五度に合わすとある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発句は物を取り合わすればできる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって彼等と同じ程度の慾望や生活に歩調を合わすことは出来なかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きゃっきゃっ、」とまた笑うて、横歩行きにすらすらすら、で、居合わす、古女房の背をドンと啖わす。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔も覚めて来た」「おお寒」など、皆、襟、袖を掻合わす。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘二人顔を見合わす。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（胸に縋って、顔を見合わす。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方おもてを見合わす。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵は、かたわらより、「ともかく、今日はまあ見合わすとしたらどうじゃの。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "居合わす四五人は其後を尾けて行くと、お杉は顧りもせずに、町の真中を悠々と歩いていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は出版会社のタイピストをしており、ある夜、その出版会社から出ている雑誌を鶴雄に貸してくれたことが切っかけで、講習会場で顔を合わすと、時どき話し合うようになった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やがて講習会が済むと、もう顔を合わす機会もなく、鶴雄は簡単に忘れてしまった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから伊都子があくまで反対していると、その男に合わす顔がない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を合わすのが怖くて、同窓会ほも行けなかった――それが悲しかったのよ。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然に出くわしたので、もう顔を合わすのすら恥しいと思っていた彼はいきなり逃げ出そうとした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立会いに相手を傲慢で呑んでかかってから軽蔑の歯を剥出して、意見を噛み合わす無遠慮な談敵を得て、彼等は渾身の力が出し切れるように思った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から比較的ゆっくり街の門並の景色も見渡して行けるし、三四年間居ない留守中に、がらりと変った日本の男女の風俗も、乗合い客によって、手近かに観察出来るし、一ばん嬉しいのは、何と云っても、黒い瞳の人々と膝を並べて一車に乗り合わすことだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "才兵衛はおろかにもそれを自身の出世と考え、わしの今日あるは摩利支天のお恵みもさる事ながら、第一は恩師鰐口様のおかげ、めったに鰐口様のほうへは足を向けて寝られぬ、などと言うものだから、鰐口は町内の者に合わす顔が無く、いたたまらず、ついに出家しなければならなくなった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯を米良の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
