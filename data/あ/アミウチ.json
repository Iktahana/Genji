[
  {
    "uuid": "456f6295-211b-5984-a20e-bad5c8328ac1",
    "entry": "網打ち",
    "reading": {
      "primary": "あみうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "net fishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網打ちについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "網打ちという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網打ちの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網打ちが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網打ちを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網打ちについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "網打ちの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網打ちの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網打ちが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網打ちという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網打ちという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網打ちについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網打ちを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網打ちは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網打ちについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網打ちが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網打ちは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網打ちの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網打ちは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網打ちは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さて、むかし、とっこべとら子は大きな川の岸に住んでいて、夜、網打ちに行った人から魚を盗ったり、買物をして町から遅く帰る人から油揚げを取りかえしたり、実に始末におえないものだったそうです。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それだけならば別に問題にもならないのであるが、重兵衛はこの二、三年来、自分自身はめったに網打ちに出たこともなければ、魚釣りに出かけたこともなく、ほとんど懐ろ手で暮らしているのである。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣りにも網打ちにも出ない漁師が、いつも魚を絶やさないというには何かの子細がなければならない。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのあくる日は重兵衛が久し振りで網打ちに出てゆく姿を見た。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "めずらしいことだと近所でも噂していると、彼はその後毎日網打ちに出て、ほかの漁師達とおなじように稼ぎはじめた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、伝兵衛と云う中年の男であったが、それが初秋の比、夕飯の後で北上川の網打ちに往って、彼方此方と網を入れてみたが、不思議に何も獲れなかった。",
              "citation": {
                "source": "亀の子を握ったまま",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は九歳の時に遠賀郡の芦屋で、お祖父様の夜網打ちの艫櫓を押したというから、相当水泳が上手であったらしい。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又首筋へ労働者でなければ見受けられない深い皺が重なり合っていたが、これは翁自身の過激な肉体的習練の結果か、又は好物の畠イジリと網打ちの結果ではなかったろうかと思われる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは能を催したり、網打ちに行ったり、歌を詠んだりするために自然と、そんな習慣が出来たのかも知れないが、そればかりでもなかったように思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁はよく網打ちに行った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は網打ちに行くといつもまだ日足の高いうちに自宅に帰って、獲れた魚の料理にかかる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　ところで翁の弟子で一番熱心な前記斎田惟成氏はよく翁の網打ちのお供をした。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それから後斎田氏は高弟連中から色々な質問を委託されて翁の網打ちのお伴をしなければならなくなったが、時に依ると翁が意地悪く口を緘して一言も洩らさない事があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起をいうと、その昔、隅田川をまだ宮戸川といった頃、土師臣中知といえる人、家来の檜熊の浜成竹成という両人の者を従え、この大河に網打ちに出掛けたところ、その網に一寸八分黄金｜無垢の観世音の御像が掛かって上がって来た。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもどうして紀州藩では、五十嵐右内を国元へ送るに、罪人として網打ち駕籠へ乗せ、公然と送って行かないのであろうか？",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏がくれば、私は魚籠をさげて父のあとから、ひょこひょこ歩き、投網打ちに行った。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り着物を着て浜で貝拾ひをすることや、夕方庭の裏手から従兄が網打ちに出かけるボートに乗せて貰ふことは大好きだつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡良瀬川では鱸、せいご、ぼらの投網打ち、鮭網、鰻の袋網。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ」「金さんと勝則とが、網打ちから帰って来たんじゃなかったな？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "先夜、投網打ちに行ったとき、息子に、光丸に許婚があるという話をした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女房の焼き餅が、妙なところへ、妙な風に、あらわれて来たわい）　勝則と投網打ちに行った夜、お京の手紙を見られて以来、マンが、そのことについて、一口もいわないので、内心、気味が悪かった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎は、投網打ちに出たとき、この寿満丸のことは、最初から、念頭にあったのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖畔の料亭で浴衣になると屋根船で、ゆったりと湖面へ出る、小和船で網打ち、牛肉とかしわのすきやきに、とり立ての魚、（ハイと称す）の天ぷら。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッシーの八田氏来る、京都で又歓迎の網打ち会をやって呉れる由で、その相談。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい網打船に分乗、しばらくは網打ち、母船へ戻って、とり立てを天ぷらにして食ふ、去年と同じだから感興は薄いが、東京では味はへぬのんびりした遊び。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "年中品川へ網打ちにばかり出て、金を撒き餌に、雑魚をすくって、欣しがっているかと思うと、神田祭に、巨額な奉納金をして、花車の上で馬鹿踊りをやって、大得意な奴がある。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
