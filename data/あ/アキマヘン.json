        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "徳兵衛が刀を収めて、Ｔ「先ず二両」　山左が驚いて、Ｔ「捨て売りにしても五十両は」　徳兵衛、Ｔ「この不景気に御冗談を」　と言われて山左が、Ｔ「では三十両」　徳兵衛、あきまへん。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぢやてて、貴方はん、梯子がおへんよつて、どないにもあきまへん。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あて、あきまへんのどっせ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠したかてあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の言うことを信用したらあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまにあんた、警戒せなあきまへんぜ」　警戒とは大袈裟な言い方だと、私はいささかあきれた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう心掛けやさかい、あんたはいつまでたっても前座してんならんネやぜ、それに、なんだっせ、いつまでも『無筆の片棒』一点張りではあきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどめから会うたらあきまへんぜ」　蚊帳の中へはいってからも、他吉の小言は続いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――もうこれから、どんなことあっても、次郎ぼんと会うたら、あきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを、君ちゃん、よう噛み分けて考えなああきまへんぜ」「そんなら、潜る気はちょっともおまへんねんな」　君枝はすっかり当てが外れた想いで、蒼い溜息をついた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を落したらあきまへん」　と慰め、女の生理の脆さが苦しいまでに同情された。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うちの人の様にくよくよしとると、ほんまにあきまへん。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどめから会うたらあきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきまへん、降りとくなはれ」結局、豹一は降りざるを得なかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細い糸の上に人間が立つてるちふやうな将棋にならんとあきまへん。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お蔭で飯もよう喰わんと走り出して来居って……、ひもじゅうて叶わんがな」「どだい此処等の宿屋の女中があきまへんわ」　船頭の代りに屋根の下から答うる者がいた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう迚もあきまへんよつて、お先きへ遣つて貰ひまつさ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきまへん、迚もあきまへんよつて、お先きへ往かしとくなはれや、そしてお爺さんは後から緩くりおいなはれ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪に深い馴染のある方やないとあきまへんな。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうだすとも、大阪に深い馴染のある方やないとあきまへん。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そやけど、そない芝居をするとなると、仕打の白井さんは当にならんし、劇場から借りん事にはあきまへんぜ……」「劇場なら乃公が心配しよう。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃龍も居合わせ、「きっとどっせ、好う好う左の花道見といやっしゃ」と云ったが、自分一人になった時、「ほんまに間違えてお座りやしたらあきまへんえ、左の花道のねきいお座りやっしゃ」と念を押した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶商売では、茶を飲み分けることができないとあきまへん。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何んぼ隱れなはつても、あきまへんで。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そらあきまへんとも、私なぞ。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "『良いやうでも百姓はあきまへん。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の身體には矢ツ張り漢法醫がよいので、西洋醫者はあきまへんわい。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
