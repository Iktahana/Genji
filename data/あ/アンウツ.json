        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗鬱について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗鬱の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗鬱が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗鬱について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗鬱の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗鬱が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗鬱という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗鬱についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗鬱は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗鬱が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗鬱は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗鬱の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗鬱は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗鬱は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "われこの新道の交路に立てどさびしき四方の地平をきはめず暗鬱なる日かな天日家竝の軒に低くして林の雜木まばらに伐られたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杳として眺望すれば街路を這ひ行く蛆蟲ども生きたる食餌を暗鬱にせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱なる思想かなわれの破れたる服を裂きすて獸類のごとくに悲しまむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に課せられている暗鬱な周囲のなかで、やがてそれは幻聴のように鳴りはじめた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙で、電燈の灯もうるむかと思われるような暗鬱な冬の夕暮であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの詩に見る宿命論的な暗鬱性は、全く思索生活の情緒に映じた殘像である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "囀鳥軟風のふく日暗鬱な思惟にしづみながらしづかな木立の奧で落葉する路を歩いてゐた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱な北国地方の、貧しい農家に生れて、教育もなく、奴隷のような環境に育った男は、軍隊において、彼の最大の名誉と自尊心とを培養された。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱なる日かな天日家竝の軒に低くして林の雜木まばらに伐られたり。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗く陰氣なものは、じめじめした暗鬱の氣分のものは、本能的に厭ひであつて、見向くことさへもイヤであつた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも、味い剰すがゆえにいつも暗鬱な未練を残している人間と、飽和に達するがゆえに明色の恬淡に冴る人間とは極端な対象を做した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎は檜垣の主人の暗鬱な未練に対し、本能の浅間しさと共に本能の深さを感じ、檜垣の主人は鼈四郎の肉体に対して嫉妬と驚異を感じた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹田から青森まで、小さい蒸気船の屋根の上に、みすぼらしい服装で仰向に寝ころがり、小雨が降って来て濡れてもじっとしていて、蟹田の土産の蟹の脚をポリポリかじりながら、暗鬱な低い空を見上げていた時の、淋しさなどは忘れ難い。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでつづく暗鬱ぞ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、暗鬱な気持であった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻一刻、気持が暗鬱になった。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く私は北海道の旅館といえば、もっと暗鬱で、女中などはアイヌ見たようなのがいて、言葉も碌に通じはしまいと、迂闊にも思っていたのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱な日がやがて暮れてしまつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朗とか軽快とか――近頃の流行のモダンとかシックとか――いうようなものは、元より求むべくもありませんが、明朗であるよりも暗鬱である方が、軽快であるよりも鈍重である方が、さらに遙かに芸術的陰影を深めているという観点からいたしましても、東北地方は、日本中のどこよりも、私の気持ちに融合するのであります。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような、貧しい農家の有り様は、今にして、東北地方の暗鬱な空気が感じられます。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような暗鬱な生活の中にある生活は、真山青果氏も『南小泉村』の中で、如実に言っています。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の仕事場の窓上の、崖の上の杜の樹木の緑が日に日に深くなって、仕事場の台の上や人形の肌などにまで淡い緑の影がうらうらと動くような季節になると、西谷は酷く暗鬱になって来た。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨があがると、熬りつけるような暑い日が幾日となく続いて、再び又暗鬱な雨がじめじめと降り続いた。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は暗鬱な曇天がしだいに暗く灰色を帯びて、ストーブが真っ赤に焼けてきた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱、愚痴、こんなものは敵だとおもつてゐるのだ、さりとて情熱の欠けた日にペンを構えてゐる己れの面つきを想像すると、どうしても、これも修業だと自惚れるわけにはいかなかつた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "○竹谷富士雄氏――特待である、『夏』『海の女』では『夏』に詩味豊かなものがある、突込んである割に、映えないのは作者の心理に停頓があるからだ、色彩の重ねの効果を計画の中で軽蔑しすぎた感がある、近代感覚としても先走つた軽跳なモダニズムを排して、重厚で暗鬱な時代の色調を表現してゐるために、実感的である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
