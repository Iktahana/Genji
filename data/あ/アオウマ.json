    "definitions": [
      {
        "index": 1,
        "gloss": "dark-colored horse with a lustrous coat (coloured)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼女が臘虎の外套に顔をうずめて銀色の夜半の灯のもとを、二、三歩すすまないうちに、金格子の門衛室の扉がひらいて青馬のような近視眼鏡をかけた小肥なボッブの女が小走りにちかづくと、悪意のあることばで、「やあ、奥さん。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『礼記』に春を東郊に迎うるに青馬七疋を用いるの、孟春の月天子蒼竜（青い馬）に乗るなどとあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬節会の白馬を青馬と訓ますを古く不審しく思うた人少なからぬと見え、平兼盛が「ふる雪に色もかはらて曳くものを、たれ青馬と名け初けん」と詠んだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬を「あおうま」とのみ訓みしは、『平兼盛家集』に「ふる雪に色もかはらで曳くものを、たれ青馬と名け初けん」、高橋宗直の『筵響録』巻下に室町家前後諸士｜涅歯の事を述べて、白歯者と書いて「アオハ者」と訓ず、白馬を「アオ馬」というがごとしといえるにて知るべし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "作の青馬が急病で死んだんで、作は大弱りである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（104）地の青馬にうち跨っている酔漢を見たか？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "作の青馬が急病で死んだんで、作は大弱りでゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽原夫婦も見送り／＼、泣く／＼帰りかゝりますと、向うからわい／＼という声で大勢駈けて来る其の先へ、真しぐらに駆けて来たのは青馬で、荒れに荒れてトッ／＼と来ます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉でも、白い浪ではなくても白浪と言ふのは、文学語として此語を取り上げてゐた訣で、馬といふ為に赤駒といふ表現をして居り、これは次第に趣味が変つて、青馬などとも言つて来る様になつてゐる。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、妻の居るあたりをもっと見たいのだが、自分の乗っている青馬の駈けるのが速いので、妻のいる筈の里も、いつか空遠く隔ってしまった、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○水鳥の鴨の羽の色の青馬を今日見る人はかぎり無しといふ　〔巻二十・四四九四〕　大伴家持　同じく正月七日の侍宴（白馬の節会）の為めに、大伴家持が兼ねて作った歌だと左注にある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青馬」は公事根源に、「白馬の節会をあるひは青馬の節会とも申すなり。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによりて、正月七日に青馬を見れば、年中の邪気を除くという本文｜侍るなり」とある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "青馬の　　　　耳面刀自。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "――青馬の　耳面刀自。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは那古井の男かい」「はい、那古井の源兵衛で御座んす」「あの男がどこぞの嫁さんを馬へ乗せて、峠を越したのかい」「志保田の嬢様が城下へ御輿入のときに、嬢様を青馬に乗せて、源兵衛が覊絏を牽いて通りました。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "長良の乙女が振袖を着て、青馬に乗って、峠を越すと、いきなり、ささだ男と、ささべ男が飛び出して両方から引っ張る。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
