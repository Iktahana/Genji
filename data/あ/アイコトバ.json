[
  {
    "uuid": "0742356d-6f33-5e4c-a1cb-2f0534451a2d",
    "entry": "合言葉",
    "reading": {
      "primary": "あいことば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "password",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合言葉は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合言葉が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合言葉に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合言葉が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合言葉について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合言葉についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合言葉について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合言葉が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合言葉が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合言葉は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合言葉は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合言葉を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合言葉をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合言葉が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合言葉の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合言葉を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合言葉に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合言葉について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合言葉は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合言葉を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ゲシュタルト心理学が持ち出され、全体主義という合言葉も生れて、新しい世界観が、そろそろ登場の身仕度を始めた。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラブ員相互の合言葉。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝教大師の円頓戒に当るものは、弘法大師に在っては灌頂でありまして、この儀式を通して人々に人格完成の希望を喚起せしめ、かつ自覚に便利な宗教的な合言葉を与えて口に唱えしめ、以て現実生活に就かしめるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と陰気な合言葉で、国境の連山を、黒雲に背負って顕れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして歸つて行く時は、恰度何かの合言葉ででもあるかのやうに色々の特有の聲を以て「お大事に」と云つて行く。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が終ると、文化が日本の合言葉になった。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇の事情に就いての予備知識が全然欠けていること、当然知っていなければならない幾つかの術語や合言葉を知らないこと、私が心理的にも論理的にも余りに大ザッパな単純な人間になり過ぎて了ったこと、之等がその原因のようである。",
              "citation": {
                "source": "章魚木の下で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、合言葉、勝つかとかけるべく候、勝々と答へ申す可く候。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても縁起のよい合言葉である。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中には、作品の表面には、人道主義の合言葉や旗印が山の如く積まれてありながら、少しく奥を探ると、醜いエゴイズムが蠢動しているような作品も決して少くはない。",
              "citation": {
                "source": "志賀直哉氏の作品",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたしはかねてから、合言葉を用意してゐるのであつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、モモンガーのやうに扉に吸ひついて地団太を踏まぬうちは、合言葉の効も奏さなかつたから、気どつた歌などは無駄に過ぎなかつたといふものゝ、一応歌つた後に、心底から焦れつたくなつて喚き出す声でないと生憎く番人共の耳には達しなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の前のわたしの合言葉は、ウヰルソン先生の模倣であつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、雄吉のクラスだけでの合言葉ではなくなって、ほとんど学校中全体にさえ承認を求めるようにまで進んでいった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "合言葉や暗号なぞを作って用心をするのは事実で、なかなか捕まりにくいという。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝は、彼等が慣れた口調で切りに合言葉めいた術語を放つてゐるのに物珍らしく耳を傾けてゐた。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に周子が、眼を輝かせて白々しく珍らしい合言葉を口にしてゐるのを傍見してゐると、何だか自分の妻ではないやうな、そして彼女に、妙に新鮮な感じを持つた。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が呟く合言葉も宵のうちとは響きが違つて、牌の囁きにもつれるやうに、それで変に鋭く金属的にひゞく。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖は螺旋を巻き忘れた柱時計の顔を見ても、飲み忘れた水薬の香を嗅いでも、直ぐこの合言葉を思ひ出すのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安の文学の瀰漫した呼声、それに絡んで作家の教養とか文章道とかが末技的に云われている一面、その頃の合言葉として更に一つの響があった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年の春創刊された『文学界』はこれらの夥しい合言葉の噴泉の如き観を呈し、河上、小林、保田与重郎の諸氏の歴史の方向からはなれた文学の「人間化」「良心」「真理」「真実」論が、蔓延した。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌『行動』も発刊され、「行動主義」文学の提唱者は、「不安の文学」という合言葉の代りに、生活と文学とにおける「能動精神」の主張を以て現れたのである。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の現実の豊饒は、決して政論的に抽出された数箇の合言葉ではもたらされないという教訓深い事実である。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の人の口に上る合言葉、新聞雜誌の中に見つける新語、書物の中に出て來る學問上の術語、それらの多くは大きな言葉である。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、中野君の作品を批評する場合、みんなの合言葉みたいになってつかわれる「詩人」という言葉の内容についてだ。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主客の対立を先ず許しての上でなければ、主観が客観を構成するという転回的な言葉も実際上は虚しい合言葉に終る外はない。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をするとただの合言葉に終って了うかも知れないのだ――文学を思想の科学の角度から取り上げるのは、今後の認識論の課題の一つにぞくするようである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本文化」というような言葉は流行の合言葉とさえなっているが、ではその文化とは何かと尋ねて見るなら、恐らく満足な返辞の出来る日本文化主義者はいない、と私は見ている。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰も経済上・政治上の統制ということが合言葉になった時期のことだった。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
