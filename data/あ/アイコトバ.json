[
  {
    "uuid": "0742356d-6f33-5e4c-a1cb-2f0534451a2d",
    "entry": "合言葉",
    "reading": {
      "primary": "あいことば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
