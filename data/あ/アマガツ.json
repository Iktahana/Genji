    "definitions": [
      {
        "index": 1,
        "gloss": "doll onto which a child's misfortune is transferred",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天児について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天児という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天児の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天児が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天児を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天児について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天児の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天児の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天児が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天児という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天児という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天児についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天児を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天児は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天児について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天児が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天児は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天児の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天児は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天児は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして天児屋根命、太玉命、天宇受女命、石許理度売命、玉祖命の五人を、お孫さまの命のお供の頭としておつけ添えになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の左側に石の華表のある社は、河津八幡宮で、元の祭神は天児屋根命であったが、後に河津｜三郎祐泰及びその子の祐成、時致の三人を合祀したものであった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "守り刀、天児などを持って少将は車に乗った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一、二例を挙ぐると、『古事記』に、天孫降下の折随い参らせた諸神を列ねて、天児屋根命は中臣連等の祖などいった内に天宇受売命は猿女君の祖で伊斯許理度売命は鏡作連の祖と書いた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "天児屋根命二十二世の孫が藤原鎌足で、鎌足十四世の孫が忠実である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王は子供好きであったから、天児の人形などを自身で縫ったりしている時はことさら若々しく見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと「あまがつ」（天児）というものがあって貴い人の寝間にあって守っていると考えているが、これは寝ている人の形代なのである。",
              "citation": {
                "source": "人形の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり天児から御伽婢子というものになる。",
              "citation": {
                "source": "人形の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天児には何を入れたか、たぶん最初は何も入れたのでもなかろう。",
              "citation": {
                "source": "人形の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢れを移す人形とは即、撫で物・形代・天児などの名によつて呼ばれるものである。",
              "citation": {
                "source": "雛祭りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、平安朝頃の上流の女たちの玩び物には撫で物・形代・天児などいふ名で呼ばれた人形はあつたのであらうが、祓除の穢れを移す人形を、其儘、玩具にしたとはいへない。",
              "citation": {
                "source": "雛祭りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "形が同じである処から、同様な名前を附けたと見ることも出来るし、殊に、天児などは祓除以外の神事の人形であることを見せてゐるものらしい。",
              "citation": {
                "source": "雛祭りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢れを移す人形とは、撫でもの・形代・天児などの名によつて呼ばれるものである。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には、かなり古くから、天児・お伽這子の類を身近く据ゑて、穢禍を吸ひ取らせる、と言ふ考へはあつた様だ。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、人形の起原を単に、此穢れ移しの形代・天児・這子の類にばかりは、かづけられない。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして同じく、祝詞の神であつた為に、中臣氏の祖先と考へられたらしい天児屋命は、此神の子と言ふ事になつてゐる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、中臣の遠祖｜天児屋命則以｜神祝祝之神祝々之。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此呪術を行ふ者が、天児屋命或は太玉命と謂はれる神々である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神に高皇産霊尊が随うた如く、亦瓊々杵尊に天児屋命が随うた如く、尊い神事を行ふ者には、威霊を操置する呪術者が随伴するものと考へたのが、こゝに言はうとした日本古代信仰の、重要な一つの形態なのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原氏が天児屋命の後と称して居た理由も、大いに肯けるのだ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多くはございますが、我国の御守護神であらせられる邇々藝命様を始め奉り、邇々藝命様に随って降臨された天児屋根命、天太玉命などと申す方々も、何れも皆そうした生神様で、今も尚お昔と同じく地の神界にお働き遊ばしてお出でになられます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢人の波の上漕ぐ小船にもうきめは刈らで乗らましものをあまがつむ歎きの中にしほたれて何時まで須磨の浦に眺めんいつ口ずからお話ができるであろうと思っては毎日同じように悲しんでおります。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ビチヤ　ビチヤ　ビチヤ　ビチヤ」　すると　こんどは　おとこのこが　あまがつぱをきて　かさをさして、やつてきました。",
              "citation": {
                "source": "あめくん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あめくんは　かさと　あまがつぱのために　どうしても　そのおとこのこを　ぬらすことができません。",
              "citation": {
                "source": "あめくん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがつぱを　ぬいだ　おとこのこ　と　ちひさな　おんなのこが　ガラスまどの　ところへきて　いひました。",
              "citation": {
                "source": "あめくん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
