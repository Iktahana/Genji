        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "・青田おだやかな風が尾花のゆるゝほど・秋暑く何を考へてゐる・こゝにも家が建てられつゝ秋日和・何もかも虫干してある青田風　八月廿四日秋、秋、秋寒く秋暑し、夜は秋にして昼は夏なり。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋、秋寒を感じる、蚊が少くなつた、夜は晴れて月がよかつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物を重ねても寒い秋寒に講壇には真裸なレオというフランシスの伴侶が立っていた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒し、近況｜如何。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒を感じさせる風、水、雲。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒、何となくうすら寒い。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽろぽろ冷飯ぼろぼろ秋寒これは今朝の実感である、実情は偽れない、そこにこそ句の尊さがあるといふものぞ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮を掘る泥まみれ泥をかいては・秋のひかりの大鋸のようきれる・近眼と老眼とこんがらがつて秋寒く・芋の葉、それをちぎつてつゝんでくれる・ゆふ空から柚子の一つをもぎとる百舌鳥がしきり啼く、あの声に聴き入つて、死身の捨身になつたこともあつたが、今はどうだ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒し旅の女は炉になづみ甲斐の渓にて水晶の痩せ　秋寒しは、文章なら水晶の痩せて秋寒しと最後に来る言葉である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜雨秋寒うして眠就らず残燈明滅独り思うの時には、或は死霊生霊無数の暗鬼を出現して眼中に分明なることもあるべし。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説",
                "note": "青空文庫"
              }
            },
            {
              "text": "花とこしへの春ならじ、夏の火峯の雲落ちて御林の陣を焚き掃ふ四十餘營のあといづこ、雲雨荒臺夢ならず巫山のかたへ秋寒く名も白帝の城のうち龍駕駐るいつまでか。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒い夜風の中で、小止みない竹の葉擦れとともに、狐のなく声が聞こえた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とかの祟りで、昔から寄席の儲かる時分になると、万橘は脳を患っては休むのが常だ――と、これも、自分は、金沢華やかなりし頃、嘘か、まことか、耳にしたことも、こうなると、いっそ秋寒い。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋寒し起て詠ル我まくら　　　　諷竹　閨怨の句と見るべきであろうか。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "諷竹の句は情を抒することが多くない代りに、「秋寒し」の一語を以て、我と我枕を眺めている人の姿をまざまざと描き出している。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
