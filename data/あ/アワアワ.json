      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bubbly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日泡々について考えている。",
              "source": "幻辞"
            },
            {
              "text": "泡々という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は泡々の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には泡々が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "泡々を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは泡々について学習した。",
              "source": "幻辞"
            },
            {
              "text": "泡々の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は泡々の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では泡々が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "泡々という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に泡々という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では泡々についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "泡々を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると泡々は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "泡々について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では泡々が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に泡々は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により泡々の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "泡々は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に泡々は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "わあわあわあわあ、みんななにか云っているのです。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ四方の草のなかから、どんぐりどもが、ぎらぎらひかって、飛び出して、わあわあわあわあ言いました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわあわしい白ら雲が空ら一面に棚引くかと思うと、フトまたあちこち瞬く間雲切れがして、むりに押し分けたような雲間から澄みて怜悧し気にみえる人の眼のごとくに朗らかに晴れた蒼空がのぞかれた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わあわあわあわあ、みんななにか云つてゐるのです。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ四方の草のなかから、どんぐりどもが、ぎらぎらひかつて、飛び出して、わあわあわあわあ言ひました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわあわしい白ら雲が空ら一面に棚引くかと思うと、フトまたあちこち瞬く間雲切れがして、むりに押し分けたような雲間から澄みて怜悧し気に見える人の眼のごとくに朗かに晴れた蒼空がのぞかれた。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
