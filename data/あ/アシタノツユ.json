        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "海棠の花は朝の露に美しく、梨の花は夕月の光りに冴ゆ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなつめたい朝の露にみちてゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜉蝣の命、朝の露、そも果敢しといわば言え、身に比べなば何かあらむ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い土塀の際の葉の枯れた牡丹に並んで短い蘭の葉が生々と朝の露霜をうけた名残の濡色を日蔭に二株三株見せていた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花も葉もまだ朝の露が乾かない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『否とよ時頼、朝の露よりも猶ほ空なる人の身の、何時消えんも測り難し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の朝の露を踏み、新しい旅へ発足した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田圃道にはまだ朝の露が残つて居た。",
              "citation": {
                "source": "父の墓",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝の露っぽい路が海岸に向けて、ぼんやり見わけられた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の穂につつまれた磯の、広い塩田には朝の露が重く、まだ人の影一つ見えなかつた。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が幾年かの前に初めて秩父の地に足を入れたのは、丁度朝の露が枯葉に結ぶ霜と変って、小春日和の長閑な空に柿の実が赤い頃であった。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう朝の露はすつかり乾いてしまつてゐたけれど、遥かな海から吹いて来る微風に百合の叢は新鮮に揺らめいてゐた。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、平常から病身の身とて、遂に全く床に就く事となりまして、程なく私の事をいひいひはかなくも、私が十九の秋｜朝の露と消へ失せました。",
              "citation": {
                "source": "こわれ指環",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "百羽の雛――それがみんなでたった一匹の虫を追いかけ、毎朝の露のなかで迷い子になり、結局ちぢくれて疥癬かきになる――をあずかっている雌鶏のような、一千の思想とぼさぼさの頭とをもった人々。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび人間の仕事は春においてのようにかがやく――そうだ、すべての葉、そして小枝、そして石、そしてクモの巣は今、午後の中ほどにおいて、春の朝の露にぬれているように光っている。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋たつやきのふの雨を今朝の露　　　　従吾　句としてはむしろ陳腐であろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
