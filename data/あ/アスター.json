          ],
          "literary": [
            {
              "text": "隣りはタカヂアスターゼの兄さんか弟の家で、子供が八人くらゐゐて、ひどく賑かだつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝が来るたびに、隣りのタカヂアスターゼの下から三番目の子供が、「イチオー………コイマー」と何度も／＼呼ぶのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシャの人たちは、其名をザラツストラ、或いはゾロアスターという偉大な教祖の説を信じていた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸をこわさないように、ジアスターゼ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃弱を患ふる人がタカヂアスターゼを服し、苦味丁幾を服し、ペプシンを服し、粥を※て吸ひ、フランス麪麭を購ひて喫ひ、壓し麥を喫ふのを見ることは多いが、咀嚼時間を長くして、丁寧に咀嚼することを敢てするのを見ることの少いなどは其の一例である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "の體内よりヂアスターゼを得よ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまいにはとにかく三十ピアスターのお金を上げるから、蛇だけはだまつてこの中へお入れなさい。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのよくなれた蛇四ひきを三十ピアスターでとられちや合はないや。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃弱を患う人がタカジアスターゼを服し、クミチンキを服し、ペプシンを服し、粥を煮て吸い、フランスパンを買って食らい、押し麦を食らうのを見ることは多いが、咀嚼時間を長くして丁寧に咀嚼することが少ないなどはその一例である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の薬箱から消化剤のジアスターゼを得るよりは君の体内からジアスターゼを得よ。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一閑張の下には、ジアスターゼの瓶とカルモチンの瓶とが転がっていました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "正ちやん、そこからタカヂアスターゼをとつて呉れよ。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスマイル教徒に言わせると、この復活並びに最後の審判に関するゾロアスター教の教えは、単に宇宙系における周期的変転を表現する影像にすぎないというのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は Whittier五月　　九日　鶴見氏と午後から Greenwich へ人をたずね、お茶をホテルでのみ、東洋軒で食べ、ミス　リザノブィッチのところへ行き、アスターに一寸より、其から Whittier にかえり、Ａに電話をかける。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京、新宿にはアスター・インターナショナル、横浜の保土ヶ谷にはソーゴーという先駆けとなる専門業者が生まれ、エレクトロニクスのマニアたちの前に、安いものなら数十万円で中古のコンピューターが並びはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六（昭和五十一）年にリースバックのコンピューターや周辺機器のショップとして生まれたアスター・インターナショナルは、キット式のマイクロコンピューターシステムにも敏感に反応して、アメリカからの情報の中継基地となっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿と秋葉原に店舗を構えていたアスター・インターナショナルの双方の店を、古川は二日とおかず交互に訪れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにさんざん通い詰めた挙げ句、古川はアスター・インターナショナルでアルバイトを始めることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなアスター・インターナショナルの上顧客の一人に、早稲田大学の学生であるという西和彦がいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイト先のアスター・インターナショナルをはじめ、つごう三つのショップから在米のコンサルタントとなってくれれば月一〇万円程度支払ってもよいという提示があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "波斯寺とのみでは、ネストル教（景教）の寺を指すか、又はゾロアスター教（※教）の寺を指すのか、一寸判定し難い。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し殘缺ながら今日に傳はれる『兩京新記』の内容を調査すると、波斯寺二とある中の一つは、右街の醴泉坊に在る波斯胡寺で、これは高宗の儀鳳二年（西暦六七七）に、當時唐の保護を受けて居つたペルシア王｜卑路斯の爲に建立したもので、ゾロアスター教の寺である。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく區別する時は、胡教（ゾロアスター教）も、等しくペルシアに行はれ、また等しく明暗の二宗を説けば、宗教の内容などに不注意勝な支那の學者は、時にマニ教をも胡※の中に混同したかも知れぬ。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾後マニ教やゾロアスター教や、最後にイスラム教が侵入するに從ひ、佛教の勢力は次第に衰退したけれど、西暦八世紀の半頃、即ちほぼ般若三藏の時代までは、細々ながらその法運を維持して居つた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "武宗は所謂三武の一人で、道教を崇信する餘り、佛教を始め諸外教に對して激烈な壓制を加へ、その會昌五年（西暦八四五）には、ネストル教及びゾロアスター（Zarathustra）教（※教）の僧侶を併せて、二千餘人或は三千餘人を還俗せしめ、外國出身の僧侶は、多くその本國へ送還させた。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一）宋の宋敏求の『長安志』に唐代長安に在つたネストル教の波斯胡寺、ゾロアスター教のが果して進士及第者であるかは頗る疑問であるが、たとひ彼を進士及第者としても唐時代に賜進士及第と稱したかは一層の疑問である。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり紐育のアスターホテルのようなもののよさも、忘られず、又自然の、我手で我食う草を採ると云う境遇もしたわしいのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに陰陽及び天地人三才の思想はカルデアにもアッシリアにも存し、イラン民族に起りしゾロアスターの教は、陰神陽神を設けてその世界觀を説きたり。",
              "citation": {
                "source": "『尚書』の高等批評",
                "author": "特に堯舜禹に就いて",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカは主としてニューヨークに住んでいましたが、最初はホテル・マカルピン、次にホテル・アンソニア、それからアスターホテル、ルーズベルトホテルと、ニューヨーク一流のホテルに居りました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
