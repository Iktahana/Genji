      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vague",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ここでは物は曖昧でいる事は許されない。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジュウムの雁宮澤賢治青ざめた薄明穹の水底に少しばかりの星がまたたき出し、胡桃や桑の木は薄くらがりにそっと手をあげごく曖昧に祈ってゐる。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曖昧だしそれにみんなも越えれまい。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその判断が客観的に明瞭に主張される場合と、主観内に止まって曖昧な形より取らない場合とがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "x＝bb＝a∴ x＝aしてみると、形式論理学で媒概念曖昧の虚偽という奴だな。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰かあはれといふ暮の」といった掛詞風の曖昧性が醸し出されたのだ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの区別をしてもまだ問題は曖昧である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曖昧さ加減を最も明らかに吾人に示すのは綿糸の撚り糸である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世評許り気にして居る、狡黠な作者が能く云ふ、試作などいふ曖昧な歌が、石川君の歌には一首も無いのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『説文』に曰く電は陰陽の激曜するなりとはちと曖昧であるが、要するに陰陽の空中電気が相合する時に発する光である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその言葉が全く孤立するやうな時ですら、いささかもそれには曖昧なところも、躊躇ふやうなところもありません。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人となるや、彼は曖昧模糊な、不安定な存在となつてしまふ。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれもじきにまた曖昧になり、やがて単純な弱気な表情になって、ぎごちなく他所見をした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ……」女は曖昧に頷いた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知かも知れませんが、赤城下はその以前に隠し売女のあったところで、今もその名残で一種の曖昧茶屋のようなものがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と曖昧に塩入れ場の前に六尺の天秤棒や、丸太棒やを六七本立てかけてある方に顎をちょいと突き出して搾り場を通り抜けて行ってしまった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あすこはさっき曖昧な犬の居たとこだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその返事のバスに人ごとながら聴耳をたてたが、相不変曖昧な言葉が同じように鈍い調子で響くばかりで、やがて女はあきらめたようすでいなくなってしまった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと相対性理論の存在を必要とするに至った根原は、畢竟時に関する従来の考えの曖昧さに胚胎しているのではないかと考えられる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまたそれらの言葉の「文法」もきわめて明確に限定されていて少しの曖昧をも許さない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見かけ上のパラドックスは、実は「あたま」という言葉の内容に関する定義の曖昧不鮮明から生まれることはもちろんである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人は大へん曖昧な調子で答へました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともわざと焦点をはずした場合のように全部が均等に調和的にぼやけたのならば別であるが、明確なものと曖昧なものとが雑然と不調和に同居しているところに破綻があり不快がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには殉情的な要求から來た自己陶醉に似た曖昧な描寫がないではないけれども、その觀察の綿密で、而して傅習的でない點に於て、彼女の末期の作品に見られる骨組みの堅固さを見せてゐる。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは教授に向けられたのか、自分に向けられたのか、はっきりしないような曖昧なものであったが。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今お話します」　園は小母さんの怪訝そうな顔に曖昧な答えをしながら、美しい楕円の感じのする茶の間に通って、いつもの所に、……柱を背にして倚りかかることのできる……胸の動悸を気にしながら坐った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時独武者、杖をわきばさみ、兜を脱いで、「ええ、何んですかな、」と曖昧。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にもうこのごろは、お互い腹のさぐり合いで、十年来の友人でも、あいまいな事をちょっとだけ書いて寄こして、あなたみたいに、長い手紙を書いてはくれません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、何々学院の何々女史とでもいつたやうな者が「子供の純真性は尊い」などと甚だあいまい模糊たる事を憂ひ顔で言つて歎息して、それを女史のお弟子の婦人がそのまま信奉して自分の亭主に訴へる。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
