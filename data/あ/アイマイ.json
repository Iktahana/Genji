[
  {
    "uuid": "88cdbd1a-6835-5234-ab1b-a1b72223d302",
    "entry": "曖昧",
    "reading": {
      "primary": "あいまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
