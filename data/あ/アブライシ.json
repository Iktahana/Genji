    "definitions": [
      {
        "index": 1,
        "gloss": "stone with oil-like lustre (luster)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油石について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油石は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油石の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油石について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油石は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油石の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油石に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油石が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油石を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油石の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油石が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油石が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油石について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油石は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油石は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油石は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油石について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油石の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油石の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油石の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "村役場と駐在所が中央程に向合つてゐて、役場の隣が作右衛門店、萬荒物から酢醤油石油｜莨、罎詰の酒もあれば、前掛半襟にする布帛もある。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場と駐在所が中央程に向合つてゐて、役場の隣が作右衞門店、萬荒物から酢醤油石油莨、罎詰の酒もあれば、前掛半襟にする布帛もある。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場と駐在所が中央程に向合つてゐて、役場の隣が作右衛門店、万荒物から酢醤油石油｜莨、罎詰の酒もあれば、前掛半襟にする布帛もある。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、りっぱな油石だ。",
              "citation": {
                "source": "てかてか頭の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
