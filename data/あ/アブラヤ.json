        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油屋について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油屋は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油屋の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油屋について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油屋は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油屋の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油屋に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油屋が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油屋を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油屋の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油屋が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油屋が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油屋について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油屋は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油屋は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油屋は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油屋について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油屋の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油屋の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油屋の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "十五六になった頃、鰯網は、五六カ月働いて、やっと三四十円しか取れなかったので、父はそれをやめて、醤油屋の労働をすることになった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、醤油屋の「ゴンゾ」にもなった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健二は、三里ほど向うの醤油屋街へ働きに出ていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、一家が揃って慾ばりで、宇一はなお金を溜るために健二などゝ一緒に去年まで町へ醤油屋稼ぎに行っていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油屋は村の田畑殆んどすべての地主でもあった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は儲けた金を家へすぐ送る必要がなかったので、醤油屋へそのまゝ、利子を取って貸したりしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、他の醤油屋で働いていた同村の連中が、やはり信玄袋をかついで六七人立っていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主や、醤油屋の坊っちゃん達なら、東京の大学へ入っても、当然で、何も珍らしいことはない。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六からこちらへの経験によると、彼が困難な労働をして僅かずつ金を積んで来ているのに、醤油屋や地主は、別に骨の折れる仕事もせず、沢山の金を儲けて立派な暮しを立てていた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と同年輩、または、彼より若い年頃の者で、学校へ行っていた時分には、彼よりよほど出来が悪るかった者が、少しよけい勉強をして、読み書きが達者になった為めに、今では、醤油会社の支配人になり、醤油屋の番頭になり、または小学校の校長になって、村でえらばっている。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって、醤油屋の労働者になっても、仕事がえらくて、賃銀は少なかった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が今更、百姓をやめて商売人に早変りをすることも出来なければ、醤油屋の番頭になる訳にも行かない。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、それぞれ試験がすんで帰ってくる坊っちゃん達を迎えに行っている庄屋の下婢や、醤油屋の奥さんや、呉服屋の若旦那やの眼につかぬように、停車場の外に立って息子を待っていた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、汽車が着くと、庄屋や、醤油屋や、呉服屋などの坊っちゃん達が降りて来た。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、醤油屋の坊っちゃんは、プラットホームに降りると、すぐ母を見つけて、こう叫びながら、奥さんのいる方へ走りよった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」醤油屋の坊っちゃんは、あどけない声で奥さんにこんなことを云いながら、村へ通じている県道を一番先に歩いた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきのは、走りよって、息子のことを、訊ねてみたかったが、醤油屋へ、良人の源作が労働に行っていたのを思い出して、なお卑下して、思い止まった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子は、今、醤油屋の小僧にやられている。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槽を使うのは、醤油屋の仕事に慣れた髯面の古江という男がやった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一カ月もたてば、醤油屋で使う道具の名前は一と通り覚えてしまわねば一人前の能力がないものゝように云われていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油屋で何どあったんかいや！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「己らあ、もう醤油屋へは行かんのじゃ。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「醤油屋へ行かずにどうするんどい？",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも、醤油屋へ行きたくなくなって、彼は、十時頃まで日向ぼっこをしていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでだれかが、村の油屋まで油を買いにゆかねばなりません。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは油屋が一軒、豆腐屋が一軒、機織工七分に農民が三分という、物質には恵まれない寒村で、一生ほとんど給銀もなしに酷使われる若い男女は、日頃ひそかに二銭三銭と貯蓄して、春秋二期の恒例になっている、この村脱けに参加し、他国へ移動するのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は隣りの油屋の娘で、笛を吹くのが上手であった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下り切つて、油屋の前から右へ曲つたところで、小學校でちよつと教はつたことのある山下といふ愛想のよい先生にゆきあつた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の毒にな、何處の年｜寄りだか知らんが……」「飛びこまれた家もびつくりしたらうね、油屋ださうだが、正面の硝子をぶちやぶつて、油桶のならんでるところへぶつかつて來たんださうだからね。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、あぶらやのおせつ、琴にて、さよかぐらを、けいこ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
