        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "窓の外には更に清く澄み切つた空の光の下に、武藏野の秋の色の複雜な旋律とハーモニーが流れて行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の岸に茂る色々の灌木はみんなさま／″＼の秋の色彩に染められて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴は頬の色の「薄花桜」であることを重要視しているが、「いき」な頬は吉井勇が「うつくしき女なれども小夜子はも凄艶なれば秋にたとへむ」といっているような秋の色を帯びる傾向をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外にはさらに清く澄みきった空の光の下に、武蔵野の秋の色の複雑な旋律とハーモニーが流れて行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の岸に茂るいろいろの灌木はみんなさまざまの秋の色彩に染められていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱くもあり蚊もいるが、夜はさすがにあらそわれない秋の色だ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "階前の薔薇の花が少し咲きかけた初夏の庭のながめには濃厚な春秋の色彩以上のものがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸じゅうの混雑を一つに集めたかと思われるような両国にも、暮れゆく秋の色と匂いとが漲っているように見えるのが、このごろの薄寒い朝の景色であった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀　　山には紅葉、野には菊、きのふけふは秋の色もだん／＼に増してまゐりましたな。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くからはただ薄青く見えてゐた山が、日が上つたのと、こつちが段々近づいて行くのとで、見る見る消えて行く青い靄のかげから、多彩な秋の色を現しはじめた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白色には神聖の感あり、粛殺の感あり、故に秋の色は白とす。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌流転美│頽廃美└壊滅美凋落の秋の色散る葉のうつくしさ木の葉は散るときが最もうつくしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は秋の色をしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩もまだ盛りとゆかず、僅に雁来紅、百日紅、はちすの花などが秋の色をあつめている。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも隣の嫗よりもらひしといふ萩の刈株寸ばかりの緑をふいてたくましき勢は秋の色も思はる。",
              "citation": {
                "source": "小園の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が弟子の句空に送りました句に、「秋の色糠味噌壺も無かりけり」とあります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中に射した日光が秋の色で、浮雲がゆるく沼の上に流れている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く床の上に起き直つて、小机を蒲團の傍まで引張つて來て胃の膨滿を抑へながら、原稿紙に向かつた時は、もう世の中が秋の色を帶びてゐた。",
              "citation": {
                "source": "「額の男」を讀む",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ秋の色の空に動くのを美くしいと観ずるよりほかに能のない私には、彼の言葉が封じ込められた或秘密の符徴として怪しい響を耳に伝えるばかりであった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年は夢かまぼろしか時の流は絶えねどもレーズの水は世に湧かずむかしの思忘られで今はたこゝにわれ一人夕日の前に佇めば染むとも見えぬ秋の色に山々高し水遠し。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳中眠かすかにて短檠光薄ければこゝにも見ゆる秋の色銀甲堅くよろへども見よや侍衞の面かげに無限の愁溢るゝを。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "群雄次第に凋落し雄圖は鴻の去るに似て山河幾とせ秋の色榮華盛衰こと／″＼くむなしき空に消行けば世は一塲の春の夢。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京に近づくに従ひ、沿道の眺めは却つて物寂しく、秋の色が次第に深くなつていくやうに思はれた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことに油画ではまだ日本のこの濃度ある秋の色の分厚さを大胆に造型化していないようだ。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、まだこの道が通えないということはございませんが、十一月になりましては、もういけません」　とにかくに馬を進ませて行くに従って、秋の色は深くなってゆくばかりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろの胆吹山が大きな鳴りを立てたかと思うと、さっと吹き下ろす風が千丈の枯葉を捲いて、原も、村も、里も、一度に裏葉を返す秋の色を見せました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "空にはもう秋の色があった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
