    "definitions": [
      {
        "index": 1,
        "gloss": "Amaterasu Ōmikami (sun goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天照大神について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天照大神という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天照大神の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天照大神が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天照大神を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天照大神について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天照大神の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天照大神の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天照大神が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天照大神という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天照大神という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天照大神についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天照大神を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天照大神は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天照大神について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天照大神が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天照大神は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天照大神の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天照大神は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天照大神は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その煤けた天照大神と書いた掛物の床の間の前には小さなランプがついて二｜枚の木綿の座布団がさびしく敷いてあった。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊弉諾神は、この女神さまに天照大神というお名前をおつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊弉諾神はこのお三方をご覧になって、「わしもこれまでいくたりも子供を生んだが、とうとうしまいに、一等よい子供を生んだ」と、それはそれは大喜びををなさいまして、さっそく玉の首飾りをおはずしになって、それをさらさらとゆり鳴らしながら、天照大神におあげになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩屋一　天照大神と、二番目の弟さまの月読命とは、おとうさまのご命令に従って、それぞれ大空と夜の国とをお治めになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、その響きにびっくりなすって、「弟があんな勢いでのぼって来るのは、必ずただごとではない。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、「はじめに生まれた三人の女神は、おまえの剣からできたのだから、おまえの子だ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、大空の神々たちは、たいそうお困りになりまして、みんなで安河原という、空の上の河原に集まって、どうかして、天照大神に岩屋からお出ましになっていただく方法はあるまいかといっしょうけんめいに、相談をなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、そのたいそうなさわぎの声をお聞きになると、何ごとが起こったのかとおぼしめして、岩屋の戸を細めにあけて、そっとのぞいてご覧になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命は、「じつはおれは天照大神の同じ腹の弟で、たった今、大空からおりて来たばかりだ」と、うちあけてお名まえをおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剣はのちに天照大神へご献上になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きじのお使い一　そのうちに大空の天照大神は、お子さまの天忍穂耳命に向かって、「下界に見える、あの豊葦原水穂国は、おまえが治めるべき国である」とおっしゃって、すぐにくだって行くように、お言いつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その当たった矢が名鳴女の胸を突き通して、さかさまに大空の上まではねあがって、天安河の河原においでになる、天照大神と高皇産霊神とのおそばへ落ちました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　天照大神は、そんなわけで、また神々に向かって、こんどというこんどはだれを遣わしたらよいかとご相談をなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしたちは天照大神と高皇産霊神とのご命令で、わざわざお使いにまいったのである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天照大神と高皇産霊神に、すっかりこのことを、くわしく奏上いたしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠沙のお宮一　天照大神と高皇産霊神とは、あれほど乱れさわいでいた下界を、建御雷神たちが、ちゃんとこちらのものにして帰りましたので、さっそく天忍穂耳命をお召しになって、「葦原の中つ国はもはやすっかり平らいだ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神と高皇産霊神とはそれをご覧になりますと、急いで天宇受女命をお呼びになって、「そちは女でこそあれ、どんな荒くれた神に向かいあっても、びくともしない神だから、だれをもおいておまえを遣すのである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夢の中で、天照大神と高皇産霊神のお二方が、建御雷神をおめしになりまして、葦原中国は、今しきりに乱れ騒いでいる。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で皇女、豊※入媛が、はじめて伊勢の天照大神のお社に仕えて、そのお祭りをお司りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまは、やはり皇后のお口を通して、「これはすべて天照大神のおぼしめしである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、室の一方には蒲団を畳んで積み、衣類を入れた葛籠を置き、鎧櫃を置き、三尺ばかりの狭い床には天照大神宮の軸をかけて、其の下に真新しい榊をさした徳利を置いてあった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年七月廿八日神武天皇の御創業　皇孫｜彦火瓊瓊杵尊が、天照大神の神勅を奉じ、日向の高千穂の※触ノ峰に降臨されてから御三代の間は、九州の南方に在つて、国土を経営し、民力の涵養を図ると共に、周囲の者どもを帰服せしめ、之を化育することに依つて、いよ／＼興隆の基礎を築かれたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民は、各氏の氏神を祭ると共に、天照大神をはじめ、天つ神を崇敬し、同時に天皇を現人神と仰ぎ奉つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、神武天皇が、御東征の途次、困難に際会される毎に、天照大神の神意に従はせられた事を見ても分ることである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神を女神としたは理に合わぬなどの論がかえって理に合わぬと惟う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神代巻」や『古事記』に、天照大神岩戸籠りの時、八百万の神、常世の長鳴鳥を聚め互いに長鳴せしめたと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他、天照大神を始めとし、諸神を祭れる小祠相接し、その數、百に下らず。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自分が嘗て考へた如く、日本に於いては倭姫が天照大神の御靈を奉じて諸國の土豪から領土人民を寄附させて統一の基礎を固めた時に當ると思ふ。",
              "citation": {
                "source": "日本上古の状態",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに神代紀に載つて居る傳説では、最初から天照大御神と素戔烏尊とが兄弟であり、又天菩比命も天照大神の子であるといふ風に神話が形作られてある。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし其の天照大神から崇神・景行までの御歴代の數を、出雲國造の系圖に傳へて居る天菩比命から出雲振根までの代數に比して、この代數が信ずべきものとすれば、其れによつても二つの系圖が同じ年代を經て來たのでないといふことが推斷される。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
