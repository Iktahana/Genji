        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "蒿雀は鳴く、風はさわたる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸から一間許り西手の小藪に蒿雀がツン／＼鳴く。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "只蒿雀は冬も春も辨へぬやうに、暖かい日南から隱氣な竹の林を求めて低い小枝を渡つて下手な鳴きやうをして、さうして猶且日南へ出て土をぴよん／＼と跳ねた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞蒿雀は忽ち啼きやんだ。",
              "citation": {
                "source": "山鴫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進曲蒿雀が鳴いて水がしたたり風が艶をぬり、雲が翳りを掃くのはわれわれのさびしい精神を空中へ、より高みへおくるあたらしい行進曲でなくて何かその笛やシンバルを愛さずしてどうして野原を歩き廻れようか。",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは蒿雀にちがいなかった。",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあおじいさんとこへきな。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の竹藪には薄い夕日がさして、あおじやつぐみの鳴き声が垣に近く聞こえる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "解けやらぬ小川の氷の上にはあおじが飛び、空しい枝の桑畠にはつぐみが鳴き、榛の根の枯草からは水鶏が羽音高く驚き立った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおじさん、あんたは知らないの、私が一ぺん死んで、だんだらのきれいな羽をした蝶々になって生まれ変わることをさ？",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車の前の方の小窓からのぞきますと、右手はふかくしげった山のふもとで、左手には小さな谷川がながれていまして、二本のレールがあおじろくまっすぐにつづいています。",
              "citation": {
                "source": "ばかな汽車",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてこんなところにいたんだ」「ああおじさん、助けておくれよ。",
              "citation": {
                "source": "街の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああおじさんですか。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさん、いつここへいらしたの」「ああおじさん、とうとうやって来たねえ。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは何をするところなの」「さあおじさんにはわからないよ。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると萩原は詩から想像した私をあおじろい美少年のように、その初対面の日まで恋のごとく抱いていた空想だったそうである。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして向岸の暗みへゆきつくと、間もなく、あおじろい夜明けがやってくるらしいのだ。",
              "citation": {
                "source": "寂しき魚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて九時ごろになって、私が急に大きい声出して、笑いながら、さあおじさま、もうそろそろおいとまいたしますよって云ったら、むくり起き上ってパチパチして、改って御挨拶で、これも大笑いいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおじいさん、どうしたの」おたねは立ってそっちへいった、「独りで出て来たりして危ないじゃないの」　それが多助であろう、登は手を洗うために金盥を引きよせながら、さりげなくそっちを見た。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公や筒鳥に代って、晴れた日にはつぐみやひたき、頬白、あおじなどの声が聞え、木戸の者たちの中には、辛抱づよく粟や稗を撒いて、かれらを呼びよせようとする者もあったが、岩ばかりのそんな高いところでは、寄って来る鳥もなかった。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああおじちゃま知らないの。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おれに従いて長い目で見ていると、今にわかって来る」「じゃあおじさんは、泥棒でもないの」「そんな割の合わない商売はしない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　多宝塔の上で、遠術の印をむすんでいた呂宋兵衛、あおじろい額から、タラタラと脂汗をながしたが、すぐ蛮語の呪文をとなえ、満口に妖気をふくみ入れて、フーと吹くと、はるかな、竹童と鷲の身辺だけが、薄墨をかけたように、円くぼかされてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらぬだに白い斑のある樺の木に、一本一本、あおじろい月光が横から射している。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふと思い出したように、「じゃあおじさん、何の約束なしに、おらを蜂須賀村まで連れてってくれるかね。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "スズメという語は本来は小鳥の総称で、今でも藪スズメ（あおじ）だのカナスズメ（鶺鴒）だのという方言は多く、これを差別するためには今日の軒の雀をサトスズメ・ホクロスズメまたはマスズなどと呼んでいる。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
