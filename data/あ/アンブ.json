[
  {
    "uuid": "1dccaa32-22a4-53e7-b410-9b15a8bca3c4",
    "entry": "暗部",
    "reading": {
      "primary": "あんぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dark side (of nature, town, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗部について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗部という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗部の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗部が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗部を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗部について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗部の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗部の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗部が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗部という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗部という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗部についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗部を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗部は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗部について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗部が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗部は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗部の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗部は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗部は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そう、思うに博士、僕らはこの暗部にいくぶん光を当てつつあるのかもしれないし、そのあいだオープンショウ青年に残された手は、僕に教わったとおりにすることだけだ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "世を吹き渡る嵐にそれも今や消えようとしておれば、恋は心の暗部と引き換えに輝きを増す灯火のごとく、消えかけてはまた燃え立ってくる。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "メッセンジャ誌の編集長が暗部に光を当ててくれた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーチンはイズミを看護したのか、そこに医者はいたのか、医者なら暗部に光りを当てられる。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
