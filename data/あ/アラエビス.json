[
  {
    "uuid": "6d037682-ad88-5780-93a7-2d7db37d0a3d",
    "entry": "荒夷",
    "reading": {
      "primary": "あらえびす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crude warrior from the eastern parts of Japan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒夷について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒夷という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒夷の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒夷が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒夷を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒夷について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒夷の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒夷の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒夷が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒夷という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒夷という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒夷についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒夷を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒夷は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒夷について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒夷が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒夷は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒夷の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒夷は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒夷は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "吉田兼好の、あはれ知らぬ荒夷の為に書いたと言ふ艶書一件は、自作ならぬ歌が入つて居た処で、うそ話と言つて了へない隠者らしい為事なのだ。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼の島の者ども、因果の理をも弁えぬ荒夷なれば、荒く当りたりし事は申す計りなし」「彼の国の道俗は相州の男女よりも怨をなしき。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る荒夷の恐ろしげなるが、かたへに逢ひて、御子おはすやと問ひしに、一人も持ち侍らずと答へしかば、さては物のあはれは知り給はじ。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある荒夷も、物のあわれを知らぬげに見ゆる武骨一遍の勇士のことを言いたるものなり。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒夷のような彼も松殿の意見に従い、押しこめた人々をみな許したのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸や上方の者からは、世界のはてか、毛むくじゃらな荒夷の住家ぐらいに思われていた奥州の、草｜茫々とした野原の片端れや、笹熊の横行する山際に、わずかの田畑を耕して暮していた百姓達は、また実際狐や狸などと、今の我々には解らない関係を持って生活していたものらしい。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体平安朝末から文献に見えるあらえびすなる語は、此常世神の其時代に於いて達した、極度の変化を示すと共に、近代に向うて展開すべき信仰の萌しをも見せてゐる。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらえびす」の「荒」の要素が忘られて来て、常住笑みさかえる愛敬の神となつたのは、今一度常世神の昔に返つた訣なのである。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらえびす」の方は、新聞に音楽や、絵のことを書くのに、胡堂でははなはだ堅いので、胡という字を柔らかく訓んで、「あらえびす」としたまでのことである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の仮名遣いは、あらゑびすでなければならないが、仮名遣い問題のうるさかった時で、読みよく「あらえびす」としたに過ぎない。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私には、本名の長一で来る手紙と、胡堂または「あらえびす」で来る手紙とがある。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらえびす」と書いて来るのは、音楽関係の人か、レコードファンで八パーセントくらいはあるだろう。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "ペンネーム由来記",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野村氏は「あらえびす」の別名でレコード音楽について書いている。",
              "citation": {
                "source": "探偵小説このごろ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年九月末日あらえびす記戦闘の人ヘンデル「お前の一番好きな作曲家は？",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胡堂」と「あらえびす」　胡堂を名乗りはじめた頃である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、私のところへ来る手紙は、本名と、胡堂と、あらえびすと、三種類ある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらえびすは、音楽とレコードの関係で、八パーセントくらいだろう。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらえびすの筆名を使いはじめたのは、大正十三年。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「袖荻祭文」という芝居の中で桂中納言に化けて出た安部の貞任が、花道の中ほどで引き抜きになり、「まことは、奥州のあらえびす」と威張るところがある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "語源的にいうならば、「にぎえびす」に対する「あらえびす」で、日本が台湾を領有した当時の言葉でいうならば、熟蕃に対する生蕃である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらえびす」の名で原稿の注文も来るようになった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年越し隣に住んでいたＳさんが、ある日新聞を見ておどろいて、「あなたが、レコードのあらえびすさんですか」　と、とびこんで来たことがある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、レコード関係の原稿に、私の別号あらえびすを署名した最初である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十四年五月あらえびすよき曲よき演奏よき録音蒐集道の法三章レコード音楽の功績　日本の音楽界とは言わないが、少くとも、日本における一般人の洋楽趣味を向上させた点において、ラジオと共に、レコードの功績を没することは出来ない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷の説によると、稚子攫いを職業にする悪者は、男の子ならば室の津の唐船へ売りわたし、眉目よい女子だと京の人々が、千里もあるように考えている東の国から那須野の原をさらに越えて、陸奥のあらえびすどもが、京都の風をまねて文化を創っている奥州平泉の城下へ遠く売りとばされてゆくのだという。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、彼のたれより生一本な皇室至上の理念とその気位が、尊氏のような武士層に人気のいいいわゆる“あらえびす”にたいしては、危険視が先立って、よくその人間を知ろうともせず、警戒の念をまず先に深くしていたといってよい。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いかに世とはいえ、東国のあらえびす、尊氏の家宰、いわば陪臣ではないか。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
