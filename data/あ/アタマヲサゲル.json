        "examples": {
          "standard": [
            {
              "text": "毎日、頭を下げるについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭を下げる戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭を下げるの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭を下げるという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭を下げるについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭を下げるの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭を下げるに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭を下げるを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭を下げるは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭を下げるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭を下げるは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭を下げるを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭を下げる」という概念について深く考察する必要があります。",
              "source": "幻辞"
