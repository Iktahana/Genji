    "definitions": [
      {
        "index": 1,
        "gloss": "approximate (number)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アバウトについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアバウトは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アバウトの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアバウトについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アバウトは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアバウトの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アバウトに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアバウトが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアバウトを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アバウトの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアバウトが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアバウトが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アバウトについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアバウトは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアバウトは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアバウトは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアバウトについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アバウトの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアバウトの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアバウトの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ノビノビというべきかダラシナクというべきか、ともかく書きたいように書いたファイルは、太っ腹というのかアバウトというのか、ともかく大きいには違いない稲葉さんの度量によって復活のチャンスを与えられた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんなの、このいそがしいときに」　とワラが、プログラム・シートから目をあげずにいって、〈トゥー・ビジー・シンキン・アバウト・マイ・ベイビー〉を口ずさむ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トィンクル、トィンクル、リトルスター、ハオアイ、ワンダア、ホアツユウアール、ホエン、アップアバウト、インザスカイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、格調急に変じて、ゼ、クイン、オブ、ナイトシャイン、フェイア、ウイズ、オールハア、バージン、スタース、アバウトハア――　口早にそれを言い切ると、また足拍子がはじまりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「シュア」「ダズ・ヨ・マザー・ノウ・アバウト・ジス・ガール？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
