        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有るか無きかについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有るか無きかの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有るか無きかが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有るか無きかについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有るか無きかの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有るか無きかが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有るか無きかという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有るか無きかについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有るか無きかは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有るか無きかが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有るか無きかは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有るか無きかの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有るか無きかは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有るか無きかは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "虫の声　垣根の朝顔やう／＼小さく咲きて、昨日今日｜葉がくれに一花みゆるも、そのはじめの事おもはれて哀れなるに、松虫すゞ虫いつしか鳴よわりて、朝日まちとりて竈馬の果敢なげに声する、小溝の端、壁の中など有るか無きかの命のほど、老たる人、病める身などにて聞たらば、さこそ比らべられて物がなしからん。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "根の根の細かな繊毛のその岐れの殆ど有るか無きかの毛の尖のイルミネエション、それがセンチメンタリズムの極致とすれば、その毛の尖端にかじりついて泣く男、それは病気の朔太郎である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上を見ると黄色がかった小さい花が簇生しているが、それはきわめて謙遜な、有るか無きかのものである。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故か此の有るか無きかの影が、ハツキリと眼に付いた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸一枚繰り開けたるところより首をさし出して窺ふに、薄墨色の雲の底に有るか無きかの星影の見えたるなど、猶おぼつか無くは思はるれど望みを断つべくもあらぬさまとなりぬ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大巌山の幻が、闇の気勢に目を圧えて、用水の音｜凄じく、地を揺るごとく聞えた時、道子は俤さえ、衣の色さえ、有るか無きかの声して、「夢ではないのでしょうかしら。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはいかに母を説き動かしけん、余は彼ら親子の家に寄寓することとなり、エリスと余とはいつよりとはなしに、有るか無きかの収入を合せて、憂きがなかにも楽しき月日を送りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小な胸には、大切なものを落したやうに、大袈裟にハツとしたが、ふと心着くと、絹糸の端が有るか無きかに、指に挟つて残つて居たので、うかゞひ、うかゞひ、密と引くと、糸巻は、ひらりと面を返して、糸はする／＼と手繰られる。",
              "citation": {
                "source": "蠅を憎む記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはいかに母を説き動かしけん、余は彼等親子の家に寄寓することとなり、エリスと余とはいつよりとはなしに、有るか無きかの收入を合せて、憂きがなかにも樂しき月日を送りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはいかに母を説き動かしけん、余は彼ら親子の家に寄寓することとなり、エリスと余とはいつよりとはなしに、有るか無きかの收入を合せて、憂きがなかにも樂しき月日を送りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の鋸屑のやうな花の白みが、音もなくそこらに散らばる度に、有るか無きかのその匂が、埃臭い土のしめりと混り合つて、たよたよと私の心の薄明りに烟のやうに低く這ひ寄つて来る。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さく尖つた頭の端に、針のさきで衝いた程の、ちよつぴりとした有るか無きかの二つの黒い目。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の中でも、背の低い、色の黒い、有るか無きかの髭を生やした、洋服｜扮裝の醜男が、四方八方に愛嬌を振舞いては、輕い駄洒落を云つて、顏に似合はぬ優しい聲でキャッ／＼と笑ふ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の中でも、背の低い、色の黒い、有るか無きかの髯を生やした、洋服｜扮装の醜男が、四方八方に愛嬌を振舞いては、軽い駄洒落を云つて、顔に似合はぬ優しい声でキヤツ／＼と笑ふ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の日射は青田の稻のそよぎを生々照して、有るか無きかの初夏の風が心地よく窓に入る。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはいかに母を説き動かしけん、余は彼等親子の家に寄寓することゝなり、エリスと余とはいつよりとはなしに、有るか無きかの収入を合せて、憂きがなかにも楽しき月日を送りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "有るか無きかの微風にも、その初毛のやうな、また綿のやうな花が軽く静かに飛んで行く。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隅に文鳥の体が薄白く浮いたまま留り木の上に、有るか無きかに思われた。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪多く余る光を椽にこぼすこなたの影に、有るか無きかの細りした顔のなかを、濃く引き残したる眉の尾のみがたしかである。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに放射する有るか無きかの光、それを以て如何にして太陽の光輝を想い得よう、日に照せば彼は一片の石塊となる、回顧は竟に茫乎として去った夢を趁うに過ぎない……私はつくづくと年の経ったのを感じた。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の戸口をガタガタ開けて嵐の吹きすさぶ井戸端へ出るまで――駄夫の通過ぎた部屋はと言へば、それが即ちこの家全体の間数を縦断したわけで、階段を降りた場所が不思議に明るい三畳の間、その隣りには与里の老母が有るか無きかに凭れてゐる朦朧とした六畳の部屋、そしてそれだけが全部であつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（檀山を去って有るか無きかの間に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀薄で、清浄で、殆んど有るか無きかの、光の凝塊と申上げてよいようなお形態をお有ち遊ばされた高い神様が、一｜足跳びに濃く鈍い物質の世界へ、その御分霊を植え附けることは到底できませぬ。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の入口の辺から前方を眺めても、霞が一｜帯にかかっていて、何も眼に入りませぬが、しばらく過ぎると有るか無きかのように、薄っすりと山の影らしいものが現われ、それから又しばらく過ぎると、何やらほんのりと丹塗りの門らしいものが眼に映ります。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、あ、あ、あ」　大きい欠伸を一つ、手足を存分に踏み伸ばすと、絡まるのは有るか無きかの、フンワリした夜の物。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "有るか無きかの小さい小さい赤い黒子。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり危機のたびに人知れず、そっと有るか無きかの刺戟を相手に与えるだけのことである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろはあるかなきかに思われし源叔父またもや人の噂にのぼるようになりつ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "檣頭に掲げられた灯が見る／＼薄れて、唯あるかなきかの圓光に變つてしまつた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありぢごくの黒い手脚にかんかんと日の照りつける夏の日のまつぴるまあるかなきかの蟲けらの落す涙は草の葉のうへに光りて消えゆけり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
