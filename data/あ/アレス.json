        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アレスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アレスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアレスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアレスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アレスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアレスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アレスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアレスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアレスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アレスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアレスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアレスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アレスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアレスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アレスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアレスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアレスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアレスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アレスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアレスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「なんでも、慶一さんの好きなもので」　管理棟のかげから出て、ステージが見える場所にくると、ちょうどエンディングで、拍手がわき起こり、深紅の蝶ネクタイをして、今夜のＭＣをやっているワラが、ワイアレスマイクごと手を叩きながら、中央に歩みでるところだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーヴはなるべく奇抜な材料を得んと心掛けている作家であるが、彼が「アドヴェンチュアレス」の中に入れている暗号は極めて平凡なものである。",
              "citation": {
                "source": "「二銭銅貨」を読む",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何かにつけてケアレスな青年であったから、そのころのことは主要な印象のほかは、すべて煙のごとく忘れてしまったけれど、その小さい航海のことは唯今のことのように思われていた。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者はチヤアレス・マツクフアレエンといひ、日本に来たことはないが、頗る日本に興味をもつた人である。",
              "citation": {
                "source": "日本の女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアレスベッドの広告が出ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チアレストンよりもっと新らしいのよ。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々と戰ひて死せる巨人等彫像にはアポロン、アテナ、アレスの三神がその父ゼウスの傍にありてフレーグラの戰ひ（地、一四・五五―六〇參照）に死せる巨人等の骸を見る状をあらはせり【ティムブレオ】アポロン。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレギュアスはアレスの子なり。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "常時フィレンツェの人口は一三〇〇年における同市の人口の五分一なりしを告ぐ〔マルテと洗禮者との間〕マルテ（ギリシアにてはアレス）の像あるポンテ・ヴェッキオ（地、一三・一四五―七並びに註參照）と聖ヨハネ（ジョヴァンニ）の洗禮所との間。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュアレスの「三人」（宮崎嶺雄君訳）岸田國士　私は嘗て、シュアレスを知るために、そして同時に、フランス人の観たイプセンなるものを注意するために、この『Trois Hommes』を読んだ。",
              "citation": {
                "source": "シュアレスの「三人」（宮崎嶺雄君訳）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし、シュアレスは、彼自身、決して民族的立場からこの「三人」を取扱つてゐるのではない。",
              "citation": {
                "source": "シュアレスの「三人」（宮崎嶺雄君訳）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに本□によって（赤門前）私のピアレス bed を買い、瓜生でジアリンを買い、（その前に燕楽で食事）かえる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーシャとヒメーラとは集会のかくれ場を見つけられアレスト〔逮捕〕される。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カドモスと軍神アレスの女ハルモニアとの結婚に際して、諸神の賜いし物数多ありし中に、一個の頚輪あり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは工神ヘファイストスの製作せしものにして、残虐なる軍神アレスの、呪咀せられたる行為、その表面に彫刻しあり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォイボスや、またアレス、ヘルメスなんどと云う神達は、己は見なかった。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして偉大なアンドレ・シュアレス（『偉大なシュアレス』といったのはモーリス・マーテルリンクであるが）は、彼がドビュッシーの熱愛者であるにもかかわらず近頃こう書いた――「福音書を書くような態度でベートーヴェンについて書く権利を私はロマン・ロランにだけ認容する。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要な本が手に這入るまでは脱稿をのばしたとか、聖トマスの『スンマ・テオロギカ』やスアレスの本を携えて旅行に出たとか、という事実も挙がっている。",
              "citation": {
                "source": "デカルトと引用精神",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことがロマン・ロラン、アンリ・バルビュス、及び『勝利』、『聖なる顔』のエリイ・フォール、『人生について』のアンドレ・シュアレスのごとき知的指導者達の失敗の一部を物語っている」云々。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアレスのベッドで三つに折れるの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乳房」という小説の書けたときこのピアレスのベッドは買ったもので、年数でいえば、詩を書く友達が亡くなったときだからまる三年ぐらいですが、スプリングがすこし弱って来て、背骨によくないといけないので板を並べてスプリングをあてにしないことにしたわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中アラビア船に逢い、ロポ・ソアレスが総司令官の後継者に任命されたことを知ったのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルブケルケを憤死せしめたロポ・ソアレス・ダルベルガリアは一五一八年まで総司令官の職にあったが、前任者のあとを追って一五一六年に三十七隻の大艦隊を以て試みた紅海遠征は散々の失敗であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧夫のアレスタナスが群を数えたときにヤギとイヌがいないことに気がついた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドビュッシーの音、ロダンの像、シュアレスの句は、あなたの国の一五〇〇年代の芸術家らと同じ系統のものです。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディアレストが己とは独立した存在だということを示す更なる証拠が必要なら、まさにこれがそれだった。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ディアレストにお仲間でいてもらうには代償を支払う必要があることに彼は気づいた――果てのない警護という代償だ。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
