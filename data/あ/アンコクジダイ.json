    "definitions": [
      {
        "index": 1,
        "gloss": "Dark Ages",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗黒時代について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗黒時代の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗黒時代が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗黒時代について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗黒時代の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗黒時代が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗黒時代という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗黒時代についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗黒時代は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗黒時代が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗黒時代は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗黒時代の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒時代は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗黒時代は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第三紀層、白堊紀、石炭紀、Silurea 紀と地球創成の跡を究めて、遂に太古の暗黒時代に這入つた時、若き研究家であつた彼が、人生の大きな不安に捉はれて、深い懷疑に沈んだ時を私は想像した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、僕の最も暗黒時代で、未だ一家を支へるだけの腕はなし、頭は固らず、讀んで修養すべき書物はなし、不安恐懼に滿ちた生活をして居た。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころは、おしゃれの暗黒時代と言えましょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落の暗黒時代が、それから永いことつづきました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落の暗黒時代というよりは、心の暗黒時代が、十年後のいまに至るまで、つづいています。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、ヨーロッパが暗黒時代の深き眠りから醒めて以来、幾十万の勇敢なる風雲児が、いかに男らしき遠征をアメリカアフリカ濠州および我がアジアの大部分に向って試みたかを。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川義元の西進　群雄割拠の戦国時代は一寸見には、徒らに混乱した暗黒時代の様に見られるけれども、この混乱の中に、自ら統一に向おうとする機運が動いて居るのを見逃してはなるまい。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代は、一見いたづらに混乱した暗黒時代に見えるが、この中に日本全国が自ら統一に向つて、動いてゐたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち地球外の他の惑星からの侵入者は四千万に達し、これを防衛する地球植物と地球人類とは実力に於て常に不利なる立場にあり、而も地球植物、殊に可動植物は地球人類を服従｜乃至無力化せんとして到る所に於て暴行を事とし、史上最高の暗黒時代である。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "引續き足利時代となり、其中頃から戰國となつて、文化の上においても殆ど暗黒時代を現はしたが、其間に自然に獨立思想がだん／＼行亙つて、さうして日本は神國であつて日本は特別な國體だといふことが、この暗黒時代において一般に浸みわたるやうになつて來たのであります。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事は私が應仁の亂のお話をした際に、皇室が衰微して其の極に達して居る時、皇室中心の思想が足利の末半分ばかりの時において一般に行亙つたといふ事を申しましたが、龜山、後宇多天皇頃から南北朝の始めに起つた所の新思想は、足利時代の暗黒時代を經ても其思想は決して消滅しなかつたやうであります。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論さう云ふ暗黒時代は折角支那から輸入した多くのものを失つて居ります、其の當時の貴族の學者、例へば一條禪閤兼良と云ふ樣な學者がありますが、さう云ふ人達は戰亂の爲めに古來相傳の文化を失つたと云ふ事を非常に殘念がつて居る。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふことで暗黒時代の神道と云ふものは、殆ど完成してそれを握つて居たのが吉田家でありまして、それを日本中の神主に傳授した、此の傳授を受けなければ神道の權威がなかつたのであります、それで之は特に當時に於いて發明された所の一つの學科であります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが暗黒時代を經て、一つの文化的權威になつて、歌は二條家とか冷泉家と云ふ所から傳授を受けなければ歌が詠めないことになつたのであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云ふことは、寧ろ日本が支那文化の衣を脱いで、自分が丸裸になつてから得た所のものでありまして、日本人は正直を尊び、ありのまゝなる姿を尊ぶことを特色とするやうになつたのでありますが、それが皆此の暗黒時代に他の國との關係を大部分失つた時分に出來て居ります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の國語の法を發見する事、日本人の性質としての特別な點を發見する事、國體の特別な點を發見する事、さう云ふ事は鎌倉時代から足利時代の暗黒時代にかけて發見した事であります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ樣に其の當時朝に夕をはからざる危難の間に、文化階級の人として、さう云ふものをどうしても失つてはならないと云ふ考へで、皇室なり公家なり、諸職の人々が一所懸命になつて暗黒時代にも保存して、それだけは日本がどんなに亂れても失はなかつたものであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暦法、陰陽と云ふ樣なものは、支那人が傳へて居た數術、或は印度で云へば吠陀の中にあるもので、之も同じく日本人が暗黒時代に保存して居たのであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ事で、兎に角印度なり支那なり西洋なりに於て文化の要素として數へられて居た條件は、日本の暗黒時代に有ゆる外國から輸入された文化の着物を脱いだ後に、新たに發明され、或は保存されて存して居たのでありますから、日本人は文化的要素を持ち得る條件を備へて居ると云ふ事は申す迄もないのであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般文化も中世は見方によって暗黒時代でありますが、軍事的にも同じことであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世暗黒時代から文芸復興へ移るときに軍事上の革命が起ったのは、鉄砲の発明という兵器の関係でありました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "用兵術もまた暗黒時代となれる中世を経て、ルネッサンスとともに新用兵術生まれしが、重金思想は傭兵を生み、その結果、持久戦争の時代となれり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代は国民皆兵であり、決戦戦争の色彩濃厚であったが、ローマの全盛頃から傭兵に堕落し遂に中世の暗黒時代となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世騎士の時代となって各個戦闘となり、戦術は紊れて軍事的にも暗黒時代となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは口では一人残らず民主主義を唱えているが、その大部分はにせものであつて、本質は、先ごろの暗黒時代の政治家といささかの差異もない。",
              "citation": {
                "source": "政治に関する随想",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一節に曰く野蛮の先導者暗黒時代の松明持孔子を祭りたる廟と今なほ二、三の考古家によりて愛読せらるる『論語』といふ古書における「子の曰く」を研究したる学校とのありし処は今の○○シヤボン屋のシヤボン庫のあたりなりといふ。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始キリスト教では、キリスト復活の第一の姿をマリアが見たとされて、愛の深さの基準で神への近さがいわれたのだが後年、暗黒時代の教会はやはり女を地獄と一緒に罪業の深いものとして、女に求める女らしさに生活の受動性が強調された。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は句読点の原則すら確立せざる言語上の暗黒時代に生まれたるものなり。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
