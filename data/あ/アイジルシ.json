[
  {
    "uuid": "7fc0bce8-d8fe-5454-b914-3671935e7c4f",
    "entry": "合印",
    "reading": {
      "primary": "あいじるし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "identifying mark (esp. a mark of comradeship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合印は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合印が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合印に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合印が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合印について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合印についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合印について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合印が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合印が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合印は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合印は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合印を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合印をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合印が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合印の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合印を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合印に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合印について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合印は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合印を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先ず福昌号の表口へ行って、その店の商品の合印が○に福の字である事を、その肉の太さから文字の恰好まで間違いないように懐紙に写し取った。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白無垢に白襷、白鉢巻をして、肩に合印の角取紙をつけた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東京随一の不良少女享楽団が全部揃いで持っているもので、どこかに合印か何かあるらしいがハッキリとわからない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして下男には、菱形の四｜角へ『多』の字の合印しの附いた法被を着せてくれた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "富森助右衛門が、帯に入れる鎖、呼笛、鎖鉢巻、合印の布などの一纒めにしたのを、配って歩いた。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、両袖に縫つけてあった合印の布を、力任せに剥ぎとって、泥溝の中へ、叩き込んでしまった。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、鎖鉢巻を懐から出して、泥溝へ投込み、羽織の下の方に縫つけてある合印を手早く剥がして、雪の中へ棄ててしまった。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄せ集めの軍勢だから同志打ちの危険があるので合印しをつくり、佐賀勢は藁の占縄、平戸勢は大小の鞘に白紙三つ巻、島原勢は左の袖に白紙、大村勢は背三縫に隈取紙をつけた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねての申し合わせは、白鉢巻を合印にするのであったけれど、今朝それを用意してきたのは森五六郎の外、二、三人しかないようであった。",
              "citation": {
                "source": "『七面鳥』と『忘れ褌』",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは最近の府藩県の動きを知るに足るもので、伝馬所に必要な宿駅の合印である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは關東でも名題の、何んとか組の合印なんださうで」「大變な男だな」「こんな男の後押しぢや、大膳坊倉の中で何をやり出すか、わかりやしませんね」「ところで、もう一つ、蝠女とかいふ巫女は何をして居るんだ」「變な女だと思つたが、段々見て居ると、こいつも惡くない女ですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地中の富",
                "note": "青空文庫"
              }
            },
            {
              "text": "延長を表すその複合印象は、視覚や触覚にとって不可分な、より小さい幾つかの印象から構成される。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、色と固体性を賦与された、多数の原子や微粒子の複合印象と呼ぶことができよう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその観念が複合観念ならば、複合印象から生じるに違いない。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "――味方同士の合印である。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではめいめい、合印として、これを※の真向へ挿してゆけ」　と、白い鷲の羽を一本ずつ手渡した。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
