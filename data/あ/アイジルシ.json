[
  {
    "uuid": "7fc0bce8-d8fe-5454-b914-3671935e7c4f",
    "entry": "合印",
    "reading": {
      "primary": "あいじるし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
