          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "六　秋から冬にかけてのことだったが、銀子は女房持ちの若林に、何かしら飽き足りないものを感じ、折にふれてそれを言い出しでもすると、若林は一言のもとに排け、金で面倒を見てやっていれば、それで文句はないはずだというふうだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実女神達よりも美しい自分が、女神と同じやうに不平なく歌つてゐることも、姫は、飽き足りない、と思つた。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の相手には上の上の品の中から選んでも飽き足りないことであろうと見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世に少しでも飽き足りない心を残すのはよくないということだから」　源氏は涙ぐんで言っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子や娘は母の態度を飽き足りない歯がゆいもののように思って、尼になっていながらこの世への未練をお見せするようなものである、俗縁のあった方に惜しんで泣いていただくのはともかくもだがというような意味を、肱を突いたり、目くばせをしたりして兄弟どうしで示し合っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実は先朝に権力をふるった人たちに飽き足りないところがあって引きこもっていたのであるから、この人に栄えの春がまわってきたわけである。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこまで理屈らしく理屈をたどって来てみると、葉子は自分というものが踏みにじっても飽き足りないほどいやな者に見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家ぢうを大声あげて、出来るだけの速さで駆け回つても、まだ飽き足りないやうな気がします。",
              "citation": {
                "source": "美智子と歯痛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長先生に対する私たちの怨恨は、私たち二人が二人とも黒焦になってしまっても、まだまだ飽き足りないでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「七郎と八郎の喧嘩の言葉を束にして、九郎の顔に投げつけてやつても俺は飽き足りないぞ。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この混乱と没規準とが頂点に達した一九三四年後半、上述のような混迷した芸術至上主義、人間的文学論に飽き足りない一団の批評家、作家によって、一つの文学的気運が醸し出された。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺しても飽き足りないくらいよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああお前は俺にとって、黄金よりも珠よりももっともっと可憐く思われる時もあれば、斬り殺しても飽き足りないほど憎く思われる時もある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉を食い血を啜っても、飽き足りないところの仇敵であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなものを考え出しおった奴は、絞り首にしても飽き足りないと思いますわい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴等の肉を裂き、骨をしゃぶっても飽き足りない思いを抱きながら吾輩は、この釜山港口、絶影島の一角に隠れて、自分の食う魚を釣っていたんだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し又誰か僕の筆記に飽き足りない人があるとすれば、東京市外××村のＳ精神病院を尋ねて見るが善い。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまただれか僕の筆記に飽き足りない人があるとすれば、東京市外××村のＳ精神病院を尋ねてみるがよい。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、憎んでも飽き足りないのは彼の蠅男！",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この形勢をみて取った松平容堂は薩長の態度を飽き足りないとして、一新更始の道を慶喜に建白した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こんないやな男に……」　一晩中自由にされていたかと思うと、殺してもなおあきたりないくらい、小郷が憎くなって来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "章は女のそうした容にあきたりないところがあった。",
              "citation": {
                "source": "狼の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが探偵小説の作者や翻訳者の中には、探偵小説にあきたりない感じをもっている人が少なくとも少しはある。",
              "citation": {
                "source": "伊豆の国にて",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "話できいた時には、殺してもあきたりない奴だと思ったが、実際あってみると、それ程どなりつけるわけにもゆかない。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる世にそむき、常識による生活の平凡な規律を我から破ったものとして来ている荷風が、女というものを眺める眼も特定の調子をもっていて、良家の婦女という女の内容にあきたりないのはうなずけることであると思う。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の私小説やそのリアリズムにあきたりない思いは、三好十郎自身のうちに烈しく存在している。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同人雑誌」でさえあればそれが新しい文学の温床なのではなくて、旧来の文壇気質やジャーナリズムの現代文学の空虚さにあきたりない何かのつよい生活的文学的欲求があり、その表現として商品性に抵抗する同人雑誌があらわれてこそ、同人雑誌としての意義がある。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインのこんにちの燃え立つ階級間の争闘を、柳沢健氏が、その民族の持っている一本気で純朴で誠実な徳性によって、惨虐性にまで進められてあるのだと説明していることだけに（中央公論「西班牙を想う」）あきたりないと同じように。",
              "citation": {
                "source": "十月の文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新派は十九世紀の終りの日本に歌舞伎にあきたりない川上音二郎一派によって創立された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独の旅路なり」という遺書をかいたということさえ、従来の女にあきたらず、しかもあきたりない女を生む社会の条件が自分にも作用していることに理解の到らなかった「人士」に対して一つの衝動として受けられたのであったろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
