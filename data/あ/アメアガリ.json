        "examples": {
          "standard": [
            {
              "text": "私は毎日雨上がりについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨上がりの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨上がりが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨上がりについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨上がりの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨上がりが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨上がりという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨上がりについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨上がりは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨上がりが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨上がりは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨上がりの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨上がりは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨上がりは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雨上がりの、それはひどい震災後の道路を、自動車で残酷に揺られて行くうちに、朝から身体のどこかに隠れていた、名状の出来ないものの塊が、だんだんにからだ中に拡がって来るようであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の横腹から頬の辺まで、雨上がりの泥濘がべっとりついて塗り立ての泥壁を見るようである。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　雨上がりに錦町河岸を通った。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を降りて徒歩で降りることさえ、雨上がりなんぞにはむずかしい。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開けて雨上がりの気持のいい空気を入れ、「きっと大丈夫だ」とオレは小さな声で言ってみた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開けて雨上がりの冷たい空気を入れ、「きっと大丈夫だ」とオレは小さな声で言ってみた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨上がりの、田舎道に蟇の子が、踏みつぶさねば歩けないほど出るのと同じように、沢山出ているはずの帆船や漁船は一｜艘もいなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "龕燈を照らしてその付近を見しらべると、雨上がりのどろの道にもところどころに消えやらぬ同じ四つ足の足跡がはっきり残っているのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨上がりでおおしあわせよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷のいさご路、雨上がりの湿った海岸の砂路、あの滑らかな心地の好い路が懐しい。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三六　火花　やはりそのころの雨上がりの日の暮れ、僕は馬車通りの砂利道を一隊の歩兵の通るのに出合った。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど雨上がりで、水がなみなみと岸にまであふれそうにたくさんでありました。",
              "citation": {
                "source": "遠くで鳴る雷",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨上がりで足をすべらせた児童の一人が河に落ちこんだ。",
              "citation": {
                "source": "石碑",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　蟻と鷓鴣の子　一匹の蟻が、雨上がりの轍のなかに落ち込んで、溺れかけていた。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「雨上がりですが好いでしょうか。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には灰色の教会尖塔が垂直に、雨上がりの青空にくっきり立っている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アゾで草が茂っている、ことに雨上がりのそんな処では、ちょっと先頭に立つのは躊躇される。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "積みあげてある馬糧のいちめんから、雨上がりの火山か、芋屋の竈のように、むっくり……と白いけむりがゆらぎはじめた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて近づいた倉院の屋根は、雨上がりに似た深い夜靄のうちに寝沈んでいた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
