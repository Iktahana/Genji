        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ひっきょう食いつつ吐きつつ食いつつ飽き足るということを知らない闇。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手も雄弁を弄することになれば、旗鼓相当って、彼の心が飽き足るであろう。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり倦みたれば、一ツおりてのぼる坂の窪に踞いし、手のあきたるまま何ならむ指もて土にかきはじめぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり倦みたれば、一ツおりてのぼる坂の窪に踞ひし、手のあきたるまま何ならむ指もて土にかきはじめぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂水巖に、蜂巣の如く穴あきたるが面白しと云ふ者もあらむ、それは兒戯的なりと云ふ者もあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日永の晝寢にもあきたるにや、遊女二三人、紐帶のしどけなき姿して樓前に草摘むも、山なればこそ。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎が祖父は隠居所にありしが、馳出でて門のあきたるを見て、外なる狼藉者を入れじと、門を鎖さんとせしが、白刃振りて迫られ、勢敵しがたしとやおもいけん、また隠居所に入りぬ。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "よってこのたびはまた、社中申合わせ、汐留奥平侯の屋鋪うちにあきたる長屋を借用し、かりに義塾出張の講堂となし、生徒の人員を限らず、教授の行届くだけ、つとめて初学の人を導かんとするに決せり。",
              "citation": {
                "source": "慶応義塾新議",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "主の死去したるかまたは旅行中にてあきたるがゆえ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては地極と地帶の旅にあきたる殉教者、吐息をついてわが漂浪を樂しくしながら、海は、われに黄色の吸盤をもてる影の花をうかぶ、その時われは跪く女のごとくなり。",
              "citation": {
                "source": "醉ひどれ船",
                "author": "LE BATEAU IVRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに小虫は四囲より集り、只眼のみあきたるにより、為に眼囲に向て集るを以て、絶えず手にて払わざる時は尚多く集りて耐ゆべからず。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリアを旅して往々穴のあきたる銀貨のツリを貰ふことあるは、此風習あるが為なり。",
              "citation": {
                "source": "馬上三日の記",
                "author": "エルサレムよりナザレへ",
                "note": "青空文庫"
              }
            }
          ]
        }
