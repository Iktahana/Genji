          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ大陸について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ大陸の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ大陸が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ大陸について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ大陸の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ大陸が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ大陸という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ大陸についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ大陸は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ大陸が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ大陸は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ大陸の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ大陸は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ大陸は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女王イサベラ（スペイン、カスティーリャ女王イサベル一世）の援助は、思うにコロンブス（アメリカ大陸発見者）に十分な張る気を生じさせたことだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等他惑星の生物が、まだわれわれの前に現われないのは、彼等が真に存在しないのではなくて、まだコロンブスの船がアメリカ大陸に到着する前に等しく、また黒船がまだ浦賀沖へ姿を見せる前と同じ状態にあることを知るべきである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ大陸の山奥に、死の谷と呼ばれるところがあって、其処を訪ねた人間は一人として無事に帰って来たものがない。",
              "citation": {
                "source": "科学時潮",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鼠の征服者として猫を発見けた事は、アメリカ大陸の発見にも優る人生の重大事である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学生の言ふ通りに、京都の目星しい靴屋の名前を一々克明に書き取つて、最後にアメリカ大陸発見にも比べられる記録の正確さを持つて、「……年……月……日午後三時発見の事」と書き足した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七千弗５・１東京日日（夕）　アメリカ大陸の価値は七千ドルだ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉にしても、草の葉にしても、獣にしても、鳥にしても、魚にしても、また昆虫にしても同じ事で、もしか寸分ちがはないといふ、これらの二つの物を見つける事が出来たなら、それはアメリカ大陸の発見以上の発見といはなければならぬ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の例で見てもニューヨークとハリウッドではほとんどアメリカ大陸の胴の幅だけ離れているはずであるが、アメリカの現代劇はいつこうに悪くない。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発チームのスタッフはアメリカ大陸を東から西へと飛んで、カリフォルニア州モントレーのデジタルリサーチと、ワシントン州ベルビューのマイクロソフトを訪れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると泥はいつの間にかアメリカ大陸に変つてゐた。",
              "citation": {
                "source": "横須賀小景",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼コロンブスは西暦一四九二年の八月のスペインのパロス（Palos）の港から出帆して西に向ひ、同年の十月に今のアメリカ大陸の西海岸に近いキユバ（Cuba）附近に到着して、所謂新大陸を發見といふ意外の大功名を遂げたのである。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはやはり、この島がアメリカ大陸に、近いと信ずる、チリー、もしくはペリコウにおもむかんとして、ホルン岬をすぐるところの汽船はきっと、航路をこの島の東方にとって、この沖をすぎなければならないと思うのだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極は、文化の開けたヨーロッパ大陸やアメリカ大陸から近いものですから、この極地方面への探検は早くから盛んになりまして、十九世紀から二十世紀へかけて、大規模な試みが幾回となく企てられました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コロンブス時代の船だろ」「アメリカ大陸発見以前の遺物だ」「船側はもう苔むしている。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は北南アメリカ大陸に陣どり、他方はヨーロッパとアフリカの両大陸を武装し、これから喰うか喰われるかの大戦闘が始まるのではありませんか。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位置は、南アメリカ大陸を西へ越した南太平洋にある、有名な仏領タヒチ島に近いところであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給へ諸君、これによつてこれを見れば、この異様なる一大勇猛心の赴くところ、おごる平家を打ちほろぼし、易々としてアメリカ大陸を発見し、然り然り！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "未開拓時代のアメリカ大陸を描いた五部作、及び海洋文学をもって有名であり、それらの作品は少年の読物としても喜ばれている。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ大陸らしいものが見える。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「脅迫的教書」は、「ことのなりゆきでは、アメリカ大陸とヨーロッパ列強との紐帯が、断ち切られるのは遠くない」と言明している。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昌造が五歳の年、一八二八年にはアメリカ大陸にはじめて汽車がはしつたのであるし、昌造十一歳の一八三四年にはヤコビの電機モーターが發明されてゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりヨーロツパ大陸からアメリカ大陸へ活字が渡つていつてから、第二の飛躍が起つたのである。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれは原理としては、という話であって、実際に氷河の氷を、アラスカから加奈陀を通り、アメリカ大陸のあの荒漠たる沙漠を横切って、シカゴまでもってくることは、大変な難事業である。",
              "citation": {
                "source": "ウィネッカの冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "１）　Id. c. iii. p. 34, and Appen. p. 551.　　　　第四章　アメリカ・インディアンにおける人口に対する妨げについて　吾々は次に、広大なアメリカ大陸に目を転じよう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "１）　Id. tom. ix. p. 90, 142. Robertson, b. iv. p. 141.　歴史家が述べているアメリカ大陸を概観すると、人口は、各地の住民が、その現実の勤労と進歩との状態において、獲得し得る食物量と、ほとんど全く比例して、地上に拡っているように思われる。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "解決しがたい問題をも容易に解決して、事ごとにアメリカ大陸を発見でもした気になっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日の航海の後にコロンブスはトゥリニダッド島につき、次で翌日オリノコ河口に達したのであるが、このアメリカ大陸の最初の発見が、彼にとっては地上楽園の位置の推定に終ったのであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やアメリカ大陸の西に横わる大洋が未知の世界として解決を要求する。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによって南アメリカ大陸の西の限界が明白となったのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
