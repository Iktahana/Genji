    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to let things end up as they will",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あるに従うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあるに従うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあるに従うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあるに従うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあるに従うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあるに従うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあるに従うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあるに従うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあるに従うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあるに従うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあるに従うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあるに従うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あるに従うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあるに従うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "高山寺本に箸人とあるに従うべきものであろう。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
