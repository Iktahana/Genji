    "entry": "あるに従う",
    "reading": {
      "primary": "あるにしたがう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
      "ctype": null,
