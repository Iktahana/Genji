    "definitions": [
      {
        "index": 1,
        "gloss": "break in the rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨止みについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨止みという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨止みの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨止みが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨止みを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨止みについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨止みの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨止みの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨止みが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨止みという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨止みという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨止みについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨止みを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨止みは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨止みについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨止みが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨止みは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨止みの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨止みは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨止みは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夕刻雨止みて一同にて手製の食事を終りブラッデイ氏邸へキネスコープの見物に赴く。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしや、雨止みて、月出でたる也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻雨止みて一同にて手製の食事を賑々しく終へたる後、ブラツデイ氏宅へキネスコープの見物に赴く。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処にはまだ男の外にも、物乞ひらしい法師が一人、やはり雨止みを待ちわびてゐた。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この当事者と云う男は、平常私の所へ出入をする、日本橋辺のある出版｜書肆の若主人で、ふだんは用談さえすませてしまうと、※々帰ってしまうのですが、ちょうどその夜は日の暮からさっと一雨かかったので、始は雨止みを待つ心算ででも、いつになく腰を落着けたのでしょう。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨脚の強弱はともかくも、女は雨止みを待つもののごとく、静に薄暗い空を仰いでいた。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心には刹那の間、あの古ぼけた教室の玄関に、雨止みを待っていた彼女の姿が、稲妻のように閃いた。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄帝の魃を下すや、此大風雨止み、蚩尤力を失いて殺さるるに至る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって、雨止みを待つがよい」「へいへい」　長庵と、長庵を送りに立った小姓とが、山城守の言葉に甘えてお部屋へ逃げ込もうとしていると、雨は一そう激しくなって、地面を打ち、樹々を叩いて、障子にも、ポツリ、ポツリ、大粒な水のあとが滲み出している。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
