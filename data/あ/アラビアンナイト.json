        "examples": {
          "standard": [
            {
              "text": "私は毎日アラビアンナイトについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラビアンナイトの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラビアンナイトが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラビアンナイトについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラビアンナイトの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラビアンナイトが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラビアンナイトという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラビアンナイトについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラビアンナイトは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラビアンナイトが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラビアンナイトは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラビアンナイトの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラビアンナイトは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラビアンナイトは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜の顛末の物語はなんとなくアラビアンナイトを思い出させるような神秘的なロマンチックな詩に満ちたものであったが、惜しいことに細かいことを忘れてしまった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうよあたしアラビアンナイトで見たわ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供だっているかぐらいあります」「そうよ、あたしアラビアンナイトで見たわ」姉は細い銀いろの指輪をいじりながらおもしろそうにはなししていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうよ、あたしアラビアンナイトで見たわ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアンナイト物語鳴いそな鳴いそ春の鳥。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしそうなのが沢山あり、特にバートンのアラビアンナイトの原版、小画風の插画のあるキング・アーサー物語の新版がひどく興味をそそった。",
              "citation": {
                "source": "静かな日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夏耿之介氏がアラビアンナイトを訳されると云う広告を見たこともおもい出し、黒衣聖母のうしろを見たら、バートンとある。",
              "citation": {
                "source": "静かな日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼間のアラビアンナイト。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大きな廻転椅子の中からボンヤリと見上げている、小さな骸骨みたような吾輩の姿は、さながらにアラビアンナイトに出て来る魔法使いをそのままだろう…………ああ睡い。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしのアラビアンナイトというおとぎばなしなら、こうして立って壁へ向かって、何か呪文をとなえると、大きな岩が動きだして、宝のかくし場所への道がひらくんだぜ」「どんなふうにするんだい。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「ひらけゴマ」ということばで扉がひらいたのだから、あのアラビアンナイトの中の文句どおりに、「とじよゴマ」といって見たらどうだろう。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て内地から大連へやって来、この遊覧道路から大連市を見下ろした探偵小説家の甲賀三郎くんが、（僕の友人だ）大連市のことを「アラビアンナイトに出て来る幻の都会のように美しい」と讃嘆したということを伝聞したが、僕も同じ讃嘆を捧げようと思う。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年以前、この赤煉瓦の建物の中に投げ込まれたときにはあのトルコの王様の退屈を慰めたというアラビアンナイトの人喰鬼の宮殿のようにおれにはこの巨大な赤煉瓦の沈黙した建物は摩訶不思議なものであった。",
              "citation": {
                "source": "春がふたたび牢獄にやってきた！",
                "author": "陀田勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、灯に顔を反けて、泣いて居る様子です、真珠色の涙が、汚い袷に落ちて、大きい汚点を画いて行くのが、アラビアンナイトの物語から飛び出した、美しい仙女の悲嘆を見るような、不思議な悩ましさに我を焦立たせます。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第二夜　匂う踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気のいい日には伯母さんはアラビアンナイトの化けものみたいに背中にくつついてる私を背負ひだして年よりの足のつづくかぎり気にいりさうなところをつれてあるく。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、コナンドイルの The Sign of Four や、ドキンシイの Murder, Considered as one of the fine arts や、アラビアンナイトのようなお伽噺から、仏蘭西の不思議な Sexuology の本なども交っていた。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
