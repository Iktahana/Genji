        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨夜について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨夜という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨夜の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨夜が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨夜を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨夜について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨夜の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨夜の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨夜が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨夜という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨夜という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨夜についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨夜を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨夜は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨夜について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨夜が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨夜は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨夜の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨夜は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨夜は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "野も山も、此の果しなき雨夜の中へ、ふと窓を開けて、此の銀の鍋を翳したら、きらりと半輪の月と成つて二三｜尺照らすであらう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦の雨夜の茶話は今も心に残っているが、それよりも、婆さんの潮風に黒ずんだ顔よりも、垣の山吹よりも深く心に沁み込んで忘られぬものが一つある。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは雨夜の仮の宿で、毛布一枚の障壁を隔てて男女の主人公が舌戦を交える場面、もう一つは結婚式の祭壇に近づきながら肝心の花嫁の父親が花嫁に眼前の結婚解消をすすめる場面である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの一石橋の夜の御領主、名代の河童が、雨夜の影を潜めたのも、やっと五六年以来であるから。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の橘の其には似ないが、弱い、細りした、花か、空燻か、何やら薫が、たよりなげに屋根に漾うて、何うやら其の人は女性らしい。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの俳句に「綱が立って綱が噂の雨夜哉」というのがある。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蓮花池は本とドブ溜だつたが、雨夜忽ち蓮花が生じ香を放ち、又、其葉や莖を風が吹く聲を聞たと云ので、決して花が開く音を指たでなく、集成同卷に、青州府志、蓮花池在玉交里中、莽蕩無際、青萍環覆、紅碧交加、蓮蕊爭勝、爛漫如霞、然乍有乍沒、兆沂之盛衰、或疑其有靈氣云と云ると等しく云はゞ蓮の幽靈だ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一本松と、そこの一基の燈籠である――　おなじ一本松という――名所が、故郷なる金沢、卯辰山の山の端にあって、霞を絡い、霧を吸い、月影に姿を開き、雨夜のやみにも灯一つ、百万石の昔より、往来の旅人に袖をあげさせ、手を翳させたものだった、が、今はない。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の人々が雨夜の河岸を奔走して、そこか此処かと探し廻ったが、二、三日降りつづいて水嵩の増している川の面に、お節の姿は浮かびあがらなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　綱が立って綱が噂の雨夜かな――其角の句である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでは空蝉階級の女が源氏の心を引くようなこともなかったが、あの雨夜の品定めを聞いて以来好奇心はあらゆるものに動いて行った。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒な気がして、源氏は東琴（和琴に同じ）を手すさびに弾いて、「常陸には田をこそ作れ、仇心かぬとや君が山を越え、野を越え雨夜来ませる」という田舎めいた歌詞を、優美な声で歌っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝えていう、月夜雨夜にここを過ぎると、凄麗の宮女に逢うことがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の怪　後に尚書に立身した呂安老という人は、若いときに蔡州の学堂にはいっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の品定に現われた女らしい論理が、いかにもそれに相応した言葉で、畦織のように示された所を見れば、これは殆ど言文一致の文章かと察しられる。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の傘雨夜の傘蛇の目傘文福茶釜は化け茶釜お寺の釣瓶も化け釣瓶雨夜に傘さして来た。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来るなら、空襲警報も間に合わないほどの急襲をやることが出来、殊に雨夜の空襲をかけると、敵の防空隊の照空灯も届かず、聴音機も間に合わず、従って高射砲で狙い撃つ方法もなく、大いに戦果をあげることが出来ようと思う。",
              "citation": {
                "source": "成層圏飛行と私のメモ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸退治の極意を一寸こゝにお話すると、（何うか成るべく口の中で低声で読んで欲しい、さもないと狸が立聞するかも知れないから）狸はよく雨夜に出て悪戯をする。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏物語の「雨夜のしなさだめ」は、婦人の一生をみる点で紫式部がリアリストであったということを証明している。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入つて雪の降る日なぞは、雨夜のさびしさとは違つて、また別の沈静な趣がある。",
              "citation": {
                "source": "路傍の雑草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の星雨夜のお星さま　　　　かくれんぼお空に一杯　　　　かくれてるかくれてゐるなら　　　　かくれてなお顔を出すなら　　　　出してみな海から海の水　　　　かけてやる山から山の水　　　　かけてやるとほせんぼここのこの川たつた今橋がはづれたとほせんぼ御用があるなら明日おいで。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈火の前まで來ると、やつぱりそこは飮み屋だつたが、此邉からまた燒野原になつてゐると見えて、その家はバラックだつたし、家の周圍は廣々とした蓮沼のやうに、燒跡の果しない擴がりが茫つと雨夜のなかに光つて見えた。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨夜の品定めの如きも未だその全貌を尽しては居まい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
