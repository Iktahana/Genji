        "examples": {
          "standard": [
            {
              "text": "毎日、藍墨は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは藍墨が重要です。",
              "source": "幻辞"
            },
            {
              "text": "藍墨に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では藍墨が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で藍墨について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から藍墨についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では藍墨について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では藍墨が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では藍墨が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に藍墨は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において藍墨は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に藍墨を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に藍墨をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で藍墨が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、藍墨の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は藍墨を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は藍墨に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で藍墨について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から藍墨は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは藍墨を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彩色と云っても絵具は雌黄に藍墨に代赭くらいよりしかなかったが、いつか伯父が東京博覧会の土産に水彩絵具を買って来てくれた時は、嬉しくて幾晩も枕元へ置いて寝て、目が覚めるや否や大急ぎで蓋をあけて、しばしば絵具を検査した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍墨の曇りの掃毛目の見える大空から雲は剥れてまくれ立った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消え去るあとからあとから、藍墨の掃毛目の空は剥離して雲を供給する。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川沿いの町はとっぷりと暮れ、藍墨いろの家並と藍墨いろの川の面を籠めた夜霧が、咽喉に冷たく吸い込まれるほど藤紫に濃くなって来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中へ藍墨で、六文銭を描いて行ったが、濡れ手拭で拭くと、綺麗に消えるよ」「ヘエ――」「すると親分の文身はペテンだったんですね」　とガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中へ藍墨で、六文錢を描いて行つたが、濡れ手拭で拭くと、綺麗に消えるよ」「へエ――」「すると親分の文身はペテンだつたんですね」　とガラツ八。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お珊文身調べ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六万の大将は鄂煥といって、面は藍墨で塗った如く、牙に似た歯を常に唇の外に露わし、怒るときは悪鬼の如く、手に方天戟を使えば、万夫不当、雲南随一という聞えのある猛将だった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
