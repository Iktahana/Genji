      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ancient boys' hairstyle with a part down the middle and a loop above each ear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "揚巻の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「映らふ色やくれなゐの薄花桜」と歌われた三浦屋の揚巻も髭の意休に対して「慮外ながら揚巻で御座んす。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「いき」のうちには「慮外ながら揚巻で御座んす」という、曲線では表わせない峻厳なところがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十郎の遊女揚巻父押上村新兵衛が白酒売となって出る。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台が廻ると、揚巻の座敷である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文左衛門が揚巻の身受をして助六に妻せる。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚巻は初め栄三郎、後梅幸であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚巻は後の五代目歌右衛門の若盛りであるから、それも改めて説明するまでもあるまい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚巻　日清戦争頃から明治三十年前後にかけて揚巻が流行りました。",
              "citation": {
                "source": "好きな髷のことなど",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで弱ったのが揚巻太夫の静物福助だから一人ではしゃぐ助六を尻目にかけて、この不良青年を目殺してしまった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "六の二　丸髷を揚巻にかえしそのおりなどは、まだ「お嬢様、おやすくお伴いたしましょう」と見当違いの車夫に言われて、召使いの者に奥様と呼びかけられて返事にたゆとう事はなきようになれば、花嫁の心もまず少しは落ちつきて、初々しさ恥ずかしさの狭霧に朦朧とせしあたりのようすもようよう目に分たるるようになりぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚巻に結いし緑の髪には、一｜朶の山桜を葉ながらにさしはさみたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪子は風通御召の単衣に、御納戸色繻珍の丸帯して、髪は揚巻に山梔の花一輪、革色の洋傘右手につき、漏れ出づるせきを白綾のハンカチにおさえながら、　「ばあや、ちょっと行って来るよ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪子は風通御召の単衣に、御納戸色繻珍の丸帯して、髪は揚巻に山梔の花一輪、革色の洋傘右手につき、漏れ出づるせきを白綾のハンカチにおさえながら、「ばあや、ちょっと行って来るよ。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此江戸助六狂言の根元の筋は訣らず、出場人物にも異論はあるが、揚巻・助六・白酒売新兵衛の出た事だけは、確からしい。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよとなったら、あっしも少し言ってやることがあるんです」　源内が先に立って、楽屋口から頭取座の方へ行くと、瀬川菊之丞が、傾城揚巻の扮装で、頭取の横に腰を掛けて出を待っている。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の方でも手ぬかりなく』『それは万々承知の、助六は堀越が一世一代、その狂言の当りよりも、こちの揚巻さまが大当り、やんやといはせて見せまする』『ホホホホ、お前の承知も久しいもんだ。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘弥ノ助六デハ物足リナイガ、訥升ガ揚巻ヲスルト云ウノデ、ソレガドンナニ美シイカト思イ、助六ヨリモ揚巻ノ方ニ惹カレタノデアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚巻ハ先代歌右衛門、ソノ時ハマダ福助ト云ッテイタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ノ家ガ本所割下水ニアッタ時代デ、両国廣小路ノ、アレハ何ト云ッタッケナ、何トカ云ウ有名ナ絵草紙屋ノ店頭ニ助六ト意休ト揚巻ノ三枚続キノ錦絵ガ掲ゲテアッタノヲ今モ忘レナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀に角子を「あげまきからわ」と訓してあるそうで、もしかすると「からわ」また「からは」は初めには頭を意味したかもしれない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（気分をかえて）えー斧足類は蛤に蜆に牡蠣、あさり、あげまき、帆立貝、赤貝、ばか貝。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐の肴にあげまきといふ貝を供す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仏への願文を文章博士に作らせる下書きをした硯のついでに、薫は、あげまきに長き契りを結びこめ同じところに縒りも合はなん　と書いて大姫君に見せた。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげまきという貝を私は思い出した。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
