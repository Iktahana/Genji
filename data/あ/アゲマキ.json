[
  {
    "uuid": "be84428f-7c21-5ef7-b390-8325cf791d36",
    "entry": "揚巻",
    "reading": {
      "primary": "あげまき",
      "alternatives": [
        "アゲマキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
