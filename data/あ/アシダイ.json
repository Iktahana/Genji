    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "footrest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その娘は、のびにのびた生垣の下の、足台に腰かけて、厚紙でこしらえた人形の、へこんだ頬にキスをしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親や娘は、彼女等の手芸、刺繍、パッチ・ウワーク等を応用して、暇々に、新たな壁紙に似合う垂帳、クッション、足台等を拵える。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん――でもね、明日の朝までに書いてしまわなけりゃならないものがあるの」　手を執られたまま私は椅子をまわって父の足もとにあった低い足台に腰かけた。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな足台の暗い論はよして、俺の云ふ事でも、筆記して置くべしだ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が椅子を足台にして、その寝床へ這いあがると、今度は躯が床にとどきそうなほど凹んで、その重みで縫目からはみだした和毛が、部屋の四方八方へ飛び散った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝梅さんが不思議がって探り廻しだしたのに吃驚した私は二ツ重ねた足台からおっこって、階下の人を驚かせ、二階へ駈上らせた。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずそれ以前に、敷物の向う端を鋲で止め、人形の着衣から護符刀を抜いておく――そしていよいよ博士が背後を見せると、敷物の端をもたげて、縦にした部分を足台で押して速力を加えたので、敷物には皺が作られ、勿論その波はしだいに高さを加えたのです。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、背後から足台を、博士の膝膕窩に衝突させる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして火のそばにラシアの足台をもって来てそれに腰をかけて白い毛につつまれた足を二つ小さくそろえた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴磨が女の靴をみがきながら、片足を揚げた短いスカートの下から女の股間を窺くために、足台をだんだん高くさせたり、また、男と女とがカルタの勝負を試み、負ける度びに着ているものを一枚ずつぬいで行き、負けつづけた女が裸体になって、遂に危く腰のものまで取る段になって、舞台は突然暗転して別の場面になる。",
              "citation": {
                "source": "裸体談義",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクルージの姪はこの目隠し遊びの仲間には入らないで、居心地のよい片隅に大きな椅子と足台とで楽々と休息していた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクルージは、一寸の間、足台に足を載せたまま片隅に腰掛けていた彼女のことを忘れてしまったのだ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく観ぜんと思い詰めたる今頃を、わが乗れる足台は覆えされて、踵を支うるに一塵だになし。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に、こわれた紅い足台があるのを見つけて、セエラはそこに腰を下しました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その誰かは、寝衣のまま紅いショオルにくるまって、壊れた足台の上に坐っていました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラはしばらく足台の上に坐って、両手で顔をおおうていました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」セエラは跛の足台にぐたりと坐りました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラは足台を見付けて坐り、ドウナルド（ギイ・クラアレンスのこと）は皮の敷物の飾りについている虎の頭に跨っていました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして織り手の足で踏む足台に推されて、交る／″＼此の糸の半分が下りると残りの半分が上る。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い小さいカラーとカフスつきの黒い服をつけた若い女店員たちは、それぞれうけもちの婦人客の前におかれた足台に向ってひざをついて、とりかえ、ひっかえ新しい靴をためす客のあいてをしながら、忍耐づよく小間使いのように立ったり居たりしていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が、きばって帽子や靴を買おうとするとき独特ののぼせかたで、足台を前にして群れていたアメリカの婦人客は、ピネの店から姿を消していた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のきいた陳列棚、柔かい緑のビロードで張られている足台。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかった」　ひろ子は、重吉がかけている深い古い肱かけ椅子の足許に足台をひきよせてその上にかけ、鼠がかじった米袋の穴をつくろっていた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も、すぐ赤坂へ帰らなけりゃあなるまい」　伸子は、父の足許で、低い足台に腰かけ、団扇で蚊遣の煙を、あっちに煽いだりこっちへ靡かせたりしながら、ぼんやり答えた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金繍でパカパカした旗は要するに旗で、彼女が足台に必要とする一尺五寸の高さを丁度その支台が持っている時、どうしてそこへ登って悪いということがあろう。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "СССР婦人市民らしく闘志つよき彼女は何故そのように熱烈に一尺五寸の足台が欲しいのだろうか。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスは子供の時分、よくこの部屋のいつもきれいな花に飾られた窓際で、小さな足台に乗ったまま、母の足もとに坐っていた。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、灰かぶりは足台にこしかけて、おもたい木ぐつから足をぬきだして、上ぐつにいれてみました。",
              "citation": {
                "source": "灰かぶり",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "この安楽いすは、ほかのいすよりもずっとたけが高くて、そのまえには金の足台がおいてありました。",
              "citation": {
                "source": "天国へいった仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立屋さんはこれを見ますと、かんかんに腹をたてて、金の足台をひっつかむがはやいか、天国から地上のどろぼうばあさんめがけてなげつけました。",
              "citation": {
                "source": "天国へいった仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
