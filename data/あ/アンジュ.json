        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日庵主について考えている。",
              "source": "幻辞"
            },
            {
              "text": "庵主という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は庵主の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には庵主が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "庵主を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは庵主について学習した。",
              "source": "幻辞"
            },
            {
              "text": "庵主の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は庵主の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では庵主が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "庵主という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に庵主という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では庵主についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "庵主を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると庵主は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "庵主について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では庵主が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に庵主は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により庵主の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "庵主は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に庵主は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "庵主となって初めて舌で柿を味わった。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中庵主　　　　右三章　　　　　　　　　　　　　　　　　　　　山頭火しるす夜、樹明君がバリカンを持つて来て、白髪頭を理髪してくれた、ありがたい、言語同断ありがたかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十一日さすがに汽車は早い、有難い、五時にはもう其中庵主として夕食の仕度にいそがしかつた、胡瓜、茗荷、トマト、そしてイリコ、それで一杯ひつかけて寝た、手足をぞんぶんに伸ばして。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉の寝十方花庵を訪ねる、庵主不在、奥様と話しながらよばれる、酒は飲んでも飯は食べない、お嬢さんはホガラカで、しごくよろしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんが、「まあ、よく庵主さんがご承知なさったね。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主だって日本人に変わりはないわけさ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、庵主さんが、もう鐘をついてもいいとおっしゃるのをまっていて、僕らは撞木を奪いあってついたのだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主さんと、よく尼寺の世話をするお竹婆さんとが、縄をまるめてごしごしと洗った。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "和太郎さんが牛車をひいて来たとき、きゅうに庵主さんが、鐘供養をしたいといい出した。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、庵主さんがしようのない頑固者であることを知っていたからだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし庵主さんのいうことも道理であった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘供養というのは、どんなことをするのかと思っていたら、ごんごろ鐘の前に線香を立てて庵主さんがお経をあげることであった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主さんは、よそゆきの茶色のけさを着て、鐘のまえに立つと、手にもっている小さい鉦をちーんとたたいて、お経を読みはじめた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはみんな黙ってきいていたが、少したいくつになったので、お経を知っている大人達は、庵主さんといっしょに唱え出した。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と庵主さんも気の毒そうにいうと、「ああ、この頃は耳の聞こえる日と聞こえぬ日があってのオ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不知庵主人が評して不朽の戯曲家と言ひたる巣林子をもて、仮に江戸に生れしめばいかならむ、深く儒家の道徳に観得するところありて、加ふるに己れの自家の理想を以てしたる馬琴をして、難波に生れしめばいかならむ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "透谷庵主、透谷橋外の市寓に倦みて、近頃｜高輪の閑地に新庵を結べり。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主は、魚面人身、よく幻術を行のうて、存亡自在、冬、雷を起こし、夏、氷を造り、飛者を走らしめ、走者を飛ばしめるという噂である。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によると彼奴めが俺に仇を討ち終せた時が身代限りをしている時かも知れぬから見ておれ」　因に彼……杉山其日庵主は、こうした喰うか喰われるか式の相手に対して最も多くの興味を持つ事を生涯の誇りとし楽しみとしている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がすこし脱線したが、其日庵主は玄洋社を離脱してから海外貿易に着眼し、上海や香港あたりを馳けまわって具に辛酸を嘗めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に政党屋流にも堕せず、玄洋社流にも共鳴しなかった彼、杉山其日庵主は、単身｜孤往、明治後半期の政界の裡面にグングンと深入りして行った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、飛切り上等の拵附きで、刀剣道楽の大立物其日庵主が大自慢のシロモノであったが、その後、法螺丸が頭山満を訪問して、「どうだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又あったら持って来てくれい」　其日庵主もこれには少々驚いたらしい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御庵主に是非にお目にかからいでは叶わぬ用事ばしござりまして……。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御庵主、あるじの御坊……。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御庵主に物申したい。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "采女は先ず双ヶ岡を心ざして、ゆき逢う人々に問いただしながら急いでゆくと、果たしてそこの庵主から姫がたった今帰ったことを聞いた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋健三は官報局の局長室に坐している時でも従五位勲何等の局長閣下でなくて一個の処士｜自恃庵主人であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子権十郎はまたその小壺に書きつけをして、「昔年亡父孤蓬庵主小壺をもとめ、伊予すだれと名づけ、その形たとへば編笠といふものに似て、物ふりて佗し。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の庵主の婆さんはありやわしの家内の遠縁のもんですけに。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
