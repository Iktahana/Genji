        "examples": {
          "standard": [
            {
              "text": "私は毎日天の浮橋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天の浮橋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天の浮橋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天の浮橋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天の浮橋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天の浮橋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天の浮橋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天の浮橋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天の浮橋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天の浮橋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天の浮橋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天の浮橋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天の浮橋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天の浮橋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その天空に浮遊するかの如き、嶮にして美なる林道を「天の浮橋」と呼ぶそうであるが、何よりも喬木林の陰森さにおどろかされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本書紀」には、「伊弉諾尊、伊弉冉尊、天の浮橋の上に立たして、共に計りて、底つ下に国や無からんとのり給ひて、廼ち天の瓊矛を指しおろして、滄海を探ぐりしかば是に獲き。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでお二人は、さっそく、天の浮橋という、雲の中に浮かんでいる橋の上へお出ましになって、いただいた矛でもって、下のとろとろしているところをかきまわして、さっとお引きあげになりますと、その矛の刃先についた潮水が、ぽたぽたと下へおちて、それが固まって一つの小さな島になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし天の浮橋の上までおいでになって、そこからお見おろしになりますと、下では勢いの強い神たちが、てんでんに暴れまわって、大さわぎをしているのが見えました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の浮橋とて、老木の一幹は立ち、他の一幹は横になりて、瓢箪池の中央に自然の橋を爲し、彼方にて起つ。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "木橋あり、天の浮橋といふ。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い高い尖塔が空にそびえており、橋梁はまるで神業のように、全然脚柱というものなしに架っている、つまり＊５セミラミーダの天の浮橋そっくりなんですよ、君！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に『古事記』の開巻第一の条に諾冊二神、此漂える国を修理せよとの、天神に詔に従い、天の浮橋に立ちて天神の賜いし矛を下して、海水を書き鳴して引上げしに、矛の末より滴る塩積りて淤能碁呂島となりしとの記事あり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ二柱の神、天の浮橋三に立たして、その沼矛を指し下して畫きたまひ、鹽こをろこをろに畫き鳴して四、引き上げたまひし時に、その矛の末より滴る鹽の積りて成れる島は、淤能碁呂島五なり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに天の忍穗耳の命、天の浮橋に立たして詔りたまひしく、「豐葦原の千秋の長五百秋の水穗の國は、いたくさやぎてありなり二」と告りたまひて、更に還り上りて、天照らす大御神にまをしたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれここに天の日子番の邇邇藝の命、天の石位を離れ、天の八重多那雲を押し分けて、稜威の道別き道別きて一〇、天の浮橋に、浮きじまり、そりたたして一一、竺紫の日向の高千穗の靈じふる峰一二に天降りましき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の浮橋の上にて、山の神千二百生れたまふ也。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
