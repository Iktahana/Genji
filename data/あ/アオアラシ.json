    "definitions": [
      {
        "index": 1,
        "gloss": "wind blowing through fresh verdure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "水の面には、生の動揺といった象が見えている中に、これはまた青嵐も吹かば吹け、碧瑠璃のさざれ石の間に介まって、黙んまりとした｜死の静粛！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあね」　ふと鳴って通った庭樹の青嵐を振返ってから、柚木のがっしりした腕を把った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青嵐する波の彼方に、荘厳なること仏のごとく、端麗なること美人に似たり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山　荘　　　　　　一　簿記台のなかから、手紙を取り出してみると、それは加世子から均平に宛てたもので、富士見の青嵐荘にてとしてあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子はここを通過して、上諏訪で宿を取ることにしてあったので、均平は独りで青嵐荘へと車を命じた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "青嵐荘は町筋を少し離れた処にあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼつぼつ話しながら、二人は青嵐荘近くまで来ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山荘一　簿記台のなかから、手紙を取り出してみると、それは加世子から均平に宛てたもので、富士見の青嵐荘にてとしてあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉が中に埋もれ玉へる御境涯を想ひやりては、小生も何となう青嵐に胸吹き払はるゝ心地いたし候。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで、最早や安蘇山群の青嵐が家々の軒に吹き寄せている佐野の町にも行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送演説の名人といわれていた故永田青嵐ですら、いつ聴いても「私は砕けて喋っていますよ」といった同じ調子が見え透いてうんざりさせられるし、この人を真似た某大官の演説は、砕けすぎて気を許したのか、お国言葉の東北弁まるだしだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしや未生以前の青嵐（昭和十年七月、渋柿）曙町より（二十六）　風呂桶から出て胸のあたりを流していたら左の腕に何かしら細長いものがかすかにさわるようなかゆみを感じた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとん着て寝た姿の東山、清水からは霞が降って、花には遅いがそれゆえにまた程よく程のよい青嵐の嵐山。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "野から山へと青嵐をわけて歩いて行く藤母子の姿が今しもはつきりと二人の眼に映つて見えた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の題目を以てこれを例せんに夏山　夏野　夏木立　青嵐　五月雨　雲の峰　秋風　野分　霧　稲妻　天の河　星月夜　刈田　凩　冬枯　冬木立　枯野　雪　時雨　鯨　等はその壮大なる者なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――魚売の声よそにふけ青嵐――これは也有翁の閑居吟であるが、私の場では、豆腐屋のラツパも寄らない青葉若葉である、呵々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴客はまだ何処にも輻湊していなかったし、途々見える貸別荘の門なども大方は閉っていて、松が六月の陽炎に蒼々と繁り、道ぞいの流れの向うに裾をひいている山には濃い青嵐が煙ってみえた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しく晴れ渡りたる空の青嵐を踏へながら山を下れば藪原の驛なり。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "青嵐が吹き靡いている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この途端、青嵐というには余りに凄かった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏のセエヌ河の明るい水の上を青嵐に吹かれて巴里へ入つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の翠りもよいし、渓流のせせらぎ、朝の青嵐もよいが、感覚的に愉しいのは、この鮎の匂ひを川から嗅ぐ時だ。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
