        "examples": {
          "standard": [
            {
              "text": "私は毎日アルカンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルカンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルカンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルカンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルカンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルカンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルカンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルカンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルカンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルカンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルカンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルカンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルカンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルカンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルカンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルカンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルカンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルカンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルカンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルカンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "フランスあたりの本屋にしても、こんな本は多分アシェットから出ているだろう、恐らくアルカンから出ているだろうと見当がつくぐらいである。",
              "citation": {
                "source": "書物の倫理",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部下は大抵｜露西亜人、猶太人、支那人、印度人、伊太利人、その他、ケンタッキー、アルカンサス等の南部｜亜米利加人で日本人は極く少数しか居りません。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大航空母艦レキシントン、アルカンター、シルバニアの飛行甲板を、蜂の巣のように、孔をあけてやりたい」「ウフ、それが大したことでなくて、何が大したことなんだ、あッはッはッ」「うわッはッはッ」　聞いていた二人の士官が、腹を抱えて笑い出した。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地わるの男がアルカンなどときまっていて、ピエロはコロンビーヌにベタ惚れなのだがふられ通しで、色恋に限らず、何でもやることがドジで星のめぐり合せが悪くて、年百年中わが身の運命のつたなさを嘆いているのである。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエロや、アルカンや、コロンビーヌや、ジャンダルムが活躍し、スガナレルやフィガロが登場しても、これほどの因果モノ的ナンセンスを生みだすことはできなかったのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地わるの男がアルカンなどときまつてゐて、ピエロはコロンビーヌにベタ惚れなのだがふられ通しで、色恋に限らず、何でもやることがドヂで星のめぐり合せが悪くて、年百年中わが身の運命のつたなさを嘆いてゐるのである。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして打たるコイラノス、アラストールと＊クロミオス、アルカンドロス、ハリオスとノエーモーンとプリュタニス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がモンテーニュにのめり込んだのは何年だったかはっきりしないが、勉強のつもりでアルカン版「エセー」を取り寄せ翻訳にかかったのは大正最後の年だったと記憶するから、私とモンテーニュとの付き合いは今や六十年になんなんとする。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
