    "definitions": [
      {
        "index": 1,
        "gloss": "light (esp. as a religious offering)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自転車の前の、ランプが灯つた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの垣根萩原朔太郎からたちの垣根の中に女のはしやぐ聲のする夕餉の葱のにほひする灯ともしごろからたちの垣根を過ぐる侘しさよ。",
              "citation": {
                "source": "からたちの垣根",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩アパート三階の便所に行くと、新宿の百貨店や何かの電燈広告が五六町ばかりの向ふに灯つてゐて、まるでほんとかと云ひたくなる。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな田舍臭い百姓歌の主人公が、灯ともし頃に羽織をきて、新宿の宿場を漂泊して居るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん薄暗くなって色々の灯でいろどられてゆく上野広小路の雑沓の様子を見おろしていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の燈やゆかしき奈良の道具市　秋の日の暮れかかる灯ともし頃、奈良の古都の街はずれに、骨董など売る道具市が立ち、店々の暗い軒には、はや宵の燈火が淡く灯っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良という侘しい古都に、薄暗い古道具屋の並んだ場末を考えるだけで寂しいのに、秋の薄暮の灯ともし頃、宵の燈火の黄色い光をイメージすると、一層情趣が侘しくなり、心の古い故郷に思慕する、或る種の切ないノスタルジアを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに山の霧が多いので、いつも水蒸気で町の軒灯が紅色にかすんで、一層山間都市の華やかな感じを深める。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の溝を流れる湯の匂ひや、朧ろにかすむ紅色の軒灯や、枕に近い湯滝の音やが、何とも言へぬ春らしい感じを起させる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵の酒宴の可笑しさよ娘が運ぶ瓶子よりもるる灯影にかしこまる左右の破顏を反り見て七兵衞獨り忻忻たり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しきり襲い来る雨の足に座敷からさす灯が映えて、庭は金糸の光に満つる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風は店の灯を吹き、軒に吊した籠や箒やランプの笠を吹き、見て過ぐる自分の胸にも吹き入る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪の街燈には今でもやもりが居るが、元のような空想はもう起らぬ、小さな細長い黒影は平和な灯影に眠っているように思われるのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上等がかえると御てらしが消えて御神燈の灯がバチバチと鳴る。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金谷の隧道長くて灯を点したる、これは昔蛇の住みし穴かと云いししれ者の事など思い出す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洲崎の灯影長うして江水｜漣※清く、電燈｜煌として列車長きプラットフォームに入れば吐き出す人波。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕快に喉をくすぐりながら通過して、體内にぽつと灯りがともつたやうな嬉しい氣持になる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店々に灯がついて、灯がついて、私がそれをみながら歩いてゐると、　　おまへが声をかけるのだ、どつかにはひつて憩みませうよと。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、乳色の、磨硝子の靄を通して灯を見るように、監獄の厚い壁を通して、雑音から街の地理を感得するように、彼の頭の中に、少年が不可解な光を投げた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その運河の汚ない濁った溜水にその向うの大きな工場の灯が、美しく映っていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の話であるが、『藪柑子集』中の「嵐」という小品の中に、港内に碇泊している船の帆柱に青い火が灯っているという意味のことを書いてあるのに対して、船舶の燈火に関する取締規則を詳しく調べた結果、本文のごとき場合は有り得ないという結論に達したから訂正したらいいだろうと云ってよこした人があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の廊下から見上げた山腹の各旅館の、明るく灯のともつた室々の障子の列が上へ上へと暗い夜空の上に累積してゐる光景は、龍宮城のやうに、蜃氣樓のやうに、又ニユーヨークの摩天樓街のやうにも思はれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円筒の外線には小さいアーク灯があって強い一条の光線を送り、写真の膜を通じて筒中のセレニウムを照らす。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信機の方ではこの電流を受けて小さい電灯に通じ、その明滅する光線の一条をば発信機のと同じような円筒に巻きつけて廻転する写真の膜に投ぜしむる。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年八月三十日『東京朝日新聞』）発電所は難破船　メキシコの南隣グァテマラの西海岸の一小市で近頃電灯を点ずるようになったが、その中央発電所は同市の海岸近くに坐洲したドイツの汽船である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラの頬は、まるで熟した苹果のあかしのやうにうつくしくかゞやいて見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の第二限ころなんか、なぜ燈台の灯を、規則以外に間〔一字分空白〕させるかって、あっちからもこっちからも、電話で故障が来ましたが、なあに、こっちがやるんぢゃなくて、渡り鳥どもが、まっ黒にかたまって、あかしの前を通るのですから仕方ありませんや。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人がそのあかしの前を通って行くときはその小さな豆いろの火はちゃうど挨拶でもするやうにぽかっと消え二人が過ぎて行くときまた点くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
