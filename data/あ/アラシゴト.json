        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒仕事について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒仕事の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒仕事が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒仕事について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒仕事の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒仕事が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒仕事という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒仕事についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒仕事は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒仕事が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒仕事は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒仕事の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒仕事は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒仕事は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "殺伐な荒仕事は彼の荒んだ感情を慰めた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "測量部の測夫たちは多年こうした仕事に慣れ切っていて、一方では強力人夫の荒仕事もすると同時にまた一方ではまめやかな主婦のいとなみもするのである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なじょして、この辺の男達よりも、もっと荒仕事しさせられんのだもの、新田の方では。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒仕事に出る男の持ち物にしては妙だ、殊に懐にしまいようがない。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手が柔らかくお上品にできて居りましたから、畑を耕したり、荒仕事ができません、そのかはり針仕事をしたりお料理をしたりすることが、たいへん上手でした、トムさんはまた、一粒の豆でも半分に分けて喰べるやうに、仲善くしましたので、お嫁さんも満足をいたしました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今まで、ずいぶん身を持ち崩していたものですから、そうした荒仕事には堪えなかったと見え、二年ばかり経つと、風邪か何かがもとで、ぽっきり枯枝が折れるように、亡くなってしまったのです。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、ああいうふうのが中肉｜中背と申そうが、娑婆にいたときはよほどの荒仕事に従事いたしおったとみえて、骨格なぞは珍しいくらいがんじょうでござったわい」「年は？",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人のあがり方がちっと手間がとれているんで、そこにつけ込み同じ手口のように見せかけて、てめえらの荒仕事もその罪跡を塗りつけようとたくらんでからの切り取り強盗にちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、きのうきょうののど笛騒動が長引いているんで、それにつけ込んでの荒仕事やったんだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ谷で今またふたりも似通った手口の死骸が見つかったというからにゃ、おそらく四、五人の仲間があってひとかせぎしてやろうと、おたげえ手をつなぎながら荒仕事やっているにちげえあるめえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の三角も両方から板でせって鼻筋をこしらえ小鼻は丸太でふくらみをこしらえる……という風に、一々仏の形のきまりを大｜握みに掴んでこしらえていかせるのですが、兄貴の大工さんも、差し金を持って見込みの仕事をするのならなんでも出来るが、こんな突飛な大仕掛けな荒仕事となると一向見当がつきません。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小説家はこれまでいろんな荒仕事をして来たらしい、巌丈な両肩を揺ぶりながら笑つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最終戦争は、どこまでも統一に入るための荒仕事であって、八紘一宇の発展と完成は武力によらず、正しい平和的手段によるべきである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそんな荒仕事がどうかすると寧ろ彼女に適しているようにすら思われた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の三角も両方から板でせって鼻筋を拵え小鼻は丸太でふくらみをこしらえる……という風に、一々仏の形のきまりを大握みに掴んで拵えて行かせるのですが、兄貴の大工さんも、差し金を持って見込みの仕事をするのなら何んでも出来るが、こんな突飛な大仕掛けな荒仕事となると一向見当が附きません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "』（註）Fair Hands とは手の美しうて荒仕事に堪へぬ謂はゞ役に立たずの義なり。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、田圃や畑の荒仕事を嫌いますので、よく留守番をさせましたが、私の家は門の処から町並では御座いますし、出入りもかなりに多い方で御座いましたから、別に可怪気ない事を仕出かして出て行ったものとも思われませぬ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様等みたいな青二才におじけて俺の荒仕事が出来ると思うか。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年のとき荒仕事ばかりして、冬になるとの切口を縫て熱油を滴らして手療治をして居た事を覚えて居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな荒仕事にはとても向かない人間ですよ」　大柄ではあるが、ゆったり椅子に靠れてそう云っている慎一の眼差しのなかには、思慮のこまやかさと心の平らかさを語る艶が籠っていた。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと性格なんてものだって、使用価値からだけ見えているんだろうな」　二度目の今夜の話は、鴻造としたならば、荒仕事には向かないと云った慎一の言葉に沿うた提案というわけであったろう。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の山男の為し得ない荒仕事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らは荒仕事をやるし、ぶらんこ往生覚悟の仕事をやるが、闘鶏みてえに贅沢に飲み食いする。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "木田やヘルメットの鼻ヒゲばかりぢやない、人間といふ人間どもをみんな殺して木にブラ下げてやりたいのだから、ピストル強盗などといふチンピラ共の荒仕事とは違つて沈鬱である。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "住田嘉久馬にでも頼まれて荒仕事をやったのかとボクもつい思ったのだが」「話がアベコベなんですよ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルトルの悪略、荒仕事、教えてやりたいのは山々だが、それが言えない、つらさ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな働くと申しても、皆さんの力が平均しているわけではありませんから、誰も彼も鍬を取り、鎌を振って、荒仕事ができるものではありません、女子供はましてそうですが、力の足らぬもの、経験の乏しいものは、見よう見まねに、仕事の成績には関係せず、努めてやってみようという心がけが大切です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
