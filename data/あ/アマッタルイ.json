[
  {
    "uuid": "82d77e6d-e5cc-5b0d-890f-7a2ccab1fadf",
    "entry": "甘ったるい",
    "reading": {
      "primary": "あまったるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sentimental",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘ったるいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘ったるいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘ったるいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘ったるいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘ったるいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘ったるいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘ったるいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘ったるいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘ったるいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘ったるいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘ったるいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘ったるいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったるいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘ったるいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかるに、「あまっちょ」「甘ったるい物の言い方」「甘い文学」などいう場合には、甘味によって明らかに反価値性が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「いき」のうちの「意気地」や「諦め」が存在を失って、砂糖のような甘ったるい甘味のみが「甘口」な人間の特徴として残るのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の味もやはり甘ったるい、しつっこい、安香水のような香のするものであったような気がする。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客や病人の眼に触れ過ぎて甘ったるいポートワインのようになってしまった海ではない。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「されば、」梟の大将はみんなの方に向いてまるで黒砂糖のような甘ったるい声でうたいました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様はまん丸くて甘ったるいばかりで何にもならないじゃないか。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ最早帰りましょうよ、母上さんが待っているから」と甘ったるい声。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その甘ったるい夕方の夢のなかで、わたくしはまだあの茶いろななめらかな昆布の干された、イーハトーヴォの岩礁の間を小舟に乗って漕ぎまわっていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、あいつの歌なら、あの甘ったるい歌なら、さっきから光の中に溶けていましたがひばりはまさか溶けますまい。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯の浮くような、甘ったるいラヴシーンで、凡そくだらない一幕だった上に、現代劇だというのに、新内流しの下座がはいっていて、いつもの信吉なら、そのチグハグさに腹を立てるか、噴き出した筈だ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、彼を手なずけるため、まず、顔に偽クリスチャンのような「優しい」媚笑を湛え、首を三十度くらい左に曲げて、彼の小さい肩を軽く抱き、そうして猫撫で声に似た甘ったるい声で、彼を自分の寄宿している家に遊びに来るようしばしば誘いましたが、彼は、いつも、ぼんやりした眼つきをして、黙っていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、この白樺の幹の蔭に、雀を狙う黒い猫みたいに全身緊張させて構えている男の心境も、所詮は、初老の甘ったるい割り切れない「恋情」と、身中の虫、芸術家としての「虚栄」との葛藤である、と私には考えられるのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、作者の愛着は、また自ら別のものらしく、私は時折、その甘ったるい創作集を、こっそり机上に開いて読んでいる事もあるのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの感激的高調にかかわらず、すべての出来るだけの無内容と、できるだけの愚劣な馬鹿馬鹿しさとで、民衆の甘ったるい理解力に訴えるべく、用意を十分に備えている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスの女流詩人のなんだか、ひどく甘ったるい大時代の作品を、ポローニヤスが見つけて来て、これを台本にして三人で朗読劇をやろうと言い出す始末なのだから恐れいる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、いったい、なんだってあんな子守っ子だって笑ってしまうような甘ったるい芝居を、年甲斐もなくはじめる気になったのですか。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛などと言うと、甘ったるいもののようにお考えかも知れませんが、むずかしいものですよ。",
              "citation": {
                "source": "一問一答",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤコブ、ヨハネ、アンデレ、トマス、痴の集り、ぞろぞろあの人について歩いて、脊筋が寒くなるような、甘ったるいお世辞を申し、天国だなんて馬鹿げたことを夢中で信じて熱狂し、その天国が近づいたなら、あいつらみんな右大臣、左大臣にでもなるつもりなのか、馬鹿な奴らだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人の癖に、愛だの、理解だのって、甘ったるい事ばかり言って子供の機嫌をとっているじゃないか。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、またもや甘ったるい事を言いました。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥で帰ると、追分で一生の道が南北へ分れるのを、ほんとうに一呼吸という処で、不思議な縁で……どうも言う事が甘ったるいが、どうもどうも、腹の底まで汁粉に化けた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのと呆けて無邪気を装う様子には何となく灰汁ぬけした甘ったるいものがあって、「そら、また、おばさんの食い辛棒が始まった」　と苦笑しながらも誰かゞ奢ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を注ぎながら、上さんは甘ったるい調子で云った、「でも営口で内に置いていた、あの子には、小川さんも※わなかったわね。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、そんな、あまったるい通俗小説じみた、――腹立たしくさえなって、嘉七は、てのひらから溢れるほどの錠剤を泉の水で、ぐっ、ぐっとのんだ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お敬ちゃんはすぐに言葉をついで、「お化粧のしっこをしましょうネ、それがいいワ、ネエ」　こんな事を云って、あまったるい好い香りのするものや、ヒヤッとした肌ざわりの、それで居てたまらなく好い気持のものをぬられたりして変って行く自分のかおを目をつぶったまんま想像した。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マア」私はこう云わずには居られないほどきれいにあまったるい様なかおになって居る。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ屋根の下に暮して居りますものを……どうぞも少し御うちとけなさって下さいな」　あまったるい声で云う。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私しゃ心から御前に惚れてるんだろうか、それでなけりゃあいつでも私はにげられるはずだ」「そんな事どうだってようござんすわ、私の体からしみだすあまったるいどくにあんたはよっぱらって身うごきが出来ないんです。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日男はたまらないほどあまったるい気持になって家に帰った。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまったるい香りがただよって居るおだやかな景色。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
