    "definitions": [
      {
        "index": 1,
        "gloss": "early in the morning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早くの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昼間は落付かないし、出掛けてもさして面白くないので、私には朝早く起きることは大変時間の損失なのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたにしませう、ね、あしたの朝早く。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはあさっての朝早く、鳥のうちを一｜軒ずつまわって、お前が来たかどうかを聞いてあるく。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはあさっての朝早く、鳥のうちを一軒ずつまわって、お前が来たかどうかを聞いてあるく。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、九月の末のある日曜でしたが、朝早く私が慶次郎をさそっていつものように野原の入口にかかりましたら、一本の白い立札がみちばたの栗の木の前に出ていました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝早く私は実習を掲示する黒板にこう書いておきました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山にまします女神だち歌のわく子にさちあらせたまへ翌日朝早く案内者一人｜召し具し二人きおいにきおいて滝壺に下る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の十六日に朝早くお松が年頭に来た時に、自分の喜んだ様子ったら無かったそうである。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るならば暮の内に学校へ帰ってしまいたかったけれど、そうもならないでようやくこらえて、年を越し元日一日置いて二日の日には朝早く学校へ立ってしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へばまた、彼はかつて僕の敍情詩「郷土望景詩」に感激し、朝早く寢衣のままで家を飛び出した。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ァ帰るのが厭になった」　「兄さん、今夜はゆっくり休んで、明日の朝早くお立ちなさいよ……ね」　「いや、矢張り今夜立つよ」　七五郎が、　「石松、話があるンだ」　「改まって、どうしたんだい」　「いや、お前のきっと喜ぶ事だ」　「俺の喜ぶ事って？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎は三次に、Ｔ「近頃決って朝早く出て行くが」　と言って、ウサン臭そうに、Ｔ「毎朝毎朝一体何処へ行くんだい？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は、朝早くから窓一ぱいの光線が差込む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日朝早く妹のアガアテが部屋に這入って参って、にっこり笑うのでございます。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は朝早く眼が覚めた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くから、晩におそくまで田畑で働き、夜は、欠かさず夜なべをした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、ある朝早く、両人は出かけた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日には、なな草のあえもの、十五日には朝早くとんどをして茅の箸で小豆粥を食べる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言いますと、あの時分は私も朝早くから起きて寝るまで、学校の課業のほかに、やたらむしょうに読書したものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで驚いたのは、田口に移った日の翌日、朝早く起きて散歩に出ようとすると、城山で会った子供が庭を掃いていたことです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉蔵もうお寝よ、朝早く起きてお復習いな。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は朝早く弟と共に草鞋脚絆で元気よく熊本を出発った。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の初めと記憶しているが僕は朝早く旅宿を出て汽船の来るのは午後と聞いたのでこの港の浜や町を散歩した。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七｜里の途はたゞ山ばかり、坂あり、谷あり、溪流あり、淵あり、瀧あり、村落あり、兒童あり、林あり、森あり、寄宿舍の門を朝早く出て日の暮に家に着くまでの間、自分は此等の形、色、光、趣きを如何いふ風に畫いたら、自分の心を夢のやうに鎖ざして居る謎を解くことが出來るかと、それのみに心を奪られて歩いた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七里の途はただ山ばかり、坂あり、谷あり、渓流あり、淵あり、滝あり、村落あり、児童あり、林あり、森あり、寄宿舎の門を朝早く出て日の暮に家に着くまでの間、自分はこれらの形、色、光、趣きを如何いう風に画いたら、自分の心を夢のように鎖ざしている謎を解くことが出来るかと、それのみに心を奪られて歩いた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝早く起きいでて源叔父は紀州に朝飯たべさせ自分は頭重く口｜渇きて堪えがたしと水のみ飲みて何も食わざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛夏の朝早く「ええ朝顔やあさがお」と呼び歩くのは去年も聞いた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつ一人ぎりか、ほかに連れはねえのか」「もう一人いるそうですが、そいつは今朝早くから山の手の方に商売に出たそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は遲く歸つたので、をぢさんは明日の朝早く起きるのが辛かつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　まいにち　あさはやく　――　だれも　おきないうちに　――　もぐもぐハンカは　ちりとりと　ほうきを　もってきて　ドールハウスの　おそうじを　するのでした。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
