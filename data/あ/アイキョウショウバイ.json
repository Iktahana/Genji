    "definitions": [
      {
        "index": 1,
        "gloss": "occupation where charm is necessary to succeed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
