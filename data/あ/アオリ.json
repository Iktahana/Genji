    "definitions": [
      {
        "index": 1,
        "gloss": "gust (of wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その無名氏なるものがカイザー・ウィルヘルム二世であることが誰にも想像されるようにペンク一流の婉曲なる修辞法を用いて一座の興味を煽り立てた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪牙船の製は既に詳しく知りがたく、小蒸気の煽りのみいたづらに烈しき今日、遊子の旧情やがては詩人の想像にも上らざるに至るべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大煽りに煽ったのは秀吉であった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北野の大茶の湯なんて、馬鹿気たことでもなく、不風流の事でもないか知らぬが、一方から観れば天下を茶の煙りに巻いて、大煽りに煽ったもので、高慢競争をさせたようなものだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日一日で仕事が打切りになると云う事も、一つの大なる期待ではあったが、軈て現われ来るべき大事件は若い好奇心と敵愾心とを極端に煽り立てて、私は勇士を乘せて戦場に駆け出そうとする牡馬の様に、暗闇の中で眼を輝かした。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に残って、砂地に独り峡の婆、件の手を腰に極めて、傾がりながら、片手を前へ、斜めに一煽り、ハタと煽ると、雨戸はおのずからキリキリと動いて閉った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、立騰り、煽り亂れる蚊遣の勢を、ものの數ともしない工合は、自若として火山の燒石を獨り歩行く、脚の赤い蟻のやう、と譬喩を思ふも、あゝ、蒸熱くて夜が寢られぬ。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が、おのれ、何が、ほうほう……（再び太刀を抜き、片手に幣を振り、飛より、煽りかかる人々を激しくなぎ払い打ち払う間、やがて惑乱し次第に昏迷して――ほうほう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に二三尺あとへ引いて、薄波を一｜煽り、その形に煽るや否や、人の立つごとく、空へ大なる魚が飛んだ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――馬だ――馬だ――馬だ――　遠く叫んだ、声が響いて、小さな船は舳を煽り、漁夫は手を挙げた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻を掴えそうな慌て方で、ざぶざぶ真中で追かける、人の煽りで、水が動いて、手毬は一つくるりと廻った。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あッと顔を背ける機に、冷い空気の煽りを受けて、頼みの蝋燭はふッと消えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "オング君は、一昔前と変らぬリボンをネクタイに結んだ懐しい姿で、赤ラベルの安｜三鞭酒を煽りながら、私に呼びかけたのである。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな人生に消極的な気持ちのあなたが僕のような煮え切らない青年に、英雄的な勇気を煽り立てるなんてあなたにそんな資格はありませんね」　復一は何にとも知れない怒りを覚えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大煽りに煽つたのは秀吉で有つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北野の大茶の湯なんて、馬鹿気たことでも無く、不風流の事でも無いか知らぬが、一方から観れば天下を茶の煙りに巻いて、大煽りに煽つたもので、高慢競争をさせたやうなものだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、嬢｜様と聞くと斉しく、朝から台所で冷酒のぐい煽り、魚屋と茶碗を合わせた、その挙動魔のごときが、立処に影を潜めた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの事に茫となって、その時座を避けようとする、道子の帯の結目を、引断れよ、と引いたので、横ざまに倒れた裳の煽り、乳のあたりから波打って、炎に燃えつと見えたのは、膚の雪に映る火をわずかに襦袢に隔てたのであった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は叫ばむとするに声｜出でず、蹶起きて逃げむと急るに、磐石一座夜着を圧して、身動きさへも得ならねば、我あることを気取らるまじと、愚や一縷の鼻息だもせず、心中に仏の御名を唱へながら、戦く手足は夜着を煽りて、波の如くに揺らめいたり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煽りもせぬのに気が立って、颯と火の上る松明より、紅に燃立つばかり、緋の紋縮緬の長襦袢が半身に流れました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思出す、あの……五十段ずつ七折ばかり、繋いで掛け、雲の桟に似た石段を――麓の旅籠屋で、かき玉の椀に、きざみ昆布のつくだ煮か、それはいい、あろう事か、朝酒を煽りつけた勢で、通しの夜汽車で、疲れたのを顧みず――時も八月、極暑に、矢声を掛けて駆昇った事がある。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、由来｜宿業として情と仇と手のうらかえす雪女郎は、東雲の頃の極寒に、その気色たちまち変って、拳を上げて、戸を煽り、廂を鼓き、褄を飛ばして棟を蹴た。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――割つて通つた人間の袖の煽りに、よた／＼と皆左右に散つた、中には廻廊に倒れかゝつて、もぞ／＼と動くのもある。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、自分に此の天守の主人から、手間賃の前借をして居つて、其の借を返す羽目を、投遣りに怠惰を遣り、格合な折から、少いものを煽り立つて、身代りに働かせやう気かも計られぬ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この煽りに、婆さんが座右の火鉢の火の、先刻からじょうに成果てたのが、真白にぱっと散って、女の黒髪にも婆さんの袖にもちらちらと懸ったが、直ぐに色も分かず日は暮れたのである。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』熊野の烏夜は深し、熊野の烏旅籠の戸かたと過ぐ、一瞬時、――燈火青に閨を蔽ふかぐろの翼煽り搏つ羽うらを透かし消えぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、妻に相談すると、連れはいいし、またとない好機会だから是非行らしったがいいと、しきりに煽り立てた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』骸骨は珍らしき物語を聞き、『君語れ、またさらに語れ、我等はもと酒煽り、婦女子を捉へ辱めしが、いま無欲なる骸骨となりては、徒にそを悔い居るなり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "朔風は焔を煽り、真昼の空の下に白っぽく輝きを失った火は、すさまじい速さで漢軍に迫る。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……煽り留めとでも申しましょうか。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
