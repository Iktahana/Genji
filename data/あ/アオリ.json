        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "庭石の根締めになっていたやしおの躑躅が石を運び去られたあとの穴の側に半面、黝く枯れて火のあおりのあとを残しながら、半面に白い花をつけている。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、もう一つ指摘するならば、一九三〇年頃より「日米若し戦はゞ」とか「米国恐るゝに足らず」とか云った日米戦争未来記が市場に洪水している如く、日露戦争前にあっては、日露戦争未来記が簇出して、いやが上にも敵愾心をあおり立てゝいたことである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨酷な情報で、群衆の熱情をあおり立てる、その沸騰する有様を、夢中に想像していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは、隊長は隊長で、その功名心に、また、もうひとつ上からあおりをかけられているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、冬のモンスーンは火事をあおり、春の不連続線は山火事をたきつけ、夏の山水美はまさしく雷雨の醸成に適し、秋の野分は稲の花時刈り入れ時をねらって来るようである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう不安をさらにあおり立てでもするように、ことしになってからいろいろの天変地異が踵を次いでわが国土を襲い、そうしておびただしい人命と財産を奪ったように見える。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただやたらにコップ酒をあおり、そうして、おもに、おでんやのおかみや女中を相手におしゃべりした。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リンカーン伝」でよびさまされた自分の中のあるものがユーゴーの「ミゼラブル」でいっそう強くあおり立てられたようである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）画工　（あおりたる児の手を離るると同時に、大手を開いて）こうなりゃ凧絵だ、提灯屋だ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と君は、その日、上野公園の茶屋でさかんにウィスキイをあおりながら、「僕は、はじめから、あの人を好きだったのですよ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなはけ口のない情慾を紛らすために、僕らは牛肉屋へ行って酒をあおり、肉を手掴みにして壁に投げつけたり、デタラメの詩吟を唄って、往来を大声で怒鳴り歩いたりした。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあらゆる最高の手段に於て、民衆の倫理感をあおり立てる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはジャネットの肉体的にも遊び廻るほど愈々冴えて来る若さを一層強く示嗾して新吉をあおりたてることに努める必要があると思った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微風も一繊雲もないのに、ゆらゆらとその潮が動くと、水面に近く、颯と黄薔薇のあおりを打った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立てば槍烏賊、坐れば真烏賊、動く処は、あおり烏賊、と拍子にかかると、また似たものが外にあった。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は新聞の記事にあおりたてられた物見高い人々が、五年目の再会の模様を見ようと、天王寺へお詣りがてら来ているのだと判ると、きゅうに自分のみすぼらしい――新聞に書かれた出世双六などという言葉におよそ似つかぬ姿を恥じて、穴あらばはいりたい気持とはこのことかと思った。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と片手を仰山にうち振ると、それからまた麦酒をグッとひとあおりだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は幾分かずつ小降りになるようであるが、波のあおりはいよいよ激しくなるばかしである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしく羽織を一あおりするとぱたりと畳に落ちた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、人びとがあちこちとはしりまわると、そのあおりかぜで、のこらずのすずがなりひびいて、じぶんのこえもきこえないほどでした。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、避雷針をはなし、足をしっかり壁にかけて踏んばり、思いきってそれを蹴ると、鎧戸はあおりをくってばっとしまるだろう。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番乗りの火がかりは、水はなし、続く者なし、火の玉は突立ったり、この時、戸が開いたのと、人あおりで、それまで、火で描いた遠見の山のようだった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界恐慌のあおりを受けて日本が昭和恐慌に見舞われ、農産物の価格が特に大きく下落したこの時期、農村は疲弊を極めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウッカリするとウォーニンのあおりを食って、海へ飛んで行かねばならなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニセコアンの丘陵の裂け目からまっしぐらにこの高原の畑地を目がけて吹きおろして来る風は、割合に粒の大きい軽やかな初冬の雪片をあおり立てあおり立て横ざまに舞い飛ばした。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然が粉雪をあおりたてて、所きらわずたたきつけながら、のたうち回ってうめき叫ぶその物すごい気配はもう迫っていた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗水が凝り固まってできたような銀行の貯金は、その銀行が不景気のあおりを食って破産したために、水の泡になってしまった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと忘れたふうに見せて、葉子の心に好奇心なり軽い嫉妬なりをあおり立てようとする、あまり手もとの見えすいたからくりだと思うと、葉子はさげすんだ心持ちで、犬にでもするようにぽいとそれを床の上にほうりなげた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
