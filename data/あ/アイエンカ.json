        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近年、禁煙の流れが加速する中で、愛煙家にとって肩身の狭い思いをする場面が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昔からの愛煙家で、食後の一服を欠かさない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康を気遣う友人に、長年の愛煙家である父が禁煙を勧められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカフェは愛煙家にも配慮して、広々とした喫煙席を設けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父は葉巻をこよなく愛する愛煙家で、彼の周りにはいつも芳ばしい香りが漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私は生粋の愛煙家だから、タバコがない生活なんて考えられないね。」と彼は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃同年輩の中学生で喫煙するのはちっとも珍しくなかったし、それに父は非常な愛煙家であったから両親の許可を得るには何の困難もなかった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛煙家のあいだで琥珀と呼んでいるものだ。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も十一谷君は、蝋引きの吸口を必ず用いて、普通の愛煙家のようにじかに吸うことがなかった。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愛煙家のうちでも、最も特異な吸い方なのだ。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って、客は大抵愛煙家だった。",
              "citation": {
                "source": "阿亀",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も大の愛煙家であったから。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も若い頃は一廉の愛煙家であったに違いない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを手にすると、よほどの愛煙家とみえて、どこのシガーかを鑑定するように眺めた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを熱中させるところね――でも、わたしはまだ新聞ひとつよめないんだから……」　はじめ元気よく喋り出して、間もなく素直に悄気た伸子を、その比田礼二という記者は、いかにも愛煙家らしい象牙色の歯をみせて笑った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "議長は愛煙家だから、おそらく煙草に毒されたか、あるいは空想にふけり、餓鬼の頃のいたずらを思い出していたのかもしれない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草が化して桜並木名流喫煙家の癖さまざま　趣味的に煙草を愛したのはやはり煙管や煙草入れに凝った時代のこと、紙巻煙草の全盛から、追い追い実質的、習慣的の嗜好品と成り下って、ただフカフカやるだけの、専売局御用の愛煙家ばかり、その中でお話になりそうなのを二つ三つ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板か体裁か、とにかく経済的の愛煙家、もっとも煙草は商売であった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち二、三本は無駄にした、大変な愛煙家もあったもの。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ煙草を注文され、ポンダ通りへ郵送いたしました」「愛煙家だったか」「ええ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
