[
  {
    "uuid": "411f9a89-b496-5a05-8104-f3b0200ab0a3",
    "entry": "愛し合う",
    "reading": {
      "primary": "あいしあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
