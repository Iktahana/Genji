[
  {
    "uuid": "411f9a89-b496-5a05-8104-f3b0200ab0a3",
    "entry": "愛し合う",
    "reading": {
      "primary": "あいしあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to love one another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛し合うは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛し合うが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛し合うに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛し合うが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛し合うについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛し合うについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛し合うについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛し合うが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛し合うが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛し合うは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛し合うは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛し合うを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛し合うをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛し合うが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛し合うの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛し合うを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛し合うに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛し合うについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛し合うは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛し合うを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "却って菜食はみんなの心を平和にし互に正しく愛し合うことができるのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い純情な、愛し合う男女が、最初の接吻に、陶酔し、それ以上の邪心がないように……前川も、嵐もなく夕立もなく、心と心とが相触れて獲た新子の唇に、充分満足し、青年のような歓喜に躍り上っていたのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌が出てからは、人々は感情のあふれてくるままに、こうした人間の愛し合う世界を千年も続けて見ていきたい気を起こしたが、二条の院を出て四日目の朝になった源氏は、今日はぜひ帰らねばならぬと急いだ。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡と愛子とが互いに愛し合うようになったら……なったとしてもそれは悪い結果という事はできない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親切な岡、柔順な愛子……二人が愛し合うのは当然でいい事らしい。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村や晶子が盛にロマンティックな詩で愛の美しさ、愛し合う男女の結合の美しさ、価値をうたった時代、現実の社会生活の中では決してそのような誰にものぞましい結合がざらにあった訳ではなかった。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、互に働いている男女が愛し合うとして共稼ぎということが問題となって来る。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが生きているこの現実の中で、愛し合う可能の下におかれ、めぐりあった相手しか、現実に私たちの愛せるものは存在し得ないのである。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のひとも家庭と妻との概念を変え、互に、愛し合う男と女とが生活に向ってスクラムを組む心持でなくては駄目と思います。",
              "citation": {
                "source": "働く婦人の結婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し合うこと、心の貧しいこと、この二つがあれば、幸福の材料を幾らでも周囲から見つけ出して来ることが出来る。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し合うと云うことに就いても、死と云うことについても。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には自然の災害があり、一方ではお互が愛し合う事もなく一人一人が勝手に暮らしているこんな世の中は全く地獄も同然と云っても好いのだ。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり愛し合う為に憎み合いながら。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人々よりは愛し合うからといってお互いの生活に立ち入り勝手という法はありません。",
              "citation": {
                "source": "成長が生んだ私の恋愛破綻",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "或女は一人の男性を愛し合うこと以外の性交は自己の生活の中枢である愛情を濁す行為とし、貞操を自己の愛情の象徴として厳粛に擁護しようとするかも知れぬ。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあ、愛し合うのは君たちの自由だが……僕で役に立つことなら、いつでも相談にのるよ。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄と妹とが愛し合うということは、世間の手前、どう言うことになるのかね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い男達が口説くというよりただもうむやみにからだを求めるのを嫌うわけではなく、私自身は肉慾的な要求などはあんまりないのだけれども、私は男女が愛し合うのは当然だと思っており、その世界を全面的に認めているから、たとえば三木昇が好色で肉情以外に何もなくとも、そのことで軽蔑はしなかった。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間として殉情的に悲惨と思われることは　最も愛し合う近親を、各人の未完成の時に失うと云うことではないか。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私は夫婦のチギリばかりじゃなく、男女が愛し合う通例の愛し方、生活の仕方というものに疑いをもっているのだが、人々が恋をする、クチヅケをする、また肉体の交りをむすぶ、それだけを恋愛と思うのは波を見て海を見ないような気がするんだね。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し合うことは騙し合うことよりもよっぽど悲痛な騙し合いだ。",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と妻とは結婚当初から可なりよく融和して、凡そ夫婦というものが愛し合う位の程度には愛し合いました。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって私達は……一寸でも……愛し合う気になったんですもの。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し合う気になったのが悪いのよ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「愛し合う気になったのが？",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、愛し合うだけで十分だったのよ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は愛し合うようなことになるかも知れないと、ふと思ってみたこともあるにはあるが、結婚なんてことは僕の考えの範囲外だった。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、なぜ浜地と愛し合うようなことをしたんだ。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、父と私と一つだけ、ほんのわずか愛し合うことの出来る時がありました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
