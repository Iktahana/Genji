[
  {
    "uuid": "d0ff39e4-1437-5906-9450-3f3512d9503f",
    "entry": "跡をつける",
    "reading": {
      "primary": "あとをつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to tag along",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日跡をつけるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は跡をつけるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には跡をつけるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは跡をつけるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は跡をつけるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では跡をつけるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に跡をつけるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では跡をつけるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると跡をつけるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では跡をつけるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に跡をつけるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により跡をつけるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "跡をつけるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に跡をつけるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」と一生懸命跡をつける。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人は支度を整えて一行の跡をつける事にした。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお蓮の跡をつけるには、都合が好かったのに違いない。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが玉太郎少年が、恐竜島に足跡をつけるようなことになったのも、ふしぎな運命のしわざである。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話声さえ雪に吸われてスキーの跡をつけるのさえすまない気がする。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもし新聞があれば、その上をべたべたと歩き廻って沢山の足跡をつける。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "燕尾服の自殺　――ブルゴオニュの葡萄祭り――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はふと会話の跡をつけるのを忘れて、一人考えに沈んだ。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、それも毎度のことではないが、ちょっぴり、怪しげな褐色の跡をつけるためにである。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何が目的で跡をつけるのであろう。",
              "citation": {
                "source": "凍るアラベスク",
                "author": "妹尾韶夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもうこれ以上、彼女の跡をつけることは斷念した。",
              "citation": {
                "source": "水族館",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は外科へ、一人は町役人へ、一人は土藏の扉を開けて若旦那の染五郎を出す爲、左陣は生濕りの路地に足跡をつけるのを嫌つて、大廻りに店口の方から入つて來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅い扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は外科へ、一人は町役人へ、一人は土蔵の扉を開けて若旦那の染五郎を出すため、左陣は生湿りの路地に足跡をつけるのを嫌って、大廻りに店口の方から入って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鼻で目っかちで、竹の子笠を冠って、襟のかかった双子縞の袷に、肩から飴の箱をブラ下げた爺、これだけ目印しがある上に、チャルメラという音楽入で宣伝して通るのですから、馴れたものが跡をつけるには、左まで骨は折れませんでした。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれた靴が、階段に跡をつけるのを気にしながら。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は力を増してきた観察および気が早い一般化にたいして提供された釣り合いの重り、および同じように信用できない作りごと――贅沢な想像またはア・プリオリの空論により自己依存性の感情感覚の上に作られたもの――を退けるために学んだ信頼によって、この非常に価値のある果実の生長の跡をつけることになるであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方にその手早い奴を見つけてもらいたい……地球のはてまで手早い奴の跡をつけるために、とほうもない公けの機構を総動員して国々に網をはらせ、うまくその手早い奴をつかまえることじや。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "滋幹が訝しみながら跡をつけると、父は脇目もふらずに前方を視つめ、階を下りて、金剛草履を穿いて、地上に立った。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はもう、その馬車に乗って先の馬車の跡をつけるよりほかに方法はなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙を持っていくとか、人の家へいくとか、方々尋ね回るとか、居所をさがすとか、人の跡をつけるとか、そんなことならあたしにもできてよ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬車からおりてあの婚礼の跡をつけるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は井戸から向うは足跡をつける必要がないと誤解したのです。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には、偽の足跡をつける場合、往復の逆であることを看破されないために、足跡の重なることを避けた程綿密な彼が、自分の足癖をそのまま、内輪につけて置いたというのも信じ難いことです」　赤井さんの声が続く。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあの翌日一杯かかって、出来るだけ調べたのですが、吾妻橋の東詰までは、色々な人の記憶を引出して、どうにかこうにか跡をつけることが出来ましたけれど、それから先は、橋を渡ったのか、河岸を厩橋の方へ行ったのか、それとも左に折れて業平橋の方に向ったのか、どう手を尽しても分らないのです。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その君に尾行してきた男があったとすれば……途中ですれ違いに見つけて跡をつけるというのは少しおかしいですからね……その男は高梨家から君をつけてきたと思わなければなりません。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が馬車鉄道を降りると、私も人力車を降りて、又テクテクと跡をつける。",
              "citation": {
                "source": "押絵と旅する男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の門戸にはいつも清浄な砂が敷きつめてあるために、砂上に足跡をつけるのは何かはばかられるような気持を時の蜀人も抱いていたにちがいない。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "――涙の露の玉かづら、かざしの花もしおしおと――　という頃は、低声であとをつけるのが、ぶつぶつぶつ、ぼうぼうと鳴いて、羽の生えたものは、蚊も、蜂も、天人であるかのごとくに聞こえた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の二段誘惑法　悲しい事に、今の女学生は男学生のあとをつける程の力を持たぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "釧路丸の船長は、代りの砲手を雇ったんですから、鯨と聞いたら、じッとしてはいませんよ」　間もなく船は、スピードをグッと落して、遠くに上る潮の林を目標にして、見え隠れ鯨群のあとをつけるのだった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、雨降りあげくであれば、轍のあとをつけることもできます。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
