        "examples": {
          "standard": [
            {
              "text": "アフロディーテについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフロディーテは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフロディーテについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフロディーテの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフロディーテが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフロディーテを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフロディーテが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフロディーテが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフロディーテは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフロディーテは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフロディーテは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフロディーテについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフロディーテの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフロディーテの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフロディーテの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――「君のまだ見ない絵がもう一つある」そして一枚の被覆をさっと取り除けると、彼は侯爵夫人アフロディーテの全身像を現わした。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おお、お美しい、――お美しいアフロディーテさまが！",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして香料に関しての諸般の知識は美の神アフロディーテの使ひ女エオーネの無分別から人間界に過つて伝へられたと云はれて居る。",
              "citation": {
                "source": "希臘及び羅馬と香料",
                "author": "加福均三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフロディーテは其名の示すが如く、海水の泡沫より、生れ出でし女神にして、潮水の生殖力の人格化たること明なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此林檎には、「最も美しき者へ」との文字書かれしによりて、忽ち天神ヘラ、正善の神パラス、アテーネ、恋愛の神アフロディーテ三女神の間に、何れか之を得可きやに関して、一場の争論を生じたり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アテーネは戦陣の名誉を与えんと云い、アフロディーテは、世界絶無の美婦を与えんと云いしが、パリスは直ちに裁决を下して、恋愛の女神は林檎を得たり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日月流るるが如く、暫くはパリスの生涯に、何等の変化も無かりしが、かの女神アフロディーテの約言は、間もなく実行さるることとなりぬ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "メネラオスと其兄弟との不在は、遂に多くの財宝と共に、ヘレナを奪うの機会を与え、アフロディーテの助によりて、パリスは安全に帰国するを得たり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアの彫刻家がある美しい女の体からアフロディーテーの像を作り出す場合には、彼はそのモデルから多くを捨て多くを付加するが、しかし彼をしてこの取捨を行なわしむる標準はその現実的な女体において彼が直視した理想の姿である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
