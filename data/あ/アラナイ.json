        "examples": {
          "standard": [
            {
              "text": "私は毎日有らないについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有らないという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有らないの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有らないが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有らないを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有らないについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有らないの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有らないの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有らないが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有らないという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有らないという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有らないについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有らないを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有らないは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有らないについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有らないが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有らないは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有らないの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有らないは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有らないは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「何うぞ、貴方、私が今夜此處に居りました事を、誰にも仰有らないで下さいまし。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ先生｜跡がこはいんですから、おあしはあげたけれど、あれは先方で何も仰有らないうちに、あたしからあげたんですつて、さう申したらわるいでせうか。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰有らないとお母さんにいいつけますよ。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんばんワ」「こんばんは、劉夫人」「劉夫人と仰有らないで……。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると妻はただそんなことはもう仰有らないで、元通りに『仲好く』〔日本語〕暮しませう、と云ふばかりだつた。",
              "citation": {
                "source": "嫉妬する夫の手記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ろと仰有らないでも出ますがね。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、奥さん、一生の願いです」「それは無理と云うものです」「そんな事を仰有らないで――」「もうどうぞお帰り下さい」　静子は思わずきっと云った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも貴郎、かかり合になるといけませんから、他人様にマンドリンの音を聞いたなどと仰有らない方がようございますよ」折江は良人の顔を見て何か不安らしい様子でいった。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなむずかしい金のかかるものは、お前の柄じゃないぞ」「いえ博士、そう仰有らないで、是非にお願いいたします。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが下さいとも仰有らないのに人が勝手にくれるものは、あなたがそれを受取っても、あなたは何を支払う必要もない。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬の風は、あなたに悪いのでせう」「すぐにも命にかゝはることはないだらうと思ふけれどもね」「なぜ、窓をとぢてと仰有らないの」「信ちやんがそれを好まないからさ」「あなたの命にかゝはつても」　谷村はうなづいた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらない先に後悔してはいけなからうと思ふのですよ」「禅問答のやうに仰有らないで下さいよ！",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「旦那様が何とも仰有らないんだもの。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に挨拶したいなんて、変なこと仰有らないで。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしては、そんなこと、ゆうべは一言も仰有らないね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうも仰有らないんです。",
              "citation": {
                "source": "素材",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か正業についてくれると宜いんだが、大きなことばかり言って彼方此方飛んで廻って歩いて、真正に兄弟泣かせだよ」「兄弟泣かせって、大きい兄さんのところや祐三さんのところへは些っとも仰有らないじゃありませんか？",
              "citation": {
                "source": "或良人の惨敗",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙子さんのが伝ったとは決して仰有らない。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清之介君はそれを嫉妬と解して光栄に存じ、妙子さんの手を取りながら、「妙子さん、何うかそんなことは仰有らないで下さい。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「結構ですけれど、つまらないことは仰有らないで下さいよ。",
              "citation": {
                "source": "四十不惑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（うまいことを言ったものだと思いながら）それでお断りしたんですから、その辺のこともよくお話し下さい」「すっかり申上げます」「僕と打ち合せたことは仰有らないで下さいよ。",
              "citation": {
                "source": "四十不惑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御冗談一つ仰有らないから、皆さんピリ／＼しているんですって」「白い歯を見せると取締りがつかないよ。",
              "citation": {
                "source": "四十不惑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたは家内の気に入りですから、仕方ありません」「仕方ないんですわね」「そんな意地悪を仰有らないで」「オホヽヽヽ。",
              "citation": {
                "source": "四十不惑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか皆さん、「俳句でも一つ作つて見るか、」などといふ戯談は仰有らないやうに、そして老人文学なぞと簡単に片づけてくださらないやうに。",
              "citation": {
                "source": "俳句は老人文学ではない",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことを仰有らないで見廻ってくださいな。",
              "citation": {
                "source": "三階の家",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことを仰有らないで一寸下りて入らしってくださらない……」「厭だな、」「ではご一緒に廻って頂けませんか、その方がよございます。",
              "citation": {
                "source": "三階の家",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも先刻からご自分のことは、仰有らないじゃありませんか。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらない先に後悔してはいけなかろうと思うのですよ」「禅問答のように仰有らないで下さいよ！",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな大きな声で仰有らないで下さい、当分この研究は秘密にして置きたいと思いますから、決して他言なさらないように」「宜し宜し、もう決して云わん」「では失礼します。",
              "citation": {
                "source": "天狗岩の殺人魔",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の童子　このお寺は唯のお寺ではあらない。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
