        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日争うべからざるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は争うべからざるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には争うべからざるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは争うべからざるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は争うべからざるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では争うべからざるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に争うべからざるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では争うべからざるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると争うべからざるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では争うべからざるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に争うべからざるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により争うべからざるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "争うべからざるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に争うべからざるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そしてこの主観的のそれはただその時に於てのみ真である、他の時に於ては真で無くなるのは争うべからざる事実である。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてかくの如くかなり広い面積を有し、主要なる港湾を備え、而も多くの歴史的人物を産出した浦添の名称が浦々を支配する所という意味を有していることは殆ど争うべからざる事実である。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、こういうたぐいの議論がだんだんに勢力を張って来たのは、争うべからざる事実であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "儼として存在しているから、この点において争うべからざる真であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "真を写す文学者もこの医者や動物学者と同じ態度で、平生は依然として善意に拘泥し、美醜に頓着し、壮劣に留意する人間である事は争うべからざるの事実であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし未来の情操文学はいかなる内容をもって、いかなる評価をなすやに至っては固より測りがたいのはもちろんでありますが、それまでに発展した客観描写を利用してこれを評価の方面に使うのは争うべからざる運命と存じます。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれどもこの論派にありて当時すでに二種の分子を孕み、いまだ相｜軋轢するに至らざるも、隠然その傾向を異にしたるは争うべからざるがごとし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかりといえども沿革の関係は争うべからざるものあり、自由派と帝政派とは国権論においてはなはだ相近かりき。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば人生の道徳は夫婦の間に始まり、夫婦以前道徳なく、夫婦以後始めてその要を感ずることなれば、これを百徳の根本なりと明言して決して争うべからざるものなり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦親愛恭敬の徳は、天下万世百徳の大本にして更に争うべからざるの次第は、前既にその大意を記して、読者においても必ず異議はなかるべし。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばその文の大意に嫉妬の心あるべからずというも、片落に婦人のみを責むればこそ不都合なれども、男女双方の心得としては争うべからざるの格言なるべし。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事情を語るには言長ければ、手近く一例をあげて示さんに、一国の富は一個人の富の集まりたるものなりとの事は、争うべからざるものならん。",
              "citation": {
                "source": "慶応義塾学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今日の文明は道徳の文明にあらずして智恵の文明なること、また争うべからざるなり。",
              "citation": {
                "source": "文明教育論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三八　決闘裁判　刑事裁判がその源を復讐に発していることは争うべからざる事実であるが、その最も著明な証跡とも見るべきは、刑事訴訟の起訴者が現今は国家であるが、往昔にあっては私人であったことである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この何分宜しく頼むの頼むは本当の意味の頼むか、又は単に辞令上の頼むか不明だけれども、平岡の一身上に急劇な変化のあったのは争うべからざる事実である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれを自家の経験に徴して争うべからざる真理と信じた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから以後改まって両人の腹の中を聞いた事はないが、それが日毎に好くない方に、速度を加えて進行しつつあるのは殆んど争うべからざる事実と見えた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の絵画の年々進歩するのは争うべからざる事実ではあるが、その原因を某氏のように一概に文部省の展覧会に帰するのは間違っているように思われる。",
              "citation": {
                "source": "文芸委員は何をするか",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけはたしかであります、これ以上は証明する事はできないが、これだけは証明する必要もないくらいに炳乎として争うべからざる事実であります。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いた刹那は争うべからざる驚きの意識で占領された刹那じゃないか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづは処女にして、夫婦の行事がいかなるものか、いかにして行うかを知らず、自ら要求する術も知らず、むしろこれらの事柄は男子たる羽山が積極的に指導し愛撫すべきことは争うべからざる公知の事実である。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "争うべからざる公知の事実だ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、最後に残ったのが、結婚初夜に於ては男子は木石の如く処女を犯すべからず、これ争うべからざる衆知の事実なり云々という大文章の問題であるが、これは法律じゃア解けそうもないねえ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう考え方があるということだけでも、事実だということの争うべからざる証拠だった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十八　まず日が没したので休戦の許しを得た様なものだ、この後の太陽の光景は見る事が出来ぬけれど、間もなく天に、争うべからざる恐ろしい凶兆が現われた。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのシベリア地方のごときもとより濠州に比すべきものにあらざれども、そのわが一の得意客たることは決して争うべからざる事実なり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、要するに、巡回文庫はニユーヨークを中心として創設せられ、漸次「マッサチューセッツ」、「ウイスコンシン」、「ミシガン」、「ペンシルヴェニヤ」、「メリーランド」、「オハヨー」、諸州に普及して、既に争うべからざる成績を得たり。",
              "citation": {
                "source": "米国巡回文庫起源及び発達",
                "author": "佐野友三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしやその系図がなんと言っておろうとも、当時においてなんと公称しておろうとも、仏に対してみずから告白したこの事実のみは争うべからざるものである。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それは争うべからざる事実です。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いな、人間の死は、科学の理論を待つまでもなく、実に平凡なる事実、時々刻々の眼前の事実、なんびともあらそうべからざる事実ではないか。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
