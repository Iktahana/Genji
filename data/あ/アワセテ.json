[
  {
    "uuid": "0cba0903-cfd7-53f2-b2c0-4ae0ec13c3c0",
    "entry": "合わせて",
    "reading": {
      "primary": "あわせて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
      "ctype": null,
