    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in all",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日合わせてについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "合わせてという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は合わせての意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には合わせてが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "合わせてを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは合わせてについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "合わせての使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は合わせての定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では合わせてが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせてという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に合わせてという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では合わせてについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "合わせてを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると合わせては複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせてについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では合わせてが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合わせては重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により合わせての意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "合わせては様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に合わせては興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "投げ槍や斧をふるう勇士が、皆音楽に拍子を合わせているように思われた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の草を縛り合わせて通りかかった人を躓かせたり、田圃道に小さな陥穽を作って人を蹈込ませたり、夏の闇の夜に路上の牛糞の上に蛍を載せておいたり、道端に芋の葉をかぶせた燈火を置いて臆病者を怖がらせたりと云ったような芸術にも長じていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って現在高知にそういう狩猟法が残存しているかどうか、また高知以外の日本のどの地方に過去現在のいずれかに同様なものが行われて来たかどうか、ということについても全然なんらの知識も持合わせていない。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々聞合わせてみてもその現象の記載がどうも要領を得ないのであるが、ともかくも電光などのような瞬間的の光ではなくてかなり長く持続する光が空中の広い区域に現われたことだけは事実であるらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はから火を見ながらかさかさ乾いて亀縮む掌を摩り合わせて「娘が子というものは」と考えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九歳の時に人力車で三日かかって吉浜まで来たことを考え合わせてみると、現代のわれわれは昔の人に比べて五倍も十倍も永生きをするのと同等だという勘定になるかもしれない。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局私はこの油の漏れる和製の文化的ランプをハンダ付けでもして修繕して、どうにか間に合わせて、それで我慢する外はなさそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の午前に日比谷近く帝国ホテルの窓下を通った物売りの呼び声が、丁度偶然そのときそこに泊り合わせていた楽聖クライスラーの作曲のテーマになったという話があったようである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の若者が団扇太鼓のようなものを叩いて相手の競争者の男の悪口を唄にして唄いながら思い切り顔を歪めて愚弄の表情をする、そうして唄の拍子に合わせて首を突出しては自分の額を相手の顔にぶっつける。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼等の文学は、手の白い、労働しない少数の者にさゝげられた文学であったことを、その小ブルジョア的作家態度と合わせて、はっきりと物語る以外の何ものでもない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客は亮の兄弟と自分らを合わせて四五人ぐらいはあったが、映画技師、説明者が同時に映画製造者を兼ねるのみならず、肝心のガラス板がやっと二枚ぐらいしか掛け替えがないのだから亮の骨折りは一通りでなかったろうと思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ朝日グラフで、街頭のスケッチを組み合わせたページが出るが、ああいうものを巧みに取り合わせて「連句」にすることもできる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから考えると、鴉がすぐ耳元で歌っている歌に合わせて頸を曲げるぐらいは何でもないことかもしれない。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生え抜きの上田市民で丁度この日他行のためにこの祇園祭の珍しい行事に逢わなかった人もあるであろうから一生におそらくただ一度この町へ来合わせて丁度偶然この七十年目の行事に出くわした自分等はよほどな幸運に恵まれたものだと思っても別に不都合はない訳である。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだ、それだ」　二人は手筈をしめし合わせて一旦別れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りにも待ち合わせてその船に乗って帰る。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はそれですっかりその婆さんに牛耳られてしまったのであるが、その女の自分の咳に敏感であったことや、そんな薬のことなどを思い合わせてみると、吉田はその女は付添婦という商売がらではあるが、きっとその女の近い肉親にその病気のものを持っていたのにちがいないということを想像することができるのであった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて夫の光国が来合わせて助けるというのが、明晩、とあったが、翌晩もそのままで、次第に姫松の声が渇れる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "定価から五銭引いて、丁どに鍔を合わせて置く。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳屋は浅間な住居、上框を背後にして、見通の四畳半の片端に、隣家で帳合をする番頭と同一あたりの、柱に凭れ、袖をば胸のあたりで引き合わせて、浴衣の袂を折返して、寝床の上に坐った膝に掻巻を懸けて居る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉は半被の袖を掻合わせて、立って見て居たが、急に振返って、「そうだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に消火山活火山をも合わせて取り扱う場合には、N'(VC) = 11 となり、R = 3.3 に減ずるが、硫黄・岩雄の頭がｙなる子音だとして、このアソ型から除けば R = 5.1 となる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃刀をとぐ砥石を平坦にするために合わせ砥石を載せてこすり合わせて後に引きはがすときれいな樹枝状の縞が現われる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、自然は人間の知らないいろいろな理由を知っており、持ち合わせているために、世界の万物はことごとく円や球や均質平等であることから救われるのである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方｜山口珪次君の単晶のすべり面の研究なども合わせて参照さるべきものと思われる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらずいつも充分な自信をもって自由に飛行して目的地に達するとすれば、そのためには何か物理学的な測量方法を持ち合わせていると考えないわけにはゆかないのである。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを一枚一枚写真にとって、そのおのおのを重ね合わせて重ね撮り写真をこしらえる。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してぐあいの悪い日は絵の具も筆も、申し合わせて反逆を企て自分を悩ますように見える。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽器の弦の調子を合わせて行ってぴったりと合ったような、あるいははまりにくい器械のねじがやっとはまった時のような、なんという事なしに肩の凝りがすうっと解けるような気がするものである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風月ではドイツ人のピアニストＳ氏とセリストＷ氏との不可分な一対がよく同じ時刻に来合わせていた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
