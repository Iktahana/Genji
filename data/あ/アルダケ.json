    "definitions": [
      {
        "index": 1,
        "gloss": "all that one has",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有るだけについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有るだけという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有るだけの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有るだけが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有るだけを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有るだけについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有るだけの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有るだけの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有るだけが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有るだけという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有るだけという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有るだけについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有るだけを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有るだけは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有るだけについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有るだけが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有るだけは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有るだけの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有るだけは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有るだけは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いのちが有るだけでも感謝しなければならない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただできうる唯一の方法としては、有るだけの材料から、科学的に合理的な一つの「可能性」を指摘するに過ぎない。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も親父に話したのですけれども、此の夏、忠一君が帰省した時に、唯った一度行ったことが有るだけで、其後は柳屋の閾も跨いだ事は無いんです。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（唯彼等の説く所が、人間の今日に於ける生活状態とは非常に距離の有る生活状態の事で有るだけで有る）。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順は落ちると云う時期に、身上の有るだけを酒にして、漁師仲間を大連へ送る舟の底積にして乗り出すと云うのは、着眼が好かったよ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様が、倅も卒業すれば、是非洋行をさせねばならないが、卒業試験の点数次第で、官費で遣られるか、どうだか知れないと話すと、わたくしがお金を持っていれば、有るだけ出して学資にして戴きとうございますなどという。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "であれば、環境の変化は人に役立ち人に張る気を生じさせるとはいえ、時には人に張る気を生じさせない時も有るだけでなく、却って散る気や萎む気等の好ましくない気をさえ生じさせることもある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵夫人は有るだけの愛嬌を振り撒いて迎へた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由、博愛、平等を標語とするこの国には極く富んだものと極く貧しいものとが有るだけで、自分の郷国にあるような中位で快適な生活はないのかとさえ疑った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうに、皆から扱われるのには慣れていますが、あなたのことが、有るだけに、たまらなかったのです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして船も其日から有るだけの帆を一杯に張って、南へ南へと下だり出した。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、無ければ無くていゝやうな、有れば有るだけの効果を生ずるやうな映画創作術がなければならないと思ふ。",
              "citation": {
                "source": "映画素人談義",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭なら厭と仰有るだけでよろしいのです。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈の光なんぞは、有っても無くってもいいわけですが、それでも、有れば有るだけに、何かしらの温か味が、身に添わないという限りもありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車、汽船、電信、電話、飛行機、潜航艇を始めとして、他の文明国に有るだけの物は我国にも有ると云ふのは誠に立派なことで、我国が今日の位地までに進み得たのは、全く絶えず文明に進むことに力を尽した結果である。",
              "citation": {
                "source": "理科教育の根底",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ有るだけ御出し」と、思ったよりは平気である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代時代の平均ノルムが有るだけ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　俺達の前には、ノツピキのならないギリギリ決着の絶壁が有るだけだ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香代は初めから留吉の方ばかり見てゐるが、彼女の性質では留吉に気持が有れば有るだけ寄つても行けないし、言葉もかけられず、奥歯を喰ひしばつて、金助の巻ゲートルの始末をしてゐる）……一本附けようか？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ時代的な幼稚さに相応せざるを得ないから、そこに発した狂いはまま有るだけの話である。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィンセントにはカンバスが有るだけだ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家に有るだけの金を出せ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく彼は、自分に有るだけの意志の力をふるい起して、その危険な場所から、―――やがては自分をどんなに堕落させるかも知れない奇怪な部屋から、―――身を退けた。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あてかてあの時姉ちゃんを取り戻そいう一心で有るだけの智慧絞ってんし。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼女は出かける四五日も前から大騒ぎをして、有るだけのものを引っ張り出して、それに一々手を通して見るのです。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がもしそのことを欺いたとして、当今人々は云ふのである、「それはお前だけのことだ、お前の註文があるだけのことだ」と。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その云ふ気持は分るけれど、それに、観念が稀薄であるよりは濃厚な方がよいに決つてゐるけれども、要するに、観念があるだけある上で見たり感じたりしてゐることが芸術になりもするのであるから、そこへ観念を持運んで来たつてたゞトンダお景品たるに過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心があるだけで、既に結構なことではないか。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとつて「手」とは「手」であり、「顔」とは「顔」であり、即ち名辞するとしてＡ＝Ａであるだけの世界の内部に、彼の想像力は活動してゐるのである。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとつて「手」とは「手」であり、「顔」とは「顔」であり、Ａ＝Ａであるだけの世界の中に彼の想像力は活動してゐるのである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
