        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日余すについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "余すという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は余すの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には余すが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "余すを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは余すについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "余すの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は余すの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では余すが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "余すという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に余すという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では余すについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "余すを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると余すは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "余すについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では余すが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に余すは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により余すの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "余すは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に余すは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "はやその谷川の音を聞くと我身で持余す蛭の吸殻を真逆に投込んで、水に浸したらさぞいい心地であろうと思うくらい、何の渡りかけて壊れたらそれなりけり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその、熱いところを我慢して飲み、かねて習い覚えて置いた伝法の語彙を、廻らぬ舌に鞭打って余すところなく展開し、何を言っていやがるんでえ、と言い終った時に、おでんやの姉さんが明るい笑顔で、兄さん東北でしょう、と無心に言った。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらぬだに持余すのにこの陥羂に懸っては、後へも前へも行くのではないから、汗になって弱るのを見ると、会心の笑を洩らして滝太、おじさん押してやろう、幾干かくんねえ、と遣ったのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門衛の持余すを見て、微笑を含みたるお丹乞食、杖をもって門の柱を、とん。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて裁判長は被告に向かいて二、三の訊問ありけるのち、弁護士は渠の冤を雪がんために、滔々数千言を陳ねて、ほとんど余すところあらざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はすでにその悪夢からもさめていたが、醒めたころには金も余すところ幾許もなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のその精力と頑強と覇気とを余すところなく発揮した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我はかくばかり善く釣り得るが、父上弟はと遥かに視るに、父上も弟も面に喜びの色あるやうなれば、おのれも心満ちたらひて一向に釣り居けるが、やがて潮満ち来て「きゃたつ」を余すこと二尺足らずとなりし時、舟子舟を寄せ来りて、今日はこれまでなり、又の日の潮にと云ふ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどなほ余すところの竹藪あり、蓋し土地の人は八幡に比し、恐れて奥を探る者無く、見るから物凄き白日闇の別天地、お村の死骸も其処に埋めつと聞くほどに、うかとは足を入難し、予は先づ支度に取懸れり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世にかくも多くの怡しきことがあり、それをまた、かくも余すところなく味わっているやつがいようなどとは、考えもしなかったからである。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "はや其の谷川の音を聞くと我身で持余す蛭の吸殻を真逆に投込んで、水に浸したら嘸可心地であらうと思ふ位、何の渡りかけて壊れたら夫なりけり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻血が停った代りに、人が見て噴きだすわ」　と、振り払った瞬間、もう姿は見えず、「――やよ、佐助、既にして汝は鳥人の極意を余す所なく会得せり。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ夫れこの心の世界｜斯の如く広く、斯の如く大に、森羅万象を包みて余すことなく、而してこの広大なる心が来り臨みて人間の中にある時に、渺々たる人間眼を以て説明し得べからざるものを世に存在せしむるなり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この漫画なども、現代の家庭における老祖母と主婦と孫娘との三角関係を心理的に描写し尽くして余すところがないような気がする。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウン管の目に与える圧迫感が、ここでは余すところなくその効果を発揮してしまうのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、心臓の周囲を、外から余すところのないように、探って居た。",
              "citation": {
                "source": "マスク",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は猶脱るるほどに、帯は忽ち颯と釈けて脚に絡ふを、右に左に※払ひつつ、跌きては進み、行きては踉き、彼もはや力は竭きたりと見えながら、如何に為ん、其処に伏して復起きざる時、躬も終に及ばずして此処に絶入せんと思へば、貫一は今に当りて纔に声を揚ぐるの術を余すのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから牝牛を買って三月末三日を余すまで無事に飼ったが、前にも懲りず三月も済んだから畏るるに足らぬと嘲った。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑部左衛門これを討つ時、この怪鐘を頭に冒り戦う故矢｜中らず、わずかに一筋を余す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "折よくも私達の大会は日を余すこと僅日、私達はどんなに大きな声でわが「少女」の歌をうたふことであらう。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこのあたりには何んな生魚でも沢山にゐて、網を打てば、いつも持て余すほど入つて来るので、必要なものだけ取つて、あとは海に戻してやるなどゝ話した。",
              "citation": {
                "source": "モウタアの輪",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "……五間……十間……十五間……もう秋森家の表門迄は、余すところ五間、だがそれも軈て……四間……三間……と、ああ、とうとう奇蹟が現れた！",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余す所は常に遊んでいる。",
              "citation": {
                "source": "写生文",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門とやらは何を詮議にお越しじゃ、どのようなことをそなたにおいいじゃ、牛ガ淵で何をお見つけじゃ、と、おしゃべりのてまえもほとほともて余すほどうるさくききましてござりやす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一切が出来上つたと同じわけといふ例なのさ、つまり用意は微に入り細に渡つて余すところは無くなつた！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十等めし一本を食い余すなんて、なんという甲斐性なしだ！",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで室生犀星は、單に經濟と時間の上で、人生をエコノミカルに生活して居るばかりでなく、藝術上の仕事の上でも、自己の天與された全財産の才能を、最も能率的にあます所なく、百パーセント以上にさへも利用して居る。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ君の認めた相似が全くオブジェクティヴだとすると、現在の科学はこの説明を持てあますだろうと思われる。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭は、主人公のただならぬ氣魄を象徴してあますところがない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸は退屈を持てあますやうな風付で、濡れたまゝぞべ／＼とその友達の下宿にころがり込んだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
