          ],
          "literary": [
            {
              "text": "彼らでも死んでしまえば、醤蝦や白子と変りあるまい。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帽子をあみだにかぶっても気になるし、まぶかにかぶっても落ちつかないし、ひと思いに脱いでみてもいよいよ変だという場合、ひとはどこで位置の定着を得るかというような自意識過剰の統一の問題などに対しても、この小説は碁盤のうえに置かれた碁石のような涼しい解決を与えている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃあみんな白状してしまいますがね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、おばさんは吐息をして、なむあみだぶを唱えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　米吉は、三反歩の小作と、笊あみの副業で食っている。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんな、祈るのだぞ、まっすぐに立て。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路で、大原女のように頭の上へ枯れ枝と蝙蝠傘を一度に束ねたのを載っけて、靴下をあみながら歩いて来る女に会いました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪狼のうしろから白熊の毛皮の三角｜帽子をあみだにかぶり、顔を苹果のようにかがやかしながら、雪童子がゆっくり歩いて来ました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんなはだんだんしいんとなって、まるで堅くなってしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあみんな団子たべろ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんなよっく火にあだれ、おらまた草刈るがらな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎だけが、いちばん上で落ちついて、さあみんな、とかなんとか相談らしいことをはじめました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんな来い」　と大喜びで、ばあやも連れて東京のおうちへお帰りになりました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これでだいたいいい……さあみんな舞台よきところにすわれ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしょっちゅう聞かされて居たもんだからふいと出されたお前の生焼けの餅に妙に愛感を持たされてしまったんだ――」　妻は夫の前から餅あみのかかって居る火鉢を抱え取って云った。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんなはだんだん気味悪くなりました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあみんな拝見いたしたいです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」曹長「マルトン原のかなしみのなかひかりはつちにうずもれぬああみめぐみのあめを下しわれらがつみをゆるしたまえ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪狼のうしろから白熊の毛皮の三角帽子をあみだにかぶり、顔を苹果のやうにかがやかしながら、雪童子がゆつくり歩いて来ました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた白衣の鮮女が、道を掃いた小店の奧に、暗く目を光らして居た、鐵あみを絞つたやうに、皺の數を面に刻んで、白髮を逆に亂しつゝ、淺葱の筒袖に黒い袴はいた媼である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯あみしてあがりたる後に纏ふゆゑにしか名づく。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有馬に湯あみせし時、日くれて湯桁のうちに、耳目鼻のなき痩法師の、ひとりほと／＼と入りたるを見て、余は大いに驚き、物かげよりうかゞふうち、早々湯あみして出でゆく姿、骸骨の絵にたがふところなし。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあみんなよろこぶだろう。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すたすた二、三丁歩いて、うしろを振り返り、家人が誰もついて来ないという事を見とどけてから、懐中より鳥打帽をひょいと取出して、あみだにかぶるのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんが壇にのぼると、お御堂にいつぱいのお爺さんお婆さん達の中から、「なむあみだぶ」、「なむあみだぶ」、といふ低い声が、藪の中の風の音のやうにおこりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊次さんもついつりこまれて、「なむあみだぶ」といつてしまひました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんやお婆さん達の中には、閻魔さんをおもひ出したのか、また、なむあみだぶ、なむあみだぶ、といつて丸い背中をよけい丸くしたものがありました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
