          "literary": [
            {
              "text": "夜の食卓に、あの鰹が皮つきのまま厚切りの刺身となって現れた。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぐろというものはむやみに厚切りするものではないという彼の信念が表われていておもしろい。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはどうかな」と中野君は洋刀を揮って厚切りの一片を中央から切断した。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "肴には厚切りのビフテキが出たことは言ふまでもない。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にお辰は茶を入れて、厚切りの羊羹とこぼれるばかりの愛嬌とを一緒に持って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            }
          ]
        }
