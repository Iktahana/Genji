  {
    "uuid": "d6df5e3b-d8af-57ec-ac4c-8bc0b0319810",
    "entry": "相番",
    "reading": {
      "primary": "あいばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being on duty with a colleague",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「おかしいじゃないか、おい」　一運は、チャートルーム（海図室）にいる、相番のコーターマスターを呼んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ」　相番のコーターマスターが、タラップから顔を覗かすと、直ぐに一運は怒鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、安直な卷莨を吹かしながら、夜番の相番と、おなじ夜の彌次たちに此の話をした。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊織が金を借りた人は相番の下島甚右衞門と云ふものである。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛が四十になった時、甚兵衛と惣八郎とが相番で殿中に詰めていた。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊織が金を借りた人は相番の下島甚右衛門と云うものである。",
              "citation": {
                "source": "じいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年まで年に一回の月番役を勤めたが、月番の提灯を預ったきりで、一切の事務は相番の肩に投げかけるので、皆迷惑したと見えて、今年から月番を諭旨免職になった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
