        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同じ俳人仲間の宝井｜其角が、自分の事を悪し様に噂をしてゐるといふ事を聞いて、大層腹を立てた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃方々で乃公の事を悪し様に言ひ触らして歩くさうだが、それは真実だらうね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七瀬殿のことを、悪し様に申してはよくないが、嫁しては夫に従う、これが、婦の道でござろう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "のろふがさうした分化を遂げるには、罵る・叱るなどの悪し様に言ふと言つた用語例が助けてゐる事であらう。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の事を悪し様に云い、一寸したものをちょろまかさない位の農民は、大抵この男の様な様子をして話すものである。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不人情者、恩知らず――父に対する哀惜の情や、跡方もなく消えた一家の犇々と身に迫る切なさから、皆は口を極めてこれらの人達を悪し様に罵り、僅かに鬱憤を洩らすのであつた。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば確かに青年が最後の狂乱の手紙の中で彼を悪し様に言い弾劾したのが説明できるはずだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばし、お名あがり家ととのうたるのちは、御兄上様御姉上様、何条もってあしざまに申しましょうや。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子、』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代には早く讀み試みて、本國の大詩人をあしざまに言ふことを止め給へ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "關八州古戰録には、三成の事をあしざまに書きたり。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、お取り上げなさらぬときに訴状をろくでもねえやつに拾われて、上お役人、われわれお番所勤めの者たち一統をあしざまにけえたことが世間に知れちゃ、あとの響きも大きかろうと、それを遠慮して特にこんななぞをかけた文句だけでぼかしたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主人の身で、使用人のことをあしざまに申しますのは、はしたないようでござりまするが、どうも十兵衛どんがこのごろ毎晩おかしいんでございますよ」「どのようにおかしいのでござる？",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口にことを欠いて、おらがひいきのべっぴんをあしざまにいうたあ、何がなんです！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、村長さんのことをあしざまに詠みこんだ点だけは怪しからん……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々父をあしざまに言ふ菊五郎でもなからうが、常に先代と比較させるやうな芸風で、先代の型に逆手を試み、時としては反語的な手法すら用ゐた。",
              "citation": {
                "source": "菊五郎の科学性",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かほどの尊い聖人様をなぜあしざまに讒訴したのでございましょう。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "屯営部隊のハイカラ者なる彼等ときては、カフヱーで勢力のある家々のこと、あしざまに云ひ散らし、新しい作業服着て、恐ろしい歌を怒鳴るといふ始末。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "この“森野”に住む人で、高橋氏のことをあしざまにいう人は見つからない。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう仏ですから、あしざまに言うのはなんですけれど、ほんとに、厭なお人でござんした。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほかでもない、もし君がもう一度……たった一口でも……母をあしざまに言ったら……僕は君を階段から突き落とすぞ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなにあしざまに喚かれることか、そう思いながら路地をはいってゆくと、ずっと雨戸を閉めて暗くなっている長屋の一軒だけ、灯を明るくして賑やかに女たちの笑い囃す声の聞える家があった。",
              "citation": {
                "source": "おれの女房",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
