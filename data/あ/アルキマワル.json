          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩き回るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩き回るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩き回るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩き回るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩き回るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩き回るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩き回るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩き回るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩き回るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩き回るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩き回るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩き回るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩き回るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩き回るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのとき、私は壁にもたれていたのですが、足下をよたよたと歩き回る鵞鳥にふと目がとまりました。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最後には椅子から飛び上がり喜びの声を上げ、手をこすり合わせながら部屋中を歩き回る。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから毎晩、自分の部屋を歩き回る親父の足音を耳にした。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽天的になどなれる筈のものではなからう――たゞ俺たちは歩いてゐるばかりだ、命のある限り歩いて／＼……」　私は、轟々と車の回つてゐる水車場の中をぐる／＼と歩き回るのでした。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らが繋ぎ綱を受けたりやったりする音と、鋲釘を打ちつけた靴で甲板を歩き回る音とが入り乱れて、頭の上はさながら火事場のような騒ぎだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポッケットに両手をさし入れて、頭を縮め気味に、波止場の石畳を歩き回る人々の姿にも、不安と焦躁とのうかがわれるせわしい自然の移り変わりの中に、絵島丸はあわただしい発航の準備をし始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸の鶏は、自らの足で自由に歩き回ることができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋葉原を歩き回ると、記事で使っていたのと同じではなかったが、似たようなビジコン管が一〇〇〇円ほどで買えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みしめる草鞋の先は雪｜溶けの道に燃えて、歩き回れば歩き回るほど新しいよろこびがわいた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう語り合う二人は、明け渡した城あとでも歩き回るように、がらんとした問屋場の方をのぞきに行った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "苔蒸した墓と墓の間を歩き回るものがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って下座敷の内を歩き回るのは多吉だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには四男の和助までが、近所の年長の子供らの仲間にはいりながら、ほっペたを紅くし、軽袗の裾のぬれるのも忘れて、雪の中を歩き回るほど大きくなっていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が火鉢だ炭取りだ鉄瓶だと妻の枕もとを歩き回るたびに、深夜の壁に映るひとりぼっちの影法師は一緒になって動いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "緩慢ではあるが、しかし深い谷が楼のすぐ前にひらけていて、半蔵はそこいらを歩き回るには事を欠かなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "階上の壁面によせて積み重ねてあるそれらの本箱の前をあちこちと歩き回る時ばかり、彼のたましいの落ちつくこともない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "お民はまた、この木小屋に移ってからの半蔵に部屋のなかを人知れず歩き回る癖のついたことを言って、あちこち、あちこちと往ったり来たりする夫の姿を見かけるのは実に気の毒だと語るから、それは父の運動不足からであろうとお粂が母に答えて見せた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その短い上着のまま、早い桃の実の色した素足を脛のあたりまであらわしながら、茶の間を歩き回るなぞも、今までの私の家には見られなかった図だ。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔だけはまだ子供のようなあの末子までが、いつのまにか本裁の着物を着て、女らしい長い裾をはしょりながら、茶の間を歩き回るほどに成人した。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か特別の用事でもないかぎり、私は樹木の多いこの町の界隈を歩き回るだけに満足した。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かごとごと言わせて戸棚を片づける音、画架や額縁を荷造りする音、二階の部屋を歩き回る音なぞが、毎日のように私の頭の上でした。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは阿武隈川へもそう遠くなく、一里ばかり行けば太平洋の岸へも出られて、歩き回る場所に事を欠きません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（興奮して舞台をあちこち歩き回る）あたしには、この世の仕合せなんか似つかないのよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "七面鳥Dindes１　彼女は庭の真ん中を気取って歩き回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい天気になると、精いっぱい歩き回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当てもなく歩き回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には奥さんのお伴をしに来た書生さんと思った者もあるらしかったが、その二人が広くもない村の中を一通りあるきまわると、夕あかりの残った網干場を別荘の方へ通り抜ける時に、こんな話をした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は山を降って下町をあるきまわる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を抱え込んでまるで学者が考え事して居る時みたいに家中をあるきまわる。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が向くと、底の平ったい靴をはいて、ひとりで気ままにあちらこちらとあるきまわるので、キャラコさんは武蔵野の岡や小径をよく知っている。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
