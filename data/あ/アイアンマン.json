    "entry": "アイアンマン",
    "reading": {
      "primary": "アイアンマン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ironman (triathlon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイアンマンは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイアンマンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイアンマンに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイアンマンが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイアンマンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイアンマンについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイアンマンについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイアンマンが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイアンマンが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイアンマンは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイアンマンは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイアンマンを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイアンマンをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイアンマンが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイアンマンの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイアンマンを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイアンマンに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイアンマンについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイアンマンは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイアンマンを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
    ],
