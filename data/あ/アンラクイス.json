        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安楽椅子について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安楽椅子の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安楽椅子が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安楽椅子について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安楽椅子の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安楽椅子が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安楽椅子という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安楽椅子についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安楽椅子は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安楽椅子が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安楽椅子は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安楽椅子の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安楽椅子は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安楽椅子は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "朝飯後書斎で手紙の返事、十時に助手のゴルドン出勤、その日の仕事の打合せ、午前中は大抵読書か書きもの、Phil. Mag. か Ann. d. Ph. が来ると安楽椅子で約半時間それに目を通してから書棚へ入れる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、十一時から十二時頃までは安楽椅子でうたた寝をしてから寝室へ行くという不思議な癖があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側の安楽椅子によりかかって寝ているイサックの黒い顔に未来の文明が浮き出ていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ということを言いたげに呉は、安楽椅子に、ポンと落ちこんでチューインガムをしがんでいる深沢をチラと見て、にたにたと笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も、安楽椅子も、飾つきの卓も、蓄音機も、骨董や、金庫も、すべて、ナラズ者の南兵の掠奪に蹂躪されてしまうだろうと居留民たちは考えさせられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用の日ざしが狭い土堤いっぱいに涼しい松の影をこしらえて飽き足らず、下の蕃藷畑に這いかかろうとする処に大きな丸い捨石があって、熊さんのためには好い安楽椅子になっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふには、髪もひげもまるで灰いろの、肥ったふくろふのやうなおぢいさんが、安楽椅子にぐったり腰かけて、扇風機にぶうぶう吹かれながら、「給仕をやってゐながら、一通りのホテルの作法も知らんのか。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとファニーは安楽椅子に仰向きかげんに座を占めた母に抱きついて処きらわず続けさまに接吻していた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うには、髪もひげもまるで灰いろの、肥ったふくろうのようなおじいさんが、安楽椅子にぐったり腰かけて、扇風機にぶうぶう吹かれながら、「給仕をやっていながら、一通りのホテルの作法も知らんのか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はやがて、ぐったり疲れた体を安楽椅子から起こしてぼろ自動車で踏み散らされた前庭を少し手入れしようと玄関の戸を開けて階段を下りかけたが、ちょっと立止まって晴れ上った夏の青空を眺めた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木本の帰ったあと遅く出た風の送る水仙草の匂いを嗅ぎながら広いサンルームでマーガレットは安楽椅子にくたりとした。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧められた安楽椅子にちょっと手をかけた景子は急に此庭の秋色が見たくなって窓際へ近寄って行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ばかりでなく、これは籐椅子、木の椅子、安楽椅子のこれらの一列の人々の凡ての顔にも表われている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には手前の壁に寄せかけて安楽椅子をはじめ五六脚の形のちがった椅子を置き、そのむこうには青い帷を引いてあった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は皮膚が薄赤くて髪毛と眉毛が黄色く薄い男であったが、あんまり朗らかで愉快そうに見えるから、私は云い知れぬなつかし味をおぼえながら眺めているところへ、一おどり踊り終ったその男は、桃色に染った口をハンカチで拭き拭きすぐ私の傍の安楽椅子へ来てドッカリと腰をかけた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "展望車の安楽椅子に金口を輪に吹く紳士の鼻の淋しさは、何とも包む術はないものでしょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には手前の壁に寄せかけて安楽椅子をはじめ五六脚の形の違つた椅子を置きその向ふには青い帷を引いてあつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな安楽椅子のような扁平なのばかりである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の田地を売つて建てたといふ洋館の応接間に通されて、此処でも生れて始めての工合のいゝ安楽椅子に坐らされた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絨毯に立ったまま一心に見つめるので、ホームズも柳の安楽椅子にもたれかかる。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　刑事は安楽椅子に腰を下ろすと、得意気に葉巻を吹かせた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは室の中程に角なテーブルを据えて、薔薇のような花の咲いた鉢をのっけ、そのまわりに真紅な天鵞絨を張った椅子や安楽椅子を置いてあった。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその白紙の蓋がホンノリと黄色く染まった頃を見計らって、紙の上の茶粕を取除けると、天幕の中に進み入って、安楽椅子の上に身を横たえた富豪貴人たちの前に、三拝九拝して捧げ奉るのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "安楽椅子に伸びちゃったまま、黄色い死灰のような色沢になって、眼ばかりキラキラ光らしている光景は、ちょうど木乃伊の陳列会みたいで、気味の悪いとも物凄いとも形容が出来ないそうです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の考へは間違つてゐた、実は室内は贅沢に整理された空虚さであつて、大きな金縁に何やら青い色が詰めこまれた洋画や、書棚、安楽椅子など、何れも高価でないものはなかつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると獅子は安楽椅子に横になつたまゝで『穴熊君、わしが煙草に火をつけてやらう』　と言つたので、穴熊は飛びあがるほど心の中で嬉しがつた、しかし獅子は椅子から立ちあがらうともしないで、頤で先方をしやくつてから『向ふの棚にライターがあるから、君こゝへ持つて来給へ―』と命令的に言つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "○合唱男子、おゝ猪大王どの　　　心おしづめ下さい、　　　それなる岩の安楽椅子に　　　おかけ下さい。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀井勝一郎は不安の精神を詰めこむ安楽椅子造りになつた。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁いっぱいの本だなに、むずかしい本がズラッとならび、部屋のまんなかには、大テーブルがあって、そのまわりに、ふかふかとしたあんらくいすが、いくつもおいてあります。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
