        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い粉について考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い粉の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い粉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い粉について学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い粉の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い粉が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い粉という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い粉についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い粉は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い粉が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い粉は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い粉の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い粉は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い粉は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして、それと一所にお乳のような、又は洗い粉のような甘ったるいにおいが、ほのかに湧いて来るのです。",
              "citation": {
                "source": "卵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "立て膝して髱をなでつける婀娜女、隅っこの羽目板へへばりついている娘、小｜桶を占領して七つ道具を並べ立てた大年増、ちょっとの隙にはいだして洗い粉をなめている赤ん坊、それを見つけて叱る母親、いやもう大変なさわぎ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂濶に手あらいことも出来ないので、たがいに眼を見あわせて躊躇していると、新九邸が少し弱った隙きを見て、采女はにわかに跳ね起きようとした。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私のお父さんはさくらあらいこの社長なのよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だから私は石鹸よりも、このあらいこをもらう事が多い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をやっているのか見当もつかないのだけれど、桜あらいこの空袋が沢山部屋へ持ちこまれる事がある。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくらあらいこの部屋へ行くのは厭だけれども、自分の好かない場違いの人の涙を見ている事が辛くなってきたので、そっとドアのそばへ行く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大丈夫よ、あんな不良パパ、この頃は、七号室のお妾さんにあらいこをやったりなんかしてるわ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくらあらいこの社長よ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をやっているのか見当もつかないのだが、桜あらいこの空袋が沢山持ちこまれる事がある。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくらあらいこの所へ行くの厭だけど、自分の好かない場違いの人の涙を見ている事が辛らくなったので、そっとドアのそばへ行く。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外気の荒さに痛められず、伸びて、繁って繚乱と咲いているカーネーションの花弁は美しくて、伸子はそこをかきわけるように入って行った人間たちの衣服の繊維のあらいこわさを、花々にふさわしくないものにさえ感じた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁の中村さんにれんらくして、コンクリートをこわしてもらってはどうでしょう」　すると、明智先生は、「そんな手あらいことをしては、あい手がにげてしまうよ。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは手あらいことはしないから、心配しないでもよろしい。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は、あらいこうしじまの背広に、同じがらの鳥うち帽を、かぶっていました。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
