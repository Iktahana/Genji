        "examples": {
          "standard": [
            {
              "text": "毎日、あ段について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社のあ段戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "あ段の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "あ段という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあ段について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "あ段の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "あ段に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちはあ段を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界でのあ段は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、あ段は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "あ段は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々なあ段を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「あ段」という概念について深く考察する必要があります。",
