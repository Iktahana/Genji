        "examples": {
          "standard": [
            {
              "text": "私は毎日飴玉について考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴玉という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴玉の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴玉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴玉を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴玉について学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴玉の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴玉の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴玉が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴玉という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴玉という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴玉についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴玉を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴玉は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴玉について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴玉が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴玉は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴玉の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴玉は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴玉は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "小さい口から嘗めかけの飴玉を取出して、涎の糸をひいたまま自分の口に押し込んだりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤイ、飴玉の間抜け野郎。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "態をみろヤーイ」　飴玉は真赤になって憤り出しました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前から見物していたキャラメルの仲間のミンツ、ボンボン、チョコレート、ドロップス、飴玉の仲間の元禄、西郷玉、花林糖、有平糖なぞはソレというので馳け寄って、双方入り乱れてゴチャゴチャに押し合い掴み合っているうちに、みんなお互いにくっつき合って動けなくなってしまいました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "油一合買ってくれた人には、飴玉一つ景品としてやったんだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てエ」　他吉は君枝を叱ったが、しかし、君枝が婆さんの袂にあらかじめはいっていた飴玉を貰う時には、もう叱らなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな可愛いい子が……」　煙草や飴玉をひそかに留置場へ持ってはいっている大胆不敵さに、陽子は驚いたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トラックに乗ってる間に、浴衣の縫込みへこっそり入れといたってン」　チマ子はペロリと舌を出して、素早く陽子に飴玉を渡した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、丸薬をしかるべく包装するわけでもなく、夜店で売る「一つまけとけ」の飴玉みたいに、白い菓子袋に入れて、……それでは売れぬのも無理はなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はよ閉めて、おはいりやすな」　そして、「――ほな、ごゆっくり……」と遣手が下へ降りると、妓はぼそんと廊下へ来て私の傍へ並んで立つと、袂の中から飴玉を一つ取り出して、黙って私の掌へのせた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "放蕩の悔恨は消え、幼な心に温まって、私はその飴玉を口に入れた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴玉とマクロン　ノラの食べる菓子を予はマクロンと書いた。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを飴玉と書けと教へて貰つた。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の女がマクロンを食ふ場合と、日本の子供が飴玉を食ふ場合との相違はどの位違ふか、少し考へて見るが好い。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこなんぞを飴玉にしたら、さぞ面白からう。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蜜柑が無がったがら、俺、飴玉買った。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「咽喉渇いて仕様ねえがら、蜜柑買わせっさやったのに、飴玉など買って……ほして、その飴玉はやあ？",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘納豆、豆板、飴玉など、この時も妻は悦んだ。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　包みを披いてみると、袷、洗濯したメリヤスシヤツ、猿又、紙などがあり、その上に別の一包みになつて、飴玉と花林糖の紙袋があつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とことわつて、また腰をおろし、杉村は飴玉を口に入れた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "密柑の皮を煮る、砂糖代用として飴玉二つ三つ入れて。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんよ、この、ひさあしいくう……といふところがとてもいいわね」　翌日、彼が大原コレクシヨンを見て、家に戻つて来ると、小さな姪が配給で貰つた五つの飴玉のその一つを差出して、「をぢさん、あげませう」と云ふ。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の女の子は、それでも寿女に懐いて、食べ倦きた飴玉などを分けてくれたり人形の着物を縫ってくれとせがんだりする時がある。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骨と三人の旅だったけれど、姑は哀しいほど浮き立って、ひっきりなしに話しかけ、隣席の学生や前の老爺へ海苔巻を分けてやったり飴玉を勧めたりした。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄菓子屋へ行って一銭の飴玉を五ツ買って来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴玉と板昆布で露命をつなぐ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああとても倖せな手ざわり何でも買える触感うす皮まんじゅうも買える大きな飴玉が四ツね灰で磨いてぴかぴか光らせて歴史のあかを落してじいっと私は掌に置いて眺めるまるで金貨のようだぴかぴか光る二銭銅貨文ちんにしてみたり裸のへその上にのせてみたり仲良く遊んでくれる二銭銅貨よ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれからも、その先生の恩に報いるため、母にねだっては時々名物の飴玉を少しばかり送った。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーターの　みみなりは　ますます　ひどくなって、　めなんか　あめだまみたいに　はれあがって！",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
