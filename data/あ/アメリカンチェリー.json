          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカンチェリーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカンチェリーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカンチェリーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカンチェリーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカンチェリーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカンチェリーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカンチェリーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカンチェリーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカンチェリーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカンチェリーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカンチェリーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカンチェリーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンチェリーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカンチェリーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
