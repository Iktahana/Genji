          ],
          "literary": [
            {
              "text": "そのとき汗っかきとみえて豆絞りの手拭で汗拭きながら、その男は表の樋をつたって流れる雨音に負けないような大きな声で自分のほうが勝手にゲラゲラ笑いだした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗拭き／＼色々見て、レターペーパーを求める。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くて、汗拭き通し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "李逵は汗拭きの布を出して、鼻と口を抑えていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、笠なしはやりきれん」　汗拭きを出して、頭へのせた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "初瀬笠、かぶろうかい」「ようございますか」「ああ、よしよし」　銭を払い、すぐ汗拭きとかぶり代えて、立ち去りかけたが、また何を見たのか、急に戻って、笠売りの隣の木蔭に佇んだ。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
