        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨雪について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨雪という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨雪の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨雪が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨雪を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨雪について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨雪の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨雪の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨雪が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨雪という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨雪という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨雪についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨雪を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨雪は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨雪について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨雪が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨雪は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨雪の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨雪は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨雪は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ひさしと縁側を設けて日射と雨雪を遠ざけたりしているのでも日本の気候に適応した巧妙な設計である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨雪とって来てやろか。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュンセは松の木の枝から雨雪を両手にいっぱいとって来ました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来下谷は卑湿の地にして、西に湯島本郷の高地を負ふをもて、一朝雨雪の大に降るに会へば高処の水は自ら低処に来りて、下谷は一大｜瀦水地となるの観を呈す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吹山　　六九、二　　　　岐阜　　　四十、二敦賀　　　七二、八　　　　京都　　　四九、二彦根　　　五九、〇　　　　名古屋　　三〇、二　すなわち、伊吹山は敦賀には少し劣るが、他の地に比べては、著しく雨雪日の数が多い、名古屋などに比べると、倍以上になるわけである。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると其軍の大将が武力を用いれば何とでも随意に出来るけれど、好い大将である、仁義の人であると思われようとする場合には、寒風雨雪の夜でも押切って宿舎する訳には行かない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱や、寒冷や、雨雪や、飮酒や、日光直射や、異常の食物や、甚だしき飢や飽や、浴後の薄衣や、皮膚の不潔や、すべて病因たることは、盡く自己の判斷と、他の批判と、即ち一個的及び相互的の注意によつて、之を避けねばならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は暑さをも寒さをも夜闇をも雨雪をも厭わずに、衝動的に思い立って、それを買いに往くことがある。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱・寒冷・雨雪・飲酒・日光の直射・異常な食物・甚だしい飢え・飽食や浴後の薄着・皮膚の不潔等がすべて病因となることは、尽く自分の判断と他の批判と、即ち一個的および相互的の注意によって之を避けなければならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども星遷り世變り、之が洒掃の勞を取るの人なく、雨雪之れを碎き、風露之れを破り、今や塊然として土芥に委するも人絶えて之を顧みず、先人の功名得て而して傳ふべきなし。",
              "citation": {
                "source": "人生終に奈何",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日月星辰の運転、風雨雪霜の変化、火の熱きゆえん、氷の冷きゆえん、井を掘りて水の出ずるゆえん、火を焚きて飯の出来るゆえん、一々その働きを見てその源因を究むるの学にて、工夫発明、器械の用法等、皆これに基かざるものなし。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨雪の多い西｜蝦夷の空にとって、奇蹟のような小春日和があらわれたのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和宮廷の呪詞・物語には、みつはをただの雨雪の神として、おかみに対する女性の精霊と見た傾きがあり、丹生女神とすら、いくぶん、別のものらしく考えた痕があるのは、後入の習合だからであろう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨雪のことは、こちらが専門なのです」こういった水の神女としての誇りが、おもしろく昔の人には感じられたのであろう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "花月の夜、雨雪の窓を開けば、忽ち座を賑はすため、権家へ送与して媚を取るの具なるが、大抵七、八両より十四、五両までの値段なりし由」と。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末」十一、十二月に、少々降る雨雪で、役にも立たぬ。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋かけ、木賃宿、其れ等に雨雪を凌ぐのは、乞食仲間でも威張った手合で、其様な栄耀が出来ぬやからは、村の堂宮、畑の中の肥料小屋、止むなければ北をよけた崖の下、雑木林の落葉の中に、焚火を力にうと／＼一夜を明すのだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和宮廷の呪詞・物語には、みつはを唯の雨雪の神として、おかみに対する女性の精霊と見た傾きがあり、丹生女神とすら、幾分、別のものらしく考へた痕があるのは、後入の習合だからであらう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨雪の事は、こちらが専門なのです」かう言つた水の神女としての誇りが、おもしろく昔の人には感じられたのであらう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し今夜にも雨雪など降りて水冷えきらば、当分暫くは望みなし。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの中途半端の市街に対しては、風雨雪月夕陽等の助けを借るにあらずんば到底芸術的感興を催す事ができない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの中途半端の市街に対しては、風雨雪月｜夕陽等の助けを借るにあらずんば到底芸術的感興を催す事ができない。",
              "citation": {
                "source": "路地",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻より雨雪となる。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨眼鋭く人を射し、薄い唇は緊張まり、風雨雪霜に鍛え尽くした黝色の顔色は鬼気を帯び、むしろ修験者というよりも夜盗の頭領と云った方が、似つかわしいような面魂に二人はちょっと躊躇した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒中｜雨雪に歩行て冷たる人｜急に湯火を用ふべからず。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井はなくて、屋根が穴だらけなら、頭上の破風も、鬼が抜けたか、羽目は吹っ飛んで、居ながら青空や月星を仰げれば、寒風も雨雪も吹込み放題。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ難儀であったのは、冬の雨雪の時であった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が家にいるのは夜分か雨雪の日であり、家で明るい暖かい所は、炉端であったことを考えてみなければならぬ。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ実地に確かめてはいないのだが、この風は多分船路に便な、雨雪を伴わない晴れの風であったろう。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
