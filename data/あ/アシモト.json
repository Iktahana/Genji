    "definitions": [
      {
        "index": 1,
        "gloss": "at one's feet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "要太郎の指をさす通りにグサ／＼と下駄の踏み込む畔を伝って土手へ上ると、精の足元からまた一羽飛び出して高く舞い上がった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右から左から赤や水色の紫外光線が足元を掬う。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧巴里の遺物　オペラの辻を中心に、左右へ展開する大通とイタリー街のキャフェたちは、朝の掃除をしまって撒いた赭砂の一掴みを椅子やテーブルの足元に残している。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかい菩提樹の葉が粉のように顔や肩や足元に散りかかった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を見出すと、片息の鹿を女の足元に抛り出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は足元に投出された血だらけの矢の雄鹿を見ても愕かず、少しわきへ寄っただけであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでもそんな事を續けて行く内に、私の足元は一日一日と固まつて行つた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、瞬間にひよいと氣が附いて足元を堅めるだけで、また直ぐにひよろつき出すのであつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　人と荷を分けて積むため、自動車をもう一｜台たのむ事にして、幅十｜間と称ふる、規模の大きい、寂びた町の新しい旅館の玄関前、広土間の卓子に向つて、一｜休みして巻莨を吹かしながら、ふと足元を見ると、真下の土間に金魚がひらひらと群れて泳ぐ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもうだいたいできあがったと思うと、実はできあがっていないという証拠が足元から発見される。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元からすこしだらだら下がりになり萱が一面に生え、尾花の末が日に光っている、萱原の先きが畑で、畑の先に背の低い林が一｜叢繁り、その林の上に遠い杉の小杜が見え、地平線の上に淡々しい雲が集まっていて雲の色にまがいそうな連山がその間にすこしずつ見える。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の学者の掘り散らした跡へはるばる遅ればせに鉱石の欠けらを捜しに行くもいいが、われわれの足元に埋もれている宝をも忘れてはならないと思う。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらず、わが国の映画界や多数の映画研究者・映画批評家はいたずらに西洋人の後塵を追蹤するに忙しくて、われわれの足元に数百年来ころがっているこのきわめて優秀なモンタージュ映画の立派なシナリオの存在には気づかないように見える。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その偉さにおいては釈尊に一目置くだけで、あとの十大弟子などは足元へも寄り付けません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蛙の絵なども気品の高さ、京やそこらの商売画描きなどは足元にも及ぶものではない。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元がふらふらする。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は幹男の足元に坐って、じっとうなだれていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元の明るいうちに、さっさと帰れ、帰れ！",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそっちこっち転々してみて、前後左右を見廻した果てに、いくらか人生がわかって来たし、人間の社会的に生きて行くべき方法も頷けるような気がして、持前の圭角が除れ、にわかに足元に気を配るようになり、養子という条件で三村の令嬢と結婚もしたのであったが、内面的な悲劇もまたそこから発生しずにはいなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが次の瞬間には、足元の白く乾いた砂の上に、襟巻のやうなものが、おつぽり出されてあつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると船頭は、良寛さんの足元にばたつと平伏したので、良寛さんはびつくりした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして銀座の散歩も、もう歩き足り、見物し足りた気怠るさを、落した肩と引きずる靴の足元に見せはじめた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら妙な腰つきで川底の砂利を踏みにじり、皆がその足元を見つめているすきを狙ってまたも自分の腹掛けから二文ばかり取り出して、「おや？",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っている自分に、寂しさが足元から上って来るのを、しみじみ感じながら。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人の足元を見やがるな。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも足元の確かでない程に酔つたのは目賀田であつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは師匠の方針によって私立大学だけは卒業し、この点インテリ芸人として花柳界の他の幇間は足元にも及ぶものはない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（空を仰ぎながら）こりゃとても明るい月明り、お上人さま足元をお気を附け遊ばしませ』蓮如『幸子坊が何のてんごうを申すことやら、………然し此の世の中は辛いところだ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したが、あなたさまは何で先程からわたくしの足元ばかりご覧じてでございます。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら丁度あしもとの砂に小さな白い貝殻に円い小さな孔があいて落ちているのを見ました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
