        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝明けの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ただ朝明けの雪を楽しみつつ客を迎える温恭な気持ちでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "快い朝明けだつたが、洋燈のホヤをこわして不快になつた、ホヤそのものはヒビがはいつてゐたぐらいだからちつとも惜しくはないけれども、それをこわすやうな自分を好かないのである、もつとくはしくいへば、こわす意志なくして物をこわすやうな、不注意な、落着のない心持が嫌なのである。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれかと云って空中でもないが、不思議などうどうと云う譬えば遠い海鳴か、山のむこうの風の音とでも云いそうな音が、その日の朝明け比から始まってその日は終日聞え、夜になってもまだ聞えていたが、何時の間にか止んでしまった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝明け方に見た夢の、扨も不思議さ面白さ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早すぎるけれど起きた、うつくしい朝明けだつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかな朝明けだつたが、寒すぎる春寒である、小雪がちらついた、私はまた／＼綿入をかさねたことである。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝明けの風景はうつくしくたのしかつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時すぎには起きた、おだやかな朝明け。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夜通しうなされるように過し、翌朝明けると起きて屋敷川で顔を洗った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝明けの澄み切った空気を吸ったり、皮膚の赤くなるほどになったりすると、一時に健康を増すように思われる。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうちに私はそういう朝明けが何んとも云えずに寂しいような気がして来て、そっと起き上ると、何をしようとしているのか自分でも分らないように、まだ暗い隣りの病室へ素足のままではいって行った。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この朝明けも緑いろの光の条も湿っぽい空気も濡れた長靴を穿いた人々も、自分の生活にとっていりもせぬ、よけいなものに思われ、窮屈でならなかった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや明朝明けの鐘と共に鬼王丸の若い寵姫になられる筈でござります」地下道をゆく　それを聞くとオースチン師は思わずハッと顔色を変えたが、すぐに一層冷静になり、グッと白虎太郎の顔を睨み、相手の頭上に両手を延ばしそれをグルグル廻わしたが、これぞ眠りを深くする術で催眠術の一手なのである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふうむ、明朝明けの鐘と共に鬼王丸めは芳江姫を妾にするというのじゃな。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝明けのことです。",
              "citation": {
                "source": "曲馬団の「トッテンカン」",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、道中「上り」「下り」の唄　お江戸日本橋の道中うたは、本文通り日本橋を朝明けの七ツ（四時）に立つて、高輪へ来てちやうちんの火を消す。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に迫る霧の色かも朝明けの山のはざまに靄こめて、動かずにゐる　ひやゝかさかも軽井沢を過ぐ山々は朝明け来つゝ、山の家の高き垣内に　鶏動く　見ゆ海ぞひに　松山長く続きたり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに――三月二十四日の朝明けは、まだ冷たくほの暗いころ――容態が変わり、不安の廷臣たちは、病床の上に身をかがめながら、もう一度、あの解き難い謎の魂が、彼らから、すらりと身をかわし去るのを見た。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限の廣大な開示は、朝明けの壯觀は、終つてしまつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常より早く目を覚まし、畑地を一廻りして来た私はほのぼのと天地を包んでいる薔薇色の靄や、裸の足の上に朝露をはね上げて、生々としている雑草の肌触り、作物や樹木の朝明けの薫りなどに、どのくらい慰められたことであろう！",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずあすの朝明けない内に、暇乞いをせずに、ここを出て行って、寂しい所へ死ぬる日の来るのを待ちに行くとする。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、今朝明け方、僕は夢を見たのですよ。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝明け方に眼が覚めてみたら誰かが運んでくれたのだと見えてベッドに寝ていた。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し積もるという程もなく歇んで、夜空は星をちりばめたように晴れるが、朝明けにはまた降りだしている、そういう日がつづいて、道の端や家のうしろや日蔭のそこ此処に、冰ったまま溶けない雪がしだいに面積を弘げていった。",
              "citation": {
                "source": "日本婦道記",
                "author": "藪の蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年十二月　　接吻の時薄暮か、日のあさあけか、昼か、はた、ゆめの夜半にか。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年五月　　あかき木の実暗きこころのあさあけに、あかき木の実ぞほの見ゆる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
