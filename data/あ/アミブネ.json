        "examples": {
          "standard": [
            {
              "text": "私は毎日網船について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網船という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網船の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網船が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網船を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網船について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網船の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網船の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網船が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網船という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網船という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網船についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網船を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網船は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網船について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網船が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網船は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網船の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網船は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網船は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "茗渓より下○稲荷河岸は小船への乗り場揚り場として古き人の能く知るところにして、美倉橋下左衛門橋浅草橋柳橋附近には釣船網船その他の遊船宿多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "網船頭なぞというものはなおのことそうです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や、その蘆の中に並んで、十四五艘の網船、田船が浮いて居た。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれはゆうべのことで、神田川の網船屋の船頭の千八というのがおなじみの客をのせて隅田川の上の方へ夜網に出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、親方はいるかえ」　船宿といっても、ここは網船や釣舟も出す家であるから、余りにしゃれた構えでもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "網船を※って一日楽しく遊びましょう。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に尻端折の男一人片手を上げて網船賑ふ河面の方を指さしたるは、静に曇りし初夏の空に時鳥の一声｜鳴過ぎたるにはあらざるか。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、一日おいて次の夜、佐竹の家臣で、相当腕のたつ武士が、これもやはり、同じように咽喉を斬られ、越前堀の『船松』という網船の横丁の溝の中で死んでいた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代は徳五郎と言いましたが、七年前、川崎へ行ったまま行方不明になり、持物は品川の海へ浮んでいたので、網船でも出して溺れたのだろう、ということになりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "招く骸骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「釣船のやうだが――」　駒形から上流｜即ち宮戸川の區域は、昔から殺生禁斷で、釣船、網船は滅多に見かけず、寮の中の潮入の池に繋いであつても、殺生を目的の船は妙に眼につきます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ぼくはもう、金毘羅さんやこい、うちの網船で、三べんもいったから、いきません」　森岡正がそういってきた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
