      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日改めるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改めるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改めるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改めるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改めるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改めるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改めるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改めるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改めるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改めるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改めるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改めるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改めるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改めるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改めるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改めるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改めるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改めるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改めるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改めるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これを治療するにはやはり余裕のある人を模倣する事によって習性を改める外はない」と論じている。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は彼の言葉で注意されても子供を取扱ふ態度を改める様子もなく、黙つたまゝで、無益にも踏みはぐ夜着を子供に着せようとしてばかりゐた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからこの制度を改めるに非ずんば、千万言を費しても文化の普及と云ふことは駄目であります。",
              "citation": {
                "source": "農民文化といふこと",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更つての話とは何事だらうと、私も俄かに形を改めると、大佐は吸殘りの葉卷をば、窓の彼方に投げやりて、靜かに口を開いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "店番をしながら、店頭装飾を改める。",
              "citation": {
                "source": "白い路",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄のトライチケを今迄通りに見てゐれば、視線の角度を改める必要も手数も要らないで、すぐ彼と今度の戦争との関係が解るのである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、みんなでその原因を検討し、改めるべきは改めて、円満解決を計ったらいいのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亂食家だつたならムラ食を改めるがよい。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といふに散る氣の習を改めようにも何にも、既に其の氣が竭きかけて居るのでは、たとへば散財の習慣の付いて居るのを改めて遣らうと思つても、改めるにも改めぬにも、先づ既に其の財が竭きかけて居るのでは仕方が無いやうなものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に乱輪の花弁を弾きかけるとそのまゝ、空に浮き、五彩七彩と意表の外に面貌を改める妖変自在な天華。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ飛び出すのだ、何しろ訪ねて見ようと銀之助は先づ懐中を改めると五円札が一枚と余は小銭で五六十銭あるばかり。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その位の元気があれば、大丈夫だ」　そして、急に声を改めると、「――ところで、些か変なことを訊くようだが、貴公、忍術のほかには何も出来ぬのか」「風邪をひくことも出来る。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光団解散後の北海所見はいずれ機を得て稿を改めるつもりである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、この場でさう云ふことはお互に云ひツこなしとしましよう」と云ひながら、老人はまたお政さんが獨りでねむさうにしてゐるのに呼びかけ、茶を改めるやうに命じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川が、夫人に対する態度をよく知っており、それを改めることが、前川にとって不可能であると思われるだけに、夫人にすべてが知られてしまった現在では、前川と自分との交際も、これが最後であると考えねばならなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大都市を去り田舎へ引き払うか、もしくは今の生活を根底から改めるか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすると、わたしは罪を悔い改めることができなくなりますからね。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の注意を受けてもそれでも改めることをしない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらを考えてみると、忠利が自分の癖を改めたく思いながら改めることの出来なかったのも怪しむに足りない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "字音に隱れて居るから之れを改めることは容易だと云つてありまするけれども、字音に隱れて居る程ならば改めないでも宜しいかも知れないと云ふ一方には理由が立ちます。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は假名遣は發音的に改めると云ふことを爲し得るものである。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "友信が大兵で、ひどく力の強いことを右衞門八は知つてゐたので、いく地なく舟を改めるには及ばぬと云つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という事務員の声が聞えて、「かねて問題になって居りました助手さんのお化粧に就いて、ただいま助手さんたちから自発的に今日限りこれを改める由を申し出てまいりました。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱食家だったならムラ食を改めるがよい。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例に依って例のような旧い運命に生け捕られたくないならば、旧い状態を改めるほかないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし身体を弱くする原因が何であるかを知りながらも、之を改めることが出来ないような、意志が弱くてそして身体が弱くては、気の毒ながらその人は自分を新にする事が出来難いのであって、従来通りの状態を脱する事は出来ない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというと散る気の習癖を改めようにも既にその気が尽きかけているのでは、例えば散財の習癖の付いているのを改めてやろうと思っても、改めるにも改めないにも、先ず既にその財が尽きかけているのでは仕方がないようなものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして一遍汚れた以上は、それに対する十倍の徳を行つても、その汚れたのを汚れざる者に改めることは到底出来んのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年ほど前読んだ、ラ・フォンテーンに、「荷鞍」と題した詩ありて、確か亭主が妻の身に驢を画いて出で帰り来って改めると、わが画いたのと異ってその驢が荷鞍を負い居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "折節年末の煤払いして屋根裏を改めると、棟木の間より杉原紙の一包みを捜し出し、見るにかの年玉金なり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
