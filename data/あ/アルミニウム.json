        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルミニウムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルミニウムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルミニウムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルミニウムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルミニウムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルミニウムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルミニウムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルミニウムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルミニウムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルミニウムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルミニウムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルミニウムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルミニウムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルミニウムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "途中の淋しい小驛の何處にでも、同じやうな乘合自動車のアルミニウム・ペイントが輝いて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚水中にアルミニウムの電極を入れて電流を通ずれば、過酸化アルミニウムを生じ、これが種々の汚物に結合して固まってしまう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒の外側はアルミニウムペイントで御化粧をしてあるが、金属製だかどうだか見ただけでは分らない。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽にはいったまま腕をのばし、水道のカランをひねって、備付けのアルミニウムのコップで水を幾杯も幾杯も飲んだ。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は、私にアルミニウムのコップを、だまって渡した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどアルミニウムだかマグネシウムだかの閃光は光度において大きく、ストロンチウムだかリチウムだかの炎の色は美しいかもしれないが、始めからおしまいまでただぼうぼうと無作法に燃えるばかりで、タクトもなければリズムもない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際器内の水の運動を水中に浮遊するアルミニウム粉によって観察して見ると、底面から熱せられた水は決して一様には直上しないで、まず底面に沿うて器底の中央に集中され、そこから幅の狭い板状の流線をなして直上する。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋マッチが一箱、二インチほどの獣脂蝋燭が一本、ＡＤＰ印のプライヤ製パイプ、長刻みの板煙草を半オンスばかり詰めた海豹皮の煙草入れ、金鎖の付いた銀時計、ソヴリン金貨五枚、アルミニウムの鉛筆入れ、書付け数通、ワイス社（ロンドン）の刻印がある細小で硬い刃の象牙柄ナイフが一振り。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃が重い、背嚢が重い、脚が重い、アルミニウム製の金椀が腰の剣に当たってカタカタと鳴る。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、試験休みか春休みか」と我知らず口に出して言って、五、六間無意識にてくてくと歩いていくと、ふと黒い柔かい美しい春の土に、ちょうど金屏風に銀で画いた松の葉のようにそっと落ちているアルミニウムの留針。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は手を挙げたまま、そのアルミニウムの留針を持って待っている。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「譬えば此の温泉の湯は化学的に分析すれば、硫酸と硫酸カルシウムと硫酸ナトリウム、硫酸カリウム、塩酸、硫酸アルミニウム、硅華硫酸鉄、まアそんなものだが、それは人体にとってはどうでも良いので、必要なのはこの温泉が果して病人に効くかどうかということだ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのが一巻の感光膜でして、それを鉄管から動力線までの垂直線より少し長めに切って、その全長に渉って直線に一本引いた膠剤の上に、アルミニウム粉を固着させておいたのです。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その径路を説明すると……、鉄管の端に集った水滴が感光膜の上に伝わり落ちますが、ツルツルしたセルロイド面からは滑り落ちて、凹凸のあるアルミニウム粉の上にだけ溜ります。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてついに伸び切った時、アルミニウム粉の線の末端が、動力線の被覆を傷つけた個所に触れるのですから、否が応でも瞬間電流が塔上の大鐘にまで伝わらなくてはなりません。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「食べんの、厭……」私はおばあさんが私の傍で小さなアルミニウムのお弁当箱をあけようとするのを邪慳に遮った。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の生徒たちは私と同じような小さなアルミニウムのお弁当箱をひろげて、きゃっきゃっと言いながら食べ出していた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルミニウムの鑛釜は今だに損なものと思はれて居ります。",
              "citation": {
                "source": "佐渡が島から",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――火の利用、機械の利用、石・木・銅・鉄・アルミニウムなどを用いて、また蒸気・電流・電波などを用いて――。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば石油の埋蔵量は地球全体であといくらある、石炭はいくらある、鉄は、アルミニウムは？",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが戦争が始まってみると、予想以上に物を食う戦争となって、資源を手に入れるつもりだったのが、ごらんなさい、元も子もなくなって、お弁当箱のアルミニウムがない、台所に使うフライパンがない、石炭がない、電力がない、おまけにお金もなくなってしまったというざまだ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりウラニウムか」「さあ、もしかしたらアルミニウムのような軽い原子じゃなかろうか」「でもそんな小さな原子じゃ、解放される力も小さいだろう」「しかし、ウラニウム原鉱は地上に少ないよ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはレントゲン線濾過板の銅とアルミニウムとを取りちがえたときの出来事で、治療室勤務の者がたいてい一度は経験したものだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅の濾過板を使うべきところをアルミニウムの濾過板を使ったなら、うっかりすると、いわゆるレントゲン皮膚炎を起こす危険があるのだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "お竹が、同情をしたように、このアルミニウムの湯沸かしは、町から買われて、この家にきてから、すでに久しい間働いてきました。",
              "citation": {
                "source": "人間と湯沸かし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
