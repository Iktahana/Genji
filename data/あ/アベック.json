[
  {
    "uuid": "c90df5a1-0da3-5cb1-afc5-3034421437c6",
    "entry": "アベック",
    "reading": {
      "primary": "アベック",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
