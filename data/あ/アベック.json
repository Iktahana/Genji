        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(romantic) couple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アベックについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アベックという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアベックの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアベックが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アベックを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアベックについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アベックの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアベックの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアベックが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アベックという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアベックという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアベックについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アベックを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアベックは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アベックについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアベックが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアベックは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアベックの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アベックは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアベックは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アベック、素敵じゃないの。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん」　鼻の先で笑って、「アベックは旅に限るよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員は同伴、アベックに限るのよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムの夏子も、誰かとアベックでリベラルクラブの発表会へ行ったのか、店にはいなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、芳ッちゃん、いいだろう、アベックで泊めて貰おうよ」　アベックで――という言葉に芳子は微笑して、「泊って……それから……明日はどうするの……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのおかげで、五百円のもうけだ」「なんの話だよ」「十五分以内に、この道を何組のアベックがとおるか賭けててよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかしたら誰か若い人とアベックだかも知れないという畏れもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の街のアベックのように、未婚の者の美しい恋愛は、遠くからみていても、けっして厭なものじゃない。",
              "citation": {
                "source": "恋愛の微醺",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当温泉はアベックの好適地、また心中の名所ですが、まさか先生、生き残りの片割れではありますまいな」「ヤ。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅館は部屋の造りが新婚旅行とかアベック向きにできていて湯殿も便所も附属して独立しているから、我々の仕事部屋にも都合がよかったが、土曜日曜になると、やっぱり団体がおしかけてくることが多い。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど非番で家に居たから、洋装させて、同じ事務所の社員男女が会社をひけて帰宅の途中というアベック姿。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アベックは別のホテルへいらっしゃい。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、近代に於ては、アベック用のホテルと、睡眠用のホテルと必ず二つが必要なのである。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば閑静の道をと音無川の清流に沿うて歩くと、暗闇にうごめき、又はヌッとでてくるアベックに心胆を寒からしめられる。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東のアベックは今も同じところにうごめいているのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東という平和な市には、深夜にうろつくのはアベックばかりだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうアベックがうろついては、泥棒もうろつけないに相違ない。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野で危害をうけるのはアベックだそうだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "アベックはジャングルを荒すばかりで、一文のタシにもならないからだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "物好きのアベックでもやらんという実に色気のないものだったね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物園となると、わずかばかりのアベックの散歩用に使われているだけだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土地にきてはアベックなどはダラシがなくてミジメそのものの存在さ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからアベックは仕方がない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その頃寄席へ行って名人上手の至芸に接するたび、つくづくアベックで聴きに来ている人々がうらやましかった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、そのごとく寄席ファン時代はアベックで名人たちを聴くことに憧れつづけ、次いで自分が高座へ上がるようになってからは何とか高座の人を情人として、なるべく彼女の上がった直後の高座へ上がりノメノメとしたことを言いたいなどと「湯屋番」の若旦那さながらの愚かな夢想を抱きそめた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてそこの寄席に、美貌なるアベックの寄席ファンでも見出すならば、なおさらである。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治九年八月末のことだからいまはその温泉の辺り、絶好なアベックのハイキングコースともなつてゐよう。",
              "citation": {
                "source": "落語家温泉録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内書に「東京以北唯一の繁華街」と記されている札幌の狸小路は、開拓使時代よなよな官員をばかす雌狸たちが出没したのでその名があるということだが、いまはもっぱら米兵アベックの闊歩場と化している。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらめて、馬具屋めざして、狸小路を西に歩けば、米兵アベック、また米兵アベック。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
