        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗ごなしについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗ごなしの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗ごなしが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗ごなしについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗ごなしの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗ごなしが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗ごなしという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗ごなしについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗ごなしは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗ごなしが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗ごなしは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗ごなしの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗ごなしは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗ごなしは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "四邊には既に刻める柱頭あり、粗ごなししたる石塊あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
