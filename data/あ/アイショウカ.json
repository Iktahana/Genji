[
  {
    "uuid": "b56a8f4b-544c-52ce-9ca7-9cea5cf65a48",
    "entry": "愛唱歌",
    "reading": {
      "primary": "あいしょうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "song one likes to sing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛唱歌は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛唱歌が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛唱歌に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛唱歌が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛唱歌について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛唱歌についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛唱歌について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛唱歌が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛唱歌が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛唱歌は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛唱歌は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛唱歌を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛唱歌をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛唱歌が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛唱歌の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛唱歌を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛唱歌に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛唱歌について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛唱歌は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛唱歌を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "眼をほそくし、何ともいえない単純な、平和な、眠たい幼子の歌うような声で、“In Happy Moments Day by Day”という、彼の愛唱歌の節ばかりを口吟み始める。",
              "citation": {
                "source": "一つの芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
