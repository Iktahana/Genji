[
  {
    "uuid": "205d1316-74fb-500a-9345-0f0c050a7fdd",
    "entry": "彼等",
    "reading": {
      "primary": "あれら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
