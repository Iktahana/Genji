    },
    "definitions": [
      {
        "index": 1,
        "gloss": "those",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日彼等について考えている。",
              "source": "幻辞"
            },
            {
              "text": "彼等という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は彼等の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には彼等が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "彼等を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは彼等について学習した。",
              "source": "幻辞"
            },
            {
              "text": "彼等の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は彼等の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では彼等が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彼等という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に彼等という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では彼等についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "彼等を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彼等は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "彼等について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では彼等が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彼等は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により彼等の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "彼等は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に彼等は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼等は、自分が自分の主人たり得てはゐない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もひどく無頓着だつた彼女は、彼等との交際も余りしなかつたのではあるが。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の作品を見るに、その制作心理過程に於ては少しも前世紀人と別に変つたものを所持してはゐないし、制作心理過程に於て変らぬものが新しい精神を抱いてゐたとしてもその作品の上では実質的な何の新しい精神をも実現してゐるわけではないのである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世、彼等の作品が手法を解放したといふ位の事は考へられるであらうが、それ以上のことが考へられようわけはない。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰つて来て、彼等の身体検査をしてみますと、そのうち二十名がイヤな病気に冒されてゐました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の文芸部か何かで我鬼大将になれた、といふやうなことが彼等の運の始まりで、適度にでしやばりで、適度に野暮ッたいといふ彼等のえてして持つてゐる性質が、偏狭で、自信のない文壇といふ小主観国にどうかしたはずみには顔を出すといふ運びとなるのである。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてはまだも少し突きたい欲望が残つてゐたわけなので、猶も勝負を続けたが彼等の勝手決めな観念がみす／＼自分に向つて放たれ、そして私以外の三人の間では立派に通用しつゝあるのをみると、イヤな気がして来たので、恰度十三回目が終ると、其処を出てしまつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等には、私がともあれ興味を以ては突いてゐたのが見えないのだ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は貴族とエゴイストとを罰するために彼等の心から愛憐の芽生をぬき去つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ、彼等の表現の多くは、乞食壮士の大道演説に類したものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そうした彼の習慣は、普通に多くの西洋人が、彼等の風習によってするごとき、単なる形式的のものではなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は詩の鑑賞家であると共に、自分自身がまた詩を持つてゐる作家である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等と交はることは、私にとつてちがつた宇宙への觀察だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は決して、そんな意地惡き觀察をしてゐるのでない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村氏が、獨り彼等の中での例外だつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の考え出すいろいろな革新は僕の周囲に死の機会を増し、彼等の説くところは僕を死に導き、または彼等の定める法律は僕に死を与えるのだ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "セザール・フランクが、或はスクリャビンがやつたあの旋廻は、蓋し彼等の抽象情緒の周囲を旋廻したのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くにして彼等も倦怠を覚えてゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼等は迷つてゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃人々は、「唯物、々々」と云つてゐるが、彼等がさう云つてゐる時くらゐ唯心的なものはないやうである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も彼等を黙させるに到るものは、多分良い作品の誕生が盛んになつて来ることのほかにはない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは彼等だとて全然の空言は吐かぬやうになるものだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最初から聞いた者がやはり自分と同じ訝しさを抱いたことを知つた時、彼等は妥協の笑ひに顔を見合せた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は何れも勇立つてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓の彼等は小さいながらブルヂョアの我々の家の中といふものが、それでなくても好奇の目を視張るに十分な対象だつたのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の所猶概して印象の羅列以上のことを為し得てゐるとは思へませんが、あれらの努力が何時の日か一個完成したものに迄到達しないものではありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――）　　　　　　　※　さうしてよき心の人よ、あれら手際よい技能家や学者等を恐れたまふな。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれら魂が稀薄なために、夢が浅いので歯切れが好いばかりだ。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
