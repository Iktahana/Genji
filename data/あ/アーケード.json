        "examples": {
          "standard": [
            {
              "text": "私は毎日アーケードについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーケードという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーケードの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーケードが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーケードを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーケードについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーケードの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーケードの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーケードが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーケードという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーケードという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーケードについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーケードを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーケードは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーケードについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーケードが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーケードは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーケードの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーケードは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーケードは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "きみは三方からアーケードに取りかこまれています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまは、りっぱなお城や、お寺や、アーケードなどを、つぎからつぎへと、たてさせました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらには、アーケードゲームと呼ばれる業務用のゲーム機という伏兵もいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマ水道に似たウイン水道の大溝渠が小さい 〔Mo:dling〕 の往来を圧してアーケードになって居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうなるのか知らないが、成行に任せるほかはないと、覚悟のようなものをしかけたとき、地階のアーケードへつづく横手のドアから大貫が入ってきた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子たちの背たけより高い石の外羽目が切れたところが、城門のようなアーケードになっていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重々しいそのアーケードの奥がちょっとした広場めいた場所だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子たちが、そこから入って来たアーケードとは反対の広場のはずれに、一軒のカフェーと、短い家なみをなして店鋪が並んでいる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧自動車はそれから東へ東へととって肉市場スミス市場のアーク燈に照らされた白い鉄骨アーケードの下を徐行した。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パドヴァ大学の建物の中庭は美しいアーケードで囲まれていて、壁と天井は至るところ以前の学生たちの系統図や盾で覆われていて、その多くは華麗に塗られている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の入り口反対側にあるアーケードに立って左に向かって２番目の柱の頂上を見ると、この区切りの一番最後に４年のあいだパドヴァの学生であったイギリスの若い紳士ウィリアム・ハーヴィのステマタがある（第84図）。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーケードのついた明るいマーケットふうの通りができ、その道路も、固く鋪装されてしまっている。",
              "citation": {
                "source": "夏の葬列",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いながら、彼はアーケードの下の道を歩いていた。",
              "citation": {
                "source": "夏の葬列",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、ご馳走してあげるわ、好きなものをおっしゃい」ふくれっつらの私にもたれかかり、真理子はさも愉しそうにアーケードふうの屋根のついた市場じゅうを歩きまわった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にウンザリしながらも、誘い出したのが身の不運と諦めて、私は苦虫を噛み潰したような顔をして、アーケード伝いにホテルの酒場へはいり込んだ。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "実ハ帝国ホテルノアーケードノ店ニアルノヲ見付ケテアルノヨ、ドウシテモコレニシヨウト思ッテ」「イクラダ」「三百萬圓」「何ダッテ」「三百萬圓」「冗談ジャナイ」「冗談ジャナイワヨ」「差当リソンナ金ハナイ」「知ッテルワヨアタシ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中はけたたましく鳴る呼び鈴が取り付けられた透かし戸を通してメゾン・ヴォーケの外に目をやると、道路の反対側にカプチン病院[3]が見え、近所に住む芸術家によって緑の大理石に愛をテーマにした絵が描かれたアーケードを見ることが出来る。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
