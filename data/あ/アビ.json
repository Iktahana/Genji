        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿比について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この阿比は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "阿比の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が阿比について知っています。",
              "source": "幻辞"
            },
            {
              "text": "阿比は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は阿比の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "阿比に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では阿比が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から阿比を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "阿比の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも阿比が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では阿比が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "阿比について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも阿比は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも阿比は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で阿比は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に阿比について学びました。",
              "source": "幻辞"
            },
            {
              "text": "阿比の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する阿比の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では阿比の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三　天皇は、はじめ日向においでになりますときに、阿比良媛という方をお妃に召して、多芸志耳命と、もう一方男のお子をおもうけになっていましたが、お位におつきになってから、改めて、皇后としてお立てになる、美しい方をおもとめになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、散歩に出たらプレッツ・ファルマシイの前で阿比留君に出合ふ。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿比留君のその別莊の裏には大きな樅の林があるが、今日はあんまり暑かつたので、鶯がその木蔭から出られずに一日中啼いてゐたさうである。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ボオイたちもその二人には特別に丁寧にしてゐるのでどんな人かと思つてゐたが、阿比留君がよく知つてゐてさういふ素姓をあとで聞いたのである。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿比留君と一しよに｜本通りをぶらぶらする。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿比留君は阿比留君で、白いベレ帽の方をこれまで何度も見かけたといふ。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は阿比留君に別れて、そんな謎めいた氣持を抱いたまま、百合のぷんぷん匂つてゐる裏門からホテルに歸つてくると、ホオルの片隅に例のドイツ人がひとりで氣むづかしい顏をしてビイルを飮んでゐた。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、阿比留信君來訪。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速阿比留君をつかまへて、けさの出來事を話して聞かせる。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから阿比留君が話を引きとつたが、なんでも君達が數年前借りてゐたコッテエヂには、屋根裏に小さな蝙蝠が棲まつてゐたこともあつたさうだ。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　夕方、阿比留君が歸つてから、僕は霧のために早目に薄ぐらくなり出した小屋の中に、いつまでも燃え殘りの火を守りながら、ぼんやりとしてゐた。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿比留君の話では、蛇は脱皮する前に、かならず半睡状態に陷つてあらゆる動作がきはめて鈍くなるのださうだ。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔大物主の神の御子〕　かれ日向にましましし時に、阿多の小椅の君が妹、名は阿比良比賣に娶ひて、生みませる子、多藝志美美の命、次に岐須美美の命、二柱ませり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に神櫛の王は、木の國の酒部の阿比古、宇陀の酒部が祖なり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にカムクシの王は木の國の酒部の阿比古・宇陀の酒部の祖先です。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記伝』巻八などには、『日本紀』の全巻を通じて、爾波那比、爾波能阿比、爾波那閇、爾波比、爾比閇などの読法があることを列記しながら、独り「爾比那閇」をもって正とし、他はみな正しからずと決定せられたのは、いささか専断の嫌いがあった。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓前花堆うして香煙空しく迷う塔婆の影、木の間もる日光をあびて骨あらわなる白張燈籠目に立つなどさま／″＼哀れなりける。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝあつて謝源はニヨツキリとつつ立つたまゝ「恩知らずツ馬鹿ツたわけめツ」とあらゆる罵声を首のない二人の死骸にあびせかけて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の温泉でもさうであるが、浴槽に浸つて居ると、槽外の流しでからだを洗つて居る浴客がざあつと溜め桶の水を肩からあびる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩に一太刀あびせるが浅手である。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコは売あびせのために底値を入れた××新株の反撥を予想して買いあつめると、雑株安をねらって、引たたぬ××百貨店株を後場引値で、これを指名人に買わすとさっさと場内を引あげた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私達が體にあびて時に雀躍する處の、あの美しい太陽の光線ではないか？",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は血のついた軍刀をさげたまゝ、再び軍刀をあびせかけるその方法がないものゝように、ぼんやり老人を見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗島は、老人の傷口から溢れた血が、汚れた阿片臭い着物にしみて、頭から水をあびせられたように、着物がべと／＼になって裾にしたゝり落ちるのを見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は、大刀のあびせようがなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆をあげた舟、発動汽船、ボート、櫓で漕ぐ舟、それらのものが春のぽかぽかする陽光をあびて上ったり下ったりした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛や馬の群が、背に夕日をあびて、草原をのろのろ歩いていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上から、機関銃をあびせかけられたこともあった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　営門で捧げ銃をした歩哨は何か怒声をあびせかけられた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、不機嫌に、二人に怒声をあびせかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
