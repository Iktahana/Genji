              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "天空には星影一｜點、二｜點、又た三｜點、風死して浪黒く、船は秒一秒と、阿鼻叫喚の響を載せて、印度洋の海底に沈んで行くのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしき大地震、大火の爲に、大都は半、阿鼻焦土となんぬ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿鼻焦熱の苦悩から、手足がはり、肉を切こまざいた血の池の中で、悶え苦んで、半ば活き、半ば死んで、生きもやらねば死にも遣らず、死にも遣らねば生きも遣らず、呻き悩んでいた所じゃ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がいままで阿鼻叫喚で生きて来た所謂「人間」の世界に於いて、たった一つ、真理らしく思われたのは、それだけでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは忽ち阿鼻狂喚の巷！",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ吹雪に怪飛んで、亡者のごとく、ふらふらと内へ戻ると、媼巫女は、台所の筵敷に居敷り、出刃庖丁をドギドギと研いでいて、納戸の炉に火が燃えて、破鍋のかかったのが、阿鼻とも焦熱とも凄じい。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、硫黄の臭もせず、蒼い火も吹出さず、大釜に湯玉の散るのも聞えはしないが、こんな山には、ともすると地獄谷というのがあって、阿鼻叫喚が風の繞るごとくに響くと聞く……さては……少い女が先刻――（ここは地獄ですもの。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと気づかぬうちに潜り込んできたクソ虫が暴れだして以来の阿鼻叫喚、血と涙の今日に至る日々を振り返って、このオレがもっとも不幸だったのは「やられた」と観念した瞬間だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――）僕への打擲はまだしもそれがきぬに加へられるときは、阿鼻叫喚の凄じさがこの少女と四十女との間に、あらゆる秘術を以つて行はれたのである。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の可聴域の上限を突きやぶりそうな周波数で知子が絶叫し、あとはもう、どれがだれの声ともわからない阿鼻叫喚となった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はほかの非江戸ッ子……上は成金から下は乞食まで、あらゆる種類階級の人々と共に、一様に阿鼻叫喚の巷にさまようた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に阿鼻叫喚ともいうべき苦しみを凌いで、半分は夢中でどうにかこうにか場内へ押込まれて、やれ嬉しやと初めてほっと息をつくという始末。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした怖ろしい阿鼻叫喚のまん中へ飛び込んだ二人は、いくら物馴れていてもさすがに面喰らって、あとへも先へも行かれなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "下、阿鼻地獄に至り、上、阿迦尼咤天に至る。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "疼痛｜烈しき時は右に向きても痛く左に向きても痛く仰向になりても痛く、まるで阿鼻叫喚の地獄もかくやと思はるるばかりの事に候。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがぼくと別れ、女ひとりになったリエが、この世の阿鼻叫喚に忽まちまきこまれ、影も姿も消えうせる恐ろしさにぼくは堪えられぬ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々はめりめりと唸りを立て、歪められ、倒され、人々はその家の下に生き埋めにせられ、辛うじて遁れ出たものも狂犬のように吠えまわり走りまわり、かくて一瞬の間に文明の楽園は阿鼻叫喚の巷と化してしまった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻や叫喚七転八倒。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、打たれながらも、その沙門は、にやりと気味の悪い微笑を洩らしたまま、いよいよ高く女菩薩の画像を落花の風に飜して、「たとい今生では、いかなる栄華を極めようとも、天上皇帝の御教に悖るものは、一旦｜命終の時に及んで、たちまち阿鼻叫喚の地獄に堕ち、不断の業火に皮肉を焼かれて、尽未来まで吠え居ろうぞ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はその事を思う度に、阿鼻大城の暗の底へ逆落しに落ちさせらるる、あえかな姫君の姿さえありありと眼に浮んで来るのじゃ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は道ばたに咲き出た松虫草の花やひるがおの花に明るい陽光の降り濺いでる静寂の中に彳んで、阿鼻叫喚の修羅の光景を実感して見ようとしたけれども、あまりにも平和な今の環境は全くそれを不可能にした。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呻く者、泣く者、喚く者、縛られたまま転げ廻る者、呪詛いの声を上げる者、……部屋の内はそれらの声で、阿鼻地獄を呈していた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚といふやうな「音響効果」は、空襲の惨状を写すに、是非ともなくてはならぬものかどうか。",
              "citation": {
                "source": "空襲ドラマ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚とは、正に、その夜のことだったろう。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿鼻叫喚の声、器物の壊れる音――その中に嵐のように荒れ狂う銃声があった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチパチと木のもえさける音、ドカーン、ドカーンとひっきりなしに聞える炸裂音、そのたびに、蒼白い閃光が、パッと焔と煙をつらぬいて、阿鼻叫喚の地獄絵巻とはまったくこのことだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇佐美で身動きできなくなったが、網代でドッと押しこみ突きこみ、阿鼻叫喚、十分ちかくも停車して、ムリムタイにみんな乗りこんでしまったのは、網代の漁師のアンチャン連だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすればヤジウマの大半が終電事につめかけたわけで、罹災者の乗りこむ者も多いから、終電車の阿鼻叫喚が思いやられた次第であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓前花堆うして香煙空しく迷う塔婆の影、木の間もる日光をあびて骨あらわなる白張燈籠目に立つなどさま／″＼哀れなりける。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝあつて謝源はニヨツキリとつつ立つたまゝ「恩知らずツ馬鹿ツたわけめツ」とあらゆる罵声を首のない二人の死骸にあびせかけて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
