    "definitions": [
      {
        "index": 1,
        "gloss": "resting place between inn towns (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "時又は川添ひの間の宿で、一寸した料理屋が川端にある。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の永い間の宿念の力がとうとう彼女の仮面を剥がしたようにも思えた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の巧もないが、松並木、間の宿々、山坂掛け、道中の風情見る如し。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日坂は金谷と掛川との間の宿で、承久の宗行卿や、元弘の俊基卿で名高い菊川の里や、色々の人たちの紀行や和歌で名高い小夜の中山などは、みなこの日坂附近にある。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の宿で、世事の用は聊かもなかつたのでありますが、可懷の餘り、途中で武生へ立寄りました。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の宿で、世事の用はいささかもなかったのでありますが、可懐の余り、途中で武生へ立寄りました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝の下を、首のない躯と牛は、ふと又歩を緩く、東海道の松並木を行く状をしたが、間の宿の灯も見えず、ぼツと煙の如く消えたのであつた。",
              "citation": {
                "source": "雨ばけ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の宿とまでもいい難きところなれど、幸にして高からねど楼あり涼風を領すべく、美からねど酒あり微酔を買うべきに、まして膳の上には荒川の鮎を得たれば、小酌に疲れを休めて快く眠る。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕七時前｜間の宿久保に而藤原沢次郎へ著。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がまあ横瀬夜雨氏を訪ねたいと思っていたのは何という永い間の宿望だったろう。",
              "citation": {
                "source": "旧師の家",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その偶然の花火を見つめて、愉しみや、心配事をつくる、人間の宿命が、美津江にはかへつて慕はしいもののやうに思へた。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賄賂は定まり通り納めてあるので、皆無事に通るを得、次の間の宿で休息し、再び常の行装になって、旅行を続けたのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが此も、もうここ半月位で、多くの客の素通りして行く静かな山間の宿場に還るのだと思うと、内容は違うけれど、田山さんの作物にあった「再び草の野に」と言う表題が、胸を掠めた。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいうなる死は爰に、人のいうなる生は彼処に、しかも壮と厳と、美と麗と、人が自らせばめた社会の思いおよばぬものは、わが立つ所ならずして、いずれにあるのだろう、七時すぎ、浅間の宿についた。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きることは虚偽であるかも知れないのだ、だが、たとへそれが虚偽であるにしろ、生きねばならぬのが人間の宿命だ。",
              "citation": {
                "source": "井の中の正月の感想",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつらいことだがどうやら人間の宿命であるらしい。",
              "citation": {
                "source": "精神のへど",
                "author": "――手帳より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朝ことが間違へば強盗でも強姦でも殺人でも自殺でも、その他なんでもなし得るのが人間の宿命である。",
              "citation": {
                "source": "発病",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる場合に、われわれは、罪を政治にぬりはせず、人間の宿命のせつなさに思いを寄せ、無限の愛を寄せ、せめても、その愛によって、高まりたいとこい希うものである。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の徒は、犯罪を人間の宿命によせ、愛によって高まることを方法とするが、政治は人間の原罪に関するものでなくて、現実の、そして万人に公平に課せられた配給的なものである。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "品行不良でもかまわないから、人間とはいかなるものか、自分とはいかなる人間か、人間の宿命の悲痛さを、深く誠実に思い知り、罪の悲しさを知らねばならぬ。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは家の歴史であり、家に生れた人間の宿命であり、溜息であり、いつも何か自由の発散をふさがれてゐるやうな家の虫の狭い思索と感情の限界がさし示されてゐるやうな陰鬱な気がする。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "法本という人は、それはむろん欠点もあるし、人間の宿命としてのもろもろの悪は強く背負っていることは云うまでもないことだけど、しかし彼は人生的に一個の見事な芸術家だよ。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　マリ子とその家族は土間の宿直室へ戻って住んだ。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「生活の美しさ」とは、人間の宿命をはらんで、ひたむきに幸福を追求する努力と苦しみとの表現であらう。",
              "citation": {
                "source": "生活の美しさについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは家の歴史であり、家に生れた人間の宿命であり、溜息であり、いつも何か自由の発散をふさがれているような家の虫の狭い思索と感情の限界がさし示されているような陰鬱な気がする。",
              "citation": {
                "source": "石の思い",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の宿場らしい道を登って行くと、親子｜二人のものはある石垣のそばで向こうからやって来る小前の百姓にあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "投入れのひからびている間の宿。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宿屋の亭主は、あいつには一週間の宿料の貸しがあるから、あの悪党、どうかしてつかまえてやりたいと言っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は冒頭の序詞において暗示されているがごとく、人間の宿命を宗教と一致させてゆくところに独自の方向と認識を持っているもののように思われるが、しかし、物語の中にあらわれた人間関係、特に権力と寺院、戦争と天変地異に応対する庶民感情の動きに重点のおかれていることはいうまでもあるまい。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間の宿題で、本当に胸がスーとしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
