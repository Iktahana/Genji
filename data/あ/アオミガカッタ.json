[
  {
    "uuid": "3e097e41-9be4-5b33-b789-ea33071a427e",
    "entry": "青みがかった",
    "reading": {
      "primary": "あおみがかった",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
