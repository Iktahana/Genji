    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bluish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして所々に露出した山骨は青みがかった真珠のような明るい銀灰色の条痕を成して、それがこの山の立体的な輪郭を鋭く大胆なタッチで描出しているのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっと目星い品が視野から彼女を呼び覚すと、彼女の青みがかった横長の眼がゆったりと開いて、対象の品物を夢のなかの牡丹のように眺める。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすけた黄褐色の千切り形あるいは分銅形をしたものの、両端にぼんやり青みがかった雲のようなものが見える。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子どもは山羊の首から帯皮をとりながら畑の向うでかげろうにぎらぎらゆれている、やっと青みがかったアカシヤの列を見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳥は元気を取り戻して立ち上がると、のぼりくる太陽のほうへ、空の旅行隊の飛び去った青みがかった岸辺をめざして飛んで行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わたくしの口から申すも憚られますが、鼻筋｜凜々しく通り、眼は青みがかった黒い瞳で、口元の締り方に得も云われぬ愛嬌がございます。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんの額には、門跡様の白い青みがかった※なお手がかかっておりました。",
              "citation": {
                "source": "尼になった老婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とジョン・オープンショウは上着の懐を掻き探り、褪せて青みがかった紙を一枚出して卓上に置いた。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかったマックとＷｉｎｄｏｗｓ　ＮＴは、パッケージ・アプリケーションを部品化してパーソナルコンピューター文化を大型に拡張する形で。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄み切った月が、暗く濁った燭の火に打ち勝って、座敷はいちめんに青みがかった光りを浴びている。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや青みがかった白皙の面にきりりと自信のほどを示すと、右門は長刀をかるくひざに敷いて、黙然と駕籠をあげさせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかった燈の燭った室で己は黒檀の卓を前にして坐り、その左側に女が匂のあるような笑顔をしていた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くには士族地の一部の草屋根が見え、ところどころに柳の梢の薄く青みがかったのもある。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、四坪の凹地に浅い湧泉を湛え、その底から青みがかった灰色の火山岩の分解物からなる泥土を一分間に数回ずつ噴出し、そこここに所謂泥火山を円錐形に作り上げ、それが流れて裾野となる有様は、火山から熔岩の流出する趣きと異らない。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん程、気持ちの平らな、感じの好い人は、この世の中に二人といない位いですのに――」　このケリイに依れば、ルウスは又とない程美しい、青みがかった灰色の眼をして、睫毛と眉毛が長く、一種特徴のある魅力を備えているという、九年前にジュッド医師と結婚して、貧しいながら、実に仲の好い夫婦だったというのだ。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "剥げかけた白粉と生地の青みがかった皮膚とが斑になり、頸部から寝巻の襟のはだけた、やせた胸廓が黒く脂じみているのが不健康らしくはあったが、いい縹緻には相違ない。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昨夜、若い高等学校の学生の一群の席で、眼鏡をかけた元気のいい生き生きした髭などの少し青みがかった男が――それをすっかり忘却してしまっていたのであった！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかった室の壁と、室の前のささやかな茂みの多い小庭と、古びた板塀が、青空をひろく受けて、そこに静寂な単一な世界を湛えていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まん円くうち開いた眼の中の、青みがかった白目の縁に、ほろりと透明な水玉が出てきて、それをじっと押え止めるかのように、冬子はあくまでも眼を見開いていた。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳密にいうならば右の目と左の目でも同じ白いものも少し青みがかったり、赤みがかって違って自分には感じられているのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたるところに青みがかった岸の柳も旅するものの目をよろこばすころで、一大三角州をなした淀川の川口にはもはや春がめぐって来ていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかたみはシナからでも渡って来た陶器らしく、厚手の焼きで、青みがかった色つやまでがいやみのないものでした。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の近くには、小諸の士族屋敷の一部の草屋根も見え、ところどころには柳のこずえの薄く青みがかったのもあり、ちょうどわたしが出かけて行ったころはおそい春がようやく浅間のふもとに近づいてきた時分でした。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかった、虫の形をした石です。",
              "citation": {
                "source": "トム吉と宝石",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青みがかった穴のあいている石は、太古の曲玉であって、光るのは、ダイヤモンドでありました。",
              "citation": {
                "source": "トム吉と宝石",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが中国の昔の松煙墨は、いわゆる青墨であって、淡くしてみると、青みがかった透明な色をしている。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかった牛乳色の水面が上の方にあって、息が苦しくなってくると、何だかその水面が自分の頭の上で渦を巻いてるような形に見えた。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みがかった透明な鼠色をしている。",
              "citation": {
                "source": "画業二十年",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはその方向に、近くの緑の丘のあいだから、またそれを越して、地平線をなす青みがかった遠い、より高い山々をながめた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
