        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網戸について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網戸という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網戸の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網戸が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網戸を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網戸について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網戸の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網戸の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網戸が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網戸という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網戸という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網戸についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網戸を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網戸は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網戸について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網戸が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網戸は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網戸の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網戸は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網戸は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "虫除けの網戸を開けて戸をノックした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺飛んで星移り、当時は何某の家の土蔵になったが、切っても払っても妄執は消失せず、金網戸からまざまざと青竹が見透かさるる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、さう気がついて見ると、小さなガラスの窓は、鳥かごの顔、正面の網戸が、立派なチョッキと云ふわけでした。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸は二重戸になっていて土戸の次には金網戸があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめだよ、口端できいたふうな事を云ったって、からっきしだめじゃないか、しっかりおしよ」「へッ」　平吉はとぼけるように云って金網戸の錠を啓けた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金網戸は錠前も軽ければ戸も軽かった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼠が入るから、早く入って、お締めよ」「へい」　平吉は後から急いで入るなり、内から金網戸を締めた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広栄が入ると定七も入って金網戸を締めた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、ここへ来ればもうだいじょうぶといわぬばかりに、足音さえも高めて、須弥壇の横からどんどん奥へぬけると、かって知ったもののように、がらがらとそこの網戸をあけながら位牌堂の中へはいって、ぴたりとまた戸を締めきりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸もまた板戸ではなく網戸なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも知らないガキにもどったみたいだ」　だれかがエアコンのスウィッチでも入れたように、開け放した窓から、いきなり冷たい風が吹きこみ、網戸をがたつかせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所で、父は、とある荷物の中から、一つの網戸を引っぱり出し、それを床店の屋根に掛けました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて父も屋根に上り、さらに網戸を大神宮の拝殿へ掛け渡して逃げ道を作りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "網戸を伝って拝殿へ這い上り、其所からまた網戸を梯子にして大神宮様の敷き石の上へ降りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い金網戸の閉つた石段の上は、母が器物を取出しに行つて、錠前をガチヤ／＼言はせたところです。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い明窓のひかりでお婆さんは何か探し物をしていたが、やがて網戸をくぐって、土蔵前の階段を下りて来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は暗い金網戸の閉った土蔵の石段の上に立って、手にした大きな鍵で錠前をガチャガチャ言わせ、やがて彼を二階の方へ案内した。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の遺した蔵書を見るために母と一緒に暗い金網戸の前の石段に立った日のことなぞもまだ彼の眼に残っていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "来たが、満員で、隅っこにやっとハンドルを動している若者が、赧い顔をして何か断りらしいことを網戸越しに云った。",
              "citation": {
                "source": "七階の住人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷石を二、三段上って古板塀の板戸を明け一足はいると、真四角な、かなりの広さの地所へ隅の方に焼け蔵が一戸前あるだけで、観音開きの蔵前を二、三段上ると、網戸に白紙が張ってある。",
              "citation": {
                "source": "西洋の唐茄子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんぽんたんは夜泣きをして、父母の室から襖の外へ投りだされて、寒い室に丸くなって泣寝入りして、祖母に抱いていかれた夜から、ちゃんと心得てしまって、泣いて室外へ投りだされると、蔵の網戸のとこまで、そっと這ってゆくことを覚えた。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の硝子戸の中には高洒な、薔薇や蘭の花が並んでゐるが、こゝも網戸が降りてゐた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "網戸をおろした広い窓へ、白い蛾の群れが貼りついてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をくしけづり、粉白粉もつけて、また、急いで食堂へ戻つたが、網戸を叩く白い蛾の気忙はしい羽音だけで、広い食堂は森閑としてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "念入りに化粧をして、粗末な布地ではあつたが、白絹のワンピースを着て、朝の食堂に降りて行くと、牧田氏と、あの男が、網戸をあげた、広い窓辺でコオヒイを飲んでゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルで御座います」　ボーイが開けた網戸から追い出されるように飛び出した吾輩は、久し振りに眼の醒めるようなサルーンに直面させられて、少なからず面喰らった。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が私は、一二の人間の気を迎えるために、窓を閉めることもしたくないし、或は、窓に網戸を拵えることもしたくない。",
              "citation": {
                "source": "美醜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを人類に要求するのだ」「窓の網戸をてっぱいさせるんだ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこが悪いんだろうか」　電気を切ると、隆夫は金網戸を開いて、器械のそばへ行った。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
