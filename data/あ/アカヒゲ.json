        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "赤ひげの人は、なにかなつかしさうにわらひながら、ジョバンニやカムパネルラのやうすを見てゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげの人が、少しおづおづしながら、二人に訊きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方で Barbarossa が「赤ひげ」であるのも不思議である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとその人は赤ひげで西洋人なのです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげがぴんとはねて、歯はみんな銀の入歯でした。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　署長さんは落ち着いて、卓子の上の鐘を一つカーンと叩いて、赤ひげのもじゃもじゃ生えた、第一等の探偵を呼びました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげの人は、なにかなつかしそうにわらいながら、ジョバンニやカムパネルラのようすを見ていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげの人が、少しおずおずしながら、二人に訊きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげの人は、なにかなつかしさうにわらひながら、ジヨバンニやカムパネルラのやうすを見てゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの隅には痩た赤ひげの人が北極狐のやうにきよとんとすまして腰を掛けこちらの斜かひの窓のそばにはかたい帆布の上着を着て愉快さうに自分にだけ聞えるやうな微かな口笛を吹いてゐる若い船乗りらしい男が乗つてゐました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげがまるで違つた物凄い顔をしてピカ／＼するピストルをつきつけてはひつて来ました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先登の赤ひげは腰かけにうつむいてまだ睡つてゐたゆふべの偉らい紳士を指さして云ひました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのとこに居るやつも毛皮の外套を三枚持つてるぞ』『ちがふちがふ』赤ひげはせはしく手を振つて云ひました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一人づつだんだん出て行つておしまひ赤ひげがこつちへピストルを向けながらせなかでタイチを押すやうにして出て行かうとしました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思つたらあの赤ひげがもう足をすくつて倒され青年は肥つた紳士を又車室の中に引つぱり込んで右手には赤ひげのピストルを握つて凄い顔をして立つてゐました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげがやつと立ちあがりましたら青年はしつかりそのえり首をつかみピストルを胸につきつけながら外の方へ向いて高く叫びました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ひげは笑つてちよつと船乗りの手を握つて飛び降りました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの赤ひげは熊の方の間諜だつたね』誰かが云ひました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると二人は、ぎょっとしたように顔をあげて、あごに手をあててしばらくブドリを見ていましたが、赤ひげがにわかに笑い出しました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」赤ひげは、ブドリとおじいさんにかわるがわる言いながら、さっさと先に立って歩きました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雲の下で昔の赤ひげの主人も、となりの石油がこやしになるかと言った人も、みんなよろこんで雨の音を聞いている。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、おいらがなぐられてよ、『むこう傷のあかひげ』か――あっははは」　と、じょうだんをいった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
