    "definitions": [
      {
        "index": 1,
        "gloss": "Société des Artistes Indépendants",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンデパンダンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンデパンダンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンデパンダンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンデパンダンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンデパンダンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンデパンダンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンデパンダンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンデパンダンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンデパンダンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンデパンダンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンデパンダンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンデパンダンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンデパンダンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンデパンダンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アンデパンダンを何処かで企てゝゐるといふ話もきいたが、今の処ノバあたりでアンデパンダン的意義を極度に発揮して欲しいと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回日本アンデパンダン展批評宮本百合子　こないだ久しぶりで第一回日本アンデパンダン展覧会を見て、断片的ですけれども、いくつかの印象が残りました。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンデパンダンの日本画家たちは、日本画というものの屈辱的な運命を克服する使命があります。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ル・ゴフさんの処方で病気が癒つたので再びアンデパンダンの絵を観に行つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンデパンダンと云へば怪物の様な奇体な絵が多い様に想はれるが、実際は純正な絵が多く、純正なおとなしい絵が土台に成つて奇抜な新画を作らうとして居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夏徳永、澤木、晶子と四人で無駄話に気を取られて居て怖ろしい雷雨に遇つたのも其森だし、僕が新しく買つた絵具箱を画家然と提げて行つたのは好いが、絵を初めた第一日に出来上つた物をアンデパンダンだと同行の小林萬吾に笑はれたのも其森だ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、芸術上のアンデパンダンを尊重するが、尊重するが故に、日本演劇の現代アカデミスムの樹立を要望するものである。",
              "citation": {
                "source": "暫く黙せしめよ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミスムの樹立以前に、アンデパンダンの発展を望むが如きは、文化の推移の法則を無視したものである。",
              "citation": {
                "source": "日本に生れた以上は",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、島村抱月も小山内薫も、終生アカデミイなきアンデパンダン的存在として、空虚な努力を「新劇」開拓の上に捧げたのであつた。",
              "citation": {
                "source": "わが演劇文化の水準",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいひたいのは、たゞ、この西洋模倣のアカデミイが、実は、国際的な新日本芸術の揺籃であつたといふ事実を誰も否定しないであらうし、それは、時代へのよき刺戟であり、民衆への啓蒙であり、殊に生気あるアンデパンダンの育成を促した間接の役割に至つては、皮肉でなく、これを認めないわけに行かぬといふことである。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
