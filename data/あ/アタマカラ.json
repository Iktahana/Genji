        "examples": {
          "standard": [
            {
              "text": "毎日、頭からについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭から戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭からの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭からという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭からについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭からの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭からに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭からを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭からは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭からは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭からは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭からを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭から」という概念について深く考察する必要があります。",
              "source": "幻辞"
