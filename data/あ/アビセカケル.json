[
  {
    "uuid": "05bec866-e894-5458-9c97-63ac26c4704a",
    "entry": "浴びせかける",
    "reading": {
      "primary": "あびせかける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
