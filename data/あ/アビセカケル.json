      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to throw (liquid) at",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浴びせかけるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この浴びせかけるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が浴びせかけるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は浴びせかけるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では浴びせかけるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から浴びせかけるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも浴びせかけるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では浴びせかけるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも浴びせかけるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも浴びせかけるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で浴びせかけるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に浴びせかけるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "浴びせかけるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する浴びせかけるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では浴びせかけるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこへコケットのダンサーが一人登場して若い方の靴磨きにいきなり甲高なコケトリーを浴びせかける。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう周囲が真暗なため、店頭に点けられた幾つもの電燈が驟雨のように浴びせかける絢爛は、周囲の何者にも奪われることなく、ほしいままにも美しい眺めが照らし出されているのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし階下ではちゃんと先生の声がしていて、それがたいていいつも細君だか女中だかにはげしい小言を浴びせかける声であった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八月の炎熱はかうして平原の到るところの街々に激しい流行病を仲介し、日ごとに夕焼の赤い反照を浴びせかけるのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な鉄の檻の中に坐り込んでいた、患者姿のＡは、とりあえず見舞いに来た私の顔を、ハッキリと記憶していたばかりでなく、何やら訳のわからない紙片を鉄棒の間から突出しながら、辻褄の合わない脅迫めいた文句を、私に向って浴びせかけるではありませんか。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今小児を受取るであろう、――彼女は小児を自分の胸におしつけるであろう、――その小さな体にしがみつき、息もつけなくなるほどに愛撫を浴びせかけるであろう。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだところで思いも寄らない拾い物をしたのを喜んだ手先どもは、すぐにばらばらと駈けて行って、彼のうつむいている頭の上に御用の声を浴びせかけると、松蔵は今や穿こうとしていた片足の草鞋を早速の眼つぶしに投げつけて、腰をかけていた床几を蹴返して起った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女性が男性を弄ぶと貴君方男性は、直ぐ妖婦だとか毒婦だとか、あらん限りの悪名を浴びせかける。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは真向浴びせにすさまじい叱咤の声をでも浴びせかけるだろうと思われたのに、主水之介の姿を見眺めるや大きく先ず莞爾として打ち笑ったものです。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは真向浴びせにすさまじい叱※の声をでも浴びせかけるだろうと思われたのに、主水之介の姿を見眺めるや大きく先ず莞爾として打ち笑ったものです。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第九話　江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八月の炎暑はかうして平原の到るところの街々に激しい流行病を仲介し、日ごとに夕燒の赤い反照を浴びせかけるのである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南禺はその当時博学な文人の一人として世間に知られてゐたが、生れつき片意地で、好き嫌ひがはげしい上に、気が短く、ちよつとしたことにもすぐに向つ腹を立て、機嫌がわるいと、誰彼の見さかひなく、口から出まかせに悪口雑言の限りを浴びせかけるので、友達も永続きはしなかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とづけ／＼嫌味を浴びせかけるので、気の弱い夫人達は、蝸牛のやうに結ひ立の丸髷を襟のなかに引つ込めてしまひたくなる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ太陽が西に沈みかけて、赤々とした光を浴びせかけるとき、この温室はまたひとしおの美しさでありました。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、また一太刀、今度は、右の肩先から胸へかけて、袈裟がけに浴びせかける。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先輩」の虚栄心は、「恐るべき後輩」に対して、自己の弱点を守ろうとしながら、こういうお世辞と、皮肉とを浴びせかける。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十号ガスを火星人に浴びせかけると、火星人が着ているあのかたい殻が、見る見る中に蒸発して、影も形もなくなってしまうのだ」　それが十号ガスの偉力であった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるが故に、お茶人の身上はこれこれとばかりなんら怪しむところなく、ただもうわけもなく喜悦し、この珍風景に縁なき徒輩たちを指しては妄りに俗物として、無風流の誹謗を真向から浴びせかけるというわけで、まことに苦笑禁じ得ないものばかりである。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私のその言葉は、寧ろ自分の頭が自分自身に浴びせかける言葉のように響いたのである。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴のフェリックスは、それに悪口雑言を浴びせかける。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "団長は怒りに震えた声を、浴びせかけるようにして怒鳴った。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大海人は、よくかげ口をきかれる例の神鳴り声を、小黒の禿げ頭のてつぺんへ浴びせかけると、ゆらりと地上へおり立つた。",
              "citation": {
                "source": "春泥",
                "author": "『白鳳』第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理で、箱根からこっちじゃアあんまり見かけねえ面が揃ってらあ」　半分逃げ腰で、遠くから罵声を浴びせかけるが、源三郎はにこにこして、ピタリ、門前に馬をとめたままです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "落雲館に群がる敵軍は近日に至って一種のダムダム弾を発明して、十分の休暇、もしくは放課後に至って熾に北側の空地に向って砲火を浴びせかける。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショオが社会に対して浴びせかける辛辣な皮肉の裏には、彼の理想の情熱と公憤とが燃え上がっている。",
              "citation": {
                "source": "転向",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "匕首を叩き落して、十手でアゴをこじ上げて、足を絡んで浴びせかけると、先手々々と打たれた大男は、最初の勢いにも似気なく、朽木をたおすようにのけぞりましたが、敷居でしたたか頭を打ったらしく、暫らくは起き上がれません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺の方は此處へ來る前から下手人の當りをつけて、一と足先に擧げてしまつたが――」「――」「十手の誼みだ、俺と八五郎親分と、二人で擧げたといふことにでもして置かうか」　市ヶ谷の喜三郎は、眞つ四角な顏を、脂と得意さに上氣させて最上等の侮辱をヌケヌケと浴びせかけるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はノリス説に対して呶罵を浴びせかけるとともに、ひょいと論鋒を変えて――あとで彼自ら呟いていうに、これは容易な、ほとんど不可避的な論鋒転換だったそうだが――自分こそ適任だと主張し始めた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は血のついた軍刀をさげたまゝ、再び軍刀をあびせかけるその方法がないものゝように、ぼんやり老人を見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、迫撃砲弾の雨をあびせかける。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
