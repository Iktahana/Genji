        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "事情を聞けば、草津行の乗合馬車には赤馬車と称する会社があって、頗ぶる専横を極めている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤馬車は通じても、他の馬車で来たものはいくら中が空いておっても断じて乗せぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の田舎｜老爺もこの事を知らなかったため横暴なる赤馬車に虐められているのであるが、いかに山の中とはいえ、かくのごとき不親切極まる営業振りは聞捨てにならぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下を旅行する多くの人のために、吾人は一日も早く草津行赤馬車の全滅を祈るものである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一月二日の夜、春木座の出方が赤馬車数台に乗込みて、銀座尾張町のやまと新聞社を襲い、社員を殴打して暴行を働く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎暑、極熱のための疲労には、みめよき女房の面が赤馬の顔に見えたと言う、むかし武士の話がある。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥桶積んだ赤馬が後ろから来る。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "空ぐるま軋るを見れば、上岨を尻毛振る赤馬、ひようひようと吹かれゆく馬子、みな寒き冬のものなり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬が帰ってくると、嫁の赤馬が出て行く。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若殿｜忍男が白袍赤馬自ら出て騎土に號令を傳へる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂より已来尾の道大輻湊の地なれども赤馬関は勝ること万々ならん。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地亦一湊会なれども遠く赤馬関に不及。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤馬渡海、海雨驟至。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし天保三年｜閏十一月二十五日に、新に夫を喪つた里恵が赤馬関の広江秋水の妻に与へた書にかう云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙に藁庖丁の上に懸けて在る手綱を外して、馬塞棒の下を潜って、驚く赤馬をドウドウと制しながら、眼にも止まらぬ早業で轡を噛ませた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合う竹の皮の草履を突かけて出ると、式台の脇柱に繋いだ西村家の赤馬が前掻きするのを、ドウドウと声をかけながら表門の閂を外した。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤馬というのも橋のたもとにあって、ウォシントン・アーヴィングが此の土地の印象記（それを私は中学時代に読んだ）を書いた時泊っていたホテルだというので有名だが、それをば此の土地第一の得意客なるアメリカの淑女紳士諸君のために譲ることにして、私たちはシェイクスピア・ホテルの方を選んだ。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず　九月二十九日　夜親たちとモンマルトルの赤馬というプチな料理やへ出かけ相当満足してかえって来たら下で私への電報だと云って電報ではない速達を渡した。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが翌日厩へ行つてその赤馬を見ますと、驚いたことには、それは土の馬でありました。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷から深川までの間に、その頃乗るものといっては、柳原を通う赤馬車と、大川筋の一銭蒸汽があったばかり。",
              "citation": {
                "source": "雪の日",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷から深川までの間に、その頃乗るものと云ひては、柳原を通ふ赤馬車と、大川筋の一銭蒸汽があつたばかり。",
              "citation": {
                "source": "雪の日",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤馬関の砲台は粉にすべし、奇兵隊の名は滅すべし。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、行ってくるわ」　佐々の一家はモンマルトルの「赤馬」というレストランで、のんびりと居心地よく、長い時間をつぶして帰って来たところだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにもう一人、「赤馬」と呼ばれる頭のおかしい男がいて、これは本当に退役した兵曹長であるが、その男はささやんがおかしくなったあとでこの浦粕へ帰って来たのであるし、それ以前にも二人は知合いではなかった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の少年時代には吉良上野顕彰の意味をふくめて郷土人形の赤馬をつくる「赤馬会」というものがあった。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤馬は上野介の愛撫した彼の乗馬である。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種の黄、レンゲの紫に彩られた田舎道に領主の赤馬が絵のようにうかびあがると鼻たれ小僧どもがわいわい騒ぎながら駈けあつまってくる。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
