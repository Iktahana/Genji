          "literary": [
            {
              "text": "はいと言い言い、あらあらかしくと書きおさめて、硯の蓋を重しに置いて出て行く。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづはあらあらかしこ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り急ぎあらあらかしこ――」「てへへへ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあらかしこなぞと若々しい止め文句を使う年寄りのばんばあが、どこの世界にあるんですかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあらかしこ　　　明治三十五年三月二十九日井の口トシ子より　　　　　菱田新太郎様　　　　　　　　　　　みもとに",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オネーギン様、あらあらかしこだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらあらかしく、お色より、恋しい恋しい弓様へ」こう結んで筆を置いた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最後の、かそけくもこそ、ねえ、シンちゃん、あらあらかしこを現代語に飜訳すると、お宅の言葉じゃこうなるというワケですかい」「わからない人だね。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く御越しのほど、先は御めもじの上にてあらあらかしく。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと筆とりいそぎ候ままにあらあらかしく　ねねどのへ　所々、文字は涙にぬれていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
