    "definitions": [
      {
        "index": 1,
        "gloss": "academic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "以上のような読み方をするのはアカデミックな言語学者から見れば言語道断な乱暴な所業であるに相違ない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こういう代表的なアカデミックな仕事ですらも審査員の眼界があまりに狭くてその部門のその問題の他の方面にまで眼が行届かないような場合には、そこに提出された論文のせっかくの狙い所が正常の価値を認められずに軽視されることも実際にあり得るのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるアカデミックな学界の権威にはこの型が多い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢を見る人の眼であって、冷たい打算的なアカデミックな眼でない、普通の視覚の奥に隠れたあるものを見透す詩人創造者の眼である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし如何なるアカデミックな大家にも劣らぬ古典的な仕事をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアカデミックな芸術に食傷したものの眼には不思議な慰安と憧憬を感ぜしめる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあるいは伝習を固執するアカデミックな画家や鑑賞家の眼からは甚だ不都合なものであるかもしれないが、ともかくも自分だけは自然の色彩に関する新しい見方と味わい方を教えられて来たのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時自分の感じた事は、その鉛筆画が普通のアカデミックなデッサンとはどこか行き方が違っているという事であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう傾向は特に現代のアカデミックな教育を受けた若い学生の間に多いのみならず、また西洋でも二三流以下の学者の中にかなりに存在するように見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学上ではなんらかの画紀元的の進展を与えた新しい観念や学説がほとんど皆すぐれた頭脳の直観に基づくものであるという事は今さらに贅言を要しない事であるにかかわらず、昔も今も通有な一種の偏狭なアカデミックの学風は、無差別的に直観そのものを軽んじあるいは避忌するような傾向を生じている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはただ現時の最高のアカデミックの課程を修得したルクレチウスにほかならないのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう革命的の仕事は、おそらくアカデミックな学者の手によってではなく、意外な方面の人の自由な頭脳によってなし遂げられはしないかという気がする。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう状況であるから多くのアカデミックなまじめな学者たちはその仕事が「世界的大発見」「大発明」として新聞に発表されることを何よりもこわがっている。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまたわが国の科学者がおりにふれてはそのいわゆるアカデミックな洞窟をいでて火災現象の基礎科学的研究にも相当の注意を払うことを希望したいと思う次第である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、問題がまだアカデミックな研究にかけるにはあまりになまなましくて、ちょっと手がつけられそうもないから、そういう問題はまずまず敬遠しておくほうがいいという用心深い態度を守って、格別の興味を示さない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙はアカデミックな科学の殿堂の細部の建設に貢献するには適しているが新しい科学の領土の開拓には適しない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうやり方は言わばアカデミックなオーソドックスなやり方であると言われる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの人の学者らしい徹底したアカデミックなしかたに感心すると同時に、なんだかそこに名状のできない物足りなさあるいは一種のはかなさとでもいったような心持ちがするのを禁ずる事ができなかった。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、またそういう独創的な仕事の常として「きずだらけの玉」といったようなものが多いから、アカデミックな立場から批評してそのきずだけを指摘すればこれを葬り去るのは赤子の手をねじ上げるよりも容易である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故に我々は、今日尚アカデミックな詩学を有し、韻律学の煩瑣な拘束を持っているのか。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女を連れ出して、この喫茶店のアカデミックな空気の中に游がせて置けば、かの女は、立派に愉快を取り戻せるものと信じ切っているらしく、かの女に茶を与え、つまみ物を取って与えた後は、ぽかんとして、勝手な考えに耽ったり、洋食を喰べたり、元気で愛想よくテーブル越しに知人と話し合う。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、アカデミックな態度を、とろうと思います。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」何かと自己弁解ばかりして、「アカデミックな態度ばかりは、失いたくありませんからね。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしだらもふしだららしいのはアカデミック小説の履行で何の刺戟も無い。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁丹を買うためにパトロンを作った彼女は、煙草も酒も飲まず、酒場のボックスでは果物一つ口にしない行儀のよさが、吉田の学生街のへんに気取ったけちくさいアカデミックな雰囲気に似合っており、容姿にも何かあえかなノスタルジアがあった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一方、リックライダーを継いだ人たちの手で、インターネットの原点となるネットワークが、アカデミックな研究所や大学を結んで築かれます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく縁のなかったアカデミックな世界から突然現れ、すさまじい勢いで成長しはじめたＷＷＷが実現したのは、その時私がネットワーク雑誌に期待したこと、そのものでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一度『現実の順序が違つたものに』などぶつかると、これらのアカデミックな画法の順序は何の用にもならない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその頃アカデミックな手法でかいてゐたが、青木は私の絵をみて、何時もかう言ひ言ひした。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もアメリカにも全然ないといふわけではなく、少しはあることはあるのですが、イギリスのやうにアカデミックな風格は備へてゐません。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
