    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀哭は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀哭が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀哭に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀哭が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀哭について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀哭についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀哭について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀哭が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀哭が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀哭は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀哭は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀哭を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀哭をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀哭が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀哭の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀哭を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀哭に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀哭について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀哭は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀哭を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "＊　それから後の私たち二人は、肉体も霊魂も、ホントウの幽暗に逐い出されて、夜となく、昼となく哀哭み、切歯しなければならなくなりました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそのほかに、饑饉があるの、地震が起るの、星は空より堕ち、月は光を放たず、地に満つ人の死骸のまわりに、それをついばむ鷲が集るの、人はそのとき哀哭、切歯することがあろうだの、実に、とんでも無い暴言を口から出まかせに言い放ったのです。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三講　ヨブの哀哭第三章の研究◯ヨブの哀哭はヨブ記の到る処にあるが、第三章はその哀哭の最初でありかつその最も代表的のものなるが故に、この章の研究は甚だ有意味なのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の友はこの哀哭に接して、ヨブを以て信仰的堕落者と定め彼を責めるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをヨブの哀哭と比して霄壌の差ありというべきである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト降世以後に生れしパウロはキリストを知れる故にかの大安心あり、キリスト降世以前に生れしヨブはいまだキリストを知らざる故にかの大哀哭があったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ヨブのこの哀哭の真因いかん。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六の禍までは彼を歎かしめず第七の禍｜来って彼の哀哭生じたと前に説明した。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし第七の禍すなわち友の誤解は、この哀哭を爆発せしめし誘因たるに過ぎない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三友の彼を正解せざるに会して、この懐疑は奔流の如く心の表に現われて、彼の口より大哀哭を発せしめたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四講　老友エリパズまず語る第四章、五章の研究◯ヨブ記四章五章の記す所は、第三章のヨブの哀哭に対するエリパズの答である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリパズら三友人はヨブの不信的哀哭に接して、彼らの推測の過たざりしを知り、半ば彼を憐むの同情心より、半ば彼を責むるの公義心――神に対する義務の感――よりして彼に向って語らんとするのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに彼らはヨブの哀哭の語に接してその言辞に因えられてその心裡を解する能わず、ますます彼らの推測の正当なりしを悟り、ここにヨブを責めてその私かなる罪を懺悔せしめ、以て彼を旧の恩恵の中に引き戻さんと計ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすればこれは海の沙よりも重からん、かかればわが言｜躁妄なりけれ」とあるは、苦悩大なるため前の哀哭も我れ知らず躁妄に陥ったのであるとの意である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の苦言もただヨブより哀哭の反覆を引き出したのみに終った。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦訳聖書において見るもその悲哀美に富める哀哭（Lamentation）たるを知り得るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯しかるに十八節以後においては、ヨブに起りし光明の一閃は消えて再び哀哭に入るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一節―六節においては友に対する不満を述べ、七節よりは悲痛極まる哀哭の語を発する。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多恨の詩人肌から亡朝の末路に薤露の悲歌を手向けたろうが、ツァールの悲惨な運命を哀哭するには余りに深くロマーノフの罪悪史を知り過ぎていた。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おもむろに哀哭の声は消えて、またそれに続いた非常な静かさの内に、芳一は老女であると考えた女の声を聞いた。",
              "citation": {
                "source": "耳無芳一の話",
                "author": "THE STORY OF MIMI-NASHI-HOICHI",
                "note": "青空文庫"
              }
            },
            {
              "text": "先達の小屋の近所を通りながら、土幕民達は婦が盛んに哀哭しているのを聞いた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう言ひながらハンナは、暗い楓の茂みと、傷ましげな枝々を水に浸して哀哭してゐるやうな柳の木立にとりかこまれた、陰気な池の面を指さした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダービー・マグロー、」とその声は哀哭する――それがその声を最もよく言い現す言葉であった――ように言った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仙界に哀哭があるだろう、しかし蜜の髪のマルヴィンよ、今からあなたは私の妃だ」フェルガルが言った。",
              "citation": {
                "source": "約束",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ」ケリルはマルヴィンの胸から矢を抜き取った「仙界に哀哭があるだろう」　ケリルはそう言いながらフェルガルに矢を投げつけた、矢がフェルガルの眼に当った、彼は暗黒と静寂を知って息が絶えた。",
              "citation": {
                "source": "約束",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレーヴシン　（泣くような哀哭の声を高くして）わしはウスナの家の声だ、永久に、永久に、風の中になげく声だ「王者は塵に横わり、貴人は辱しめられ、強国の勇士は葦を振る剣士の如く、草をしごく槍手の如く影を追い影にあこがるる人の如くなろう！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く引く哀哭の歌声きこえる。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれはコルマックと美しいアイリイの死体をコノールの許に持って来る人々の哀哭の声だ。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいこく行進曲をうたおう。",
              "citation": {
                "source": "日の当たる門",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
