    "definitions": [
      {
        "index": 1,
        "gloss": "to open wide (doors or windows)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "開け放つの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "からっ風が、ばたん、と入口のドアを開け放つ。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からつ風が、ばたん、と入口のドアを開け放つ。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは鍵を外して扉を開け放つ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と執事が扉を開け放つ。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏返しに結つた娘の髮が開け放つた襖の蔭から少し出てすぐ余が眼の前にこちらを向いて居る。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の三分通りまで、開け放つた敷居を越して柔かな外光が覗き込むで、私は自分の肢体が舟のやうに浮びあがるのを感じました。",
              "citation": {
                "source": "愚かな朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は屡々窓を開け放つて、ベツドの中で読書してゐたものだ。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの木立を透してそよそよと吹入る秋風の動きにつれて、冷々とした物の匂が、開け放つた室々を腹這ふやうに流れて往つた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに好い季節、障子を開け放つて眺める。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青年団、処女会、国防婦人会、学生、民衆、……まさに総動員の態勢である、私も庵を開け放つて、今日の日を祝福した。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠不足が影響したらしく思はれるので、手を窮屈に伸ばして、自分の後丈を開け放つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸障子を開け放つて、雨気の籠つた黴臭い家の中へ日の光を導き入れると、畳の面に、人の足痕のべと／＼ついてゐるのも目にはひつた。",
              "citation": {
                "source": "五月雨",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは別荘の窓は悉く開け放つてあるのに、只一箇所の窓丈鎖してあると云ふ事である。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二階の窓を開け放つて、小供の爪の先きが人の肉體をこそこそと掻きおろしてくる樣なきつい温さを含んだ日光に額をさらしながら、みのるは一日本を讀んで暮らした。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半宵もし軒をうつ雨の音を聞く時は、蹶然褥を蹴って飛び起き、急ぎ枕頭の蝋燭に火を点して窓を開け放つなり、火影に盆栽の木々の枝葉の濡色を照らし見て、独り自ら娯しむ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は大抵、武者小路氏が文壇の天窓を開け放つて、爽な空気を入れた事を愉快に感じてゐるものだつた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は崖上の開け放つた窓から諸峰を望み、松風を聴きながら、小孩の汲んでくれる茶を喫み、是等の道士と対してゐる閑寂沖澹の趣は現代の事とは思はれなかつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ下の通りではどの家も表の戸を開け放つたまゝ道路に出てゐたので、屋内からの明りが方々から路面に流れ、立つて空を見上げてゐる人達の半身を照してゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真壁は、窓を開け放つ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙つて縁側の障子を開け放つ。",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子も襖も開け放つ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、窓を大きく開け放つて、深呼吸をした。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日のコースか知らないけれども、瀬戸船山村は今や天下の名所になつたわけですね」　二人は、窓を開け放つた事務室のなかで愉快さうに笑つた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の格子戸は一パイに開けて、近郷の人や親類やら、何をするともなくザワ／＼として居り、冬の日向に開け放つた縁側には、引つ切りなしに人が往來して居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙を開けると、窓は開け放つたまゝ、主人孫右衞門は床の上に横たはつて、靜かに眼をつぶつてゐるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝になつて、手代の清松が庭から聲を掛けると、雨戸は一枚だけ開け放つたまゝ、カンカンと朝陽の入る中に、五十男の主人五左衞門は脂ぎつた死體を横たへてゐたと言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お篠姉妹",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を少し曲げると、一枚開け放つた障子の中に、上段の高麗縁が見えて、豐かに坐つた黒羽二重の膝も見えます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金色の處女",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　「与えられた文学現象の社会的等価を発見することに努力しつつ、若しも、問題がこの等価物の発見にのみ制限され得ないということ、社会学は美学の前に扉を閉すことではなくて、反対にその前に夫を開け放つことであるということを理解しないならば、文芸批評はそれ自身の本性を裏切るものである。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開け放つと、彼は深々と息を吸いこみながら、ちょっとの間たたずんでいた。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子を開け放つと、手摺の外には鈍色の海があっておりおり紙片を飛ばすように鴎の舞いたつのが見えた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
