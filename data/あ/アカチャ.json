        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "都会の上に広がる濁った空気を透して見るのでそれが妙な赤茶けたあたたかい色をしていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶けた、澤のない、ばさばさ髪、高い頬骨、肩掛をはづした女の顏は見違へる程痩せてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うにいた別の、少女のような美しいボーイが、赤茶色のロシア毛布を手にして馳せ出してきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の槐が可恐かつた……」　時々梢から、（赤茶釜）と云ふのが出る。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今も居るか、赤茶釜。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の町の、奧を透かす處に、誂へたやうな赤茶釜が、何處かの廂を覗いて、宙にぼツとして掛つた。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動止んだ赤茶けた三俵法師が、私の目の前に、惰力で、毛筋を、ざわ／＼とざわつかせて、うツぷうツぷ喘いで居る。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口元には赤茶けた口髯がチョビリ生えておりました。",
              "citation": {
                "source": "薬指の曲り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝腎の陽射しを受ける南に本棚や壁があって、僅かに奥の方に小窓が在るので其処から入って来る秋の午後の赤茶気た光線は氏の左側を照すのみで、他の部分は――顔も胸も――陰となって向い合った客の景子達だけを明るく照し出した。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の胎児のような赤い斑点はますます拡がりを持ち、縮れた頭髪は赤茶けて見えた。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気になるまで己を慕うている女を捨てて逃げることは、人としての行でないように思われて来たが、赤い顔の斑点と、赤茶けた縮れ毛を思うと、醜いと云うよりも寧ろおそろしい気がして、とても帰って往こうと云う気にはなれない。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女の姿はみるみる赤茶けた色の獣となった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………深く斬込まれた刃の蔭に赤茶気た肉がヒクメク。",
              "citation": {
                "source": "月蝕",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが果して生きた人間のため息だったかどうかわかりませんが、私は、何がなしにハッとして飛び上るように背後をふり向きますと、そこの一際大きな樹の幹に、リヤトニコフの屍体が引っかかって、赤茶気た枯れ葉の焔にユラユラと照らされているのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女の姿はみるみる赤茶けた色の獣となつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉生　　浮浪人、二十六、七の背のひょろ長い髪の赤茶けた碧い眼の青年。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺は力なく赤茶けたその野菜を曳いて、自分の家に帰っていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、吾平爺はその赤茶けた野菜物を曳いて青物市場へ出かけていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾平爺の二日も陽に晒した赤茶けた野菜の売れるわけはなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちそこから飛び出てきたのが綺麗な赤茶の生き物。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔はやつれて骨ばかりで、羊皮紙のように赤茶けた肌が骨に強く引っ張られていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く丸い腕を男の赤茶けた筋っぽい首に回して、黄金色の頭を男の別珍のチュニックに預けていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "見附に受附のような出っぱった室の窓ガラスが見えて、中に肥った頬ペタの赧い老婆が鼻眼鏡のような黒い紐の附いた玉の大きな眼鏡をかけて、横向になって表紙の赤茶けた欧文の小本を覗いていた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬髪は昔のままだけれども哀れに赤茶けて薄くなっており、顔は黄色くむくんで、眼のふちが赤くただれて、前歯が抜け落ち、絶えず口をもぐもぐさせて、一匹の老猿が背中を丸くして部屋の片隅に坐っている感じであった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山にはいま朝日の射して來る處で、豐かな赤茶けた山肌全體がくつきりと冷たい空に浮き出てゐる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山にはいま朝日の射して来る処で、豊かな赤茶けた山肌全体がくっきりと冷たい空に浮き出ている。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に入ってゆくと赤茶色の山の蔭に僅かに沖の余波を思わせる小波が立っているのみであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとぶきみなことか、その太い杉の赤茶けた幹の腹には、手足そろったわら人形が、のろいのあのわら人形が、両足、両手、胸、首、頭と、七本の三寸くぎに打ちえぐられて、無言のなぞと、無限の秘密をたたえながら、ぐさりとくぎづけになっていたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺったり折り畳まった拾円紙幣が二枚、赤茶けた畳の上に落ちてきた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い冷たいその海の彼方には、暗緑の鳥喰崎が、折りからの雲の切れ目を鋭い角度で射通した太陽の点光に照らされて、心持ち赤茶けながらくっきりと映えあがって来た。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
