    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rain water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨水について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨水という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨水の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨水が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨水を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨水について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨水の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨水の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨水が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨水という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨水という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨水についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨水を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨水は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨水について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨水が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨水は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨水の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨水は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨水は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その雨の中を漂ひながらいつだか消えてなくなつた、あの乳白の※嚢たち……今や黒い冬の夜をこめどしやぶりの雨が降つてゐて、わが母上の帯締めも雨水に流れ、潰れてしまひ、人の情けのかずかずも竟に蜜柑の色のみだつた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の人が、セント・ジョルジ・ギルドの人たちのように、糸車を挽いて、木綿を手織って衣ているかどうかを知らないが、風呂の水も、雑用の水も、熔岩の下から湧く渓河から汲み上げて、富士の高根の雪解の水と雨水との恩恵の下に、等分に生きていることを思うと、富士の裾野の水々しさに、一倍の意義があると思われる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峰の雪というと、誰でもその高潔を予想するが、新雪はともかく、いわゆる万年雪の状態にあるものは、表面は雨水が流れたり、崖の砂が塗られたり、偃松の枯枝が散ったりして、存外に汚ないものが多い。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "た※｜渺々として果もない暗夜の裡に、雨水の薄白いのが、鰻の腹のやうに畝つて、淀んだ静な波が、どろ／＼と来て線路を浸して居さうにさへ思はれる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この石の中ほどにたしか少しくぼんだところがあって、それによく雨水や打ち水がたまって空の光を照り返していたような記憶がある。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に雨水がたまっていた。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨水を含んでいる岩角はウッカリすると墜落して手も足もかけることが出来ぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻瀧のやうに降注いだ雨水は、艇底に一面に溜つて居る、隨分生温い、厭な味だが、其樣事は云つて居られぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其翌日は、漂流以來はじめて少し心が落付いて、例の雨水を飮み、沙魚の肉に舌皷打ちつゝ、島影は無きか、る日よりは餘程元氣もよく、赫々たる熱光の下、日出雄少年は私の顏を見詰めて『おや／＼、叔父さんは何時の間にか、黒奴になつてしまつてよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雨水が渺々として田を浸すので、行く行く山の陰は陰惨として暗い。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに今乗った下らしいから、また葉を分けて……ちょうど二、三日前、激しく雨水の落とした後の、汀が崩れて、草の根のまだ白い泥土の欠目から、楔の弛んだ、洪水の引いた天井裏見るような、横木と橋板との暗い中を見たが何もおらぬ。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、まっぱだかで、雨水が長い金髪から、ぽたぽたと、したたり落ちているではありませんか。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色の髪の毛からは、まだ雨水がたれてはいましたが、でも、それはそれはきれいにうねっていました。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆の木、淡竹、虎杖、姫｜日向葵の葉、そうした木草の枝葉が強い風に掻きまわされ、白い縄のような雨水に洗われて物凄かった。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来のわきのどぶには、泥の雨水がどん／＼流れてゐました。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間はもう三寸以上も雨水に浸されていた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ雨が残っているような雨雲が空いちめんに流れている晩で、暗いうえに雨水を含んだ地べたがじくじくしていて、はねあがるようで早くは歩けなかった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の前を屋根から、まだ雨水が小川のように落ちている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ雨が残つてゐるやうな雨雲が空いちめんに流れてゐる晩で、暗い上に雨水を含んだ地べたがジクジクしてゐて、はねがあがるやうで早くは歩けなかつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はやんでいて雨水は手にかからなかった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周圍の臺地からは土瓶の蓋をとつて釣瓶をごつと傾けたやうに雨水が一｜杯に田に聚つて稻の穗首が少し浸つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "熾烈な日光が之を熱して更に熱する時、冷却せる雨水の注射に因って、一大破裂を来たしたかと想う雷鳴は、ぱりぱりと乾燥した音響を無辺際に伝いて、軈て其玻璃器の大破片が落下したかと思われる音響が、ずしんと大地をゆるがして更にどろどろと遠く消散する。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "包みの油紙は雨水と泥とでひどくよごれていて、差出人の名前がようやくの事で読めるくらいだったが、そこにしるされた姓名を私はだれともはっきり思い出すことができなかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりぬれているらしい靴をはいて、雨水で重そうになった洋傘をばさばさいわせながら開いて、倉地は軽い挨拶を残したまま夕闇の中に消えて行こうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は雨水で川のようになっている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "『雨水がたまると、この穴から入りこみゃしないかなあ』　と僕は、この背の低い空気抜けを指していった。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　雨の晴れ間を田圃へ出てみると、小川には薄濁りした雨水が、田の畔を浸すまでに満ち溢れてゐました。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大窪の泉と云つて、杉の根から湧く清水を大きい据桶に湛へて、雨水を防ぐ為に屋根を葺いた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大窪の泉と云つて、杉の根から湧く清水を大きい据桶に湛へて、雨水を防ぐ爲に屋根を葺いた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
