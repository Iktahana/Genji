[
  {
    "uuid": "240717f8-71a6-5525-9fa8-16ced130613e",
    "entry": "雨水",
    "reading": {
      "primary": "あまみず",
      "alternatives": [
        "うすい"
      ],
      "is_heteronym": false
    },
    "grammar": {
