        "examples": {
          "standard": [
            {
              "text": "私は毎日綾絹について考えている。",
              "source": "幻辞"
            },
            {
              "text": "綾絹という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は綾絹の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には綾絹が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "綾絹を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは綾絹について学習した。",
              "source": "幻辞"
            },
            {
              "text": "綾絹の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は綾絹の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では綾絹が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "綾絹という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に綾絹という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では綾絹についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "綾絹を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると綾絹は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "綾絹について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では綾絹が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に綾絹は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により綾絹の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "綾絹は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に綾絹は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから繻珍の夏帶とお召の單衣と綾絹の蝙蝠傘とを強請られて購はせられたが、これは彼の消極的經濟に取ツて、預算以外の大支出で、確に一｜大打撃であツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たまえ、帯は綾絹で、裏地も見事だ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って調べると、嚢のなかには綾絹が百余｜反もはいっていましたので、わたくしは思わぬ金儲けをいたしました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、紫や緋や黄の綾絹をもって幾重にも仏像をつつみ、拝む者があれば先ずその一重を剥いで見せる。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "香橙色の薔薇の花、物語に傳はつた威尼知亞女、姫御前よ、妃よ、香橙色の薔薇の花、おまへの葉陰の綾絹に、虎の顎が眠てゐるやうだ、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は縞羅紗ではなく綾絹だった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬班、むっくと起き上がり、泥だらけの防寒外套を脱ぎ棄てると、その下から見事にきらびやかな綾絹の衣装が現れる。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "その九「うぐいすも、都の春にあいたけと、きは淀川へ上り舟、………」お久は絃を三下りにして地唄の「あやぎぬ」をうたっていた。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
