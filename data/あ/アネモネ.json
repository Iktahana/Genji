        "examples": {
          "standard": [
            {
              "text": "私は毎日アネモネについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アネモネという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアネモネの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアネモネが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アネモネを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアネモネについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アネモネの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアネモネの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアネモネが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アネモネという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアネモネという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアネモネについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アネモネを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアネモネは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アネモネについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアネモネが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアネモネは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアネモネの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アネモネは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアネモネは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まっ赤なアネモネの花の従兄、きみかげそうやかたくりの花のともだち、このうずのしゅげの花をきらいなものはありません。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は物干へ出られる窓の硝子窓を半分開けて、廂間から淀んだ空を仰ぎ溜息を吐いたが、夜店もののアネモネーや、桜草の鉢などがおいてある干場の竿に、襁褓がひらひらしているのが目についた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、重く咲き誇るアネモネ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚がマホメット本寺の円頂塔に立籠って風速に嚮っている、それをコルクの砂漠に並んでアネモネの花が礼拝している。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにまだグラジオラスの根やアネモネの根もずっと前に見た記憶があった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月はこのとき、あたかもアネモネの覆いのように、極めて薄い雲の天蓋をもって、その光りを小暗くしていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた母の留守の時は温室のなかの藤椅子の上に美しいチューリップや、アネモネの上に瞳をすゑておとなしく暮したのであった。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アネモネの花瓣、亦雨や夜の前に捲上つて睡る。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側にアネモネの鉢が並べてある。",
              "citation": {
                "source": "四月五日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのころ妻は、クロッカアズ、アネモネ、ヒヤシンスなど買って来て、この土地での春を待った。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アネモネぢや有りませんか。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むゝ、アネモネさ。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄――」「面倒くさいからここんところですましちゃうのよ」「今夜は、もっと本式よ」　房は、悪戯らしくにこにこしながら、わざと隠して置いたアネモネの花を運んで来た。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをここんところに飾ってさ」　彼女は、卓子の横に赤いアネモネをさした硝子花瓶を置くと、直ぐとってかえして、両手に西洋皿を持って入って来た。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコットランドではアネモネの花が野生で繁茂してゐるといふが、それが我々の高原地ではちごちごの花と呼ばれ、翁草と呼ばれて初夏の野原を飾つてゐる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊（三月×日）　階下の台所に降りて行くと、誰が買って来たのか、アネモネの花の咲いた小さな鉢が窓ぶちに置いてあった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円い環のなかではアネモネ、ヒヤシンス、チューリップなどが渦巻いていて、それはいきなり僕を眩惑させる。",
              "citation": {
                "source": "雲の裂け目",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い迷送香、赤い紫羅欄花、アネモネ、薔薇、そして枝も撓わなミモザ。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジギタリス、アネモネ、グラジオラス、サフラン、そんな花々につつまれて、一日中、陽があたっている明るさ暖かさでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "買って来た真紅のアネモネが非常に電気の光線で美くしく見えた。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の栄華と耶蘇の比べた、百合はアネモネだと云ふ説のやうに、強烈な色に印度では咲く沙羅双樹か知らぬが、日本の山の白い沙羅は、あてに、いみじく、脆い花である。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはテューリップ畠と、アネモネ畠でひろびろとした耕地の間に途方もなく大きな毛氈を敷きひろげたように、しかも、このテューリップ畠は赤は赤一色、黄は黄一色、白は白一色で、中に紫はアネモネの花畠だった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、テューリップもアネモネも美しければ、バタ・チーズ・野菜・卵等の産出も多量であれば、また風車もおもしろければ、運河・堤防も珍らしかったが、それ等にもまして私にいつまでも忘られない印象を与えたものはオランダの絵画であった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子には、驚くべきアネモネの縫とりがあった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは不思議に柔らかな色と色との交錯した、アネモネの花のやうな一夜に見えた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
