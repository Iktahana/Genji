        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天津について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天津という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天津の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天津が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天津を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天津について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天津の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天津の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天津が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天津という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天津という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天津についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天津を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天津は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天津について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天津が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天津は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天津の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天津は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天津は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "春水や四条五条の橋の下　この句を読んで聯想するのは、唐詩選にある劉廷芝の詩「天津橋下陽春水。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の日本人経営のクラブとかレストランでは先例によって女を雇入れることはめったにないことなのだが、私は天津の日本租界、敷島町の或るレストランに近頃日本の少女が青磁の衣服をつけてそれでなくとも感傷的になった旅人の私の心を瞑想的にするのに会ったことがある。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイ・ファン・ユウが早朝天津から香港に向けて出発する知らせであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに甚だをかしい告白だが本場の北京、天津、上海、杭州、乃至は奉天などで支那料理を食つたその晩やその翌日なりは、私は、いつもとなく色欲の興奮を感じさせられた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲も面白くない、天津へ来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、大連、奉天、青島、天津などを荒しまわっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天津がいにくゝなる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸は南北の中間に位置し、海には、渤海の南半を抑制し、一呼して立てば、天津、北京の形勢を扼することが出来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゞいて、黄河の鉄橋を破壊しつゝ津浦線を、天津に向って退却した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、蒋介石は、これ以上、天津、北京にむかって進軍させる訳には行かなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こゝから約四哩の黄河の沿岸の※口まで、一息にとばして、そこから天津方面へ落ちのびるのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな妨害に抗しても、天津、北京へ、攻めのぼらずには置かない意気を示した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒋介石は、日本のどんな要求でも容れるから、たゞ、ここを通過して、天津、北京を攻撃することをゆるせ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手甲、脚絆、たすきがけで、頭に白い手ぬぐいをかぶった村嬢の売り子も、このウルトラモダーンな現代女性の横行する銀座で見ると、まるで星の世界から天降った天津乙女のように美しく見られた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにわれは思う、女もし恋の光をその顔に受けて微笑む時は花のごとく輝く天津乙女とも見ゆれど、かの恋の光をその背にして逃げ惑うさまは世にこれほど醜きものあらじと、貴嬢はいかが思いたもうや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの説によれば、貴嬢はもと心順なる少女なれば境によりてその情を動かすがゆえに南洋丸に乗せて一年が間、浮世の風より救い出さば必ず御顔にふさわしき天津乙女となりたもうとの事なり、われはたやすくこれを信ずるあたわざるのみ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "天津乙女は恋の香に酔いて力なく男星の肩に依れり。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといここに、天津乙女の、麗しき翼を休めたとて、縋る力も絶えたのが、三人といわず、五人といわず、濃く薄く湯気の動くに連れて、低くむらむらと影が行交う。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐　傳へ聞く、近頃、天津の色男に何生と云ふもの、二日ばかり邸を明けた新情人の許から、午後二時半頃茫として歸つて來た。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは怪しからず、天津乙女の威厳と、場面の神聖を害って、どうやら華魁の道中じみたし、雨乞にはちと行過ぎたもののようだった。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち陽に遼東を征するを令して、徐凱をして備えざらしめ、天津より直沽に至り、俄に河に沿いて南下するを令す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天壤と窮みなき、天津日嗣、ここに　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬づ世の皇統、皇孫や天津日繼。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "万づ世の皇統、皇孫や天津日継。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "思金神は、「それでは、天津国玉神の子の、天若日子がよろしゅうございましょう」と、お答え申しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまっさきには、天忍日命と、天津久米命という、よりすぐった二人の強い神さまが、大きな剣をつるし、大きな弓と強い矢とを負い抱えて、勇ましくお先払いをして行きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天津桃とかいふので、味はわるいが大きな肉の眞紅な桃である。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "又書紀卷二に、天津彦火瓊々杵尊、大山祇神の女｜木花開耶姫の美貌を見初め召れしに、大山祇其二女姉妹を進む。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやアたなびく、天津風、雲の通路、といったのがある。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ、彼等の表現の多くは、乞食壮士の大道演説に類したものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
