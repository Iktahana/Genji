        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アプロプリエーションについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアプロプリエーションの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアプロプリエーションが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアプロプリエーションについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアプロプリエーションの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアプロプリエーションが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアプロプリエーションという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアプロプリエーションについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアプロプリエーションは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアプロプリエーションが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアプロプリエーションは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアプロプリエーションの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アプロプリエーションは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアプロプリエーションは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
