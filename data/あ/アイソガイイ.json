        "examples": {
          "standard": [
            {
              "text": "毎日、愛想がいいは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛想がいいが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛想がいいに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛想がいいが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛想がいいについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛想がいいについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛想がいいについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛想がいいが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛想がいいが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛想がいいは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛想がいいは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛想がいいを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛想がいいをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛想がいいが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛想がいいの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛想がいいを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛想がいいに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛想がいいについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛想がいいは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛想がいいを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「矢部さんは円山さんよりよほど愛想がいい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人、今日は中々愛想がいい。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は法科の学生は皆愛想がいいと聞いたが、なるほどと思った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、誰に対しても愛想がいいので、門弟らのあいだにも評判がよかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「――でも、なぜあの先生、いつもああ、お愛想がいいんだろう、妙で仕様がない」「…………」「三年の川原さんての、親類なんだってね」　それは宏子に初耳であった。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みさ子はにこりともしないが、声の調子は愛想がいい。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした風の吹き廻しか、今日は滅法愛想がいいの」　火鉢を前に近々と坐り、「ついでに日頃の念願ってやつを、どうだい……」　とお吉の手を握った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肥満した身体をどっしりと落着けて、いつもにこにこと愛想がいい。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、彼等はまた、クイックシルヴァがあまり愛想がいいので、杖も蛇も一しょでいいから、彼を毎日朝から晩まで喜んで家にひきとめておきたいような気もしました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルグリ先生は、その点以外実にお愛想がいいのですが、とうとう僕に椅子ひとつ薦めずじまいです。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰をも好き、誰にでも愛想がいいが、そのくせ、粗忽に知己をつくらぬしっかりしたところがあり、理解力と感受性が豊かで、どんな物事に対しても妥当な判断を誤まらず、何に対しても極めて穏健な意見をはいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なかなかお愛想がいいわね。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、古狼、やけに嬉しそうで愛想がいいじゃないか。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋江へ愛想がいいのは当り前だが、張三への執りなしも並ならず細やかだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒を飲むと、もう、まるで気違いですし、意地くねが悪いというのか、陰険というのか、よそのひとには、ひどくあいそがいいようですけど、内の者にはそりゃもう、冷酷というのでしょうか、残忍というのでしょうか、いいえ、ほんとう、本当でございますよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上のだんなの御用ならいま行くぞ……」　耳にはさんだとみえて、いそいそと出てきたその親の新助が、また至極とあいそがいいのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人は絵がすきな人種で、そして油絵はやはり本場だけに、うしろへ立って見ている奴も、中々あいそがいい。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のあるあいだは女たちもあいそがいいし、なかまも取巻いて騒いでくれる。",
              "citation": {
                "source": "やぶからし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父は背丈のすらりとした、眼のやさしい、なかなかの美男で、立ち居もおっとりしていたし、いつも静かな笑い顔をしていたが、それはあいそがいいというより、むしろ皮肉な、人をばかにしているといったような、感じのものに近かった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも刷毛屋の人のほうがまだましだね」とかみさんたちは云った、「こっちは鬼ばばあだけれど、刷毛屋の人はまだあいそがいいし、つきあいってことを知ってるもの」　このように、お琴はかみさんたちから嫌われていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
