    "definitions": [
      {
        "index": 1,
        "gloss": "American (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アメリカ人が見たら、あれをどう感ずるでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦のように、深く相愛して愛におぼれず、堅く相信じて信に甘えないというのは、アメリカ人の目にはよほど珍しく目新しい一大発見として映ずるかもしれないが、日本人には実は少しも珍しくもなんともない、むしろ規準的な夫婦関係のスタンダードであったのではないかという気がする。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界じゅうでいちばん「若い」アメリカ人が一九三〇年代の今ごろになって、いくらかこの俳諧の世界の存在に気づいて来たように見えるのははなはだ興味の深いことである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人がまともに引っかかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三人がいよいよ成功してそのアメリカ人を取巻いて巣へ引上げようとかかるとみんな一斉に、「家族万歳！",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人を巣に引き入れて衣裳戸棚の葡萄酒の最後の一本を重く取り出した時リゼットは急に悲しくなった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一八七〇年にダーウィンと一緒になったとき、あるアメリカ人からよこした手紙のことを話した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人にしても特別に長い方に属するかと思われるこの税関吏の顔は、チューインガムを歯と歯の間に引延ばすアクションのために一層長く見えるのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり憂鬱になって、そこを出ると、うしろから来たアメリカ人が「ビグ、ジャーップ」と云って唾をはいた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人には勉強家努力家がなかなか多い。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クーシューというフランス人は『アジアの詩人と賢人』と題する書物の一節において、およそ世界の中で日本人とアメリカ人と程にちがった国民は先ずないという意味のことを云っている。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあの一種特有なアメリカ人の歩き方までを真似ようとするのである。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューインガムの流行常用によってその歯噛みの動作の反応作用から日本人が生理的並びに心理的にだんだんアメリカ人のようなものに接近して行くというようなことはあり得ないものか。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（丁度今日のアメリカ人のやうに。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が品川を過ぎると、彼女のかたわらに美男のアメリカ人がにこにこしながらやってきた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "通過記録計がまた一転廻すると、太田ミサ子が、情夫のアメリカ人を連れて、中之島の方面から並木道をつたってあらわれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫舌のアメリカ人がスープを睨んでいる。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アメリカ人がどうして、日本の偽札を拵えるの？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてアメリカ人に日本の偽札が拵えられるの？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アメリカ人はずるいんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにアメリカ人になりたがっても、過去二千余年の歴史は消されない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広告びらの版画でも絵がよければ芸術であり、アメリカ人が高い金を出して買うのであるが。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯はアメリカ人の学校だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人は、労働賃銀が動物なみで、原料がいくらでも得られる、殆んど組織がない支那へ眼をつけている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タフトらしい、せいの高い、鼻筋の通った、アメリカ人が支那語を使って何か指図をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アメリカ人のナンセンスとは全く別の種類に属するナンセンス芸術である。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそかもしれないがしかしアメリカ人にとっては充分可能なことである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人でありながらロシア人やアメリカ人になったような気持ちで浮かれた事を満載した書物はよく売れると見えて有り過ぎるほどあるのに、連句の本などはミイラかウニコーンを捜す気で捜さなければ見つからない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば日本人は彼の映画を鑑賞する際に、アメリカ人や、ドイツ人には許されない特等席の一部を占有した形になるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人やドイツ人には到底理解されないものが東洋日本の大衆には理解され享楽されている例はいくらでもある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
