    "definitions": [
      {
        "index": 1,
        "gloss": "green willow (i.e. one that has budded)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "乘合船の河蒸汽を棧橋に出でて待つに、結びて放つ青柳の絲もなく、鳥さへ今は塒にかへりし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的新しい方の例で自分の体験の記憶に残っているのは明治三十二年八月二十八日高知市を襲ったもので、学校、病院、劇場が多数倒壊し、市の東端｜吸江に架した長橋｜青柳橋が風の力で横倒しになり、旧城天守閣の頂上の片方の鯱が吹き飛んでしまった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳教諭を送る宮沢賢治瘠せて青めるなが頬は九月の雨に聖くして一すぢ遠きこのみちを草穂のけぶりはてもなし",
              "citation": {
                "source": "青柳教諭を送る",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇の惰力で、青柳の影の濃い千住大橋の袂へ近づく。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒目勝の清しやかに、美しくすなおな眉の、濃きにや過ぐると煙ったのは、五日月に青柳の影やや深き趣あり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜って流れた扇子の余波か、風も無いのにさらさらと靡く、青柳の糸の縺れに誘われた風情して、二階にすらりと女の姿。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れて咲いた欄干の撓な枝と、初咲のまま萎れんとする葉がくれの一輪を、上下に、中の青柳は雨を含んで、霞んだ袂を扇に伏せた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶にこぼれて出て来るのは、小姓梅之助に手を曳かるる腰元の青柳か、密と外して酔ざましの椎茸髱。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがてお千世が着るようになったのを、後にお孝が気が狂ってから、ふと下に着て舞扇を弄んだ、稲葉家の二階の欄干に青柳の糸とともに乱れた、縺るる玉の緒の可哀を曳く、燃え立つ緋と、冷い浅黄と、段染の麻の葉｜鹿の子は、この時見立てたのである事を、ちょっとここで云って置きたい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も誰も知らず、諸国漫遊の途次、一昨年の秋、この富山に来て、旅籠町の青柳という旅店に一泊した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯燈がほんのり點れて、あしらつた一本の青柳が、裾を曳いて、姿を競つて居て、唄が題してあつたのを覺えて居る。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "針の稱に、青柳、女郎花、松風、羽衣、夕顏、日中、日暮、螢は光る。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、島の青柳に銀の影が、パッと映して、魚は紫立ったる鱗を、冴えた金色に輝やかしつつ颯と刎ねたのが、飜然と宙を躍って、船の中へどうと落ちた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、「いらして、また、おいで遊ばして」と枝折戸でいう一種綿々たる余韻の松風に伝う挨拶は、不思議に嫋々として、客は青柳に引戻さるる思がする。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干に青柳の枝垂るる裡に、例の一尺の岩魚。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「憚り、」　と身を横に、蔽うた燈を離れたので、玉ぼやを透かした薄あかりに、くっきり描き出された、上り口の半身は、雲の絶間の青柳見るよう、髪も容もすっきりした中年増。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱いだ羽織の、肩寒そうな一枚小袖の嬌娜姿、雲を出でたる月かと視れば、離れた雲は、雪女に影を宿して、墨絵に艶ある青柳の枝。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の氏郷が自ら毒飼をされた事を知って、限りあればの歌を詠ずると、千利休が「降ると見ば積らぬさきに払へかし雪には折れぬ青柳の枝」という歌を示して落涙したなどというのは余り面白くない演劇だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓家二軒の廂合で、透かすと、奥に薄墨で描いたような、竹垣が見えて、涼しい若葉の梅が一木、月はなけれど、風情を知らせ顔にすっきりと彳むと、向い合った板塀越に、青柳の忍び姿が、おくれ毛を銜えた態で、すらすらと靡いている。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　門、背戸の清き流、軒に高き二本柳、――其の青柳の葉の繁茂――こゝに彳み、あの背戸に團扇を持つた、其の姿が思はれます。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月廿六日、神田青柳にて古書即売会。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お納戸、利久、御幸鼠、鶯茶、それにはなほ青柳の色も雑つて、或は虫ばみ、或はねぢれたのもあり、斑らに濃い地面の色の上に垂れ流れるのは自らなる絵模様である。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の勸めで初めて青柳學士の診察を受けて、慢性腹膜炎といふ名を附けられ、入院しなければならぬと申し渡された時は、結局はそれを信ぜねばならぬと思ひながらも、まだ何か嚇かされたやうな氣持がしてゐた。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "予をして爾く速かに入院の決心をなすべく誘つたものは、夜寢てさへも安き眠りを許さぬ程に壓迫するその腹でも、また青柳學士の口から出た予の生命に對する脅迫の言葉でもなく、實に予をして僅かに一日の休養さへも意に任せさせぬ忙がしい生活そのものであつた。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛙だと青柳硯と云うんです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら今朝の雪では、遊女も化粧を朝直しと来て、青柳か湯豆府とあろう処を、大戸を潜って、迎も待たず、……それ、女中が来ると、祝儀が危い……。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　門、背戸の清き流、軒に高き二本柳、――その青柳の葉の繁茂――ここに彳み、あの背戸に団扇を持った、その姿が思われます。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒の雀焼の匂いの中を通り、橋詰の青柳を見返り、いそ／＼とさしかゝる千住の大橋、蓊※として川気の黄いろなさみだれ月のすみだ川。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちがその青柳橋の上に立っていると、何が珍しいのかぞろぞろと年寄や子供たちが周囲にたかって来た。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳町の百二十余日、予はついに満足を感ずることができなかった。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
