        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『ほれ喧嘩だ』と、云ふとドツと一時に動搖めいて一崩れ、ばたばたと男の後を追うて、津浪が押し寄せた樣、逸早く合點した連中は、聲を擧げて突貫した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な顔して三次と紙入れを見比べて居たが、紙入れを拾って三次の後を追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひら小僧単身そッとその後を追う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて山左と左膳が後を追う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎大声に、Ｔ「泥棒ッ」　と叫んで文六の後を追う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑怯者ッ、とばかり、文六と若侍達後を追う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎が心配して、　「コレコレ怒るな」　で後を追う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吉は逃げて行く浪之助とお類の姿を見て後を追う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "群を離れた犬が一疋汀へ飛んで来て草の間を嗅いでいたが、笛の音が響くと弾かれたように駆け出して群の後を追う。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広袖を着たまま亡くなると、看病やつれの結び髪を解きほぐす間も無しに、母親も後を追う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は黒百合の花を捧げて、身に影も添わず、淋しく心細げに彳んでいたが、およそ十歩を隔てて少年が一度振返って見た時、糸をもて操らるるかと二足三足後を追うたが、そのまま素気なく向うを向いてしまったので、力無げに歩を停めた、目には暗涙を湛えたり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と間に割込むは、夫人の後を追うて、勝手口より出たる矢島、「今聞いた、何か、活す法もあると謂ったな、なろう事なら活して戻せ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後を追うて大阪に来た、探すのに苦労した、今はこの辺りの料亭にいる。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八代の共同作業所へ着いたのは五時過ぎだつた、そして意外にも樹明君が後を追うて来た、小郡から自転車で二時間半で飛んだのである。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を追うようにして、先日の女のひとが鞄とステッキを持って玄関からあわてて出て来て、「あら！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭、大変だ、お店の軒下に縊死人があるのだ、すぐ来ておくんなさい」「そうか、すぐ往く」　米は羽織を引っかけながら小僧の後を追うた。",
              "citation": {
                "source": "寄席の没落",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に分ち名づけたる心が身に先だてば、身は心に隨つて後を追うて漸く一となり、身が左の方へ進めば、心も左の方へ伴なつて行き、心身一即二、二即一、の妙趣を不斷に繰返すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴染みの女給がちかごろ東京へ行った由きいたので後を追うて行きたいと思っていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本だけと酒をとり、果物もおごってやって、オイチョカブの北田のことを訊くと、こともあろうに北田は小鈴の後を追うて別府へ行ったらしい。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩は物乞に往っている父親の左門を、お袖は途中で別れた与茂七の後を追うて来たところであった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年の後、スティヴンスンは、其の時カリフォルニアに帰っていたファニイの後を追うて、大西洋を渡った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニイの後を追うてカリフォルニア迄渡って来、極度の貧困と極度の衰弱との中に、友人や肉親との交通も一切断たれたまま・桑港の貧民窟の下宿に呻吟していた時のことだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にゐた二人の島民水夫が其の場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にいた二人の島民水夫がその場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかれはこのとき、海水にぬれた壁のあとをおうて眼をだんだんに上へうつしたとき、水は階段の上の口、すなわち甲板への出入り口から下へ落ちてきたのだとわかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもなら、とびだしてきてあとをおうのですが、どうしたのか、音もたてなければ、姿も見せませんでした。",
              "citation": {
                "source": "ペスときょうだい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
