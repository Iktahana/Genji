          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "下屋の水窓へ、折から横づけの船から、穴子、ぎんばうの畚、鰈、あいなめの鮹盤臺を、掬ふ、上げる、それ抱き込む、大鯛の溌剌たるが、（大盤臺）から飛び上つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱚、魴※、鯒、あいなめ、目ばる、藻魚の類合せて七百籠。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、あいなめを焼いて久しぶりに御飯をたべる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいなめに、鯛に、さばに、いさき、かつおの紳士。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹のたたき、あいなめの煮物、船で作った絹｜漉しの冷奴、大根の風呂吹き。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいなめ、と云う小魚と栗と新しい野菜の漬物で茶漬をうまく喰べた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕れるのは鰈が多く、あいなめとか、夏になるとわたり蟹なども捕れるが、蟹の場合はべつに心得があった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
