        "examples": {
          "standard": [
            {
              "text": "私は毎日ＲＧＢについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＲＧＢの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＲＧＢが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＲＧＢについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＲＧＢの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＲＧＢが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＲＧＢという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＲＧＢについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＲＧＢは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＲＧＢが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＲＧＢは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＲＧＢの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＧＢは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＲＧＢは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ディスプレイの解像度は七二〇×五一二ドットと定め、アナログＲＧＢ方式によって五一二色の中から任意の一六色を選べるようにした★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方三つの信号を分けて送るＲＧＢ信号の形式をとれば、より鮮明なカラー画像が実現できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＲＧＢには、デジタル方式とアナログ方式とがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタル方式では、電球のスイッチを入れたり切ったりするように、ＲＧＢのそれぞれの色を出したり出さなかったりする単純な組み合わせによってカラーが表現された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方アナログＲＧＢでは、電球の明るさを連続的に変化させられる調光式の照明のような、中間的な明るさの組み合わせによる表現も可能になった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は新しいマシンにアナログＲＧＢを採用し、ＲＧＢの各色に三ビットで八段階の輝度を表現できる構造を与えて、八の三乗で五一二色の表現を可能にした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ＰＣ―９８０１は、デジタルＲＧＢによる八色の表示にとどまっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルＲＧＢで決まりきった八色しか表示できないという点は、彼らが目指した世界とは無縁の発想から導き出された解答だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身、ＰＣ―９８０１の基本路線とするべく腹をくくっていたＭＳ―ＤＯＳを前面に押し出し、アナログＲＧＢを採用して六四〇×五〇〇ドットで二五六色中から任意の一六色を表示できる強力なグラフィックス機能を備えたパソピア16に、浜田は強い警戒感を覚えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
