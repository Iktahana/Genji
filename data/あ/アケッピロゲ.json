        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "開けっぴろげの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「わざと見えるように、お店をすっかり開けっぴろげてあるのよ。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は、肉体の喜びさえかくし勝ちなのだが、桂子はすべてが開けっぴろげのようで、私には可愛い女だった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも完全に、開けっぴろげに。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一度だけ見た小柄で色白なあの娘の、驚愕とも恐怖ともつかぬ開けっぴろげな表情を瞼にうかべながら、その沈黙に対抗する。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "全然秘密にしていないし、扉を開けっぴろげにして、レスブリッジや誰にでも中を見せており、盗難品であれば決してやらない。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "典型的な退役軍人、開けっぴろげで、押しが強く、灰色の瞳がうっすら赤い。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに関しては余りにも率直で開けっぴろげだ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあけっぴろげな笑顔でニッコリ笑ったものである。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグランドにでも、つれてってくれるのかしら」　と、あけっぴろげな笑顔を慶一に向ける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その船員は、すぐに前とおなじあけっぴろげな態度になって、「おれは、本なんてものはなん年間も読んだことがねえが、ずいぶんめずらしいことを書いたのがあるそうだね。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は君を、ありとあらゆる美徳をかねそなえた男だと思ってるよ」　彼はあけっぴろげに、いかにも愉しそうに笑ったが、相手は調子にのってこなかった。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、二階目に一つ空いたアパートがあって、すっかりあけっぴろげにされ、中でペンキ屋が働いていたが、その連中も彼の方をふり向きもしなかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから部屋を出たが、今度はすっかりあけっぴろげにして置いた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗ラシャの外套をあけっぴろげにして、醜い顔にずるそうな笑いを浮かべている。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは外套の前をあけっぴろげた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけっぴろげの窓から、海風が流れこんできて、もうあと二日で夏休みになるよろこびが、からだじゅうにしみこむような気がした。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、刀はふりまわしていても、もうこのときには、くるった頭はいよいよその度をまして、刀をふりかざしているかと思えば、たちまちゲラゲラと笑いだし、ゲラゲラと笑いだしたかと思えば、また目をいからせて枝を見あげてにらみつけ、ヨダレをながして前を子どものようにあけっぴろげて、カラキシだらしがありません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも赤鬼という仇名にふさわしく、栄二は「こいつは案外お人好しだな」と思いながら、彼の見ている前で仰向けに倒れ、両手を頭のうしろで組んで、あけっぴろげに大欠伸をした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつにさばさばした、あけっぴろげの女性だね。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだずっと、小柄で肥り気味の、あけっぴろげな性的魅力のある女のこが、なにもしていないのだが、すでに髪をふり乱した感じで、大きなアンプのそばに立っている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）けれども、わたしの心は十分に大きくない代りに、それだけあけっぴろげである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシを追い出してちょうだい」　バーカ団長があけっぴろげに愚痴った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
