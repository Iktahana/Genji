          ],
          "literary": [
            {
              "text": "何処からか指輪が来ると云うあんばいで、仕事も休みがちで遊びまわるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が私を引っぱり出してこんな事をして遊びまわるのは、叔父の待合に入浸っているか、又は旅行している間に限っていたので、公園前の自宅に私を引っぱり込むような事は絶対にしなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り五週間も遊びまわることは許されなかった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし他人にはえらく寛大で、人が元気にまかせて遊びまわるのを、さも羨ましげに、驚嘆することもあった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯がいらないのでないけれど、食事をしながらああしたりこうしたり遊びまわるのは子供のつねです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの子供のありは、だんだんあたりを遊びまわるようになりました。",
              "citation": {
                "source": "三匹のあり",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "健一は休みの間、彼らと一緒に遊びまわるのだ。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "生来おっとりとした健一が、伯母のところではのびのびと遊びまわることができたのは、いとこのお蔭といってもよかっただろう。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔にも、今にも、将来へも、つばさをひろげて、遊びまわるべきである。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女の桎梏を脱け出して、たった一日、庶民生活の中を遊びまわる姫君を仮りて「王侯生活も羨ましいものではない」ということを、お説教でなくあの映画は、ユーモラスなうちに颯爽と子供らにさえわからせる。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年萬聖節の前夜になると、古い窓には明るく燈火がついて、しろの中をあそびまわる妖精たちの小さいすがたが道ゆくものにもよく見えて、パイプや笛の音も聞えてきた。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            }
          ]
        }
