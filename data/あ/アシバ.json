[
  {
    "uuid": "5a15d5c9-beaa-5a72-a46f-27bb23ae0d7b",
    "entry": "足場",
    "reading": {
      "primary": "あしば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
