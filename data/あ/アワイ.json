        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日淡いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "淡いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は淡いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には淡いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "淡いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは淡いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "淡いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は淡いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では淡いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "淡いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に淡いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では淡いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "淡いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると淡いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "淡いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では淡いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に淡いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により淡いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "淡いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に淡いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "遺骨を拾う人と対照して、早春の淡い哀傷がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句から感ずるものは、各自に小さな家に住んで、それぞれの生活を悩んだり楽しんだりしているところの、人間生活への或るいじらしい愛と、何かの或る物床しい、淡い縹渺とした抒情味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが消えたあとに残るものは淡い「時の悲しみ」である。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "莟みの集団の下から、房になった黄色い四弁花が、いま電燈の蒼い光にきらびやかに匂っている、茎は一皮下には、青い血が通っているのではないかと思われるほど透き通って、有らゆる春の緑の中で、最も練り抜かれた緑である、見つめていると、早春の名残といったような淡い哀愁に加えて、物の末期の惨酷を思わせる姿である。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯の準備をしているうちに、驟雨が一としきりあって、雷鳴が近くに聞えたが、夜に入って、星が瞬いた……かと思うと、淡い、軽い霧が、銀河のように空に懸る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに富士の裾野の水車は、水辺に夕暮の淡い色を滲じみ出した紫陽花の一と群れに交わって、丸裸のまま、ギイギイ声を立て、田から田へ忙しく水を配ばり、米を研ぎ、材木を挽いたりして、精を出して働いている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は野火の煙の低迷する如く、富士の胴中を幅びろに斜断して、残んの月の淡い空に竜巻している、うぐいすのなく音も交る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はかういふ驛には附きものであつたあのヨボ／＼の老車夫の後姿にまつはる淡い感傷はもう今では味はゝれないものになつてしまつたのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ぐれ、めっきり水の細った秋の公園の噴水が霧のように淡い水量を吐き出している傍を子守達は子を乗せた乳母車を押しながら家路に帰って行く。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」に左袒する者は 〔amour-gou^t〕の淡い空気のうちで蕨を摘んで生きる解脱に達していなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」な空間に漂う光は「たそや行灯」の淡い色たるを要する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「秋の歌」のうちで「白く灼くる夏を惜しみつつ、黄に柔かき秋の光を味わわしめよ」といって人生の秋の黄色い淡い憂愁を描いている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで若い靴磨きが変な街路詩人の詩を口ずさみ三等席の頭上あたりの宵の明星を指さして夕刊娘の淡い恋心にささやかな漣を立てる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較にならぬほど上等であるために却って正月の雑煮の気分が出なくて、淡い郷愁を誘われるのであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十首の連作を通しての上に、物になずむ親しみの情の淡い気持が、油然として湛うてる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もあらぬ実験室の夜の更けにしづかにひびく装置を聞きぬ　この歌は題目が殊に新しく、着想も面白いが、その題目や着想が淡い情調に融合されて、少しも目立たないで能く単純化が行われて居る。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼は休暇の度に近親の年上の誰かに淡い恋をしたが、次の休暇には前の恋人はすっかり忘れて、また別の初恋をするのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカバレット・トア・ズン・ドルの淡い憶いがネムの花に夢のように、あらわれるのだが、彼女は何もかも知らぬふりをして、私の用事を待つ、それが英国種の牝犬のように無関心な顔をして、その実細心なデコルテを内にかくしてかしこまっている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方が来ると烏瓜の煙のような淡い花が繁みの中から覗いているのを蛾がせせりに来る。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには「まさかこれまでが」と思うほど淡いのが草の葉などに染まっていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばそれを故のない淡い憧憬と言ったふうの気持、と名づけてみようか。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風景のうえを遊んでいた私の眼は、二つの溪をへだてた杉山の上から青空の透いて見えるほど淡い雲が絶えず湧いて来るのを見たとき、不知不識そのなかへ吸い込まれて行った。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の木瓜はちら／＼と灯をともし、樹の根を包むだ石楠花は、入日の淡い色を染めつゝ、然も日は正に午なのである。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈より高い一｜面の雑草の中に、三本、五本また七本、淡い紫の露の流るゝばかり、且飛ぶ処に、茎の高い見事な桔梗が、――まことに、桔梗色に咲いたのであつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉の形をしたこの島山の胴のまん中に、岩と岩との幅広い断れ目の溝があって、そのあわいから、わたくしは生い立たせられつつあるのを見出したのでした」　西の海を越えて、うねって来た二つの大きな山の脈系、それは島山の胴の裂け目を界にして南北に分けられる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遁ぐるが遠くには去らず、いつもおなじほどのあわいを置きてはキラキラとささやかなる羽ばたきして、鷹揚にその二すじの細き髯を上下にわづくりておし動かすぞいと憎さげなりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立あがりてゆくてを見れば、左右より小枝を組みてあわいも透かで躑躅咲きたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廁は井戸に列してそのあわい遠からず、しかも太く濁りたれば、漉して飲用に供しおれり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徳を修めて仁を行うなら、火※中にも青蓮がありますじゃ、このわしが何を知りましょうや」　曾は思いあがってきて、すっかり気をおとして帰ったが、それから台閣の想いはあわいものになった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわい褐色のベストからは太い真鍮製のアルバート型時計鎖が垂れ下がっていて、先には四角く穴のあいた金属の小片が装飾品としてついていた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
