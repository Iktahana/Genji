        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "秋の日は、干物の匂ひがするよ干物の、匂ひを嗅いで、うとうとと秋蝉の鳴く声聞いて、われ睡る人の世の、もの事すべて患らはし匂を嗅いで睡ります、ひとびとよ、秋の日は、干物の匂ひがするよ",
              "citation": {
                "source": "干物",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良いお天気で、幅二間程の、下高井戸駅通りは秋の日をうけて黄色く乾いてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋の日に、庭の桜が返り咲きをしたのを見て、『春のように暖かいから、桜思いました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日の侘しく散らばふ青梅街道。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ號令がかかつて、私たちは捧げ銃をして、みると、校長は、秋の日ざしを眞正面に受けて、滿面これ含羞の有樣で、甚だ落ちつきがなかつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の燈やゆかしき奈良の道具市　秋の日の暮れかかる灯ともし頃、奈良の古都の街はずれに、骨董など売る道具市が立ち、店々の暗い軒には、はや宵の燈火が淡く灯っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳散り清水かれ石ところところ　秋の日の力なく散らばっている、野外の侘しい風物である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま秋の日は暮れ行かむとし風は人氣なき小徑に散らばひ吹けどああ我れは尚鳥の如く無限の寂寥をも飛ばざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日がかんかん照りつけるので柿の葉が乾燥してじりじりと巻き上がるのでいつの間にかそっくりと雀を包んで動けないように縛ってしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕合せに晴天が続いて毎日よく照りつける秋の日のまだなかなか暑かったであろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の市の秋の日は、　　大人しい発狂。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わが家へと入りてみれば　　なごやかにうちまじりつつ秋の日の夕陽の丘か炊煙か　　　　われを暈めかすもののあり　　　　　　　　　　　　古き代の富みし館の　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　何時の日か絶えんとはする　カドリール！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日が段々低く落ちて行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日足の短さ、日はようやく傾きそめる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午過ぎの秋の日を一杯に浴びて気持のよさそうに羽根をふるわせたり、可愛らしい頭をかしげてみたりしている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日影は次第に深く、旅館の侘しい中庭には、木々の落葉が散らばっていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の四辻に写真屋があり、その気象台のような硝子の家屋に、秋の日の青空が侘しげに映っていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り出せるは、皺になれる敷島の袋、残れる一本を、くわえて、火を点ず、残れる火を、さて敷島の袋にうつす、秋の日の下、物思いのひるさがり、芝生の上、めらめらと、袋は燃ゆらし　灰となりゆく、あわれ、我が肺もこの袋の如、日に夜に蝕まれゆくか、秋の日の下、くゆらす煙草のいとからし。",
              "citation": {
                "source": "詩二つ",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「すつかり水の涸れてゐた、空つぽな噴水が再び落ち出す、秋の日々であつた。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終支拂ひに足らず勝ちな月末までにもう十｜日とない或る秋の日の夕方だつた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは靜に差した明るい秋の日差の中に涙の熱くなるやうな努力に見えた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　へリオトロープ　よく晴れた秋の日の午後｜室町三越前で電車を待っていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の商人風の男の中に交じった一人の若い女の紫色に膨れ上がった顔に白粉の斑になっているのが秋の日にすさまじく照らし出されていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源は秋の日など隅田堤より遠く西の方に青み渡りて見ゆる秩父郡の山※の間にて、大滝村といへるがこの川の最上流に位する人里なれば、それより奥は詳しく知れねど、おもふに甲斐境の高山幽谷より出で来るなるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "石神川は秋の日の遊びどころとして、錦繍の眺め、人をして車を停めて坐に愛せしむる滝の川村の流れなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかあかとつれない秋の日」が、野の果に沈んで行く。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気のために一年以上全くコーヒーを口にしないでいて、そうしてある秋の日の午後久しぶりで銀座へ行ってそのただ一杯を味わった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉のからだが、秋の日ざしに、透きとおって見える。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままの距離で二人は二三歩あるいて来ると、派手な水色で胸あきのひろい服をつけたエレーナ・ニコライエヴナがわざとらしくはしゃいだ調子で、「まあ思いがけないですこと！",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
