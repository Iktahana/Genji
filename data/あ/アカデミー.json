    "definitions": [
      {
        "index": 1,
        "gloss": "academy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔は建築のアカデミーでシンケルが死ぬまでここに住まっていたそうである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い昔の天測器械や、ドルイドの石垣などは別として、本当の意味での物質科学の開け始めたのはフロレンスのアカデミーで寒暖計や晴雨計などが作られて以後と云って宜い。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴を生んだ日本に、西鶴型の科学者の出現を望むのは必ずしも空頼めでないはずであるが、ただそういう型の学者は時にアカデミーの咎めを受けて成敗される危険がないとも限らない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは却って古代の宗教画などに見られて近代のアカデミー風の画には薬にしたくもないところである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はこの意味において仏蘭西にアカデミーのある事すらも快よく思っておらぬ。",
              "citation": {
                "source": "博士問題の成行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ここには無名の偉い人々の傑作もあるし、――ここには、その当時は有名であったが、後にはその名さえ炯眼なアカデミーに黙殺されてわたしのところに残っている人々の、未完成の下図もある。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれらの普遍性一般性に依拠して尚ほ且つモヂリアニがアカデミーに反逆的であつたといふ困難な努力やその価値を、汲みとらなければいけない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "光りと物質との区分の機械論者の多いアカデミーな画家達にとつては、油絵具といふ一物質に就いて『思索』したことなどは恐らくあるまい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミーの画家は油絵具の処理の仕方は成程経験者で苦心的である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼の架空に描いた幻のやうに見えたり、古風な物語の中のアカデミー派の挿画の一つのやうに、眼の先の百合子の姿から遊離して、頭の一隅に映つて見へてゐた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木清氏等によって、明治以来、政府は文化政策というのを持たなかったと云われ、アカデミーの問題も今日そこのことからふれられているのであるが、明治初期から文化振興のための政策はなかったかもしれないが、その或る面を罰することには決して吝でなかったことが分る。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本も、軍事的行動に於て所謂怒髪天を衝く態に猛勇なばかりでなく、文華の面でこのように独自であり、政府もその評価に吝でないという一つのジェスチュアとして、アカデミーもつくられる一つの時代的必然があるのである。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミーによって日本最高の芸術と云われる竹内栖鳳の五匹の蛙が五千円というような絵や「新日本文化の会」で中河与一氏、保田与重郎氏などによってロマンティック狂信的に讚えられる万葉精神と、私たち一般人の日々の経済力、合理性との間に、調和し難い裂け目が口をあいている。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるからこそ、アカデミーについて言及する時、人々の顔には複雑な表情が浮ばざるを得ないのである。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし真に文学の発展を期するのであれば、日本の文学史の上に一つの新たな芸術運動をもたらした左翼的作家の業績も、当然アカデミーによって評価せられなければならない筈である。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタイン自身が自分の心持からレーニングラードのアカデミーで働くのなどはいやだというのと、ソ連がもし希望ならばよろこんで、この名誉ある人類的スケールの科学者にふさわしい待遇をした、というのとは、二つの別な態度なのではあるまいか。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は誰知らぬ者ない「フォマ・ゴルデーエフ」の作者、「三人」の作者、鋭く小市民性に反撥して人生の叡智を勇者の飛躍にあることを示した「鷹の歌」の作者、フランス・アカデミーのユーゴー百年祭にパリへ招待された国際的作家マクシム・ゴーリキイである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイの誕生六十年記念祭にあたって、ソヴェト同盟・共産主義アカデミーで行われた討論は、ゴーリキイをもっとも重大な使命を果した文豪であるとした。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して「地球の回転は時の経つに従って其の速さを変えるか」に就いてのベルリン・アカデミーに提出された懸賞論文はカントの独創的天才を示すものである。",
              "citation": {
                "source": "カントと現代の科学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　同アカデミー版全集。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミー（大学の如き）とジャーナリズム（報道現象）との対語でなくてはカテゴリー論の虫がおさまらない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこうしたフィロロギーとカテゴリエン・レーレとは大学のアカデミーの絶大な価値を生むものだと私は信じている。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大学は、それがブルジョア科学の大学であっても、文化技術の素養的習得を与えるというアカデミー機能に於ては、尊重すべき存在なのだ。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私はアカデミー至上主義に対しては判然と反対せざるを得ない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた史的認識の代りに思想的定位のないただのフィロロギー、時局認識の代りに思想目標のないただのカテゴリー分析、之が今日の大学アカデミー機能の精々の仕事である。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が又大学アカデミーは、文化的技術は有っていても使い途が明らかになっていないから、盲目的なテクニシャンしか産まない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通のアカデミーの科学者には見られない思い切りよく斬新で傍若無人な進歩的思想家である。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は独学の異分子がアカデミーで出会う運命の一つであったらしい。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミーにいる沢山の旧友達、先輩、知人で、これと思われるような人は、大抵幾冊かの本を出し始めたが、どれも之まではあまり筆を執らなかった人達だ。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミーの友人達は曽つて何に遠慮して沈黙していたのだろうか。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
