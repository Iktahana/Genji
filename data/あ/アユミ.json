    },
    "definitions": [
      {
        "index": 1,
        "gloss": "walking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩みについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩みという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩みの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩みが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩みを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩みについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩みの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩みの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩みが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩みという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩みという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩みについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩みを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩みは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩みについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩みが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩みは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩みの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩みは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩みは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "馬場は躊躇せず、その報いられなかった世界的な名手がことさらに平気を装うて薄笑いしながらビイルを舐めているテエブルのすぐ隣りのテエブルに、つかつか歩み寄っていって坐った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、――」立ちあがって、つかつか太宰のほうへ歩み寄り、「ばけもの！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＳ子の後から昇降口の方へ歩み寄つた、――ピヨツとＳ子は運転台の方へ走つて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朗吟調小曲――詩篇小解漂泊者の歌（序詩）　　斷崖に沿うて、陸橋の下を歩み行く人。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡しきものに逢ひけるよ、と思ふまもなく、つかつかと歩みよりて、なつかしげに物言はるるに、こはけれど遁れゆくべきにあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じ白衣着けたる連れの男は顔長く頬髯見事なれど歩み方の変なるは義足なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかつかと歩み寄つたＫ少尉、いきなりびんたの一つも張るかと思つたらさにあらず、『それ位にして置いて早く集つて下さい、濟まんが』とやつたものだ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢいつと茫然黄昏の中に立つて、なんだか父親の映像が気になりだすと一歩二歩歩みだすばかりです深夜の思ひこれは泡立つカルシウムの乾きゆく急速な――頑ぜない女の児の泣声だ、鞄屋の女房の夕の鼻汁だ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒き浜辺にマルガレエテが歩み寄するヴェールを風に千々にされながら。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の照る砂地に落ちてゐた硝子を、歩み来た旅人は周章てて見付けた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝるをりしも剛直の、さあれゆかしきあきらめよ腕｜拱みながら歩み去る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "石楠花の群落が一時途絶えて、私の歩みは御庭へと移された。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三金時丸は、貪慾な後家の金貸婆が不当に儲けたように、しこたま儲けて、その歩みを続けた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音にせき立てられて、子等の歩みも一層速くなつたんだらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の体にも、私の心にも、私の歩みを速めるだけの力が残つてゐなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、次の歩みの時には、もう元の闇に帰つてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄の歩みはたどたどしいにしても翁は次いで三日も歩んだ麓の幅を計ることはできなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はそれに満足しまた身を返して広い桜庭を円形に歩み出すのでありました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるという事実の上に根を置いて、冷酷なほどに思索の歩みを進めて下さい。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこれから寝て、明日はまた、次に来る来年の「試験」の準備の道程に覚束ない分厘の歩みを進めるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くより音して歩み来るやうなる雨、近き板戸に打つけの騒がしさ、いづれも淋しからぬかは。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦心霜ふりてすこしつめたき朝を、手に雲雀料理をささげつつ歩みゆく少女あり、そのとき並木にもたれ、白粉もてぬられたる女のほそき指と指との隙間をよくよく窺ひ、このうまき雲雀料理をば盗み喰べんと欲して、しきりにも焦心し、あるひとのごときはあまりに焦心し、まつたく合掌せるにおよべり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の心の歩みは尊く涙ぐましい。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "（絵具入の箪笥に歩み寄り、紙巻を一本取りて火を付く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徐に戸の口に歩み寄り、徐に戸を開き、退場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は徐に煖炉に歩み寄り、その上なる素焼の瓶を取りて絵具入の箪笥の上に据え、それに翁草の花を挿す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（立ち上り、歩み寄る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なんだかひどく気楽な心持になつて、或る柱の背後へ歩み寄つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等を踏みにじつてゆく日々の歩みの下にぢつと我慢をして、まだ何かしらを待つて居なければならないかのやうに、頑強な甲蟲のやうに生き續けてゐるのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の足もとから私の歩みを引き離して、それでもつて町の向う側を、木靴でもつてのやうに鳴らしだした。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
