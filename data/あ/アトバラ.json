    "definitions": [
      {
        "index": 1,
        "gloss": "afterbirth pains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
