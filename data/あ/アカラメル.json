    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to blush",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから、僕は、わけもわからず、顏を赤らめる。",
              "citation": {
                "source": "白紙",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この婦人は、顔を赤らめるどころか、いたって平気でフルハタの前に立った。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の銀と紺青が笑むと、ぶなの黄金色は快く笑いかえしてその間の桜のうす紅の花は恥かしがって顔を赤らめる。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹に逢った時顔でも赤らめるかと思ったら存外｜淡泊で毫も平生と異なる様子のなかったのはいささか妙な感じがした。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人物が赤面するなぞとは、ちよつと思へないであらうが、あんなに顏を赤らめる人はなかつた。",
              "citation": {
                "source": "三十五氏",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の言葉がすぐ自分に反映してくるらしく、その蒼白い顔を度々赤らめるのだった。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を赤らめるということも人間としてそんなに恥ずべき道徳的欠点や、間違いに対してではないのですから、我々はもつと率直に笑い、そして笑われることを、それほど恐れないというような習慣をつける必要があると思います。",
              "citation": {
                "source": "笑について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は妻君と別居して自炊してをり、女房のゐない方が清々とえゝですわと言つてゐたが、もう五十ぐらゐ、鼻ヒゲなど生やしてゐるくせに何かといふと顔を赤らめるやうな小心な善人で、根気のつゞかない気分屋であつた。",
              "citation": {
                "source": "ヒンセザレバドンス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中の一寸した冗談口にも、蒼白い顔を赤らめることがあった。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで、たゞ一人、ある新聞の音楽批評を受持つてゐる佐山某の、うそとは思へぬ力の籠つた賛辞と、会へばきまつて顔色を赤らめる年に似合はぬ幼々しさとに、彼女は無関心ではゐられませんでした。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を見れば、片焦げて※び赤らめるその面、端に殘れる緑にも蟲づき病める瘡の痕、黒斑歪みて慘ましく鮮明にこそ捺されたれ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今では、おずおずと男の方を見て、顔を赤らめるだけだった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルソオは、それに、第一、なぜともわからず、不意に顔を赤らめるという魅惑的な手段をもっていて、それでまた、彼は、少女のように誰かれから好かれるわけなのだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とよもうっかりせんといてな」「ほんなもん、わたしら、大丈夫どす」　が、とよは何故か顔を赤らめる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから腰抜け彌八はどうしたというんだ」「最初は一番可愛らしい祭が目当てだったが、この娘はたった十七で、腰抜け彌八が半日眺めて居たって、まだ顔を赤らめることも知らないほどのねんねだから、張合い抜けがして、今度は一番｜年嵩のお半に乗り換えた。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しきまりが悪いと、頬ではなく、その日に焼けた頸を所斑に赤らめる母親は、独りの娘を珠のように労って、夕方涼風が立つと、並木の下をゆるゆると威厳をもって散歩する小娘の傍に引添って、満足したお伴のように随いて行くし、私にとっては、どうしても悪意の持ちようのない善良な愛すべき一家であったのである。",
              "citation": {
                "source": "一つの出来事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独と異境と、晩期の深い陶酔の幸福とに勇気づけられ、説得されて、かれはどんな風変りなことをも、はばかるところもなく、顔を赤らめることもなしに、みずからに許した。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を狂人爺さんだとして、言い進んだ、今まではりっぱな人だと思っていたが、しかしそれは自分の思い違いだった、車夫でさえ顔を赤らめるようなひどいことを言い、眼は顔から飛び出し、その眼がもしピストルだったら、自分は殺されるところだった、などと……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に会うと直ぐ顔を赤らめるような、優しいあのセルヴィヤ人が鉄心石腸の社会主義者で、熱烈な憂国者で、而も亡命の志士であったのか。",
              "citation": {
                "source": "二人のセルヴィヤ人",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のほうがずっと豊かな顔をしてるが、でも君は彼と同じように顔を赤らめる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を赤らめる合唱隊の子供のいかに多くが、年わかき法師のいかに多くが、ペルレットの牛乳の壺を頭にいただくことであるか！",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は、目のふちを真赤にして（娼婦というものは、心にもなく顔赤らめる術を心得ているものだ）じっとうつむいていたが、わしの言葉が熱して来るに従って、彼女は何か総毛立つ様に身を震わせ、感激の面を上げて、わしを見上げた。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "折檻の鞭の下にうちふるえる・うぶな何も知らぬ少年に、紅き色にそめたるインドの象牙のごとく、薔薇に混りてその強き色をうつす白百合のごとく、（ウェルギリウス）顔を赤らめるどこかの少年に、ゆずってしまいなさい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのほどは、酒を酌みつつ、わざとらしい猥談を放って、女客が顔赤らめるのを興がッていた程度だったが、やがてのこと博奕道具を取出すと、ことば巧みに、そこらの乗客を鴨に引きこんで、銭の音やら雑言のやりとりに、眼いろを変えだしたものだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "うら、おもて、材小屋の戸口、――生あをき水の香と、はたあからめる埃のにほひ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、接待の当番にあたって、これが社用ですから、あれぐらいのこと、我慢しなければいけませんのよ」「あれぐらいッて、どんなことですか」「昨夜のようなことですわ」　と、はずかしがって、ボッと顔をあからめる。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をついたカドにより良心が咎めて顔をあからめるワケではない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のことかなんか」「あんた、なぜ、顔をあからめるの？",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたぐらいの年になって、そんなことを言いながら顔をあからめるなんて、スッキリしてないね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かぽっと、一人で顔をあからめることもあるのでした。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
