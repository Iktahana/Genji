[
  {
    "uuid": "ba648c30-7dc8-5b37-b18e-415b9244d1a0",
    "entry": "有り無し",
    "reading": {
      "primary": "ありなし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "existence or nonexistence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り無しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り無しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り無しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り無しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り無しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り無しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り無しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り無しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り無しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り無しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り無しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り無しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り無しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り無しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り無しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り無しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り無しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り無しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り無しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り無しは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "土橋から少し離れて馬頭観音が有り無しの陽炎の中に立っている、里の子のわざくれだろう、蓮華草の小束がそこに抛り出されている。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所で紹介をお求めなさるなり、また酒井先生は紹介の有り無しで、客の分隔をするような人ではないから――直接にお話しなすって、御縁があれば纏る分。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頬へ宛てていた手を空中へ伸して人を探るように風の有り無しを試してみます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、努力は効果の有り無しによって、すべきであるとかすべきでないとかを判断すべきではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等が交す言の葉に燃ゆる命の有り無しは花に比べて知りぬべし。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人々の如く、客觀的時間そのものを殆ど問題とするに及ばぬ自明の事柄であるかのやうに前提し、ただそれの始めや終りの有り無しについて論ずるは、全く方法を誤つたものといはねばならぬ。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今此のお侍も本当に刀を鑒るお方ですから、先ず中身の反り工合から焼曇の有り無しより、差表差裏、鋩尖何や彼や吟味致しまするは、流石にお旗下の殿様の事ゆえ、通常の者とは違います。",
              "citation": {
                "source": "怪談牡丹灯籠",
                "author": "怪談牡丹灯籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない遊軍の有り無し。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイトの薄萠黄の――最も古ぼけては居たが――天鵝絨の劃を、コチンと窓へ上げると、紳士の作法にありなしは別問題だが、いゝ頃合の枕に成る。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂蓮の雲の歌　「風にちるありなし雲の大空にたゞよふほどや此世なるらん」といへる寂蓮法師の歌こそおもしろけれ。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂蓮の雲の歌「風にちるありなし雲の大空にたゞよふほどや此世なるらん」といへる寂蓮法師の歌こそおもしろけれ。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "村里に、形のありなしとも、悩み煩らいのある時は、私を悪いと言うのかい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのありなしの日照りの雨が霽れたので、草はあらたにきらきら光り、向うの山は明るくなって、少女はまぶしくおもてを伏せる。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、ありなしの縁に曳かれて、雛妓の小とみ、弟が、かわいい名の小次郎、ともに、杖まで戸惑いしてついて来て、泣いていた、盲目の爺さんが、竹の杖を、お光の手に、手さぐりで握らせるようにして、「持たっしゃれ、縋らっしゃれ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書　夢のような仰せなれば、名のありなしも覚えませぬが、姫川図書之助と申します。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、日のありなし雲の雨となり、そそぐ夜にこそ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "微笑を保てよ、閑かなる世の母、昼ながら※たき月、ありなしの雲さながら。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と大分｜横柄……中に居るものの髯のありなしは、よく其の勘で分ると見える。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗をずっぷりとかいて、意識のありなしも疑わしい。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲のひとひら、たよたよとひゆきて、ありなしにやがては消えつ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありなしの暫にながらへ、その間だに懶き身には、おほ天もむなしき名のみ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉おしろひのにほひか、けふの入り日の顫へか、あかあかと、母のお弓がチヨボにのり泣けば…………なげけば…………蟲の音が…………芝居小屋の土間のむしろに何時しか沁みて芽に出るまだありなしの韮の葉。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二澄みつる空や、さながらありにし戀も忘れて、菩提樹がくれの法の苑に、『無漏慧』にあそぶ聖の、とわたる鳥のありなし、いささの染をもえは許さぬ齋戒か、――嚴の清まりは、見るだに堪へせじ、現しごころ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲のひとひら、たよたよとひゆきて、ありなしに、やがては消えつ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今ははた、鈍色被衣身ぞたゆげに、苅野に凭ひ、隱り沼の水澁に浸り、伏木に添ひて火移りの昨日を夢み、冷かの今に涙ぐみ、もの倦がほにたゆたひつ、迷ひつ、軈て木の上枝より細高に、い行くか烟、ありなし雲とたゞよひて、天のこころに溶け入りぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を待つ間をゆるされに、天の足日をかいまみるありなし時や、せつなさの心もすずろ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日　ありなし雲、椽の端にあり。",
              "citation": {
                "source": "雲の日記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やぶそば」のありなしや「のんき」のあるなしはともかく、本富士署のあの留置場空気だけは、土台まで焼けおちてもう二度と存在を許されるべきものでない。",
              "citation": {
                "source": "本郷の名物",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "色も光沢もきれいな服の上に薄物の直衣をありなしに重ねているのなども、源氏が着ていると人間の手で染め織りされたものとは見えない。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の言葉のように、春の花が皆散ったあとで若葉もありなしの木の梢の寂しいこのごろに、横が長く出た松の、たいして大木でないのへ咲きかかった藤の花は非常に美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            }
          ]
        }
