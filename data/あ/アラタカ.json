        "examples": {
          "standard": [
            {
              "text": "私は毎日灼かについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "灼かという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は灼かの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には灼かが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "灼かを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは灼かについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "灼かの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は灼かの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では灼かが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "灼かという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に灼かという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では灼かについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "灼かを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると灼かは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "灼かについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では灼かが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に灼かは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により灼かの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "灼かは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に灼かは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さわやかな秋の時計の盤面には、青く灼かれたはがねの二本の針が、くっきり十一時を指しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲がすっかり消えて、新らしく灼かれた鋼の空に、つめたいつめたい光がみなぎり、小さな星がいくつか連合して爆発をやり、水車の心棒がキイキイ云います。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さわやかな秋の時計の盤面には、青く灼かれたはがねの二本の針が、くつきり十一時を指しました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲がすつかり消えて、新らしく灼かれた鋼の空に、つめたいつめたい光がみなぎり、小さな星がいくつか聯合して爆発をやり、水車の心棒がキイキイ云ひます。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思ふと、己は今も胸を灼かれるやうな悔を感じる、己には最早人間としての生活は出來ない。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うと、己は今も胸を灼かれるような悔を感じる。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然胸を灼かれるような気がした。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青春への郷愁に胸を灼かれるやうな思ひをしながら、私は部屋に歸つて來た。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗乗の誤謬を匡すべく、火に灼かれる迄も正理を標榜した鼻がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　吾平爺がその翌日、警察から釈放されてきたときには、荷車の上の野菜は残暑の陽に灼かれてすっかり萎れていた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本紀』一に伊弉冊尊火神を生む時｜灼かれて崩りましぬ、紀伊国熊野の有馬村に葬る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子爆弾の殺人光線もそれが直接彼の皮膚を灼かなければ、その意味が感覚できないのであらうか。",
              "citation": {
                "source": "戦争について",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の総身は火に灼かれるように熱くなった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあの原爆の光線で灼かれて死んだ人間たちが、人間といふより塑像か何かのやうに無機物の神秘な表情をしてゐたのを憶ひ出す。",
              "citation": {
                "source": "火の子供",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供ごころの悲しさに、そんな情ない惡口を言つてくれるなと、惡太郎共に紙や色鉛筆の賄賂を使うて阿諛ふやうな不憫な眞似もするだらうがなどと子供の上に必定起らずにはすまされない種々の場合の悲劇を想像して、圭一郎は身を灼かれるやうな思ひをした。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの当座、硫酸で顔を灼かれた痛みがひどくて、それから盲になって、おれの一生は恐怖と死のほかに何にもないということが初めてわかった時分は、今とは似ても似つかぬ考えに囚われていたんだ。",
              "citation": {
                "source": "暗中の接吻",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は世界の運動を鵜飼と同様だとは思わないが、急流を下り競いながら、獲物を捕る動作を赤赤と照す篝火の円光を眼にすると、その火の中を貫いてなお灼かれず、しなやかに揺れたわみ、張り切りつつ錯綜する綱の動きもまた、世界の運動の法則とどことなく似ているものを感じた。",
              "citation": {
                "source": "鵜飼",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の、灼かれようとも挫けない人道主義の天使が、夜は、想像もされない別貌をしてあらわれたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、またしても幻を起す、この灼かれた皮膚のしたに鎖を曳いて逆流する海洋、北方の。",
              "citation": {
                "source": "逸見猶吉詩集",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き抜かんとする地を灼かんとするは露はなる岩漿の世にもなき夢なりあはれ葦酒に酔ふ旧き靺鞨の血も乾れはてゝいまぞ鳴る風の眩暈。",
              "citation": {
                "source": "逸見猶吉詩集",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しろ此方は真物が二柱だから御利益が灼かだ。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場處全體が一樣に日に灼かれ、海からの風に蠶食せられてゐるやうに見えた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はうだりきって疲れて空腹で、そうして傾いた西陽に灼かれながら歩いていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからふらふらと寺町のほうへ歩きだした、――苦しい、頭が灼かれるようである、非常に重い物で前後から胸を圧しつぶされそうだ。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子心中を一日延ばすために、飲んだとなると、効き目が一寸あらたか過ぎる。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島四国めぐりは、霊験あらたかであると云い伝えられている。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の戸を繰ると、あらたかな日の光が部屋一杯に射し込んだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でもあらたかですよ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、まあ、君たちが飲んだ亜刺此亜風の薬の効き目はあらたかだったに違いないと信ずる。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその貧しい男は、手を振つて答辯し、神のあらたかな御利益につき、熱心になつて實證した。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
