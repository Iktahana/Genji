    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beloved child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛児は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛児が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛児に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛児が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛児について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛児についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛児について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛児が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛児が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛児は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛児は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛児を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛児をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛児が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛児の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛児を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛児に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛児について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛児は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛児を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうした八雲の心理は、我が子の魯鈍に幻滅を感じてる親が、他人から、その愛児の悪評を聞いて怒る心理と、よく似たものであったと思われる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎になってしまってからの愛児の看護に骨を折るよりも、風邪を引かせぬ予防法、引いたときに昂じさせぬ工夫に一倍の頭を使う方が合理的である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに知人のある者は保養地で疫痢のために愛児を亡くしたりした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番最後に歌った意味は、『老母は愛児の帰りを待ちわび、紅粧の新妻淋しく空閨を守る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛児を失いし人は始めて死の淵の深きに驚き悲しむと言い伝う、わが知れる宗教家もしかいえり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道を、やうやくに拾ひ歩める吾が愛児なる。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、私の愛児は、幼年紳士は、急斜面の弧状の、白い石の太鼓橋を欄干につかまり遮二無二はい登ろうとしている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌白村が第二の愛児笑むらむかはた泣くらむか聞かまほしくも。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、秀吉がその愛児秀頼に、この難攻不落の名城を遺したことは、却って亡滅の因を遺したようなものである。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めての愛児として、両親の全盛時代に、甘やかされて育った姉は、生活ということに対しては、全然考えようともしないらしく、てんで話にならなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、愛児の生長が彼を家庭につなぎ止めているのと、酒をたしなまず、花柳界の趣味を解しないため、路傍の花に心を奪わるることなく、上部だけは善良な良人であった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学といえども人間の産んだ愛児の中の愛児である。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某君は部下の軍曹とともに飛行中、機体に故障を生じたので、それぞれパラシュートで難を避けたが、今来て見ると己たちの乗っていた飛行機がすこしの損傷もなく着陸していたので、まるで愛児にでも逢った時のように嬉しかった。",
              "citation": {
                "source": "人のいない飛行機",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は自ら重井との関係を断ち翻然悔悟してこの一身をば愛児のために捧ぐべし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛児が病むのも勿論不幸である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｍ君は自から謙遜するといふよりも、寧ろ愛児を正直に讃美した。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久に神の清き愛児たるべき処女よ。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早月母子が東京を去るとまもなく、ある新聞は早月ドクトルの女性に関するふしだらを書き立てて、それにつけての親佐の苦心と貞操とを吹聴したついでに、親佐が東京を去るようになったのは、熱烈な信仰から来る義憤と、愛児を父の悪感化から救おうとする母らしい努力に基づくものだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、瑠璃子の真意を測りかねて、茫然と愛児の顔を見詰めていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分の容しを瑠璃子に乞うた上、二人の愛児の行末を、瑠璃子に頼んでいる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その格闘の恐ろしいものの音が、産褥にある妻に与える激動、また居間の向うの六畳に寝ている、幼い三人の愛児に与えるおどろきと危険とを考えると、若杉さんの手は、どうしても延びなかったそうです。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、同時に居間の向うの部屋からは三人の愛児が、おどろいて泣き出しました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、三人の愛児までが、その夜のできごとがあって以来、妙にものに怯える臆病な子供になりました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、三人の愛児が受けた悪い影響も、金銭をもっては償いがたい、大なる被害に相違ありません。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は貴女に麻酔薬を用いて、老婆に頼んで、愛児を講演会場につれてゆきました。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠藤博士の胎教に関する新学説が夫人の愛児について実験されて成功したという話を博士の口から今きいてきたので、早速、その赤ちゃんの写真をとらせていただきにきたのであると僕はもっともらしくきり出したのだった。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら学問のためだって、他人の愛児を犠牲にするなんて許すべからざるこったからねえ。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この百観音は、羅漢寺｜建立当時から、多くの信仰者が、親の冥福を祈るためとか、愛児の死の追善のためとか、いろいろ仏匠をもっての関係から寄進したものであって、いずれも中流以上の生活をしている人々の手から信仰的に成り立ったものであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "女将は、その冷たく青白い面を、恐怖に一層青めながら、愛児を必死に小脇へかかえて、凝然とおどろき怪しんでいる黒白隊の間をかいくぐりつつ、退屈男のところへ駈け近づくと、おろおろとすがりついて訴えました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛　あいじゃあねえ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
