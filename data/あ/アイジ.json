          ],
          "literary": [
            {
              "text": "焉んぞ一片の哀辞なきを得んや。",
              "citation": {
                "source": "北村透谷君",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十九年十月十日東京において　　著者記第一回　洪水の後には洪水あり（緒論）　朕が後には洪水あらんとは、これルイ十五世が死になんなんとして仏国の将来を予言したるの哀辞なり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛　あいじゃあねえ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう諦めたの」「牢屋へ往くか、死んで申しわけするか、其の二つあいじゃ」　女房は黙り込んでもう何も云わなかった。",
              "citation": {
                "source": "雁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがの、内なぞは傍のおつきあいがおつきあいじゃで、そこはまたな、御婦人じゃから直接にいっては赤い顔でもなさると悪いで申さんじゃったが、前掛は止して袴になさるなぞは、まず第一のお心懸じゃよ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、しかし貴方の前じゃけれどお夏さんは珍しい御容色よし、ほんのこと内なぞはおつきあいがおつきあいじゃから、御華族様から大商人方の弟子も沢山見えるけれど、品といい様子といいあのお娘が一番じゃ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面じゃの、ふァふァふァ、お夏さんなぞは心懸次第またどんな出世でも出来るのじゃ、こっちへ出入ってござればおつきあいがおつきあいじゃから、ふァふァふァ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあるはずだが、気のついたことはねえかい」「あのおかみさんのおちつきぐあいじゃござんせんかい」「そうだよ、そうだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつり右門はただのできあいじゃねえや、知恵の出どころがちっと違わあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "上役人のおいらがお出ましになっているのもかまわねえで、はばかりもなくコロいじりをしているぐあいじゃ、よくよくあの三下奴め、あれが好物にちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その鳴りぐあいじゃ切れ味もよさそうだから、威勢ついでにちょっくら月代をあたっておくれよ」「な、な、なんですかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどし文の文句のぐあいじゃ、まさしく二本差しのしわざとにらんでおったが、春先ゃやっぱり眼も狂うとみえらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鼻緒ならばまず年のころは二十一、二、あっちへ一方、こっちへ一方横向きにゆがんで脱いであるぐあいじゃ、気性もあっちへ一方、こっちへ一方、細かいことのきらいな鉄火ものだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いつきあいじゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の女性の髪の伸びないのは、いろいろの髷にして、髪をあっちへ曲げ、こっちへねじていじめつける故で、ああいじめつけては髪は伸びるどころか縮むばかりである。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんに何が出来る、え、って云っちゃあいじめたんだもの。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし浪が今死なんにしたとこが、そのうちまたきっとわるくなッはうけあいじゃ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにはきっと卿に伝染すッなこらうけあいじゃ、なあ武どん。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏上づきあいじゃもの。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうキツネの話をしてるばあいじゃないんだ！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のぐあいじゃ一哩も遠くから聞えることがありまさ。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかかりあいじゃ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君にきいたら、明智さんは、何か、ほかの事件にひっかかっていて、手がはなせないのだそうですが、いまはもう、そんなことを言っているばあいじゃありません。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてまあいじわるな神様でしょう！",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「見事な大太刀を背に負って、これ見よがしの伊達な装い、よほど兵法自慢の者らしいが……一体朱実さんとあの男とは、どういう仲の知りあいなのか」「べつに……なにも深い知りあいじゃないんですけれど」「知っていることはいる人なのだな」「ええ」　武蔵に誤解されることを惧れるように、朱実は、はっきりいった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
