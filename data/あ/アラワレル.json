    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to appear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日現れるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "現れるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は現れるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には現れるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "現れるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは現れるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "現れるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は現れるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では現れるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "現れるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に現れるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では現れるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "現れるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると現れるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "現れるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では現れるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に現れるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により現れるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "現れるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に現れるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長三代太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）捧げ銃をして。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）工合い-------------------------------------------------------　四月十一日。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私信太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）就いて、-------------------------------------------------------　叔母さん。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この情態が面白からぬことを気付く頃に現れる次の現象は、凡そ私に分る所を以てすれば、心理的に病弊を究明しはじめることであらう。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちジヤツク・ウオーキイ等によつて映画で紹介されてゐるやうな、歌詞を本位として簡単な音楽を伴奏的につけ、専ら歌詞の滑稽味やエロチシズムやで、大衆を興がらすやうに出来てる「音楽入西洋万才」が、近い未来に於て日本に現れることを予感させる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道場の入口から、時々水を飲みに、剣道用の繻絆姿で現れるのは生徒だが、それは選手だから暑中休暇も帰省しないで道場にゐるといふわけである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊の歌中原中也-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）吁！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の風景葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：入力者注　主に外字の説明や、傍点の位置の指定（例）増産競技であった。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セメント樽の中の手紙葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）蔽われていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンとナンバンとが、サロンデッキに現れるや否や、彼は遠方から呶鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災日記より寺田寅彦-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）子供等と志村の家へ行った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると真赤な血のような色の何とも知れぬものが暗黒の中に現れる。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷と後光宮澤賢治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）苹果-------------------------------------------------------「ええ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の構造九鬼周造-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）畢竟｜：ルビの付いていない漢字とルビの付く漢字の境の記号（例）一見｜相容れない：入力者注。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の構造九鬼周造-------------------------------------------------------【テキスト中に現れる記号について】：入力者注。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬戸内海の潮と潮流寺田寅彦-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）沢山あります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような外国語式の発音が、日本語の中に普通に用いられるようになったのはいつ頃からかというと、これは非常にむずかしい問題で容易に断言は出来ませぬけれども、まず普通の言語に現れるようになったのは多分平安朝になってからであったろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に純粋の国語の中に、撥ねる音すなわち「ン」で表わす音とか、つまる音、すなわち促音、そういうものが現れるようになったのは、やはり平安朝以後――平安朝には既にあったと思いますが――平安朝以後のものであろうと考えております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに現れる夏の夕べの涼風は実に帝都随一の名物であると思われるのに、それを自慢する江戸子は少ないようである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高知は毎時観測の材料がなくて調べなかったが、広島や大阪では、前記の地方的季節風が比較的弱くて、その代りに海陸風がかなり著しく発達している、そうして夕方から夜へかけては前者が後者と相殺する、そのために夕凪がかなりはっきり現れる、そうして海陸の位置分布の関係でこの凪の時間が異常に引延ばされるらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどにも国々の国民性がこんな演芸の末にまで現れるというのは面白いよりはむしろ恐ろしいことであろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば二色の写真が迅速に引続いて交互に現れるから、眼には丁度二色の写真を重ねて見るとほとんど同じ結果になり、従ってほぼ天然色に近いものが現れるのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その所説に拠れば、疑問の死体をＸ線で透して撮影すれば、もし本当の死産なれば体内の機関は一つも写らぬが、少しでも空気を呼吸したものなれば胃だけが現れる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じーっと見送って居た仲蔵の面に歓喜の色現れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟敷の女客が花道の方見る（仲蔵が其処から現れるからです）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "合図をすると、児分が二人現れる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この例は甚だ多いけれども、同じ語にはいつも連濁があらわれるというのでもなく、いかなる場合に連濁が起るかという確かなきまりはまだ見出されない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、語頭の母音と語尾音の終の母音と二つの母音が並んであらわれる場合にその内の一つが脱落したので、古代語において母音がつづいてあらわれるのを避ける傾向があったことを示すものである。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
