    "definitions": [
      {
        "index": 1,
        "gloss": "ankh (hieroglyphic symbol for life)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンクについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンクという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンクの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンクが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンクを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンクについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンクの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンクの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンクが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンクという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンクという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンクについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンクを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンクは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンクについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンクが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンクは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンクの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンクは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンクは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暗褐色に赤に横縞のあるアンクル・サックス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は「アンクルトムス・ケビン」にて、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "塗香はざっと英語のアングエントに当り、医学上の立場からアンクション、宗儀上はアノインチングというらしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから、寮中どこにでもあるスピーカーに、音楽を流すだけのことだった（慶一は、『ナポレオン・ソロ』からとって、四〇七を「アンクル」、放送室を「スラッシュ」と名づけたが、だれも使ってくれず、この暗号名はすぐに忘れられた）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストウ夫人といふのは、人も知る『アンクル・トムス・ケビン』の作者として名高くなつた婦人である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンクル・トムの小舎」の作者、「ジョン・ファリファックス」の作者、「小公子」の作者。",
              "citation": {
                "source": "子供のために書く母たち",
                "author": "――「村の月夜」にふれつつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンクル・トムの小舎。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このリモジンの行動を掴まえなくてはと、刑事隊が、半月湾国道に沿う民家の一つひとつに即いて訊いて歩いた末、やっと拾い上げた唯一のレポウトというのは国道をホテルと反対の方向にすこし下ったところに、アンクル・タムス・キャビンという看板を掲げた郊外料理店がある。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、これを古代火術符号（以上の符号は、火薬の始祖コンスタンチン・アンクリッツェン以降、ヴェネチアの攻城火術家アレッサンドロ・カポビアンコあたりまで用いられていたもの）に当ててゆくのですが、もちろんその知識は、外国の軍事専門家――しかも、極めて少数の人たちに限られていると云えましょう。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンクル・トムス・ケビン」は合衆国の奴隷解放を描いた宣伝小説であり、かのビクトル・ユーゴーの「レ・ミゼラブル」は、歴史的小説であるとともに、仏蘭西革命を書いた政治的社会的宣伝小説である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス大革命時代に流行した「アンクロワイヤーブル」(その名からして『本当とは思はれぬ』と云ふ意味だ。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日本誌で、フアンク氏の日本映画論を読んだが、なかなか適切なことを云つてゐると思つたが、実は、今更われわれは、同氏から「如何にすれば優秀な映画が作れるか」といふ教へを受ける必要はないのである。",
              "citation": {
                "source": "日本映画の水準について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、フアンク氏は、その直接使用した俳優への好意ある批評を含めてゞあらうが、日本映画俳優一般への認識に恐ろしい「甘さ」があるやうに思へる。",
              "citation": {
                "source": "日本映画の水準について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも映画的効果としては十分生かし得るものであるが、同国人たるわれわれにとつては、エキゾチスムは、零と計算すべきであるから、フアンク氏の御世辞で鼻を高くするには当らぬのである。",
              "citation": {
                "source": "日本映画の水準について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "フアンク・イデオロギイをもつてしては、却つてその反対が云ひたいかも知れぬが、日本国民の一人として、私は真に「日本的なるもの」を「旧劇」のなかに見出される苦痛を感じないわけに行かぬ。",
              "citation": {
                "source": "日本映画の水準について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして北仏の戦線に近い、リアンクウルと言ふ小さな町に細い命を継いで行くことになつた。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のリアンクウルで作つたのに比すれば、見る蔭も無い程あわれなものではあつたが、そうも言はれず、「大そう可愛らしいですな」と挨拶すれば、「小さいけれども、それは美味いです」と御自慢であつた。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程晩餐の食卓で、其人蔘の煮ころばしを戴いたが、それはホンとにリアンクウルのよりは美味だつた。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の蒔いた馬鈴薯は、曽て初めてリアンクウル町で耕作した時の様に立派に成長したが、不思議なことにその馬鈴薯が茎の末に実を持つた。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽てリアンクウルでは馬鈴薯が花の跡に実るものかと思つて、其無智なのに自ら呆れたが、今度は却て其馬鈴薯の花に実が成つたのである。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョロヒョロして、思いがけぬ所に妙な角度が見える奇怪な身体つき、そしてオープン・アンクルの靴が彼の固い、やせた脛の後から、変な格好につき出ている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンキホーテ、アンクルトムは、自由主義というイスラエリズムをお題目にして、「英国がドイツに負けたら、同じ自由主義国の我米国もあぶない」　とばかり、今度は米国の方から、英国を後詰めしている。",
              "citation": {
                "source": "今昔茶話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルウズが去ると、代つてイギリス海軍大佐ヴアンクヴアが二隻の軍艦を率ゐて、アラスカの多島海へきた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヴアンクヴア大佐が困難な多島海の測量を終へて退くと、その部下ブラフトン大尉が、愈々クツク以來の宿願である日本沿岸測量を遂行、寛政五年の九月、暴風の中を津輕海峽に達し、北上して蝦夷地の繪鞆（室蘭）に入港投錨したのであつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄アレクサンドルが『アンクル・トム』を読んで泣かされたと書いてよこしたのに対し、十六歳のチェーホフはやや冷笑的な調子で、……このあいだ読み返したら、乾葡萄を食いすぎた時みたいな嫌な気持がした、と答えている。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄アレクサンドルが『アンクル・トム』を読んで泣かされたと書いてよこしたのに対し、十六歳のチェーホフはやや冷笑的な調子で、――僕もこのあいだ読み返してみたが、まるで乾葡萄を食いすぎた時みたいな嫌な気持がした、と答えている。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらポンピアンクリームや耳隠しを排斥したって、日本が亜米利加から尊敬されるようになるまでは排日は君なかなか止まんよ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は小父さんの方のお話を聞かして下さいな、アンクル・トム。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」紳士の望みで、セエラは紳士を『アンクル・トム』と呼んでいました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返って窓から離れたブレイクは、祭壇の上方にある蜘蛛の巣に覆われた十字架が普通のものではなく、古代のアンクないしかぐろきエジプトのアンサタ十字(*13)に類似していることに気づいた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
