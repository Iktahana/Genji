    "definitions": [
      {
        "index": 1,
        "gloss": "Afghan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフガンについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフガンは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフガンの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフガンについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフガンは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフガンの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフガンに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフガンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフガンを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフガンの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフガンが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフガンが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフガンについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフガンは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフガンは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフガンは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフガンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフガンの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフガンの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフガンの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ジョッキとアフガンに従軍し、キャラシァブ、シャープール及びカブールに駐屯したる事あり。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "気づけばとうとうアフガンのなかだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時連隊はインドに駐屯していたが、私の赴任に先立ち第二次アフガン戦争が勃発、ボンベイに到着するやいなや、連隊は峠の向こう敵陣深くにあり、と聞かされることになった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフガンの後、もう少し物事に動じなくなってもよさそうなものなのだが。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "大伽藍のように壮麗な側壁、天空を摸した高い天井、輝き渡った床と円柱、アフガンの厚ぼったい緋の絨氈。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今年の春に、ミネルバの細いピンクと白の毛糸で赤ちやんのアフガンを編んだことがございます。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角に折つて肩かけにしたくなりましたのに、それに、それに、いま星のいつぱいな爽かな初夏の夕暮を、あなたのお胸に、それは美しく白いアフガンが揺らめきます。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは赤ちやんのアフガンを、僕の胸へ勲章のやうにかけようとなさるのです。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、僕があなたのお傍に行きつくまでに、いま一度、ミネルバのアフガンを編み上げなければなりません。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのジョン・ブライト氏が「余は清国戦争・クリミア戦争・アフガン戦争・ズール戦争・エジプト戦争のごときみなその決して得策にあらざるを論じたり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "これアフガン争論のつねに英露の間に絶えざるゆえんなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
