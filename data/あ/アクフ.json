        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "悪婦は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪婦対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪婦に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪婦がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪婦は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、悪婦の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは悪婦を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により悪婦の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における悪婦の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "悪婦について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日悪婦について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から悪婦を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により悪婦の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは悪婦を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で悪婦に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "悪婦は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪婦対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪婦に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪婦がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪婦は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども毒飼は最もケチビンタな、蝨ッたかりの、クスブリ魂の、きたない奸人小人｜妬婦悪婦の為すことで、人間の考え出したことの中で最も醜悪卑劣の事である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "左れば広き世の中には随分悪婦人も少なからず、其挙動を見聞して厭う可き者あれども、男性女性相互に比較したらんには、人非人は必ず男子の方に多数なる可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の姑｜悉皆悪婦にあらず、天下の嫁悉皆悪女子にあらざるに、其人柄の良否に論なく其間の概して穏ならざるは、畢竟人の罪に非ず勢の然らしむる所、一歩を進めて論ずれば世教習慣の然らしむる所なりと言わざるを得ず。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――いくらこの人が悪婦でも、兄貴の女房、まして自由のきかない女ずれを」「まだ憐愍を持ってくれるのか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
