        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンスコについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンスコという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンスコの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンスコが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンスコを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンスコについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンスコの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンスコの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンスコが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンスコという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンスコという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンスコについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンスコを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンスコは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンスコについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンスコが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンスコは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンスコの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンスコは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンスコは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
