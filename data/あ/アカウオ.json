    "definitions": [
      {
        "index": 1,
        "gloss": "Pacific ocean perch (Sebastes alutus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は尺に近い赤魚を、サンザン苦労して引つ張り上げ、魚籠に入れる直前に落した。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "……場所を何う取違へたか、浴衣の藻魚、帶の赤魚、中には出額の目張魚などに出逢ふのみ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この河からは鯉、鮎、鰻、赤魚、山女魚、等々が釣れる。",
              "citation": {
                "source": "信濃の山女魚の魅力",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は又、水の中に住む赤魚の恋を妬んででもゐるのであらうか。",
              "citation": {
                "source": "かちかち山",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "県、赤魚、月丸、鯖、小次郎、お小夜の六人である。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金を隠したとは呆れたものだ」「いいや俺は呆れもしねえ」次男の赤魚がベソを掻きながら、「明日から俺らはどうするんだ。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本バヤ即ち学名うぐいはあかはら又は赤魚の名で雌雄ともに腹が赤くなるが、主として天竜に居て、諏訪湖の上流の方はうぐいは稀でおいかはが主である。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その場合にはねえ」と男は真面目｜相に「あなたはあの菓子をもう一度持って来なくてはいけないね」「あら、あなたは大事な話の方をよくきいて下さらなくてはいけませんわ」とローラは負けずにいった、「では始めに、私のお父さんがラドベリーに『赤魚軒』という料理屋を出していた事からお話しいたしましょう。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の握るものは、鱧、河豚、赤魚、つばす、牡蠣、生うに、比目魚の縁側、赤貝の膓、鯨の赤身、等々を始め、椎茸、松茸、筍、柿などに迄及んだが、鮪は虐待して余り用いず、小鰭、はしら、青柳、玉子焼等は全く店頭に影を見せなかった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『塩松勝譜』には常陸坊海尊、衣川にて老人に逢い赤魚をもらって食った。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇我ノ蝦夷、平群ノ鮪、蘇我ノ赤魚、押返ノ毛屎、阿曇ノ蛍虫――などはまだよいが、巨勢ノ屎子という女性がある。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
