    "definitions": [
      {
        "index": 1,
        "gloss": "white gooseweed (Chenopodium album)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "裏の田圃を、山の裾から、藜の杖を支いて、畝路づたひに、私が心細い空の雲を見て居ります、離座敷へ、のそ／＼と入つて來ました、髯の白い、赤ら顏の、脊の高い、茶色の被布を着て、頭巾を被つた、お爺さんがあつたのでございます。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の和尚が、私の目の前へ腰を屈めて、支いた藜を頤杖にして、白い髯を泳がせ泳がせ、口も利かないで、身體中をじろ／＼と覗込むではござんせんか。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……情なさに歩行き惱みますと、時々、背後から藜の杖で、腰を突くのでございますもの。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日尋春不見春　　杖藜踏破幾重雲帰来拭把梅花看　　春在枝頭已十分　その梅はもう盛りをすぎたけれど、あちらこちらにしろじろと立っている。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "藜※　我腸を充し、衣蔽れて　両肘露はる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽かなは竹、親しいも竹、なにかそこらのちらちらが、蓼や藜を明るくする。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩菊、浜菜、もるちの花叢、藜に茅萱、　黄だ、黄だ、黄だ、緑だ、金だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると勇斎が、「此のことは、けっして人に云うな」　と云って、藜の杖をついて伴蔵といっしょに新三郎の家へ往った。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「婿は久しく姑の家にいるものじゃありません、それにあの人は貧乏人ですから、久しくおれば久しくあるほど人に賤しまれます、私は一旦承知しましたから、小屋がけに甘んじます、藜※のお菜もいといません」　孫はそこで阿宝を親しく迎えて結婚したが、二人は互いに世を隔てて逢った人のように懽んだ。",
              "citation": {
                "source": "阿宝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小供の背丈けほどもある昼間見ると藜※のような草と粟粒のような微紅い実をつけた草がぎっしり生えた住宅地の入口に、人の足によって通じた一条の路がうっすらと微月の光に見えていた。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主従は有難きことに思い、御像をその駒形堂の所へ安置し奉ると、十人の草刈りの小童が、藜の葉をもって花見堂のような仮りのお堂をしつらえ、その御像を飾りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで駒形堂をまた藜堂とも称えます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからクローバー、車前草、藜などがほしいままに繁った。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは酒の池、肉の林と歌わずんば必ずや麦の飯、藜の羹と歌わん。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の句は佐野が宿｜鉈ふるふべき藜かな　　　　徴羽郎といふのである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野が宿は源左衛門の宿なるべく、鉢の木の梅松桜を伐りたる面影を留めて夏季の藜を伐るに転用したる処既に多少の厭味があるやうに思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは他の草花から離れて、偶然この雑草の抜いてない場所に生えたので、よく茂った藜や、名も知らぬ丈の高い南方の雑草が、ぎっしりと周りを取り囲んでいた。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "三益は採薬に土民を役したから、藜蘆を植うる俗の如きも、或は此人の時に始つたのではなからうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し少しでも変つてゐるとすれば、それは一面にスレヱトの屋根や煉瓦の壁の落ち重なつた中に藜の伸びてゐるだけだつた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず大小さまざまの譜本もかすかに色づいた藜の中に桃色、水色、薄黄色などの横文字の表紙を濡らしてゐた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノは丁度月の光に細長い鍵盤を仄めかせてゐた、あの藜の中にあるピアノは。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノは不相変ひつそりと藜の中に蹲つてゐた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは只藜の中の弓なりのピアノに目を注いだ。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから家族の衣食もそれに准じて粗末なもので辛棒させて、魚や肉などは余りに買わないで多くは浅蜊や蛤または鰯売り位を呼込んで副菜にし、あるいは門前の空地に生い茂っている藜の葉を茹でて浸し物にする事もあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは昔中国から渡り来ったもので中国の名は藜である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこれがいわゆる藜杖でアカザの杖をついておれば長生きをするといわれる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝原益軒の『日本釈名』には「藜、あかは赤なり、さはなと通ず赤菜なり」と書いてあるのも怪しい。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の李時珍という学者が、その著『本草綱目』蓬草子の条下でいうには「其飛蓬ハ乃チ藜蒿ノ類、末大ニ本小ナリ、風之レヲ抜キ易シ、故ニ飛蓬子ト号ス」とある。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のように白い長髪を肩へ深々と垂れ下げた、棗のような赧い顔の、獣の皮と木の葉とで不細工に綴った着物を着た、仙人のような老人で、いつも藜の杖をついて、静かに歩いて来るのであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島方の三人は、重湯をとるやら粥をつくるやら、その間に藜の葉の摺餌をこしらえ、藤九郎の卵を吸わせ、一日中、病人の介抱に忙殺された。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
