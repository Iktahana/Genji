        "examples": {
          "standard": [
            {
              "text": "私は毎日アンケートについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンケートという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンケートの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンケートが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンケートを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンケートについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンケートの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンケートの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンケートが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンケートという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンケートという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンケートについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンケートを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンケートは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンケートについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンケートが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンケートは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンケートの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンケートは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンケートは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このあいだ朝日新聞が講和問題についてアンケートを集めたとき「単独講和でいいから、そして軍事同盟の条件がついてもよいから早いほどよい」と答えたのはおもに実業家でした。",
              "citation": {
                "source": "講和問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、小山書店が、「チャタレー夫人の恋人」につけた読書調査のアンケートは、こんにち小山書店が、この本の文学性を強調して、たたかうについて、果してふさわしく且つ有効なクレイムをもつものでしょうか。",
              "citation": {
                "source": "「チャタレー夫人の恋人」の起訴につよく抗議する",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンケートの質問は、文学的であるでしょうか。",
              "citation": {
                "source": "「チャタレー夫人の恋人」の起訴につよく抗議する",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "講和の出た去年の十一月下旬、新聞が集めたアンケートでは面白い事に、警視総監のような政府の役人と株屋と徳川夢声等が単独講和でも早いほうがよいという回答をしています。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンケート用として整理されたものである。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者の主張の整理のしかたに、整理した人のはかりのかたむきが解答への暗示となってちらついているし、アンケート用として適当だと感じられない。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアンケート用に整理されている徳永の議論を、同じ号にのっている座談会記事「勤労者の文学をどう前進させるか」第二回のなかでの徳永自身の話、岩上、坂井などの話とてらしあわせてよんでみると、きわめて示唆にとんだこんにちの諸問題が発見される。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人々に新聞社は、講和問題に関するアンケートなどもおくっている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題がおこってから俄にローレンスの作品の社会的、文学的意味をジャーナリズムの上に語りはじめた同じ人たちが、出版のはじめから、「チャタレイ夫人の恋人」のバンドに刷られたアンケートが果して文学の問題であるかどうか考えることは出来なかったろうか。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャラップの世論調査所員の大多数は女子で、アンケートの送りさきは彼女たちの任意とされていた。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャラップの世論調査所に働いているのが女子だったから、アンケートの送りさきが限定されたのではなかった。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年のダイジェストの調査は調査ごとに五〇万ドルの費用をかけ一千万枚のアンケートを発送し、二、一五八、七八九の回答にもとづいて行われた。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三六年のルーズヴェルト大統領選挙のとき、ダイジェストの世論調査所がアンケートを送りつけた人々の名簿は、電話と自動車所有者からとられたのだそうだった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイジェストがアンケートを送った電話・自動車所有者名簿には、数百万の失業者、もっと多数の半失業者、貧農とその妻たちその娘たちの名はのっていなかった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見俊輔さんは『本の雑誌』第三八号で行われたアンケート、「なぜか怒りの秋なのだ」に実に鋭く答えられています。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアンケートは、活字とその周辺について何か腹の立つことはないかと問うたものなのですが、それに鶴見さんは「他人の頭をなぐる道具として本を用いることには腹が立ちます」と答えておられるのです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一時頃おき、食後出かけ、近藤さんの奥さんの様子を見、本やドーム・ゲルツェナ〔ゲルツェンの家〕へ行ったら、作家クラブはＹ、〔数字分空白〕51だというのでそこへ行き、アンケートを書いて来た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一雑誌のアンケートではない場合に「なにを云つたつてできやしねえ」と内心うそぶく精神の不健康、何事にも自分の順番を待てぬ人間の悪趣味を、私は、自分のうちに発見して、しばしば苦笑することがある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、たとえば、新聞社からのアンケートでも、私に来ないで父に来た時の父の喜び方は大へんなものです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国において「最も必要なことは何か」というアンケートに対して、その二割が第二戰線だと答えたが、大東亞戰爭だと言ったものは一人もなかった。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは一般のお客から「落語はどういうところがお好きでおいでになりますか」とアンケートの投書をいただいた。",
              "citation": {
                "source": "昔の言葉と悪口",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "『スタイル』という婦人のモード雑誌の新年号（一九五一）にアンケートがある。",
              "citation": {
                "source": "戦争はわたしたちからすべてを奪う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めてアンケートに書いておきました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこれ考えていたらば、この間、労働科学研究所から、一枚のアンケートが送られて来た。",
              "citation": {
                "source": "作家への新風",
                "author": "――著作家組合にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは珍しい作家の労働調査のアンケートである。",
              "citation": {
                "source": "作家への新風",
                "author": "――著作家組合にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としては労研のアンケートの最後に、著作組合はいらないかという問いがあったことについて感銘を受けた。",
              "citation": {
                "source": "作家への新風",
                "author": "――著作家組合にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、雑誌か何かで一度ひろくアンケートをとってみたらなお立証できるとおもう。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちあけて、といえば社の出版局から愛読者カードで「著者へ何を訊きたいか」というアンケートを出し、諸兄姉のお手をわずらわしたようである。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
