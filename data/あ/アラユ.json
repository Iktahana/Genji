    "definitions": [
      {
        "index": 1,
        "gloss": "clean, freshly poured bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日新湯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "新湯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は新湯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には新湯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "新湯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは新湯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "新湯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は新湯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では新湯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "新湯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に新湯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では新湯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "新湯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると新湯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "新湯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では新湯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に新湯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により新湯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "新湯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に新湯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "温泉はやはり、新湯に泊まった、去年（四十年）秋、笹子峠のトンネルを崩壊し、石和の町を白沙の巷に化して、多くの人死を生じさせた洪水は、この山奥に入ると、いかばかりひどく荒れたかということが解る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "身綺麗なお爺さんが、只一人位ざっと済したあとは、まだほんの新湯と同じ程に澄んで居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩原｜古町から一里ほど人里放れた山の中を行くと新湯に出る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして透きとほつた新湯のなかで蛙のやうな恰好をして暖まつてゐたが、急に顔色を曇らせて夫人の名を呼んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿は新湯の傍、なか／＼よい、よいだけ客が多いのでうるさい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "株を売った真の徳川御家人の一人は、先見の明をほこって、小金貸でもはじめたであろうが、みじめなのは、新湯川金左衛門邦純であった。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝風呂の新湯の感触がトゲトゲしいのに反して、仕舞風呂の湯の軟かさは格別である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは新湯、古湯等の他の温泉場と数町を隔てた谷間の別天地をなしていて、新湯の現代式なのと相違し、全く田舎の湯の宿の気分の漲っているところである。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "前なるは古湯で後なるは新湯、私は新湯の玄関に荷物を下させた。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが宿の主人は特別に優待せられて毎日湯を沸かすと一番新湯に入れといってくれるです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで風呂が沸くと、与八は真先にお毒見をするつもりで、郁太郎を抱いて新湯を試みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは抽象的でも具体的でもない、又あらゆる習慣、あらゆる思索の便宜に作られた言葉、あらゆる名辞以前にあるものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる外的概念、あらゆる学校教育なぞが人を誤らせる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる『文明』を嫌ったヘルンは、反対にあらゆる自然を深く愛した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもただ、自分が彼について語り得る唯一の權利は、あらゆる他のだれよりも、すべての彼の友人中で、自分が最も新しい、最近の友であつたといふことである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は透明な叡智を以て、あらゆる自然の實相を見通してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、ひどい憂鬱の厭世觀に憑かれてゐた私は、談話のあらゆる本質點に於て彼と一致し、同氣あひ引く誼みを感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあらゆる聰明さで、あらゆる人と調子を合せて談話する。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家は――あらゆる小説家は――私にとつて「星からの人類」だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その日の彼は、あらゆる點に於て深い悲痛の感をあたへた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに故人のあらゆる友人は、だれしもこの感情に於て同じだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身の教養は、あらゆる點に於て理智的であり、常識的であり、禮節的であり、そして二二が四的の透明さだつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）16　あらゆる自分の藝術が、あらゆる自分の表現が、芥川君自身にとつて不滿であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにその時、あらゆる天才の不運について、藝術家の宿命的な孤獨と悲慘について、彼が沈痛な聲で訴へたか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛の叫びは、いよいよ世の嘲笑の声を大にするだけであろうから、男は、あらゆる表情と言葉を殺して、そうして、ただ、いも虫のように、もそもそしていた。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介は一代の才人であり、琴棋書画のあらゆる文人芸に達した能士であつたが、その俳句は、やはり多分にもれず文人芸の上乗のものにしか過ぎなかつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろこの二つの文学は、彼のあらゆる作品的欠点を無恥に曝露したものだと思ふ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「粗野で逞しいポーズ」と、そのポーズの背後に潜んでゐる「優しくいぢらしいセンチメント」とは、彼のあらゆる小説と詩文学とに本質してゐるものなのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる文學と藝術とは、本質上に於て「詩」なのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
