          "literary": [
            {
              "text": "実相平等とは善因は善報を受け、悪因は悪報を受けて、ちゃんと割り切れるという、物事の実体方面で常に不増不減のところを指します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "善人必ずしも栄えず、悪人必ずしも悪報を受けぬところがあつてこそ始めて面白い、微妙な捕捉すべからざる味が出て来るのである。",
              "citation": {
                "source": "ある時に",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "善の酬ひは幸福、悪の酬ひは悪報ときまつてゐないところが面白いのだ。",
              "citation": {
                "source": "ある時に",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですけれど法水さん、やっとこれで、｜善行悪報の神の存在が私に判りましたわ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと申すも皆、前世の悪報です。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の法師は邪見であつたが為に悪報を受けた。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
