        "examples": {
          "standard": [
            {
              "text": "毎日、相具すは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相具すが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相具すに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相具すが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相具すについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相具すについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相具すについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相具すが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相具すが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相具すは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相具すは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相具すを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相具すをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相具すが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相具すの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相具すを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相具すに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相具すについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相具すは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相具すを高めるため日々訓練しています。",
              "source": "幻辞"
            }
