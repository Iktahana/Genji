        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アドについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "当時十八才のヂェラルド・ド・ネルヴァル――後世狂詩人として知られた男と――アドリンは図らずも一緒に踊ることとなつた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来アドリンは彼によつて忘れられないものとなつた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に彼はアドリンが出家して死んだと聞いたが、その面影は彼に残つて生きつづけ、其後彼は他の女を愛したが、それはかのアドリンの化身としてであつた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "プランクの明るい感じと反対にアドルフ・シュミット教授は何となく憂鬱な感じのする人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウ・レ・トアド・パリの唄から“C'est pour mon papa”の唄へ――巴里の感情は最近これらのはやり唄の推移によってスイートソロから陽気な揶揄の諧調へ弾み上ったことが証拠立てられた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰って昼飯を食いながら、今日のアドヴェンチュアーを家人に話したが、誰も一向何とも云ってくれなかった。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会で童女像を見た事と壷のアドヴェンチュアーとは一見何の関係もない事のようである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原氏が靜岡に遊び、氏の寓居を訪はうとした時、町の何人も蒲原氏の名を知らず、この知名な大詩人の寓居について、一もアドレスを知ることができなかつたさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空には今日もアドバルンと来やがらア」　装甲自動車の列。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのバアナアド・ショオの脚本にゼ・デヴィルス・ヂッシプルというのがあります。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでアドレスや請求文を書いて、父はイギリスの織物会社からしきりにカタログを取り寄せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金羊毛の踊子の白粉が夜会服のシルレルに、アドリア海にも似た陸地の汚点をつくっていると、シルクハットには女の腕に巻いた跡が緑色のリボンをつけてはねかえっているのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画俳優はアドルフ・マンジュウとグレタ・ガルボが好き。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、アドリナリン注射を要する強烈な發作には至らずに濟んだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい弔詞というものは、あれは誰にアドレッスされたものだろう。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらないようで実に不思議なアドヴェンチュアーとして忘れることが出来ないのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども学者のアラムハラドは小さなセララバアドという子がすきでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小さなセララバアドは少しびっくりしたようでしたがすぐ落ちついて答えました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "セララバアドは小さな革の水入れを肩からつるして首を垂れてみんなの問やアラムハラドの答をききながらいちばんあとから少し笑ってついて来ました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六万の観客中には、シネマ俳優としてのベーアの才能と彼のいろいろなセンチメンタル・アドヴェンチュアとを賛美する一万の婦人がいてはなやかな喝采を送ったそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど小牛のようなシェパアドに飛びかかっていって、あのときは、私が蒼くなった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私の繰り返し繰り返し言った忠告が効を奏したのか、あるいは、かのシェパアドとの一戦にぶざまな惨敗を喫したせいか、ポチは、卑屈なほど柔弱な態度をとりはじめた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてはじめて見た人形芝居一夕のアドヴェンチュアのあとでのこれらの感想のくどくどしい言葉は、結局十歳の亀さんや、試写会における児童の端的で明晰なリマークに及ばざることはなはだ遠いようである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは少年少女期の終り頃から、アドレツセンス中葉に対する一つの文学としての形式をとつてゐる。",
              "citation": {
                "source": "『注文の多い料理店』広告文",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは少年少女｜期の終りごろから、アドレッセンス中葉に対する一つの文学としての形式をとっている。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――これはこのあたりのものでござる――」　藍の長上下、黄の熨斗目、小刀をたしなみ、持扇で、舞台で名のった――脊の低い、肩の四角な、堅くなったか、癇のせいか、首のやや傾いだアドである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取着き引着き、十三の茸は、アドを、なやまし、嬲り嬲り、山伏もともに追込むのが定であるのに。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『象牙と薔薇の葉とでつくられたアドニス……』とヘンリイ卿は云った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とベエシル・ハルワアドは絵筆を措いて云った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
