[
  {
    "uuid": "f781b73b-070e-5795-872e-b94020b209ce",
    "entry": "阿摩美久",
    "reading": {
      "primary": "あまみきよ",
      "alternatives": [
        "あまみく",
        "あまみきょ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Amamikyu (Ryukyuan religion creation goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿摩美久について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿摩美久の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿摩美久が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿摩美久について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿摩美久の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿摩美久が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿摩美久という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿摩美久についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿摩美久は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿摩美久が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿摩美久は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿摩美久の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿摩美久は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿摩美久は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『中山世鑑』などはいとも簡単に、「阿摩美久天上へ昇り五穀の種子を乞ひ降り」と書き流しているが、是は少なくとも古伝を改めたものであって、由来記その他の後年の記録までが、一致して是と異なる伝えを載せている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑぞゑぞのいしぐすくあまみきよがたくだるぐすくゑぞゑぞのかなぐすく　〔十五―一五〕　伊祖の石城はアマミキヨが築いた城ぞ、伊祖の金城は、という意である。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
