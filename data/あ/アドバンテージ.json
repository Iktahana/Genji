          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アドバンテージについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドバンテージの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドバンテージが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドバンテージについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドバンテージの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドバンテージが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドバンテージという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドバンテージについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドバンテージは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドバンテージが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドバンテージは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドバンテージの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドバンテージは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドバンテージは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "×夏目漱石の墓　アドバンテージ　妻君　門下　故先生　　　　　Сижки　Суми　　二十五歳　一寸した小会社の娘　変りものを以て任ず。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
