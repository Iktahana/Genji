[
  {
    "uuid": "80ce7a68-5cc9-5b14-8c72-a71a769a067c",
    "entry": "安全地帯",
    "reading": {
      "primary": "あんぜんちたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "safety zone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安全地帯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安全地帯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安全地帯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安全地帯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安全地帯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安全地帯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安全地帯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安全地帯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安全地帯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安全地帯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安全地帯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安全地帯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安全地帯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安全地帯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このように、颱風は大陸と日本との間隔を引きはなし、この帝国をわだつみの彼方の安全地帯に保存するような役目をつとめていたように見える。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立っていた中年の下町女が何気なしにバスの間を覗いていたがふと自分の前の少女を見付けてびっくりしたような顔をして穴の明くほど見詰めていたようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯の危険率も、危険地帯の安全率もゼロではない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度安全地帯の脇の狭い処で、車をかわす余地がない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総師として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総帥として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯はアメリカ人の学校だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏｜数寄屋橋の電車停留場安全地帯に一人の西洋婦人が派手な大柄の更紗の服をすそ短かに着て日傘をさしているのを見た。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に張った投身者よけの金網のたった一つの六角の目の中にこの安全地帯が完全に収まっていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これは火口から七キロメートルを隔てた安全地帯から見たからのことであって、万一火口の近くにでもいたら直径一メートルもあるようなまっかに焼けた石が落下して来て数分時間内に生命をうしなったことは確実であろう。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は久しい前から、自分がついて行くにしても京子の散歩区域は裏通りの屋敷町を安全地帯だと定めてしまっていた。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頭山満の左右と背後の安全地帯に逃げ損ねた芸者仲居が、小さくなって固まり合って、生きた空もなくなっていた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして電車停留場の安全地帯に立っていたら、通りかかったトラックの荷物を引っ掛けられて上着にかぎ裂きをこしらえた。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉山へ移ってから、三四日の間、勝平は瑠璃子を安全地帯に移し得たことに満足したのであろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夜の交叉点の安全地帯で電車を待っていると、冷たい風が頬に吹きつけてくる。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉山へ移つてから、三四日の間、勝平は瑠璃子を安全地帯に移し得たことに満足したのであらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一度敵地を占領して要塞、河川、山地等のよき掩護を欠く時は冬期その地方を撤退、安全地帯に冬営するのが通常である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕方、東京で云えば日本橋のようなクズニェツキー・モーストの安全地帯で電車を待った。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の事実を綜合して見ると、今日、国文学の古典について云々することは、読者大衆の側からの鋭い視線にそなえる用意も比較的なくてすむし、本当の国文学研究者たちの、大衆的場面への批判的進出の懸念もさし当りはないという、一種異様な地の利を占めた安全地帯に身をよせる仕儀となるのである。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は永久に安全地帯に置かれたのである。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "××終点の引かえし線の安全地帯に立っていたら、すぐうしろで、「ストライキ見に来たよ」と太い男の声がした。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ストライキをやってるってえから……電車動いてるじゃないか」　その芸者は黙って、安全地帯の上から珍しそうに通って行くバスの中をのぞき込み「お父さん」何とかと、云っている。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「車庫へ行って見よう」　やがて五十がらみの男はそう云って歩き出したが、芸者はそれについて二三歩あるいたきり、安全地帯からはなれず、頻りに四辺を見まわしている。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終点のまわりには、何ということなし、街の様子を見物に出ている子供づれの女や男が、安全地帯のところではなく、洋服屋の既成品のぶら下ったしたあたりに佇んでこっちを見ている。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一台ポールの向きをかえるごとに、安全地帯の上をコツ、コツ、歩いている赧ら顔に新しいカンカン帽をかぶり、縞ズボンに白い襟がついた黒チョッキ、黒上衣といういでたちのずんぐりした四十男が、「××橋行きでございます。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――××方面のお方はおのり下さい」　一こと一ことをはっきりと呼んで、またコツ、コツ安全地帯をこっちへやって来る。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥にとっては此処は安全地帯だと見えて、時々東京には珍しい奴がやって来て鳴いている。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は或敵意のある批評家の僕を「九百十年代の麒麟児」と呼んだのを思ひ出し、この十字架のかかつた屋根裏も安全地帯ではないことを感じた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は或敵意のある批評家の僕を「九百十年代の麒麟児」と呼んだのを思い出し、この十字架のかかった屋根裏も安全地帯ではないことを感じた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
