    "definitions": [
      {
        "index": 1,
        "gloss": "blue king crab (Paralithodes platypus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油蟹について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油蟹は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油蟹の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油蟹について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油蟹は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油蟹の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油蟹に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油蟹が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油蟹を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油蟹の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油蟹が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油蟹が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油蟹について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油蟹は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油蟹は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油蟹は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油蟹について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油蟹の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油蟹の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油蟹の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
