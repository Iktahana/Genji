    "definitions": [
      {
        "index": 1,
        "gloss": "as it is",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日在るがままについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "在るがままという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在るがままの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在るがままが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在るがままを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在るがままについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "在るがままの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在るがままの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在るがままが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在るがままという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在るがままという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在るがままについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在るがままを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在るがままは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在るがままについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在るがままが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在るがままは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在るがままの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在るがままは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在るがままは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このロマン主義にあらわれている彼の受動性は、ヨーロッパ文化の伝統に対して、日本文化の伝統というものをいきなり在るがままの常套、約束、陳腐ごと受けいれ得る性格にあらわれている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "在るがままに在らしめ、成るがままに成らしめる、それが私の心境でなければならない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただ在るがままのちっぽけな自分自身が、しみじみと感じられていとおしくなった。",
              "citation": {
                "source": "父母に対する私情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、私はここにこうしています、自分の在るがままの生を愛して生きています、と母に向って――大地に向って、囁きたい気持である。",
              "citation": {
                "source": "父母に対する私情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただ足の行くままに目当もなく、墓地の片隅から発足して墓石の文字を一字づつ在るがままに読みつぶしては歩いてゐたが、時々気に入つた墓を見出す度毎に、自分の親しい知人達を一人づつ静かに其処へ埋葬して、それはそのまま忘れたやうに其処へ埋めて歩いて行つた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子に乗るものの常として、在るものを在るがままに見ないのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "在るがまま、便きなき、在るを忍びて、文もなし、曲もなし、唯あらはなり、臥房なき人の生や裸形の「痛み」、さあれ身に惱みなし、涙も涸れて。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが手によつて在るがままに再現されるそのことだけで、充分満足を覚えたのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感情の底にしみ込んでくる在るがままの不満な感じであった。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただ在るがままの心で空と地との静けさを呼吸した。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ在るがままの現在に、彼女は前方を塞がれていた。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを在るがまま受けいれて、彼の毅然たる魂は損われたことがないようだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識のゆたかな紳士といわれるような人びとは決して私の表現するようなぐあいには言わないが、あの長いものをすらりと組み合せ、それに何の値をももとめないで在るがままに在らしめていることに、私はむねに痞えているものが一度に下りた気がした。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "在るがままの人生、在るがままの文学の味が深く複雑に充分にわかりながら、しかしその上に立って、在るべき人生や在るべき文学の途を見出したり生み出したりすることは出来ないものでしょうか？",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし根本は、仏像をそれが本来在るがままのものとして拝せんとする心を失った点に在るのではなかろうか、私にはそうとしか思えなかった。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり在るがままなのだ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無、如意輪観世音菩薩」合掌をこらして、在るがままに在るうちに、我ともあらぬものが満身の毛穴から祈念のさけびをあげてくる。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規一派の俳人たちは、詩からすべての主観とヴィジョンを排斥し、自然をその「あるがままの印象」で、単に平面的にスケッチすることを能事とする、いわゆる「写生主義」を唱えたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は現在あるがままの相対性理論がどこまで保存されるかという事は一つの疑問になりうると思う。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、あるがままがよいとして、食べたい放題、遊び放題、無理の言いたい放題、不義理のし放題――それを、また世間でも、磊落だとか無邪気だとか言って買い被り、苦笑しながらも黙って見ているようなことがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし世の中が、あるがままがいいということになったら、人生は骨折りも努力もいりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・　あるがままの自然を描け！",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に芸術家としての彼等の態度は、この実に「あるがままの世界」に対して、あるがままの観照をすることにある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に「主観を高調する」とは、自己の理想や主義やを掲げて、観念を強く主張することであり、逆に「主観を捨てよ」とは、そうした理想や先入見やの、すべてのイデオロギイとドグマを捨て、非我無関心の態度を以て、この「あるがままの世界」「あるがままの現実」を視よということである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の側から言ってみれば、この「あるがままの現実世界」は、邪悪と欠陥とに充ちた煉獄であり、存在としての誤謬であって、認識上に肯定されない虚妄である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうよりのち、私は、あるがままの自身を語る。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしていよいよ一切の実相をあるがままに肯け入れると共に己れをまたあるがままにその中に置く、即ち人間はただその本元に還り、ただ自然のままに己れを還す、かうした恭礼三昧の境地に私は私自身を見出して来た。",
              "citation": {
                "source": "「白秋詩集」序",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中はあるがままにて怎かなる。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるがままの自分にできること　やっかいな病気にかかっていることを突きつけられ、動かなくなった身体を抱えて考えていたのは、治ってもとの自分に戻ることでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるがままの自分が書き、まとめて人に手渡そうとするとき、ツールキットは力を貸してくれるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
