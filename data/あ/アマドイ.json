        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨樋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨樋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨樋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨樋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨樋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨樋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨樋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨樋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨樋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨樋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨樋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨樋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨樋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨樋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨樋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨樋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨樋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨樋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨樋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨樋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "政治狂が便所わきの雨樋の朽ちた奴を……一雨ぐらいじゃ直ぐ乾く……握り壊して来る間に、お雪さんは、茸に敷いた山草を、あの小石の前へ挿しましたっけ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもお話ししたやうに、彼はイギリスにゐた時分には、こんなたかい屋根を見ると、どうしてもがまんがしきれなくて、いきなり雨樋につたはつてかけ上り、窓のあいてゐる屋根裏の部屋へとびこんだものです。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今、目のまへの建物の、たかい雨樋を目で見計りました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウ※ルターは思はず雨樋の下までかけつけました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ちよつと立ちどまつて、又、ない左手の肩先をふりかへりましたが、つぎの瞬間には、右手一本で雨樋につかまつたと見ると、まるでりすかなぞのやうに、ものゝ四十秒もたゝないうちに、もう屋根のはしのところまでかけ上り、小猫をつかまへて上着のふところに入れました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルターは、あたりが暗くなるとすぐに、こつそりとその倉庫の雨樋をつたはつて、高窓から二階へしのびこみました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はふと雨樋を伝う雨だれの音を聞いた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はぶりき屋が來て、いつも鳥籠をかけて置く板壁のそばの、雨樋を直してゐるので、こちらへ置かれたのだらうと話した。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒下の暗がり伝いに足音を窃み窃み、台所の角に取付けた新しいコールタ塗の雨樋をめぐって、裏手の風呂場と、納屋の物置の廂合いの下に来た。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身にゾーッと生汗を掻きながら今一度、静かに左右を振返ってみたが、その彼の怯えた視線は、タッタ今通って来た台所の角の、新しい黒い雨樋の処へピタリと吸い寄せられた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のままの濃化粧と、口紅のクッキリとした、高島田の金元結の艶めかしい、黒い大きな瞳を一パイに見開いた人形のような瓜実顔が、月の光りに浮彫りされたまま、半分以上雨樋の蔭から覗き出して、彼の姿を一心に凝視しているのであった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケケケケ……エベエベエベ……キキキキ……」　人形のような高島田の顔が、静かに雨樋の蔭から離れた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして屋根の端の雨樋の処から顔だけ出して、直ぐ下の廻転窓越しに、部屋の中を覗き込んで見たのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨樋がタンタンタラ・タラタラ鳴っている。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根から伝つて雨樋に落ち、雨樋から庭へ下る流れの喧しい音、庭の花壇も水に浸つてしまひ、門の下から牀下まで一つらに流れとなつて、地皮を洗つて何処へか運んで行く。",
              "citation": {
                "source": "五月雨",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨樋から溢れるやうな雨音を聞いてゐると、富岡は、一晩ぢゆうでも酒を飲みたくなるのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ直に雨樋をおろした壁にはいろいろのポスタアの剥がれた痕。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワの雨樋はちょっとよそのとかわってる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンの雨樋を流れる雨の音のあい間に、「ねえ、旦那やって下さいよ、お願いします」と、保護室でいっている。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その――古風な風見が廻っている岬の一つ家には、痩せてひょろ高い浜草が、漆喰の割目から生え伸びているほどで、屋根は傾き塗料は剥げ、雨樋は壊れ落ちて、蛇腹や破風は、海燕の巣で一面に覆われていた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いみやこに襦袢で一日水づかいしている馬鹿でキリョウよしの女房○家の並んで岬のように出ている四つの棟棟と棟との間に横タテに雨樋が通っている。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○家の中にいてきく雨樋の音、　　○瓦のメジがころがりこんで樋がつまって溢れる、　　○兼サアから魚を買う、自転車。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室は二階のはしで、窓のそばに、大きな雨樋が地面までつゞいてゐました。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨樋も別に壊れてはゐない。",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "その閑々たる空気を、下駄屋の親爺が破って言うことには、「外へ出てごらんなさい、大変な物だ、そこの雨樋筒に生首が一ツ……」「エ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺連はせっかくの興を殺がれたけれど、また別の興味を持って外へ出たり、外を覗いたりして見ると、その自身番の北手の雨樋筒に大きな張紙がしてあって、それを通りがかりの人が、大勢して読んではワイワイ騒いでいるのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "４．若い雀は今日立派に飛行試驗に及第した、彼は首尾よく隣家の雨樋の中へ飛び込んだ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも一枚岩の河床が雨樋のように抉れて、一丈近い飛瀑を奔下させている上を徒渉した時には、皆危く足を浚われる所であった。",
              "citation": {
                "source": "北岳と朝日岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは花崗岩の一枚岩が七、八町の間、雨樋のように深く抉られて、幅は二間ともあるまい。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
