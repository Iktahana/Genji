        "examples": {
          "standard": [
            {
              "text": "事故で家族を一度に失った彼女の境遇は、まさに哀絶を極めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "戦地から届いた手紙には、最前線で戦う兵士たちの哀絶な叫びが綴られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "胡弓の哀絶な調べが、雪降る夜の静寂に響き渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "幼くして難病に倒れた少年の手記は、読者の涙を誘う哀絶極まりないものであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "舞台上で演じられる主人公の哀絶な最期に、客席からはすすり泣きの声が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
