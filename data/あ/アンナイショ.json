        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内書について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内書という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内書の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内書が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内書を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内書について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内書の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内書の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内書が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内書という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内書という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内書についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内書を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内書は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内書について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内書が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内書は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内書の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内書は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内書は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その人にとっては先ず全国の温泉案内書のようなものは甚だ重宝である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都見物を一定時日の間に最も有効にしようというには適当な案内者あるいはこれに代るべき案内書があると便利である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう少し詳しく具体的の事が知りたくなって、今度は温泉専門の案内書を捜し出して読んでみる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んだ案内書や聞いた人の話が、いつまでも頭の中に巣をくっていて、それが自分の目を隠し耳をおおう。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは案内書や教えた人の罪ではない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人はとかくに案内書や人の話を無視し、あるいはわざと避けたがる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら、九頭竜の野郎、それは耳よりなお話ですから、私もひとつ損得を捨てて乗らないものでもありませんが、それほど先生がたがおほめになるもんなら、展覧会の案内書に先生がたから一言ずつでもお言葉を頂戴することにしたらどんなものでしょうといやがった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はあわてて案内書を読みはじめてゐた。",
              "citation": {
                "source": "ペルリ行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　かれはやがて元の室へともどつて来て、暫しは茫然として椅子に腰を下してゐたが、まア少し片附けようと思つて起上つて、そこに卓の上に出してある雑誌だの案内書だの報告書だのを鞄の中に入れて、それを向うの方へと持つて行つた。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内書の秘密　美しいお嬢さんの居る家に一枚のビラが配られた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………　××社交クラブ成立案内書大正の大震火災後社会の風潮は著しく悪化して参りました。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この案内書を貰ってポケットに畳込んだ記者は、そのまま省線に飛び乗って中野で降りた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケットから例の案内書を出して見つめながら、頭をゴシゴシ掻きまわしたが、わからないものはどうしてもわからない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の敷石の打水の上に、赤い紙に刷った「文化生活研究会案内書」というのがヘバリ付いていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、都市の大建物で、拝金宗の権化ならざるものは尠なく、ニユーヨークのウールウオース・ビルヂングの案内書に、商業寺院 Church of Commerce として紹介されてあるのは、さすがにヤンキーだけあつて、言ふことが徹底的である。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の政治学者は事によつたらあの通り綿密な内田氏の事だ、案内書の本文にどこか間違でも発見けて、それをわざ／＼気をつけに来たのではあるまいかと思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信のない外国語は、旅先きで使ふものでないといふ事は、ベデカの案内書にもかいてあつて、有島氏も万々承知してゐるが、娘はやはり美しかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "初歩的な機械についての案内書から、資本主義の解説から、トルストイやゴーリキイまでが読みたいと思われ、読書は生活の必要と感じられている。",
              "citation": {
                "source": "文化生産者としての自覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には雑誌や新聞の展覧会評の切抜きを道案内書として、展覧会を眺めて廻る忠実なる鑑賞家も大阪の二科展会場等で時々見受ける。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "又支那に『示我周行』といふ題目の旅行案内書がある。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどりの勤め先の堂本兄弟商会というのを一階の案内書で調べると、五階にある。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下にいることはできにくかったから、朝子はその都の案内書をたよって、いろんな場所いろんな人の集るところへ出かけた。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之と同じ姿勢をした木彫の小児を巴里のクルニイの博物館で観た事を思出したが、此奇抜な放尿の噴水に如何なる由来があるかは早速繰返して見た案内書にも見当ら無い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内書に由れば鉄嶺の城市は柴河の南にある。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この計算がね、ふしぎの国の案内書でありますよ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕もとにはお義理のように横文字の本を堆高く積んであるが、見ているのは大抵例の「スゥイス日記」か、ベデカアのスゥイス案内書位なものである。",
              "citation": {
                "source": "雉子日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悲劇喜劇」は、この迷宮を訪ふものの案内書であり、探検用の新版地図である。",
              "citation": {
                "source": "「悲劇喜劇」の編輯者として",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊悲劇喜劇は、近代演劇の迷宮を訪ふものの為めに編まれた新版案内書である。",
              "citation": {
                "source": "「悲劇喜劇」広告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は長崎へついて、まつさきに、数種の案内書と地図を買つた。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
