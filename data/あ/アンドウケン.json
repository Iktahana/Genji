        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安導券について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安導券という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安導券の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安導券が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安導券を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安導券について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安導券の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安導券の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安導券が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安導券という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安導券という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安導券についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安導券を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安導券は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安導券について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安導券が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安導券は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安導券の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安導券は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安導券は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
