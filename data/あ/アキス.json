        "examples": {
          "standard": [
            {
              "text": "空き巣は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き巣対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き巣に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き巣がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き巣は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、空き巣の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは空き巣を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により空き巣の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における空き巣の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "空き巣について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日空き巣について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から空き巣を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により空き巣の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは空き巣を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で空き巣に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "空き巣は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き巣対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き巣に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き巣がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き巣は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「柵は、空き巣になってもかまわぬ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよはそれを見て「飽きあきする、あんなまずいもの」と顔を皺めた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、前年とおなじように彼女は飽きあきするような歎願をくりかえし、私もまた例のごとくに情ない返事をした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰惨な光景にはあきあきするほど遭遇してゐたが、さつき見た甥の姿は眼に沁みるのだつた。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十六日（月曜）晴、寒　あきあきするほどの長雨が漸くはれて霜が降って居た。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の下手な探偵作家があきあきするほどくり返し、そうして日本の探偵作家が真似をしはじめたトリックだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の五",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレみたいのノンダクレでも、毎日同じことをしてゐるうちには、いゝ加減、あきあきするよ。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、　ほんとうに、もうあきあきするほど長い事っちゃあないかい。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "育つ勢の盛なる子供達はたとえその度毎にあきあきするほど食べても、又その次の時には、前に一口も何も食べなかった様に待ち遠がったり、食べたがったりするものだけれ共、その度毎十分にたべて又次に待ち遠がる子供の眼は必して、今これ等の子供達が持って居る様な眼は持つものではないのである。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただマがちょッとあきすぎていたから斬りつけたのは剣先で、致命傷には至らなかった。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは退屈であきあきするに違いない。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人たちは今でも、このあきあきするような難儀や怖ろしい行脚の御褒美を、私のために用意しているのだ。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このごろは、あきすや、どろぼうが、横行するというから、むりもないが、ここを通るものが、みんな私の顔をつめたい目つきで見ていく。",
              "citation": {
                "source": "春さきの朝のこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤーシャ　お前さんの話にも、あきあきするよ、爺さん。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いっそ小鳥みたいに自由になって、さっさとこんな所から飛び出したら、みんなの寝ぼけっ面や、あきあきするような長話が、見えも聞えもしない所へ行って、きれいさっぱりみんなのことが忘れてしまえたら。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このままでは討ちもらす、遠矢を射て落してくれよう」　と、距離があきすぎ射当てる自信は梶原にはなかったが、もしやと思い、弓を満月に力一杯引きしぼって放てば、見事その矢は重衡の乗る馬の後のつけ根に深くささり、名馬童子鹿毛の足はみるみる崩れてきた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには病院の入口から病室まであきあきするほど長い廊下のところどころに人が立って××さんの姿がみえると同時に出来るだけはやく病室へしらせる手筈になった。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、あきあきするような旅でした。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "司教さん、エホバの仮説には私はもうあきあきする。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ、だらしなく口があきすぎると？",
              "citation": {
                "source": "飛騨の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃宝石類はあきあきするほど見なれているはずの大宝石商の娘さんが、声を立てて驚いたのだ。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
