        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――」　そういって博士は、戸棚の上から、一束の青写真をおろし、テーブルの上にひろげてみせた。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "青写真を水に入れてある。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは米国の参謀本部で作った日本地図の青写真の写しです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしその写されたあとの青写真は……」「又もとの通りに畳んで、化粧箱の中へ返しておきました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上には『極秘』の赤紙が貼られた怪潜水艦『富士』の青写真が、ものものしくひろげられている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで、一枚一枚、繰っていくうちに、私は、その青写真が、どんな器械をあらわしているかについて、知ることが出来た。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのときは、うんと代償物を用意して置けよ」　そういって、金博士は、大きな青写真にとった設計図を、惜し気もなく密使に渡してしまったのであった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、それを無造作に拾いあげ、その中に手を入れると、やがて一枚の青写真を引張りだした。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝の上に青写真を展げて、二度びっくり。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かと思えば、それは藍色の仕事服を着て、青写真を小脇に抱えているカコ技師であった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああここに工事のあらましを書いた図面がありますから、これをごらんなさい」　タクマ少年は、やすんでいる起重機の上にのっていた青写真をとりあげると、僕に見せてくれた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "交叉点の一角を占有している千四百余坪に上る空地に、私の計画した東宝文芸会館の構想は、今や青写真の残骸となって、書斎の一隅に永久に眠っている。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから蚋にくわれながら懐中電燈をもって叢のなかを明るく照らす、懐中電燈の明りは叢のなかを青写真のように映し出し、茎と葉との宮殿がならんで見える。",
              "citation": {
                "source": "螽※の記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな大理石の見本だの蝶番だのの見本がつみ重ねてあるわきに、高いファイル棚があり、泰造はテーブルの上に青写真をひろげて調べていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はモーニングを着ていて、眼鏡のはしのところを左手の指でつまむような手つきをして青写真をのぞきこんでいる。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青写真の用事がすむと、「さ、出かけましょうか」　顎のところに大きいほくろのある人に、来客のことをうちあわせると、泰造はさっさと事務所を出て、エレベーターのところへ行った。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は父にことわり、その許しが出ないと、半地下室で青写真が水槽に浮いている素晴らしいみものさえ、勝手に見にはゆかなかった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の未来像は、未来こうなるというのを見せてくれる青写真だ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
