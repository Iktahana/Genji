    },
    "definitions": [
      {
        "index": 1,
        "gloss": "simple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安直について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安直という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安直の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安直が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安直を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安直について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安直の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安直の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安直が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安直という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安直という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安直についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安直を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安直は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安直について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安直が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安直は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安直の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安直は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安直は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アインシュタインおよびミンコフスキーの理論のすぐれた点と貴重なゆえんはそんな安直な事ではないらしい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の望むところは、そういう安直な見どころをむしろ故意になくするように勉めるくらいにしてもらいたいと思うのである。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう能力の獲得が一人の人間の精神的所得として、そう安直な無価値なものであろうとは思われないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしＳの判断が本当であったとしたら、つまり私は自分の想像の中で強いて憐れな蜂を殺してしまって、その死を題目にした小さな詩によって安直な感傷的の情緒を味わっていた事になるかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合にもし百貨店で買物の節に軽便安直な知識を購入出来れば工合がいい。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかになかなか美しい人形や小箱なども陳列してあったが、いちばん自分の注意をひいたのは児童教育のために編纂された各種の安直な絵本であった。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり暑いので耳たぶへ水をつけたり、ぬれ手ぬぐいで臑や、ふくらはぎや、足のうらを冷却したりする安直な納涼法の研究をしたこともあった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してここで言うところの「映画による若返り法」はきわめて実用的に安直であり、しかもなんらの副作用や後害を及ぼす危険がないようである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも安直なトーキーの器械やフィルムが書店に出るようになれば教育器械としてのプロフェッサーなどはだいぶ暇になることであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の哀れというのも安直な感傷や宋襄の仁を意味するものでは決してない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野山に、によき／＼、と言つて、あの形を想ふと、何となく滑稽けてきこえて、大分安直に扱ふやうだけれども、飛んでもない事、あれでなか／＼凄味がある。",
              "citation": {
                "source": "くさびら",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、安直な卷莨を吹かしながら、夜番の相番と、おなじ夜の彌次たちに此の話をした。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、家内の財布じりに當つて見て、安直な鯛があれば、……魴※でもいゝ、……希くは菽乳羮にしたい。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかゝは、うんと藤村家に驕らせて、此の安直なことは、もづくの比ではない。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品ではないが安直すぎた。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この男はまだ芸術家になりきらぬ中、香具師一流の望に任せて、安直に素張らしい大仏を造ったことがある。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならこの散策子が、そのぶらぶら歩行の手すさびに、近頃｜買求めた安直な杖を、真直に路に立てて、鎌倉の方へ倒れたら爺を呼ぼう、逗子の方へ寝たら黙って置こう、とそれでも事は済んだのである。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲府市外の湯村温泉、なんの変哲もない田圃の中の温泉であるが、東京に近いわりには鄙びて静かだし、宿も安直なので、私は仕事がたまると、ちょいちょいそこへ行って、そこの天保館という古い旅館の一室に自らを閉じこめて仕事をはじめるということにしていたのである。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな安直な友情のみせびらかしは、僕は御免だ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしも通夜の席の笑いばなしの種子にされるというのは何という果敢なくも薄手で安直な老女のいのちでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　銀造を乗せた人力車夫は、見掛けは上品な顔だちだったが、車賃だけでは食って行けぬのか、怪しげな周旋もするらしく、旦那は木屋町へ行ってヤトナを買うのか、ヤトナは芸者よりは安いようで結局高いものにつく、それよりも、もっと安直で面白い所を紹介しようか――と、しきりにすすめるのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如くして二葉亭の鉄槌は軽便安直なドグマや「あきらめ」やイグノランスを破壊すべく常に揮われたのである。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは安直に山の空氣を吸ひたいといふ人達の便を計つて、ヂョウシア・ランキン氏が建てたものである。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三はその部屋で、飯のかわりによくコーヒを飲み、パンをやいて食べたが、夜は外へ出て、葉子がいつの間にかお馴染になっているおでんやだの、安直なレストランなどで食事を取ったりした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれを実践にうつす段どりになると彼はきわめて安直に、粗末に、非組織的に行動することしかなし得ない。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "師範卒業生佐田の安直ぶりが、階級的発展の端緒としての意味をもつ未熟さ、薄弱さとして高みから扱われているのではなく、作者須井自身にとっても弱い一点であることは、「幼き合唱」のところどころの文章にうかがわれる。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり思想の動員というのは、一時的な思想体制のことではあり得ないだけに、それだけ実は動員という性質を充分に備え得ないものだから、他の領域で比較的簡単に行なえるような意味での動員も之を思想について行なうことは、普通世間が想像しているほど安直に成立はしないわけなのである。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば、安直な便宜主義のために善い意図さえ流産させる行動感覚は、民主主義文学者の間にだけ残されている古さなのだろうか。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空想的な扮装したレヴューの土人みたいな「赤紫島」の住民が何かのキッカケで、至極安直に革命を遂行し、ツァーの追っ払いをやり、目出度し目出度しとなるのだが、ソヴェト同盟のルバーシカを着た観衆はゾロゾロ、カーメルヌイ劇場から出て来ながら、この劇全体から受けた何だかいやな印象について議論した。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それよりもこのホテル・アムステルダムあたりの古風な部屋と安直な宿料が有難いというので、一時は、と言うのは、つまり、「三階の十四号」が「自殺室」として、こうして巴里中に、仏蘭西じゅうに、いや、大きくいって全欧羅巴に有名になる迄は、可成り流行ったものである。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
