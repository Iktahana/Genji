[
  {
    "uuid": "5792f5a8-daee-59e4-bde4-fc059b2f5b58",
    "entry": "兄い",
    "reading": {
      "primary": "あにい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
