    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elder brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「兄いもうと」というのを、やっていた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『間拔奴、見損やがつたか、汝、記憶えとけ、深川の芳兄いてで鳴らしたもんだい、手前達の樣な、女たらしに、一文たりとも貰ふ覺えはないぞ、ヘツ、どうだい、その面は、いやにキヨロツキやがつて、憚乍ら口惜しけりや腕ツコキで來い、白痴ツ』『女たらし』の一言に力を罩めて憤怒の焔燃ゆるが如し、果然彼には一物あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、私は、市川の駅へふらと下車して、兄いもうと、という活動写真を見もてゆくにしたがい、そろそろ自身｜狼狽、歯くいしばっても歔欷の声、そのうちに大声出そうで、出そうで、小屋からまろび出て、思いのたけ泣いて泣いて泣いてから考えた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、兄いさん、黙つて聞いてゐて下さい。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、兄いさん、わたし今少しで口笛を吹く所でした。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうお客にすりゃ御損が行く、情人にして不足のねえからっけつ曾我の十郎てえお兄いさんだ、頼むぜ、と取巻いた人立を割って怒鳴り込んだんでさ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の兄いだが、目を円くして驚いた。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田三河町の徳次兄いに頼まれて来たのだが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はきょう来たのはほかでもねえが、今も云う通り、徳次兄いに頼まれて来たのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえは兄いを識っているのだろうね」と、半七は先ず念を押した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで兄いの御用というのは何んでございますね」「少しおめえに訊きてえことがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳次兄いはもう知っていなさるのかえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徳次兄いに睨まれちゃあ助からねえから、何もかも正直に云いますがね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徳次兄いは何と云ったか知らねえが、わっしはそんなに悪い人間じゃありませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには又、仲裁するような奴が出て来て、兄い、まあ我慢してくれとか何とか云って、一朱銀の一つも握らせてくれたか」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄いさま方が揃うておいでなさるから、お父っさんの悪口は、うかと言われますまい」これは前髪の七之丞が口から出た。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも自分にひどく懐いてゐた、頭の毛のちぢれた弟の、故郷を立つとき、まだやつと歩いてゐたのが、毎日毎日兄いさんはいつ帰るかと問ふといふことを、手紙で言つてよこされてゐる。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弟が、若し兄いさんはもう帰らないと云はれたら、どんなにか嘆くだらうと思ふ。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし妙なことには、その家にお兄いさんというのがいて、余程お人好と見えて、お麗さんに家来のように使われている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様にはそのお兄いさんというもののいるのが気に入らない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亡くなった兄いさんのおよめになら、一も二もなく来たのでございましょうが」と言いかけて、ご新造は少しためらった。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナタの目上、例へばお兄いさんとか伯父さんとかいふ方の御不幸が此頃有りましたらう。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら未だ南京米を口に入れた事の無いお兄いさんだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ぶ声　おうい、浅兄い、待てえっ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎助は五十に近き老人、弥助は四十前後）才助　（九郎助に）やあ、稲荷の兄い、足は大丈夫かい。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅太郎　兄い、あんまりそうでもなさそうじゃねえか。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ら若い時にゃ、忠次の兄いと一緒に、信州から甲州へ旅人で、賭場から賭場をかせぎ回ったもんだ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥助　そうだったなあ、稲荷の兄いの若い時は豪勢なもんだった。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "式作法は稲荷の兄いに教わったかも知れねえが、あの度胸骨と腕っ節は、まさか教わりゃしねえだろうねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥助　なぜだい、兄い！",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
