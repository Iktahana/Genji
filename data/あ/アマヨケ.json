[
  {
    "uuid": "dd750cf6-fc2e-59ab-824c-36d44e4e27bb",
    "entry": "雨よけ",
    "reading": {
      "primary": "あまよけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rain cover",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨よけについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨よけという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨よけの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨よけが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨よけを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨よけについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨よけの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨よけの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨よけが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨よけという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨よけという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨よけについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨よけを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨よけは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨よけについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨よけが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨よけは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨よけの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨よけは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨よけは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "姉よりも地味な好みの、たった一枚持っている上布の着物に、淡い色ばかりの縞の博多帯で、やや下目にキリリと胴を締めて、雨よけのお召のコートを着て、新子は十一時、四谷の家を出た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の上には樫の大木がしげった枝をさしのべていていい雨よけになった。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者の叫ぶ声が、桟橋の上で打ち振るハンケチの時々ぎらぎらと光るごとに、葉子の頭の上に張り渡された雨よけの帆布の端から余滴がぽつりぽつりと葉子の顔を打つたびに、断続して聞こえて来るように思われた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、男はうしろに長方形の箱を背負って、ちょうどそれは子どもの寝棺のような箱でしたが、その奇妙な箱を相当重そうに背負って、上に雨よけの合羽をおおいながら、いましも表へ向かって歩みだそうとしているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "又長いトンネルがあり、つづいて雨よけのさしかけのようなトンネルがあり、つき当りにやっと、鵜原館と電燈で照し出した白い板が見えた。",
              "citation": {
                "source": "黒い驢馬と白い山羊",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちさ持って来るだよ」　声のする方を振り返って見れば、雨よけの所に黒い影が跼っている。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "平賀源内の発明にかかわる、火浣布（羅紗）でこしらえた雨よけ合羽じゃ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの雷は雨よけをしようとしたあの松の木に落ちたのだよ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い野原の中で嵐に遇つた時に、その雨よけの場所に木の下、殊に高いのが一本だけしか立つてゐない木の下をさがすのは大変に不注意なあぶない事だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの嵐の日に僕が雨よけしませうと云つたあの松の木の下で、あの時、僕達は死んでゐたかもしれないんですね。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中でにわか雨があり、そのためわたしは半時間ばかり松の木の下に立って、頭の上に枝をいただき、ハンケチで雨よけをしなければならなかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのとき二人は店へおりたところで、彼女が女中に向って、雨よけを取ってくれ、と云うのと同時だったので、やはり返辞は聞けなかった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は頭巾をかぶり、雨よけの被布を被ると、無言でそっと会釈をして、出ていった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
