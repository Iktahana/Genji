    "definitions": [
      {
        "index": 1,
        "gloss": "autumn crops",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "近所の女だの、年上の従姉妹だのに、母が絵解をするのを何時か聞きかじつて、草双紙の中にある人物の来歴が分つたものだから、鳥山秋作照忠、大伴の若菜姫なんといふのが殊の外｜贔屓なんです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が秋作、豊後之助の贔屓なのは分つて居るが、若菜姫が宜くツてならない、甚だ怪しからん、是は悪党の方だから、と思つて居たんです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作はことごとく吉、ただし春の詰まりに秋｜吉けれども、物も作らぬ者いよいよ明けし春までも貧なり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夏作があんなだに、秋作がこれじゃ困ったもんだ」「不作つづきだからやりきれないよ全く」「そうだ」　ぼそぼそとしたひとりごとのような声だったけれども、それは明らかに彼の注意を引くように目論まれているのだと彼は知った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、五つ（午後八時）の時計の鳴る頃まで、青柳春之助や鳥山秋作の話をしたのですが、それが病み付きになってしまって、それからはお仙が毎日「しらぬひ譚」のお話をする役目をうけたまわることになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく鳥山犬千代――秋作――は、家橘生れてはじめての大役であつた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕内の人々は、家橘の秋作と聞いて、会心の笑みを洩したことが察せられる。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稗や黍の秋作も蒔かねばならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま紹介したひとたちのほかに、剛子の従兄の秋作氏がすっかりこちらへ背中をみせ、窓のそばで新聞を読んでいる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　槇子たちの組がおお騒ぎをしながら出て行ったあと、いつの間にか、『キャラコさんの恋人』も猪股氏もいなくなって、広い社交室の中にキャラコと従兄の秋作氏の二人だけがポツンと残されることになった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏は窓ぎわの椅子にかけ、いぜんとしてこちらへ背中を向けたまま、塑像のように微動もしない。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは秋作氏のたくましい肩をながめながら、よくあんなに動かないでいられるもんだと思って、急におかしくなって、もうすこしで笑いだすところだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たぶん『黒いお嬢さん』と喧嘩でもしたんだわ）　秋作氏は長六閣下｜末弟の子で、従って槇子たち同様、キャラコにとっても従兄にあたる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏は、銀行家の沼間氏も、虚栄坊の夫人も二人ながらだいきらいで、沼間夫妻をいつもあいつらという代名詞で呼んでいる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏が知っていた槇子は、すくなくとも、こんな了見の狭い娘ではなかったはずだったが、論より証拠で、やはり自分の計量ちがいだったと思うよりほかはなかった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あまりな返事なので秋作氏も不愉快になり、槇子に、貴様はクソみたいなやつだぞ、とひどいことをいったということを、あとでキャラコさんがきいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏はそれっきり沼間氏の一族と交渉を絶ってしまった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹を立て、飲んだくれて歩いているという評判もあったが、その秋作氏が、つい二日前、卅二三の、すこし薹のたったお嬢さんと二人でフラリとこのホテルへやって来て沼間夫人を驚かした。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお嬢さんは、へんに煤黒い、ひどい斜視の、棒を嚥んだようなヌーッとした感じのひとで、眉目秀麗な秋作氏と並ぶと、一種、対照の妙を示すのだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作さんが、この『黒いお嬢さん』と二人で食堂へはいってきたとき、沼間の一族もそこにいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、槇子は、この二人づれを見てもなんの反応も示さなかったし、秋作氏のほうもチラリと見かえったきりで、一向顔色も動かさずにずんずん奥のテーブルのほうへ行ってしまった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏は、もう四五年、長六閣下のところへやって来ないが、毎年クリスマスになると、かならず、とぼけた玩具や小さな人形をキャラコさんに送ってよこした。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秋作氏としては、ちと、どうかと思うやりかたなのである。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏が、やっと身動きする。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "（秋作氏は美しいな）　下から仰ぎながら、キャラコさんは、そう思う。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏は今年三十三になる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、そうなの」　秋作氏は、てらい気のない、素直なこの従妹がだいすきだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五年見ないうちに、すっかり立派なお嬢さんになってしまったが、率直なところだけは、一向子供のときと変らないとおもって、秋作氏はほほえましくなる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏は、長六閣下の一家が、つましく暮らしていることをうすうす知っているので、ホテルのロビイでキャラコさんを見かけた時は、たぶん人ちがいなのだと思った。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋作氏が見ると、キャラコさんはたいへんな質素な服を着ている。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
