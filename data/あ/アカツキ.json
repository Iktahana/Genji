        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りにそれが叶つたとしても、叶つた暁には芸術は芸術ではなくなるであらう、即ちその役を果さなくなるであらう。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格が分裂して徹底した没分暁漢になれなくなるから。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁を思わせるうす紅色で、雨気を含んだ虚空に、浸み透るように、暈して描かれた自分たちの印画は、この大なる空間を跨いで、谷間へと消え落ちた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　旅人の「山」　万坊ヶ原の一本松は、暁の暗に隠れた、那須野ヶ原あたりの開墾地にありそうな、板葺小舎から、かんがりと燈がさす。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁の空に大宮表口の裾野原は、うす紙をはがすように目がさめる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暁に、どちらが正しいかが分るんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうございます、暁の祭までにはまだ間の時刻もございます。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、暁が白みかけました。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、暁の祭りにいそしまねばなりません。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「気象の精粋」の意味とともに、「世態人情に通暁すること」「異性的特殊社会のことに明るいこと」「垢抜していること」を意味してきている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらが一通り具備したる暁においても、現象の偶然性を除く程度まで精しくこれを知悉する困難は現象の性質上甚だ大なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山深き暁のながめ、しんしんとして物一つ動かぬ静かさは膚にしみわたりて単衣に寒さを覚えたり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は猶母牛の注意を男共に示して置て寝てしまった夜明けて後男共は今暁の死犢を食料にせんことを請求してきた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつぎの夜もつぎの夜もおぼつかなくて、何時しか暁月夜の頃にもなれば、などかくばかり物はおもはする、いとつれなくもあるかなと憎くむ／＼猶まつに弱らで一夜を待あかしゝに、ある暁のいとねぶうて、物もおぼえずしばし夢結ぶやうなりしが、耳もと近くその声あやまたず聞えぬ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつも暁よりなきいでゝ夕ぐれまでは御軒のものなるを、いかにしてさは聞き給ひけん、物ぐるほしくもおはしますかな」といよ／＼笑ふに、「さにはあるまじ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁天の白露を帯びたこの花の本当の生きた姿が実に言葉通り紙面に躍動していたのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影者が単に映画のテクニークに通暁しているばかりでなく、その対象に関する十分な知識をもっていることが絶対に必要である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によれば、鳥類が農作物の害虫を駆除する功は非常なもので、もし鳥類濫殺の結果有益な鳥が絶滅に近づく暁には、地上の植物は大半滅亡するに至るであろうというている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝山道――暁　武蔵と団九郎がお絹を伴って、　下りて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁がたちかくふと私は眼覚めた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の銅羅が暁を破ると見送人達は鉄梯子を下りて対岸に並ぶと、二度目の銅羅と一斉にわめき出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云うと、彼女の靴音が暁前の静寂を遠のいて行った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府にあったリー・シー・ツワンは今暁香港に飛行機で来り、直にホテル・マンションに入ったことが記事になっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今暁飛行機で香港にくると陳独秀の革命的遺産をうけついだのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつきや破れし鐘樓に。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつき覺めにけり菊の露",
              "citation": {
                "source": "秋の日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "県会議員が、当選したあかつきには、百姓の利益を計ってやる、というような口上には、彼等はさんざんだまされて来た。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あかつき眠るみどりごを〕あかつき眠るみどりごを、　　　ひそかに去りて小店さき、しとみ上ぐれば川音や、　　　　霧はさやかに流れたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども萬一、私が『表現の祕訣』を握つたあかつきには、私は私の藝術を捨てることを躊躇しない。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
