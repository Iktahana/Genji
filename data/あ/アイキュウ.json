[
  {
    "uuid": "f92691a3-54c7-54d7-89a5-8910ccfcbc33",
    "entry": "哀泣",
    "reading": {
      "primary": "あいきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crying with sadness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀泣は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀泣が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀泣に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀泣が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀泣について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀泣についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀泣について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀泣が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀泣が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀泣は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀泣は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀泣を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀泣をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀泣が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀泣の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀泣を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀泣に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀泣について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀泣は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀泣を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "悲哀泣涕のほかは無き折なれども、こゝは大切の時である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "血は、見るみる砂に吸われて、苦悶の極、虎視眈々と一時静止した牛が、悲鳴し怒号し哀泣し――が、許されっこない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "血はみるみる牛の足を伝わって流れて、砂に吸われて、点々と凝って、虎視眈々と一時静止した牛が、悲鳴し、怒号し、哀泣し――が、どうせ殺すための牛だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして夥しい叫喚と、呻吟と、哀泣。",
              "citation": {
                "source": "十時五十分の急行",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「影の人」の２、アリストファネスの卓上演説、切り離された半身が、他の半身を求めて、哀泣しつつ彷徨する……。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々大の男が如何に猛威をふるって怒罵叱責してもその威力はこの仔猫が一分間の悲鳴哀泣に及ばない、ものには各々天分があるものだと云う事がつくづく思わせられる、それから以後、別々に母屋と寮との間に毎晩はなして寝かせて、鼠族鎮台の役を勤めさせることにした。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し許さる可くは余は一切のセンチメンタルなる哀泣と嘆願とを避けて、唯汝と一つにならむことを祈りたい。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如くにして二分せられたる人は其半身を求めて哀泣し彷徨した。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物音にまじって漂う老婆の哀泣である。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき一族兄弟の間に争論を起こし、哀泣の声たちまち変じて罵詈の声となるの例、しばしば聞くところなり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不自然な物音や、こんな咆哮や、悲鳴や、歯がみや、哀泣や、乱打や、罵詈雑言は、いままでついぞ一度も聞いたことも、見たこともない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
