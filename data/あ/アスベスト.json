          "literary": [
            {
              "text": "手製のアスベストスの棒に針金を捲きつけて、それを不細工な歯車か何かにとりつけた妙な装置が出来上がった。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室井君の「地球磁気の根源に関する」大研究も、検流計が一つとあとはアスベストスの棒と手細工のがらがら廻る歯車とが出来上がれば、とにかく実験が始められた。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手製のアスベストスの棒に針金を捲きつけて、それを不細工な歯車か何かにとりつけた妙な装置が出来上った。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＭ君の「地球磁気の根源に関する」大研究も、検流計が一つとあとはアスベストスの棒と、手細工のがらがら廻る歯車とが出来上れば、とにかく実験が始められた。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなとき、得意先のアスベスト会社の支配人が女房の話を持込んだ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
