        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アリアについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アリアという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアリアの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアリアが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アリアを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアリアについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アリアの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアリアの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアリアが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アリアという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアリアという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアリアについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アリアを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアリアは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アリアについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアリアが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアリアは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアリアの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アリアは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアリアは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さて、本題に立ち帰つて、「どうすれば、真実な意味の、強いプロレタリア文学が生れるか」　私は、調べた芸術とか、プロレタリアリアリズムとか、難かしいもつともらしい文句から、全つ切り、傍道へ外れ込んだ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルクナー主演の「女の心」（原名アリアーネ）の一場面で食卓の上にすみれの花を満載した容器が置いてある、それをアリアーネが鼻をおっつけて香をかいだりいじり回したりするのであるが、はじめは自分にはそれがなんだかよくわからなくて、葡萄でも盛ったくだもの鉢かと思っていた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつからとも、わかりませんが、月日の経つのにつれて、アヤ子の肉体が、奇蹟のように美しく、麗沢に長って行くのが、アリアリと私の眼に見えて来ました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのダラシのない姿が、寝台の上に寝そべっている夫人の姿と重なり合って、室の奥の大鏡にアリアリと映っていた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は烈しく切り結んでいるうちに、底知れぬ霊的の冷静味がリズム化して流れている事を、客観的にアリアリと感ぜられる。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光の群れがサーチライトのように一団の大光明となって二人の真正面の窓から流れ込んで来て、金ピカずくめの応接間の内部を白昼のようにアリアリと照し出しているではないか。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかの地で聞く機会の多いオペラのアリアや各種器楽のレコードを集めて、それを研究し修練してわびしいひとり居の下宿生活を慰めていた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼はそれと一緒に、ツイ四日前あの珈琲店で、彼自身と星田と村井の三人が、女給の綾子を取巻いて交換した、印象の深い会話の数々までもアリアリと思い出したのであった。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな笑い声の中にもまたアリアリとあの少女……瑠璃子のあどけない風付きを思い出すと、もうジッとしておられない気持ちになってしまった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度振り返って見ても依然としてアリアリと見えている。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈を消して静かに眼を閉じてみると、今朝からの出来事が、アリアリと眼の前に浮み上って来る。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "星明りに透かしてみると墓原らしい処は一面の竹籔となって、数百年の大｜銀杏が真黒い巨人のように切れ切れの天の河を押し上げ、本堂の屋根に生えたペンペン草、紫苑のたぐいが、下から這い上った蔦や、葛蔓とからみ合って、夜目にもアリアリと森のように茂り重なっていた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩の機嫌を窺うと同時に、自分の世間的立場を傷けまいとするような当世思想に囚われていた私の考えが、アリアリと見え透いて来たように思いました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は酒の神なるバツコスとその妻なる女神アリアドネとの姿したる人を圍みて、貸車の御者に扮したる男あまた踊り狂ふ最中なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジッと眼を閉じると間もなく、薄暗く、ダラリと垂れた鯉幟の姿が、又もアリアリと瞼の内側に現われたので、思わず頭を強く振った。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔アリア種がインドに攻め入った時、那伽種この辺に栄え、帽蛇を族霊としてその子孫と称しいた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち竜種と漢訳された民族で、ついにアリア人に服して劣等部落となった。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのインド人が昨今ややもすれば英国を嫌い、英国の学者までもドイツ人を匈奴の裔と罵り、その身に特異の悪臭あり全く英人と別種なるよう触れ散らすを見ては、学説の転変猫の眼も呆れるべく、アリア種の馬の名が、一番高尚とかいう説も、礼物の高い御札で、手軽く受けられぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がさえてしまって、電灯を消した部屋の中までが、アリアリと眸にうつって来る。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを聞いた時、舞台の上の美しい斎世宮――その時は、菅原伝授手習鑑が芸題で、染之助は斎世宮になっていたのです――のまぼろしが消えてしまってその代りにあの馬道で逢った蒼黒い、頬のすぼんだ小男の面影が、アリアリと頭の中に浮んだのです。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、その時、出方が『あの犬塚信乃さんが』とでも云ったら、私は二つ返事で会いに行ったかも、知れなかったのだけれど、染之助と云うと、直ぐ馬道であった色の蒼黒い小男の顔が、アリアリと眼の前に浮んで来て、逢う気はしなかったのですよ。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って来ると、八重桜の下で、自分達二人を、睨み付けた恐ろしい眼が、アリアリと浮んで来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は、淑やかに椅子から、身を起したとき、彼女の眉宇の間には、凄じい決心の色が、アリアリと浮んでいた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、次ぎの瞬間には青木｜淳の紫色の死顔や、今先刻見たばかりの、青木淳の弟の姿などが、アリアリと浮んで来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またまた、デッド・シアリアスになっちゃって。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう、そう思いますと一緒に、私の運命が眼の前で行き詰まりかけておりますことがアリアリとわかりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無言の二人の頬には、恐怖の色がアリアリと浮かんでいた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松子はウトウトしたかと思うと高手小手に縛り上げられて病院を引摺り出される姫草ユリ子の姿をアリアリと見たりしてゾッとして眼が醒めたという。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
