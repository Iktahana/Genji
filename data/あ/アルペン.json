        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルペンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルペンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルペンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルペンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルペンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルペンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルペンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルペンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルペンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルペンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルペンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルペンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルペンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルペンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルペンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルペンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルペンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルペンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルペンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルペンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に先生がこれはアルペン菫という花だと教えてくれた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しき国にしたしく遊びたりし時の君の想ひは如何なりしか、と云へば、美髯を一捻して主人の静かに答ふらく、然りアルノの河の畔など、伊太利の風光もさる事｜乍ら、然も我にはかの瑞西の楽天地、アルペン山の又なき神々しさを拝みたる許り嬉しき時はなかりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇みに勇める我が心も、かのアルペンを仰ぎ見たる時は、小蜘蛛の如く小さくなりて、渾身の血も凍るかと許り、口は開きたるまゝに言葉も得出でざりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて更らに幾葉の写真など取り出して、これこそはアルペンぞ、こなたの丘の上は我は半日あまりも立ちつくしたる事なり、など、云ひ／＼てその美しき国の事｜遽かに恋しくやなりけむ、暫し目を瞑ぢて、レナウが歌とおぼゆるを口吟み居たりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かちより往きてやうやう一日ほどの処なれど、はやアルペン山の近さを、唯何となく覚えて、このくもらはしき空の気色にも、胸開きて息せらる。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時アルペンおろしさと吹来て、湖水のかたに霧立ちこめ、今出でし辺をふりかへり見るに、次第々々に鼠色になりて、家の棟、木のいただきのみ一きは黒く見えたり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はモンブランに登らうと敢てしなかつたゝめに、身は滅ぼさなかつた代りに、山頂の崖に咲き匂ふアルペンの花を摘みとり得なかつた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら熱海線の長い思ひ出の中の、私にとつては得難きアルペンの花であつたような気がするのである。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行の何人もが、今日の登山者達のやるやうな服裝や準備をするのでもなく、そんな事は夢にも知らないで、たゞ絲經を身に着け、草鞋を穿いて、アルペン・ストックの代りに蝙蝠傘をついてゐるといふ不思議な行裝であつた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュツクサック、アルペンストック、靴穿きである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーはアルペン担ぎにした方が両手が自由なので都合がよい。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーはアルペン担ぎにし、両テールは紐で腰に縛り付けてぐらつかぬようにする。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを順々に追うて行くと、本館の左端と密着して建てられていて、造園倉庫という掛札のしてある、シャレイ式（瑞西（スイス）山岳地方、即ちアルペン風の様式）の洒落た積木小屋から始まっている。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖が、上河内が、アルペングリューエンに血のごとく燃え立った。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃鉄道にゆられながら、重いリュックサックを背負ったまま腰をかけて、顎の下にアルペンストックをかって、反対側の窓の中に刻々に移って行く真白な雪の山々を眺めていると、雪の山の不可抗な吸引力は、ジットしていられないほど強くなった。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおアルペンストックをスキーの杖とすることは、どうしても危険であるから金の部をとりはずせるようにするか、あるいは滑降には用いないようにせねばならない。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからアルペンシュトックをふるって、一足ごとに足形を刻まなければ登れない。",
              "citation": {
                "source": "登山の朝",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "●アルペン・グリューン（エッシネンゼー）　ヴェランダに出る。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇はもう渓を包んで、しーんとした森の上に、アルペン・グリューンの美しさ！",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場に迎いに来ていたポルティエに荷物を頼んで、もううす寒い日暮の雪路をアルペンルーエ Hotel Alpenruhe に行った、私の泊ったのは、ラウテルブルンネンに臨んだシャレーで、ストュディオのデザインにでもありそうな、小ぢんまりした感じのいい建物である。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャレーに帰って、煙草をくゆらせながらテレースに出ると、驚いたのは、今宵のアルペン・グリューンである、今述べた山々の頂は、まるで火のように真紅である、そして雪の蔭のコバルトを帯びた、その対照が実に美しい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルペン・グリューンはたちまち淡くなって、最後までほんのりと赤く見えたメョンヒが消えてしまうと、もう山は暗くなって、三つ星が、ユンクフラウの右の肩に光りはじめた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "室に入ると、窓にぱっとうつるアルペン・グリューンは、昨夕に変らず美しい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白のミュッツェと巻ゲートルはいいが、小屋で借りたネイルド・ブーツは大き過ぎて、いくら靴下を重ねてもパクパクしている始末、アルペンシュトックの方は余り短かすぎて、本当に突いてると腰が二重になりそうだった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると小屋は、忘れられたように雪の中に寂として、見渡す南の方、十里にわたる氷河は、人の生れなかった世をそのままにしんとして、彼方の空、ワリーゼル・アルペンにアーベント・グリューンが望まれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェンゲン、ウェンゲルンアルプはすぐ足もとに点在しているが、ミュルレンはすぐ下のジルベルホルンの蔭で、ただ台地につづくギンメルワルト Gimmelwald が見えるだけだ、従って数日前、ミュルレンに遊んでいた時、アルペンルーエのテレースから仰いだのは、頂上の一角に過ぎなかったのだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し何よりも眼をひくのは、ベルネルアルペンの最高峰フィンシュテラールホルンではなく、又、第二高峰四千百八十二米突のアレッチホルンでもない、オーベレス・アイスメーヤの空に高く、フリントのように雪を浴びた、彼のグロース・シュレックホルンであった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な空に、画き出された山と云う山は、悉く雪に覆われて、見取図に記されてある通り、一つ残らず数えられる、アルペンの名のある山で、今ここに記されたのが百七十ばかりある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルネル・アルペンはもうここからは随分遠い、然し地平線上にくっきりと、刻みつけられた山の輪廓は、それを覆う蒼空と、はっきり区別されて、此の間、登った山などは、明らかにそれと指さされる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
