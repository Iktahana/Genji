    "definitions": [
      {
        "index": 1,
        "gloss": "beginning of autumn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "松崎は工科出の健康な青年で秋口から東北の鉱山へ勤める就職口も定まっていた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、草は其のまゝです……近頃までに、四五｜度、越して來た人がありましたけれども、何う云ふものか住着きませんから、別に手入れもしないので、貴女のおもの好のまゝに殘つて居ます、……秋口には、去年は、龍膽も咲きましたよ。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋口に入って、僕が寝起にも自由を欠く程の有様になってから、幸子さんは泊りがけで看病に来てくれたが、併しそれと同時に、最早や単に情慾なぞと云う生やさしいものではなく、もっと執拗な純然たる復讐の形の下に、たとえ破れかぶれであろうともこの目的を果さなければならないと決心するに至った。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程然ういふ母親は、此の秋口から慢性の腎臓病に罹ツて、がツくり弱込むで來た。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に秋口になって、山々の木立に法師蝉がポツポツ啼き初める頃になると、深良屋敷の一知夫婦が揃いの晴れやかな姿で町へ出て、生れて初めての写真を撮った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一は秋口だけに、「さあ、ことだ」とベッドの中で脅えながら、何度も起き上ろうとしたが、意識が朦朧として、身体もまるで痺れているようだった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松崎は工科出の健康な青年で秋口から東北の鉱山へ勤める就職口も定まつてゐた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋口だから、川風がひえるわ」　窓の外は加茂の川原で、その向うに宮川町の青楼の灯がまだ眠っていなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏とはいっても何かしら寂しい秋口の朝の光であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ秋口の日中は暑くて、昼のうちは横になったなりに体の置き処のないようにしているが、ついうとうとして夕方になってみると、幾らか軽い気もちになっているので、縁側に円蓙を敷かして、一人でちびりちびりと酒を飲むのであった。",
              "citation": {
                "source": "庭の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに秋口といっても、旭川の日中はまだ相当暑いのですからね。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が過ぎて秋口になって来ると、やや彼の健康も回復して来た。",
              "citation": {
                "source": "赤い花",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう年は、いわゆる片降り片照りで、秋口になって雨が多いであろうという、老人たちの予言がまず当った方で、八月から九月にかけて、とかくに曇った日がつづいた。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来この東駿河地方は秋口から春にかけて吹きつくる沖の西風の極めて烈しい所で今でも大の男がまともに歩きかぬる風に出会ふことが屡々ある。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この西伊豆の海岸は、西風の吹き出す秋口から冬にかけてよく荒れがちであるのだそうだが、終に今日もその例に漏れぬ事となったのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁日は呉服橋北町お番所の面々、半日は数寄屋橋南町お番所詰めの面々が、秋口のひと月間、一日おきにこのお馬場へやって来て、朝のうちの半刻ずつ馬術を練るならわしなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋口だって恋風が吹かねえともかぎらねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十日もたちゃ霜が降りようってえいうこの薄寒い秋口に、毎晩毎晩何を着て寝ていたんでしょうね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方を屏風のやうな丘に囲まれた私達の村は、秋口から初冬へかけての南風が襲ひはじめると、どつとばかりに津波の勢ひで村外れの河口から吹きあげてくる速風は周囲の丘に行手をさへぎられて、唸りを挙げて天に沖し、壮烈な風巻を巻き起すのが常であつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まだ老朽船と云うほどでもない北海丸が、秋口の時化とは云え、何故そんなに激しい浸水に見舞われたのか、それは当の沈没船から発せられた信号によってさえも、聞きとることは出来なかった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海の常として秋口から春先へかけて、海は怒ったように暴狂い、波の静かな日は一日も無かった。",
              "citation": {
                "source": "おさなき燈台守",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の郷里の海で、秋口に捕れるものに、ままかりといふ小魚がある。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七　叔母は荒れた秋口の湯治場に、長く独りで留まっていられなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ、秋口になって、そろそろ涼風の吹く時分一景気附けましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいことをした」など、私たちは愚痴交りに話していますが、野見さんの方は、秋口というもう一つの季節を楽しみにして、ここを踏ん張ろうという肚もあるのですから、愚痴などは一つもいわず、涼風の吹いて来るのを俟っておりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しみにしていた秋口の時候に掛かって来ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　きのうきょうは秋口らしい豪雨が降りつづいた。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みのるが詰めて稽古に通ふ樣になつた時はもう冷めたい雨の降りつゞく秋口になつてゐた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の秋口のことである。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
