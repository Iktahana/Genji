        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛顧は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛顧が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛顧に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛顧が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛顧について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛顧についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛顧について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛顧が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛顧が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛顧は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛顧は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛顧を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛顧をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛顧が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛顧の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛顧を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛顧に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛顧について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛顧は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛顧を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "若い新趣味の人には食ひ足らず、古い老人には漢詩的風情がなさすぎる所から、一般に伊香保の愛顧者は温健な婦人に多い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に伊香保の愛顧者は女性に多いと言つたが、つまりその女性とはかういつたやうな、中庸的の夫人や娘たちである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又見よ、かの中央｜亜弗利加の黒奴がすなる如く、吾人の足に接吻しては礼拝幾度か低頭し、ひたすらに吾人の愛顧の衰へざらむことを憂ふるものは英吉利にあらずや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吉は紋床で謂った、鴨川はその敵で親の仇とも思う怨がある、それは渠がかねて愛顧を蒙る勝山の女お夏というのに就いたことである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも稲舟と結婚した時は両人連名で益々御愛顧を願うというような開業の引札然たる活版｜摺の通知を交友間に配った。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで予は遺憾ながら、当局並びに同僚たる文武教官各位の愛顧に反いて、とうとう大阪毎日新聞へ入社する事になった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろご愛顧くださる伊豆守様までが詮議を禁じたうえに、そのまた禁じ方なるものが、さながら尾州家において名人の出馬するのを恐るるもののごときけはいがうかがわれましたものでしたから、身分の相違、役の低さに、しみじみとこの世がはかなく思えたのはむべなりというべきでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一切金銭の心配からはなれ」息子の処女出版のために特別費を心がけている母の愛顧の下で、二十歳の彼は処女作「アンドレ・ワルテルの手記」を書いたのであった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い歳月の間、まじめな御用の時も、遊びの催しにもお身近の者として離れず侍してきて、だれよりも多く愛顧を賜わった院の、なつかしいお優しさを思うと、無礼な者としてお憎しみを受けることになっては、自分は御前で顔の向けようもない。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の兄の中将が、「公務で忙しくしているうちに、姫君の愛顧を侍従に独占されてしまったのはつまらないね」　と言うと、次の兄の右中弁が、「弁官はまた特別に御用が多いから、忠誠ぶりを見ていただけないからといっても、少しは斟酌していただかないでは」　と言う。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで予は遺憾ながら、当局並びに同僚たる文武教官各位の愛顧に反いて、とうとう大阪毎日新聞へ入社する事になつた。",
              "citation": {
                "source": "入社の辞",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めて独立した茶室を建てたのは千宗易、すなわち後に利休という名で普通に知られている大宗匠で、彼は十六世紀｜太閤秀吉の愛顧をこうむり、茶の湯の儀式を定めてこれを完成の域に達せしめた。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引立てを蒙る、御愛顧を願う、という文句は米屋か仕立屋の広告文では最早やないのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家は常に各展覧会において特別の御引立てと御愛顧を蒙らなければならないがために、年末年始、暑中は勿論、かなりのはがきさえも用意せねばならない時代である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "中元御祝儀と暑中見舞と、相変りませず御愛顧を願わなければ全く以て、食って行けない時代であるかも知れない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引立てを蒙る、御愛顧を願う、と云う文句は米屋か仕立屋の広告文で最早や無いのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家は常に各展覧会に於て特別のお引立てと御愛顧を蒙らなければならないが為めに、年末年始、暑中は勿論、かなりのはがきさえも用意せねばならない時代である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君の確信する所によれば、古今の才人は一人残らず諸君の愛顧を辱うしてゐる。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに僕は諸君の愛顧を辱うする光栄を得なかつた湖州の薄命を弔はなければならぬ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "父家橘の愛顧者は、少し胸を撫でおろし、あらためて新家橘を守り立てようと云ふ念を固めたことであらう。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の愛顧者も、彼を越して菊五郎を見ることが屡であつたらう。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は是から遠方へ参りますが、何卒従前の通り御見捨なく御愛顧の程を願ひます。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれから遠方へ参りますが、なにとぞ従前の通りお見捨てなくご愛顧のほどを願います。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "長らくの間御愛顧に相成りました段は深くお礼を申上げます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅の長政が人質の時、政所の愛顧を蒙つた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オデン屋のオヤヂは文学青年でその作家とは個人的に親しくその愛顧に対して恩義を感じてゐた。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅の長政が人質の時、政所の愛顧を蒙つた、石田三成が淀君党で、之に対する政所派といふ大名があり、長政などは政所派の重鎮、さういふ深い縁があるから、政所の手を通して執念深く願ひでる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　初七日から四十九日までのオツトメの日には代理の高徳をさしむけてホトケの冥福を祈ってもらったが、ホトケには特別の愛顧をうけ、またはしなくもその臨終に立ち会った因縁もあるしするから、代理まかせにしておくだけでは気持がすまなかった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御愛顧の大恩もあり、また浅からぬ因縁もあるホトケの法要にオツトメにも参じませず心苦しくは存じておりましたが、重ねて不調法をはたらいてはと心痛いたしましてな。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男　　さあいこうよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
