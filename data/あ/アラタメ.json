[
  {
    "uuid": "84f6cd4d-c52c-53a4-83f0-6c4ebda36b5a",
    "entry": "改め",
    "reading": {
      "primary": "あらため",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "former (e.g. name)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日改めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「さあこれから、俺はこれを改めなくちや……」　だが今迄のやうに、自分のすることは直ちに郡視学の耳に入り、県視学に聞達するやうなことは、都会ではあるし、それに私立中学のことだからないだらうと思はれた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や蕪村の俳句は、改めてまた鑑賞され、新しくまた再批判されねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日本の上田秋成が飜譯して、題も夢應の鯉魚と改め、雨月物語卷の二に收録しました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、多少口調を改めて、そんなことを家内に教へた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお鈴さんは口調を改めて言ひ、「せめて、雀の里のお土産のおしるしに、この葛籠のうちどれでもお氣に召したものをお邪魔でございませうが、お持ち歸り下さいまし。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを出立点として、改めて稿を次ぐ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし富士山の位置を、北アルプスに移し換えて、その痩削的の山容を改めたらば、あるいはどういう雪の結果を齎らしたか、予め知り難いのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中高山植物の美麗は熱帯の壮大華麗なる花を凌ぐのであるが、高山植物の美観は他日題を改めて説くつもりである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺の火は燃え出した、その明るくなることは、花が発くのと同じで、万象の色が真の瞬間に改まる、槍と穂高と、兀々した巉岩が、先ず浄い天火に洗われて容を改めた、自分の踏んでいる脚の下の石楠花や偃松や、白樺の稚いのが、今眠から醒めたというように朝風に身振いしてソヨソヨと顫った、天地皆新しい。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて）　吉田は、そう考えることによって、何かのいい方法を――今までにもう幾度か最後の手段に出た方がいい、と考えたにも拘らず、改めて又、――いい方法を、と、それが汗の中にでもあるように汗みどろになって、全速力で考え初めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は照れるようなこともなく言葉もそう改めず、この旅でも、ただ身のまわりの世話ぐらいは少し遠慮を除けてしてあげるぐらいなものであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も何かしら書きたいことがあって筆を取ったはずであったが、思うことがなかなか思うように書けないので、途中で打切ってさて何遍となく行を改めて更に書出してみても、やはりうまく書けない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを治療するにはやはり余裕のある人を模倣する事によって習性を改める外はない」と論じている。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして今此遺著を読んで見ると、改めて石川君に逢着したやうな気がする。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の「怒」の類の仮名で書かれている「野」「角」「偲」「篠」「楽」などの諸語は、『万葉集』の訓でも古くは「の」「つの」「しのぶ」「しの」「たのし」と読んでいたのですが、江戸時代の国学者が「ぬ」「つぬ」「しぬぶ」「しぬ」「たぬし」と改めたものです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれらの語については、まだ他に多少問題になる点もあり、また、古典語として「ぬ」「つぬ」「しぬぶ」など読むこともかなり久しい慣例となっていますから、現代の読み方としては必ずしも改めなければならないこともないかも知れませんが、理論上は右のようになると思われるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前回はかなり手を加えたが、今回は誤字を訂正したほかは、二、三の不適当な語句や用字法を改めたのみである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君はそういう魂のないものを我慢して画く事の出来ぬ性の人であるから、たとえ幾枚画き改めたところで遂に「仕上げ」の出来る気遣いはないのであろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と僕が改めて質問したのは、彼が金澤の舊家である古寺から、煤で黒くなつたまひら戸を引きずり出し、玄關や茶座敷の戸にしたのを見た時であつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この發見をしてから後、改めて僕は芥川龍之介の全貌を追懷した。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君の弟子になり、改めて始めから詩を學ばうと決心した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで改めて恩地孝氏にたのんで著者のために田中氏の遺志を次いでもらふことにしたのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほくそ笑んで中味を改めようとしてギクリとなった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳兵衛が、Ｔ「では改めて」　と言って、Ｔ「その刀わしが買います」　二人顔見合わせた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚の花　（藤澤桓夫氏）　この作家の從來の作品に於て、これまで私にネガテイヴな價値しか持つてゐなかつたものは、この作品によつてポヂテイヴなものに改められた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今改めて御禮申します。",
              "citation": {
                "source": "編輯後記（大正十五年三月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字書き、一行進めては氣に入らなくなり、不滿になり、厭やになつたりして、私は幾度か原稿紙を引き裂き、幾度か書き出しの稿を改めずにはゐられなかつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして語氣を改めて、「一體實社會を離れて、信仰生活だけに沒頭することが人としての道に適ふのでせうか。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その精神とはどんなものか、それについては章を改めて述べてみたいと思う。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
