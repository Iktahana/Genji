        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "明らかに芸術にとつてそれから恐らく人間性にとつても不幸な世の中なのであらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなそれぞれ理由のある所であらうが、原因はいざ知らず、見渡した所感情が喪失されてある状態であること明らかであるやうである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が此處まで考へてきた時、始めてあの鵠沼における悲壯な會話が、言語の隅々まで明らかに解つてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来難解の句と称されているが、この句のイメージが表象している出所は、明らかに大阪のいろは骨牌であると思う。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕につけた片方の耳の奥では、動脈の漲る音が高く明らかに鳴っている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきのことばと言へ、今の笑ひ声と言ひ明らかに自分を侮辱してると彼は一途に思ひつめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸はいま明らかに、このおそるべき錯誤を犯してゐるのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明らかなれば冬の夜を我は嘆かず人々の憔懆のみの愁しみや憧れに引廻される女等の鼻唄をわが瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福は、休んでゐるそして明らかになすべきことを少しづつ持ち、幸福は、理解に富んでゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一評者が「一時は紀行文は前人の未だ踏まない深山幽谷の奇景を、紹介するのを職とするような傾向であった、いや今でも、そういう好奇心で、紀行を書いている人もあるようだが、これはつまらぬことだろう」と言って、明らかに私に当たっている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "責任を明らかにしたのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的知識の進歩した結果として、科学的根拠の明らかでない云い伝えは大概他の宗教的迷信と同格に取扱われて、少なくも本当の意味での知識的階級の人からは斥けられてしまった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根拠の無い事を肯定するのが迷信ならば、否定すべき反証の明らかでない命題を否定するのは、少なくも軽率とは云われよう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと云ってこれらの関係を本式に研究するのはなかなか容易ならぬ難事業で、多数の専門家が永い年月を費やして始めていくらかでも明らかにし得る性質のものであろうと思われる。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の少しばかり調べてみた結果では、昨年の颱風の場合には、同時に満洲の方から現われた二つの副低気圧と南方から進んで来た主要颱風との相互作用がこの颱風の勢力増大に参与したように見えるのであるが、不幸にして満洲方面の観測点が僅少であるためにそれらの関係を明らかにすることが出来ないのは遺憾である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に四十八手を分析したら槓杆の原理のみならずあらゆる力学上の原理の応用が見つかるに相違ない、例えば体量の少ない力士が大きい敵手にぶつかる場合には速度の大小でどれだけの効果があるかという事あるいは敵の運動量を利用して強敵を倒す事など物好きな学者の研究によって明らかになりそうな事である。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲が特有の国技である以上はどうか我国の学者の研究によって四十八手の力学を明らかにしたいものだ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそうだ、向うの崖の黒いのはあれだ、明らかにあの黒曜石の dyke だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、この泥岩は、粘土と火山灰とまじったもので、しかもその大部分は静かな水の中で沈んだものなことは明らかでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせまた水が出れば火山灰の層が剥げて、新らしい足あとの出るのはたしかでしたし、今のは構わないでおいてもすぐ壊れることが明らかでしたから。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の構造を明らかにする前に我々はこれらの先決問題に答えなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、或る民族の特殊の存在様態が核心的のものとして意味および言語の形で自己を開示しているのに、他の民族は同様の体験を核心的のものとして有せざるがために、その意味および言語を明らかに欠く場合がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで第二の課題として、類似の諸意味とこの意味との区別を外延的に明らかにしてこの意味に明晰を与えることを計らねばならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、これらの語はその基礎附けられている公共圏内にあっては明らかに価値判断を担っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、「あまっちょ」「甘ったるい物の言い方」「甘い文学」などいう場合には、甘味によって明らかに反価値性が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "……足と脛とは拍子の主調を明らかにし、かつ保つ役をする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、意味体験と概念的認識との間に不可通約的な不尽性の存することを明らかに意識しつつ、しかもなお論理的言表の現勢化を「課題」として「無窮」に追跡するところに、まさに学の意義は存するのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族的存在の解釈としての「いき」の研究は、「いき」の民族的特殊性を明らかにするに当って、たまたま西洋芸術の形式のうちにも「いき」が存在するというような発見によって惑わされてはならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、つひに、中國がその自らの獨立國としての存立を危くしてゐるのは、決して中國人たちの肉體の病氣の故ではなくして、あきらかに精神の病ひのせゐである、すなはち、理想喪失といふ怠惰にして倨傲の恐るべき精神の疾病の瀰漫に據るのであるといふ明確の結論を得るに到ります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
