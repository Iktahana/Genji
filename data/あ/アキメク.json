        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暑いとはいつても、朝晩は秋を感じる、一雨来たらめつきり秋めくだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "南晴るゝ　上野の山山の肌　なべて秋めく草の葉のさえ／″＼しきに、さびしまむとす碓氷嶺の　峠の町をいでゆきて、いち早かりし戦死者を　とふ盆すぎの山にのぼり来て、戦死者の家をおとなふ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑さ短き日と　なりにけり昼深く　秋めく風や。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天候がしずまるともうすっかり秋めくことでしょうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河一　初袷を着、風も秋めくと、毎日のように、江戸のどこかしらで、笛太鼓の音の聞えない日はない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を大きく見ひらいているのに、手さぐりでそんなことをしているところをみると、あきめくらなのだろう。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少女は、あきめくらであるばかりでなく、気がくるっているのだろう。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君は、そこにいる白い少女が、あきめくらでも気ちがいでもないことがわかったけれど、でもなんとなくきみがわるくて、しぜんに、目や耳は少女の方にひきつけられた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきめくら共めがッ、この眉間の三日月形が分らぬかッ」「………?!」「よよッ」「………！",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきめくら共めがッ、この眉間の三日月形が分らぬかッ」「………※」「よよッ」「………！",
              "citation": {
                "source": "旗本退屈男",
                "author": "第二話　続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのようなあきめくらがのぞいたっても、犬が星をみるようなものなんだから、尾っぽを巻いておとなしくかしこまってな」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきめくらとはなんですかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大自然のあきめくら、見くびつてくれるな、人間には備はつてゐる、刹那に永遠を見通す目、それから、上下左右へ即座に方向転移の出来る飛躍自在の魂。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともあきめくらで、子供も人並に育てることはできない。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
