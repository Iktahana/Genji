        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新宿で好きなのは、あの淀橋から煙草工場の方へ出る青梅街道の通である。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日の侘しく散らばふ青梅街道。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青梅街道を志して自分で地図を見ながら、地理を知らぬ運転手を案内して進行したが、どこまで行ってもなかなか田舎らしい田舎へ出られないのに驚いた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の畑で芋を掘上げている農夫に聞いて、見失った青梅への道を拾い上げることが出来た。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに青梅を出て間もなく二度までも巡査に呼止められて検査札を見届けられた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ばたの青梅を十個ばかり盗んできて（捨てゝあるのだから、むしろ拾うてきて）漬ける、果して焼酎漬が出来るか知ら。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に実っている青梅は、妊婦のように見逃さず※いで噛んだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青梅もまだ苦い頃、やがて、李でも色づかぬ中は、実際｜苺と聞けば、小蕪のように干乾びた青い葉を束ねて売る、黄色な実だ、と思っている、こうした雪国では、蒼空の下に、白い日で暖く蒸す茱萸の実の、枝も撓々な処など、大人さえ、火の燃ゆるがごとく目に着くのである。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（小丼に入れた、青梅の紫蘇巻じゃ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこにて、腹や傷めむと叱らるゝ老母の目を盗んでは、潜かに庭の青梅｜竿に落して心を洗ふ様なる其味を賞せし事は叶はずなりたれど、わが幸福の増しこそはすれ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段を駆けて上って、境内にちらほらとある、青梅の中を、裳はらはらでお君が潜って。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏、青梅、李など、幼き時は欲しきものよ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘の島田に結っている鬢付きから襟元から、四入り青梅の単衣をきている後ろ姿までがかれと寸分も違わないので、西岡はすこし不思議に思った。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この沿線の風景は武藏の立川驛から青梅に向ふ青梅線のそれに實によく似てゐた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐川流域の平原が次第につまつて來た奧に在る附近一帶の主都らしく、さうした位置もまた武藏の青梅によく似てゐた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋の樣子は高さから何から青梅の萬年橋に似て居り、鮎を名物とするところもまた同所と似て居る。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "武藏の青梅は私の好きな古びた町であつた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝はコンピューターやワープロの開発、製造を青梅工場に集約しているが、徹底してコンピューターによる自動化を推し進めたこの工場のマスコミ向け見学ツアーが催されたのが一九八九年の十二月四日。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあの懐かしきＰＡＳＯＰＩＡがマシンの温度テスト用恒温槽で今もけなげに働いているのを発見したり、基本ソフトの開発部門にＮｅＸＴのキューブが転がっているのを見つけたりと青梅工場見学ツアーを存分に満喫しているうちに、またまた、次なる疑問がむくむくと湧いてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのオレは東芝の青梅工場に潜入してアラン・ケイが「Congratulations !!」と記したダイナブックを発見し、「その祝福の言葉に込められた真実は」との問いに、深く思いを致してしまったというところまで前回は行った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "四入り青梅の片袖で、潮水にぬれては居りますが、色合いも縞柄も確かに相違ございません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を飛び出した時にはどんな物を着ていたかと訊くと、四入り青梅の単衣でこうこういう縞柄だという。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、ここは青梅街道の入口で、新宿の追分から角筈、柏木、成子、淀橋という道順になるんですが、昔もなかなか賑やかな土地で、近在の江戸と云われた位でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは青梅線の鉄道によりて所沢に至り、それより飯能を過ぎ、白子より坂石に至るの路なり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内にては、湯島天神、芝公園、深川公園などにも梅林あるが、關東にては、青梅在の吉野村の梅を見ずんば、梅を説くの資格なかるべし。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "國分寺驛より青梅線に乘換ふれば、梅之に代りて、驛々みな梅花なきは無し。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『青梅驛に下り、萬年橋を渡りて、ぽつ／＼散在せる梅を探りつゝ、吉野村中最も梅花の多き下村に至り、日向和田驛より汽車に乘るが順路なり』といふまゝに、青梅驛に下る。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "青梅はまた山間の市街也。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
