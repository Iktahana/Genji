    "definitions": [
      {
        "index": 1,
        "gloss": "Arabian (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アラビア人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアラビア人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアラビア人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアラビア人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアラビア人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアラビア人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアラビア人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアラビア人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアラビア人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアラビア人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアラビア人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアラビア人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アラビア人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアラビア人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで、焙り出されかけた家の子供等は、「水」と云ふものに、原始アラビア人が覚えた程も、驚異と礼讚の念を抱くやうになつたのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にあのアラビア人のような名前のついた一団の自由自在に跳躍する翻筋斗の一景などは見るだけで老人を若返らせるようなものである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの一室で人が対話していると、窓越しに見える遠見の屋上でアラビア人のアルラーにささげる祈りの歌が聞こえる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ですからこの五人のほかの七人の同志は皆、トルコ人や、アラビア人……思い切った奴は黒ん坊に化けて、かの方面の有利な天産と、その天産物に涎を流して働きかけている白人連中の勢力を探っていたんです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビア人の馬方が道のまん中に突っ立った驢馬をひき寄せようとするがなかなかいこじに言うことを聞かない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを彼の「モロッコ」の冒頭に出て来るアラビア人と驢馬のシーンに比べるとおもしろい。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはこの案内者の見かけが平凡でそこらにざらにある雑種のアラビア人とちっとも違わないし、その上相当に狡くもあったのでただ出鱈目をいう言葉のなかに聞き流した。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベドゥインと言ふのは、アラビヤやシリア地方にある、アラビア人の遊牧民で、さういふ土人は、羊を飼つて、草地のあるところを移りあるいてくらしてゐるのですから、村と言つても、たゞ、見すぼらしいテント見たいなものゝほかには家らしい家もありません。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウ※ルターは例の片腕を切り落された貴い愛国の勇士を、やはり、じぶんだとは言はず、どこまでも、或知合ひの、遊牧民上りのアラビア人としてかき続けてゐるのでした。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの片腕のアラビア人は赤痢のためにおとろへつくした、敗残のからだを引きずつて、とう／＼アデンの町までたどり着きました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、やはりアラビア人の石炭人夫を使ふ外はないと、最後に一人が言ひました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、傲然と、河岸のアラビア人の家をたゝきおこし、トルコ軍の火薬庫へ重要貨物をはこぶについて、数人の人夫がいる、すぐにそろへ集めろと命令しました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラビア人の遊牧民は、これでつくすべき仕事をしとげました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たび／＼言つたとほり、これまでウ※ルターは、すべて自分といふものを秘めかくし、このはじめからのすべてを、彼自身にそつくりそのまゝの、或遊牧民上りのアラビア人の乞食の行動として、報告してゐるのでした。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二週間前に、丁度一人のアラビア人の婦人が、その夫だといふ英人の一患者を、当病院につれて来ました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、アラビア人としては容貌のよい、品位ある女で、夫には命をもかけて、尽してゐたらしく、今度も、七十マイル以上のところから、はる／″＼つれて来たのです。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビア人マスージー等の書に見る海蛇（『聖書』の竜と同根）は、その記載旋風が海水を捲き上ぐる顕象たる事明白で、それをわが国でも竜巻といい、八雲立の立つ同様下から立ち上るから竜をタツと訓み、すなわち旋風や竜巻を竜といったと誰かから聞いた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに回教を奉ずるアラビア人は、無毒の蛇を捕え頭を去り体を小片に切り串に貫き、火の上に旋しながらレモンや塩や胡椒等を振り掛け食う。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またバートンは北米のインジアンが沙漠中に天幕と馬に資りて生活するよりアラビア人と同似の世態を発生した由を述べた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビア人など駿馬が悪鬼や人の羨み見る眼毒に中らるるを恐るる事甚だしく、種々の物を佩びしめてこれを避く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーノー仏訳、九世紀のアラビア人、ソリマンの『支那記』四一頁にいわく、支那には市ごとに知事の頭の上に鐘を釣るしてダラー（銅鑼？",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーノー注に、十二世紀のアラビア人エドリシの『世界探究記』に拠れば、昔｜北京の帝の宮殿近く太鼓の間あり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚屋大声を揚げて啌つきの牝犬め、わが夫は十年来離さず犬の皮のパッチを穿いているが、彼処は肉荳き、リチャード・バートンはアラビア人が小唇の黒きを貴ぶ由をいった（一八九四年版『千一夜譚』注）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代エジプトに於ては紫と黒の二色が尊ばれ、織物の染色と共に、主として僧侶の手によって寺院内で行われたのであるが、後にアラビア人が埃及を占領するに及んで、金属の染色だけでは満足せず、卑金を黄金に変化せしめる術を錬金術と呼ぶに至ったのである。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの方の男は、退職大尉と呼ばれた人物で、年は四十がらみ、みっともないほどのアバタ面で、アラビア人みたいに髪の毛が縮れて、猫背で、がに股で、肩章のない軍服を着て、胸のボタンをはずしている。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニグロやカフィール族（Kaffer）の黒人やアラビア人はこの種の伝説を知らないのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビア人は太陰（ワッド Wadd ホバル Hobal またはハウバス Haubas）を父として、太陽（シャムシュ Shamsh）を母、また金星（アッタール Atthar）をその子として礼拝した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともアラビア人らは、後に彼らの文化が洗練されるようになってからは、科学に対する趣味を生じ、そうして特にアレキサンドリア学派の著述、もちろん断片のようなものではあったが、それを収集するようになった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアラビア人一般の心情は、元来異教に対して容赦のなかった僧侶らのために大分違った方へ導かれていたために、決して科学向きにはなっていなかった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
