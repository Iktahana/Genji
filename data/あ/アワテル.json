[
  {
    "uuid": "45ac96e3-d96b-5655-8bcc-6d1223c81e98",
    "entry": "慌てる",
    "reading": {
      "primary": "あわてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become confused (disconcerted, disorganized, disorganised)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日慌てるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "慌てるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は慌てるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には慌てるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "慌てるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは慌てるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "慌てるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は慌てるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では慌てるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "慌てるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に慌てるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では慌てるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "慌てるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると慌てるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "慌てるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では慌てるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に慌てるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により慌てるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "慌てるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に慌てるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "慌てるやうに蠅打を手放すと、「彼奴は……」と再び両手で額を支へて考へ込んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には何か云つた後で、「さう、なくちや――なくちやならぬ」と慌てるやうに附加す癖があつたが、殊に修身の時間にはそれが頻々として出された。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでも人間の十人や百人呑んだところで、慌てると云ふ風な河ではなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お半さん、鶴さんが来たよ」Ｓ＝二階　その声に石松慌てる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎懐中を探したが無いので少し慌てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいは別に慌てることもなく、すなおな気持で立ち上って迎いに出ようとしたが、部屋の出口の柱に、母とおぬいとの襷がかけてあるのを見ると、派手な色合いの自分の襷を素早くはずして袂の中にしまいこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は困っとるよ……」　と父は膝のまわりを尋ねまわして、別々になっている煙草入と煙管とを拾い上げると、慌てるようにして煙草をつめたが、吸うかと思うと火もつけずに、溜息とともにそれを畳の上に戻してしまった、おせいはおずおず父の顔を窺った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも廊下を蹈鳴して、得三の帰る様子に、かの男少し慌てる色ありしが、人形を傍へずらして柱に寄せ、被は取れて顔も形もあからさまなる、下枝を人形の跡へ突立せ、「声を立てるな。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛倒して慌てるほど、身体のおしに重みがかかる、とその度に、ぐ、ぐ、と泣いて、口から垂々と血を吐くのが、咽喉に懸り、胸を染め、乳の下を颯と流れて、仁右衛門の蹠に生暖う垂れかかる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おお吃驚した……慌てるわねえ、お前さんは。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此うなると、狼狽る、慌てる、確に半分は夢中になツて、躓くやら轉ぶやらといふ鹽梅で、たゞ妄と先を急いだが、さて何うしても村道へ出ない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てるとよけいはまらない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更慌てる事はないさ、はじめから知れていら。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訊くから、そういうのが、慌てる銃猟家だの、魔のさした猟師に、峰越しの笹原から狙い撃ちに二つ弾丸を食らうんです。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てる紋は泡沫のよう。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と判事も屹と目を瞠ったが、この人々はその意気において、五という数が、百となって、円とあるのに慌てるような風ではない。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎ァ気がせく、蟹ァ慌てるし、早く早くと客ァ詰めこむし。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角が、方角が違ったぞ、と慌てる処へ、おっぱいが飲みたい、とあびせたのがあります。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが気を鎮めて窺っていれば、大抵の見当は付く筈だのに、みんなびくびくして慌てるからいけねえのだ」「まったくお前さんの云う通り、そんなに遠いところから呼ぶのじゃああるめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水飮ませて見ろ」彼は慌てるといふことを知らぬものゝ如く一｜言いつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川博士は気のゆつたりした人で、何事があつても驚くの慌てるのといふことはない。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぐなかれ、慌てるなかれ、神を待ち望め、静に待望せよ、これ暗中に処する唯一の健全なる道である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい慌てたものだから……」「何をそんなに慌てるのさ」「落付れる訳のものではないよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校から家までかなりの道程を、夢中になつて駆けて来た清一は、息が切れて、おまけに少し慌てると、吃る癖のある彼は、容易に言葉が続けられなかつた。",
              "citation": {
                "source": "清一の写生旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「慌てることはないよ。",
              "citation": {
                "source": "清一の写生旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てるばかりが能ではなかろうぞ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事が夜通しに二三度もありましたが、傍に居る人々は何の事やら訳が解からずに、唯驚き慌てるばかりでした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慌てるない――それでも大声をあげて騒がれるのは恥だとおもふ位ゐの、良心はあるのか、偽善者の倅！",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が、屋根裏の寝室へ引きあげようとすると、久良は弁当をつくり終るまで待つて呉れと慌てるのであつた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは、あわてればあわてるほど、へまなことしか言えないものなのだろうか。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
