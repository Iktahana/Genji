        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ご愛息の健やかなご成長を、心よりお祈り申し上げます」と、祝辞を締めくくった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "亡き愛息の遺志を継ぎ、彼は私財を投じて地域の少年野球チームを支援し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ご愛息、この春から名門校に通われるそうですね。本当におめでとうございます」と、近所の方から声をかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "創業者は、海外で経営学を学んだ愛息を次期社長に据えることを株主総会で発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自慢の愛息が描いた絵が県展で特選に選ばれ、父親は目を細めてその作品を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『愛息の不祥事は私の監督不届きです』と、議員は記者会見で深く頭を下げた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の大学へ進学する愛息の荷造りを手伝いながら、母親は誇らしさと寂しさが入り混じった表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鈍栗庵の愛息が自転車で栗飯を持つて来てくれる、さつそく御馳走になる、感謝々々。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの時、ロス夫人は、来らんとする夏を逃げて、早くも田舎の別荘へ避暑に行っていたが、この問題の一日の夕方、ロス氏が、市の中心にある自分の会社から帰って来ると、二人の愛息に付けてある若い保母が、玄関に立って、主人の帰宅を待ちながら泣いていた。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こうして突然フィラデルフィアの富豪ロス氏の家からいなくなった、三つになるこの愛息 Charlie Ross ほど、そしてそれを序曲として開幕されたあの劇的場面の連続ほど、奇怪な特異性に富む事実物語はまたとないであろう。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、奇しきめぐりあいをとげた愛息隆夫のうつろな霊魂をみちびきながら、ようやくこれまで登ってきたのである。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人息子でも、可愛息子でも、云い聞かされた「国家の為」だ、出せとあったら出さねばならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、邦子さんの愛息悦氏の依囑で、これらの文反古と呼ばれるにはあまりに美しい斷簡を編纂した時、特に私の住んでゐる眞間にゆかりの深いこの一通を所望した。",
              "citation": {
                "source": "緑雨と一葉",
                "author": "伊庭心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛息の徐廷権は拳闘家として知れていると言う。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
