        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「あゝ、おめでたいね、お客さまが濟むと、毎年ね、お前がたも夜あかしで遊ぶんだよ。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんさくだの、かしわの葉、あかしで、いぬしで、いぼた、白い花の咲くがまずみ、うつぎ、赤い花の咲くはこねうつぎ、模様のようなやまにしきぎ、そんな名前を一つ一つていねいにおしえて下さいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は夜あかしでお月見しませうよ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その血は私の胸にもとびかゝつたが、まるで大きな噴水の柱にたゝかれたやうに強くて重い力がこもり、私はそれが彼の愛情のすべてのあかしであるやうな、なつかしさに激動した。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすべて女帝が与へた愛情のあかしであつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その種あかしですか？",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出発地点である忍谷では、夜あかしで準備がととのえられた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にあそこだ…………（本を取り上げて読む）すべて、見える世界から見えない世界へ還つたもの、すべて思ひ出に変つたもの、今はもう、跡形もないあかしでの並樹が、われわれの心に、今もなほ影を落とす…………プルウスト　　読むのはよしてくれ。",
              "citation": {
                "source": "序文",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、ずっと夜あかしで、それに、気を張りづめだったから、さすがに疲労をおぼえて、これから駕籠に揺られて帰る気はない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは間違ひない誓ひのあかしであるのであります。",
              "citation": {
                "source": "ザボンの実る木のもとに",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中になって夜あかしで釣って、舟がイカの重みで沈んだという話もある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの繁華な名古屋駅前に、釣り餌専門の店が何軒もあって、夜あかしで店をあけている。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすべて女帝が与えた愛情のあかしであった。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗がやうやく足もとを見透かされ初めたあかしである。",
              "citation": {
                "source": "天狗塚",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奉納の舞のなかばに、篝火の中へ落ちて来た、これこそ恵林寺さまの御霊が、挙兵のときをお告げになるあかしです、この……」　とつぜん、彼女の声がとぎれ、ひきつるようなその顔を、こちらへ、半之助の隠れているほうへと、ふり向けた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月四日（土曜）　喜多村緑郎・英太郎に山田伸吉・僕といふメムバーで、つひに夜あかしである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハハ……、これがインド人の魔術の種あかしです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　じつに、はっきりした種あかしでした。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
