        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お父さんという人は下町の商人気質の堅い一方なところへ、阿母さんは読書の趣味もあるし、昔の江戸ッ児風の教養や趣味があるもんで、清川兄弟が文学へ進むことにも共鳴があるわけなの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いの関係から云えば、主婦たちが迅速に計画的にそういう方策を立てて行動してゆく実際の力によって商人の従来の商人気質も脱皮されて行く訳だろう。",
              "citation": {
                "source": "主婦意識の転換",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人は商人気質の鋭さ万能に、家を守る女性は、何はともあれ我家のやりくり専一に、それぞれ主観の利益に立った個々の生きかたを続けて来たところへ、今日は一方から謂わば純理的な方針が与えられ、しかもその純理的な算数の根本には、まだ従来の生産の形式がそのままでいるという複雑さである。",
              "citation": {
                "source": "主婦意識の転換",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもしかし当時の商人気質を代表した人物であった。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく日本文学にとつては、大阪の商人気質、実質主義のオッチョコチョイが必要なのだ。",
              "citation": {
                "source": "大阪の反逆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな書籍を並べて置いたって、売ると成れば紙屑の値段だ」――こう言うほど商人気質の父ではあったが、しかし三吉はこの老人の豪健な気象を認めずにはいられなかった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく日本文学にとっては、大阪の商人気質、実質主義のオッチョコチョイが必要なのだ。",
              "citation": {
                "source": "大阪の反逆",
                "author": "――織田作之助の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰がふんでも、一人前の、商人気質である。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
