[
  {
    "uuid": "436860c8-18a1-5a90-a1ac-e2e96c113023",
    "entry": "愛楽",
    "reading": {
      "primary": "あいぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seeking after (Buddhist teachings, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幼少より仏道を愛楽し、世俗の栄華を顧みることなく山中での修行に明け暮れた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "師が説く深遠な法を深く愛楽し、その一言一句を漏らさぬよう熱心に聴聞する。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「正法を愛楽する心があれば、険しい悟りへの道も自ずと開けるでしょう」と老僧は語った。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経典に記された真理を愛楽するあまり、彼は家財をすべて擲って入道の決意を固めた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "俗世の執着を断ち切り、静寂な草庵で経を読み仏を念ずる生活をひたすらに愛楽する。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "女人に愛楽を生じたためしは、古今の聖者にも稀ではない。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女人に愛楽を生ずるのは、五根の欲を放つだけの事じゃ。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ああうたて、恋も、まことも、愛楽も蒼蠅羽ならし飛びめぐる腐肉にまとふ温気のみ。",
              "citation": {
                "source": "ねたみ",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくも言語と異なるときは、これを読んで喜怒愛楽の情、感動することなし。",
              "citation": {
                "source": "平仮名の説",
                "author": "清水卯三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜怒愛楽の情、感動することなきときは、教化、訓導の意を失す。",
              "citation": {
                "source": "平仮名の説",
                "author": "清水卯三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "loving",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は仏法を深く愛楽し、日々の読経と座禅を欠かすことはなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "富や名声といった世俗の栄華を愛楽する心は、仏教において迷いの根源とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "自然の風物を愛楽し、それを詩歌に詠み込むのが当時の文人たちの嗜みであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "現世への愛楽を断ち切り、彼は剃髪して厳しい修行の道に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古くからこの地方の町衆には、能楽や茶の湯を愛楽する文化が深く根付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "過酷な修行の日々の中にあっても、彼の心には常に悟りへの愛楽があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
