[
  {
    "uuid": "1e94dfc3-4c83-5ab0-85d0-efbb2842b514",
    "entry": "愛犬",
    "reading": {
      "primary": "あいけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pet dog",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛犬は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛犬が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛犬に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛犬が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛犬について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛犬についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛犬について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛犬が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛犬が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛犬は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛犬は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛犬を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛犬をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛犬が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛犬の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛犬を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛犬に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛犬について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛犬は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛犬を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いまでは横田はヤンキーの女達が過去スペインの愛犬に恋慕したように、無謀な愛情ときわどい婦人社会の教養をうけて裸体で近東風な機械体操や、スパルタ風の腕力を発揮したり、恐らくあの毛むくじゃらの胸を、つき出して、サロンを物好きな流行女の号令によって、自由自在に這い廻っていることだろう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時バードの愛犬が主人に飛びつこう飛びつこうとするのだが人々にさえぎられて近寄れず不平でむやみに駆け回っているがだれも問題にしてくれない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの可憐なる日出雄少年は、今は我が敬愛する櫻木海軍大佐閣下と共に朝日島に元氣よく、今頃は屹度、例の可愛らしい樣子で、水兵共や、愛犬の稻妻なんかと、海岸の岩の上から、遙かに日本の空を眺めて、早く孤島を出發して、一日も速かに貴方等に再會したいと待望んで居る事でせう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、愛犬を路傍に捨てては置かれぬので、市郎は血に染みたるトムの死骸を抱えて起った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬の骨を敵に渡すのは、何だか口惜い様にも思われるので、市郎は到頭トムを抱えて帰った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬は権右衛門にかみつこうとした。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとしの夏、三郎は隣家の愛犬を殺した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがわたしの愛犬にして、しかも忠犬なる、ナハトであります。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬の蚤を一匹残さずとるよう命じたことさえあった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "我がリヒヤード・ワグネルも亦、愛妻ミンナと愛犬ルツスを率ゐ、飄然として祖国を去つて巴里に入るや、淋しき冷たき陋巷の客舎にありて具さに衣食の為めに労苦を嘗めぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬倶楽部の書記助手。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三世紀の初めウェールスのルエリン公、その愛犬ゲラートをして自身不在ごとにその幼児を守らしめたが、一日外出して帰って見ると揺籃に児見えず。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『淵鑑類函』四三六には、宋の太宗の愛犬、帝朝に坐するごとに必ずまず尾を掉って吠えて人を静めた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またデルフトに、蘭王ウィルヘルム一世の碑ありてその愛犬像を碑下に置く。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方先生｜件の名歌を訳するに苦しみ、かれこれ思い廻らす内、また見付かったから犬寺の話に再追加するは、インドのマーラッタ王サホは五十年という長い間在位して、一七四八年にわれ掛かる処を救うた愛犬を埋めた場所という（バルフォールの『印度事彙』三版三巻四九〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史で一番｜評判の愛犬家は北条高時どのだ子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから高時殿と一対の愛犬家は五代将軍綱吉公だナ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お犬公方様またなき御愛犬と見えて、お守役のお城小姓がふたり。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気鳩が飛びだしたと見るや、高一は愛犬マルという、よくはなのきく犬をつれて、いっしょに電気鳩のあとをおいかけました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高一は、そんなこととはしらず、ただ鳩舎へおりた電気鳩が、だいじな伝書鳩をころしたのにちがいないとおもって、愛犬マルといっしょに、この山のおくのほら穴の前まで、電気鳩をついせきしてきたのでありました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、おりよく愛犬マルが、足をひきながらかえってきました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミドリのたのみをきいて、良太おじさんは一隊の洋服すがたの憲兵をひきつれ、高一の愛犬マルを道案内に、その山の中にわけいりました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、さがすんだ」　そのとき愛犬マルは、なにおもったか耳をぴんとたて、かたわらのおおきい岩のうえにとびあがり、そのむこうにすがたをけしました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、家の前に高一の愛犬マルがいるのをみると、ハグロはその前に、くわえてきたズボンのきれをおとし、マルを案内するかのように、さきにたってとびました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "染めたのは灰色な自分の頭ではなくて、白い毛鞠のやうな皇后の愛犬だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十五（一九二六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬君は下関へ出張、駅まで見送る、戻つてから、預つた愛犬Ｓと遊ぶ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さん云う「庭の東南の隅を去る五尺余の地下にはカーライルの愛犬ニロが葬むられております。",
              "citation": {
                "source": "カーライル博物館",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "街頭劇名監督　少々荒療治ではあったが山木断髪令嬢の愛犬｜ＵＴＡを中心として渦巻くピンク色ローマンスの半分は、これで片付いたようなもんだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野性の叫び」は一匹の犬を主人公とした小説で、初めは富豪に愛育されていたが、人に盗まれ、売られ、虐使され或は北アラスカの荒涼たる氷原に橇を引き、或は愛犬家に撫育されて人の感情に鍛えられ、文化や野蛮の間に彷徨しながら、遂に天性の野獣性が眼覚め、狼群の長となる、ユニークな物語である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それう持ってわやくをしちゃあいけんちゅうのに」　僕はふいと立ち留って声のする方を見た。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
