    "definitions": [
      {
        "index": 1,
        "gloss": "to fix one's affection on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
