        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、生まれたばかりの娘に惜しみない愛情を傾けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若き陶芸家は、土と向き合う日々の中で作品に深い愛情を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年連れ添った老犬に、彼女は最期まで変わらぬ愛情を傾け続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "恩師は、教え子の才能を信じ、時に厳しく、時に優しく愛情を傾けて指導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、故郷の自然保護活動に人生の後半生を捧げ、多大な愛情を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての恋に、彼は全身全霊で愛情を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭師は、手入れする盆栽の一つ一つに細やかな愛情を傾けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本では美しいものは風景で、庭などに愛情を傾けるのであるが、人間のノルマルな欲求が歪められ、人間的であるよりも諦観自体がすでに第二の本性と化した日本人が、人間自体の美よりも風景に愛情を托したのは当然であつたに相違ない。",
              "citation": {
                "source": "欲望について",
                "author": "――プレヴォとラクロ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
