[
  {
    "uuid": "3bf0be54-c777-569d-b0f6-596ebb9f5925",
    "entry": "阿兄",
    "reading": {
      "primary": "あけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
