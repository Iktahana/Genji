          ],
          "literary": [
            {
              "text": "せめて半時なりともこの悪天候を、我らが同胞のなおひどい世の常をふたりして忘れてみよう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住吉の神、この付近の悪天候をお鎮めください。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は悪天候に見舞われ、かつ君のお抱えはロンドン女中の例に漏れず、靴を傷つけるほどに使えない、と。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで春、草が芽ばえて悪天候に害されもせずのびていくような筆致で歴史が書かれている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな悪天候をものともあそばさなかった御訪問であったから、恨めしさも紛らされていってもいいのであろうが、中の君は逢ってお話をする気にはなれなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前からの悪天とともに続いて来ている不平が、村をかく苦しみに落した実行組合長の兵衛門に対い、集中して来た。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそこれほど悪天の続くところはあるものだろうか。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪天の連続でどの田の進行も遅遅としている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人は磁石なしに方角を知り、バロメーターなしに悪天候を前知する。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までたとえ天候が良くとも、万一悪天候に悩まされても、自分は死なないという誇りのもとに、晴天を享楽しつつ辿ってきた。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "十×年八月八日　晴れ　小便に起きたついでに、明り取りの窓から暁の空を透かしてみると、憎らしいほど霽れ渡った悪天候である。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇悪な共産党員に乗りこまれている上、いままた悪天候に追いかけられることとなった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは私たちの不機嫌を、旅先きで悪天候ばかりを気にしているせいにしようとした。",
              "citation": {
                "source": "燃ゆる頬",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都に友達がなく、無聊に悩んで、三日目毎に、どんな悪天候を犯しても、僕のところへ遊びにくる習慣だつた。",
              "citation": {
                "source": "本郷の並木道",
                "author": "――二つの学生街――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにてさへ、まゝ想はざる悪水悪天候に遭ひ、失敗すること少からず。",
              "citation": {
                "source": "研堂釣規",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヴュウなら終幕前というところで、汽船は波と風と吹雪と霧と流氷と、悪天候の総出場の中をとんぼがえしをうちながらころがって行くのである。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日雨もよいの悪天候で、女たちはアブレがちであった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪天候のもとの強行軍にへとへとになって、カテリーナ・リヴォーヴナは次の営舎の板どこの上で、傷ついた胸をいだきながら、その夜ふけ不安な夢路をたどっていた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに見込の八掛けで手がたく構えていたとしても、前日より用意しなければならぬパンの原料が、次の日の悪天候で処分し尽せぬということは時に免れぬものである。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪天候が軍の活動を困難ならしめている。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは取りやめてよかったので、その後十五分か二十分したら、はげしい雷雨が襲ってきて、雷鳴がとどろきわたるという悪天候になった。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつならば、どんな悪天であろうとも、インド、アメリカの果てまでも平気で乗り切るだけの腕を持ってるが、残念ながら諸君では、世界はおろか、日本の領海でも、まだ全く心許ないと遠慮のないところ、拙者は想像している。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の顔に疲労と、悪天候と、肉体の困憊と、ほとんど一昼夜も続いた自分自身との闘争のために、ほとんど醜いくらいになっていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、悪天候時の花卉のことを恐ろしげに回顧していたが、通常話すのは、たった一つ、海のことだけだった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でニューギニアの北岸に触れつつ、六月から八月へかけて二カ月間悪天気と戦った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はここが安全で悪天候や敵にたいして護られていると感じた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が話すのは、夜とか、悪天候で船を出せないときだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "テムズ河口で悪天候に遭遇し、ひどい状況下、突風と乱風によって動索を多数失った。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャット新聞をなんで邪魔するんだ、悪天候め」　部長はベッドからくるりと降りて、窓を開けた。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
