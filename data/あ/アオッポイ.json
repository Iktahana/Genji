          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで、その薄暗い山王下あたりへ続くまことに寂しい並木のある甃石道を、うしろから青っぽい靄をふくんだ月の光に照らされながら歩いているうちに、井深君は何時しかそんな場合に似合わしい気分に落ち入って行ったのである。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こういう青っぽい駈出しが、得てしてあと先も見ずに慾得もなしに、無茶なゴシップを書きくさるのや）　佐古の顔は急にほころびた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "長手な重みのある、そしてどこか艶かしいところのある顔を見せて、洋服の男の背後の方から出ようとする容で、長い青っぽい襟巻の襟を掻き合せていた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ帰って手帳に物を書いていたら、薄いカーテンに妙に青っぽい閃光が映り、目をあげて外を見ると、窓前のプラタナスに似た街路樹の葉へも、折々そのマグネシュームをたいた時のような光が差して来る。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、此の青っぽい白眼も奇麗に見える事があるけれ共、此頃の様なまとまらない様子をして居ると、眼ばっかりが生きて居る様な――何だか先ぐ物にでも飛び掛りそうに見える。",
              "citation": {
                "source": "秋毛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜毛を見ながらも、変な青っぽい眼を見ながらも、徒に立って行く秋の貴さと健康の有難味を思う。",
              "citation": {
                "source": "秋毛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野さんは青っぽい蒲団の中に寝ていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のように青っぽい匂いの流れてくる暗い廊下に、私は瞳にいっぱい涙をためて、初夏らしい、ハーモニカの音を耳にした。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪え難いという顔色で、朝子は椅子をずらし、「外へ行きましょう」　素子の手をつかんで、ひっぱるようにその青っぽい窓べりをはなれた。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの欅の梢や松の梢のあたり　薄すり青っぽい靄がこめている。",
              "citation": {
                "source": "無題（十）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと云うと千世子は短っかく「ザンギリ」にした頭をまるむきに出して青っぽい袴と黒か白位の着物をノコッと着た肇を見てつくづく気の毒な様な気持がした。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんかと云うと、　ええと青っぽい油の浮いた顔を赤くして寝ぼけた様な返事をするのが千世子には堪らなく見っともなかった。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく井桁を散らした青っぽい着物に、赤い縦縞の丹前を引っかけてる彼女は、そのしゃくれ気味の長めの顔と共に、いつもよりか勝気らしく老けた感じだ。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体苦力たちの服が、きたなく褪せてはいては青っぽいものなので、その青色の布片は初めは殆んど人目につきませんでしたが、いつしか船員たちにも町の商人たちにも知れ渡り、その布片が次第に数をますにつれて、それがないと幅も利かないし仕事も少いというような状態になってゆきました。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、青っぽい羽二重の帯を胸高にしめ、上からお召の羽織を背抜き加減に引っかけて、その紐を胸に小さくきっと結え、無雑作に分けた髪を耳の上で一つねじって低めに束ね、細い頸筋を差しのべて、心持ち眉根を寄せながら、睫毛の長い澄みきった眼で彼の方を窺ってるのは、やはり以前から見馴れた俊子だった。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、青っぽい着物が、ばかに似合っている。",
              "citation": {
                "source": "生きた人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛痘の膿疱によく見られる青っぽい色はいつでも存在しない。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "試料を刺した部分にすぐに青っぽい赤色の発疹が現れ、かなり広範に広がったが何らの人痘症状〔１〕も起こさずに消失した。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタポタ青っぽい雫が落ちてきてきんぽうげ咲く草原を濡らした（ウルル、寒い）。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えるものといえばわずかに水平に動く青っぽい微光のみで、だが彼は堪え難い悪臭を嗅ぎ、頭上からやってくる奇妙な、柔らかく密やかなざわつきを聞いた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこちらは大型で、金属ではなく何か奇妙な青っぽい石からできていて、独特の角度を持つ台座があり、そこには解読不能な象形文字があった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ、変り編の青っぽいスウェターを羽織って。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデンの街路樹のしげみのかげに、ぼんやり青っぽい灯のついた一つのドアをあけて入った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優――といっても、まだ素人同然の青っぽい卵なのだが――たちは、一向に疲れた気配もなく、深夜の自動車の中で、大声で笑ったりふざけあったりしている。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上にすこしばかり樹の青っぽい蔭がさしていて、一寸何だか夏休みの或日のようです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絣のきもので、一寸前かけかけて、青っぽい廊下草履はいて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し今は、青っぽい筒袖のセルを着て、紺の大前かけかけて、青葉の色よりすこし水色っぽい更紗の布で頭包んで、とにかく小さいシャベルふるって土も掬って居るのですもの、えらい進歩であり、生きる力は大したものだと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼つきは、短い濃い睫毛のある青っぽい眼瞼が落とす見通せない影の下に隠れていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、昨夜の彼女と現在の彼女とがうまく一つに重ならないのも、自分にまだまだ青っぽいさまざまな幻影がこびりついている証拠であり、でも、いま、それがまた一つ剥がれたと思った。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして薄黄ろい、ヒナヒナした肌の、脳天のところに、ポツポツと青っぽい斑点がある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
