        "examples": {
          "standard": [
            {
              "text": "私は毎日粗砥について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗砥という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗砥の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗砥が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗砥を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗砥について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗砥の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗砥の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗砥が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗砥という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗砥という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗砥についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗砥を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗砥は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗砥について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗砥が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗砥は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗砥の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗砥は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗砥は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "陽が西の海に入って、麺麭の大樹の梢に大蝙蝠が飛び廻る頃になって、漸く此の男は、犬猫にあてがわれるようなクカオ芋の尻尾と魚のあらとにありつく。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中烈しい労働に追い使われ、食物としてはクカオ芋の尻尾と魚のあらとしか与えられないことも今迄通りである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に芋の尻尾と魚のあらとだけで我慢せねばならぬか。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "なま暖かく、どんよりと曇った日の夕方で、その頃まだ十一のおなおさんが近所の娘たち四、五人と往来で遊んでいると、そのうちの一人が不意にあらと叫んだ。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わずあらと顔を赧くした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　きゃあらきゃあらと若い奴、蜩の化けた声を出す。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐天竺日本にあらとあらゆる阿修羅の眷族を、一つところに封じ籠めて、夜な夜なかたきを呪うて居りまするぞ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらと言って挨拶をしたあとで、美禰子が、「せんだってはありがとう」と礼を述べた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄泉の洞なる戀人に生命の水を掬ばむと、七つの關の路守に、冠と衣を奪はれて、「あらと」の邦におりゆきし生身素肌の神の如、ああ爭ひの七八日、銀杏は征矢を射つくして、雄々しや空手眞裸に、ほまれの創の諸肩を、さむき入日にいろどりて、み冬の領にまたがりぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近「見ともねえなア、大きな声であらあらと云ひなさんな。",
              "citation": {
                "source": "心眼",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらと云つて挨拶をした後で、美禰子が、「先達ては難有う」と礼を述べた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもろ双紙にも、王を褒めて「せちあらとみ」といふ語の見えることは、先に触れておいた。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかがですな、目下お手持の発明兵器で世界一と思召すものは……」「ふむ、ふむ、ふむ」　博士は、猫が魚のあらと取組んでいるように只呻るばかりである。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元豊はそれを焚かすまいとしたが、もうあらあらと燃えてしまった。",
              "citation": {
                "source": "小翠",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらとござい」という声の、今も忘れ得ぬ妙なおかしさ――。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「いえね、あした早く発って、旦那といっしょに伊万里のほうへ年例の仕込みにゆきますからね、ちょっとこの前を通ったついでに、しばらくのお別れに寄ってみましたのさ」　といいながら、なにげなくお駒のほうを見ると、あらと驚いたお民の手から、きせるが落ちた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "千々子さまは、あらと、あどけないみたいに眼を見はって、「それは誤解よ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのみじかい時間にあらといふ驚きのこえを發したが、私の眼は見開きの寫眞が裸體の女の實寫で、林檎のやうな果物を乳房に當ててゐて、横臥した片峯の横の太腿上部が、そびえてゐる逞しい寫眞であつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或冬万作が黐網で鴨をとって来て毛をひくのを見て、「あらとっちゃん、とっとの衣服をとってしまうの。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或時万作が鯉を漁って来て料理するのを見て居たが、其右の手にすがって「あらとっちゃん、いやいやあたいもうお魚たべるのはいや」。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に動き出して、杉子はほっとすると一緒に、あらとおかしそうな眼色を輝かした。",
              "citation": {
                "source": "杉子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ内からよむところまで到達はして居りませんが、この頃は、フト気がついて、あらと思う、内側からよんでいた自分に心づくのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは座談会で、日比谷の陶々亭を出ようとしたら雨になっていたので、あらと思い、雨の音を珍しくききながらいい心持で眠りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってさ、相当がっちりかまえて心得顔に歩いて行っていると思うと、急に二三歩ひょろついてそれなり倒れもせず又とり直して行きつづけるの、うしろから見ていたら、あらと思うのはあたり前ですものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あらと心の内におどろくのよ、あなたに似ていると感じて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "友ちゃんは友ちゃんで、あらと思うところがあるのでしょうし、お母さんはお母さんでやはり俤をそこに認めて一層可愛くお思いになるのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の太柱でさえ風化して、老人の筋骨のように、あらあらと木目のすじが露出している。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戦場に在る日は、つぶ漆のあらあらとした鎧に、虎御前の太刀を横たえ、　コノ若殿、魁ニ御在セバ、軍中、何トナク重キヲナシ、卒伍ノ端々ニマデ心ヲ強メケル――　とは家中のみでなく一般の定評だった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒をこぼしたりすると、あらあらと言って、その声が若やいでいるのが何だか奇妙に気になった。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手をまちがえたらしい、あらと云って口をあけた。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
