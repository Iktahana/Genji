    "definitions": [
      {
        "index": 1,
        "gloss": "native of Amagasaki",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日尼っ子について考えている。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は尼っ子の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には尼っ子が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは尼っ子について学習した。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は尼っ子の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では尼っ子が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に尼っ子という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では尼っ子についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると尼っ子は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では尼っ子が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に尼っ子は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により尼っ子の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "尼っ子は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に尼っ子は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんなデコボコ尼っ子」「本当？",
              "citation": {
                "source": "田園情調あり",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、海竜が出ました、角を二本｜生やした、こんな怖い顔をして、お杉のあまっこを追っかけて来たのを、命からがらで逃げて来やんした」　窓の外は、けんけんごうごうとして、潮のわくような騒ぎであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
