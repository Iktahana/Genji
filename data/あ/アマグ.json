        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨具について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨具という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨具の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨具が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨具を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨具について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨具の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨具の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨具が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨具という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨具という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨具についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨具を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨具は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨具について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨具が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨具は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨具の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨具は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨具は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あわれ、祖母に導かれて、振袖が、詰袖が、褄を取ったの、裳を引いたの、鼈甲の櫛の照々する、銀の簪の揺々するのが、真白な脛も露わに、友染の花の幻めいて、雨具もなしに、びしゃびしゃと、跣足で田舎の、山近な町の暗夜を辿る風情が、雨戸の破目を朦朧として透いて見えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何、降るものと極れば、雨具の用意をするのは賢い。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、また、雨具もござる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具を持たないお客だよ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われに等しき避難者は、男女老幼、雨具も無きが多く、陸続として、約二十町の間を引ききりなしに渡り行くのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我に等しき避難者は、男女老幼、雨具も無きが多く、陸續として、約二十町の間を引きゝりなしに渡り行くのである。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男｜市太夫、四男｜五太夫の二人がほとんど同時に玄関に来て、雨具を脱いで座敷に通った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具で何重にも身を固めているから、途中で行き逢っても人間か何かわからぬ形をした、まず奇怪な者として追い払わなければならない下侍に親しみを感じる点だけでも、自分はみじめな者になったと源氏はみずから思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具を用意して出で、箒川の左岸を上る。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山の屋敷ではその出先を知っているので、どうで今夜は遅かろうと予期していたが、やがて四つ（午後十時）に近くなって、雨はいよいよ降りしきって来たので、中間の仙助に雨具を持たせて主人を迎えにやった。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　従軍記者の携帯品は、ピストルのほかに雨具、雑嚢または背嚢、飯盒、水筒、望遠鏡で、通信用具は雑嚢か背嚢に入れるだけですから、たくさんに用意して行くことが出来ないので困りました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原や畑に野宿していると、夜半から寒い雨がビショビショ降り出して来て、あわてて雨具をかぶって寝る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具をつけていない僕は頭からびしょ濡れになって、宿へ帰りつく頃には骨まで凍りそうになってしまった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは雨具を持っていなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "下衆の持つた雨具や炊事具。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉葉は橋のほとりまで行つて、その家の殿の馬や雨具の向うに見えなくなるのを見送つて涙組ましい悲しい心持で家の方へと戻つて來た。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具の支度はして來なかつたので、房まで行く間はいくらもないのであつたけれども、それでも窕子の髮も衣も白くなつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降りしきる中に、果たしてそこに内裏から來たらしい雨つゝみをした網代車が二輛――白い黒い斑牛も、笠をかぶつて雨具をしてゐる牛飼の男子もすべて深い泥塗にまみれて、その車臺すらも半ばは泥濘に汚されてゐるのを眼にした。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも完全な雨具とても用意してないので、衣冠束帶の勅使と喪服を着たやうな登子とが長柄の傘を後からさしかけられただけで、あとは皆なびしよぬれなるのを何うすることも出來なかつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お師匠さまは雨具の用意してゆけと言われたを、近い路じゃと油断して、そのままに出て来ると直ぐにこれじゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具をつけて自転車を走らせてゆくのもある。",
              "citation": {
                "source": "雪の一日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨具もなし、おまけに二人は下駄がけと云うのだから、色々勧めて帰らせようとするが、つまり承諾しない。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしやかかる雨具もあるものをとわれも見まねに頬冠りをなんしける。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "背に雨具、筆、墨のたぐひ、あるひは夜の防ぎにもと紙布、ゆかたの類までも用意して百里二百里の道を踏んだといふ頃にわたしたちの心を馳せるとしたら、そして初しぐれの來る季節を想像し、山茶花なぞの咲く宿々を想像するとしたら、旅人と自分の名を呼ばれようと言つた昔の人の姿がおのづとそこに浮んで來る。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のわたしたちには、雨具を背にする必要もない。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、身すがらにと出立ち侍るを、紙子一衣は夜の防ぎ、浴かた、雨具、墨、筆のたぐひ、あるはさりがたきはなむけなどしたるは、さすがに打捨てがたく、路次の煩ひとなるこそわりなけれ」「奥の細道」　牛込の下宿で捨吉はこの芭蕉の文章を開けた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時半の列車で日田へ（今日は歩きたかつたのが雨具の用意がないので、仕方がない）。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ある人のいへる、「あまぐものはるかなりつる桂川そでをひでゝもわたりぬるかな」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほきみは神にしませば、あまぐもの　雷が上にいほりせるかも　この歌は、持統天皇のお伴をして、雷の岳――また、神岳ともいふ――へ行幸なされた時に、人麿が奉つたものなのです。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジェレミーさんは　あまがっぱを　はおって　ぴかぴかの　あまぐつを　はきました。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
