            }
          ],
          "literary": [
            {
              "text": "肺炎になってしまってからの愛児の看護に骨を折るよりも、風邪を引かせぬ予防法、引いたときに昂じさせぬ工夫に一倍の頭を使う方が合理的である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会の開催前になるとやはりどうしても平生よりは仕事が忙しくなって何かとよけいに頭を使う。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を使う人は歯が悪くなると言って弁解するのは後者であり、意志の強さが歯に現われるというのは前者である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは手や指を使うというよりもむしろ頭を使うためらしく思われた、芝を刈るというような、機械的な、虚心でできる動作ならばおそらくそんな事はあるまいと思われた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "知恵のある人間が悪事のために頭を使うとは、末恐ろしい。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし下駄を脱ぐ事に徹底すれば、何時でも暗闇で穿けるので頭を使うには及ばないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ頭を使う仕事じゃないんですから。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が平和に関してせっせと頭を使うものか。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は私で自分の頭がだんだん悪くなるのも君が私の頭を使うからだ。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターに関する知識が皆無では困るが、それほど頭を使う必要はない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くそう云って下されあコンナに頭を使うんじゃなかったのに……」「そんなに頭を使ったかね」「……どうも変だと思いましたよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を使うわりに私は食物を多くとりすぎる傾向か。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ああ云う裾模様をつくらないのだろう、自然、智、愛と云うようなものを、一つの衣服の中に、うるわしくあらわせ、そう云う風にこってこそ着物に頭を使う甲斐があるのではないだろうか、単に色の調和でも、感じが、ずっと出るのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては、ただ頭を使うのが臆劫になった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまず諸君よりもそんな方面に余計頭を使う余裕のある境遇におりますから、こういう機会を利用して自分の思ったところだけをあなた方に聞いていただこうというのが主眼なのです。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はあの事件以来妙に頭を使うので、近頃では落ちついて書斎に坐っている事が困難になりましてね。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの都立の産院だか、病院だかで、捨子公認所をつくったそうだが、こういう工夫をいろいろとやる方に頭を使うべきである。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物を得るために死物狂いとなり、外敵を防ぐために頭を使う。",
              "citation": {
                "source": "季節の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を使うと胃ブクロへ行く血液がへる。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに頭を使うと不幸になる。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア人間の九割ぐらいは、外によく内に悪いのが当然だし、特に頭を使う商売や人間関係の複雑な世界に政策商略的な生き方をしなければならない人間は、外によく、内に悪いのが自然で、内に悪いのが一種の休息と目してよかろう。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "概して頭を使う人の声は濁るようである。",
              "citation": {
                "source": "音の世界に生きる",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしては、下らないことに頭を使うまいと努めた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私からいうとどうでもいいような事にこれほど時と頭を使うことから推測すると、利害関係のはげしい議会の議事の運行はどんなに面倒であろうか。",
              "citation": {
                "source": "ペンクラブと芸術院",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら話をしてもいつもと違って、頭を使う込み入った問題には触れませんでした。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "述作の際非常に頭を使う結果として、しまいには天を仰いで昏倒多時にわたる事があるので、奥さんが大変心配したという話も聞いた。",
              "citation": {
                "source": "博士問題とマードック先生と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
