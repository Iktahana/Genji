[
  {
    "uuid": "56fabb92-78f4-5d4d-ae13-a58de597db3f",
    "entry": "蟻地獄",
    "reading": {
      "primary": "ありじごく",
      "alternatives": [
        "アリジゴク"
      ],
      "is_heteronym": false
    },
    "grammar": {
