    },
    "definitions": [
      {
        "index": 1,
        "gloss": "antlion (larva)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日蟻地獄について考えている。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は蟻地獄の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には蟻地獄が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは蟻地獄について学習した。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は蟻地獄の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では蟻地獄が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に蟻地獄という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では蟻地獄についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると蟻地獄は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では蟻地獄が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に蟻地獄は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により蟻地獄の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "蟻地獄は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に蟻地獄は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は、蟻地獄に陥る蟻だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻地獄ありぢごくは蟻をとらへんとておとし穴の底にひそみかくれぬありぢごくの貪婪の瞳にかげろふはちらりちらりと燃えてあさましや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田清輝も、沙漠について、砂について、蟻地獄について、さまざまの考察をしているようですが、どうかするとこの頃は人間の魂まで砂のなかに埋没されそうになるのです。",
              "citation": {
                "source": "ある手紙",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻地獄といふもの、何だか気味悪い存在だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は軒の長い御かげでとばしりの来ない部屋に座って蟻塚は崩されたり埋められたりすまいか、蟻地獄の摺鉢も、大方流れたろうなどと思う。",
              "citation": {
                "source": "無題（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、蟻地獄に落ちた蟻のような、いら立たしい心で、彼の周囲を見まわした。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、蟻地獄と言われる草や、蠅取草のようなものは、自分で動いて、蟻とか蠅とかを捕えるという話である。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はあらゆる努力をして渦巻の外へ出ようとしたが、蟻地獄へ落ちた蟻のようにどうすることも出来なかった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると上から小砂利が漏斗の内壁にザラザラと落ちて来て、其上を蹈むとするりと滑る、ハッと胸騒ぎがする、蟻地獄の縁を匐い廻る小虫の惨めさを思い出す。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が三四年前の蟻地獄みたいな解剖癖から抜け出て、チツトは生きた人間になれたのは彼奴のおかげだからな。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のくせに、ナヨナヨとした大變な野郎で、一名は蟻地獄」「それが怪しいのか」「怪しいどころの騷ぎぢやありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死骸の側に蟻地獄野郎の定紋の金具をつけた、煙草入があつたんだから、文句はないでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の雨つい／＼と吸ひ蟻地獄六月二十九日　鎌倉俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの手の女は、先ず蟻地獄――君みたいな身体だと忽ち命取りだぜ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの窓の下の地面に蟻地獄がいましたっけ、それを捕って手のひらを這わせるんです、するとそいつは手の皮の中へもぐり込もうとする、むずむずして擽ったいんですが、その恰好がおもしろいのでよくやったものです、ご存じですか」　そんなことを興ありげに云った。",
              "citation": {
                "source": "日本婦道記",
                "author": "糸車",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の入道雲の下には、蟻地獄のような囚人の群れが、腰鎖のまま、気息｜奄々と働いていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、坑の口から外へだした土の山が、蟻地獄のように、敵陣の諸所に盛られ始めたからである。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑から上げた土は、厚い土壁とし、数条の堤となし、壇となし、ここに蟻地獄のような土工業が約一ヵ月も続いた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
