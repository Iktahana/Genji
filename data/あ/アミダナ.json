        "examples": {
          "standard": [
            {
              "text": "私は毎日網棚について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網棚という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網棚の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網棚が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網棚を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網棚について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網棚の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網棚の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網棚が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網棚という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網棚という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網棚についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網棚を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網棚は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網棚について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網棚が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網棚は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網棚の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網棚は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網棚は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは、網棚にでも上りたいほど、乗り込んでいた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、網棚から兵児帯を吊して、首でも縊る時のように、輪の中へ顎を引っかけて、グウグウ眠っている男があった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一人連れていてその癖、網棚から首なんぞ吊るしやがって、横柄な顔をして大鼾で寝てやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚に繪具箱をのせる空所もなかつたのでベンチにのせかけて持つて居るうちに、誤つて取落すと隣に立つて居た老人の足に當つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、ひげの中でかすかに微笑ひながら、荷物をゆっくり網棚にのせました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚の上には白い荷物も見えなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その匂は、けれども、あちこちの網棚の上のほんたうの苹果から出てゐたのです。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車がニースの駅を出て国境に近づくと、一行は網棚から荷物を下して、身支度をととのえましたが、彼はまるで精神のない人間のように、身動きもしないで、俯むいたまま一点を見詰めていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、ひげの中でかすかに微笑いながら荷物をゆっくり網棚にのせました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、例の大鞄が、其のまゝ網棚にふん反返つて、下に皺びた空気枕が仰向いたのに、牛乳の壜が白い首で寄添つて、何と……、添寝をしようかとする形で居る。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、ひげの中でかすかに微笑ひながら荷物をゆつくり網棚にのせました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その男は立つて、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚の上には白い荷物も見えなかつたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚に絵の具箱をのせる空所もなかったのでベンチにのせかけて持っているうちに、誤って取り落とすと隣に立っていた老人の足に当たった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは室内のトランクが汽車の網棚のトランクに移り変わるような種類である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふり仰ぐと、それまで私のうしろに立っていたらしい若い女のひとが、いましも腕を伸ばして網棚の上の白いズックの鞄をおろそうとしているところでした。",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は網棚の横の棒にしつかりつかまり、背中を丸めてバスの窓から外の風景を覗き見る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく、アンブレラとお道具を、網棚に乗せ、私は吊り革にぶらさがって、いつもの通り、雑誌を読もうと、パラパラ片手でペエジを繰っているうちに、ひょんな事を思った。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそいで網棚から、お道具と傘をおろし、すばやく割りこむ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを恐れる少年は、旅行中、汽車の中でも網棚の上に上って寝た。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井も同じ絹布で張って、壁には網棚もある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の揺れはますます激しく、私のいわゆる王様のベッドの洋銀の欄干、網棚、カーテンの鐶などは、しっきりなく音を立てて鳴った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯ならぬ車内の様子にいよいよ驚かされて、だんだんその子細を聞きただすと、列車はもうＦの駅に近づいたので、三、四人の乗客はそろそろと下車の支度をはじめて、その一人が頭の上の網棚から自分の荷物をおろそうとする時に、汽車にゆられて手をはずして、半分おろしかけていた風呂敷包みをほうり出してしまった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが傍を向いていたのは、せいぜい二分か三分に過ぎなかったが、そのあいだ兄と妹はどう相談をしたのか、網棚の上にあげてある行李をおろし始めた。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
