        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天の下について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天の下という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天の下の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天の下が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天の下を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天の下について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天の下の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天の下の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天の下が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天の下という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天の下という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天の下についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天の下を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天の下は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天の下について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天の下が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天の下は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天の下の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天の下は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天の下は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「水が飲みたあい」　と、炎天の下で乾物になりさうな程も、焙られて怒鳴りながら駆けて、帰つた子供たちは、井戸に飛びついてポムプを押すのだが、井戸からは一滴の水も出ないのだ。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は赫々とした炎天の下で、烈しく鋭い精神を私の裡に感じたのである。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生村にくすぶって、毎年同じように麦を苅ったり、炎天の下で田の草を取ったりするのは楽なことではなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんだんの花のこぼれる南国の真夏の炎天の下を、こうした、当時の人の目にはスマートな姿でゆっくり練り歩きながら、声をテノルに張り上げて歌う文句はおおよそ次のようなものであった、「エーエ、ホンケーワーア、サンシューノーオー、コトヒーラーアヨ。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇天の下の池の面は白く光り、小波の皺をくすぐつたげに疊んでゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇天の下の池の面は白く光り、小波の皺をくすぐったげに畳んでいた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南天の下に手水鉢が見えるあたりから、雨戸を三枚ばかり繰った、奥が真四角に黒々と見えて、蚊帳の片端の裾が縁側へ溢れて出ている。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "光る雨、輝く木の葉、この炎天の下蔭は、あたかも稲妻に籠る穴に似て、もの凄いまで寂寞した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつつ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交う人は点々と蝙蝠のごとく、電車は光りながら山椒魚の這うのに似ている。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――……　　　　　　　十一　翌日の午後の公園は、炎天の下に雲よりは早く黒くなって人が湧いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰥暮しで暇のある蛍雪は身体の中で脂肪が燃えでもするようにフウフウ息を吐きながら、一日中炎天の下に旅行用のヘルメットを冠って植木鉢の植木を剪り嘖んだり、飼ものに凝ったり、猟奇的な蒐集物に浮身を※したりした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の後の塵無き天の下にて快き風に船を送らせながら、絵も及びがたき雲の美しさに魂を酔はせつゝ、熱き飯、熱き汁を味はふ此楽しさは、土にのみ脚をつけ居る人の知らぬところなり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "亢る氣の象は、人の上、天の下に横流して暴溢し、自を張つて他を壓するのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高台の職人の屈竟なのが、二人ずれ、翌日、水の引際を、炎天の下に、大川｜添を見物して、流の末一里｜有余、海へ出て、暑さに泳いだ豪傑がある。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "満ち満つや、み蓄、早やかく成りぬ、天の下ことむけむ、秋今成りぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "滿ち滿つや、み蓄、早やかく成りぬ、天の下ことむけむ、秋今成りぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗は戦と風もない炎天の下に死んだ様に低頭れて襞一つ揺がぬ。",
              "citation": {
                "source": "氷屋の旗",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五歳以後は、最早あらゆる魔術と呪文とに通じた博学の大賢者として天の下に並ぶものもない。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮普天の下勅命に逆ふ輩は、早く誅伐を加へざるべからず云々」　実に秀吉一流の大見得である。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天の下に水を溜めようとしても、水は、いつの間にか蒸発してしまう。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女は天の下の奇しき事どもを多く知れるものにて、世には法皇の府の僧官達も及ばざること遠しとぞいふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "光る雨、輝く木の葉、此の炎天の下蔭は、恰も稲妻に籠る穴に似て、もの凄いまで寂寞した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつゝ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交ふ人は点々と蝙蝠の如く、電車は光りながら山椒魚の這ふのに似て居る。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――……　　　　　　　　十一　翌日の午後の公園は、炎天の下に雲よりは早く黒く成つて人が湧いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお菊は幼少の時｜孤児となり叔父の家に養われたりしが、生れ付きか、あるいは虐遇せられし結果にや、しばしば邪の径に走りて、既に七回も監獄に来り、出獄の日ただ一日を青天の下に暮せし事もありしよし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、焼付けるような炎天の下で居眠りをしながら水車を踏んでいることがあった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼らは一様に、――ちょうど炎天の下を強行軍する軍隊の兵士が一様に水を欲しているように、――陸上における、陸上であれば木賃宿でもいい、生活に飢えていたのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その炎天の下を、ここから四、五町ばかり彼方にある街道を朝から、織田勢が幾人も幾人も続いて通る。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は、白日青天の下に此の如く無残に曝し出されている東京市政の破綻を見て、無限の感慨に打たれざるを得なかった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式令に於ては、日本天皇、或は、天皇と書いてゐるが、此は、恐らく朝廷大辞と同じく、古くは「あきつみかみと、あめのしたしろしめす大倭根子天皇」と云ふ資格の宣言を、開口としたのであらう。",
              "citation": {
                "source": "高御座",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
