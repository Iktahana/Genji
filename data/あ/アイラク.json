        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "而も所謂喜怒哀楽――即ち損得に因つて起る喜びと悲み――を叫びたかつたのではなく、かの生の歓喜だ！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に今日、日本の現実する社会相と接触し、民衆のリアルな喜怒哀楽を表現してゐる芸術は、蓄音機のレコード等によつて唄はれてる、町の流行唄以外にないのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数々の線の一つずつには、線の両端に居る人間の過去現在未来の喜怒哀楽、義理人情の電流が脈々と流れている。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて形容詞のなかへ入れられないような人間同志が無上の信頼と哀楽と相憐とを共にして生きて居る。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "このただ一枚の飛び石の面にだけでも、ほとんど数え切れない喜怒哀楽さまざまの追憶の場面を映し出すことができる。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その吹き出づる哀楽の曲は彼が運命｜拙なき身の上の旧歓今悲を語るがごとくに人々は感じたであろう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "応身とは、人間に相応して生れ、人々を教化せられる仏陀ということでありまして、人間に相応ずる以上、人間の肉体を持ち、人間の喜怒哀楽を備え、お腹も減り、病気もされる仏陀であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はかなり喜怒哀楽の変化の激しい人間である。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が顔面に喜怒哀楽の表情が少しも現れないと等しく彼の声にも常に何等の高低はない。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "此立退場を有って居る人の喜怒哀楽と、有たない人の喜怒哀楽とは人から見たら一様かも知れないが之を起す人之を受ける人から云うと莫大な相違がある。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の菊と喜怒哀楽を共にして生きて行くだけです。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して愚かな狂熱の坩壺の中に一切の智慧も理性も哀楽も焼け爛らして了つたのです。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さり乍ら、小生にはあらゆる讚辞と輝やかしい彩花とに生き甲斐のある一少詩人の万歳を祝つて載いた「思ひ出会」の当夜よりも、今は却て一層の安静な自己の霊魂の面に尊い而して親しみ易い哀楽の諸相を味ふ事が出来さうに思はれます。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐息そこ、ここ、哀楽のつめたきにほひ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く光る硝子戸に真白なる顔ふりむけて、哀楽の表情もなく親しげに畜類の眼と並びつつ何をか凝視む。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山河草木、旧のごとくにして人また変転、哀楽また新にして恩愛一のごとし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て溶かして掻き廻す観相の余裕から初めてとりあつめた哀楽のかげひなたが軟かな思の吐息となつてたちのぼる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがわかき日も哀楽も遂には皐月の薄紫の桐の花の如くにや消えはつべき。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大抵これまで父親と二人で暮していた、何年かの間に閲して来た、小さい喜怒哀楽に過ぎない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他囃子の手の中でも只一回、指一本で、軽く鼓の表面に触れるだけで、宇宙間の森羅万象と喜怒哀楽、その他のあらゆる芸術表現の使命を達し得る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の表現に現われた喜怒哀楽の基調が卑しいものであるか、高尚なものであるか、又は狡いものであるか、正直なものであるかという事は、その底に表現されている、その人間の性格を見れば一目瞭然するのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の目覚めや、夜ごとの就寝命令、復習や、暗誦、定期的な半休や、散歩、運動場での喧嘩や、遊戯や、悪企み、――こんな事がらが、長いあいだ忘れられていた心の妖術によって、あまたの感覚、かずかずの豊富な出来事、さまざまな悲喜哀楽の感情、もっとも熱情的な感動的な興奮などを味わわせてくれたのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くして伴侶を喪った祖母は、歌うことで、暮らしの中で生じる感情のうねりの下に潜り込み、喜怒哀楽を腹におさめて安心を得ました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした喜怒哀楽の強い感情がみなぎったときに、かれらの眼のひかりは怖るべき魔力を以って初めて相手を魅することが出来るのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は未来永遠に私を準備するためにこの世の中に来て、私の流すところの涙も、私の心を喜ばしむるところの喜びも、喜怒哀楽のこの変化というものは、私の霊魂をだんだんと作り上げて、ついに私は死なない人間となってこの世を去ってから、もっと清い生涯をいつまでも送らんとするは、私の持っている確信でございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、曽子から学問を受けた子思が、「喜怒哀楽の感情が未だ発しない、之を中という」と云われたその「中」というものは、忠恕の「忠」の答えだと云っても差し支え無い、忠は中心である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……喜怒哀楽のどれか一つだけでは表わし得ない、不思議に交錯した感情が、葉子の目からとめどなく涙を誘い出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜怒哀楽の情の上にあって、ただ鉄槌を振っている勇猛精進の菩薩心であった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
