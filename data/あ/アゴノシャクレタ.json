          "standard": [
            {
              "text": "顎のしゃくれたの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ごじゃ／＼と書類の積まさった沢山の机を越して、窓際近くで、顎のしゃくれた眼のひッこんだ美しい女の事務員が、タイプライターを打ちながら、時々こっちを見ていた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへえ、これは先生さまあ……」顎のしゃくれた女房がお世辞笑いをして科をつくるのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様は、この蔀半四郎を怪しいと睨んだそうだな」「とんでもない、旦那」「いまさら胡麻を摺っても追っつかぬぞ、――その方の家来、あの顎のしゃくれた野郎が、昨日拙者が何をしていたか、くどく訊きおったぞ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろい、あごのしゃくれた小さい顔は、あらわに敵意をみせていた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
