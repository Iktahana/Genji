[
  {
    "uuid": "82075aba-be64-50d1-b06f-50c7e88a20d2",
    "entry": "慌て者",
    "reading": {
      "primary": "あわてもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scatterbrain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日慌て者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "慌て者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は慌て者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には慌て者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "慌て者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは慌て者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "慌て者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は慌て者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では慌て者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "慌て者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に慌て者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では慌て者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "慌て者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると慌て者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "慌て者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では慌て者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に慌て者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により慌て者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "慌て者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に慌て者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先ず和製では、野生的の勇気を表わす「獅子鼻」を筆頭に、意地の悪い感じを与える「鷲鼻」、お人好しと見られる「団子鼻」、無智を示す「蓮切鼻」、無能を示す「トンネル鼻」、慌て者を表白するという「二連銃」、むずかし屋を表明する「碇鼻」（「怒り鼻」？",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時世に「人類の幸福」なんて、とりとめもない事を、方々訊ね廻ってたら、慌て者があったら殴られちまうだろう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌て者の日本人はすっかり驚いて、日本魂までデングリ返らせた結果が、今日では処構わず爆弾を取り落すような悲しい民族的精神となり果てた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とまあ自分は気の毒な慌て者だつたことだらう――彼は辛うじて間に合つた汽車の窓に腕をのせて、真盛りの莱畑を眺めながら、あんな手紙位ゐでこんなにも一個の人間が有頂天になるものか！",
              "citation": {
                "source": "陽に酔つた風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて医者といふものは、診断が拙からうが、学問が無からうが、唯病家へ往つて落つき済まして居さへすればそれで良い評判を取る事も出来るものなのだが、不仕合せにもこの元孝は性来ひどい慌て者だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話口でこちらの番号を怒鳴る慌て者である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様の前に出た時も同様で御座いましたので、お側に居った慌て者が「コレコレ鉢巻を取れ」と申しましたところから、殿様が大層、興がらせられて、斯様な苗字を賜わったという、世にも名誉ある鉢巻で御座いました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又、そのうちに、乗客の中でも一番航海通の海軍将校上りが……サッキ話した慌て者さ……そいつが手ヒドイ神経衰弱に引っかかってしまった。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、私達三人を幽霊じゃないかと疑った慌て者も居たそうであるが、これは考えてみると無理もなかった。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌て者もゐることだから、と、しみつたれた根性で、一回だけこの匿名を使つてしまつた。",
              "citation": {
                "source": "新作いろは加留多",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから恋をするのだよ」「先生は本当に慌て者ね。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガサツな慌て者だから、衝突したり、ひつくり返つたりするのである。",
              "citation": {
                "source": "私は海をだきしめてゐたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかした犯人がボクだときめてる慌て者もいるほどだから」「どうも、それでは話があわない。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガサツな慌て者だから、衝突したり、ひっくり返ったりするのである。",
              "citation": {
                "source": "私は海をだきしめていたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌て者の探偵に犯人は捕りません。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の火事でも、いろんなウカツ者がいて、心気顛動、ほかの才覚はうかばず、下駄箱一つ背負いだしたとか、月並な慌て者はタクサンいたが、一気に多賀まで逃げ落ちたというのは他に一人もいなかったようだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は平さん自身が飛び出さない方がよかったのだけれども、この男は正直者でもあり、慌て者でもあったから、店の者から何か言われると、慌ててここへ飛び出して来たものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、癩病と知った当日逃げだした弱虫の慌て者もいたほどだよ」　大家にも拘らず、大勢の召使いが一人残らずそう古くない理由がうなずけるのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "木場の旦那の数あるうちでも音にきこえた山キの旦那ともあろうお方が、ヨイヨイやモウロクジジイじゃあるまいし、自分で趣向をたてた葬式に火にすくんでトビの者に助けだされたなどと、旦那の名を汚すような外聞のわるい評判がたつようなオチョッカイをはたらくほど慌て者のコマ五郎じゃアありませんぜ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々慌て者が部屋を間違へてドアを開けて覗き込むので、此のカーテンをつけたのであるが、それでも中には、此のカーテンを押し開けて中を覗いてから「失礼しました」と云つて出て行く客があつたとモード夫人が説明してゐた。",
              "citation": {
                "source": "ツーン湖のほとり",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは慌て者の読者が考えるようにすべての文明の結果を捨て去って未開の状態に戻るのでないことに注意して欲しい。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て、おせっかいな人が、もしくは慌て者が、得々として慈善心をほころばせて財布を開ける。",
              "citation": {
                "source": "乞はない乞食",
                "author": "添田唖蝉坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁鼻は八丁先を鼻で嗅ぎだす敏腕だが、根が慌て者の一人呑みこみ、田舎の犯罪にはカンは確かだけれども、インテリの計画犯罪には読み方の足らない憂いがあるのであった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌て者の松明は、一目散に、銀閣寺のわきまで駈け降りて来た。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ早く行けじゃ分らないじゃないか」　病人と慌て者のあいだに立って一人で癇癪を起してしまう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが誤解であったことは、彼がもすこし落着いていたら、充分、すぐ翌日にも分っていたはずだが、何しろ、よほど仰天したか、慌て者だったにちがいない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に持っている品物をないないと言って騒ぐのは、漫画のヒーロー「あわてものの熊さん」ばかりではない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが思うのには聖オウガスチンという男はあわてものさ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえみたいなあわてものは、今から用意させておかねえと、いざ鎌倉というときになってとち狂うからと思って、活を入れておいたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "扮装は、少年少女は平常着のままでも好い、その他は子供の空想の産物で好いが、先生は威厳を損じない程度にのどかな人物であること、猟人はずんぐりしていて意気なあわてもの、兎はフランネルのマスクを被る。",
              "citation": {
                "source": "春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
