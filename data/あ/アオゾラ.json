        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "わが知らぬ、とほきとほきとほき深みにて　青空は、白い雲を呼ぶ。",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は青空を見上げて、「しかし、東京は、のんきだな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は「さび」や「渋味」や「枯淡」やの老境趣味を愛したけれども、青空の彼岸に夢をもつような、自由の感情と青春とをなくしてしまった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論現実的の憂愁ではなく、青空に漂う雲のような、または何かの旅愁のような、遠い眺望への視野を持った、心の茫漠とした愁である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子のように冷たい青空。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青空の上に浮んで、昨日も今日も、さびしい一つの凧が揚っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸附近の林の中へ這入つても、雨のやうな緑と、気品の高い青空の影とを感ずる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋上の砂利の上に関東八州の青空。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い青空に、濃い白雲がギラギラ光つて、おもひばかりが一杯で、私には、なにが何やら分らない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸青空が顏を出したと思ふと又降出す。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、結局高い澄み切った青空の下で北欧の中秋の好晴の日は静粛な午後を保っていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はやんで、晴れ上つた青空の奧に、私は今窓に現はれた印度人が正しく前へ向けて開いてゐたかんらん色の瞳の色が光つて居るのを見つゝ歩いた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は仕事に疲れると、この縁へ出て仰向けに寝転び、都会の少し淀んだ青空を眺めながら、いろいろの空想をまどろみの夢に移し入れた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今年は実際に小春の好晴がつづき、その上にこの界隈の銀杏の黄葉が丁度その最大限度の輝きをもって輝く時期に際会したために、その銀杏の黄金色に対比された青空の色が一層美しく見えたのかもしれない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうある日の快晴無風の午後の青空の影響を受けたものか、近頃かつて経験したことのないほど自由な解放された心持になって、あてもなく日本橋の附近をぶらぶら歩いているうちに、ふと昨日人から聞いた明治座の喜劇の話を想い出してちょっと行って覗いてみる気になった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり「試験」のあとの青空の影響もあったのかもしれない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手摺窓の障子を明けて頭を出すと、椎の枝が青空を遮って北を掩うている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "席上「驢馬」の宮木喜久雄「青空」の三好達治の二君あり。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の四辻に写真屋があり、その気象台のような硝子の家屋に、秋の日の青空が侘しげに映っていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其処には玻璃製の上品な市街や青空やが映る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたき地面に竹が生え、地上にするどく竹が生え、まつしぐらに竹が生え、凍れる節節りんりんと、青空のもとに竹が生え、竹、竹、竹が生え。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗苗は青空に光り、子供は土地を掘る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青空」といふ雜誌は大正十四年の一月から昭和二年の央まで發行されてゐた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが青空の前身であつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエホフの　「熊」　　　　　　一幕シングの　　「鑄掛屋の結婚」　一幕山本有三の　「海彦山彦」　　　一幕「熊」の老僕にはあとで「青空」の同人になつた小林馨がなつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには「青空」の中谷孝雄が田舍の老牧師になつて出てゐる。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海彦山彦」は「青空」の外村茂と淺沼喜實とがやつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「青空」を出すやうになつてからは誰も戲曲を書く物はなくなつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
