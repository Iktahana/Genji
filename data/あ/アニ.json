    "definitions": [
      {
        "index": 1,
        "gloss": "older brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――いつたい何処までゆきなさる、――いえ、兄の嫁の危篤を知らせに、此の下の村まで一寸。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔こんにやくの〕宮沢賢治こんにやくのす枯れの茎をとらんとて水こぼこぼと鳴るひぐれまぢかの笹はらを兄弟二人わけ行きにけり",
              "citation": {
                "source": "〔こんにやくの〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒つたのはその五名の父兄で、病気の軽重で処分の軽重を割出したとは何といふことだといふので、復校運動を開始しました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの詩集は、北原兄の『思ひ出』以後における日本唯一の美しい抒情小曲集である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど私と彼とは密接な兄弟的友情をもつて居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄いもうと」というのを、やっていた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、兄は、それが出来るかも知れない極めて少数のひとの一人だと思います。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまのこの世の中に最も適した表現を以て、諸兄に話かけているだけなのである。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の最初の短篇集『晩年』二百四十一頁を、たった三夜で書きあげた、といったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あれには十年たっぷりかかりまして、と殊勝らしく伏眼でいったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "意の在るところの一端は、諸兄にも通じたように思う。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と當時縣會議員をしてゐた、私の兄が言つてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、兄貴の言葉ではないが、教育界にゐてそんなことをしたからこそ、失敗なので、あれで、當時の政黨にゐて動いてゐたなら、あるひは成功したのかも知れない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴兄の縁談は小生が引継がなければならなくなった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小生と雖も、貴兄の幸福な結婚を望んでいる事に於いては人後に落ちないつもりだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんがいらっしゃったら、きょうは、どんなにお喜びだったでしょうね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟中で自分ひとりだけが、のけものにされているような気がしていた。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのことは附加へなければならないが、私の両親も兄弟も、私が別れた女と同棲してゐたことは知らないのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこへ二階からドヤドヤドヤと降りて来た良子の義理の兄さんが、便所に行かうとして椽側に出ると、其処に猫の食べ物を入れてやるお皿が置いてあるのを見ると、お祖母さんの眼を怖い顔で見ながら、そのお皿を庭の方へ蹴り棄てた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つてお祖母さんも怖い顔になつて兄の方を睨んだ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はお祖母さんの怖い顔には頓着しないで、便所の中に這入ると、きつく戸を閉めてしまつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんと兄とは、昨日の晩、兄の嫁のことから喧嘩をしてゐたが、良子には、それはどんな理由なのか分らなかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良子はそれを、兄がまだ便所にゐるのが気になつて、なぜかゆつくり見てゐることが出来なかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで養子したのが、ゆんべからお祖母さんと喧嘩してゐる兄であつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はそれを聞くと初め一寸は危惧の念に駆られたが、「なあに課業の妨げにはなりませんよなあに」と大きい声で云はれてる中遂に承諾せざるを得なくなつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、今によくなりますよ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに女つてものは昨日さうでも今日は別だよ」　友の所へ行つて昨夜の話をすると友はさう言つてアザ笑つてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは岩の上に大あぐらをかき、瓢のお酒を飮みながら、頬の瘤を撫で、「なあに、こはい事なんか無いさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
