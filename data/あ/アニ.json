            }
          ],
          "literary": [
            {
              "text": "おしまひのはうに、「我國人の間にも豈之が紹介の要無しと言はんや、本書の譯ある徒爾ならざるを信ず。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宜しい、鬼を食つ了ひなさい、と景気をつけて、肥つた奴を、こんがりと南京の中皿へ装込むだのを、私が気をつけて、大事に※つて、箸で哺めたんですが、みでは豈夫と思ふんです。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邵子が橋上に杜鵑の声を聞いて天下の形勢を悟つたといふのも、豈直に杜鵑の声を聞いて而る後に悟るところ有りしならんやである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらなさそうな顔をしてその本を棚に返す……と思ったら大間違いの豈計らんやでげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎にいると、これでも相当の東京通であるが、本場に乗り出すと豈計らんやで、皆から笑い草にされる事が多い。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが豈計らんやである。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈夕陽の印影ならんや。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白薩摩の汚れた単衣、紺染の兵子帯、いが栗天窓、団栗目、ころころと肥えて丈の低きが、藁草履を穿ちたる、豈それ多磨太にあらざらんや。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「豈しからん、この美肉をよ、貴様一人で賞翫してみい、たちまち食傷して生命に係るぞ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣中豈驚かざらんや。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈それ辟易せざらんと欲するも得んや。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつくしき人の、葉柳の蓑着たる忍姿を、落人かと見れば、豈知らんや、熱き情思を隱顯と螢に涼む。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈ひとり居に堪ふべけんや。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いものが歸ると、此の話をして、畜生の智慧を笑ふ筈が、豈計らんや、ベソを掻いた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "流水豈心なからんや。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫式部日記に、ゆまきすがた、といへるは、豈腰にまとふに布のみを以てしたる裸美人ならむや。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりや然うですけれども、家にゐらツしツて見れば、豈夫お先へ戴くことも出來ないぢやありませんか。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈夫に追ン出す氣も無いのだから確に然うでない。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何うなツて了うのだらう、豈夫消えて了うのでも無からうけれども、何處へ行くんだらう。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　豈夫に螢狩とにも謂へぬから、どぎまぎしてゐると、「何か、また螢を捕へに行くんぢゃな。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈夫星光ではあるまいと思ツて見てゐると、確に星光では無い。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈夫パレツトを看板にしてフリ賣もして歩けないじやないか！",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豈天、お前………」とおふくろは何處までも氣の好い挨拶だ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我｜豈に試験の点数などに関せんや」と云ったような考で、全く勉強と云う勉強はせずに居たから、頭脳は発達せず、成績はますます悪くなるばかり。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈図らんや造物の脚色は、綺語の奇より奇にして、狂言の妙より妙に、才子の才も敵する能わざるの巧緻あり、妄人の妄も及ぶ可からざるの警抜あらんとは。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども人智は限有り、天意は測り難し、豈図らんや、太祖が熟慮遠謀して施為せるところの者は、即ち是れ孝陵の土｜未だ乾かずして、北平の塵既に起り、矢石京城に雨注して、皇帝｜遐陬に雲遊するの因とならんとは。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はそれを聞くと初め一寸は危惧の念に駆られたが、「なあに課業の妨げにはなりませんよなあに」と大きい声で云はれてる中遂に承諾せざるを得なくなつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、今によくなりますよ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに女つてものは昨日さうでも今日は別だよ」　友の所へ行つて昨夜の話をすると友はさう言つてアザ笑つてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは岩の上に大あぐらをかき、瓢のお酒を飮みながら、頬の瘤を撫で、「なあに、こはい事なんか無いさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
