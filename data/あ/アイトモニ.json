        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "願くば諸君と相共に国家の為に奮励努力せむ。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其単純なる思想は階級に応じて、武士は武士の思想を継ぎ、平民は平民の思想を受けて、甲乙相共に異色をもつて生長し来りぬ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来同志を糾合し、相共に此問題を研究し来りしが、時機｜稍到来し、茲に一小雑誌を刊行して我が同胞に見ゆるの栄を得たるを謝す。",
              "citation": {
                "source": "「平和」発行之辞",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "相共に憐れむ双鬟の霜といったような劇的シインが期待されていたが、実際は大違いであった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後は秀吉と和し、相共に天下の無事を計りたい考であるから、よろしく御取なしを乞う」と。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆景に賛成したのが宗茂で、相共に奮戦したのである。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はただ相共に天国に見えん事を待つのみである」と呼ばわりながら、見送った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の決戦は未明から黄昏まで続いたけれど勝敗決せず、疲れ果てて両軍相共に退いた。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七節には「かの時には晨星相共に歌い、神の子ども皆歓びて呼わりぬ」とある。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類はここに長い経験の結果を綜合して、相共に依拠すべき範律を作り、その範律に則って自己を生活しなければならぬ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち内芸者の総上げをやり、相共に繰返してうたへる伊那節の唄逢うてうれしや別れのつらさ逢うて別れがなけりやよい　十一月六日　どうも先生一人をお立たせするのは気が揉めていけない、もう一日お伴しませう、と大沢君が憐憫の情を起した。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "相共に上天気を喜びながら宿を出た。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙と紅葉とは本と同じ町に育って同じ学校に学び、或時は同じ家に同宿して同じ文学に志ざし、相共に提携して硯友社を組織した仲であった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の月日を姉と呼び妹と呼んで一棟の寄宿舎に起臥を共にした間柄、校門を辞して散々に任地に就いてからの一年半の間に、身に心に変化のあつた人も多からうが、さて相共に顔を合せては、自から気が楽しかつた寄宿舎時代に帰つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "静子と縁談の持上つてゐる松原家の三男の狷介とは小い時からの親友で、相共に陸軍に志し試験も幸ひと同時に及第して士官学校に入つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の月日を姉と呼び妹と呼んで一棟の寄宿舍に起臥を共にした間柄、校門を辭して散々に任地に就いてからの一年半の間に、身に心に變化のあつた人も多からうが、さて相共に顏を合せては、自から氣が樂しかつた寄宿舍時代に歸つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その相伴うや、相共に親愛し、相共に尊敬し、互いに助け、助けられ、二人あたかも一身同体にして、その間に少しも私の意を挟むべからず。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、相共に死のうとした二人の人物のうちで、どちらが他人の同情をひいたかといえば、それは自動車の運転手であった倉持陸助という青年であった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "間問題相共にその自らの力を試さぬ人と行かじ、彼等の心には隙あり、油断あり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女主人公南家藤原郎女の、幾度か見た二上山上の幻影は、古人相共に見、又僧都一人の、之を具象せしめた古代の幻想であつた。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女主人公｜南家藤原｜郎女の、幾度か見た二上山上の幻影は、古人相共に見、又僧都一人の、之を具象せしめた古代の幻想であった。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新嘗の夜は、神と巫女と相共に、米の贄を喰う晩で、神事に与らぬ男や家族は、脇に出払うたのである。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他者との交渉があり從つて接觸がある限り、相共にする何ものかがなければならぬ。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは單獨なる存在ではなく、相共にある存在、即ちその意味においてすでに世界である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "死は單に主體そのものを見舞ふばかりでなく、主體が相共にある一切の時間的存在者の共通の運命である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は口々に――意味はさつぱりわからぬが――多分「顔が黄色いと思つて甘く見るな」とか、「馬鹿いへ、警官に訴へるぞ」とか、「愚図々々せずに早くやれ」とか、「相共に抱いて海に投ぜん」とか云つてゐるのであらう。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にわれわれ自身のなかにある弱点を、公然と指摘して、相共に、これを克服することに全力をあげねばならぬ。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯次の第七節に言う「かの時には晨星あいともに歌い、神の子たち皆｜歓びて呼わりぬ」と。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔マルホール氏『万国進歩の実況』〕　以上の諸々の発明、諸々の進歩はあいともに協同一致の運動をなし、もって著大なる変化を地球上に生じたり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおれば嬋娟たる美姫を擁して巍々たる楼閣に住し、出ずれば肥馬に跨り、軽車に駕し、隷従雲のごときは全国人民をして風に櫛り、雨に浴し、父子兄弟妻子をしてあいともに離散し、あいともに溝壑に転ぜしめたればなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
