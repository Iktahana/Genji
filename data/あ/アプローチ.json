    },
    "definitions": [
      {
        "index": 1,
        "gloss": "approach (to a problem, issue, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アプローチについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アプローチという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアプローチの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアプローチが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アプローチを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアプローチについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アプローチの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアプローチの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアプローチが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アプローチという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアプローチという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアプローチについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アプローチを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアプローチは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アプローチについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアプローチが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアプローチは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアプローチの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アプローチは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアプローチは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だが理想主義者のおせっかいを存分に発揮してワークステーションがカバーする領域を一挙に拡大しようとするサンの日本市場へのアプローチは、異種格闘技に燃える基本路線の攻撃性とは対象的に、いかにも大人風である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが結局のところ、印刷機の縮小版としてＤＴＰにアプローチせざるを得なかったワークステーション（後に触れるジャストシステムの大地の流儀もこれだ）は、人の手の中にある絵筆と鉛筆の拡張版としてこれに取り組んだマッキントッシュの前に、抵抗らしい抵抗をなしえなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾野に分厚く形成され、今この瞬間にも増殖を続けているパーソナルコンピューターの基盤の大きさを念頭に置けば、下から上を目指すアプローチは常に追い風を期待できる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしあくまで理想主義的なＴＲＯＮ的アプローチも、いわゆるインテリジェント・ビルのような限定的な空間では、成果を上げるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今、これまでの成果を元に分子レベルでの生命へのアプローチが進んでいる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは新手の情報機器、しこうしてその実体はＰＣといったブックマン流のアプローチは、ここで触れている電話絡みのマシンでも今後しばしば採用されるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラが彼女にアプローチをかけているが、慶一の観察では、郁子は高志に気があるようだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップル※やＰＥＴ、ＴＲＳ―80といったパソコン元年を飾った機種に、いかにしてマイクロソフトのベーシックを売り込んだかをとうとうと語りはじめ、新型のパーソナルコンピューターにいかにアプローチしているかを披露する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子式のスイッチとして機能する真空管を使って、ともかく微分解析機に代わる計算機を作るとして開発されたＥＮＩＡＣは、基本的なアイディアは既存の計算機から借りながら、資金にまかせて強引に電子化を推し進めるというアプローチをとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプローチは違っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもアプローチという近距離の打ち方やバンカーという障害物からの打つけいこはできるから、私も仲間にいれてもらった。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドアではアプローチとパターの練習ができないから、コースへでるとスコアはひどくわるい。",
              "citation": {
                "source": "ゴルフと「悪い仲間」",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがいのアプローチに七番を使うとなんとなく間に合う。",
              "citation": {
                "source": "ゴルフと「悪い仲間」",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城山のシャンツェで、諾威の選手や日本の選手が、秩父、高松両殿下にジャンプをお目にかけた時、ある新聞が「アプローチ君八十米を飛ぶ」という見出しで記事を載せた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の名前にはさまって、ヘルセット、スネルスルード、コルテルード等の外国名が入って来るのだから、アプローチを外国選手の名前と考えたのであろうが、これはいさゝか世界記録的の間違いである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプローチとは出発点から飛び台の踏切りまでをいうので、この長さが増せば飛ぶ時のはずみも増すから、飛跳距離も大きくなる。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城の記事は三回飛んだ最後に、アプローチを八十米にしたら、Ａ選手三十何米、Ｂ選手四十何米というのであった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番のグリーンで、どうしてもアプローチができないのだ。",
              "citation": {
                "source": "雪間",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "産業計画会議の勧告書では、第一次五カ年計画の失敗を、アプローチ（取扱い方）のあやまりに帰している。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に目標であるが、それを「あくまで経済的効果で割切ったアプローチ」としている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から五十五年の昔、一九〇二年に、Ｔ・ルーズヴェルト大統領が、開発法にサインした当時から、「経済効果で割切ったアプローチ」というのは、公理であって、誰も気がつかないくらい当り前のことになっている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃になって、「経済効果で割切ったアプローチ」などという勧告を出さねばならないということは、まことに残念であるが、しかし今からでも、この勧告が、要路の人々によって、真面目に考慮されることを願う次第である。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいかに量子力学が発達し、現在のような蓋然的アプローチで統計的に物と物との関係を把握するのではなく、古典力学のように必然的アプローチで一切を認識できるようになったとしても、それだけでは説明されつくせないものがある。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・リーチ，ジェフリー・Ｎ、他（2003）『小説の文体　英米小説への言語学的アプローチ』（筧壽雄監修、研究社）。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにある資料を読んで私も知ったのだけれど、コレクションのためのありとあらゆるアプローチが、すでに誰かによって試みられているのよ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハ・シャツに関しては、ほとんどのアプローチからの研究や調査が、すでにおこなわれているの。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアに向けてのアプローチのかたわらに小さな看板が立っていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭がひとつになった二軒の家の配置、そして脇道から玄関へのアプローチなど、よく似ていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関へのアプローチのかたわらに、棕櫚の樹が一本、ほかの植物に囲まれて立っていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
