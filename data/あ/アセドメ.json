          ],
          "literary": [
            {
              "text": "――襷、汗止め、袴の股立をしっかりと取って、愛剣｜包光二尺八寸を右手に傲然と突立った。",
              "citation": {
                "source": "武道宵節句",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――相手は誰と誰だ」　白布を出して汗止めをし、袴の股立をとりながら、初めて彼はそこにいる青年たちを眺めまわした。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着の肌をぬぎ、汗止めをし、袴の股立をとる、おちつきはらった動作を見ていると、明らかに殺気が感じられた。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東次郎は刀の下緒を外し、それを襷にかけると、ふところからたたんだ晒し木綿を出して、しっかりと額に汗止めをした。",
              "citation": {
                "source": "葦は見ていた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそいぞ」と広一郎が云った、「必ず五時にと云った筈だ、支度しろ」　そして彼は襷をかけ汗止めをし、袴の股立をしぼった。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、せくなよ」と私は呟きました、「一の太刀が大事だぞ」　下緒を取って襷に掛け、汗止めをし、袴の股立をしぼりました。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗止めもそのまま、片手で袴を掴んで、湯気の立っているような顔で、せいせいと荒い息をしている。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗止めはもとより、稽古着も汗びっしょりであるが、これまでに見たことのないくらい力のこもった、精悍な稽古ぶりであった。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすでに汗止めをし襷を掛け、袴の股立をしぼっていた。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下は袴の股立を取り、汗止め襷がけの充分な身拵えである。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の登って行くところから十四五間も右手に、雪まみれになって倒れている者があった……汗止めの白い帛が鮮かに三人の眼にしみた。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、人数は五人、みな襷を掛け汗止めをし、袴の股立を絞っていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、藍花染の小袖に革のたすきをかけ、白い布で、額から後鬢へ汗止めをきりっと締めている侍が、草の中に顔を埋めて、俯つ伏しているのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い汗止めの鉢巻には、一滴の血もついていなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白布の汗止め、キッチリとうしろに結び、思いきって袴を高くひっからげた姿――群集のむかえる眼にも涼しかった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗止めの鉢巻した神後五六郎が、真槍を把って積み重ねてある五斗入りの米俵を、槍にかけては、鮮やかに、宙へ刎ね上げて、怪力を見せていたのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
