        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……赤新聞と言うのは唯今でもどこかにある……土地の、その新聞は紙が青かった。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校の卒業式をもう済ませていることで、両親は赤新聞の種にならないで良かったと安堵した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、去年の秋、俗に赤新聞とよばれている大阪日日新聞の音楽コンクールで、彼の三人の弟子たちが三人とも殆ど最高点に近い成績を取った。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬚をあんなふうに整え、懐から赤新聞をのぞかせている男なら、絶対、賭でつれる。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は品川大井大森方面を縄張にしている匪徒で、丹前は岡本と云う三百代言あがり、揉あげは松山と云って赤新聞の記者あがり、角刈は半ちゃんで通っている博徒であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜畑を見透しの縁――そこが座敷――に足を投出して、腹這いになった男が一人、黄色な団扇で、耳も頭もかくしながら、土地の赤新聞というのを、鼻の下に敷いていたのが、と見る間に、二ツ三ツ団扇ばかり動いたと思えば、くるりと仰向けになった胸が、臍まで寛ける。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から二十四五年以前の事で、新聞紙も今ほど機敏ではなかったろうが、一方にはこんな事を喜んで書き立てる赤新聞もあったろうに、嗅ぎつけられもせず、よし嗅ぎつけられたとしても、それを紙上に出させなかったのは、確かに特筆すべき野村の父の功績といっていゝ、全くこの事は少しも世間に洩れないで済んだらしいのだ。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこの赤新聞で紙を横に流したがつてゐるといふ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の赤新聞にはトオサンなる二世、とでていた由でした。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三大新聞にくらべれば東京新聞は部数の上では二流紙であろうが、その第一面の匿名論説たる放射線欄と云い、文芸欄の小原壮助さんと云い、その論理がいかにも粗雑にすぎて、教養を欠き、暗黒街でしか見られない騒音に類して、あまりにも赤新聞的すぎるようだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを第一面の匿名論説にかかげる新聞の品性というものは三流四流でもなくてゴロツキの赤新聞のようなものだね。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君の自ら持っているという聖火は、単にくすぶっている燈芯のようなもので、諸君がこの聖火をもってなお従前のごとく続けて行くならば、諸君の芸術はやがて、夜店商人の装飾か、赤新聞の小説書きか、安芝居の脚本書きのような職業に堕落してしまうであろう。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、自分にしても、赤新聞が書き立てる醜聞を恐れなければならないような弱いところはすこしもなかった。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大目に見ていればいい気になって、今度こそあの赤新聞の息の根を止めてやる、すぐ、直ぐ、直ぐ連れて来いといってくれたまえ」　十分ほどすると幸田は二人の私服に腕をとられて入って来た。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤新聞の雑報記者なぞ、どうせ文無しにきまっているから。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "選りによって赤新聞社の雑報記者にすっかりこっちの内幕をさとられ、そいつをヌケヌケとホテルから出してやる！",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、また、マンが、小窓の外から、笑いながら、「はい、新聞」　見ると、土地の赤新聞に、大きな見出しで、でかでかと、「コレラの海の中で、すこしも感染しなかった、不思議な二人の不死身男」、そして、金五郎と新之助との写真が、ならべてかかげられてある。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤ、この辺は赤新聞に負う所が多い。",
              "citation": {
                "source": "一枚の切符",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点について、黒田氏は赤新聞で大いに味噌を上げているが、その曰くさ。",
              "citation": {
                "source": "一枚の切符",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味があったら昨日の赤新聞を読んで見給え。",
              "citation": {
                "source": "一枚の切符",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本評論新聞の記者てのが二人、赤新聞のひどいのだ、いろ／＼言って結局年賀広告を出せと言ふのだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大阪の赤新聞に（昨日の読売既載）渡辺篤脱退かといふみだしで、記事が出た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
