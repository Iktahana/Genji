    "definitions": [
      {
        "index": 1,
        "gloss": "appearing to have",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り気について考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り気という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り気の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り気が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り気を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り気について学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り気の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り気の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り気が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り気という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り気という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り気についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り気を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り気は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り気について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り気が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り気は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り気の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り気は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り気は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これを聞いてか嫂が母に注意したらしく、或日母は常になくむずかしい顔をして、二人を枕もとへ呼びつけ意味有り気な小言を云うた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ……　と誰も皆思つたと覚しく、一座の人々は皆意味有り気に眼を見合せた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慈母さん」とお勢は何をか憶出して事有り気に云ッた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、友は愚にも附ん事を言っているのだが、其愚にも附かん事を、人生だ、智慾だ、煩悶だ、肉だ、堕落だ、解脱だ、というような意味の有り気な言葉で勿体を附て話されると、何だか難有くなって来て、之を語る友は偉いと思った。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹心にはことごとく武田家の浪人筋を用い、軍用金として佐渡の黄金を溜めて置き、時機を見て、武田家再興の大陰謀を企てるのじゃで、随分忠勤を励まれよと言い含め、一方公儀に向っては、信州黒姫山の麓には、金脈有り気に見えまするで、佐渡へ上下の折々に試掘致しとう御座りまする。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で好いのを見つけて上げようじゃありませんか」　藤尾は意味有り気に小野さんを見た。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がフト思い付いた事が、自分の予期以上にスラスラと運んで行って、何と云っても憎かろう筈の無い実の子を大びらに家に入れる事の出来たお関はそりゃあ満足して居たには違いなかったけれ共、一方恭吉が自分に向ける意味有り気な眼を気に掛けずには居られなかった。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は、いかにも用事ありげに、そそくさと外出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は――地面は半ば乾いてあつたかい、空を風は、目標ありげにとぶ、梅雨期の或る一日だ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の汽車は、箱根｜火山彙を仰ぎ見て、酒匂川の上流に沿い、火山灰や、砂礫の堆積する駿河｜小山から、御殿場を通り越したとき、富士は、どんより曇った、重苦しい水蒸気に呑まれて、物ありげな空虚を天の一方に残しているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、傍で砂いじりしている子はおいたさんと呼ばれるほどの一くせありげないたずらっ子の男児だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光が力付ける、Ｔ「頑張ってね」　と云われると、仲蔵自信ありげに、Ｔ「頑張る」　先程とは打って変って元気づいた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは目を高い腕附きの椅子からそらして、ちよつとアウグステをばさんの陰気な額の上に休ませて、更に一転して、大いに意味ありげに女主人イレエネの顔に注いだ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからバロツク式の木の柱の立つてゐる、レクトリウムを通つて、その奥の方に行くと、段々暗くなつて、そこには煤けた聖者の像の前に点してある、小さい常燈明が、さも意味ありげに瞬をしてゐる。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼の同棲者が意味ありげにこたえた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、助手の一人がその聲にひよいと聽耳を立てて、私の顏に意味ありげな視線を投げた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」松本は意味ありげにきいた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、田口のなんか事ありげな気配で栗本は直ぐ不安にされた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも宮の下あたりで買ったものらしかったが、教授のなくなった日、室のボーイが自分にこの尾長鶏を指さしながら「このお客さんは、いつも、世の中にこのくらい悲惨なものはないと言っていましたよ」と意味ありげに繰り返して話していた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、半七は例の眼で意味ありげに知らせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、女と見ると、何か仔細ありげに中津に耳打ちをした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高取は、にた／＼意味ありげに笑って、どっしりとした玉田に云った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、含むところありげな眼をした。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送って太郎左衛門が意味ありげに笑います。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と仔細ありげなことをいった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにてもなおものありげにわが顔をみつつ行くが、冷かに嘲るがごとく憎さげなるぞ腹立しき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　海野は太くあらたまりてさもものありげに問懸けたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "跫音乱れて、スツ／＼と擦れつゝ、響きつゝ、駅員の驚破事ありげな顔が二つ、帽子の堅い廂を籠めて、園の居る窓をむづかしく覗込むだ。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時代物の映画で俳優たちのいちばんスチューピッドに見えるのは、彼らが何かひとかどの分別ありげな思い入れをする瞬間である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白石は、コンパスというものかどうか知らぬが、地図に用ありげな機械であるから、私がこの屋敷で見つけていま持って来てある、と言いつつ懐中から古びたコンパスを出して見せた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
