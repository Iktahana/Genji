      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to lay waste",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒らすについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒らすという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒らすの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒らすが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒らすを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒らすについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒らすの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒らすの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒らすが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒らすという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒らすという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒らすについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒らすを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒らすは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒らすについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒らすが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒らすは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒らすの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒らすは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒らすは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また作物を荒らす有害な野鼠や虫類なども捕って食うので農夫にとっては非常に有益なものだそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電気というものは、長い線で山の奥からひっぱって来るもんだでのイ、その線をば夜中に狐や狸がつたって来て、この近ぺんの田畠を荒らすことはうけあいだね」　こういうばかばかしいことを巳之助は、自分の馴れたしょうばいを守るためにいうのであった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気持ちのリズムに添うて、暮さなければ夫の心情を荒らす。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無作法過ぎまさあ、それに勝手に家の中は荒らす、写真は撮る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿では食膳を荒らす恐れがあるから飼わないそうである。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その言葉がいまにも自分の身内へ飛び込んできて、自分の心臓を滅茶めちゃに噛み荒らすような気がするのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "定家卿の『明月記』建仁二年五月四日の条に「〈近日しきりに神泉苑に幸す、その中｜※猟致さるるの間、生ける猪を取るなり、仍りて池苑を掘り多くの蛇を食す、年々池辺の蛇の棲を荒らすなり、今かくのごとし、神竜の心如何、もっとも恐るべきものか、俗に呼びていわく、この事に依り炎旱云々〉」。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、当時後鳥羽上皇講武のためしばしば神泉苑に幸し、猪狩りを行うとて野猪を野飼いにされたので、年々池辺の蛇を食いその棲処を荒らす故、蛇の大親分たる善如竜王が憤って雨を降らさぬと風評したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮でも野鼠殖えて草を荒らす予防に、正月上子の日その蟄伏した処を焼いて野草の繁茂を謀ったので、支那で一月七日に家鼠を饗するを虫焼きと呼ぶも、本この日野鼠を焼き立てる行事があった遺風だろう。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのごとく大黒の槌はガネサの斧の変作で、厨を荒らす鼠を平らぐるが本意とみえる。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "善助　その獲物がないというのも、例の狼めがここらを荒らすせいではないかな。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題については、私のような門外漢が探偵小説の、「温室」を荒らす前に、グループの内部において、もっと自己批判が峻烈に行われているべきであったのだ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野菜や家畜を荒らすようなら、構わないから荒らさせて置け。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の家にも三毛猫が一匹いるが、裏口合せの長屋の猫が質が悪く、毎度こちらの台所を荒らすところから、疑いはその猫に掛かっている様子であります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猫と鼠のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの魂の中には荒らす要素がある。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "足尾銅山の地理も調べずに採掘を許したのが惡いばかりで無い、其上に機械を据付ける、其機械が如何なる働をするか、其採掘がどの位盛大になるものか、此割合を取調べもせず監督もせず、無暗に之を許して關東の地を荒らす。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ではいまだ、パーソナルコンピューターはオフィスコンピューターの市場を食い荒らす敵に育ちきってはいなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "水谷氏は非常に兒島家の好意を喜び、一人の以て此聖跡を荒らすべきで無いとして、斯道のオーソリチーたる坪井博士、それから華族人類學會の牛耳を執らるゝ二絛公爵に通知し、余にも其末班に加はるべく交渉されたのだ。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は多くの蚊よりもたった一匹の蚊、一匹の蚤が寝室を荒らすのを怖れる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この畜生、何だつて、己の煙草畑を荒らすのだ。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　――この畜生、何だつて、己の煙草畑を荒らすのだ。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに彼等の幸福の領分を荒らすやうでちよつと氣のひけたこともひけたが、そのまま其處を過ぎ去つてしまふにはあんまりすべてがその瞬間の自分達に似つかはしく、愉しさうだつた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神殿を荒らす背教者でござるぞ！",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも後者においては姑息なるものに対するはがゆさであるが、前者においては｜荒らす者に対する敵意である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこんどは、彼女が彼の肩に頭をもたせかけますと、女には少しく荒らすぎるその髪を、彼はごく静かに撫でてやりました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の樹を荒らすと言ふので、一九二七年からは六月一日からでないと放牧してはならぬ、五年後には放牧一切罷りならぬと言ふことになつて來て居ります。",
              "citation": {
                "source": "相川おけさ",
                "author": "村松おけさ、佐渡牛などのこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえと同じようなものを別に造ってみろ、いっしょに悪事をはたらいてこの世界を荒らすだろう！",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大抵の御百姓に、この稲は何だなんて聞いても、名を知らないのが多い位に、沢山いろいろと御座います」　話好きな辰さんの父親は、女穂、男穂のことから、浅間の裾で砂地だから稲も良いのは作れないこと、小麦畠へ来る鳥、稲田を荒らすという虫類の話などを私にして聞かせた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を開けて外へ出したらいいんだけど、隣の畑を荒らすからだめだし……」　誠一に名案はないらしい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "………他の獣の窩へ這い込む、蟻塚をやたらに荒らす、蝸牛を殻ごと噛みくだく。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
