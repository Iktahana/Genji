[
  {
    "uuid": "dcb3ecdb-bdf6-5a78-acd0-fd98b4df4e9d",
    "entry": "荒らす",
    "reading": {
      "primary": "あらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
