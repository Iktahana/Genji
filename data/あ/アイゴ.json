        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛護は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛護が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛護に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛護が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛護について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛護についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛護について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛護が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛護が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛護は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛護は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛護を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛護をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛護が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛護の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛護を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛護に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛護について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛護は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛護を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それをひねくり廻している矢先へ通りかかったのが保険会社社長で葬儀社長で動物愛護会長で頭が禿げて口髯が黒くて某文士に似ている池田庸平事大矢市次郎君である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は十分に尊敬し、十分に愛護し、そして其の生長して偉才卓能をあらはすのを衷心より歓迎せねばならぬ。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の学界ではこの思いつきを非常に尊重して愛護し、保有し、また他人の思いつきを尊重する学者が多いのであるが、わが国ではその傾向が少ないようである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いつきはやはり愛護し助長させるべきであろう。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の平坦な部分のまん中にそれが旗ざおのように立っているのがどうも少し唐突なように思われたが、しかし植物をまるで動物と同じように思って愛護した父は、それを切ることはもちろん移植しようともしなかったのであった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俺たちは自分の愛護する芸術のために最後まで戦わねばならない。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして上院議員の最も愛護している店だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢と動物愛　動物の情緒（悲哀や、喜悦や、恐怖やの感情）が、いかに生々しく強烈なものだといふことを、夢の經驗によつて推測するところの人々は、彼等の畜類に對して、自然に同情と理解をもつようになり、基督教的の倫理觀から、動物愛護主義者になる。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが反抗する必要のない、彼らによってまでも愛護されなければならない、虐げられたる女性、それは、虐げられさいなまれて来た労働階級と、よく似た運命を持っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "八節―十二節において彼が神の愛護を述べたとき、彼の心に愛の神は曙の光を発し初めたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来のある時に彼の上にある変動来り、神と彼と相呼ぶに至り、神彼の業を顧み歩みを数えて彼を愛護し、神彼の罪を窺わず、愆と罪を抑えて外に出でざらしむというのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は昔の日に変わらずよく左大臣家を訪ねて行き故夫人の女房たちを愛護してやることを忘れなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を生みし後も宮が色香はつゆ移はずして、自ら可悩き風情の添りたるに、夫が愛護の念は益深く、寵は人目の見苦きばかり弥よ加るのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分を愛護してその道を踏み迷わずに通って行けばいいのを知るようになった。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して時の政府に建言し、枝一本腕一本といふきびしい法度を設けて苗木を愛護し、数代の苦心によつて現在の壮大な松原が出来上つたものださうだ。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介がその次に着手し、成立させたのは、道路愛護會の仕事であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介の周圍の者達は、他村にある道路愛護會の名は知つてゐても、この縣の補助金のことは知らぬものが多かつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月のよく晴れたある日、道路愛護會の會員達によつて、この奉仕勞働は始められた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの道路愛護會は息子の主唱で始められたものだし、この會の幸先を祝ふためにも彼は出ないではゐられぬのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ一本伐つておけば當分いいし、どうせ誰かに伐られるのだから、道路愛護會がもらはうぢやないか、と云ふのであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が發起し、自分が中心となつて村のために始めた道路愛護會の最初の仕事に於て不慮の難に逢つたといふことにも、何か運命的なものが感じられる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの保健運動や道路愛護會の時にも感じたことだが、かういふ公共的な施設や事業に於ては、この村は他村にくらべてもひどくおくれてゐるのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来反動として極端に住民を愛護し、馬糧以外は概して倉庫より給養する事となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さまも民間に残っている話にとくに別な愛護と追惜とをおもちくださいまし。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月三日は動物愛護デーというので外国から来ている貴婦人たちが天皇の子息である少年を左右から囲んで「なごやかな交歓」をした写真が二面に出ている。",
              "citation": {
                "source": "動物愛護デー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『朝日新聞』六月四日）飼主の命令のままに馴らされ、使役される犬猫から牛馬のたぐいは人道的なひとびとによって組織されている愛護デーをもつ。",
              "citation": {
                "source": "動物愛護デー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬を愛するものも愛護される。",
              "citation": {
                "source": "動物愛護デー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ願くは三世十方の諸佛、愛護の御手を垂れて出離の道を得せしめ給へ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論すぺいん人だって普通の感覚は持ってるし、闘牛以外では、ずいぶん人に譲らない動物愛護者のつもりだが――とにかく、メリイ・カルヴィンの場合なんか、メリイには、リングの牛が、不愉快なほど無神経に、愚鈍に見えてしょうがないそうだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論文には予期以上の反響があって、ことに英吉利人が灰色兎・栗鼠・蜂鳥・馴鹿・かんがるう・野犬を襲撃するくだりには、それらの生物に対する氏の同情が切々と溢れ出ていて、ジェネヴァに本部のある万国動物愛護会が特にこの一節の抜粋を番外週報として一般に配布したくらいである。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
