              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "尾世川は藍子のドイツ語の教師であった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "箇人教授をしているのだが、藍子の他に彼に弟子は無く、またあったとしても無くなるのが当然な程、彼はずぼらな男であった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火曜と木曜の稽古の日藍子が彼の二階へ訪ねて行ってもいない時がよくあった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の神さんが藍子に告げる事もある。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の勤め口もその方面の失敗でしくじった事を、藍子は尾世川自身から聞いた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に藍子が、「少し休もうじゃありませんか」と云い出した。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子がそばをおごったりして夜までいるようなことがあった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若きヴェルテルの悩みや名家選集をもって、藍子は二年の間尾世川に教えて貰ったと云うより寧ろ教えさせて来たのであった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の第一火曜日の午後、藍子は小日向町へ出かけて行った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾世川が牛込の方から此方へ越して来てから、藍子も、同じ小石川の向う側の高台へ部屋を見つけたのであった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑った彼女の口元からちらりと金歯の光ったのや、硝子ケースの中にパイプや葉巻の箱を輝やかせている日光が、いかにも春めいた感じを藍子に与えた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、今日はいらっしゃいますよ、さあどうぞ」　店の横にある二畳から真直｜階子を登ろうとすると、神さんは、「ちょいと、三島さん」　変に潜めた声で藍子を呼び止めた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客さまなんですよ」　藍子は、何事かと思った顔をゆるめ、駄々っ子らしく、「なあーんだ」と云い、本包みとショールをそこへ置いた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かと思っちゃった」　神さんは、男の児みたいな藍子の様子にふっと笑いながら座布団を出して来た。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお客さん」「それがね、千束から来た方なんですよ、女の人は来ていないかって――どうも銘酒屋さんか何かの主人らしゅうござんすよ」「へえ」　藍子の、意外そうな表情を見て、神さんは、「あなた何にも御存じなかったんですか」と云った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子は、二畳の敷居へはみ出していた座布団を体ごと引っぱって、顔を店の方へ向けた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ」「そうですか、失礼しました」　送り出してしまうと、尾世川は、「やあ」と云いながら、照れたような生真面目な顔をして藍子の傍へとってかえした。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子はそれを下げて、窓際へ行った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台の中とかに私の所書があったからって来たんですが、……私はそんなことちっとも知りゃしないんですよ」「ひどく不満そうですね」　藍子が、可愛い眼に悪戯らしい色を浮べて笑った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五月蠅いですからね」　藍子は悪意のない皮肉で心持大きい口を歪め、美しい笑いを洩した。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が生れた日の星座がそうだとでもいうのか、五月蠅いことのためばかりに、彼は弟子の藍子に頭が上らないほど身をつめ、しかも欣々然と我が世の重荷を背負っているではないか。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼が植物園へ行くことをしなかったなら、こうであったろうと云う風に……」　稽古も終りかけで、応用作文を藍子が帳面へ書いていると、「ごめん下さい」　神さんが上って来た。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――何だかうまく行かないな――これで通じますか」　ちょいちょい字をなおしながら藍子は帳面を尾世川の方へ向けた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああ出来ましたか」　急いでハガキを置こうとし、猶その方に気をとられ、やっとそれを下へ置いて尾世川は藍子の作文に目を通した。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　風呂敷を結びながら、藍子が何心なく訊きかえした。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、――到頭来たんです」「へえ」　覚えずあげた藍子の顔と尾世川の顔とが正面に向き合ったが、二人とも笑うどころか、藍子は心配そうに、「どこにいるのです？",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子は尾世川に渡されたそのハガキを机の上へ戻した。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……然し何故こんな真似したんだか、どうも……」「判って見れば放っても置けまいが――」　藍子はすっぱり彼女らしい調子で、「どうなさいます？",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、どうも先がどんな気なんだか見当もつかない訳なんです」　藍子は黙って考えていたが、ふっと、「じゃあ私が行って見ましょうか」と云った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あなたにはやはり今も半兵衛さんを大事にするような気持があるのでしょうね」「アイゴ……何も訊かないで下さい」彼女は小さな声で哀れ深く云った。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
