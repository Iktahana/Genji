[
  {
    "uuid": "5f69d206-511f-5279-9efd-db20b01c7aef",
    "entry": "有明",
    "reading": {
      "primary": "ありあけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dawn (esp. from the 16th day of the lunar month onward)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有明について考えている。",
              "source": "幻辞"
            },
            {
              "text": "有明という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有明の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有明が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有明を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有明について学習した。",
              "source": "幻辞"
            },
            {
              "text": "有明の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有明の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有明が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有明という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有明という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有明についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有明を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有明は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有明について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有明が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有明は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有明の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有明は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有明は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや長じて後は、蒲原有明氏や北原白秋氏の作を讀んだ。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "この自選詩集に對する不滿は、蒲原有明氏についても同じであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "自選詩集に採録されてる有明の詩は、彼の中での最も惡い作品であり、多くは修辭的の技巧に凝つて、リリツクの純眞性を喪失してゐるやうなものばかりである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば薄田泣菫氏や蒲原有明氏やは、或る若い時代だけ詩人であり、後に年を取つてからは、本質的にそのリリシズムを喪失してしまつたのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "円かなる夢百里の外に飛んで眼覚むれば有明の絹燈｜蚊帳の外に朧に、時計を見れば早や五時なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時たま特別の来客を饗応でもするときに、西洋｜蝋燭がばね仕掛で管の中からせり上がって来る当時ではハイカラな燭台を使うこともあったが、しかし就寝時の有明けにはずっと後までも行燈を使っていた。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日朝まだきに起き出でて見るに有明の月東の空に残りて雨はなごりなく晴れたり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、靜岡に蒲原有明氏を訪ねた時、有明氏は茶の湯や生花の趣味を愛して居られ、且つ僕にかう語られた。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛蘭西の新しい近代詩を、初めて日本の詩壇に輸入した有明氏からこの言を聞き、僕も深く考へるところがあつた。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君の「詩と告別する」を讀んで、僕は蒲原有明氏の言葉を考へ、當時の僕の感慨を、新しくまた繰返して感慨した。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の君の心境は、おそらく蒲原有明氏と共に、次の述懷をしてゐるだらう。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二期は新體詩から自由詩へ、浪漫派から象徴派に移つた過渡期であつて、その目ざましき完成者は蒲原有明氏であつた。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味で蒲原有明氏は、日本近代詩壇の父とも稱すべき先輩であるだらう。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし有明氏の夫人が※花の指南を職として居られるからである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに此等の青年たちは、最近一二の雜誌に現はれた詩によつて、始めて蒲原有明なる名前を知り、自分等より尚後輩の新進詩人――老年の新進詩人――と思ひ込んで居るのだらう。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも我が田舍における蒲原有明氏は、果して幸福であるかどうか。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村……全詩集中の詩大半薄田泣菫……暮笛集・ゆく春蒲原有明……春鳥集・獨絃哀歌三木露風……廢園・白き手の獵人北原白秋……邪宗門・思ひ出（二重圈點◎を附したのは、特に名詩集たるもの。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありあけながい疾患のいたみから、その顔はくもの巣だらけとなり、腰からしたは影のやうに消えてしまひ、腰からうへには藪が生え、手が腐れ身体いちめんがじつにめちやくちやなり、ああ、けふも月が出で、有明の月が空に出で、そのぼんぼりのやうなうすらあかりで、畸形の白犬が吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながい疾患のいたみから、その顔はくもの巣だらけとなり、腰から下は影のやうに消えてしまひ、腰から上には藪が生え、手が腐れ身体いちめんがじつにめちやくちやなり、ああ、けふも月が出で、有明の月が空に出で、そのぼんぼりのやうなうすらあかりで、畸形の白犬が吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思い切ったる死に狂い見よ」「青天に有明月の朝ぼらけ」と付けたモンタージュと、放免状を突きつけられた囚人の画像の次に「春の雪解け川」を出した付け合わせと、情は別でも、手法においてどれだけの差別があるか。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに俳諧連句にしてみると朝霧やパリは眠りのまださめず　河岸のベンチのぬれてやや寒有明の月に薪を取り込んで　あちらこちらに窓あける音とでもいったような趣がある。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山懐のところどころ、一帯に産出する蜜柑の林に射入る旭に、金色の露暖かなれど、岩の衝と突出でた海の上に臨んでは、路の下を掻い潜って、崖の尾花を越す浪に、有明月の影の砕くる、冬の朝まだ七時というのに、早や吉浜を過ぎ、真鶴を越して、江の浦さして行く途中。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薄の霜に入残る、有明月の消え行く状、覗いている顔が彼方へ、茅萱の骨に隠れんとした、お鶴は続けさまに呼び留められ、あえて危む様子もなく、「あい、私。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日の月の有明に、片頬を見せた風采は、薄雲の下に朝顔の莟の解けた風情して、うしろ髪、打揺ぎ、一たび蚊帳を振返る。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明月の肌寒い光が身にも心にも沁み入って、おもいでは果もなくひろがる、果もない空のように。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよ戀びとよ有明のつめたい障子のかげに私はかぐ　ほのかなる菊のにほひを病みたる心靈のにほひのやうにかすかにくされゆく白菊のはなのにほひを戀びとよ戀びとよ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西暦一九二五年夏東京の郊外にて著者愛憐詩篇夜汽車有明のうすらあかりは硝子戸に指のあとつめたくほの白みゆく山の端はみづがねのごとくにしめやかなれどもまだ旅びとのねむりさめやらねばつかれたる電燈のためいきばかりこちたしや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよ戀びとよ有明のつめたい障子のかげに私はかぐ　ほのかなる菊のにほひを病みたる心靈のにほひのやうにかすかにくされゆく白菊のはなのにほひを。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああげにたへがたくもみじめなる私の過去よながいながい孤獨の影よいまこの竝木ある冬の日の街路をこえてわたしは遠い白日の墓場をながめるゆうべの夢のほのかなる名殘をかぎてさびしいありあけの山の端をみる。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
