[
  {
    "uuid": "611a2135-61a6-5a8f-b913-95c03dc28e00",
    "entry": "仰向き",
    "reading": {
      "primary": "あおむき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
