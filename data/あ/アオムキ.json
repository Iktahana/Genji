      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "facing upward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐは蒲団の上に仰向きになれなくて、暫くは枕に肘を突いてゐたが、つらいことだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく一匹はそこに仰向きに転んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母が髪を結つてたのでその傍にゴロンと仰向きに寝転んだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェンロッカー（錨室）の蓋の上には、安田が仰向きに臥ていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向きに泥だらけの床の上に落ちて、起き直ろうとして藻掻いているのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はゴロッと仰向きに寝転んで、猫を顔の上へあげて来る。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "視感的空間では仰向きの茶わんとうつ向きの茶わん、一里を隔てた山と脚下の山とはあまりに相違したものである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの二三年前、偶然な機会から椿の花が落ちるときにたとえそれが落ち始める時にはうつ向きに落ち始めても空中で回転して仰向きになろうとするような傾向があるらしいことに気がついて、多少これについて観察しまた実験をした結果、やはり実際にそういう傾向のあることを確かめることができた。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで木が高いほどうつ向きに落ちた花よりも仰向きに落ちた花の数の比率が大きいという結果になるのである。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてころりと仰向きに寝ころがった。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとファニーは安楽椅子に仰向きかげんに座を占めた母に抱きついて処きらわず続けさまに接吻していた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、」と離すと、爪を袖口に縋りながら、胸毛を倒に仰向きかゝつた、鸚鵡の翼に、垂々と鮮血。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十　婆が帰った後、縁側に身を開いて、一人は柱に凭って仰向き、一人は膝に手を置いて俯向いて、涼しい暗い処に、白地の浴衣で居た、お雪は、突然驚いたようにいった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛みますか」「いいえ、あなただから、あなただから」　かく言い懸けて伯爵夫人は、がっくりと仰向きつつ、凄冷極まりなき最後の眼に、国手をじっと瞻りて、「でも、あなたは、あなたは、私を知りますまい！",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツは仰向き、一ツは俯向き、横になるもあれば、縦になりたるもありて、風の吹くたびに動き候よ。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして娘が気鬱症にかかるとあすこに……と云った小店員がその言葉と一緒に一寸仰向き加減にした様子が、いかにも娘が、私の部屋の近くにでもいるような気配を感じさせたのに気づくと、娘は私の頭の上の二階にいるのではないかと、思わずしがみついていた小長火鉢から私は体を反らした。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は、うしろに両手をついて仰向き、「僕の作品なんか、まつたく、ひどいんだからな。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧も村の人の後から谷へおりて往って岩の端に仰向き、菅笠を水に濡らさないようにと隻手を笠の縁にかけて、心もち顔を反らしながら口を流れに浸していた。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリツツ・ゼツテルベルグは毛布の帽子をかぶり毛皮の靴をはいたまま仰向きになつて血溜りの中に倒れてゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ臺所には顏をぐざぐざに碎かれた小間使が仰向きに倒れて、床にも家具にも血が飛散してゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へへ、」佐伯は、机の傍にごろりと仰向きに寝ころび、へんな笑いかたをした。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流れ物の中にも仰向きになって両足を水の中にした死骸があって、それは力士のようにぶくぶくと膨れあがっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手づきに、白襟の衣紋を外らして仰向きになんなすった、若奥様の水晶のような咽喉へ、口からたらたらと血が流れて、元結が、ぷつりと切れた。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　謂われて叔母は振仰向き、さも嬉しげに見えたるが、謙三郎の顔の色の尋常ならざるを危みて、「お前、可いのかい。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小稲はわが顔を仰向き見て、「坊ちゃんも何ぞお唄いなさい。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やや仰向き加減に眼を細め、口をすぼめて。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの後、私は専用の雪白の湯槽の中に長々と仰向きになった私自身であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるもの、若きもの、更に稚きもの、商人、学生、教員、画家、牧畜家、官吏、玄人筋らしい老婆と娘、各種の中流階級の人々が、仰向き、横向き、斜め向き、手を曲げ、足を蹴ぬき、潜まり、反り出し、歯をむき、眼をあけ、品よく、或は露わに、卑しく、または素直に子供のように眠りこけていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛のごとく吼ゆるもの、　図体の憎々しく大きく、群獣をぬいて高く怒号するもの、　うそぶき、笑い、闊歩するもの、　孱弱く疲れていざり寄るもの、　ごろりと仰向きに臥ている牡、右の前｜鰭で、はたりはたりと煽いでいるもの、（暑いんだな、あいつ鰭を団扇にしているんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
