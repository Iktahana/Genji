        "examples": {
          "standard": [
            {
              "text": "毎日、合鴨は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合鴨が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合鴨に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合鴨が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合鴨について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合鴨についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合鴨について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合鴨が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合鴨が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合鴨は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合鴨は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合鴨を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合鴨をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合鴨が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合鴨の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合鴨を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合鴨に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合鴨について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合鴨は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合鴨を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "最も根底的な批判は、西表島の〈合鴨農法〉による米作りを、十年かけて一冊にまとめた安渓遊地さんから受けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "農薬を使わず、合鴨に雑草を食わせるというその話を電子本にしないかと誘うと、安渓さんからは言葉の生み出し方そのものへの疑念が返ってきたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "合鴨を買って待っていたのだからと云って十時頃になって夕飯をたべた。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊この頃食ってうまいものに合鴨、あひるがある。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "合鴨の青首はあひると同じ格好で区別がつかぬ。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし煮てみると前歯で皮がプツプツと切れるのが合鴨、切れないでいつまでもしねしねしているのはあひる。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "合鴨のロースが、うまし。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "南へ出て、浜作へ行く、あこの生ちり、小芋、合鴨バタ、茄子田楽、天ぷら食って、宿へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいがものスキでオールドパー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
