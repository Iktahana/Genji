[
  {
    "uuid": "c84a05ff-96f9-5f86-80d8-1faf0a9f149e",
    "entry": "或いは",
    "reading": {
      "primary": "あるいは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "or",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日或いはについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "或いはという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は或いはの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には或いはが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "或いはを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは或いはについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "或いはの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は或いはの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では或いはが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "或いはという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に或いはという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では或いはについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "或いはを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると或いはは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "或いはについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では或いはが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に或いはは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により或いはの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "或いはは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に或いはは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "燈台守は何も知らずに一家団欒の食事を続けていたに違いないし、遭難者は怒濤にもまれて（或いは吹雪の夜であったかも知れぬ）ひとりで死んでいったのだ。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、無謀とも言へるかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここで匙を投げたら、或いは、日本のお伽噺はギリシヤ神話よりも殘酷である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る冬の夜、非常に天候が荒れ（或いは雪の夜だったかもしれません）ました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは新発明とか、創造とかには或いは適さぬ性質かも知れない。",
              "citation": {
                "source": "異性に対する感覚を洗練せよ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは更に二元性を強調して、一部分には平天井を用い、他の部分には懸込天井を用いる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械文明は電灯に半透明の硝子を用いるか、或いは間接照明法として反射光線を利用するかによってこの目的を達しようとする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉苦笑して、Ｔ「俺の鼻の下、も少し　長かったら、或いは　そんな言葉に　有頂天になったかも　知れぬ」　「エッ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは甘みとか、苦しみとか臭さ、そういう性情が生活に適応して、そこに味いとか臭とか、或いは他の感覚が惹起するものなのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗賊がどこからか盗み出して来たのを、邪魔になるので捨てたのか、或いは後の証拠になるのを恐れて捨てたのか、おそらく二つに一つであろうとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみよばかりでなく、不義の相手の自分とても或いは屋敷へ引っ立てられて、どんなわざわいに逢うかも知れないと恐れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いものは小さく、近いものは大きく、遠いものは橙や黄いろではっきりし、近いものは青白く少しかすんで、或いは三角形、或いは四辺形、あるいは電や鎖の形、さまざまにならんで、野原いっぱい光っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらカムパネルラが出て来るか或いはカムパネルラがどこかの人の知らない洲にでも着いて立っていて誰かの来るのを待っているかというような気がして仕方ないらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、彼は、私より一級上であったのが、三学年か四学年の時にいちど落第をして、それで私と同級生になったのではなかったかしら、とも私は思っている。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも秋に関係ない、そんな言葉まで、書かれてあるが、或いはこれも、「季節の思想」といったようなわけのものかも知れない。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは又、孫のハアモニカを、爺に借せと騙して取上げ、こっそり裏口から抜け出し、あたふた此所へやって来たというような感じでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を言っていると、いかにも私は我慢してキザに木石を装っている男か、或いは、イムポテンツか、或いは、実は意馬心猿なりと雖も如何せんもてず、振られどおしの男のように思うひともあるかも知れぬが、私は決してイムポテンツでもないし、また、そんな、振られどおしの哀れな男でも無いつもりでいる。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその翌年に女学校を卒業して、つまり、今は、その叔父さんの悪魔のような予言を、死ぬほど強く憎んでいながら、或いはそうかも知れぬと心の隅で、こっそり肯定しているところもあるのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、十丈の断崖だったら、或いは、こんなことにならなかったかも知れぬ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシャの人たちは、其名をザラツストラ、或いはゾロアスターという偉大な教祖の説を信じていた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いはまた、桃の花を一ぱいに染めてある寝巻の浴衣を着ていると、私は、ご難の楽屋で震えている新派の爺さん役者のようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、ケイ子以上に、感激し握手など求めるかも知れない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一寸からだをひるがえしましたのではねうらが桃色にひらめいて或いはほんとうの火がそこに燃えているのかと思われました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三銭あるいは四銭位です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち不勉強の学生たちを気の毒に思い、彼の知識の全部を公開する事は慎しみ、わずかに十分の三、あるいは四、五、六くらいのところまで開陳して、あとの大部分の知識は胸中深く蔵して在るつもりでいたのだろうけれども、それでも、どうも、周囲の学生たちは閉口した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の詩情には、古い故郷の家を思わせるような、あるいは昔の祖母や昔の家人の、懐かしい愛情を追懐させるような、遠い時間への侘しいノスタルジアがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは少しく解りかけて来たように思われる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは実景であるかも知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
