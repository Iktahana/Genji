        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "承知しながらもとうとう長居になって夕飯をもてなされ七時頃にいとまもうした附記是は赤木格堂が為に先生の病情を見のまま記して送れるなり明治参拾四年二月十五日明治34年３月『俳星』署名　伊藤左千夫",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤革の靴を穿き、あまつさえ、リボンでも飾った状に赤木綿の蔽を掛け、赤い切で、みしと包んだヘルメット帽を目深に被った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、かかる日に病みて伏すやはらかにかなしき畜生の捉へがたき微温の、やるせなきそのこころ……四十三年六月　　隣人隣人は露西亜の地主のごとく、素朴な黒の上衣に赤木綿のバンドを占め、長靴を穿き、禿げた頭のきさくから他の畑を見回る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが同じ熊野でも安堵峰辺で自ら聞いたは、山神女形で、山祭りの日一山に生えた樹木を算うるになるべく木の多きよう一品ごとに異名を重ね唱え「赤木にサルタに猴滑り」（いずれもヒメシャラ）「抹香、コウノキ、コウサカキ」（皆シキミの事）など読む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしこの山神は専ら森林を司り、その祭日には自分の顔色と名に因んで、赤木に猿たに猿滑りと、一種の木を三様に懸値して国勢調査すと伝えたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "春によせし心もいつしかに秋にうつらふ黒木赤木のませのうちによしある花の色々。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時ジャーナリズムには赤木桁平が「遊蕩文学」となづけて排撃した情痴の文学が流行していた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にして備前｜児島に赤木格堂あり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木は即座に妙な句ばかりつづけさまに諳誦した。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は赤木のように、うまいとも何とも思わなかった。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると何ごとにもムキになる赤木は「君には俳句はわからん」と忽ち僕を撲滅した。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時又可笑しかったことには赤木と俳談を闘わせた次手に、うっかり蛇笏を賞讃したら、赤木は透かさず「君と雖も畢に蛇笏を認めたかね」と大いに僕を冷笑した。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは蛇笏を褒めた時に、博覧強記なる赤木桁平もどう云う頭の狂いだったか、「芋の露連山影を正うす」と云う句を「連山影を斉うす」と間違えて僕に聞かせたからである。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで江戸まで出てきたのかというと、疱瘡を病らっているとき、あんまり許嫁の息子とその母親が、顔を気にして見舞いに来るので、ある日、赤木綿の着物に、赤木綿の手拭で鉢まきをし熱にうかされたふりをして、紅提灯をさげて踊り出し気の弱い許嫁｜母子を脅かして、自分の方から愛想ずかしをさき廻りにしてしまった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九日　朝から午少し前まで、仕事をしたら、へとへとになったから、飯を食って、水風呂へはいって、漫然と四角な字ばかり並んだ古本をあけて読んでいると、赤木桁平が、帷子の上に縞絽の羽織か何かひっかけてやって来た。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木は昔から李太白が贔屓で、将進酒にはウェルトシュメルツがあると云うような事を云う男だから、僕の読んでいる本に李太白の名がないと、大に僕を軽蔑した。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に赤木は、「一体支那人は本へ朱で圏点をつけるのが皆うまい。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそこで一杯の酒を持ちあつかいながら、赤木に大倉喜八郎と云う男が作った小唄の話をしてやった。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木は、これも二三杯の酒で赤くなって、へええ、聞けば聞くほど愚劣だねと、大にその作者を罵倒していた。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出たら、このまま家へかえるのが惜しいような気がしたから、二人で電車へ乗って、桜木町の赤木の家へ行った。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると石の門があって、中に大きな松の木があって、赤木には少し勿体ないような家だから、おい家賃はいくらすると訊いて見たが、なに存外安いよとか何とか、大に金のありそうな事を云ってすましている。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "始はマンドリンかと思ったが、中ごろから、赤木があれは琴だと道破した。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、僕はいいが、赤木は向う同志と云う関係上、もっと恐縮して然るべき筈である。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも赤木の雄弁に少し祟られたらしい。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な因縁は此の美育社の資本主の赤木巴山君は、永井君に戀した散髮屋の看板娘を當時愛人として居たことである。",
              "citation": {
                "source": "永井荷風といふ男",
                "author": "生田葵山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが卒業後まもなく、赤木桁平君といっしょに飯を食ったら、君が突然自分をつかまえて樗牛論を弁じだした。",
              "citation": {
                "source": "樗牛の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自分は依然として樗牛はうそつきだと確信していたから、先覚者でもなんでも彼はうそつきだからいかんと言って、どうしても赤木君の説に服さなかった。",
              "citation": {
                "source": "樗牛の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ受付へ行こうじゃないか」――気の早い赤木君が、新聞をほうり出しながら、「行」の所へ独特のアクセントをつけて言う。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸一人が都会に出て、手足にあかぎれ一つ切らさず、楽をしながら出世する。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いあかりで足袋の継ぎはぎをして、皸あかぎれの手を、けちで炭もよくおこさないから……息で暖める隙もなしに、鬼婆の肩腰を、擦るわ、揉むわ、で、そのあげくが床の上下し、坊主枕の蔽いまで取りかえて、旦那様、御寝なれだ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
