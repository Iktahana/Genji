        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗記について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗記という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗記の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗記が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗記を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗記について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗記の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗記の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗記が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗記という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗記という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗記についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗記を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗記は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗記について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗記が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗記は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗記の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗記は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗記は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その耕作法その物は、真に偉い学者が発見したものであるが、その農学士は、唯それを暗記したに過ぎないとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は科学というものの方法や価値や限界などを多少でも暗示する事が却って百千の事実方則を暗記させるより有益だと信じたい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に言語などを機械的に暗記する事の下手な彼には当時の軍隊式な詰め込み教育は工合が悪かった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に、連句三十六景のコンチニュイティは容易に暗記が出来るが、レビューの二十八景の順序は到底覚えられそうもないのである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理のような基礎科学の教科書が根本の物理そのものはろくに教えないで瑣末な枝葉の物理器械や工学機械のカタログを暗記させるようなものでは困ると思う。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的常識というのは、何も、天王星の距離を暗記していたり、ヴィタミンの色々な種類を心得ていたりするだけではないだろうと思う。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は自分たちのもつてゐる名前に關心を持ち、それを大事さうに暗記してゐて、それを彼等に訊ねる者があれば誰にでもそれを言つてやります。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その仕方もいろいろ聞かされたが、僕が如何にも支那人式だなと一｜番感心し、且つ恐るべしと思つたのは、百三十六｜個もある麻雀牌の背中の竹の木目をすつかり暗記してしまふといふいんちき師のことだ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、その暗記の仕方といふのが、先づ日光の中で、次は曇り日、次は夕方、次は電燈、結局最後に蝋燭の光の中でといふ風に明暗の順序を追つて眼を慣らしながら研究暗記し、乏しい明るさの中でもこの木目はこの牌とすぐ分るやうに努力するのだと言ふ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ不正を企るのならば、百三十六｜個の麻雀牌の背中の竹の木目を暗記するなどは、その努力感だけでも僕には寧ろ氣持がいい。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」と彼の暗記しおる公報の一つ、常に朗読というより朗吟する一つを始めた、「敵艦見ゆとの警報に接し、連合艦隊は直ちに出動これを撃滅せんとす、本日天候晴朗なれども波高し――ここを願います、僕はこの号外を読むとたまらなくうれしくなるのだから――ぜひここをやってくださいな。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "主だった星座を暗記していれば素人でも新星を発見し得る機会はあるという事も話した。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "法律の条文を暗記させるように教え込むべきものではなくて、自然の不思議への憧憬を吹き込む事が第一義ではあるまいか。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして教わったものなら、どんなめんどうな数式でも暗記していて、所問に当たろうが当たるまいが、そのままに答案用紙に書き並べるのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただそれを一通り理解し暗記しただけでは自分で話す事もできなければ文章も書けない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりいろいろな符号の意味をすっかり徹底的にのみ込む事はもちろん、またいろいろな公式をかなりの程度まで暗記して、一度わがものにしてしまわなければ実際の計算は困難である。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノオトのおなじ文章を讀み、それをみんなみんなの大學生が、一律に暗記しようと努めてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノオトのおなじ文章を読み、それをみんなみんなの大学生が、一律に暗記しようと努めていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに先方に不幸でもあった場合に、向こうで述べるべき悔やみの言葉を宅から教わって暗記して行って、それをそのとおりに言おうとする時に、突然例の不思議な笑いが飛び出してくるのである。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが毎日同じ事を繰り返している間にあらゆる興味は蒸発してしまって、すっかり口上を暗記するころには、品物自身はもう頭の中から消えてなくなる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体が七五調の歌謡体になっているので暗記しやすかった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪はみんな俺が引き受けてやるからナ……それが俺の人助けの仕納めだ……なぞと親父は毎日のように云って聞かせたので、スッカリその文句を暗記してしまった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『稚な母』って題で連作でしたよ」「…………」「沢山あった歌のなかで一つだけ覚えてて僕暗記してます――鏡のなかに童顔写るこのわれがあはれ子を恋ふる母かと泣かゆ――ねえ、そうでしたね」　突然、かの女は規矩男と若い男女のように並んで歩いている自分に気がついた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらは、十年前に覚えた定義を、そのまま暗記しているだけだ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく試驗が來たけれど、私は博物でも地理でも修身でも、教科書の一字一句をそのまま暗記して了ふやうに努めた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟だけは話からはづれて、窓ぎはをぶらぶら歩きながら英語の單語を暗記してゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルチュアというのは、公式や単語をたくさん暗記している事でなくて、心を広く持つという事なんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの暗記物に堕してしまった。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうときまれば、サイちゃんも立派なおつとめ人だもの、あんきに手足を伸すところもいるわけだね」　耳のうしろから半分吸った煙草を出して、何か思案しながら豆タンの火をつけている秀太郎に、「あの二畳あけたらいいだろう」と云った。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いので中々火がたけず、私はこのゆタンポのにえ上るまでの間に「水車小屋」を二十曲訳してあんきした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
