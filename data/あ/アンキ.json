        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安危について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安危という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安危の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安危が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安危を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安危について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安危の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安危の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安危が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安危という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安危という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安危についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安危を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安危は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安危について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安危が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安危は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安危の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安危は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安危は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それにもかかわらず今日の政治をあずかっている人たちで地震の事などを国の安危と結びつけて問題にする人はないようである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ一時間を無事に保たば、安危の間を駛する観音丸は、恙なく直江津に着すべきなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国の安危にかかわる事です。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府の安危にかかはる事です。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや本件の如き國家の安危に至重至大の關係を有するものに於てをや。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをでかばちに申したら、国家の安危に係わるような、機会がないとも限らぬ、その拇指、その小指、その片手の働きで。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の人間の出処進退の適不適の方が、天下｜蒼生の安危ということよりも大切なのであろうか？",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、忽ち朝鮮一件より日清の関係となるや、儂は曩日に述べし如く、我が国の安危旦夕に迫れり、豈読書の時ならんやと、奮然書を擲ち、先ず小林の処に至り、この際｜如何の計画あるやを問う。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく獄裏に呻吟するの不幸に遭遇し、国の安危を余所に見る悲しさを、儂｜固より愛国の丹心万死を軽んず、永く牢獄にあるも、敢えて怨むの意なしといえども、啻国恩に報酬する能わずして、過ぐるに忍びざるをや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田家程の家の去就は天下の安危に關する。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おしまいには、国家の安危にも、自分の死際にも、呪われた意地につきまとわれているゼラール中尉を憫まずにはいられなかった。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の良し悪しは直に一身の安危になるのですから、不断の注意を怠ってはなりません。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら地球人類の安危は、一にこの問題の解決如何に懸っているのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで神功皇后様には御自ら新羅御討伐の壮挙を御決行あそばす御決心をあそばされ、群臣に、「軍を興し兵を動かすは国の大事にして安危、成敗は繋って焉に在り。",
              "citation": {
                "source": "日本上古の硬外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、そうだったら帝国の安危にかかわる重大使命はどうなるというのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんなんか、大した元気だった」　旗男は一瞬間、直江津の姉たちの安危を思った。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう願かけに、義弟の尊い生命の安危をたくしかねる私の心は、素朴な憤りにふるえた。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先生一身の安危に繋る事情より念ひ到つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想単純の時代というといえども、一は安危の繋がるところ小異を顧みるに遑あらざるがゆえにあらずや。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う動物を生かして置いては、今日の法律に違うばかりか、一国の安危にも関る訣である。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（実を云えばこの代官も、世間一般の人々のように、一国の安危に関るかどうか、そんな事はほとんど考えなかった。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日までは、まだ栖方の新武器が夢だと思っていた先日まで、栖方の生命の安危が心配だったのに、それが事実に近づいて来てみると、彼のことなども早やどうでも良くなって、悪魔の所在を嗅ぎつけようとしている自分だということは、――悪魔、たしかにいるのだこ奴は、と梶は思った。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その口に説くところを聞けば主公の安危または外交の利害などいうといえども、その心術の底を叩てこれを極むるときは彼の哲学流の一種にして、人事国事に瘠我慢は無益なりとて、古来日本国の上流社会にもっとも重んずるところの一大主義を曖昧糢糊の間に瞞着したる者なりと評して、これに答うる辞はなかるべし。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の成否は帝国の安危に係っている。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど一國の存亡安危を背負ふ支那の政治家も、この著しい缺陷をもつて居るのは、困つたことと申さねばならぬ。",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれまで、あわよくば衝角を狙おうと、操舵していたのであったが、船長の決意は、全員の安危に白旗の信号を送ったのであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一身の安危などは上帝の意志に任せてあるのか、やはり微笑を浮かべながら、少女との問答をつづけている。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい娘の身に一家の安危を負担して居る。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に思へ、我日本にても政治の黨派起りて相互に敵視し、積怨日に深くして解く可らざるの其最中に、外患の爰に生じて國の安危に關する事の到來したらば如何するや。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうときまれば、サイちゃんも立派なおつとめ人だもの、あんきに手足を伸すところもいるわけだね」　耳のうしろから半分吸った煙草を出して、何か思案しながら豆タンの火をつけている秀太郎に、「あの二畳あけたらいいだろう」と云った。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
