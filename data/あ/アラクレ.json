[
  {
    "uuid": "67b4483b-3790-509b-ae64-b311a36031d1",
    "entry": "荒くれ",
    "reading": {
      "primary": "あらくれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rough",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒くれについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒くれの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒くれが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒くれについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒くれの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒くれの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒くれが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒くれという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒くれについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒くれは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒くれが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒くれは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒くれの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒くれは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そんなこと自由ぢやないの……」「えゝ、さういへばさうだけど、自由なんて引つぱり出すと却つて不自由だ、怒鳴りたい時は怒鳴るが好いつてのが自由でせう……」「ぢや若し、隣の人達が女だから好いけれど、荒くれ男共だつたら如何するの」　低声で言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの時の相手が龜と子供でなく、まあ、たとへば荒くれた漁師が病氣の乞食をいぢめてゐたのだつたら、あなたは五文はおろか、一文だつて出さず、いや、ただ顏をしかめて急ぎ足で通り過ぎたに違ひないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒くれた漁師と病氣の乞食の場合は、まつぴらなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その姿態は決して荒くれて岩乘な大女ではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳凰山地蔵岳の大花崗岩山は、その峻しい荒くれた膚を、深谷の空気に、うす紫に染めている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかましい税関をくゞり抜けて、禁制品を持ちこむのは、荒くれた男よりも、女の方が、――殊にまだどこかあどけない娘の方が、はるかにやりよかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つのランプの光は赤くかすかに、陰は暗くあまねくこのすすけた土間をこめて、荒くれ男のあから顔だけが右に左に動いている。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌脱の荒くれ男の影鬼の如く映れるあり、乱髪の酌婦の頭の夜叉の如く映るかと思へば、床も落つると思はるゝ音が為て、ドツとばかり笑声の起る家もあり。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の光の中で園がそれを見返った時、荒くれて黝ずんだその幹に千社札が一枚斜に貼りつけられてあって、その上を一匹の毛虫が匐っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の荒くれ馬を四頭雇い入れて、いよいよ馬上、栗生峠を越すことになった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟夫や樵夫の荒くれ男ですら之を魔所と唱えて、昼も行悩む三方崩れの悪所絶所を、女の弱い足で夜中に越そうと云うのは、余りに無謀で大胆であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、荒くれ者の船長が彼の哀れな腕を嗤っただけあって、船の仕事は辛かった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの時の相手が亀と子供でなく、まあ、たとへば荒くれた漁師が病気の乞食をいぢめてゐたのだつたら、あなたは五文はおろか、一文だつて出さず、いや、ただ顔をしかめて急ぎ足で通り過ぎたに違ひないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒くれた漁師と病気の乞食の場合は、まつぴらなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その姿態は決して荒くれて岩乗な大女ではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で十年間、さまざまの人と争い、荒くれた汚い生活をして来た私に較べると、全然別種の人のように上品だった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の主従は左右より屍に取りつき、言葉も無くただ武者振りついて慟哭して、さすがの荒くれた漁師たちも興覚める思いで眼をそむけた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台石から取って覆えした、持扱いの荒くれた爪摺れであろう、青々と苔の蒸したのが、ところどころ※られて、日の隈幽に、石肌の浮いた影を膨らませ、影をまた凹ませて、残酷に搦めた、さながら白身の窶れた女を、反接｜緊縛したに異ならぬ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神と高皇産霊神とはそれをご覧になりますと、急いで天宇受女命をお呼びになって、「そちは女でこそあれ、どんな荒くれた神に向かいあっても、びくともしない神だから、だれをもおいておまえを遣すのである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はそれといっしょに、ふと正気におかえりになって、「おや、おれはずいぶん長寝をしたね」とおっしゃりながら、高倉下がささげた太刀をお受けとりになりますと、その太刀に備わっている威光でもって、さっきのくまをさし向けた熊野の山の荒くれた悪神どもは、ひとりでにばたばたと倒れて死にました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宇陀には、兄宇迦斯、弟宇迦斯というきょうだいの荒くれ者がおりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまたその宇陀をおたちになって、忍坂というところにお着きになりますと、そこには八十建といって、穴の中に住んでいる、しっぽのはえた、おおぜいの荒くれた悪者どもが、命の軍勢を討ち破ろうとして、大きな岩屋の中に待ち受けておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命は建がそう言いおわるといっしょに、その荒くれ者を、まるで熟したまくわうりを切るように、ずぶずぶと切りほうっておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かえりにはまた必ず立ち寄るからとお言いのこしになって、さらに東の国へお進みになり、山や川に住んでいる、荒くれ神や、そのほか天皇にお仕えしない悪者どもをいちいちお説き従えになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はそこから、なおどんどんお進みになって、いたるところで手におえない悪者どもをご平定になり、山や川の荒くれ神をもお従えになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月代の伸びた荒くれ男どもは本職の渡世人らしく、頬冠りや向う鉢巻で群がっている穢苦しい老若は、近郷近在の百姓や地主らしい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがグッジ街の角にたどり着いたところで、その見知らぬ男は数人の荒くれどもに絡まれてしまった。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピータソンはその男を荒くれどもから守ろうと走り出した。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てっきり、私を襲った荒くれ者の一団が、帽子と鳥を持ち去ったのだと思っておりました。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして君のもとへたどり着いたわけだが、その途上、棍棒を手にした荒くれ者に襲われた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
