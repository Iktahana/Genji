[
  {
    "uuid": "b7c33f4e-64c5-5688-a513-77e3f0cd2a61",
    "entry": "飴細工",
    "reading": {
      "primary": "あめざいく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "candy fashioned in human and animal forms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日飴細工について考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴細工という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴細工の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴細工が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴細工を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴細工について学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴細工の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴細工の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴細工が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴細工という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴細工という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴細工についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴細工を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴細工は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴細工について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴細工が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴細工は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴細工の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴細工は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴細工は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　と、あゝ、およしなされば可いのに、借りものの籠に、折つて來たしぼりの山茶花と白の小菊を突込んで、をかしく葉を撮んだり、枝を吹いたり、飴細工ではあるまいし……對をなすものの人がらも丁ど可い。",
              "citation": {
                "source": "鳥影",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも注意深い性質の末造は、わざわざ探るともなしに、この娘が玉と云う子で、母親がなくて、親爺と二人暮らしでいると云う事、その親爺は秋葉の原に飴細工の床店を出していると云う事などを知った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴細工屋の爺いさんの家に、或る朝戸が締まっていて、戸に「貸屋差配松永町西のはずれにあり」と書いて張ってあった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では世間の広くなっている末造の事だから、手を廻して西鳥越の方を尋ねさせて見ると、柳盛座の裏の車屋の隣に、飴細工屋の爺いさんのいるのを突き留めた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治時代までは鉦をたたいて売りに来る飴売りがすこぶる多く、そこらの辻に屋台の荷をおろして、子どもを相手にいろいろの飴細工を売る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飴細工と※粉細工とが江戸時代の形見といったような大道商人であったが、キャラメルやドロップをしゃぶる現代の子ども達からだんだんに見捨てられて、東京市のまん中からは昔の姿を消して行くらしく、場末の町などで折りおりに見かける飴売りにも若い人は殆ど無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七老人と飴細工、それが不調和の対照とも見えなかったが、平生から相当に他人のアラを云うこの老人としては、朝っぱらから飴屋の店を覗いているなどは、いささか年甲斐のないようにも思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飴細工が器用に出来るので、芝居の休みのあいだは飴屋になって稼いでいるんです」　成程その飴売りは三十前後の小粋な男で、役者の紋を染めた手拭を肩にかけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今の人たちは飴細工とばかり云うようですが、むかしは飴の鳥とも云いました」と、老人は説明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、飴細工を飴の鳥と云います。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは飴細工をするのでなく、ぶつ切りの飴ん棒を一本二本ずつ売るんです」「じゃあ、和国橋の髪結い藤次の芝居に出る唐人市兵衛、あのたぐいでしょう」「そうです、そうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくとも理髪店のビラの種類、八百屋や駄菓子屋の店の品物、子供相手の飴細工や※粉細工の注文振りを見ても、ここいらに江戸ッ子が居るなと思わせられるものである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "試にその顔の恰好をいうと、文学者のギボンの顔を飴細工でこしらえてその顔の内側から息を入れてふくらました、というような具合だ。",
              "citation": {
                "source": "ランプの影",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ仲間の飴屋が、大道で飴細工を拵えてゐると、白服の巡査が、飴の前へ鼻を出して、邪魔になつて仕方がない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に其顔の恰好をいふと、文学者のギボンの顔を飴細工でこしらへて其顔の内側から息を入れてふくらました、といふやうな工合だ。",
              "citation": {
                "source": "ラムプの影",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で一番記憶に残っているのは細工飴の店で、大きな瓢箪や橋弁慶なぞを飴でこしらえて、買いに来たものは籤を引かせて、当ったものにそれを遣るというので、私などもよく買いに行ったものだが、いつも詰らない飴細工ばかり引き当てて、欲しいと思う橋弁慶なぞは、何時も取ったことがなく落胆したものだった。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ仲間の飴屋が、大道で飴細工を拵えていると、白服の巡査が、飴の前へ鼻を出して、邪魔になって仕方がない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "角張った絵紙鳶も飴細工であるからは必ず流れ出す。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにしらべてみましょう」　と、甲板のうえから、艦橋が飴細工のように曲っているのを見上げて、しきりに首をふって感心していました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　大利根博士は、竿竹のようにほそい体をいろいろに曲げては、飴細工のように曲ったり溶けたりしている軍艦淡路の艦体をいちいちていねいに見てまわりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴屋などは荷を下して、笛を吹いて子供を寄せて、そこで飴細工をするのでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他｜羽子板、押絵、飴細工、菊人形、活人形、覗機関、声色使の雑技あり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は飴細工の加藤清正である。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人をして僅に自信を保たしむる者は實に此飴細工の加藤清正である。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小物とは大傘を拡げかけてその下で駄菓子飴細工の類を売る者、三寸とは組立屋台を引いて来て帰りには畳んで行く者、転びとは大道へ蓙を敷いて商品を並べるもの、ぼくというのは植木屋、引張とあるは香具師のことである。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "折るとポキリ／＼と丁度飴細工か何かを折るやうに折れるのです。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五条橋の袂を、西東から行き交う人々の顔が、みんな汗にうじゃじゃけて、赤く火照って、飴細工の如く溶けて壊れ出しそうに見えた。",
              "citation": {
                "source": "恐怖",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで飴細工のタヌキみたいな太鼓腹だ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小手先でもヘシ曲がるような飴細工を、清麿の弟子の刀といわれては、おれの名折れだ』『……へ。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まゆ毛をひっぱってみたり、鼻をおさえてみたり、ほおをつねってみたり、あめざいくでもおもちゃにしているようです。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
