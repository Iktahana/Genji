    "definitions": [
      {
        "index": 1,
        "gloss": "anpan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日餡パンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "餡パンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は餡パンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には餡パンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "餡パンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは餡パンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "餡パンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は餡パンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では餡パンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "餡パンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に餡パンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では餡パンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "餡パンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると餡パンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "餡パンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では餡パンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に餡パンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により餡パンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "餡パンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に餡パンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "六　松木は、酒保から、餡パン、砂糖、パインアップル、煙草などを買って来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保山の大阪商船待合所で別府までの切符を買うと、八十銭残ったので、二十銭で餡パンを買って船に乗った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡パンで別府まで腹をもたす積りだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送の巡査が駅で餡パンを買ってくれた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の来るのを待つ間に私たちは幽かに沁み出る額の汗を感じながら、爽やかなアイスクリームの黄を啜り、水筒に水を、弁当鞄にサンドウィッチを、チョコレエトケーキ、餡パン、思い思いに用意した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――麦酒、正宗、サンドウィッチ、サイダァ、牛乳、餡パン、マッチ、新聞、――　あ、坊やの声だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこのノンブルを餡パンのような大きな文字で書くことが好きであった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんはと聞くと、電車ちんちん餡パン買いに行ったなんて、それは面白いことを言いますよ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ餡パンを啣えた宿の小さな子供が出て来て、手橇の柄を掴み、それを動かしてみようとしてうんうんと力み出した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡パンを啣え口を空に向け、ふんぞり返った顔を充血させていたが、橇は微動もしなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち子供は餡パンを一口食べてからまた思い切れずに前に廻った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、餡パンを食ってみたり、押してみたり、唱歌を唄ってみたりしているうちに、時間が来ればあの橇の主が出て来て曳いて行きますよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "依田君もそのかたわらで、大きな餡パンの袋をあけてせっせと「ええ五つ、十う、二十」をやっているのが見える。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、塩せんべいと餡パンとを合わせると、四円ばかりになるんだから、三人とも少々、勘定には辟易しているらしい。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中の廊下に待っていて、僕たちは、おとなの諸君には、ビスケットの袋を、少年少女の諸君には、塩せんべいと餡パンとを、呈上した。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒夫は女中から餡パンを貰ってきた。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は急いで餡パンを隠した。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は首をひょいと縮こめて、眼と眼でにっこり笑み合って、また餡パンを頬張り初めた。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっと手をもっていってみると、そこの所は、餡パンをのせたように、ひどく腫れあがっていました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ン坊をおぶったある…………が、両方に二三人の子供を連れていたが、五銭玉と引換えに一袋の餡パンをツカむと、イキナリ自分の口へもっていったその顔！",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの女房など、女学生時代、ダグラスの「ドンＱ」のとき、ラムネや餡パンをたべては昼飯晩飯の代りにして終日活動小屋へ入つたまま繰返し／＼同一映画を見物したと云ふ。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、桃太郎が生まれなかったらそのかわりに栗から生まれた栗太郎が団子の代わりにあんパンかキャラメルを持って猫やカンガルーを連れてやはり鬼が島は征伐しないでおかないであろう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫にあてがう食事としてはこちらの飯を分けてけずり節を少しかけてやる程度だが、魚類があれば少し分けてやる、生がかったメザシよりは干物の方を好んで食う、またあんパンなんどをつまんでやると飯よりはかえってよろこんで食う、いまの処｜肴よりはかえってパンが好きらしい。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんパンもあんの部分だけは食わない、ビスケットなどは噛んでやればよろこんで食べる、この二ツのうち、三毛の雌の方が丈夫でトラの方が少し痺弱いようだ、組打をしてもトラの方が押され気味で、いつもねわざに受けて居る。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ、お母さんが仏さまにあげておいたあんパンを一つ食べたのだよ。",
              "citation": {
                "source": "もののいえないもの",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時頃から雨になって、母様だけ下松でおり、あんパンやらマンジュウやらの手配をなさり、五時頃かえり、それから又お墓へお詣りなさいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
