        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アピアについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアピアは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アピアの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアピアについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アピアは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアピアの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アピアに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアピアが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアピアを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アピアの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアピアが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアピアが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アピアについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアピアは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアピアは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアピアは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアピアについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アピアの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアピアの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアピアの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "七十｜噸の縦帆船は、マルケサス・パウモツ・タヒティ・ハワイ・ギルバァトを経て一年半に亘る巡航の後、一八八九年の終にサモアのアピア港に着いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は此処で住んで見る気になり、アピア市外に四百エーカーばかりの土地を買入れた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処はアピア市の南方三｜哩、休火山ヴァエアの山腹で、五つの渓流と三つの瀑布と、その他幾つかの峡谷断崖を含む・六百｜呎から千三百呎に亘る高さの台地である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハガードといえば、今、彼の弟が土地管理委員としてアピアの街に住んでいる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、会議及び其の実権者、ツラファレ（大地主）達が王を操っていたのに、今は、アピアの街に住む極く少数の白人が之に代ったのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来アピアには、英・米・独の三国がそれぞれ領事を置いている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアの西郊ムリヌウ岬から其の附近一帯の広大な土地が独逸商会の農場で、其処でコーヒー、ココア、パイナップル等を栽培していた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紛争が続き、結局、独逸は（ビスマルク流の遣り方だ）軍艦五隻をアピアに入港させ、其の威嚇の下にクー・デ・タを敢行した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の夜の中に彼はアピアの街に出て、秘かに前の副王候補者であったマターファに会見し、之に後事を託した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マターファは度々王の軍を破り、ムリヌウから王を追うてアピアの東方ラウリイの地に包囲した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び、英米、殊に米国が正面から之に反対し、各国はそれぞれ軍艦をアピアに急航させて、事態は更に緊迫した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八九年の三月、アピア湾内には、米艦二隻英艦一隻が独艦三隻と対峙し、市の背後の森林にはマターファの率いる叛軍が虎視｜眈々と機を窺っていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の島に於ける白人の生活と政策とに対する彼の非難は、アピアの白人達（英国人をも含めて）と彼との間に溝を作って行った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マターファはアピアの西、七｜哩のマリエに住んでいる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アピア湾で捕れた怪魚の腹に不吉な文字が書かれていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアの街に対しても、王に対しても、島に対しても、一文の金も出さぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は、アピアの一英人の言葉である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアの要人達と会って話して見るのだが、彼等は私を真面目に扱っていないように思われる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、犯人等に自らアピア迄出頭するように命じた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人達は男らしく自らアピアへ出て来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、碇泊中のアメリカ軍艦へ行ってダイナマイトを貰おうとしたが拒絶され、やっと、難破船引揚業者（前々年の大｜颶風で湾内に沈没したままになっている軍艦二隻をアメリカがサモア政府に寄贈することになったので、其の引揚作業のため目下アピアに来ている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏和な、我がへンリ・シメレも今日、「浜（アピア）の白人は厭だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピア市の巡査ではない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂叛乱者側（マターファ側の者をアピア政府の官吏は、そう呼ぶ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアのホテルに泊る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月××日　朝、雨中を馬でアピアへ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アピア政府の反対を冒して、余（マターファ）を助けんが為に雨中を馳せ来りし人物なれば、卿等は以後ツシタラと親しみ、如何なる場合にも之に援助を惜しむべからず。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアでは白人達が納税を拒んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートの底に溜った生ぬるい水に漬りながら、九時近く、やっとアピアに着く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月×日　アピア市婦人会主催の舞踏会に出席。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
