        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天名地鎮について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天名地鎮の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天名地鎮が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天名地鎮について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天名地鎮の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天名地鎮が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天名地鎮という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天名地鎮についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天名地鎮は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天名地鎮が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天名地鎮は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天名地鎮の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天名地鎮は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天名地鎮は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
    ],
