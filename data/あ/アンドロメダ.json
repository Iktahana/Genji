        "examples": {
          "standard": [
            {
              "text": "私は毎日アンドロメダについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンドロメダの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンドロメダが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンドロメダについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンドロメダの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンドロメダが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンドロメダという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンドロメダについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンドロメダは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンドロメダが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンドロメダは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンドロメダの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンドロメダは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンドロメダは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "オリオンは高く　うたい　つゆとしもとを　おとす、　アンドロメダの　くもは　さかなのくちの　かたち。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンドロメダ、　あぜみの花がもう咲くぞ、　おまえのラムプのアルコホル、　しゅうしゅと噴かせ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばアンドロメダにもオリオンにも猟犬座にもみんなあります。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリオンは高く　うたひつゆとしもとを　おとす、アンドロメダの　くもはさかなのくちの　かたち。",
              "citation": {
                "source": "星めぐりの歌",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばアンドロメダにもオリオンにも猟犬座にもみんなあります。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンドロメダ、　あぜみの花がもう咲くぞ、　おまへのラムプのアルコホル、　しゆうしゆと噴かせ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝はいきなり、きんきんした声をあげて、「〆さん、あんたアンドロメダ星座いうのん知ったはる？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝はきんきんと、「〆さん、あんたアンドロメダ星座いうのん知ったはる？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の偉大なる自慢の鼻“Nose-of-wax”は、まんまとへし折られたものの、遠く近く無何有に煌くアンドロメダは金粉となつて降り灑ぎ僕は何も彼も忘れて、光りの雨の中に恍惚とした。",
              "citation": {
                "source": "ユリイカ・独言",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アンドロメダ……？",
              "citation": {
                "source": "海路",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と飛びつくことが出来たのはいつか夕暮時の土星の瞬きが影を没してアンドロメダ星雲が甍の上に燦びやかな翼を拡げてゐる公園の五重塔の下であつた。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると間もなくアンドロメダの渦状星雲が見るも壮麗な大幅を拡げて輝きはぢめるのだ。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――秋らしい澄明な空は、いつの間にかすつかり暮れて森の上にはきらびやかなアンドロメダ星雲が瞬いて、牡牛星に導かれた「七人の花嫁」が微かに流星の彼方に光りはじめてゐた。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殻の蜂の巣にも退屈して、窓掛の間から空を仰ぐと、蝎座の一端から仄かに流れ出てゐる銀河が北方の空高く竜巻山の上に翼を拡げる白鳥座を貫いて、夜更けのアンドロメダを呼んでゐた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八頁図（第二十五図）は天の一部分、すなわち、三角、アンドロメダ、牡羊、及び魚の各星座付近における恒星の運動を示すものである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斗となつたペルセウスは、その天界でひそかにアンドロメダの星のために狙はれてゐた。",
              "citation": {
                "source": "静かなる羅列",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、いま君の云った正方形が、いわゆる天馬星の大正方形であって、天馬座の鞍星の外二星にアンドロメダ座のアルフェラッツ星を結び付け、そうして出来る正四角形を指しているからなんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼女が、ペルセウスとアンドロメダというライトンの絵の写真版を、いつまでもじっと眺めていたことが、変に頭に残っています。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女アンドロメダ其母の罪によりて、海中の怪物の犠牲となり、海浜の岩角に繋がる。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て、ペルソイス遂にかの怪物を斃して、王女アンドロメダを娶る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "320　海魔を殺しアンドロメダを救ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、星座を数える方便として、支那の二十八宿だの、西洋のオリオンだの、アンドロメダスだのというのを、形状と、歴史を以て指し示すと、その位置よりは、伝説としての空想の方に、頭を取られてしまいます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドロメダの辺なり。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
