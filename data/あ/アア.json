[
  {
    "uuid": "2eec08b2-ab4a-5667-baf3-a636306466d3",
    "entry": "嗚呼",
    "reading": {
      "primary": "ああ",
      "alternatives": [
        "あー",
        "あぁ",
        "アー",
        "アア",
        "アァ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
