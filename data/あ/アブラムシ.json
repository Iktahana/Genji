[
  {
    "uuid": "1f607a5e-559e-58be-ae61-b95ca52e1fc9",
    "entry": "油虫",
    "reading": {
      "primary": "あぶらむし",
      "alternatives": [
        "アブラムシ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aphid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油虫について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油虫は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油虫の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油虫について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油虫は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油虫の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油虫に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油虫が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油虫を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油虫の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油虫が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油虫が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油虫について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油虫は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油虫は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油虫は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油虫について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油虫の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油虫の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油虫の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "勝手に雲が飛び、勝手に油虫どもが這い廻っているようであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "拷問の後にほうり込まれた牢獄の中で眼前に迫る生死の境に臨んでいながらばかげた油虫の競走をやらせたりするのでも決してむだな插話でなくて、この活劇を生かす上においてきわめて重要な「俳諧」であると思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かなるわれら杞人の後裔から見れば、ひそかに垣根の外に忍び寄る虎や獅子の大群を忘れて油虫やねずみを追い駆け回し、はたきやすりこ木を振り回して空騒ぎをやっているような気がするかもしれない。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船虫が飛ぼうも、大きな油虫が駈け出そうも料られない。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫よ、私ばかりではないぞ、怒るな憎むな。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟷螂の子は可愛い、油虫の子には好感が持てない。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "戻つて来て、何の変化もない、蜘蛛が網を張り、油虫が這ふだけ！",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "木炭を持つてきてくれないのにフンガイする、油虫の横暴にもフンガイする、フンガイしたところでどうにもならないけれど。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫が新刊歳事記の表紙を舐めて剥がしてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪蚊と油虫とが癪に障る。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曼珠沙華が一輪、路傍の叢に咲き出てゐた、折つて戻つて、机上に飾つてゐたら、油虫が食べてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫をうたふ二句・虫も食べる物がない本を食べたか・這うてきて虫がぢつと考へてゐる　八月廿八日晴、早天、酔うて倒れこんできた樹明君はそのまゝにして出立。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国を立って、しばらくは、線路の両側にただ工場、また工場、かと思えばその間に貧しい小さい家が、油虫のように無数にかたまって建っている、と思うと、ぱらりと開けてわずかな緑地が見えてサラリイマンの住宅らしい赤瓦の小さな屋根が、ちらりほらり見える。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青白い油虫の円陣のまんなかにいて、女ひとりが、何か一つの真昼の焔の実現を、愚直に夢見て生きているということは、こいつは悲惨だ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青白い油虫の円陣のまんなかにゐて、女ひとりが、何か一つの真昼の焔の実現を、愚直に夢見て生きてゐるといふことは、こいつは悲惨だ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟窓からさし込む陽に飴色の油虫が二三びき光った。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫を駆除するためにその一疋を糸で括り、家内一同だんまりで戸より引き出す内、家中の一婦髪を乱して窓に立ち、その虫が閾近くなった時、今夜断食の前に何をたべると問うと、一人牛肉と答え、油虫は何をたべると問うと油虫は油虫をたべると答う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "まじめにこの式を行えば油虫また生ぜずという。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "露人もかくのごとく油虫を同士打ちで死に尽さしめ、さてその全滅を歎き悲しむ表意に、親族が死んだ時のごとく髪を乱してかの式を行うのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫ごとき害虫も家に留むれば福を齎すというはよく考えると一理あり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから上述露国の旧信者が油虫も天より福を持ち下ると言い、『日次紀事』に初寅の日鞍馬寺で福授けの蜈蚣を売ったとあるなど、魔王でも悪虫でも拝めば無害で役に立ちくれると信じての事で、世に近隣の小言を顧みず、ペスト流行にもかかわらず、鼠を多く活かし供養して大黒天に幸いを求むる者の心また同じ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻、蜂、油虫、夜は名の知れぬ虫がしきりにズイズイと鳴き、蛙の声はわくようにした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな死にぞこないの、油虫みたいな奴は、どこへへたばりさらすか知れるかい。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お喋舌の好きな男で、どんな腹の空いた時でも追悼演説を頼まれると、直ぐ出掛けて往つて、宮川氏のやうに悲しさうな詞を料理場の油虫よりも沢山並べ立てて呉れる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一に武士道、二に小猫の尻つ尾、三に竈の油虫……すべて女の嫌ひなものは滅びてゆく世の中である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流声楽家三浦環女史が倫敦に居る頃、女史の周囲には医者や、銀行員や、外交官や、大学の助教授やが油虫のやうに寄つて集つて、御機嫌取りに色々の進物を女史の足もとに持ち運んで来たものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　店員は三越のなかに棲んでるものだつたら、重役から油虫にいたるまで、みんな裕福な生活をしてゐるらしく言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "・土の虫のちぎられたまゝ土にもぐる　月にむいて誰をまつとなくくつわむし　ふけてあぶらむしがはふだけ・住みついて煤のおちるにも（改作）　十月十六日夜あけのしぐれはさびしくわびしく身にしみた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "こほろぎの子、あぶらむしの子、子は何でもかあいらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行が眼新しいのと、場所がいいのと、入場料が安いのと三拍子揃っている上に、天気がよくて、おまけに風がないと来ているので、満場｜立錐の余地もない大入りで、色々な帽子やハンカチが場内一面に蠢いている有様は宛然あぶらむしの大群のように見える。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
