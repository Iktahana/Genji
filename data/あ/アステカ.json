          ],
          "literary": [
            {
              "text": "アステカ人にシラミがたかっていただろうか？",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前1116年にトランのトルテック（＊アステカ人以前にメキシコ高原を支配した民族）人の都市が壊滅したのは発疹チフスの流行によるという言い伝えをディアスおよびレオンは信じている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近オカランザはアステカ王国の疫病の信用することができる記録の総説を書いている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "1564年に不幸なアステカ人は不明な病気によって再び多数が犠牲となった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "アステカ族は発疹チフスを“matlazahuatl”と呼んでいた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしもアステカ族にシラミがたかっていなかったとしたら発疹チフスの流行があったことは全く問題にはならない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にシラミがアステカ族にたかっていたことについては貧乏人がシラミの入った袋をモンテスマへの貢ぎ物としたことについてのオヘダの話以外に資料が無い。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多くの状況証拠はアステカ人にシラミがたかっていたことは殆ど疑うことはできない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "アステカ人はたぶん12世紀の初期にメキシコ高原に達した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスタネダが研究した純粋とは考えられない小グループのアステカ族の子孫は80%、純血のアメリカインディアンは90%またはそれ以上がＯ型であった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことおよび少なくとも２つのアメリカ土着民族の歴史前のミイラにシラミを見つけた事実を考慮するとアステカ族もインカ族も同じようにシラミに取り付かれていたようである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで論じてきた歴史資料とアステカ族にシラミがたかっていた可能性を結びつけるとスペイン人による征服の前に発疹チフスが西半球に存在したらしいということになる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖のアステカ族から受け継いだ魔術で糊口をしのぎました。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
