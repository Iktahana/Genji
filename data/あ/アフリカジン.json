        "examples": {
          "standard": [
            {
              "text": "アフリカ人について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフリカ人は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフリカ人について知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフリカ人の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフリカ人が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフリカ人を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフリカ人が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフリカ人が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフリカ人は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフリカ人は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフリカ人は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフリカ人について学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフリカ人の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフリカ人の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフリカ人の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ディオニシアスは遂にシラキュース人を率いて、それらのアフリカ人と大戦をしました。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその表情の中には、疑いもなくアフリカ人系統の容貌が現らわれていた。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで君はその声の主をアジア人かアフリカ人かであつたかも知れないと云ふだらう。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はアジア人の――アフリカ人の声だったかもしれんと言うだろう。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アジア人もアフリカ人もパリにはたくさんいない。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、若い頃マドロスとして、印度あたりまで行つた時、欧米人などに、どことなく差別的に見られたりして「こいつはいけない」と思つてから、私はヨーロッパ人だから優越してゐるとも思はない代りに、インド人でもアフリカ人でも、支那人でも、朝鮮人でも、私よりも劣つてゐるなどとは思はなくなつてゐた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスーシやチューマたちアフリカ人の忠実な美しい行ひは、アフリカの父たるリヴィングストーンの徳をしたつてのことでありました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アフリカ人の日本人に対する不深切なる原因も、旧来土人および異人種を虐待せし習慣あるによる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、乗客中豪州人と南アフリカ人と両方に相分かれ、綱引きの大競争をなし、豪州人の勝利に帰す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客総計二百八十三人のうち、男百四十二人、女百四十一人、その女子のうち、既婚者七十四人、未婚者六十七人、みな上流の紳士令嬢にして、英人過半を占め、米人これに次ぎ、その他はフランス人、ドイツ人、南アフリカ人等なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にオーストラリア人、南アフリカ人、イングランド人、スコットランド人、アイルランド人の別あれども、要するに大英人種のみである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでもまた政府は年六分の配当を保証しなければならぬというのである（私は今、アフリカ人を北米へ輸出した会社が、株式であったかどうか、何割の配当をやったか不幸にして思い出せない）。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカ人の黒いのよりもなお黒いのがある。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはアフリカ人種の心理学に独特なものである（呪物崇拝、動物の頭を持った神、宇宙の力に反対する地域の神の多いこと）。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　征服者たちの活動　西航して発見されたのはシナでもインドでもなくして、これまでヨーロッパ人もアジア人もアフリカ人も曽て知らなかった全然新しい大陸なのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーイングによると現在生きているインディアンはコーカサス型（白人）とエチオピア型（アフリカ人）のアタマジラミの２種とさらにアメリカ型との雑種を持っていることになる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "また南アフリカで、町（訳注：南アフリカでは黒人居住地区）に移って繊維が少ない西側諸国風の食事を摂るようになったアフリカ人で、直腸ガンのやはり少ないことが確かめられた（166）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "）５　ブルース〈１〉　ブラック・アメリカン　一六一九年の夏、アメリカ植民地の労働力としてはじめてのアフリカ人が、二〇名、ヴァージニア州のジェームズタウンに揚げられた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそれがブルースにあるかは、アフリカ音楽あるいは、アフリカ人がしゃべるときの音声を徹底的に研究すれば、ひょっとしたらわかるかもしれない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "父祖が暗黒大陸から奴隷船で連れ去られてから五世代を隔てても、ほとんどのアフリカ人はそうなのだ。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
