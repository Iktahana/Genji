        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り難やについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り難やという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り難やの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り難やが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り難やを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り難やについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り難やの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り難やの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り難やが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難やという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り難やという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り難やについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り難やを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り難やは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り難やについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り難やが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り難やは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り難やの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り難やは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り難やは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああ、親に会すとのお情け、有り難や、勿体なや。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り難や、正等正覚。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はますますよろこんで、「あゝありがたや、山猫さま。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はますますよろこんで、「ああありがたや、山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても帰れまいと思つてゐたがありがたや敵が残らず脚気で死んだ今年の夏はへんに湿気が多かつたでな。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや阿弥陀様。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おありがたや親鸞様も、おありがたや蓮如様も、それ、この杖に蓮華の花が咲いたように、光って輝いて並んでじゃ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君から来信、私が酒を買ひ、君が下物を持つてくることになつた（酒代は、ありがたや、句集代を樹明君が保管してゐてくれたので、十分、十分、十分である）。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや、ハレルヤとぞ涙ながして讃め祷りませば、雀もともに、ハレルヤ、ハレルヤと眼を上げ涙ながして御空を仰ぐ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランチエスコは御空を仰ぎて、主よ、主の奴僕はかくありぬ、かく貧しきが故にこそ世のあらゆるもろもろの御宝をも却つて主のごとく、この身ひとつに保ちまつる、ありがたやハレルヤとぞ、涙ながして讃め祷りませば、雀もともに、ハレルヤ、ハレルヤと、眼を上げ涙ながして御空を仰ぐ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがたや、ありがたや。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此の殿、聊かものの道理を弁へてゐながら、心得違ひな事は、諸事万端、おありがたや関東の御威光がりでな。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東蔵赤面閉口していると、磐次磐三郎はまたいわく、真の狩人はかくのごときことのみにあらず、なおかくあるべきにとて、さらにまた気を吐けば前の尾嶺に忽然として出現ましませしは南無ありがたや三十三観音、金色燦爛、微妙清音、まんじゅしゃげを雨と降らせたまいてダンスをしたもう。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや朝酒がある（昨日のおあまり）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋからうれしいたよりがあつた、ありがたや、めでたや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや、火鉢に火がある（なさけなや、米桶に米はなくなつてしまつたが）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝蜘蛛果して好事の前兆であるか――果して好事到来だつた、Ｋ社から稿料落手、そしておもひがけなくＴ君から旅費として着金、ありがたや／＼（Ｓから返事のないことは気がゝりだが――）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "又何ものにもまして私に宗教的法悦の感情を印銘したものは、見台の上に延びあがった父が、「はっ、ありがたや、ありがたや」と叫ぶところであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日出来た句の中から、――　はてもない旅の汗くさいこと・このいたゞきに来て萩の花ざかり　山の水はあふれ／＼て・旅のすゝきのいつ穂にでたか・投げ出した足へ蜻蛉とまらうとする　ありがたや熱い湯のあふるゝにまかせ此地は県政上は宮崎に属してゐるが、地理的には鹿児島に近い、言葉の解り難いのには閉口する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明兄から米を頂戴した、これで当分はヒモじい目にあはないですむ、ありがたや米、ありがたや友。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "サケとスシとを与へられた、ありがたや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三派に新大橋がかかつたときありがたやいただいてふむ橋の霜の句がある。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや、かたじけなや。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたやと食べながら、パンのみに生きるに非ずの思いが湧く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたや……とキョロキョロチョロチョロと駈けまわる間もなく、今度は世界が消え失せるばかりの大地震、大噴火、大海嘯が四方八方から渦巻き起る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お江戸となつた元祿のころには、江東にばせをが住んでゐて、大川に、新大橋がかかると、ありがたやいただいてふむ橋の霜。",
              "citation": {
                "source": "大川ばた",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたやの父は、この霊験のあらたかそうなお札を押し頂き、あつく礼を述べたということである。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆連は本当に祭神の化身と信じて、ありがたや、もッたいなや、ナンマンダブ、ナンマンダブと拝んでいる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
