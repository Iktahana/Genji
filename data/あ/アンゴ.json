    "definitions": [
      {
        "index": 1,
        "gloss": "varsika (meditation retreat; usu. for 90 days starting on the 15th day of the 4th month of the lunisolar calendar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安居について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安居という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安居の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安居が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安居を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安居について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安居の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安居の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安居が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安居という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安居という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安居についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安居を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安居は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安居について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安居が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安居は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安居の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安居は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安居は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夏の初めから夏安居に入って、破れ寺の瑞雲寺でも型ばかりの結制を行っていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その習慣が伝わって、後世の夏安居になったという。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれや平常かんぺきの強い師匠への不平が不平を生んで月も七月に入って安居の終りの日が来たのをよい機会に彼等は暇を取り揃って寺を出て行った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十日早く起きたが、そして行乞するつもりだつたが、雨がふりだしたので安居。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生さんは受け取って私の顔をチラリと見たが、私の眼の前で風呂敷を解くと中味は杉折りを奉書に包んだもので黒の水引がかかっていて、その上に四角張った字で「妙音院高誉靖安居士……七回忌」と書いた一寸幅位の紙切が置いてあった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人留まる久しくして、帝これを遣りたまい、今後再び来る勿れ、我｜安居す、心づかいすなと仰す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仍つて早く返し遣る者なりとなれば、旧堵に帰着し、兵事を忘却し、弓弦を綬くして安居しぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天慶二年十二月十五　　　　　　謹※上　太政大殿少将閣賀恩下　此状で見ると将門が申訳の為に京に上つた後、郷に還つておとなしくしてゐた様子は、「兵事を忘却し、弓弦を綬くして安居す」といふ語に明らかに見はれてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和に渇した頭は、とうてい安んずべからざるところにも、強いて安居せんとするものである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和に渇した頭は、到底安ずべからざる處にも、強ひて安居せんとするものである。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後天魔に乗ぜられて犬鬱憤を生じ、われは一切家外の難件に当り、家を衛り盗を捍ぎ、風雨に苦しんで残食と骨ばかり享け、時としては何一つ食わず、それに猫は常に飽食して竈辺に安居するは不公平ならずやと怒る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬ラキムは当時一切の聖賢を凌駕した智犬と崇められ、人争うてこれに飲食を供したが、死後回教の楽土に安居常住すという。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「安居のお妨げ、何とぞお免しくださりませ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見窄らしい安居院の屋根には、疫病やみのやうな鴉が一羽とまつて、をりをり頓狂な聲を出してそこらをきよろきよろ見まはしてゐる。",
              "citation": {
                "source": "飛鳥寺",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高い飛鳥の大佛といふのは、今安居院に殘つてゐる丈六の銅像の事で、お堂の構を少しも取り壞さないで、あれだけの大佛を入れたのは、世にも不思議な手練だと言ひ傳へられてゐる。",
              "citation": {
                "source": "飛鳥寺",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際その時代の知識で、萬が一にも出來ないと信じてゐた事を仕遂げたのは驚嘆すべき不思議で、人間の努力の極致を『可能』に一を加へたものだとすれば、安居院の狹苦しい御堂に丈六の佛を入れたのは、その極致の象徴として見る事が出來る。",
              "citation": {
                "source": "飛鳥寺",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大正十四年八月アララギの安居會（雜誌アララギにて十年以上毎夏催す歌の精進勉強會）その年は高野山において開かれ、それに出席された齋藤茂吉氏がその時高野山で聞いた佛法僧の事を、昭和三年一月四日と五日の時事新報の文藝欄に載せてゐる。",
              "citation": {
                "source": "佛法僧",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "挂塔を免されたのが、去年の霜月であったから、安居はまだ半年に及んだばかりであったけれども、惟念の念頭からは、諸々の妄念が、洗わるるごとくに消えて行った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、一年と安居をしていない彼の道心は、ともすれば崩れかけた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、我らを許して安居を続けられようとも、現在親の敵を眼前に置いては、所詮は悟道の妨げじゃ。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の魂がひとり空堂に安居して、思惟の三昧に耽るとか、または宇宙の霊や艸木の精と黙語点頭するとかいつたやうな、何かしら秘密なものを羽含まうとする場合には、静寂こそはなくてならない唯一のものなのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、残された実の一つは、初めて本然の姿を取り回したらしく、自らが小さな精霊ででもあるかのやうに、寂然として安居してゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の北京は各国軍がそれぞれ駐屯区域を定めていたのだが、日本軍駐屯の北城地域が最も平和で住民が安居し、ロシヤ、フランス、イギリス等の駐屯区域では兵隊が乱暴するので縊死するもの、井戸に投じ、焼死するものが続出し、そうした区域からの避難民は争って日本軍駐屯の北城区域へ避難して来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に防共の第一義は民心を安定し、安居楽業を与える事である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后、物安居士、いく子刀自を訪ふ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然かも父祖の遺業に安居して天産に衣食せる人民は悠々として世故に迂なるを以て四年の水害に苦しみ四年の凶斂に悩み、更に居村滅亡の猾策に遭ふも詭弁甘言の惑ハす処となりて自ら陥穽に墜落するを知らざるなり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "叢林に夏安居して修業したる年数をいう、と末尾に註釈がある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちそれ等の伝説記録等に拠って、屍体飜弄の状況を按見するに、まず劈頭に、棺柩中、もしくは床上に静臥安居しおりたる屍体が忽然として立上り、虚空を走るという形容あり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる事實があるから當時囘教徒の支那に歸化安居したものが隨分多かつたに相違ない。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活力の当面の要求は安居楽業であり、精神的には他から指導されるままに導かれる。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
