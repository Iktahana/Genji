          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "小一の顔色が青瓢箪を俯向けにして、底を一つ叩いたような塩梅と、わしども家内なども申しますので、はい、背が低くって小児同然、それで、時々相修業に肩につかまらせた事もござりますが、手足は大人なみに出来ております。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、方頷粗髯の山本権兵衛然たる魁偉の状貌は文人を青瓢箪の生白けた柔弱男のシノニムのように思う人たちをして意外の感あらしめた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家型というものを強ち青瓢箪的のヒョロヒョロ男と限らないでも二葉亭は小説家型ではなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧羅巴の野菜料理てのは鶯のスリ餌のようなものばかりだから、「ヴェジテラニヤン・クラブ」へ出入する奴は皆｜青瓢箪のような面をしている。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今木刀が浮いて来たら神の救けであるのだが――」　私は水に映つてゐる自分の顔色が、青瓢箪からすつかり色を染め変へて、赤鬼と化してゐるのを発見した。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青瓢箪のような顔をしている青年ばかりこしらえちゃ、学問ができて思想が高尚になったって、なんの役にもたたん、ちと若い者は浩然の気を養うぐらいの元気がなくっちゃいけませんなア」　などという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度｜喀血したことがあつて、口の悪い男には青瓢箪と云はれたと云ふが、現にもと頷かれる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこぎりで蔓先をとめてしまつたので径のへりに尻をむけたこの青瓢箪は、時々雨露をいつぱいふりため、青草を敷いて涼しげに太つてゆくのであつた。",
              "citation": {
                "source": "瓢作り",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦も船酔で青瓢箪みたいに真青な顔をしながら、二人で上陸すると、いや大変な騒ぎなんでびっくりしてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次が、これは、わたしの眼鏡違ひで、飛んだ奴に借りられて了つたのですが、なんでも、小説を書いてるとか書いてないとかいふ青瓢箪、その嬶といふのが、また髪をかう、お河童さんにしやがつて、風呂敷のやうな洋服を着てゐるんですから、なんとも、はや、お話にならん。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述のように、親父の中風、死に続いて、おふくろが気がおかしくなって前の谷川の淵に落ちて半死のまま引き上げられたり、次には女房が四番目の子を産んで以来、まるで青瓢箪のようにふくれてしまい、ずっとぶらぶらのしつづけである。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中姉と私とは在校當時は痩せてゐたので火箸と仇名され、又血色の惡いこと校内三青瓢箪中の二人であつたが、今頑丈にでつぷりと肥えた體格には互におどろき喜びあうたことである。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さっきの青瓢箪はもっとくわしくきいたぜ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青瓢箪が来て、そんなことをきいて行ったか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋ではすぐ栄一に『青瓢箪』と云ふ綽名がつけられた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで頭から、『書生ツポの青瓢箪は生意気だ』と云つて『鉄砲担ぎ』――（屋根に土を運ぶ時に、桶に土を入れて、鉄砲の様に肩にのせて、屋根に上つて行くことを鉄砲担ぎと云ふ）――をやつて居る時でも、無理な註文ばかりするのである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "この煙の中に育った大阪の娘には恋も何も出来ない青瓢箪ばかりかと思っておりました」「まあひどい！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実際、今日までというものは、娘を大切に奥の間に閉じ込めて青瓢箪に育て上げて、品物のようにのしをつけてよそにやりよったのです。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青瓢箪の役者野郎に夢中になつて、働き者の旦那の阿波屋を大事にしないから、あんなことになるんで」　と言つた調子。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐原屋の茂吉は、金に糸目をつけない代り、青瓢箪が化けて出たような男で、これもあまり問題にならず、――もっとも本人は佐原屋の身上をお中元に持って行ってしまいそうな意気込みでしたが、見識の高いお勇は、白い歯も見せたことはなかったでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "手へ着いた血が、四つん這ひになつて梯子段を登る時――」「すると、あの青瓢箪野郎が兄嫁を――」　八がいきり立つのを、平次は手をあげて押へました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の幾太郎と一緒に」　後ろに突っ立って、ブッ切ら棒に挨拶をして居るのは、二十一、二の若い男、八五郎に青瓢箪と形容された、総領の幾太郎です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも親は歴とした旗本だとか言いましたが、臆病でなまくらで、嘘つきで出たら目で、又の名を腰抜け彌八という――」「変な名だな」「剣術を教えてもモノにならず学問を習わせても埒があかず、青瓢箪でヒョロヒョロで、その癖遊芸と女が好きじゃ手のつけようはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、その死にかけて居るのは誰と誰だ、人の命に拘わると聞いちゃ放っても置けまい」「第一番は和泉屋の倅嘉三郎、――練塀小路の油屋で、名題の青瓢箪」「第二番は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十前後の平凡そのものと言った男、少し青瓢箪で、口が重くて、一向に話の埒はあきませんが、さすがに大家を支配して居るだけに、何処かに確りしたところはありそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し青瓢箪ですが、お店者風の良い男で、精々｜二十歳前後でせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幽靈の手紙",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仲間の者に頼んで氣をつけて見張らせてありますがね」「伜が、親父の妾に何うとかするのは、少し不穩當ぢやないか」「十九の青瓢箪が、穩當な惚れやうばかりはしてゐませんよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろあの青瓢箪野郎と來た日にや、煮え切らなくて、欝陶しくて、話をしてゐると、痺がきれるでせう」「それでどうした」　その煮えきらないのに口をきかせて、平次はいろ／＼の手掛りをつかんだことは、八五郎の分別に想像もつかないことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫よりは舌たわばやとおもふに、だん／＼舌長くなり、歯ぎわ後へ廻り、ほぞの下、うしろにては腰尻残らずねぶり、夫からはちらばへ、それより蚊屋ふせり候へば、天井より青瓢箪さがり、長くなり、又、じるくなり、其内にわれ寝入るなり。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、青瓢箪、己を見よ」　再び籠を持って、胸糞悪い爬虫類をどさっと出した。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
