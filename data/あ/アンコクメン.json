    "definitions": [
      {
        "index": 1,
        "gloss": "the dark side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗黒面について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗黒面の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗黒面が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗黒面について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗黒面の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗黒面が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗黒面という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗黒面についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗黒面は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗黒面が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗黒面は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗黒面の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒面は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗黒面は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これは「将に来らんとする私の生活の転機の暗黒面だ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にはそんな暗黒面でない、光明面の思い出はないのかい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大概、これらの言葉は、人間が悲境のときか、人生の暗黒面に見舞われたときに使われる常套語になっております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十の指は我があらゆる暗黒面を指し、却りて我をして我に一光明面なしや否やを思はしめ、我をして自ら己の長を覓め、自ら己の能を衒はしめたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼指は又この影を顧みて自ら喜ぶ情を指して、更に一の暗黒面を得たりとせり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集作業について回る「暗黒面」を、パーソナルコンピューターで彼方に蹴飛ばしてしまうという若き日の夢が現実に変わりつつあると思うと、もういけなくなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に機械になることを求める編集の暗黒面に、マシンでけりが付けられる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし迷信はどこまでも迷信の暗黒面を腰にさげている。",
              "citation": {
                "source": "二つの道",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り憚りなくいうと自然暗黒面を暴露するようになるが、緑雨は虚飾家といえば虚飾家だが黒斜子の紋附きを着て抱え俥を乗廻していた時代は貧乏咄をしていても気品を重んじていた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局書斎の研究ばかりでは満足出来ないで、学者の畑水練は何の役にも立たぬからと、実際に人事の紛糾に触れて人生を味おうとし、この好奇心に煽られてしばしば社会の暗黒面に出入した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必要の前に善悪無し」　この悪魔の標語ポスターは今も尚、新東京の暗黒面の至る処にブラ下がっている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に社会の暗黒面、又は人間の弱点なるものを想像でなく体験する事が出来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の東京の暗黒面を最も深刻に、且つ不可思議な美しさで彩っているは、実にこうした職業婦人なのである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリングは探偵になるまでによく社会の暗黒面に出入りしては人間研究をする癖があったが、探偵になってからは、そうした癖はなくなった。",
              "citation": {
                "source": "ヂュパンとカリング",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の思想は、人間の暗黒面に出逢つて喫驚する程の山出ではなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒面でなく、光明界を出さなければならない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那における考証学亡国論の如きは、固より人文進化の道を蔽塞すべき陋見であるが、考証学者中に往々修養のない人物を出だしたという暗黒面は、その存在を否定すべきものではあるまい。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "且山陽の伊沢氏と狩谷氏とに寄つたのは、山陽の経歴中暗黒面に属する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やまた梶が帰ってみればヒューマニズムの論議が沸き立ち上っている最中であったが、これも仔細に眺めていると、種族の知性と論理の国際性との分別し難い暗黒面から立ち昇っている濛濛とした煙であった。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長がぶらりとやって来て、此様な社会の暗黒面を知るような本を読んではいけないと云った。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、東洋の邪魔者日本に挑戦すべく、猛悪な排日案を挙国一致の一般投票で決議する一方、自国内に於ては資本主義社会に附きものの暗黒面組織をぐんぐん拡大深刻化し初めた頃である。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもまだ十分女の暗黒面を『著聞集』や『今昔物語』などのように露骨に書いてないのは、当時の手本である支那文学にそういう類の物がなかったせいでもありましょうが、一つは男に甚く女の醜い所を見せまいという矯飾の心、後世の道徳家の言葉で申せば貞淑の心から書かなかったのでしょう。",
              "citation": {
                "source": "産屋物語",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申すと、女は大変に暗黒面の多い者、御座の醜める事の多い者であって、それを忌憚なく女自身が書いたら風俗を乱すなどと想う人もありましょうが、女とても人ですもの、男と格別変って劣った点のある者でなく、あるいは美しい点は男より多く、醜い点は男より少いかも知れません。",
              "citation": {
                "source": "産屋物語",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、また話を社会生活の暗黒面へ戻してしまった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも自然主義系統の作家で、社會の暗黒面を容赦なくあばいてゐるところは同じでありますが、到底フランス人のやうに冷血な經驗の分析者であり、絶望的運命觀の上に立つことは出來なかつた處にスカンヂナヴィア人の生地があらはれてゐます。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
