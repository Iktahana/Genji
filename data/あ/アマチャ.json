[
  {
    "uuid": "26c1b47b-2b6e-57dc-9683-c4910ec5b3e4",
    "entry": "甘茶",
    "reading": {
      "primary": "あまちゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Hydrangea macrophylla var. thunbergii (variety of bigleaf hydrangea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘茶について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘茶という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘茶の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘茶が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘茶を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘茶について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘茶の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘茶の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘茶が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘茶という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘茶という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘茶についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘茶を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘茶は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘茶について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘茶が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘茶は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘茶の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘茶は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘茶は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "渋茶、甘茶、渋糟、甘糟、渋皮、甘皮などの反対語の存在も、この対立関係を裏書する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、人に取入ろうとする者は甘言を提供し、下心ある者は進んで甘茶を飲ませようとする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "活惚、活惚、甘茶で活惚、塩茶で活惚、ヨイトナ、ヨイ、ヨイ、……　くるくると二つばかりとんぼがへりをする。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい物としては、甘茶の木だの、三叉の木などがあった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし毎年四月八日の私の誕生日になると、子供たちが大勢来て、私の頭の上を花で飾って、頭から甘茶をかけてお祝いをしてくれます。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞の中甘茶が沸いた茶が沸いた鐘は霞の中で鳴る甘茶がこげた茶がこげた小鳥も霞の中で啼く甘茶がはねた茶がはねた花も霞の中で咲く甘茶が燃えた茶が燃えた鐘は霞の中で鳴る。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "清と山嵐とは固より比べ物にならないが、たとひ氷水だらうが、甘茶だらうが、他人から恵を受けて、だまつて居るのは向ふを一※角の人間と見立てゝ、其人間に対する厚意の所作だ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "清と山嵐とはもとより比べ物にならないが、たとい氷水だろうが、甘茶だろうが、他人から恵を受けて、だまっているのは向うをひとかどの人間と見立てて、その人間に対する厚意の所作だ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺々の鐘が子供を呼ぶと、爺か嬶か姉に連れられた子供が、小さな竹筒を提げて、嬉々として甘茶を汲みに行く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蚕の時に使う栃の木で刳抜いた盆にのせると非常によくはまって、丁度お釈迦様の甘茶の時のように中に小さく桃があって面白いと思ってそれに載せて出したが、その盆にヴェルレーヌの詩句を彫ってあったのを面白く思って買われたのか、然し盆は売る積りではなかったから長谷川さんは弱られたらしい。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦が甘茶で眼病を直すより、もっとわけねえ仕事じゃねえか」「それでもあたしゃ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夕陽新聞なるものは、土台骨ばかり大きくて一向に尻腰のない甘茶新聞とは訳が違い、なにしろ命旦夕に迫っているんだから、もう死物狂いだア。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、かれのそうした様子を見ていた茶目な一塾生が、四月八日の甘茶だといって、タオルにふくませた湯を、かれの頭上にたらたらとかけてやった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "灌仏や捨子則ち寺の児　　　　其角　灌仏というのは、四月八日の釈迦の誕生日に寺で灌仏会というものを修じ、参詣人に甘茶などを配るのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灌仏の日は甘茶を酌んで参詣人に渡したりするために、寺の人も世話して皆総がかりで働いておる、参詣人も多い、そこで多くの参詣人が、「あの児さんが捨子じゃそうな。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佛殿の花御堂に、青竹の杓子を把り、誕生佛のあたまに甘茶を灌ぎ參らせる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月八日の花まつりにはお糸さんと一緒に竜泉寺町の大音寺に甘茶をもらいに行った。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘茶をもらいに行くのは私の役目で、まえの年にはなかやと一緒に行った。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に甘茶をもらってくるだけのことであったが、つい外すというわけにも行かなかったのは、以前貸座敷業を営んでいたときの縁起を祝う習慣が残っていたからであろう。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘茶をもらって家に帰ると私にはもう一つやる仕事があった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寝てるさ」「あきれたお人」「そうだ、明日ならよかった、四月八日の灌仏会だから、甘茶を浴びて、こうしている――」　と、沢庵は、真面目くさって、両足をそろえ、天上天下へ指をさして、お釈迦さまの真似をした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしこそは悉達多太子の生れかわりだ」「お待ちなさい、今、頭から甘茶をかけてあげますから」「いけない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年するように、花御堂の花を摘んできて、灌仏会のお支度をしなければならないし、晩には、甘茶も煮ておかなければいけないでしょう」「――花を摘みにゆくのか。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変なあまちゃんで、発馬して五分後に賭けているのですから。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
