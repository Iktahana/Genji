[
  {
    "uuid": "f485c80c-afa5-546b-af8e-522439e8c455",
    "entry": "安保",
    "reading": {
      "primary": "あんぽ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "security (e.g. national security)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安保について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安保という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安保の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安保が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安保を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安保について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安保の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安保の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安保が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安保という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安保という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安保についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安保を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安保は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安保について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安保が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安保は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安保の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安保は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安保は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何の事はない、美少年録のソレ何だっけ、安保箭五郎直行さ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安保箭五郎悪い事は言わないが、どうだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七〇年安保への反対とベトナム反戦をテーマとしたデモへの参加体験。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六九（昭和四十四）年十月十日、ベ平連、全国全共闘会議、反戦青年委員会など新左翼系の四〇〇団体は、安保粉砕、佐藤訪米阻止などをテーマに、全国五三か所で統一行動を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根河畔なる衝突現場に於ける警官の殴打は治安保護上の必要なりと弁解することを得ん。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、安保条約反対のストの当日である。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍備放棄、安保問題とは別に、釣り師の心得として覚えておくことだとつくづく思った。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は独立を回復したが、しかしその独立は条件つきのもので、アメリカとのあいだには安保条約があり、日本内地には強力な、数多くのアメリカ軍事基地がある。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昨年末とくに日米軍事同盟の性格を有する日米安保条約の改定と強化をし、更に将来はＮＥＡＴＯの体制の強化へと向わんとする危険な動きであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の日米安保条約の改定と日中関係の不幸な状態とは、いずれも関係しあって岸内閣の基本的外交方針であり、アメリカ追随の岸内閣の車の両輪であります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに去年四月の日本社会党中央委員会ではいままでの軍事基地反対運動、平和憲法擁護運動、原水爆禁止運動、沖縄返還および日中国交回復国民運動と日米安保条約体制打破の国民運動を、とくに本年におきましては日中国交回復国民運動と日米条約体制打破の国民運動に力を結集してたたかうことを決定したのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府は現在安保条約を改定する方針を明らかにしている。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この集会に結集したわれわれは決意をあらたにしてあらゆる階層とその要求、行動を統一して安保条約改定を断固阻止し、すすんで安保条約を解消し、アメリカのクサリを断固切り、平和政策を樹立し、中日国交回復を実現しよう。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため社会党は安保条約体制の打破を中心課題としてたたかっているのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この安保条約を廃棄させて日本の平和の保障が確立するならば、すなわち日本が完全独立国家になることができまするならば、中ソ友好同盟条約中にあるところの予想される日本軍国主義とその背後にある勢力にたいする軍事条項もおのずから必要はなくなると私どもは期待をするのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回開かれる国会は、安保条約改定の国民的な処置をつけるための解散国会であろうと思うのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味あいにおきまして、私どもはこんどの選挙をつうじまして、この安保条約の危険性を国民に訴えまして、議会においてはああいう状態になっておるけれども、日本の主権者たる国民が安保条約に対して正しき立場を投票に表わすのが、主権者の任務なりと訴えてまいりたいと考えております。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが党が反対しておる法案は、警察官の職務執行法とかあるいは新安保条約とか、わが国の平和と民主主義に重大な影響を与えるものに対して、この大部分に対して私どもは反対しておるのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、議会政治で重大なことは警職法、新安保条約の重大な案件が選挙のさいには国民の信を問わない、そのときには何も主張しないで、一たび選挙で多数をとったら、政権についたら、選挙のとき公約しないことを平気で多数の力で押しつけようというところに、大きな課題があるといわなければならぬと思うのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば新安保条約にいたしましても、日米両国交渉の結果、調印前に衆議院を解散、主権者たる国民に聞くべきであったと思います。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十九日、二十日に国会内に警官が導入され、安保条約改定案が自民党の単独審議、単独強行採決がなされた。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一度、二十六年秋に、講和、安保両条約の賛否で党内が分れたとき採決をやったが、これが原因で党内左右派が大分裂した。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉ノ大介、宇都宮三河守、小山政朝、武田伊豆ノ三郎、小笠原彦五郎、土岐｜伯耆、芦名ノ判官、三浦｜若狭、千田太郎、城ノ大弐、結城七郎、小田の常陸ノ前司、長江弥六左衛門、長沼駿河守、渋谷遠江守、伊東前司、狩野七郎、宇佐美摂津ノ判官、安保の左衛門、南部次郎。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵七党の一つ、丹党の一族｜安保ノ丹三郎忠実が彼を守った。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、安保ノ丹三郎も供のうちか」「は。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "これへ千寿王さまのお供をしてまいったのは、あらまし安保の人数でございまする」「手柄な者だ。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい、鎌倉武士のほこりは今、どこへ失せてしまったのか」　索莫たるひとみで、味方の陣をながめわたし、そばにいる長崎時光、城ノ越後守、安東高貞、安保ノ道勘、塩田陸奥守らの副将たちの顔へ、「いいのか。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまはんまで寝こんでしまうようになったら、どんならんさかいな」　そんな口を敲くと、他吉は、「何ぬかす、あんぽんたん奴。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんぽんたん」　他吉はまるで火を吹いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、しきりに空を仰ぎながら言ったのへ、「あんぽんたん！",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
