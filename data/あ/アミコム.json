        "examples": {
          "standard": [
            {
              "text": "私は毎日編み込むについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "編み込むという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編み込むの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編み込むが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編み込むを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編み込むについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "編み込むの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編み込むの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編み込むが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編み込むという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編み込むという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編み込むについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編み込むを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編み込むは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編み込むについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編み込むが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編み込むは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編み込むの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編み込むは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編み込むは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "住職のことはこの話にそう編み込む必要がないが、とにかく、かれは僕の室へよく遊びに来た、僕もよく遊びに行った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そしてそのかなり調子のなだらかな言葉を自分の髪の中に編み込む様に耳を被うてふくれた髪を人指指と拇指の間で揉んで居た。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女は、これらの個々の形象を、一つの心の歴史に編み込むことはしなかった。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で批評というのは、批評家の理解や解釈、紹介や説明や、広告、宣伝をさえ通じて、多少とも社会の水準面から孤立した一切の文化物をば、社会の日常的な統一の内に編み込むことなのである。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人代議士ばかりがかたまろうとするならば、その集団の力で内外へ働きかけ、各自の党が、婦人代議士たちの存在に組織的な現実性を賦与するよう、組織の内部へ正直に婦人代議士をも編み込むよう活動することに、最良の、そして最も適切な方向がある。",
              "citation": {
                "source": "一票の教訓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
