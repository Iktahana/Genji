[
  {
    "uuid": "d64a2857-9811-576f-aab6-5acd75cee9c3",
    "entry": "あいうえお",
    "reading": {
      "primary": "あいうえお",
      "alternatives": [
        "アイウエオ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese syllabary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、あいうえおは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではあいうえおが重要です。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではあいうえおが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室であいうえおについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からあいうえおについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではあいうえおについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではあいうえおが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではあいうえおが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあいうえおは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてあいうえおは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にあいうえおを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にあいうえおをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議であいうえおが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、あいうえおの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はあいうえおを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はあいうえおに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断であいうえおについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からあいうえおは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはあいうえおを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "本体はマイクロコンピューターを使ったシステムで組み、テレビとのインターフェイスを付けて「あいうえお」の文字を順に画面上に表示していく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上に「あいうえお」を順に出していき、確定された文字を引き取って文章を続けていくプログラムは、玉城重信が中心になってすぐに書き上げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なので、このお遊び訳でも、あいうえお作文のうち「ぬ」と「ね」は似てるだろうってことで、「ね」を飛ばしたりしております。",
              "citation": {
                "source": "あップルパイを",
                "author": "ケイト・グリーナウェイ　え",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
