    "definitions": [
      {
        "index": 1,
        "gloss": "clouds in the sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天雲について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天雲という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天雲の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天雲が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天雲を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天雲について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天雲の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天雲の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天雲が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天雲という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天雲という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天雲についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天雲を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天雲は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天雲について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天雲が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天雲は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天雲の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天雲は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天雲は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中禅寺の湖をながめて天雲のいはひもとほる湖の上に眞白片帆の舟歸る見ゆ歌袋歌滿ちあふるなめ革のかはり袋のありこせぬかも歌袋の歌は文して格堂にからかいやりしなり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨ふれば北にたなびく天雲を君によそへてながめつるかな」、「北へ行く夕の雲の大空にかさなるみれば雨はふりつゝ」などいへる、地異なり時異なれば、たがひあるべき道理ながら、思ひくらぶれば、如何にも那方かいつはりなるべきやう浅まなる心には思はるゝを免れず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天雲のあをくたなびく大き陸かく古も和したまひき。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河なる沼津より見れば富士が嶺の前に垣なせる愛鷹の山愛鷹の真黒き峰にまき立てる天雲の奥に富士は籠りつ　先づ愛鷹の山が見える。",
              "citation": {
                "source": "村住居の秋",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "光明は闌干として天雲のあなたに流れ、千萬の瓦斯の燈は金光の林の如く、鐵路、軌道を投げて憚ることなく、佯の幸福を追へば、富貴と勢力とこれに伴ふ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とあたゝかい手紙が――澄太君をして迎田さんから――ふと思ひ立つて山口へ行く、途上、冬村君に逢ふ、ニコ／＼してゐる、その筈だ、今夜が婚礼だといふ、一天雲なし、めでたい／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天雲なくして暑い、まだ梅雨のうちだのに。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……やがて日本晴だ、一天雲なし、ありがたいな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても好いお天気、すこし風はあるが、一天雲なしで、青空の澄んだ深い色は何ともいへないうつくしさである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天雲なし、ほがらかな日である。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小春日和のうらゝかさ、一天雲なし、気分ほがらか。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一月廿五日　晴、行程三里、佐志、浜屋（二五・上）一天雲なし、その天をいたゞいて、湊まで、一時間半ばかり行乞、近来にない不所得である、またぶら／＼歩いて唐房まで、二時間行乞、近来にない所得だつた、プラスマイナス、世の中はよく出来てゐます。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天雲なく腹裡一物なし、そして途上二句だけ拾つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・青空の筍を掘る・春山の奥から重い荷を負うて鮮人・蕗のうまさもふるさとの春ふかうなり　四月廿八日けふも晴れてつめたい、きのふのやうに一天雲なし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は千木が天雲に隠れる程大きな建築であつた。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天雲の上をかけるも谷水をわたるも鶴のつとめなりけり」――こう自ら歌ったほど、彼の薬を請うものは、上は一藩の老職から、下は露命も繋ぎ難い乞食非人にまで及んでいた。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさ日の光りゆふ光りかれとこれとの染め替ふるたくみもよしや天雲の輕羅のころも花ごろも曳くやもすその紅に詩神の影を君見るや。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻第三　　　　　　　　　　　○大君は神にしませば天雲の雷のうへに廬せるかも　〔巻三・二三五〕　柿本人麿　天皇（持統天皇）雷岳（高市郡飛鳥村大字雷）行幸の時、柿本人麿の献った歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長歌の方は、「父母を見れば尊し、妻子見ればめぐし愛し、世の中はかくぞ道理」、「地ならば大王います、この照らす日月の下は、天雲の向伏す極、谷蟆のさ渡る極、聞し食す国のまほらぞ」というのが、その主な内容で、現実社会のおろそかにしてはならぬことを云ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻九（一七〇〇）に、「秋風に山吹の瀬の響むなべ天雲翔る雁に逢へるかも」とあって、やはり人麿歌集にある歌だから、これも人麿自身の作で、上の句の同一手法もそのためだと解釈することが出来る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○思はぬに時雨の雨は零りたれど天雲霽れて月夜さやけし　〔巻十・二二二七〕　作者不詳　思いがけず時雨が降ったけれど、いつのまにか天雲が無くなって、月明となったというだけのものであるが、言葉がいかにも精煉せられているようにおもう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途に、「天雲のたゆたひ来れば九月の黄葉の山もうつろひにけり」（同・三七一六）、「大伴の御津の泊に船｜泊てて立田の山を何時か越え往かむ」（同・三七二二）などという歌を作って居る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日は秋ばれの一天雲もない好天気。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　多爾具久とクグツ　我が古語に遍満行き渡らぬ所なきことを表わして、「天雲の向ふす極み、タニグクのさ渡る極み」、或いは「タニグクのさ渡る極み、潮沫の留る限り」、或いは「タニククのさ渡る極み、かへら（櫂歟）の通ふ極み」、或いは「山彦の答へん極み、タニグクのさ渡る極み」などいう成句がある。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮風歇みて一天雲翳なし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "降雪中の街の景色と、屋上における観測の場面とがなくては、どうにもシナリオが書けないので、毎日待っているが、夕方になると一天雲もない空の地平線近くが薄紫色に霞んで、春の光の兆しが見えるような日ばかり続いて如何にも心細かった。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）熱帯圏中路、火輪蹴浪趨、暮天雲断処、夕日赤於朱。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "海暗狂風捲怒濤、不知何処是西濠、暁天雲破吐紅旭、認得北涯山影高。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
