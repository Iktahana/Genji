    },
    "definitions": [
      {
        "index": 1,
        "gloss": "abstract (e.g. art, music)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アブストラクトについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアブストラクトは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアブストラクトについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアブストラクトの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアブストラクトが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアブストラクトを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアブストラクトが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアブストラクトが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアブストラクトは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアブストラクトは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアブストラクトは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアブストラクトについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アブストラクトの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアブストラクトの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアブストラクトの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "残りの大多数の人たちは、そういう少数の信用ある批判者の批判の結果だけをそのままに採用して、そうしてその論文のアブストラクトと帰結とだけを承認することになっている。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも芸術が常になによりもまず新奇を目がけることは是非の問題ではなくて芸術の運命のようなものでしょうから、君たちの多くがシュールやアブストラクトやアンフォルメなどへ自ら方向をとろうとしていることには、強い必然性があります。",
              "citation": {
                "source": "絵画について",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりがシュールやアブストラクトはいつでも描けるがすぐ飽きる。",
              "citation": {
                "source": "絵画について",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解釈」から絵を描けば、一方において唯美主義やデカダンスが生れ、一方においてキュービズム、アブストラクト、シュールその他が生れる。",
              "citation": {
                "source": "ゴッホについて",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在、パリその他に、アブストラクトやシュールを批判して否定して、もう一度強固な人生と実在を踏んまえて立とうとしつつ素朴なリアリストたちの動きが現われて来つつあるのはそれだろう。",
              "citation": {
                "source": "ゴッホについて",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家具調度のたぐいもアブストラクトふうの最新様式のものがそろえてあった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
