      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "greeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、挨拶は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは挨拶が重要です。",
              "source": "幻辞"
            },
            {
              "text": "挨拶に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では挨拶が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で挨拶について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から挨拶についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では挨拶について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では挨拶が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では挨拶が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に挨拶は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において挨拶は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に挨拶を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に挨拶をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で挨拶が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、挨拶の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は挨拶を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は挨拶に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で挨拶について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から挨拶は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは挨拶を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「僕、邪魔はしないからねえ、邪魔はしないからねえ」と、みんなの者に云つたのがその時の挨拶であつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなむしろ邪魔されて欲しいくらゐのところへ、この挨拶は、一寸ツカないものであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暫くでした」とあんな奴が三田村の肩越しに挨拶した。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――（少し早口になる）「私は自分が向ふへ歩いてゐるのか、自分が向ふから蒼白い顔で歩いて来てるのか分らない時がある――十字路で、みんなの元気な顔、殊には出遇つて互に喜ばしさうな挨拶を交はしてゐる人達をみる時。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、あれほど禮儀正しく、應接の家人と丁寧な挨拶をする芥川君が、この日に限つて取次ぎの案内も待たず、いきなりづかづかと私の書齋に蹈み込んできた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私の顏を見るとすぐ、挨拶もしない中に芥川君が話しかけた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が近づいていって、やあ、と馬場に声をかけたら、菊ちゃんが、あ、と小さく叫んで飛びあがり、ふりむいて私に白い歯を見せて挨拶したが、みるみる豊かな頬をあかくした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光虫は私たちに一言の挨拶もせず、溶けて崩れるようにへたへたと部屋の隅に寝そべった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小坂氏は部屋へあがって、汚い畳にぴたりと両手をつき、にこりともせず、厳粛な挨拶をした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、またひとり、三十ちょっと前くらいの美しい人があらわれ、これもやはり、姉でございます、という御挨拶をなさるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いろの着物を着て、はにかんで挨拶した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすは瀬川先生のとこへ御挨拶に行け。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の挨拶が滑稽だといつて笑はれるがよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも折には矢も楯も堪らない程訓辞の必要を感じたが、そしてまた実際腹案を立てゝ登校したこともあつたが、教員室に覗いて教師達から威勢の好い挨拶をされるともうその勇気はなくなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "候補者なる人は、来ると先づ校長に挨拶した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝もＭのおつ父さんに会つたがね、あれはお前が入学当時の成績のことを思つて、あなたのお子さんはよくお出来でつて挨拶をしたが私は冷汗が出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知つてゐても知らない振でさう私に挨拶したのだよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸挨拶を済ますと、彼は直ぐ引つ込んだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが母に挨拶してゐる時に、後ろでも一人の客は吹き出してゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう「御大事になさい……」といふ挨拶をされた晩から、三週間ばかりも経つてゐるが、そして指のキズは従兄のためにはもはやトツクに癒つて好い頃だが、いまだにＳ子の所に行く時、彼は繃帯をして行く……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "初対面の挨拶もすんであたりを見廻した。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで行く船に苅谷氏も乗り居てこれも今日の船にて熊本へ行くなりとかにてその母堂も船窓より首さしのべて挨拶する様ちと可笑しくなりたれど、じっとこらゆるうちさし込む朝日暑ければにや障子ぴたりとしめたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島木さんの事について何か書くようにとの御手紙を頂きましたので、考えてはみましたが、私は同氏から稀に御手紙は頂戴しておりましたものの、御目にかかったのは前後にただ一度だけ、それも宴会の席上でちょっと御挨拶をしたばかりでありまして、同氏の追憶と云っては別段に申上げるほどの資格も御座いません。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の頭の上へ逆さまに汗臭い油ぎった顔をさし出して、むつかしい挨拶をしむつかしい質問をしかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御尊父様へよろしく」と改まったる御挨拶で。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ色の青い恐ろしく痩せた束髪の三十くらいの女をつれた例の生白いハイカラが来て機関長と挨拶をしていたが、女はとうとうこの室の寝台を占領した。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長の処へ挨拶に行ったら、仕方がないまたやるさと云ってくれた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕口を言はず、駄洒落を飛ばさないから、Ｋ君をユーモリストだと誰も思はないけれど、挨拶をさせたり、序文を書かせたりしたら、Ｋ君のものは天下一品だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお爺さんは、猿や兎や山鳩に、いちいち上機嫌で挨拶して林の奧に進み、山櫻の大木の根もとが廣い虚になつてゐるのに潛り込んで、「やあ、これはいい座敷だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と聖人は、頬被りをとつて莊重に朝の挨拶をする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
