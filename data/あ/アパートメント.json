        "examples": {
          "standard": [
            {
              "text": "アパートメントについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアパートメントは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアパートメントについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアパートメントの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアパートメントが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアパートメントを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアパートメントが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアパートメントが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアパートメントは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアパートメントは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアパートメントは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアパートメントについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アパートメントの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアパートメントの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアパートメントの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "我れ非情の妻と別れてより、二兒を家郷の母に托し、暫くこのアパートメントに寓す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにしなくても市中の地の底へ何層樓のアパートメントでも建てた方がよささうに思はれる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傲がんなこころがすこしの反省もなく、イズモ町の彼女経営の流行品店を素通りして、築地河畔のコルビジェ風のアパートメントの一室を訪れた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、夙川のアパートメントの独身部屋をノックする音で私は眼ざめました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにしなくても市中の地の底へ何層楼のアパートメントでも建てたほうがよさそうに思われる。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お茶の水のアパートメントへ往ってもいいし、新橋の待合へ往ってもいいよ」　お葉は、ストーブを距てた右側のテーブルにいる二人の客と、その対手になっている朋輩に用心するように、ちらっとその方に眼をやりながら云った。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放免されて後、彼女は以前の住家に近いあるアパートメントを借りて、やはり前同様の後ろ暗い仕事を始めていた。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ブロンクス区フルトン街に、あるアパートメントの管理人をしているヘララというキューバ人が住んでいた。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題の日にヘララのアパートメントに出入した人々の穿鑿に取りかかっても、これという怪しい人物は見当らなかった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい家と云うものが、ちっとも、贅沢な、フリーボラスな気分を醸さず、素朴な、自分等各々の献物によって形造られ、豊かにされた巣、心の棲家と云う落付きを持つ便利と云う点を云えば、米国風のアパートメントは勝れていましょうが、人間の心の要求の何ものかを、どうも殺していると感ぜられます。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリンピック村の建物は競技がすんだ後も残るから、それを下附すればアパートメントとして収入を得られる。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供はなく、六室ばかりのアパートメントに住んでいるのです。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパートメントの入口にはいつも玄関番がいて、若し来客でもあった時には氏名、用向を聞いて書きつけて置きます。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔シカゴ市で見学した一つのアパートメントの有様は、今もまざまざと目に残っています。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのクリーム色に塗られた近代風のドアが開くと、その一間住宅であるアパートメントの瀟洒な布張のアーム・チェアに細君がかけて編物をしています。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故、上へ上へと積上げた空間のそのまた平面を、最少限の面積で、最大限の能率に活かすアパートメント経営者の、才覚にほかなりません。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるアパートメント式の住宅であった。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを書いたのは、モスクワ市をかこむ並木道のはずれにあるアストージェンカという町の狭いクワルティーラ（アパートメント）の一室だった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼女が自身の力さえあれば、どんな大きな邸宅に百人の従僕を使って暮す事が出来ると倶に、どこかアパートメント只一つの部屋をかりて、男のような服装で暮したとて、誰も、其を非難したり変更させたりするものはございますまい。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの惨劇以来、大川竜太郎氏は、遺された一人の娘を妻の里にあずけ、家をたたんで、全然一人となって、この病院に程近きアパートメントに入ったのであった。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮殿のような高楼の階下は、贅沢品を売りつけようとあせっている商店で、その上のアパートメントには富裕な人たちが住んでいた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のＡ・Ｍは、当日、アパートメントの入口に立つて、一々来訪者に名簿を差だし、そのサインを需める。",
              "citation": {
                "source": "世界人情覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い横丁を二三度あちこちへ折れて、飛びこんだのはアパートメントとは名ばかりの安宿の、その奥まった一室――彼等の秘密の隠れ家！",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父、母、妹たちはヴル※ール・ペレールのアパートメントに住み、百合子はヴォジラールの下宿の窓から、シトロエン６、シトロエン６、とせわしい明滅が、シャンゼリゼイの方に向って瞬くのを眺めた。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミケランジェロの建築と言われている法王門から、両側に、閑静なアパートメントと、乾麺類や薬を売る近処相手の小商店とを持つ、かなり広い並木街が、真直ぐに逃げています。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "六週間以前に、家内と僕とが二人連れで、家具付きのアパートメントをさがしに出て、ある閑静な町をとおると、窓に家具付き貸間という札が貼ってある家を見つけたのだ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、馬車から降りて自分の孤独なアパートメントに伴れて行かれ、その晩は好きなようにして過ごした。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の住んでいたアパートメントには戻る気にはなれず、暗くて気もちのよくない空から降りそそぐ雨に流れそぼちながら、急ぎつづけなくてはならぬような衝動を感じた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、自分のアパートメントに残してきた生きたものがまだあそこに居て、生きて歩きまわるだろうと考えると、がたがた慄えが来た。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
