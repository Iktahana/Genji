        "examples": {
          "standard": [
            {
              "text": "私は毎日アナクロニズムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナクロニズムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナクロニズムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナクロニズムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナクロニズムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナクロニズムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナクロニズムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナクロニズムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナクロニズムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナクロニズムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナクロニズムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナクロニズムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナクロニズムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナクロニズムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アナクロニズムといい、エキゾーチシズムという語は色々な、複雑な意味を持っていると思う。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度といえばコナン・ドイルの印度に関する知識はよほど深いようであるが、あまりに、それが神秘化されすぎていて、読者にアナクロニズムの幻覚を起こさせるきらいがあります。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は人性を善なりと大掴みにきめてかゝれないと同時に、その反対に悪なりとも断言することを躊躇するものだが、誰も彼も皆正義人道の擁護者らしく見えるときに、自分の汚ない心は皮肉な嘲笑を催して、それぢや是を見ろと現実暴露といふ昔｜流行つたアナクロニズムをやつてみ度くなる。",
              "citation": {
                "source": "愛人と厭人",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく多くのアナクロニズムのできたのは、私が故実に通じていないためばかりで無く、それに拘泥することによって私の表わそうとする親鸞が生き生きとして近代の心に触れてこないことを恐れるため、それよりもむしろそういうことを気にしていられないほどあれを書いたときの私の心持ちが切迫していたためである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にアナクロニズム時代逆行というべきであろう。",
              "citation": {
                "source": "集団文化と読書",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "又こゝに奇妙なことには、とうにその昔「紅露時代」を荷なはれた先生が亡くなられたことは、それが「今」ではなく、紅露と並んでうたはれた時代の立役団十郎、菊五郎などの死んだのが、又々逆に「昔」ではないやうなまじり合つたアナクロニズムを感じることである。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切のユートピア・一切のアナクロニズムは形式論理的方法の所産であるだろう。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、想像してみていただきたい、その時は将校がわたしを侮辱して以来もう二年から経っていたので、わたしの挑戦は、アナクロニズムを掩蔽し説明する巧妙な手紙の書き方にもかかわらず、醜悪をきわめたアナクロニズムには相違なかったのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十世紀の現代に殉死などとは、如何にもアナクロニズムであるが、乃木大将の場合に限り、西南戦役以来の事情もあって、美しい武士道の発露と見なす。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
