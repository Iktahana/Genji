        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "護身術として、娘に合気道を習わせることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合気道は、相手の力を利用して制する、和の武道である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "演武会で見た合気道の師範の動きは、まるで舞うように滑らかだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合気道の稽古を始めてから、心身ともに落ち着きが得られるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「合気道の神髄は、争わないことにある」と祖父は常々語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "物静かな彼が、実は合気道の有段者だと知って驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "警察官の中には、犯人制圧のために合気道の技を応用する者もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "最初に日本へ来たとき、彼女は滞在期間のぜんたいをとおして、空手と合気道の訓練を受けた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "合気道にも、なぜか、いつのまにか、ごく若い時期に、彼女は熟達した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「直子さんは、居合と合気道の、高段位者なのですって」「知らなかった」　ほどなく直子がふたりの席へ戻って来た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「居合と合気道の話を、僕にも聞かせてください」　ヨシオが言った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "居合と合気道のどちらかに、入門を勧めていただいたの。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
