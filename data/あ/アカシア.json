        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこから、だらだら坂になっているアカシア並木の赭土の途を揺られながら、ペル・※ュウ村の木立の上に風車の廻っているロダンさんの粗末なお宅につくと、薔薇園の木戸口に肉体の彫刻的に締った、銀髪のロダン夫人が立って、妾を迎えてくださいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は眼を瞑り、先程まで、水際のアカシアの葉を洩れて、うすく落ちていた夕方の日影が、この時、ほっと消えて、あたりが急に、うすら青い影にはいったのを、閉じた眼蓋の裏から、ぼんやり感じながら、水に浮んでいた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは坂の中途で、アカシアの街路樹が少し断れて、暗い街燈の立っている所であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯黙つてアカシアの花の咽ぶやうに匂つて来るのを嗅いだ。",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外に見えるアカシアの梢の方に紫色の雲が渦巻いてゐたが、ピカリと大きな稲妻が閃いた。",
              "citation": {
                "source": "奇蹟",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は短い赤い袴の下から白い絹の靴下を見せ赤いモロッコ皮の靴を緋色のリボンで結んで、わざとショールをひろげて肩を出し、アカシアの大きな花束を肌衣の外へはみ出させて、口にもアカシアの花をくわえながら、コケティッシュに腰を振って多勢のスペイン女の中をかきわけて左手から舞台へ出ました。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟木先生の後にはアカシアの樹があり、その梢に白いちぎれ雲がある。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もゐないのか白い障子が立てきつてあつてアカシアの花が揺いでゐた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "道幅の莫迦に廣い停車場通りの、兩側のアカシアの街※は、蕭條たる秋雨に遠く／＼煙つてゐる。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この罷業はマロニエの花が散り、アカシアの花が雨に浮き流れて、街路の敷石にたまるころから急激に進行した。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはその小道が、ちょうどその場所で人が乗り越えたらしい足跡の残っている垣根の下を、蛇のように這い抜けて、アカシアばかりでできている円い四阿へ、通じていたからである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の札幌　樹木についた雪、すぐ頭の上まで、積雪で高まった道路の為来るアカシアの裸の、小さいとげのある枝。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キスが留守になると、このパウル・ビハリが、ブダペストからやって来て、附近にはアカシアの森が多い、そのアカシアの森を二人で恋人気取りで散歩したりする。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃、ツインコタからブダペストへ行くアカシアの森で、偶然若い女の屍体が発見された。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一四年一月、冬にしては暖い陽が、ツインコタからブダペストへ出る途中のアカシアの森を照らしている。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルビアと露西亜の捕虜をツインコタへ呼んで来て、附近のアカシアの森を中心に大々的捜索をしてみた。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀越しにそよいでゐたアカシアの悩ましげな青葉……恐怖に張りつめられて青く美しかつた空……それらが胸をふさぐやうだつた。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にそのひとと晴れた日、白いアカシアの花々が川岸に匂う青い川上に、白いボオトを浮べ、ぼくが力漕して汗になったので、何気なく上半身、裸体になったら、差向いのそのひとがパッと顔に紅を散らし、身悶えして、「厭よ、恥かしいわ、早く襯衣を着て頂戴」と乱暴に、ぼくの裸の胸をつきまくったのも忘れられぬ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶々カチ鴉が二羽慌ただしく飛んで來て近くのアカシアの梢で啼いた。",
              "citation": {
                "source": "尹主事",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "主事は驚いて何かを氣遣うらしく私を傍の暗いアカシアの繁みの中へ急いで連れ込んだ。",
              "citation": {
                "source": "尹主事",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は幾度となく、青い水に臨んだアカシアが、初夏のやわらかな風にふかれて、ほろほろと白い花を落すのを見た。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "平原の町らしく晴々して、アカシアの並木が深い葉を垂れてゐた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下落合の丘には、あの細々と背の高い榎はないが、アカシアとポプラと桜が私の家を囲んで、春は垣根の八重桜が見事に咲き、右手の桜の垣根の向うは広々とした荒地になっている。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道あたりの、アカシアのプンプン香る並樹舗を、一人できまゝに歩いてみたい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の前からアカシアの並木が繁っている。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからこそこの一家族も熱心に家さがしをしているわけなのだが、門前の大きいアカシアだけが風情のある下でいくら格子をこじっても手におえないので、ひろ子は到頭声をあげた。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
