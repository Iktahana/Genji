        "examples": {
          "standard": [
            {
              "text": "私は毎日アルピニストについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルピニストの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルピニストが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルピニストについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルピニストの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルピニストが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルピニストという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルピニストについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルピニストは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルピニストが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルピニストは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルピニストの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルピニストは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルピニストは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この本能を守り立てればアルピニストになれる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂、アルピニストと呼ばるゝ純粹の探嶮探美の人々が登山を初むることになつたのは、日本に於ては極めて最近のことのやうである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、登山の電車は、多くのアルピニストを載せて、徐々に山間の谿谷をのぼりはじめた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロック・ウォーキング、垂直の岩壁を散歩するのでなければ、現代のアルピニストではないそうですね。",
              "citation": {
                "source": "登山は冒険なり",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頂きはもはや何ものでもなくなった」一部のスポーツアルピニストたちはそう言って頂きの没落を唱える。",
              "citation": {
                "source": "ピークハンティングに帰れ",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狙うこころがより遠く広くなり、それに高さそのものと言う存在的性格の空間的方向を加えたスポーツ気分は即ち数年或いは一生を犠牲にして一つのピークを狙うところのアルピニストのみがもつ気分である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで来たと始めて眼をかえすときのアルピニストの胸に湧き来る遠い哀感と何の変りもない。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　もちろん私はテーブルマウンテニヤでもなければ、カフェーアルピニストでもない。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど熟練したアルピニストを必要とするが、橋本君はマナスルの勇士の一人で、ヒマラヤの氷河で、十分経験をつんでいる。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルピニストの七つ道具は、その頃まだ恐らく日本に、まして田舎の都会にははひつて居なかつた。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生曰く、　そもそも、誰でもがアルピニストになれるものではない。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか本格的なアルピニストであるＩ・Ａ・リチャーズ夫妻と一緒に、後立山を歩いたことがある。",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
