    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Alan (member of an ancient Scythian people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アランについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アランという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアランの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアランが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アランを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアランについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アランの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアランの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアランが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アランという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアランという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアランについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アランを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアランは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アランについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアランが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアランは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアランの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アランは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアランは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は前にも述べた通り、シャスタとシャスチナの間の、鞍部に懸垂しているが、アルプスのベルニーズ・オーバアラント山地あたりの大氷河に比べると、恐らく雛形ぐらいの小さいものだろうが、それでも擬似氷河ではない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "競犬場番人、黒奴のアランがノラの男妾だという評判が街にひろがった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、黒奴アランはひどい下痢のために租界内の赤十字病院に入院したとか。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラン・ポーの短編の中に、いっしょに歩いている人の思っていることをあてる男の話があるが、あれはいかにももっともらしい作り事である。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　アラン「ベンガルの槍騎兵」などとは全く格のちがった映画である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しくいえば、大西洋の海面の恒久の退屈さでありアラン島民の生活の永遠の退屈さである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした映画を見るのは、自分でアランの島へ行って少なくも二三日ぐらい滞在したとほぼ同じような効果があるのではないかという気もした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランの島民たちと、現にこの映画を見ている都人士とで、人生というものの概念がどれくらいちがうであろうか、というようなことも考えさせられた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「麦秋」などは題材がロシアふうであるのに映画は全然ヤンキーふうであるが、「アラン」にはそうしたアメリカふうがどこにも見えないように思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランや正宗白鳥のエッセイがいつ読んでも飽きないのは、そのステイルのためがあると思っている。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "間接に師と仰いだのは、前記の作家たち、ことにスタンダール、そしてそこから出ているアラン。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンダールもアランも私には大阪人だ。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はやはり三高の出身の仏蘭西文学者で、スタンダールやアランの翻訳家として知られている桑山竹夫。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭青年科学者アラン・キャンベル氏がやって来た。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は再び君の家の閾をまたぐまいと固く決心したのだったが……』とアランは答えた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』アランは顔色を変えて叫んだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『よし……』ドリアンは憫笑を浮かべながら黙って紙片に何事かを書いて、それをアランに渡した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランは紙片を読んで狼狽した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームス・ヴェンはセルビイの墓地に名も知られずに葬られたし、アラン・キャンベルは自分の研究室でピストル自殺を遂げたし、ベエシル・ハルワアドの失踪も永遠の秘密としてやがて人々から忘れ去られるだろう。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバァトの三人の息子、アラン、デイヴィッド、トマス、もそれぞれ次々に此の職を襲った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本人は直ぐに西洋人の真似をするのだナ」　と思いながら「エドガー、アラン、ポー」「エドガワ、ランポ」と心の中で繰り返して、何とも云えない物足りなさを感じた事を、今でもハッキリと記憶しています。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、「江戸川乱歩は要するにエドガア、アラン、ポーに対するエドガワ、ランポに過ないのかナ」　なぞと思い思いした事でした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、パーシヴィアランス炭坑引込線のみは複線なり、該坑は産額はなはだ多きをもって、六月三日も平常の如く絶えず線路を使用し、二｜哩四分の一なる全線に沿うて数百の労働者が就業しつつありしも、本線より列車の闖入せるを認めたるもの無し。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、カーンストック引込線、ビッグ・ベン引込線、パーシヴィアランス引込線の三を「可能なる」ものと認むるものなり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君はエドガー・アラン・ポオのデュパンを彷彿とさせるね。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんなコンピューターなら、人は身近に感じ、自由に使いこなすことができるだろう」　こう考えて、一九七〇年前後から研究に取り組んでいったアラン・ケイという人物のアイディアは、一九八〇年代になって商品に盛り込まれていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『アラン・ケイ』によって、日本の読者は、彼の考え方の流れを容易にたどれるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユタ大学の大学院ではアラン・ケイの同期で、卒業後はＮＡＳＡのために飛行士訓練用のフライトシミュレーターの開発に携わっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時まとめた報告書を、彼はアラン・ケイに読んでもらおうと考えます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
