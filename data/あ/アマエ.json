    "definitions": [
      {
        "index": 1,
        "gloss": "overdependence (on others; usu. one's fosterers or seniors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘えについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘えという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘えの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘えが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘えを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘えについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘えの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘えの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘えが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘えという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘えについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘えを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘えは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘えが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘えは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘えの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘えは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘えは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "われ星に甘え、われ太陽に傲岸ならん時、汝等ぞ、讃ふべきわが従者！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年近く広島といふお天気の好い街の教会で伝道婦として働いたその叔母の甘えた気持が――といつて別に当人甘えたといふのでもあるまいが、その生活といふものがそも／＼甘えたものであつたのではあらうが、そいつが癪に障つたね。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日をいっぱいに生きている」　それ以後、私は馬場へ肉親のように馴れて甘えて、生れてはじめて友だちを得たような気さえしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、「おどさ」に、ずいぶん甘えてゐました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、「おどさ」に、ずいぶん甘えていました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり甘えて物を考へるからだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "疳高い甘え声が、真昼の暑熱が漸く鈍い渾然さをみせた夕刻の空気の中を、矢のやうに走つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分に甘えたくないのに甘えたりする時もある。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　弟は甘え気味で、私に「僕でも方便といふことを知つてる」といふことを知らせたいらしく言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだお前こそ甘え奴だ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　尋常一年の男が甘えるやうにいつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もその夫といふのは、アメリカイズムの流行中心である映画会社にゐるにも関はらず、珍しくも太い横幅の長い口鬚をつけて、ゐて、女に甘えられるのが嫌だといふのではないが、そんな新式な甘え方を、調子よく受け取れるといふ格恰の男ではなかつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中のことは何も知らぬふりして無邪氣をよそほひ、常に父兄たちに甘えて居ればいいのか。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦のように、深く相愛して愛におぼれず、堅く相信じて信に甘えないというのは、アメリカ人の目にはよほど珍しく目新しい一大発見として映ずるかもしれないが、日本人には実は少しも珍しくもなんともない、むしろ規準的な夫婦関係のスタンダードであったのではないかという気がする。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの白痴に取ってせいぜい甘えた態度だった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘える者と甘えられる者との間には、常に積極的な通路が開けている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甘えてすねて」とか「甘えるすがた色ふかし」などいう言葉に表われている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男へ対しそのものいひは、あまえずして色気あり」とか「言の葉草も野暮ならぬ」とかいう場合がそれであるが、この種の「いき」は普通は一語の発音の仕方、語尾の抑揚などに特色をもってくる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はお松はなつかしいけれど、まだ知らなかったお松の母が居るから直ぐにお松にあまえられなかった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう拝見な」と自分にあまえてぶら下った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花は叔父を慰め、源造は叔父さんと遊び、勇は叔父さんにあまえた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴女にあまえているんでしょう。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあ様を慕って、おばあ様にあまえ、おばあ様にねだる孫が、桂屋に五人いる。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か特別なわけがあるに違ひないと考へると、ます／＼そればかりが聽きたいので、翌日も午砲が鳴るまで一緒に寢てゐた上に、女をあまえるままにまかせて、午後の時間を二人で寢ころんで無駄ばなしで送つて、とう／＼家へは歸らなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、痛い」とばかり、かの女はあまえるやうな關西口調でその夜も頻りに泣き訴へてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青木が呼びに来るだろうから、下へ行け」「あの人は今晩来ないことになったの――そんなに言わないで、さ、あなた」と、吉弥はあまえるようにもたれかかって、「今言ったことはうそ、みんなうそ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お言葉にあまえて」と、お袋は愛相よく、「先生、そろってまいりましたよ」「さア、おあがんなさい」と、僕はさきに立って二階の奥へ通った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「持病とあれば左程案じることもなかろう、癒るまで逗留して、それから出発せらるるが宜い」「お詞にあまえるようで、心苦しゅうございますが、どうぞ乳母の病気が癒りまするまで、お助けに預かりとうございます」　壮い女は涙を流した。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふさは揶揄ふ樣なあまえる樣な態度で又妙な聲を出して嫣然した。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあ樣を慕つて、おばあ樣にあまえ、おばあ樣にねだる孫が、桂屋に五人ゐる。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
