        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「おれは、ここの亭主の友達で、風呂屋町の喧嘩買、赤螺三平という男だ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤螺殿、この友人は、さる大身の子息で、遊びの道はまだ初心な若殿。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――じゃあ、市の字、淋しかろうが、暫くひとりで」　と、大亀は、その軽い舌先と、変に応じて弱くもなる物腰とで、さすがの赤螺三平をも煙に巻き、支度もそこそこ、朝飯前に往来へ飛び出してしまった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、時たつほど、荒っぽくなって来たので、市十郎も落着かず、厠へゆくふりをして、そっと、廊下から隙見してみると、男は、いつか神田の丁字風呂で、大亀と一しょに溺遊していたとき、自分たちへ脅しをかけた風呂屋町の地廻り、銀歯組のひとりと名のる赤螺三平だ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがお白洲へ坐る日には、赤螺三平こそ、ひと足先に、獄門台へお出かけのはずだよ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と男の勝負をつけてみせる）（ばかなことをおいいでない）（いや、赤螺三平の男がたたねえ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎を出せ）　そのうちに、どたどたという物音がひびき、すぐ梯子だんの下から、赤螺三平が、二階へ向って、吠え出した。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そんな事に、今さら驚くか」　市十郎は、赤螺三平に対したお島の口真似みたいなことを口走って、「よし、おれも飲むぞ」　と、起き直った。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、赤螺三平だ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀のお島に可愛がられて、お島の情夫の赤螺三平に、あぶなく叩ッ斬られるところだったそうだが、三平が怖くて、逃げ廻っているのか」「いや。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大亀と、赤螺三平だ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは」　赤螺三平も、顔をよせた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今じゃあ、大岡越前とかいって、江戸町奉行になりすましている、あの男が書いたものか」　と、赤螺三平は、好奇心を眼に燃やし、阿能十は、まだ上からしゃべっていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袖とお燕が、堺町の歌舞伎見物にゆくというので、大亀や阿能十や赤螺三平などで、あとを見送っていると、物蔭から、異様な敏捷さで、二つの絵日傘を尾けて行ったものがある。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ野郎を、ひと思いに、たたっ殺しちゃいけねえんですか」　赤螺三平は、不平｜面だった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、赤螺三平が、そこへ戻って、床口をふさぐ遑もなく、すでに三人、五人、十人と、躍り上がッた同心と捕手は、そこらの部屋に、充満していた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、曳くならどこへでも曳いてゆけ」　一方、赤螺三平も、裏の井戸端で、包囲され、ついに、縄にかかった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、ほかの賊徒は」「赤螺三平も、大亀も召捕りました。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今度は、これまで一回の下吟味しかしていない大亀こと――大岡亀次郎、赤螺三平、阿能十蔵なども、次々に白洲へ呼び出し、いよいよ本裁判にかかるであろうと、奉行の名をもって言明した。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前守は、次に、「堀留の山善へ押込の際には、そちは堀留川の舟の中に残っていて、屋内へ入って、強盗を働き、家人を殺傷した者は、男の三人だけであったと、阿能十蔵も申し、赤螺三平も自白しておるが、相違あるまいな」　お袖は、答えもせず、否定もしない。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、また翌々日にかけ、赤螺三平や阿能十蔵の調べもどしどし進捗した。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、数日前まで行われて来た、南町奉行所の白洲におけるお袖の吟味や、大岡亀次郎、阿能十蔵、赤螺三平などの予審ぶりなども、傍聴に立会った横目の二人から細大、洩らすところなく、報告されていたのである。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも新聞を読んだろうが、絲満って男は、古今未曽有のあかにしだったんですぜ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかにしであればあるほど、反動も大きければ爆発も異常だ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしあ、……あかにしだが、これで、いちめん純情なところもある男さ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
