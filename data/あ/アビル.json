[
  {
    "uuid": "47102681-edac-5313-8d2d-f06f2cdf48bf",
    "entry": "浴びる",
    "reading": {
      "primary": "あびる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to dash over oneself (e.g. water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浴びるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この浴びるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "浴びるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が浴びるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "浴びるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は浴びるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "浴びるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では浴びるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から浴びるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "浴びるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも浴びるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では浴びるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "浴びるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも浴びるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも浴びるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で浴びるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に浴びるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "浴びるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する浴びるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では浴びるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "体のよいためか、ここへ来ると、新鮮な魚はうまく、潮を浴びることは快かった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇一は、顔に、直接、健二の視線を浴びるのをさけた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い時に風呂に行って背中から熱い湯を浴びると、やはり「涼しい」とかなりよく似た感覚がある。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この変化は必ずしも低温の方向に起らなくてもいいということは、暑中熱湯を浴びる実験からも分ると思う。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日を浴びていても、否、日を浴びるときはことに、太陽を憎むことばかり考えていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと煙管を払いて、（何、遠慮をしねえで浴びるほどやんなせえ、生命が危くなりゃ、薬を遣らあ、そのために私がついてるんだぜ、なあ姉さん。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗道にも三熱の苦悩、髪が乱れ、色が蒼ざめ、胸が痩せて手足が細れば、谷川を浴びると旧の通り、それこそ水が垂るばかり、招けば活きた魚も来る、睨めば美しい木の実も落つる、袖を翳せば雨も降るなり、眉を開けば風も吹くぞよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀の糞を鼻のあたまに浴びるなど、わしはいやなのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、悪銭身につかぬ例えのとおり、酒はそれこそ、浴びるほど飲み、愛人を十人ちかく養っているという噂。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえに大地を生命として踏むことが妨げられ、日光を精神として浴びることができなければ、それはその人の生命のゆゆしい退縮である。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笞を受けた雲は眩むばかりの血潮を浴びる。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは浴びるばかりの涙なのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私は水を浴びるやうに悚然して、聲も出ませんでした。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何らの寵児ぞ、天地の大きな盥で産湯を浴びるよ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし果してそうならば、猪早太ほどにもない雑兵葉武者のわれわれ風情が、遠慮なしに頭からざぶざぶ浴びるなどは、遠つ昔の上臈の手前、いささか恐れ多き次第だとも思った。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "泳ぎを知ってると、なかなか死ねんもんでね」「あ」　と、豹吉は釈然として、伊部が死んだものと思い込んでいた自分の間抜けさ加減に苦笑したが、しかし、なぜ伊部が留置場に入れられているのか、これは判らなかったので、きくと、「なアに、一水浴びた勢いで、浴びるようにアルコールを飲んだんだよ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、銭湯で湯舟に永く浸り、湯気のふき出している体に冷水を浴びることが好きだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、浴びるほど飲んでみたい気持でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧弊な家風に反抗し、頑迷冷酷な義父と戦い、自由を求めて再び大学へ帰って来た、真実の友、正義潔白の王子として接吻、乾盃の雨を浴びるでしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの巓は、後になって己達の方へ向いて降りる、永遠の光を先ず浴びるのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のような俗人でも、月光を浴びると、少しは sentimental になるようです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い火を汗に浴びると、うら山おろしの風さ真黒に、どっと来た、煙の中を、目が眩んで遁げたでござえますでの。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと煙管を払いて、（何、遠慮をしねえで浴びるほどやんなせえ、生命が危くなりや、薬を遣らあ、其為に私がついてるんだぜ、喃姉さん。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗道にも三｜熱の苦悩、髪が乱れ、色が蒼ざめ、胸が痩せて手足が細れば、谷川を浴びると旧の通、其こそ水が垂るばかり、招けば活きた魚も来る、睨めば美しい木の実も落つる、袖を翳せば雨も降なり、眉を開けば風も吹くぞよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩調のせいでしょうか、それとも浴びる光の加減でしょうか、その身体の揺らぐ度に女の影は一重に見えたり二重に見えたりします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は月光を浴びると乱れた髪の毛が銀髪に変色し忽ち奇怪な老婆のように変形した。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、銭湯で水を浴びるのを好んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "登勢は風呂場で水を浴びるのだった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "万豪和尚より習ひ覚えしといふ奈美女の優れたる竹抱、牛血、大蒜、人参、獣肝、茯苓草のたぐひを浴びるが如く用ふれども遂に及ばず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の温泉でもさうであるが、浴槽に浸つて居ると、槽外の流しでからだを洗つて居る浴客がざあつと溜め桶の水を肩からあびる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
