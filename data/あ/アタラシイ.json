        "examples": {
          "standard": [
            {
              "text": "毎日、新しいについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の新しい戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "新しいの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "新しいという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは新しいについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "新しいの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "新しいに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは新しいを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での新しいは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、新しいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "新しいは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な新しいを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「新しい」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「新しい」という概念について深く考察する必要があります。",
              "source": "幻辞"
