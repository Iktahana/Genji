        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あやかしの鼓」の由来を書いていい時機が来たから……「あやかし」という名前はこの鼓の胴が世の常の桜や躑躅と異って「綾になった木目を持つ赤樫」で出来ているところからもじったものらしい。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは宝の木といわれた綾模様の木目を持つ赤樫の古材で、日本中に私の鑿しか受け付けない木だ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴の模様は宝づくしで材木は美事な赤樫だ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能張りのサミダレになった鉋目がまだ新しく見える胴の内側には、蛇の鱗ソックリに綾取った赤樫の木目が眼を刺すようにイライラと顕われていたからである。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　小宮山は切歯をなして、我｜赤樫を割って八角に削りなし、鉄の輪十六を嵌めたる棒を携え、彦四郎定宗の刀を帯びず、三池の伝太｜光世が差添を前半に手挟まずといえども、男子だ、しかも江戸ッ児だ、一旦請合った女をむざむざ魔に取られてなるものかと、追駈けざまに足踏をしたのでありまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長者は太い赤樫の杖を持って、日毎に奴隷の前にその姿を見せました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤樫の杖は、時とすると、奴隷どもの肩のあたりに蛇のように閃きました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の麦畑の間にある路から、中脊の肥満った傲慢な顔をした長者が、赤樫の杖を引摺るようにしてあるいて来るところでありました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一滴でも油を滴したら、これだぞ」と云って、長者は傍に置いてある赤樫の杖を揮って見せました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに就いては小説的の閲歴があるのさ、情夫ぢやない、亭主がある、此奴が君、我々の一世紀｜前に鳴した高利貸で、赤樫権三郎と云つては、いや無法な強慾で、加ふるに大々的｜※物と来てゐるのだ」「成程！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その赤樫と云ふ奴は貸金の督促を利用しては女を弄ぶのが道楽で、此奴の為に汚された者は随分意外の辺にも在るさうな。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だつて何時までも赤樫に居たいことは無いぢやございませんか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は姑く打案ぜし後、「あの赤樫の別品さんね、あの人は悪い噂が有るぢやありませんか、聞きませんか」「悪い噂とは？",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが芸者だとか、囲者だとか云ふのなら、私は何も言ひはしませんけれど第一は、赤樫さんといふ者があるのぢやありませんか、ねえ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は何方までお出なのですか」「私は大横町まで」　二人は打連れて四谷左門町なる赤樫の家を出でぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い男の所へ若い女子が度々｜出入したら、そんな事は無うても、人がかれこれ言ひ易い、可えですか、そしたら、間はとにかくじや、赤樫様と云ふ者のある貴方の躯に疵が付く。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、間も貴方のやうな方と嘘にもかれこれ言るるんぢやから、どんなにも嬉いぢやらう、私のやうな老人ぢやつたら、死ぬほどの病気したて、赤樫さんは訪ねても下さりや為まいにな」　貫一は苦々しさに聞かざる為してゐたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は赤樫さんの処へ行つて言ひますぞ」「はい、有仰つて下さいまし。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤樫さんはああ言うてをらるるが、さうかの」「如何ですか、さう云ふ事は」　誰か烏の雌雄を知らんとやうに、貫一は冷然として嘯けり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤樫満枝さまと有仰いますか」　この女の素性に於ける彼の疑は益暗くなりぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意にこの体を見たる老婢は、半啓けたる紙門の陰に顔引入れつつ、「赤樫さんがお出になりまして御座います」　窮厄の色はつと貫一の面に上れり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今まで我慢をしてゐたですけれど、もう抛つて置かれんから、私は赤樫さんに会つて、貴方の事をすつかり話して了ひます」　満枝は始て涙に沾へる目を挙げたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、お話し下さい」「…………」「赤樫に聞えましたら、どう致すので御座います」　貫一は歯を鳴して急上げたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤樫は貴方の何ですか」「間さん、貴方は又赤樫を私の何だと思召してゐらつしやるのですか」「怪からん！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間さん、どうぞ赤樫にお会ひ遊ばしたら、満枝の奴が惚れてゐて為方が無いから、内の御膳炊に貰つて遣るから、さう思へと、貴方が有仰つて下さいまし。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は大方赤樫に言ふと有仰つたら、震へ上つて私が怖がりでも為ると思召すのでせうが、私驚きも恐れも致しません、寧ろ勝手なのですけれど、赤樫がそれは途方に昧れるで御座いませう」　貫一はほとほと答ふるところを知らず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し話が一つ間違つて、面倒な事でも生じましたら、私が困りますよりは余程赤樫の方が困るのは知れてゐるのですから、私を遠けやう為に、お話をなさるのなら、徒爾な事で御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤樫は私を恐れてをりませうとも、私｜些ともあの人を恐れてはをりませんです。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
