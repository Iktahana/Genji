    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese evergreen oak (Quercus acuta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
