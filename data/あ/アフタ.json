        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフタについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフタは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフタの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフタについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフタは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフタの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフタに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフタが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフタを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフタの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフタが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフタが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフタについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフタは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフタは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフタは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフタについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフタの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフタの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフタの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "衣裳は、三十枚のアフタヌーン・ドレス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフタヌーンのスカートは短くイブニングのスカートは長い。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達の訪れを、心待ちにしていたらしい令嬢の路子は、さっぱりした趣味のよいアフタヌーンを被て、新子を欣び迎えてくれた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い色を多く使った明るい家具が置かれ、バルコニイ近い豊かなソファに、軽い紗のアフタヌーンを被た夫人が、あだかも大公妃のような態度で、彼女を待っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時取りかかっていた仕事は、アメリカのボイジャーからこの年の八月に刊行された、『ザ・デイ・アフター・トリニティー』というＣＤ―ＲＯＭの翻訳でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平岡敬広島市長の陳述『ザ・ディ・アフター・トリニティー』日本語版の発売開始は、一九九六（平成八）年二月のマックワールドエキスポを目標に据えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚的には、ソフトもアフターケアーもハードのおまけだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみの為か心なしやつれの見える夫人の容貌は、暗緑の勝ったアフタヌーン・ドレスの落着いた色地によくうつりあって、それが又二人の訪問者には甚らなく痛々しげに思われた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "10気分よく暮らすのが好きなんだこういうぜいたくな暮らしがね陽射しの明るい夏の午後にこうして怠けているのが〈サニー・アフターヌーン〉キンクス　七月二十八日には、映画にはいけなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中々元気のよい講義をする人で、調子附いて来ると、いつの間にか、英語の発音がドイツ語的となって、ゲネラチョーン・アフタ・ゲネラチョーン＊１などとなった。",
              "citation": {
                "source": "明治二十四、五年頃の東京文科大学選科",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　もう永年のつき合いで、だが顔を見、やあというだけで気がくつろぐというのではないから、はる子は時に千鶴子の訪問から気ぜわしさだけをアフタア・イメイジとして受けた。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子爆弾開発プロジェクトの中心となった物理学者、ロバート・オッペンハイマーの軌跡をたどったドキュメンタリー映画、『ザ・デイ・アフター・トリニティー』を中心に据えたタイトルだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に『ザ・デイ・アフター・トリニティー』を紹介しようとするのなら、この作品がもっぱら片側の声のみを拾ったものであることを自覚するべきだと、しだいにそう思うようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄色のアフタヌーンを着て、自分の方から故算哲博士の秘書｜紙谷伸子と名乗って挨拶したが、その美しい声音に引きかえ、顔は恐怖に充ち土器色に変っていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、空色のアフターヌウンに黒い毛皮の外套を着た若い婦人と、先刻銀行で顔を合せた老婦人が、飛鳥のような素早さで自動車から下りて、石段を馳上るなり、厚い扉の裡に姿を隠してしまった。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐には、アフタアヌウンの上へ真黄いろなジャンパアを引っかけて出席した。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、治兵衛さん……和田さん、お久しゅう」　パール・グレイのしゃれたアフタヌンを着て、リュムゥルの香水をほんのりと漂わせている。",
              "citation": {
                "source": "川波",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンのタァヴァンにおなじ色のアフタ・ヌゥンを着、濃い人参色のストッキングをはいているので、大きな植木鉢でも倒れてきたのかと思った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようすが変なので、玄関の三畳をのぞいてみると、賢夫人が第一装のアフタヌンをすんなりと着こんでいる。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お部屋へ行ってみると、千々子さまは、このごろ、そればかり着ているレースのついた洒落れたアフタヌンにおさまり、長椅子のうえに足を投げだして、ジャルダン・デ・モードを読んでいらっしゃった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "年にしては派手すぎるマチス模様のクレープのアフタヌンを着ている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "由良ふみ子はタフタの黒っぽいアフタヌンを着て、れいの賢夫人の風格で、ひとり離れた椅子に、しずまっていた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵の持ちものといっては、いま着ている古いアフタヌンだけになってしまった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草馬道の、松村という貸衣裳屋の保証金の受取証で、（金二十円他、薄鼠、クレープドシン、アフタヌン一着、保証金）と書いてあり、その裏に血痕と思われる拇指頭大の丸い褐色の汚点がついていた。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員の話では、フリのお客で、年齢のころは十八九怒り肩のそばかすだらけなみっともない女で、四寸ぐらいのアフタヌンという註文で、それ位のを二三着出して見せたところ、碌に身体へもあてずに持って行った。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに、君のアフタヌンも背中の釦がひとつとれている」　葵の喉が、ごくりと鳴った。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はアフタニデスの蓄妾論を読んだことがあるか？",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフタニデス曰く、妾宅こそは、いや、ま、よそう。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
