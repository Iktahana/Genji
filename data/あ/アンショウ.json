        "examples": {
          "standard": [
            {
              "text": "私は毎日暗礁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗礁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗礁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗礁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗礁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗礁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗礁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗礁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗礁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗礁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗礁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗礁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗礁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗礁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗礁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗礁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗礁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗礁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗礁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗礁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
