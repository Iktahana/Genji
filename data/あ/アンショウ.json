            }
          ],
          "literary": [
            {
              "text": "この附近は偃松の原でなければ、暗礁のような岩角が立っていて、高山植物が点じている、なお北岳を見ていると、東の谷、西の谷、北の谷から霧が吹いて来て、その裾は深谷の方に布きながら、頂上を匝ぐって、渦を巻いている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがままで不精な彼にとって年賀状というものが年の瀬に横たわる一大暗礁のごとく呪わしきものに思われて来たのだそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで重力の秘密は自明的に解釈されると同時に古い力学の暗礁であった水星運動の不思議は無理なしに説明され、光と重力の関係に対する驚くべき予言は的中した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが暗礁になって私の美しい幻の船は難破してしまう。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコの机はたびたび誰かにぶっつかられて暗礁に乗りあげた船のようにがたっとゆれました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは有名な暗礁や島の多いところだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗礁については一度こんなことがあった。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の入口の暗礁へ一隻の駆逐艦が打つかって沈んでしまったのだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗礁に乗りあげた駆逐艦の残骸は、山へあがって見ると干潮時の遠い沖合に姿を現わしていることがあった。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島が生まれるという記事なども、地球物理学的に解釈すると、海底火山の噴出、あるいは地震による海底の隆起によって海中に島が現われあるいは暗礁が露出する現象、あるいはまた河口における三角州の出現などを連想させるものがある。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとジャーナリズムはむしろ科学の学海の暗礁になりうる心配さえ生じるのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と小首を傾けたが忽ちカラ／＼と笑つて『あゝ分つた／＼、畜生巧くやつてるな、此前あの邊で沈沒したトルコ丸の船幽靈めが、まだ浮び切れないで難破船の眞似なんかして此船を暗礁へでも僞引寄せやうとかゝつて居るんだな、どつこい、其手は喰はんぞ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋とて千尋の水深ばかりではない、斯く立浪の騷いで居るのは、確に其邊に大暗礁の横つて居るとか、今しも我が弦月丸の進航しつゝある航路の底は一面の大海礁で蔽はれて居るのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『何か起りましたか、暗礁へでも？",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『暗礁どころか、ま、早く／＼。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤオヤと叫んで立ちあがるに、船底は大波を打つごとく、足許ふらふらとして倒れんとす、さては余の眠れる間に、天候にわかに変り、海上はよほど荒るると見えたり、願わくは波速かに静まれと祈りつつ、ふたたび船底に身を横たえる、途端もあらせず、船は何物かに衝突しけん、凄まじき音して少しく右舷に傾けり、「暗礁！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は暗礁に乗りあげたような気持でしばらく相対していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗礁へ誘い寄せる、連を呼ぶ幽霊船だ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷へ手をかけて、神様のような顔を出して、何にもねえ、八方から波を打つける暗礁があるばかりだ、迷うな、ッていわしった。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦まく淵を恐れず、暗礁おそれず、誰ひとり知らぬ朝、出帆、さらば、ふるさと、わかれの言葉、いいも終らずたちまち坐礁、不吉きわまる門出であった。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父が、凡そ想像に絶する困難と闘ってベル・ロック暗礁岬の灯台を建てた時の詳しい記録が残っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月××日「退潮」は一時暗礁に乗上げたままにして置いて、「エンジニーアの家」の祖父の章を書上げた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沖の御前の西にはドド根と云う一大｜暗礁があって、その附近は古来数限りなく船舶を呑んでいる危険区域であった。",
              "citation": {
                "source": "真紅な帆の帆前船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると「ウタレ」に近い暗礁の上に一人釣をして居るものがある。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "平潟の港にはひらうとしたのであつたが夕方から波が荒かつたしそれに闇かつたので遂船底が暗礁へさはつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は暗礁へ障つたらもうすぐにばら／＼に成つて畢ふ。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其平らな入江の沖には暗礁でもあるものと見えて土手のやうに眞白な波の立つて居る所がある。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員たちは、自分の目の前に、手の届きそうなところに、大黒島の雪におおわれた、鷲の爪のような岩石に向き合っており、左手に一体に海を黒く、魔物の目のように染める暗礁を見いだした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "チーフメーツは、暗礁に乗り上げたよりももっともっと驚いた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のせきばんの上に、ダイヤモンドの石筆で字をかいて、本でよんだことは、そばからあんしょうしました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
