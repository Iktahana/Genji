    "definitions": [
      {
        "index": 1,
        "gloss": "earth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アースについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アースという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアースの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアースが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アースを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアースについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アースの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアースの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアースが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アースという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアースという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアースについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アースを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアースは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アースについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアースが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアースは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアースの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アースは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアースは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たとへば、「伯父ワーニヤ」のアーストロフ氏の言の如く、――インテリゲンチヤには閉口です。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしラジオ商や百貨店ラジオ係が自分の店でそれを試験する場合には、高い長いアンテナを使い、完全なアースを使って試験するのであるから、感度の低い機械でもちゃんと立派に聞こえ、何不足もない機械としか見えないであろう。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくアンテナを拡張し、完全なアースをすれば聞こえるであろうと思われたが、それがおっくうであるのと、もう一つは、前述のような理由から元来熱心でないためとでついついそのままに放棄してあった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが近頃になって、どうかした機会に、近所のラジオ屋に来て見てもらったら、このラジオ屋さんはちゃんと心得ていてさっそく水道栓へアースを引っぱって、アンテナを天井の廻りに引延ばして、ともかくも音だけは旧通りに聞こえるようにした。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアースやアンテナを引っぱり廻わす事なしに役に立つ感度の好い機械としての価値はもう永久に失われたようである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それにつれて、各地の交換手の癖や訛なぞは勿論、その局の交換手に対する訓練方針の欠点まで呑み込むと同時に、電線に感ずる各地の天候、アースの出工合、空中電気の有無まで通話の最中に感じられるようになった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵語アース（迅速）、ギリシア語のアコケー（尖頂）、ラテンのアクス（鍼）、アケル（迅速また鋭利また明察）、英語アキュート（鋭利）等から煎じ詰めて、これら諸語種の根源だったアリヤ語に鋭利また迅速を意味するアスてふ詞あったと知る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本塁からフアーストまで僕は三秒半で駈け得たのである。",
              "citation": {
                "source": "自慢山ほど",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人のやうにメイフアース――没法子――とうそぶいてはゐられない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは幾何学の初にあるコンヴアース、オツポジトなどといふ事を英語で言ふのが余には出来なんだのでそのほか二行三行のセンテンスは暗記する事も容易でなかつた位に英語が分らなかつた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンヴアースやオツポジトを英語でしやべる位は無造作に出来るやうになつたが、惜しい事にはこの時の先生はもう隈本先生ではなく、日本語づくめの平凡な先生であつた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと水道管でアースがとられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自主講座運動に加わり、のちに『ホール・アース・カタログ』を刊行するポートラ協会のコンピューター教育部門の発足にかかわる中から、アルブレヒトはマシンのパワーを人々に解放しようとする仲間たちと出会っていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゼームスが自己の認識論の立脚点をプラグマチズムと名づけたのはピアースの用語を踏襲したのであって、それまでは Radical empiricism と呼んだのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイアースとヘクトールとの決鬪、未決に終る。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイアース水陣を防ぐ（二十六日）。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキリュウス勇を奮つてアイナイアース及びヘクトールと戰つて之を走らす（二十七日）。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アイアース（テラモンの子＝テラモニデース）第二の猛將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アイネーアース　又アイネアース。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は恐れる色なく一同を見て「わたしはもう少年のスノーバアド（雪鳥）ではない、今日からアースアールとなりました」と言つた。",
              "citation": {
                "source": "北極星",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（古いイギリス語でアースは「熊」であり、アールは「大なる」または「驚くべき」の意味）そこでみんな彼をアーサアと呼んだ。",
              "citation": {
                "source": "北極星",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オークランドのジュニアースクールの一学級に山田章子さんというのがある。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフが、そばを歩き回っている。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　（気乗りのしない様子で、コップを受ける）あんまり欲しくもないがね。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　いいや、ウオトカも毎日はやらない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　その時分から見ると、わたしも随分かわったろうねえ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　そう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　いいや、欲しくない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　ああそうか、ありがとうよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
