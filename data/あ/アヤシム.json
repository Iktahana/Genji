[
  {
    "uuid": "6374a0aa-69f6-5fe6-bdf0-69cc1210b5e3",
    "entry": "怪しむ",
    "reading": {
      "primary": "あやしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
