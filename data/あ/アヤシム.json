    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to suspect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日怪しむについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "怪しむという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は怪しむの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には怪しむが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "怪しむを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは怪しむについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "怪しむの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は怪しむの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では怪しむが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しむという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に怪しむという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では怪しむについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "怪しむを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると怪しむは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "怪しむについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では怪しむが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に怪しむは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により怪しむの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "怪しむは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に怪しむは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "博識の人が、おのれの知識を機会ある毎に、のこりなく開陳するというのは、極めて自然の事で、少しも怪しむに及ばぬ筈であるが、世の中は、おかしなもので、自己の知っている事の十分の一以上を発表すると、その発表者を物知りぶるといって非難する。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、その何某先生が鬼のやうな醜惡の才能を持つてゐるといふ事實を暴露し、以て世人に警告を發するつもりで、その案内欄に鬼才などといふ怪しむべき奇妙な言葉を使用したのでもあるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはむしろあまり遅きに過ぎると思われるが、いったい英国の流儀としては怪しむに足らぬかもしれない。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、グロテスク美術が自然や文明の脅威から生れるものとすれば、あらゆる意味で不安な現代日本で産み出される絵画がこういう傾向をとる事は怪しむに足らないかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員の怪しむような眼を睨みかえして油絵を見た。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、そのなかに、日本ブルジョアジーの特色の一つをなす、軍事的性質が反映しているのは、怪しむに足りない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乞食の子を家に入れしは何ゆえぞ解しがたしと怪しむものすくなからず、独りはあまりに淋しければにや」「さなり」「紀州ならずとも、ともに住むほどの子島にも浦にも求めんにはかならずあるべきに」「げにしかり」と老婦口を入れて源叔父の顔を見上げぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々怪我ぐらゐはする覚悟で、幻覚、錯視かと自ら怪しむ、その水の彩りに、一｜段と、枝にのびて乗出すと、余り奇麗さに、目が眩んだのであらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　自分は彼の差した杯を受け、少ずつ啜りながら彼の言う処を聞て居たが、聞くに連れて自分は彼を怪しむ念の益々高るを禁じ得なかった。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　　　　＊　　　　　　　　　　　　＊　　　　　　　　　　＊　若い者のにわかに消えてなくなる、このごろはその幾人というを知らず大概は軍夫と定まりおれば、吉次もその一人ぞと怪しむ者なく三角餅の茶店のうわさも七十五日｜経たぬ間に吉次の名さえ消えてなくなりぬ。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、火事で焼け出されて、神社の森の中に持ち出した家財を番している中年の婦人が、見舞いの人々と話しながら、腹の底からさもおかしそうに笑いこけているのを、相手のほうでは驚き怪しむような表情をして見つめているのを見かけた事もある。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その同じ微分子が、一方で有機的な国家社会的の機関を構成しているのを見てその有機体の生命の起原を疑い怪しむに相違ない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店などで見受ける若い男女に活動仕込みの表情姿態を見るのは怪しむまでもないが、これが四十前後の堅気な男女にまで波及して来たのだとすると、これはかなり容易ならぬ事かもしれない。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その鞄は」　と小母さんは怪しむように尋ねた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に通り懸かりたる夜稼ぎの車夫は、怪しむべき月下の密会を一瞥して、「お合い乗り、都合で、いかがで」　渠は愚弄の態度を示して、両箇のかたわらに立ち住まりぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして倫敦中の社交界や倶楽部なぞに於て、彼の身の上に関する最も不名誉な怪しむべき噂を耳にした人々でも、一度彼を見てはその誹謗を信ずることをやめた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "金モールのいかめしい制服を着た門番も、その他の誰も、私を怪しむ様子はなかった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、その何某先生が鬼のやうな醜悪の才能を持つてゐるといふ事実を暴露し、以て世人に警告を発するつもりで、その案内欄に鬼才などといふ怪しむべき奇妙な言葉を使用したのでもあるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから旦那がその時、その年増のひと、秋ちゃん、といいますが、そのひとに連れられて裏の勝手口からこっそりはいって来ても、別に私どもも怪しむ事なく、れいのとおり、奥の六畳間に上げて、焼酎を出しました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、庚寅、天晴、未剋、鶴岳上宮の宝殿に、黄蝶大小群集す、人之を怪しむ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の順礼　（程よき所に立留り、もの怪しむ気はひ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時老いたる男下手より来りてこの様を怪しむ貌。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に性急である、故に彼等に、其理論の堂々として而して何等危險なる要素を含んでゐないに拘らず、未だ調理されざる肉を喰ふが如き粗暴の態と、小兒をして成人の業に就かしめ、其能はざるを見て怒つて此れを蹴るが如き無謀の擧あるは敢て怪しむに足らぬので有る。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しむべきは此事なり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "写実派と理想派との区別漸く立たんとする今日の文壇に、理想詩人の、万人に願求せられながら出現することの晩きも、強ち怪しむに足らじと思はるゝなり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人は此書に於て露伴の文章｜漸く西鶴を離れて独創の躰を出せりと言ひしが、文章に於ては或は然あらんかなれども、其想に至りては却て元禄を学ぶこと前の著述よりも多きに似たるを怪しむ。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塔は園に向きたるかたに、くぼみたる階をつくりてそのいただきを平らかにしたれば、階段をのぼりおりする人も、いただきに立ちたる人も下よりあきらかに見ゆべければ、イイダ姫がこともなくみずから案内せんといいしも、深く怪しむに足らず。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも山岸が彼の父にむかってその話を洩らしたときに、父の態度に怪しむべき点を発見したらしい事を考えると、父には何か思いあたる節があるのかとも察せられます。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えようによっては、さのみ怪しむべきことでもないかも知れない。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう訳であるから、外出嫌いの先生が今夜のような晩に桐沢氏を訪問したのも、別に怪しむにも足らないのであった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
