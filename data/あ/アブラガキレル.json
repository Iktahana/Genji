          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油が切れるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油が切れるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油が切れるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油が切れるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油が切れるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油が切れるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油が切れるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油が切れるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油が切れるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油が切れるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油が切れるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油が切れるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "油が切れるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油が切れるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油が切れるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もうソロ／＼油が切れる」　と菊太郎君も、この辺が本音だろう。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
