        "examples": {
          "standard": [
            {
              "text": "私は毎日粗筋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗筋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗筋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗筋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗筋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗筋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗筋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗筋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗筋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗筋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗筋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗筋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗筋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗筋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗筋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗筋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗筋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗筋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗筋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗筋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "秋雄がわたしの状態の粗筋を病歴のようにおまえに話し聴かして呉れたのち、わたしはいよ／＼おまえに会って話を切り出した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野玲子という女性をとおした後藤美代子について、ごく基本的な粗筋は聞くことが出来た、と日比谷は思った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "）しかし、この昔話にはたくさんのバージョンもあるので、読者諸氏は、つぎのあらすじから、自分たちのために一九世紀の今日の物語を容易に作ることができるであろう。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、そのあらすじを、かいつまんでお話をいたしておきましょう。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「於竹大日」のあらすじはこうである。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇のあらすじが終わった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇のあらすじは下劣な陰謀を企てた父が、息子ハーバートと私との間に割り込む構成です。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、いまはとにかく第一巻を、上巻と下巻とに分けて訳すことにし、第二巻のほうはあらすじだけを下巻のおしまいにつけておきました。",
              "citation": {
                "source": "「ニールスのふしぎな旅　上」まえがき",
                "author": "矢崎源九郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ニールスのふしぎな旅」続編のあらすじを、つぎにご紹介いたしましょう。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に、「あらすじ」を言ってみせよというと大抵の者が、「坊ちゃんなる人物が英語の先生として松山に赴任して、赤シャツやら山嵐やら、ぬらりひょんやらいった同僚たちと、マドンナなる婦人をめぐって鞘当てを繰り広げる話」などと答える。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、『坊ちゃん』のあらすじを、みんな間違って覚えていることに注目するのだ。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの世には、全く書かれていない内容をあらすじとして提示する文章というものが存在するのだ。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうあらすじとして読まれるかを事前に指定することはできないからだ。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "というか、『坊ちゃん』の例を虚心に考えるなら、あらすじなるものはどうやら、書かれている文章とは関係がないらしいということになる」　それは極端ではないかと思うが、聞き入れる様子は見えない。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『ぞなもし狩り』のあらすじは、一読した者が本を片手に、思わず別府にでかけてしまいたくなるような内容なのだ。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あらすじとして、どんな解釈をすることも許す』と書いてある本のあらすじはどうなるかね。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、そのあらすじをたどってみることにする。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下、重複する点もあるが、日本の権力の移動のあらすじを知る便宜のために、もう一度、要点だけを整理して述べることにする。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、そうした新しい読者のために、時にはぜひ“前回までの梗概”というのがあってよいのだが、既刊単行本だけでも十六巻となって来たので“あらすじ”といっても容易ではない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
