        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幼子の、いまだ言葉もおぼつかなきが、懸命に語りかけるさまは、いと愛くろし。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この子猫の、毛玉のごとき姿こそ愛くろしう侍れ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雛人形の小さき道具どもの、細工の細やかなるが、いみじう愛くろし。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "孫の不器用ながらに文を認めたるを見れば、限りなく愛くろしと思はる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あな愛くろし。この童の、袖を引きて離れざるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の隅に咲き初めたる、名もなき小草の花の、いかにも愛くろしきこと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
