        "examples": {
          "standard": [
            {
              "text": "私は毎日網猟について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網猟という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網猟の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網猟が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網猟を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網猟について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網猟の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網猟の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網猟が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網猟という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網猟という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網猟についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網猟を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網猟は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網猟について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網猟が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網猟は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網猟の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網猟は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網猟は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
