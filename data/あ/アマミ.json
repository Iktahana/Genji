      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sweetness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘味について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘味という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘味の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘味が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘味を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘味について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘味の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘味の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘味が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘味という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘味という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘味についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘味を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘味は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘味について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘味が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘味は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘味の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘味は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘味は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それからマントを正面壁に掛け、机に来て甘味さうに吹かす。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "橙紅色の丸薬のような実の落ち散ったのを拾って噛み砕くと堅い核の中に白い仁があってそれが特殊な甘味をもっているのであった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲食も、コーヒー、シトロン、紅茶などの近代的芳香の飲料と、阿倍川もち、力もち、葛湯、麦粉などの中世的粗野なる甘味が供給される。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに柿は「渋味」のほかになお「甘味」をももっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、「渋味」の対立者としては「甘味」を考えても差支ないと信ずる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　渋味―甘味は対他性から見た区別で、かつまた、それ自身には何らの価値判断を含んでいない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘味はその反対に積極的対他性を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "対他性上の区別である渋味と甘味とは、それ自身には何ら一定の価値判断を担っていない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘味についても、たとえば、茶のうちでは玉露に「甘い優美な趣味」があるとか、政よろしきを得れば天が甘露を降らすとか、または快く承諾することを甘諾といったりする時には、甘味は有価値的意味をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、「あまっちょ」「甘ったるい物の言い方」「甘い文学」などいう場合には、甘味によって明らかに反価値性が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、渋味と甘味とが対他性上の消極的または積極的の存在様態として理解される場合には、両者は勝義において異性的特殊性の公共圏に属するものとして考えられる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公共圏内の対他的関係の常態は甘味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、渋味は甘味の否定である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、その女のもっていた昔の甘味は否定されて渋味になっているのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味と地味とは共に消極的対他性を表わす点に共通点をもっているが、重要なる相違点は、地味が人性的一般性を公共圏として甘味とは始めより何ら関係なく成立しているに反して、渋味は異性的特殊性を公共圏として甘味の否定によって生じたものであるという事実である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味は甘味の否定には相違ないが、その否定は忘却とともに回想を可能とする否定である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば、渋味および甘味は「いき」とはいかなる関係に立っているか。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、甘味を常態と考えて、対他的消極性の方向へ移り行くときに、「いき」を経て渋味に到る路があることに気附くのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味において、甘味と「いき」と渋味とは直線的関係に立っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは甘味から「いき」への推移について語ったにほかならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷風の「渋いつくりの女」は、甘味から「いき」を経て渋味に行ったに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、この直線的関係において「いき」が甘味へ逆戻りをする場合も考え得る。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「いき」のうちの「意気地」や「諦め」が存在を失って、砂糖のような甘ったるい甘味のみが「甘口」な人間の特徴として残るのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、上品、意気、野暮、下品を角頂にもつ矩形は対自性上の対立を示し、派手、甘味、渋味、地味を角頂とする矩形は対他性上の対立を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、Ｏ、Ｐ、甘味、派手の矩形は積極性、Ｏ、Ｐ、渋味、地味の矩形は消極性を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「味」とは、甘味と意気と渋味とのつくる三角形を指していう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘味、意気、渋味が異性的特殊存在の様態化として直線的関係をもつごとく考え得る可能性は、この直角三角形の斜辺ならざる二辺上において、甘味より意気を経て渋味に至る運動を考えることに存している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだかの肌をするする撫でられるようなころ合いの酸味に、飯と、玉子のあまみがほろほろに交ったあじわいが丁度舌一ぱいに乗った具合――それをひとつ喰べて仕舞うと体を母に拠りつけたいほど、おいしさと、親しさが、ぬくめた香湯のように子供の身うちに湧いた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑぞゑぞのいしぐすくあまみきよがたくだるぐすくゑぞゑぞのかなぐすく　〔十五―一五〕　伊祖の石城はアマミキヨが築いた城ぞ、伊祖の金城は、という意である。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに就いては、今度「あまみや考」中にくわしく述べておいたから参照して頂きたい。",
              "citation": {
                "source": "土塊石片録",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
