[
  {
    "uuid": "67a79d49-e358-5981-8b50-fe9502fa6ca6",
    "entry": "甘味",
    "reading": {
      "primary": "あまみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
