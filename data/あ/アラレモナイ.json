[
  {
    "uuid": "d4678df8-41ec-51ac-825d-0aa3855731e3",
    "entry": "有られもない",
    "reading": {
      "primary": "あられもない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unladylike",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有られもないについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有られもないという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有られもないの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有られもないが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有られもないを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有られもないについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有られもないの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有られもないの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有られもないが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有られもないという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有られもないという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有られもないについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有られもないを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有られもないは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有られもないについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有られもないが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有られもないは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有られもないの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有られもないは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有られもないは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "有られもないこと「私、何う考えても面白くありませんわ」　安達君の軍師大谷夫人は美しいと自任している顔を曇らせた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の大家の娘が、あられもない賭博なんどとは……ちと受取り悪いが……」「ところが間違い御座いませんので……元来あの蔵元屋と申しまするは、蔵元町と申しまして町の名前にもなっておりまする位で、土蔵の数も七戸前。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と角目立ってあられもない、手先の突合いが腕の掴合いとなって、頬の引掻競。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさも訝しげに時次が謂えば、「まあ、あられもない扮装をしてどうしたというのだろう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つね日頃より貴族の出を誇れる傲縦のマダム、かの女の情夫のあられもない、一路物慾、マダムの丸い顔、望見するより早く、お金くれえ、お金くれえ、と一語は高く、一語は低く、日毎夜毎のお念仏。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾端折り、頬被して、男――とあられもない姿。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時おくれの古い紋着、襦袢も帯もうつりません、あられもないなりをして、恋の仇の奥様と、並んでここへ参りました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のあられもない姿が世に残っているかと思うと、恥かしいと情けないとで、居ても立ってもいられないような気がする。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とはいえあの「蟲」の主人公が、女優の屍体を土蔵の中からトウトウ取り出し得ずに、変テコになってヘタバッてしまう迄の極度にあられもない気分の変幻を、あんなに平気で扱い去った筆力の凄まじさには「鬼か人か」と叫びたいくらい、参いらせられてしまいました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも突然に老婆がワアと云って振り返ったら……なぞとあられもない事を考えているうちに、台所に首を突込んでゴソゴソやっていた老婆は、片手に茶碗を持ちながらヨタヨタと這いもどって来た。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それじゃあ手術台に肌脱の、俗にそれあられもないという処を見られたのが御縁になったか、但しちっとどうもおかしいな。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、愛吉、お前は、これね、」　とあられもない。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとておとよにあられもない疑いをかけられるも苦しいから、「おとよさん決して疑ってくれな、おはまには神かけて罪はないです。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　終ひに村長と私とは、あられもない口論の未、眼眦を裂いて別れたが、今もなほ、あの言葉は斯用に慣用されてゐるのを私は発見して、少なからずあきれたのであつた。",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あられもない事云うて、人の心をまどはさうとするのであらう。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　無我夢中となつた私は、あられもない鎧のいでたちで、まぶしく陽りの満ち溢れてゐる屋上の、白日の中に踊り出てしまつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板をおもちやにする位ゐのことなら、何もそんなに威猛高になつて激昂するにも当るまい、あの子供の云ひ草が疳に触るのは無理もないが――それにしても私は寧ろ亭主の神経的にあられもない姿が不可解であつたが、その時更に憾みがましい守吉の叫ぶ、しみつたれ！",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その途すがら、屡々狐に化されて、あられもない悲惨と滑稽とを演ずるといふところから、思ひあまつてお蕗の灸を決心した。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同の者は、互ひの顔が、あられもない空想のために、恥て、凝固してゐるのを認めた。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あゝ、それは、私のあられもない自惚れで、私は弱くて貧乏でそして稀代の塩辛声であつたのか――そのやうなあきらめ心も湧かぬでもなかつたが、今や、彼女の憧れは、太十の上にかゝつてゐるかも知れない。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると、窓の硝子扉へ、あられもない影法師のうつることさえあった。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなあられもない言葉を吐き出す一団が、ひと車輛全部を貸切りにしていても、あえて驚くにはあたらない。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――全く彼女等も日増に鬱憤が積み重なつて、あられもない矛盾の板挾みになるのも道理だつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あられもない濡衣をきせて、たった一人の姉を狂い死にさせた七人のかたきを唯そのままに置くまいと堅く決心したが、なにをいうにも相手はみな大の男である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵をおめおめと死なせた上に、あられもない悪評の的になっているのじゃ」　忠次郎は、声こそ出さないが、男泣きに泣いた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鴎丸は、舳先におしたてた公園の瓦斯灯のやうに巨大な新しい誘魚灯の手入れをしながら、あの日に、あまりの永雨で気をくさらせてゐる連中が誰を憎むといふわけでもなしに（つまり天を憾んで――）あられもない大立廻りの喧嘩が始まり、樽野が奇妙な仲裁役になつてしまつたことを云ふのであつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "定めし夫が、いつもの通り家賃とか敷金とかをごまかす為に、故郷の母にあられもない法螺を吹いたに決つてゐる、いつまで不良学生のつもりでゐるんだらう、実家の危期も忘れて――彼女は、斯う思ふと怖ろしくなつた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲谷は車の上で、昨夜参木と食い違って追い合ったその結果が、お杉にあられもない行為をしてしまったことについて考えた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は茫然と女史の、あられもない屍体の前に立ちつくした。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の風呂場で感電騒ぎが起ったとき、向井湯の直ぐ向う側にある交番の警官が、バタバタと飛び出して来た浴客の女達のあられもない姿を認めて、彼女等を訊問したことに依って早くも事件を知って、時を移さず表口や裏口に手配をしたことが報告されている。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
