        "examples": {
          "standard": [
            {
              "text": "私は毎日アンバランスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンバランスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンバランスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンバランスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンバランスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンバランスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンバランスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンバランスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンバランスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンバランスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンバランスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンバランスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンバランスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンバランスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "したがって、作中の人物の分析にアンバランスがある。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新しいこと」しかわからぬということは、「教養」の上からいえば、ひとつのアンバランスであり、畸型であり、その「新しいこと」すら、ほんとにわかっているかどうか怪しいと言えましょう。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って全体をアンバランスにし、片輪ものを感じさせる。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアンバランスがひどく好色的に見える。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに似たような、そしてそれよりも何千倍もグロテスクで恐ろしいアンバランスが、このことの中にあるような気がするのです。",
              "citation": {
                "source": "アメリカ人に問う",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、この関係のアンバランスが、主人公の時ならぬ破局をまねいたのである。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録的な構成の中に小説的な要素を持ちこんで、大した不自然さやアンバランスを引き起していないのは、最近現われたこの種の作品中目立ったものであるし、新しい小説分野への展開へのヒントのようなものをも含んでいる。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が頭が苦しかったから、この小さい頭のアンバランスも察しられてなかなかいいところをなでるらしくてトロトロよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "店に入るとラーメン屋でありながらジャズが流れているというアンバランスさにちょっと驚いたが、この向うの新宿通りにいつもボリュームいっぱいにロックをかけている弁当屋があるのを思い出し、特にこの店だけが変わってるわけじゃないんだなと独りごちて浩は苦笑した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Mellanby, 1921 （31）.　この頃までに、ジョンスホプキンスにおけるマッカラムと彼の医師共同研究者たちは、カルシウムとリンの比率を厳しくアンバランスにすることにより、使いやすいラットをくる病モデルにできることを見いだしていた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの影響を毒性、拮抗作用、インバランス（訳注：アンバランスとは言わない）に分ける試みがなされた（80）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとならその辺も、もっと突っこんで、近来の“一夫多妻論”や“一夫一婦尊重論”などに答えることもできようが、それは私本太平記の途上ではいたずらな構成のアンバランスになりかねないのだ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
