        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安打について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安打という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安打の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安打が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安打を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安打について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安打の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安打の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安打が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安打という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安打という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安打についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安打を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安打は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安打について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安打が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安打は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安打の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安打は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安打は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "またＡとＢとは同じ野球チームの選手だが、春のシーズンには二人とも同じ打撃率だったものが、秋のシーズンになってＡは安打数が増え、Ｂは相変らず凡打、三振を続けている。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "打チサエスレバ、カナラズ安打。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき五大洲は安打して一塁をとった、つぎのクラモウはバントした、手塚はそれを取って二塁へ投げようか一塁へ投げようかと疑惧してるうちに双方を生かしてしまった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンプシイとタニイ、ベイブの安打数、市長の選挙、軍縮会議の成否はもとより、生れる子が男か女か、今度とおる自動車は偶数か奇数か、お前とおれがどっちがさきに死ぬか、彗星が見えるか見えないか――人間万事があめりかでは賭け・賭け・賭け。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだ」と私は思つてゐた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜は聞きとがめて、「なあんだ、若旦那。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、あなたなの？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その草庵の垣根越しに、そつと覗いてみた者は、なあんだ、とがつかりさせられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はなあんだという気がしたと同時に自分らの思っているよりは遙かに現実的なそして一生懸命な世の中というものを感じたのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江島さんは大声で、「なあんだ、何時来たんだい。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と私が言ったら、「なあんだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、やっぱり、そうだったじゃないか。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん森の奥へ入って行きますと、一本の古い柏の木の下に、木の枝であんだ大きな笊が伏せてありました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ではたしかに濤の音「なあんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎やみんなは、河原のねむの木の間をまるで徒競走のように走って、いきなりきものをぬぐとすぐどぶんどぶんと水に飛び込んで両足をかわるがわる曲げて、だあんだあんと水をたたくようにしながら斜めにならんで向こう岸へ泳ぎはじめました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ではたしかに涛の音「なあんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだ、これでいいのか。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めんこいとっつあんだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだん／＼森の奥へ入つて行きますと、一本の古い柏の木の下に、木の枝であんだ大きな笊が伏せてありました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあんだ、戦争が終ってすぐじゃないか。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ったら、なあんだというような力ない安堵に似た笑い声が聴衆の間にひろがりました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあんだ、それは画題だ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のアントはね、……およそこの世で最も花らしくないもの、それをこそ挙げるべきだ」「だから、その、……待てよ、なあんだ、女か」「ついでに、女のシノニムは？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀は聞きとがめて、「なあんだ、若旦那。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだ、そんなら一緒に今夜、全部飲んでしまいましょう。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い出せば、それは、あたりまえのことで、なあんだということになるのかも知れないが、下手に言い出して曲解され、損をするのは、いやだ。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、越後にだつてあるぢやないか、お爺さんやお婆さんが揺籠を揺すりながら、乳母車を押しながらうたふのと同じぢやないか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、つまらない、といふ顔を金ちやんがした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、その事か。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだ、そんなにお顔を赤くなさっている癖に、まだ、とぼけようとしている。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
