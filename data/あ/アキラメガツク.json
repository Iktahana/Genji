        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その原因を臆測するにもまたその正否を判断するにも結局当の自分の不安の感じに由るほかはないのだとすると、結局それは何をやっているのかわけのわからないことになるのは当然のことなのだったが、しかしそんな状態にいる吉田にはそんな諦めがつくはずはなく、いくらでもそれは苦痛を増していくことになるのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、父の方をうかがうと、父はその女の子を可愛がろうともせずに、玉子と喧嘩ばかりしていたので、私はべつに自分や新次が父に可愛がられなくても、少しは諦めがつくと、早熟な考えをした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自分の思い通りにしたときは、失敗しても諦めがつくと思うのです。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結局それも駄目と諦めがつくと、黴が生えてどろどろになった液の底に蠅が無数に沈んでいるインキ壺へペンを突っこんで、まるで楽符のお玉杓子そっくりの文字をならべながら手紙を書きにかかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めるつていふ点から云へば、自分一人の胸に畳んでおく方が、早く諦めがつくでせう。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀策　　戦災に遭つた方が、まだ諦めがつくかもしれん。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の方は何とか諦めがつくとしても、毎日学校の往き帰りに、俊三と並んで歩かねばならないことは、次郎にとって、何としても我慢の出来ないことであった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし斯うなって見れば、完全に諦めがつく。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなると諦めがつく。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな接吻される位なら、乞食にだって、泥棒にだってキスされた方がまだいいわ、その方がまだあきらめがつくわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤作　けど弟さんの末さんが町の学校でようできるんやけに、旦那もあきらめがつくというもんやな。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうとき、本当に愛し合ったいろいろの思い出は愛を暖め直すし、またあきらめがつく。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのさいなんで、命びろいをしたと思えば、あきらめがつく。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いささか思いが残るが、壺を千貫目で買ったと思えばあきらめがつく。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の方ではあきらめているにしても、またもういらないといわれるとしても、原稿を持って行っての上でなら、こちらもあきらめがつくわけで帰京のあいさつを後回しにしてその原稿をまず書くことにしたのである。",
              "citation": {
                "source": "沖縄帰郷始末記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "増屋の旦那は、名代の※々親爺だ、――俺が見世物になるくらいの事は、何の、――親不孝の業さらしだと思えばあきらめがつく」「だって、兄さん」　兄妹二人の美しい争いを、平次と八五郎は、黙って見ているより外に工夫もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の茶釜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでだめなら、あんたもあきらめがつくでしょう。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中で盗まれる方が、安全な場所で盗まれるよりはあきらめがつく。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
