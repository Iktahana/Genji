        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そは「チベリナ」學士會院（アカデミア、チベリナ）の演壇の、我が上りて詩稾を讀み、又即興詩を吟ずることを許しゝがためなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "即興詩人としての我名は漸くヱネチアの都に傳はり、美術會院（アカデミア、デル、アルテ）は一日我を招きて技を奏せしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してペーソスなんていふしやれたものではなくて、それはとても悠長なトアパイロン見たいな、出来損ひのアミーバ見たいな奇怪なデタラメさ加減なのですが、さうかと思ふと洒落たアカデミアンで、読んでゆくうちに何だか得体の知れない信用を覚えさせられて来るのです。",
              "citation": {
                "source": "「風博士」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川幕府のアカデミアであった林氏の儒学とそのアカデミズムとは、全く幕府の権力に従属した一つの思想統制のシステムであった。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大学は、人類の理性と学問に関するアカデミアであるより以前に、官僚と学閥の悪歴を重ねた。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大学は、どのようなアカデミアであり、アカデミズムをもっているだろうか。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の大学に、もしアカデミアの精神が伝統するというならば、これらの人々が現在、大学とその教授、学生――即ちわたしたち人民に向って示す精神のどこにその片鱗を見よ、というのだろうか。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちの日本からは、正しい人民のアカデミアとアカデミズムが生まれてゆかなければならない。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその先に別棟になって二つの部屋があり、アカデミアとビブリオテカと名が付いているけれども、もちろん今はがらんどうである。",
              "citation": {
                "source": "パラティーノ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンツォ・デ・メヂチが、カレッジの別墅に文士を集めて清談を試みたと云ふ夜遊は、プラトンがアカデミアの昔を忍んだのであるといふけれど、單に人相同じからざるのみにあらで、其の山河もちがふ。",
              "citation": {
                "source": "足利時代を論ず",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フローレンスでは、アカデミア・デル・シメント（Academia del Cimento）に行って、図書館、庭園、博物館を見物した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "17世紀の初めのころアカデミア・デイ・リンチェイ（＊オオヤマネコ・アカデミー）創立のために数人の学者がチェシ公爵の宮殿に集まった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの広大な計画は実行出来なかったがこのアカデミア・デイ・リンチェイは半世紀以上にわたって優れた研究を行い類似した組織のモデルになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィレンツェではメディチ家のフェルディナンド２世とレオポルドが自然科学に興味を持ち主としてガリレイの弟子たちを集めアカデミア・デル・チメント（＝実験アカデミー）を創立した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミア・レオポルディナは1687年以来、いろいろと名前は変わったが現存する最古の科学アカデミーでハレ市に中心がある。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりの数の医師たちがアカデミア・デル・チメントの会員であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "レディもアカデミア・デル・チメント会員で、詩人、動物学者、医師であり「昆虫の発生に関する実験」の著者であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミア・デル・チメントの最も有名な会員はボレリであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
