    "definitions": [
      {
        "index": 1,
        "gloss": "Double Wing Attack (opening)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相掛かりは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相掛かりが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相掛かりに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相掛かりが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相掛かりについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相掛かりについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相掛かりについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相掛かりが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相掛かりが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相掛かりは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相掛かりは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相掛かりを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相掛かりをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相掛かりが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相掛かりの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相掛かりを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相掛かりに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相掛かりについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相掛かりは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相掛かりを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……いよいよ南と北のあいがかり、火の出るような鍔ぜりあいになってるというのに、こんなところで凧あげなんかしているひとがありますか！",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            }
          ]
        }
