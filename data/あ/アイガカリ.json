    "definitions": [
      {
        "index": 1,
        "gloss": "Double Wing Attack (opening)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
