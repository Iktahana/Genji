          ],
          "literary": [
            {
              "text": "」Ｔ「手前なかなか頭がいいな」　「そッそッそうだよ」と鉄五郎。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がよくて、そうして、自分を頭がいいと思い利口だと思う人は先生にはなれても科学者にはなれない。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……諸君なかなか頭がいい……。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がいいからむだな事に時を費やさないのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、そうか」　と、ひょうきんに言いながら、この女優大分頭がいいと思った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんのほうが、よっぽど頭がいいや。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットさまは、とても頭がいいから、僕の言おうとしている事は、言わないさきから御承知になっています。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄さんは、やっぱり頭がいい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも春秋座の人たちも、なかなか頭がいいと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は、ほとんど生粋の都会人の如き浅墓な社交振りを示して、「その弟さんは、しかし、あなたに似て頭がいいのでしょう？",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は、頭がいいと思いましたよ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一頭がいいからね。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父子兄弟とも、頭がいいのであるから、大事な場合に、激論などする筈はない。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで頭がいいとでも？",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今の人はみんな頭がいいから、ここまでお話をすれば、もう大抵お判りになったでしょうが、弁天堂で死んでいたのはやっぱり髪結のお国で、善昌は生きていたんです」「善昌が殺したんですか」と、わたしは訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは、頭がいい。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こいつは、勉強ができるだけあって、頭がいい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿馬鹿しい……そんなのが忠義じゃないと思う位に彼等は頭がいいのだ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシュースは頭がいいかも知れない、然し俺の方が遥かに上手さ、とスパイダーは得意になった。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サディ」「何しろマシュースの奴は頭がいいからな」スパイダーは独りで呟いた。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お道はわしなんぞとは違うて頭がいいけに、そのくらゐのもんはなんちやないがな。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは単に頭がいいということが、どんなにあてにならないかを示したものだと思います。",
              "citation": {
                "source": "双葉山を手玉にとった“じこう様”について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの事件ではっきりしたことは、人間はただ頭がいいということではなしに、科学的な裏付けをもった正しい判断が大切だということと、社会がすべての人にとって不合理のないように改善されなければ、いつまでたっても邪教はでてくるということです。",
              "citation": {
                "source": "双葉山を手玉にとった“じこう様”について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之からこの子爵が、犯人としてどの位頭がいいかを説明しましょう。",
              "citation": {
                "source": "彼は誰を殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふうん」　私はさすが警部というものは頭がいいものだとしばらくは感心していたが、ひろ子が犯人だなんてどうして信じられるものか。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、小川、警部の論理もひろ子のテオリー同様中々頭がいいじやないか」「うん、しかし腑におちない点があるな」「そうかね。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだ子その他とはダンチに頭がいい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は君もきいた通り中々頭がいい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお役人の頭がいいました。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "在る……なかなか頭がいいね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
