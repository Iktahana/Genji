        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アドバルーンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドバルーンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドバルーンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドバルーンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドバルーンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドバルーンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドバルーンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドバルーンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドバルーンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドバルーンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドバルーンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドバルーンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドバルーンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドバルーンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "恋の季節を修飾する早春の枯木や、アドバルーンや、轢死人が彼等の周囲にあって移動した。",
              "citation": {
                "source": "玩具",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り背中のところで、どてらはアドバルーンのように丸く膨らんでいた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ソーセージ型のアドバルーンだよ！",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、またはなやかなアドバルーンのようにも、糸が切れた風船玉のようにも、うすべに色をして、美しかったのです。",
              "citation": {
                "source": "道の上で見た話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "デパートの屋根には、アドバルーンが高く上がっていました。",
              "citation": {
                "source": "青い草",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版・ラジオ・キネマ・演台（舞台及び演壇）、博覧設備（展覧会・博覧会・ショーウィンドー・スカイサイン・アドバルーン等々）など＊。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それから同じ報道現象でも広告は、色々の斬新新奇な乗具を用いるが（例、アドバルーンの如き）今は言論の表現報道だけに話を限定しよう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治的言論に限らず、文学乃至純文学的表現発表までも含むが併しアドバルーンやチンドン屋は入れないことにするわけである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は繋留気球を見ていつも思うことだが、アドバルーンというものは上に昇る性能を持っている。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがアドバルーンの独自性であって、それによってアドバルーンの役割を果している。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、上に昇るだけでアドバルーンとして完全であるかというと、そうではない。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地に繋がれていないと、アドバルーンとしての役割を完全に果すことができない。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、上に昇るという独自の能力があり、同時に他方には、それが大きなものに繋がりを持っているというところに、アドバルーンの存在の意義がある。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機時代から見れば問題でないが、時は日露役前の明治三十六年、アドバルーン宜しくの円形繋留気球が一進歩して、葉巻型の気球が初めて陸軍の御採用。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、アドバルーン（広告気球）だ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドバルーンにぶらさがっているのだ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「透明怪人」劇のアドバルーンなのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドバルーンは、塔の屋根から、つなで空にういていたのですが、四十面相はそのつなを切って、赤い布の大文字にすがりつき、大ふうせんのとびさるままに、身をまかせたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドバルーンのガスは、すこしずつ、もれていきます。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界劇場の塔から、四十面相が、アドバルーンでとびさった、あくる日のお昼すぎのことです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、アドバルーンっていうんだよ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少年たちは、怪人四十面相が、アドバルーンにつかまって逃げたことを、まだ知りません。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は怪人四十面相がアドバルーンで逃げたことを、ちゃんと知っていたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらべてみると、たしかに、世界劇場のアドバルーンでした。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの悪がしこい四十面相が、海のまんなかへ落ちるかもしれないアドバルーンなどで逃げるはずがありません。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その人形をアドバルーンのつなに、しばりつけ、さも、自分が空中へ逃げたように見せかけたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、みんなの目を、アドバルーンに、ひきつけておいて、そのすきに、ふしぎな手品を、つかったのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官と乞食少年　お話はもとにもどって、黒衣の人形をしばりつけたアドバルーンが、世界劇場の塔から、とびさった、すぐあとのことです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、みんなアドバルーンに気をとられていたので、このふしぎな警官に注意するものは、ひとりもありませんでした。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
