        "examples": {
          "standard": [
            {
              "text": "私は毎日有りきについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りきという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りきの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りきが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りきを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りきについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りきの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りきの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りきが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りきという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りきという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りきについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りきを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りきは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りきについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りきが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りきは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りきの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りきは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りきは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もっとも有りきたりの陳腐な方法を追求する場合には、器械の良いほど良い結果を得られるのは普通である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山住ひではごく有りきたりの出來事のやうにして靜かな樣子で聞いてゐる。",
              "citation": {
                "source": "山日記　その一",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（又　）（一四）夏の時に及んでは、卞隨・務光なる者有りき』と。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りに「太初に言葉ありき」といふことを考へてみるに、そは「太初に意ありき」といふことであると同時に「太初に意を聴かされしものありき」といふことである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾てこの河に漁どりすべくいとむつまじき二人のうなゐありき、されどその事たえたる今にして蓼の香さむきあしたには寒水のほとりうら悲しき笛の音をきくものありと云ふは何ぞや。",
              "citation": {
                "source": "斷調",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜眼さめて指針の光れる時計をば枕辺に見る二時にしありき　結句「二時にしありけり」と云わないで『ありき』と留めた処に深い感じがある。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで子供を生んでもらうためなんてしらじらしい、ありきたりの嘘を云ったのですか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人が差向いにて夕餉につく様こそ見たけれなど滑稽芝居見まほしき心にて嘲る者もありき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はみな泉を去りて、　　　　山ちかくつどひてありき。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しきものども、何とてやはわれをみいだし得む、愚なる、と冷かに笑いしに、思いがけず、誰ならむたまぎる声して、あわてふためき遁ぐるがありき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "断崖の左右に聳えて、点滴声する処ありき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松柏のなかを行く処もありき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに海野はこれを聞きて、不心服なる色ありき。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が嘗て住みし谷中の家の庭に一｜本の此樹ありき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場のさる人の庭のいと濶きに此花のいと多く咲きたるを見しそれの年の秋の夕暮、かゝるところにてこそさる男も泣きけめと、楸楡颯々｜蓬艾蕭々として夕月の光り薄く西風の音の淋しかりしまゝ、勝れて艶なる此花を見る／＼徘徊りて想ひやりたることありき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりこの興奮剤の正当な作用でありきき目であるに相違ない。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの気取りに対するたたかいです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の片隅を指先で小さくむしっておいて、結いたての日本髪（ごくありきたりの髷だったが、何という名だか園は知らなかった）の根にさした銀の平打の簪を抜いて、その脚でするすると一方を切り開いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの品物だけれども、大事に取り扱われているためか、その瑠璃色の部分が透明で、美しい光沢を持っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨を入れて蝙蝠傘のような形に作った白紙の笠、これとてもありきたりのものだが、何んとなく清々しくって、注意してみると、一カ所、針の先でいくつとなく孔を明けた所があった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのやうな時もありき、寒い寒い　日なりき。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦女等は苦悶に苦悶を重ねて、人心地を覚えざるもありき。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寶暦五年春三月、伊豆守江戸に參覲ありて、多日在府なされし折から、御親類一同參會の事ありき、幼君其座にて、「列座の方々、いづれも豫て御存じの如く、某勝手不如意にて、既に先年公義より多分の拜借いたしたれど、なか／＼其にて取續かず、此際家政を改革して勝手を整へ申さでは、一家も終に危く候。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中の婦人はこれが始終を見物しながら、貴族たる権威の発表せられしを歓べる色ありきという。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と屹と老婦人の面を見たる瞳は閃然として星のごとく、渠は太く愁色ありき。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子は喜べる色ありき。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁くて互に其の間に考案する隙ありき。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の灯美しき夜ありき。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれにも聞かすことはなりません」　夫人は決然たるものありき。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
