          "standard": [
            {
              "text": "私は毎日ＡＲＰについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＡＲＰの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＡＲＰが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＡＲＰについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＡＲＰの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＡＲＰが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＡＲＰという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＡＲＰについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＡＲＰは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＡＲＰが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＡＲＰは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＡＲＰの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＡＲＰは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "エンゲルバードのものをはじめ、さまざまなコンピューターのプロジェクトを支援していたＡＲＰＡ（国防省高等研究計画局）は、一九六七年春、資金を提供しているすべての研究所のマシンをネットワークで結ぶ計画を発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＡＲＰＡＮＥＴ★によって、自らのＮＬＳが距離の壁を乗り越えてしまうことに、彼は知的な衝撃を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★一九六九年に運用が始まったＡＲＰＡＮＥＴは、その後、研究機関を結ぶＣＳＮＥＴ（Computer Science NETwork）などとの接続によって規模を拡大し、インターネットへと発展していく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゲルバード氏がＡＲＰＡＮＥＴ越しに見た夢は、今、大きく花開いている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレックスの開発作業はＡＲＰＡの援助を受けて進められ、ケイは操作用にキーボードは付いているけれど、プログラミングにはパンチカードを使うしかなかったＩＢＭの１１３０というコンピューターで作業を進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じＡＲＰＡをスポンサーとしていた関係で、ダグラス・エンゲルバートにはすでに一九六七年に会っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＲＰＡは研究を後援している大学院生の会議を、定期的に開いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "対話型のシステムの可能性にいち早く注目して、ＡＲＰＡの情報処理部長としてエンゲルバートのＮＬＳを支援したボブ・テイラーは、一九七〇年にゼロックスが新設した、パロアルト研究所の実質的な責任者として招かれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴の今一つの英名エープは、梵名カピから出たギリシア名ケフォス、ラテン名ケブス等のケをエと訛って生じたとも、また古英語で猴をアパ、これ蘭名アープ、古ドイツ名アフォ等と斉しく猴の鳴き声より出たともいう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
