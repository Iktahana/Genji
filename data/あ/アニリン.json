        "examples": {
          "standard": [
            {
              "text": "私は毎日アニリンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アニリンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアニリンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアニリンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アニリンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアニリンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アニリンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアニリンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアニリンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アニリンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアニリンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアニリンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アニリンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアニリンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アニリンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアニリンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアニリンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアニリンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アニリンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアニリンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある時たまたま逢った同窓と対話していた時に、その人の背後の窓から来る強い光線が頭髪に映っているのを注意して見ると、漆黒な色の上に浮ぶ紫色の表面色が或るアニリン染料を思い出させたりした。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして東京みやげの「江戸絵」を染めたアニリン色素のなまなましい彩色がまだ柔らかい網膜を残忍にただらせていたころの事である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園は右手の食指に染みついているアニリン染色素をじっと見やった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南部の紫紺染は、昔は大へん名高いものだったそうですが、明治になってからは、西洋からやすいアニリン色素がどんどんはいって来ましたので、一向はやらなくなってしまいました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらのゴミ溜や、よその畠から失敬して来た材料にアニリン塗料とサッカリンで色と味を附けた、ちょっと口あたりのいい料理を作るのが芸術界の大勢になって来る。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日増しの材料とアニリン塗料と、サッカリンの味とにいつとなく飽きて来る。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実話の流行、新進作家の濫造、座談会の隆盛が、この慾求を満たすべく現われ初めたが、これとてもアニリン、サッカリンで味を占めた店は、真剣なものを作ろうとしない。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりアニリン、サッカリン趣味の名だけの新進創作、実話、座談会を濫造する。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおまた多くのアニリン色素は、紫外線に当たるときわめて美しい光を発します。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、この黒い紙に、アニリン色素で書いたものです。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アニリン色素は紫外線に当たると、このとおり蛍光を発するものです」　と俊夫君は言いました。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと頃ドイツで「アニリン」とかその他科学小説がかかれましたが、その場合、科学技術者というものの特殊性がどこまでとらえられていたでしょうか。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一は自分の手に、紫のアニリン染料が附いているのを気付かないで、紳士の濡れたハンカチを取ろうとしたために、隅の方に紫の指痕を附けた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地先で昨夜、極東染料会社の移転でもって、アニリン染料の真青な液が一ぱい大樽に入っているのを積んだトラックがハンドルを道悪に取られ、呀っという間に太い電柱にぶつかって電柱は折れ、トラックは転覆し、附近はたちまち停電の真暗やみになった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アニリン剤の青竹や洋紅に毒された世界近代の画人は此の前に愧死するに値する。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はアニリン染料に圧倒せられて、紫根染めを見ることはきわめてまれとなっている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今それをアニリン染料の紫に比ぶれば、地色が派手でないから、玄人が見れば凝っているが、素人の前では損をするわけだ。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このベンジンからアニリンが採れるので、従って今日のアニリン色素製造の大工業の基礎になった発見というてもよい。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後エールリッヒの学生時代になって多数のアニリン色素が市場で得られるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北の婦人がアニリン色素を喜び、モスリン、紀州ネルに心を傾けるのはもちろん流行であるが、末法の今日にいたるまで、上下二つの裳を堅く身にまとい、でき合いの人形のようにただきればかりを節約したがる改良服論者を毅然としてのけているのは、すなわちこれ正風の尊さではないか。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
