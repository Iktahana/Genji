    "definitions": [
      {
        "index": 1,
        "gloss": "(as used in Northern Japan) greenling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油子について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油子は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油子の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油子について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油子は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油子の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油子に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油子が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油子を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油子の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油子が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油子が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油子について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油子は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油子は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油子は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油子について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油子の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油子の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油子の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "北海道で油子といふのが、関東のアイナメで、関西ではアブラメ、佐渡ではシジウなどといふ。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、楕円形の見事な大櫃には盛り上った白飯が置かれ、それを包んで並んだ膳には、主人の参右衛門がこの日磯釣りして来たあぶらこという魚が盛ってある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶらこという魚は長さ四五寸の小さなものだが、このあたりではこの魚を非常に珍重する。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
