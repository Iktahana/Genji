        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "曙は知らず、黄昏に此の森の中辿ることありしが、幹に葉に茜さす夕日三筋四筋、梢には羅の靄を籠めて、茄子畑の根は暗く、其の花も小さき實となりつ。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思へ、とどろく跫音に大御軍の征くところ、物ことごとくよみがへり、茜さす日ぞ照り滿たむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜さす額の薔薇の花、蔑まれた女の憤怒、茜さす額の薔薇の花、おまへの驕慢の祕密をお話し、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "萠野ゆきむらさき野ゆく行人に霰降るなりきさらぎの春　これも言葉の音楽で別に意味はない、初めの二句はいふまでもなく額田の女王の歌茜さす紫野行き標野行きの句から出て居るのであるが、その古い日本語の音楽を今様に編曲して元に優るとも劣らないメロヂイを醸成してゐること洵にいみじき極みといふべきだらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明るい陽に照らされて、浅間山の中腹から、前掛山の頂かけて茜さすのは秋草の霜にうたれた色であるかも知れないと思う。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山の裾野にあかねさす紫匂ふ花あやめかも櫻草の花によく似る紫の花めでつゝも名を知らずけり花あやめしみ咲きにほふ紫の花野を來れば物思もなし紫の雲ゐる野べに朝遊び夕遊びます二荒の神湯の滝を見、湯本に遊びて帰る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中あかねさす西日は照れどひぐらしの鳴き蟲山に雨かゝる見ゆゆくゆく一人の少女のいと艶なるに逢う。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "野は、あかねさすむらさき野。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかねさす花の若えはおとろへぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼうと首筋までがなにやら陰にこもって赤らんでおりますね、あかねさす色も恥ずかし恋心というやつだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかねさす光は空に曇らぬをなどてみゆきに目をきらしけんぜひ決心をなさるように。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "○あかねさす紫野行き標野行き野守は見ずや君が袖振る　〔巻一・二〇〕　額田王　天智天皇が近江の蒲生野に遊猟（薬猟）したもうた時（天皇七年五月五日）、皇太子（大皇弟、大海人皇子）諸王・内臣・群臣が皆従った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あかねさす」は紫の枕詞。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○あかねさす日は照らせれどぬばたまの夜渡る月の隠らく惜しも　〔巻二・一六九〕　柿本人麿　日並皇子尊の殯宮の時、柿本人麿の作った長歌の反歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぬばたまの夜わたる月の隠らく」というのは日並皇子尊の薨去なされたことを申上げたので、そのうえの、「あかねさす日は照らせれど」という句は、言葉のいきおいでそう云ったものと解釈してかまわない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の第二句は、「日は照らせれど」であるから、以上のような解釈では物足りないものを感じ、そこで、「あかねさす日」を持統天皇に譬え奉ったものと解釈する説が多い。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○あかねさす昼は物思ひぬばたまの夜はすがらに哭のみし泣かゆ　〔巻十五・三七三二〕　中臣宅守　これは中臣宅守が娘子に贈った歌だが、この方は気が利かない程地味で、骨折って歌っているが、娘子の歌ほど声調にゆらぎが無い。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカネの根から前述の様に染料が採れ、その色が赤いから「あかねさす」と言う枕言葉も生じた訳で、それは赤い事を意味する。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天智天皇、蒲生野に遊猟し給える時、額田王の歌った、「あかねさす紫野行き標野行き野守は見ずや君が袖振る」という歌に対し、東宮の大海人皇子の答えた有名な相聞がある。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかねさすむらさき野ゆきしめ野行き野守りは見ずや君が袖振る　すると高氏もすぐ言った。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
