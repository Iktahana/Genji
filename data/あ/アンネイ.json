        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安寧について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安寧という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安寧の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安寧が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安寧を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安寧について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安寧の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安寧の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安寧が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安寧という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安寧という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安寧についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安寧を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安寧は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安寧について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安寧が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安寧は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安寧の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安寧は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安寧は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "厳父の厳訓に服することは慈母の慈愛に甘えるのと同等にわれわれの生活の安寧を保証するために必要なことである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明を誇る日本帝国には国民の安寧を脅かす各種の災害に対して、それぞれ専門の研究所を設けている。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして民族の安寧と幸福を保全することが為政者の最も重要な仕事の少なくも一部分であったのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ国民社会一般の幸福安寧に資すべき調査研究報告機関のようなものになってしまう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、これらの経は、直接個人の幸福に関係するというよりは、むしろ天下国家の安寧福利に関係ある経であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人の言ふやうに、仏蘭西革命は退屈から起つたので、之れがいちばん社会の安寧に危険なものだ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸木戸の権威を保ち、町の騒動や危険事故を防いで安寧を得せしむる必要上から、警察官的権能をもそれに持たせた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年九月六日この日安寧秩序を紊亂するものとして社會主義書類五種發賣を禁止せられ、且つ殘本を差押へられたり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに裁判所が公判開廷の初日に於て公開を禁止したる爲に、復疑を容るゝものありと雖も、苟も對審の公開にして安寧秩序を害するの虞ありと認めたるときは、之を停止し得べきは國法の命ずる所にして、裁判所は普通の事件に付ても之を行ふことを得。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして私は、たとひ其動機が善であるにしろ、惡であるにしろ、觀劇的興味を外にしては、我々の社會の安寧を亂さんとする何者に對しても、それを許す可き何等の理由を有つてゐない。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは安寧秩序を妨げたり、臣民の義務に背かせない限りの自由である。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安寧秩序を妨げたり、臣民の義務に背かせるやうな思想は危險思想である。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　不当な大金であるとは思ったが、それだけに母に送ったときの母の笑顔や、またその金に依って、一家の生活と安寧とが、一月でも三月でも支えられるということは、新子にとってはたいへんなことだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長｜家高某という者、世に神仏は無用の物なり、万事村長の言をさえ遵奉せば安寧浩福なりとの訓えなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民ノ安寧秩序ヲ保持スルコトガ國家ノ唯一任務ナリトセバ、國民ノ死活榮辱ヲ日夜ニ亘リ終生ヲ通ジテ脅威シツツアル此等ヲ處分セズシテハ國家ナキニ同ジ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち彼等は専ら腕力を用ゐて或組の果報と安寧とを妨害せんと為るなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の真情は既に嬢様に献げたから、自分は生涯妻を娶らず、永く独身で清く送つて嬢様の安寧幸福を神に祈ると云つておるさうだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡は××に來る度に、かういふものを「お×はりさん」と云つて、町では人達の、「安寧」と「幸福」と「正義」を守つて下さる偉い人のやうに思はれてゐることを考へて、何時でも苦笑した。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "また国家が人を罰するのは復讐の為でもなく、また社会安寧の為でもない、人格に犯すべからざる威厳がある為である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバルトソン・スミスも「宗教は不可知的力を恐れるより起るのではない、己と血族の関係ある神を敬愛するより起るのである、また宗教は個人が超自然力に対する随意的関係ではなくして、一社会の各員がその社会の安寧秩序を維持する力に対する共同的関係である」といっている。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、今では荷厄介なこの己の存在が、他所様の安寧を妨げるのを、そっと静かにおそれているのである。",
              "citation": {
                "source": "曲者",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも一身の打算と安寧からだけ進退したがる現今の人心を、よいと認めることの出来ない常識に、こういう山本有三氏の或る程度の社会正義感の発動は、少なからず触れるものをもっているのは自然である。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし被征服階級がいささかでもこれに疑惑をさしはさむようになれば、それは社会の安寧と秩序との大なる紊乱を生ずるもととなる。",
              "citation": {
                "source": "征服の事実",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれがその子供たちの生命とその家庭の安寧を守ることを神聖な義務と考えていることを、世界の希望をになう婦人および母親たちに知らしめよ。",
              "citation": {
                "source": "わたしたちには選ぶ権利がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を失ったあらゆる子供たちの将来の安寧と幸福を築き守るものは、共通の涙と奮起する心とを知り合っている婦人たちの実行ばかりである。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん私は掠奪や殺人や放火を企てそして公共の安寧のいつはれる楯にかくれて最も卑しい利己的な目的をねらつてゐる革命の輩の味方ではない。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうに民族は、半神の如く先頭に立つて守護と安寧となるやうな民族の英雄を作り出す。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
