        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天が下について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天が下という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天が下の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天が下が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天が下を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天が下について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天が下の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天が下の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天が下が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天が下という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天が下という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天が下についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天が下を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天が下は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天が下について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天が下が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天が下は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天が下の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天が下は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天が下は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やはり天が下に新しいものは一つもないと思ってひとりで感心して帰って来たのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天が下に新しいものはない」というのはこういう事を指していうのかもしれない。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智光秀も信長を殺す前には愛宕へ詣って、そして「時は今｜天が下知る五月かな」というを発句に連歌を奉っている位だ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀は紹巴に「天が下しる五月哉」の「し」の字は「な」の字｜歟といわれたが、紹巴はまたこの公には敵わない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は人知れず天が下にて行なわれし厳かなる事実なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "積薪習ひ得て、將た天が下に冠たり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下に何と烏ともあろうものが、大分権式を落すわけだな。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天が下に一の新しきものあることなし！",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下に一の新しきものあることなし！",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに貴重な紙を、どっさり汚して印刷され、私の愚作は天が下かくれも無きものとして店頭にさらされる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の愛宕山の連歌で、ときは今｜天が下知る五月かな　と云う発句を見ても、天下を狙う大志が躍動しているわけである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、秀吉に訊問せられた時、「天が下成る」であったのを自分に反感を持つものが、知るに訂正したのであると云った。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下に何と烏ともあらうものが、大分｜権式を落すわけだな。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "信者のある所、天が下、これ皆拙者の安住地でござる」「大きく出たな」と由井正雪、今度はあべこべにヘラヘラ笑った。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル教の大行者、島原神父のご神殿は、この天が下、人あるところ、至る所にござるぞよとな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしいよろしい天が下、人ある所おめえの住居、大きく出たところに稚気があって、そうして大変可愛らしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであねごの隠れ家だが、やっぱりそうだ天が下、人ある所にあるらしい」ここで意地悪く笑ったが、「ただしちょっくら匂わしておく。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのだいたいが、あぶないものさ『この天が下、人あるところ、みなそれがしの住居でござる』などと途方もなく大たばをきめこむ、あの島原城之介の住居だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下には隱家もなくなつて、今｜現身の英傑は我が目前咫尺の處に突兀として立ち給うたのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――すべて木の葉の中で、天が下の王妃の君とも稱ふべき公孫樹の葉、――新山堂の境内の天聳る母樹の枝から、星の降る夜の夜心に、ひらり／＼と舞ひ離れて來たものであらう。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで其種の聲の太い人間は、鼠賊と一緒になつて、大笊を抱へて夜中に林檎畑に忍ぶことが出來ぬから、勢ひ吾輩の如く、天が下に家の無い、否、天下を家とする浪人になる。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下には隠家もなくなつて、今｜現身の英傑は我が目前｜咫尺の処に突兀として立ち給ふたのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――すべての木の葉の中で、天が下の王妃の君とも称ふべき公孫樹の葉、――新山堂の境内の天聳る母樹の枝から、星の降る夜の夜心に、ひらり／＼と舞ひ離れて来たものであらう。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで其種の声の太い人間は、鼠賊と一緒になツて、大笊を抱へて夜中に林檎畑に忍ぶことが出来ぬから、勢ひ吾輩の如く、天が下に家の無い、否、天下を家とする浪人になる。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天が下にはかくれ家もなし、まつたくね！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ法體なれ、ありし昔の瀧口が此君の御爲ならばと誓ひしは天が下に小松殿｜只一人。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "當今｜天が下は源氏の勢に充ちぬるに、そも何地を指しての御旅路にて候やらん』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れあらん小松殿の嫡男として、名門の跡を繼ぐべき御身なるに、天が下に此山ならで身を寄せ給ふ處なきまでに零落れさせ給ひしは、過世如何なる因縁あればにや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
