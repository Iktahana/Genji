    "definitions": [
      {
        "index": 1,
        "gloss": "new",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日新たについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "新たという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は新たの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には新たが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "新たを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは新たについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "新たの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は新たの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では新たが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "新たという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に新たという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では新たについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "新たを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると新たは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "新たについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では新たが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に新たは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により新たの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "新たは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に新たは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "冬の野原を夏の風が行くに煙が去つた情熱の火が突進するブツカルものもなく――だから不可ない昔からあつたものだのに今新たに起つたものだそれを如何して呉れるい横から眺めてゐるな誰の罪でもない必要ぢやない欲しいだけだ",
              "citation": {
                "source": "情慾",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、一つの作品が生れたといふことは、今迄箒しか存在しなかつた所へ手拭が出来たといふやうに、新たに一物象が存在したことであり、従来あつたものの改良品が出たといふやうなこと以上である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に今日に於ける僕等の醫療は、その「失はれた耳の健康」を新たに囘復することでなければならぬ。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路みな霜に凍りて冬の凜烈たる寒氣の中地球はその週暦を新たにするか。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは尚悔いて恨みず百｜度もまた昨日の彈劾を新たにせむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の思惟するものを斷絶して百｜度もなほ昨日の悔恨を新たにせん。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかんぞ殘生を新たにするも冬の蕭條たる墓石の下に汝はその認識をも無用とせむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年來り、百度過失を新たにするも、我れは尚悲壯に耐へ、決して、決して、悔いざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに実施された児童虐待防止法案に、引つかゝる程にも泣き喚くのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又雨の音と川瀬のせゝらぎとが新たな感覚をもつて枕に迫つて来る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また五分くらいすると不意に思い出したように一陣の風がどうっと吹きつけてしばらくは家鳴り震動する、またぴたりと止む、するとまた雨の音と川瀬のせせらぎとが新たな感覚をもって枕に迫って来る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとなでつけるのかと思ったら自分で新たに巻き直すと見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辛辣にして愉快なる三十棒の響きは今にして筆者の耳に新たなるものがある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、またもとのｅとyeとの区別が失われて、新たに語頭にはｅを用い、語頭以外にはyeを用いるというきまりが出来たかも知れない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の（二）および（四）の音変化の結果、もと直音であったものが新たに拗音となり、拗音を有する語が多くなった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、明治以後になって大矢透氏がこれを新たに調べ直してその説が正しいということを証明し、そうして、もう少し材料を補って『古言衣延弁証補』というものを書かれたのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼にとって大きな悲しみであったのみならず、父の遺産の管理という新たな責任が彼の科学的生活の前途を妨げはしないかという心配があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは石油ランプを使っていたのをガス燈にし、また実験用の吹管や何かに使用するために、新たに自家用のガス発生器を設備した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ある会社のある工場に新たに就職した若い男が、就職後間もなく誰かから自分の前任者が二人まで夭死をしたこと、その原因がその工場で発生する毒｜瓦斯のためらしいという話を聞き込んで、ひどく驚きおびえて、少し神経衰弱のような状態になっていると聞いた。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに今度新たに岩波文庫で読み返してみると、実に新鮮な記憶が残っていた。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体津田君の主張するように常に新たな眼で自然を見直すという事は科学者にとっても甚だ重要な事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十一日『東京朝日新聞』）　　　　　　　　　三十六　　　　　　ドイツの製粉研究所　ドイツ人がすべての工業の発達を計るためにその根本たる科学的の研究に注意する事は今に始めぬ事だが、今度また麺麭粉の研究所を新たに設立し既設の製糖並びに醸造研究所とともに三幅対を作るそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月十七日『東京朝日新聞』）　　　　　　　　　五十一　　　　　　坑夫に賞牌　英皇エドワード陛下は今度新たに二種の賞牌を制定せられた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英仏海峡の難避者を満載した船の上で、過去の傷ましい事件が私の記億を新たにするのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀が稲妻のように舞踊靴の部屋に這入ってくると、彼は米良にボロジン一味が再び南昌から漢口に潜入したことを告げ、彼は嶮しい眼を閉じるとボロジンの南昌入によって新たな時局の転廻となるか、恐らくは最期の瓦解となる二つの道を告げるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、云うのは昨日広東の事変で共産軍が敗れると、武漢、南京、広東の三政府が提携して新たに国民党中央政府の設置が提議され、俺はその委員に名を連ねたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうさう、それからねえ……」　やがて青木さんはその冷やかな現実の意識を逃れようとするやうに、新たな空｜想をゑがきながら、奧さんを振返つた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから五六日して、上野動物園で貘の夫婦をあらたに購入したという話を新聞で読み、ふとその貘を見たくなって学校の授業がすんでから、動物園に出かけていったのであるが、そのとき、水禽の大鉄傘ちかくのベンチに腰かけてスケッチブックへ何やらかいている佐竹を見てしまったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
