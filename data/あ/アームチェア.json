        "examples": {
          "standard": [
            {
              "text": "私は毎日アームチェアについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアームチェアの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアームチェアが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアームチェアについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアームチェアの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアームチェアが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアームチェアという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアームチェアについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアームチェアは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアームチェアが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアームチェアは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアームチェアの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アームチェアは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアームチェアは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寮長室のドアをあけて最初に目にしたのは、窓を背にしてアームチェアに坐り、頭のうしろで手を組み、こころもち顔を上にむけ、目をつぶった寮長だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソファー、アームチェア、ライチングデスク、それらの物は鞣革と、紫檀とで出来て居りました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大きなアームチェアにポコンと埋って、大人しくパンを噛っている子供を抱き上げた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――私は彼女をもとのアームチェアに下しながら云った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　テーブルの　はしに　すてきな　みどりの　アームチェアが　あったんだけど、　それが　まるで　アリスの　せきみたいに　みえてね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とぷんすかアリス、そうしてテーブルのはしにあった大きなアームチェアにどしん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブスマン　失礼して――（アームチェアを引き寄せる）ガル博士　どうか――ファブリ　ぼくも――アルクイスト　船旅はいかがでしたか？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "（右手のドアの前にアームチェアとテーブルを引っ張ってくる）　爆発音が聞こえる。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一人の紳士がおり、気楽そうにアームチェアに凭れていた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはアームチェアを暖炉とランプの間にありえない角度で置くし、テーブルクロス――トリニティ・ホールのステンドグラス模様付き――をテーブルにかけるやり方を見たら、ネクタイや服がひん曲がっていた時とそっくり同じ感じがする。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアームチェアでもソファーでもなく、なにかえたいの知れぬ巨大なクッションであった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "影男はその長イスのひじ掛けに身をもたせて、最も安易な姿勢をとり、かれを導いた男は、その向こう側のアームチェアに、行儀よく腰かけた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの娘は長イスにかけ、アームチェアの影男と相対した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おり入ってお話があるというので、利害関係のあることだから、追い帰すわけにもいかず、応接間に通させておいて、行ってみると、見も知らぬ小男が、大きなアームチェアにちょこんと腰かけていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぞいてみると、まんなかに大テーブルがすえてあって、それをかこんで、アームチェアがならべてありますが、人の姿はありません。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、アームチェアにこしかけて、顔を見あわせました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男はひくいバスの声でそういいながら小林君たちのむこうがわのアームチェアに、ゆったりと、腰をおろしました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸テーブルをかこんで、ソファ、アームチェア、婦人用のもたれのない椅子、木製のもたれの小型の椅子など、つごう七脚のセットが、はでやかに並んでいた。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼は一つのアームチェアに沈みこんだまま、ほかの椅子を試みようともしなかったのだ。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷きつめた高価なペルシャジュウタン、まっ白に塗った天井、船内とは思われぬ凝ったシャンデリヤ、飾り箪笥、織物に覆われた丸テーブル、ソファ、幾つかのアームチェア。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "名探偵の憂慮　邸内の応接室では、アームチェアにもたれた明智小五郎の前で、神谷青年が、人間｜豹恩田との異様な出会いからのすべての出来事を、くわしく説明していた。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方のすみに畳一畳もある事務机、まん中には客用の丸テーブル、ソファー、アームチェア、いずれも由緒ありげな時代ものだが、これらは皆、元金ではなくて利息の代りに取り上げた家具類である。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分ほど、彼はアームチェアにもたれこんで、じっとしていた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "克彦は書斎のアームチェアを窓際によせて、それにかけたまま、カーテンの隙間から覗いていた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋口と三益と並んで見てると、樋口はゆふべからのベロ酔い、いびきかくので、外へ出しといたらアームチェアで小便しちまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "にせの明智探偵は、あの鏡の部屋のアームチェアに、ゆったりと腰かけて、タバコを吹かしていました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
