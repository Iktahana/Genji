    "definitions": [
      {
        "index": 1,
        "gloss": "fat greenling (Hexagrammos otakii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油女について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油女は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油女の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油女について知っています。",
              "source": "幻辞"
            },
            {
              "text": "油女は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油女の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油女に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油女が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油女を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油女の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油女が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油女が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油女について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油女は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油女は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油女は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油女について学びました。",
              "source": "幻辞"
            },
            {
              "text": "油女の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油女の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油女の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "谷のいよ／＼細くなつたあたりの岩の蔭にはあぶらめといふ魚が遊んでゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人には手にさはつても少しもあぶらめいたことがなく、かいつくろつた両腕のわき、乳や、胸のあたりにも、恐らく明石町の人は、汗をかいてゐない程だらう。",
              "citation": {
                "source": "鏑木さん雑感",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            }
          ]
        }
