        "examples": {
          "standard": [
            {
              "text": "私は毎日アナーキーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナーキーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナーキーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナーキーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナーキーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナーキーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナーキーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナーキーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナーキーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナーキーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナーキーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナーキーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナーキーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ねえ、アナーキーってどんな事なの？",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロオベルの隠遁的でゐて、それで一つ／＼その使ふ言葉にまで心を注いで行つたやうな、一面ニヒリストでありアナーキーストであつて、一面サンボリストであり、修道院の僧侶のやうな心持であつた心境になるのではないかと思ふ。",
              "citation": {
                "source": "社会劇と印象派",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからといって作家同盟の方向が根本的に誤っているとか、または林房雄の憫然たるアナーキー性の爆発的言辞を引用すれば「鎌倉に引込んだ僕の方がプロレタリア的仕事をするから見ていろ」などというに至っては、すでに論外である。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟橋聖一氏が昨今提唱する文学におけるリベラリズムの根源は、そういう反動的憎悪とかつて進歩の旗のにないてであったものへの報復的アナーキーの危険の上にたっているのを見て、私はつよくそのことを考えるのである。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちのアナーキーに対し、一方先生の神の如き正しさが立っている。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の秩序を知り得る場所で性格の破綻からそれをあえて破ろうとするアナーキー的本質のものではない。",
              "citation": {
                "source": "作品のテーマと人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の價値の轉換といふニーチェの思想そのものが實は近代社會の辿り着いた價値のアナーキーの表現であつた。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかやうな虚無主義、内面的なアナーキーこそ獨裁政治の地盤である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "雰囲気の異なった店が雑然と集まり、それぞれが独自のにおいを発しながら、アナーキーな活気を生み出している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の価値の転換というニーチェの思想そのものが実は近代社会の辿り着いた価値のアナーキーの表現であった。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかような虚無主義、内面的なアナーキーこそ独裁政治の地盤である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空壕の風通しのいいところへ太いだいこんを投げだしてアナーキーな恰好で眠っていると、「ご放送ですからお起きなさい」　とママが起しにきた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "百々子の感慨などに関係なく、千々子さまとミドリさまは、ダンスでもしているような恰好で、うまいこと掴みあったまま、枸杞の垣根のそばから物干場のほうへ移ってきて、残忍ではないが、なにかむごたらしい、終りのないようなアナーキーな喧嘩をしている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの推移の過程の内に、多くの道徳的混乱やアナーキーが、道徳的犠牲の様々が、織り出されるのである。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こうした批判主義による科学と哲学との超越的な区別が、如何に学問の統一をアナーキーに陥れたかを吾々はすでに見た。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の或る教授が歎いているような「思想のアナーキー」がないということであって、哲学はそうやってこそ本当に自由に統一ある発達を遂げることが出来る。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "纏りが悪るかった罪はブルジョア哲学のアナーキーに帰着するのであって、科学の非文学的性質にあったのではない。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなアナーキーな突発的な虫を体に入れておくことは何とも承知出来ない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏からみればロックはアナーキーであり、表からみれば、直接民主主義の原型のようでもある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ社会が持っている精神的な貧困さだけではなく、アメリカのすべてを否定するアナーキーな精神運動であり、強力なリーダーもきっかけもなしに、自然発生的に生まれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
