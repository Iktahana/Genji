        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安静について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安静という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安静の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安静が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安静を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安静について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安静の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安静の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安静が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安静という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安静という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安静についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安静を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安静は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安静について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安静が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安静は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安静の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安静は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安静は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その近頃に発表した論文によると、この薬剤に酸素を混じて試験用の動物に吸入させてみたが一時間ほどごく安静に魔睡し、睡りからさめる時も速やかに醒め切って、エーテルやクロロホルムのようにさめ際の悪いようなことがなかったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のノーベル・プライズのために不意打ちをくらった世間が例のように無遠慮に無作法にあのボーアの静かな別墅を襲撃して、カメラを向けたり、書斎の敷物をマグネシウムの灰で汚したり、美しい芝生を踏み暴したりして、たとえ一時なりともこの有為な頭の安静をかき乱すような事がありはしないかというような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和四年八月『東京朝日新聞』）　　　　　　二　地図をたどる　暑い汽車に乗って遠方へ出かけ、わざわざ不便で窮屈な間に合せの生活を求めに行くよりも、馴れた自分の家にゆっくり落着いて心とからだの安静を保つのが自分にはいちばん涼しい銷夏法である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対安静の病床で一カ月も米杉の板を張った天井ばかりを眺めて暮した後、やっと起きて坐れるようになって、窓から小高い山の新芽がのびた松や団栗や、段々畑の唐黍の青い葉を見るとそれが恐しく美しく見える。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかそれに気がついてみると、栄養や安静が彼に浸潤した、美食に対する嗜好や安逸や怯懦は、彼から生きていこうとする意志をだんだんに持ち去っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、頭を打ったと思ったらたとえ気分に変わりがないと思っても、絶対安静にして、そうして脈搏を数えなければならないそうである。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラパラ、頁をめくっていって、ふと、「汝もし己が心裡に安静を得る能わずば、他処に之を求むるは徒労のみ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私は静かに眼を開き安静な気持ちで受験番号や名前も書き入れ、問題の解答を書き進めて行きました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ清らかな透明な限りのない愉快と安静とが菜食にあるということを申しあげるのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は療養書の注意を守って、食後の安静に、畳の上に寝そべっていた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合、ぼくの身体の状態から考えれば、黙っていることこそ自然であったに違いなかったのだが、ぼくは自分が絶対安静を必要とする病人であることを忘れていたのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の貧乏、そして私の安静、私の孤独、そして私の自由、不幸なる幸福。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は入院当時、自尊心を傷つけるのがいやさに、わざと肋膜だといって脅かし、家の都合でここで安静にしているのだと話したのだったが、しばらく姿を現わさないところを見ると、それを真に受け、怖れて近づかないのかしらなぞと思っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂照は入道してから、ただもう道心を持し、道行を励み道義を詮するほかに余念も無く、清浄安静に生活した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さり乍ら、小生にはあらゆる讚辞と輝やかしい彩花とに生き甲斐のある一少詩人の万歳を祝つて載いた「思ひ出会」の当夜よりも、今は却て一層の安静な自己の霊魂の面に尊い而して親しみ易い哀楽の諸相を味ふ事が出来さうに思はれます。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎と坐骨神経痛と風眼とが同時に起った時、彼は、眼に繃帯を当て、絶対安静の仰臥のまま、囁き声で「ダイナマイト党員」を口述して妻に筆記させた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば、俺の魂の安静のための唯一の必要事は、『形而上学的迷蒙の形而上学的放棄』だということになる。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の平和と、彼自身の魂の安静との為に、哀れなギラ・コシサンは狭い路の真中を、右にも左にも目をやらずに、唯真下の白い眩しい砂だけを見詰めながら、おずおずと歩かねばならなかった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも非道い肺炎ですから、絶対に安静にして寝ておいでなさい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、もう、何も往くべき処へ往った、我が党の足痕へは、もう新しい世界の隻足が来ている、吾輩の魂も、これから永遠の安静に入るべき時が来たから、最後の言として、君にまで懺悔して置きたいことがあってやって来た」　三造は頭をさげた。",
              "citation": {
                "source": "雨夜草紙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が朝鮮へ行って農業をやりたいというのは、どういう意味かよくわからないが、僕はただしばらくでも精神の安静が得たく、帰農の念がときどき起こるのである。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし帰農したらば安静を得られようと思うのが、あるいは一時の懊悩から起こるでき心かもしれない。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがってなつかしく忘れられないこの小さな村の安静も、この県道のために破壊されてしまっていやしないか。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにようやく下宿にもなずみ、学校にもなれて、すべてのうえに安静を得て来た。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　午後四時の自然というのは、まあ、安静の時間だ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道場は、いま安静の時間である。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とＨ青年と三人の子供達と、そして彼の長男やＨ青年の親友であるＴ青年の姿が、或日またＭ君の安静な家庭を襲つた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして絶対安静なコンデションが必要なんです。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れ鼠の被害も私の安静の心を掻きみだす程ではなかった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
