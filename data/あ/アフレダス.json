    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to overflow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "溢れ出すについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この溢れ出すは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が溢れ出すについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は溢れ出すの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では溢れ出すが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から溢れ出すを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも溢れ出すが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では溢れ出すが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも溢れ出すは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも溢れ出すは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で溢れ出すは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に溢れ出すについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "溢れ出すの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する溢れ出すの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では溢れ出すの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だが何気ないその笑い顔の頬にしきりに涙が溢れ出す。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長者大悦して倉に納れると溢れ出す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、蒸気が浴室に溢れ出すと、一面長方形の真白な靄の中に、主人も客も茫々として見えなくなった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは再びその中から溢れ出すと、手に手に、その鉄の棍棒を振り上げて新しく襲って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫んで工場から溢れ出す。",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、二人以上の重量が法度で、それが加わると、松毬の頂飾が開いて、この粉末が溢れ出すのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、なんだか寒いほど引き緊つた気持の中で、一斉に開かうとする花束のやうな、夥しい微笑がふくらみ、やがて静かな泪となつて溢れ出すのを感じた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "葭本幾野という歌手の声は、まるで場内から溢れ出すように透った良い喉なので聴衆は皆感嘆する。",
              "citation": {
                "source": "美音会",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの手を切られると、水は忽ち日下部や塩山一帯に溢れ出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風呂屋の湯尻は、直径一尺の土管を通して、道路に沿った掘割に注いでいるのであるが途中になに物か滞って不通となって湯水が溢れ出すというのである。",
              "citation": {
                "source": "泡盛物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豊饒な、杯から溢れ出すほどの過剰な美は、殊にその紅色の花にあつて彼の心をひきつけた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、重吉が、買いものなんかして置くがいいよ、と、おだやかに、ひろ子を惑乱させないようにと心をくばりながらつたえたとき、重吉の体は、あんなに大きくなって面会窓から溢れ出すように見えた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、思わずゆき子が、溢れ出す愛を感じたほど、暖い心と眼で、迎えてくれたのである。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを自分の胸に感じ、魂に知り、ちょうど疲れたとき、一瞬の虚無に脳を休めるため知らず識らず深い欠伸をするように、必要であり、適当である場合には、知らず識らず、自分の中から溢れ出すものとなりさえすればよいのである。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、なんだか寒い程引き緊った気持の中で、一斉に開こうとする花束のような、夥しい微笑がふくらみ、軈て静かな泪となって溢れ出すのを感じた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとまさしく神尾の怖るべき酒乱が兆して来たもので、その兇暴な力が溢れ出すと、お吉も禁制を破らせては済まないという奉公心も手伝って、なお一生懸命に支えると、提灯はハネ飛ばされて闇となり、闇のうちに組んずほぐれつの体。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、右の手には早くも脇差を抜いて、仰向けに倒れながら、それを構えたが、みるみる、面の全部が溢れ出す血潮で塗りつぶされ、余れるものは指の間から筋を引いて下へ落ちます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物が潮のように溢れ出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に彼女の瞼から泉のように涙が溢れ出すのが見えた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉を開くと、一度にドッと溢れ出す濁水、先に立った警官達は、はずみを食って、階段の根本まで押し流される騒ぎであったが、兎も角も、親子三人のものを、助け出すことに成功した。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には雪のあいだからほとばしり出て、前には砂がちっとも見あたらなかったところにあふれだす。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は無色になって、夜が明けかけてきたが、人気のない広い構内はまだ真暗で、海風で湿った岸壁が舷窓からあふれだすあかりを受けてところどころで光っていた。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水の大山が、甲板にくずれ落ち、うちあたる大力にまかせて、手あたりしだいに、なにかをうちこわして、滝のように甲板からあふれだす。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありあまる体力の自然にあふれだす瞬間の発作である。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏どおりにある相撲部屋の賑わいはもとよりであるが、柳橋から浜町にかけての夜をいろどる大川端の風景は水にうつる灯のかげもなまめかしく、打どめの櫓太鼓が鳴りわたると国技館の門からあふれだす人の波が幾つかの層をつくって両国橋の雑踏はさんざめく三絃の音の湧くがごとき巷の露地に吸い寄せられてゆく。",
              "citation": {
                "source": "土俵の夢",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
