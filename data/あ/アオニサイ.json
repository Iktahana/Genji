        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『いやにじれつたいな、何うにも、恁うにも、恐かないなら、手を地べたに着いて謝罪んねえ、そこへ坐つて、チエツ、意氣地のない青二才だ』「カツ」と痰を吐いたのが、胸の處へベツタリ絡みつく。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は青二才だが、チャンコロのように雄弁だね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな奴にちやほやする青二才があるから、のさばりやがるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「この青二才がお前を返して呉れとよ」　お類がフンと冷笑する。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもお前が病院へ行った時には、あの本間の青二才が、まだ呼吸があったというではないか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私はまだヤット二十歳になったばかしの青二才である。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わめき乍らジャネットが新吉の方へ救いを求めるように手を出したので、その方向を辿って男は新吉を見つけると、――青二才だな。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から見れば青二才だ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　青二才の無礼を憤る心は充分あつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙汰過ぎた青二才、）と可恐い顔になった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てめえみてえな、青二才にタカっても、張合いねえが、何かあったら出しな」と言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳臭い青二才にも、旦那と云ってお辞儀をする。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………　青二才の分際で師の批評などおこがましいと腹が立ち、また、これを言わせているのは畢竟顔淵への嫉妬だとは知りながら、それでも子路はこの言葉の中に莫迦にしきれないものを感じた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関所の役人は幕府方と心得るが、貴公方はいつ、徳川の手先になった」　二人はちょっと云い籠められた形になったが、間もなく平馬が、まだ青二才である事に気が付いたらしい。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を青二才とあなどって、いい加減に誤魔化すのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「忠告とはおぞましいぞ、青二才奴、怒田へ行け！",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "地位も、金も、系累も、家も、それこそ何にもない、便所掃除の労働者の青二才じゃないか、だのに船長は椅子から立ち上がれなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「厭味な青二才の酔ツ払ひ！",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青二才の酔ツ払ひなんぞは……」と、それでもいくらか息を切らせた清親が、静かに盃を取りあげて、笑つた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今度「青二才奴！",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前の様な青二才に籤が当ってみろ、反って、親分の足手｜纒いじゃねえか。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな青二才のいうことを聞いちゃ、だめじゃねえか。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし籤が十蔵のような青二才に当ってみろ、親分のお伴どころか、親分の足手まといじゃねえか。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこのごろ自分の庭のあき地を徘徊して、朝に夕にめっきりと伸びてゆく唐もろこしの青い姿を見るたびに、三浦老人その人のすがたや、その当時はまだ青二才であった自分の若い姿などが見かえられて、今後更に二十余年を経過したらば、こゝらのありさまも又どんなに変化するかなどと云うことも考えさせられる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人者の、やわら取りのというからは、どんな逞ましい強そうな男かと思えば、それはまだ廿二三歳の町人風で、色の小白い痩せぎすの、小二才とか青二才とかいいそうな、薄っぺらな男であったので、市兵衛も案に相違して、しばらく呆れてその顔をながめていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「撲るとは、面白いだ、この藤田重右衛門を撲れるなら、撲つて見ろ、奴等のやうな青二才とは」　と果して腕を捲つて、体をくるりと其方へ回した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな駈け出しの青二才の手柄にされちゃあ、おれは死んでも浮かばれねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに、金蔵が例の三甚の事を云い出して、あんな青二才に縄をかけられたのが残念でならない、行きがけの駄賃にあの野郎を眠らせてやろうと思っていたのに、こうなっちゃあ思いが達かねえと愚痴をこぼした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ青二才の癖にして酒など飲みやアがつて……」「何でもいゝから、百遍云つて見ろ！",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
