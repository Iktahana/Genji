        "examples": {
          "standard": [
            {
              "text": "曙貴の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夜があけたから、あの子どもを起さなけあいけない。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可いか、活返ったら夢と思って、目が覚めたら、」といいかけて、品のある涼しい目をまた凝視め、「これさ、もう夜があけたから夢ではない。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一※ほども過ぎた後に、誰があけたか知らないが、入口の扉が自然にあきました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、そーら中をご覧よ」　そしてサックの蓋をあけたかと思うと、ぱっと閉めましたが、中には紅色の宝石がまがいもなくきらきらと輝いておりました。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸と起きて来て、戸をあけたかと思ふと、恐ろしい権幕で脅かすんです。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここにあったのよ、確なの其は」「――台処の木戸あけたかい？",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟲類のきらひだつたあたしといふ子供は聲をあげて、呪魔の凾をあけたかのやうに騷いだ。",
              "citation": {
                "source": "桑摘み",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待っててね」　文子は足をけあげて走りだし、勝手口の戸をあけたかと思うと大きな声で叫んだ。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その背中がムクムクと動き、パックリ口をあけたかと思うと、ヒラヒラヒラヒラと気を吐いた。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる秘計をうちあけたか、わからない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルトルは感謝感激、夢｜心持、ここで二人の心は寄りそったが、ちょうど夜が白々とあけたから、ツル子は別荘番のオバサンの部屋へ寝床をしいてもらって、ねむる。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の顔は駕籠の中で月光に隠されているがために、一様にほの白く見えるばかりであったが、その顔の一所に黒い※ができて――女が唇をあけたからであろう――こう小次郎へいった時に小次郎の心を恍惚とさせてほとんど絶息させるまでの馨しい匂いが、言葉と一緒に匂って来た。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで　うろたえて　さとうを　おっことし、　ティーテーブルの　下へ　さぐりいるはめに　なったので、　リービが　パイを　とりだすさい　どちらの　オーヴンを　あけたか、　見のがしてしまう　ダッチェス。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉をどうしてあけたか全く夢中で覚えませぬ。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げながらサラリ、二階縁の障子をあけたから、ぱっと流れる灯のなかに、座敷着も崩れてホンノリ上気したお艶のすがたが……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜宿をあけたかあけないか、人をやつて訊けばすぐわかることです」　平次も見るに見兼ねて、二人の老人の仲に割つて入りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき獲物",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい手で錠をこじあけたから私は惹きつけられたのだ。",
              "citation": {
                "source": "性に眼覚める頃",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の出た小指を吸いながら、あわてて座敷へ駈けこんだお吉は、針箱の抽斗をかき廻して、小布を探しているふうだったが、その物音を聞きとめたものらしく、誰か、中二階の腰窓をあけたかと思うと、梯子の上から、「おばさん」　と呼ぶ声がした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠木さまへ」「こう、打ちあけたからには、鳶七、口外するとゆるさんぞ」「なんで。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
