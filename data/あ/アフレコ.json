        "examples": {
          "standard": [
            {
              "text": "アフレコについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフレコは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフレコの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフレコについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフレコは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフレコの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフレコに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフレコが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフレコを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフレコの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフレコが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフレコが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフレコについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフレコは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフレコは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフレコは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフレコについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフレコの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフレコの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフレコの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "気にいらぬ楽隊ならさつそく帰つてもらつて他の楽隊と取りかえればいいのであるが、日本ではなかなかそういうわけには行かないから、せめて音楽のアフレコのときには耳に脱脂綿でも詰めていねむりをしているのが、最も良心的とでもいうのであろう。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして一介の監督風情が、頭から湯気を立ててアフレコ・ルームを走りまわつてみたところで何の足しにもなりはしない。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意して見ると、楽隊のメンバーにはアフレコ・ダビングでかねてなじみの顔ばかりである。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生駒が、先日来、金のことでダレちまって、ＪＯのアフレコの仕事を、十月にはしたいと言ってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口が蒲田のアフレコをたのみたい旨言って来た由、暮のこと故いゝだらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲田スナップ「春は朗らか」の、セレモニー役で、もう出来てるスナップにアフレコで、説明を入れる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間で終り、あとは十八日か二十日の夜、アフレコをやる由。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春は朗らか」一巻、之にアフレコで説明を入れる、いゝ仕事じゃないが、言葉のギャグを考へ／＼、三時近くまでやって、漸くチョン、労れて帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年三月三月一日（日曜）　今日は砧へ行くとすぐアフレコを始める。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これであとアフレコのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はアフレコである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜又ＰＣＬでアフレコかと思ふと起きた途端からつまらなくなっちまふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時半、アフレコを残して僕のとこ全部アガリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月四日（火曜）　今日はＰＣＬのアフレコ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフレコは、一時間余りで終った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日にアフレコで終る予定らしいが、そんなら二週間ばかりでアガるわけである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで明夜のアフレコでチョンである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時にＰＣＬへ行ったが中々始まらない、九時すぎからアフレコ、昨日撮った、運動会のラッシュ見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のグリルで大沢善夫と食事して、撮影所へ引返すと、完全な曇天で、オープンは無し、くさりダレの骨頂状態のまゝねて待ち、アフレコ――十時迄。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後はアフレコ、スクリーン見つめ乍ら色んな声を出す、これも終り、セットの模様代へで待ち。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアアといふ唖の発する声は、高島忠夫が、アフレコで代役して呉れた由。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、アフレコを残して此の映画全部了った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけで了るのだが、アフレコになったので二日かゝるわけ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
