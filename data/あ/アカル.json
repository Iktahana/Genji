[
  {
    "uuid": "51e691f1-ecd6-56a0-932f-ff4abd2828aa",
    "entry": "明る",
    "reading": {
      "primary": "あかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
