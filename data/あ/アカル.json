    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become bright",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "牧野さんの作品には明るい風景が出て来るし、陽に透いた桜の葉のやうな色や又赤い色があるが、その赤はうでた小海老の赤である。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長の年月、海を見るたびに、おぼろに感じてゐたことが、急に明るみに出た感じ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびにレールの軋音は肉声に消され、電燈はひときは明るくなるやうに思はれる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論暗くなつたればとて、他人様にまで八ッ当りを始められる程の自分なら何を書かう程のことでもないけれど、暗くなると却て明るい真似をしてみたり急に他人本位になつたりしなければならない上に、それでゐて結局人からもさういふ時はやつぱり此奴暗いと見て取られてしまふからには、なんとも馬鹿化た話なんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかそれをいつかどな理由をつけて、その理由への対策を講じてみたつて、暗い女が明るくならうとしてアバズレになるみたいなもんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方また私の求めてゐた者は、卒直なる情熱的の人格と、男らしき単純さと、明るく健康なたましひをもつた人格であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには近代文明の不幸な疾病が憧憬する所の、あの美しく明るい健康の哲学がある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く、その中に彼の顏には、平常の明るい活氣が現はれてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れに反して藤村の詩は、僕にとつてあまりにナイーヴで明るすぎ、陰影のない不滿さを感じさせた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽業の方は明るい上に楽隊は盛んに鳴らしてゐる、所で神明館の方は仄暗く、例の昔の映写機が、憂鬱な音を立てゝ廻つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外を見ると明るい日光が急に懐しくなつて来たので裏に出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人心が少しでも明るくなり、景気が活気づいて来た時には、音楽の調子がすぐ明朗になつてくるし、その反対の場合には、音楽がまたすぐ憂鬱になつてくる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨や同車の君がさざめ言白梅や誰が昔より垣の外妹が垣根｜三味線草の花｜咲ぬ恋さまざま願の糸も白きより二人してむすべば濁る清水かな　蕪村の句の特異性は、色彩の調子が明るく、絵具が生々しており、光が強烈であることである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの点が、彼の句を枯淡な墨絵から遠くし、色彩の明るく印象的な西洋画に近くしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、これらの句には、洋画風の明るい光と印象があり、したがってまた明治以後の詩壇における、欧風の若い詩とも情趣に共通するものがあるからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く春や白き花見ゆ垣の隙　この句もまた、蕪村らしく明るい青春性に富んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来日本文化は、上古の奈良朝時代までは、海外雄飛の建国時代であったため、人心が自由で明るく、浪漫的の青春性に富んでいたのであるが、その後次第に鎖国的となり、人民の自由が束縛されたため、文学の情操も隠遁的、老境的となり、上古万葉の歌に見るような青春性をなくしてしまった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や月は東に日は西に　これも明るい近代的の俳句であり、万葉集あたりの歌を聯想される。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は関西の人であり、元来が南国人であるけれども、好んでまた南国の明るい風物を歌ったのは、彼自身が気質的にも南国人であったことを実証している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若葉の青色と、城の白堊とが色彩の明るい配合をしているところに、この句の絵画的のイメージがあり、併せてまた主観のヴィジョンがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば前に評釈した句、白梅や誰が昔より垣の外白梅に明る夜ばかりとなりにけり　などの句も、白という色の特殊なイメージが主題になって、これが梅の花に聯結されているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの湿気が全くなく、常に明るく乾燥した空気の中で、石と金属とで出来た家に住んでる西洋人らに、日本の俳句が理解されないのは当然であり、気象学的にも決定された宿命である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るき四月の外光の中嬉嬉たる群集の中に混りてふたり模擬飛行機の座席に乘れど君の圓舞曲は遠くして側へに思惟するものは寂しきなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり車窓に目醒むれば汽笛は闇に吠え叫び火焔は平野を明るくせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕の孤独癖は、最近になってよほど明るく変化して来た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の新しい僕は、むしろ親しい友人との集会なども、進んで求めるようにさえ明るくなってる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鮮緑といふやうな明るい感じがすきだから、百姓風のぢみくさい気分は陰気でいやだ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
