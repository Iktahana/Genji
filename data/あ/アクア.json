          ],
          "literary": [
            {
              "text": "こゝよりウベルティーノ・ダ・カサーレ（一三三八年死）出づ、過激派（所謂精神派 Spirituali）の首領にて宗規を極度に嚴守せり〔アクアスパルタ〕ウムブリアの町。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の露をふいて外をのぞくと、狭い谷の空にアクアマリンの夕星を見る。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその上にアクア・フォルティス（硝酸）を注いだところ、殆ど全部が発泡して溶解した。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも柔かく積み重った新しい雪の中へストックを差し込んで穴を作ると、その内部がアクアマリンのような色を呈すること位は誰にも見られる現象である。",
              "citation": {
                "source": "雪の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクアマリンという水色の宝石があるが、あれを夕闇の窓で見たような色である。",
              "citation": {
                "source": "画業二十年",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の旧い時代の墨にはいわゆる青墨が多くて、淡くすると、鼠色の蔭にアクアマリンのように透明な青味が見え、非常に美しい色をしている。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水藻は思ったほどではありません……湖岸と湖棚を終りましたから、午後から標識を入れて最深部をやります」「ご苦労さん……夕方までに揚らなかったら、明日からアクア・ラングでやる。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アクア・ラングなんかじゃ、仕様がない。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがアクア・ラングというものなの？",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクア・ラングをつけた隆だった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちフアブリシイァス・アブ・アクアベンデンテといふ猶太の人だ。",
              "citation": {
                "source": "光る生物",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彼の名前には生まれた場所のアクアペンデンテが名前につけることがある）彼はヴェサリウスの後継者として適していた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、一人前にアクア・ラングの道具かなんかを得意げに肩にかついでてね。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十めんそうは、ふねに、アクアラングをよういしておいて、それをつけて、とびこんだのかもしれませんね」「うん、きっとそうだ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクアラングなら、いつまでもうみの中にかくれていられるからね。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずのくんのにいさんが、とくべつじかけのアクアラングを二くみもっているので、それをかりてくるようにたのみました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こばやしくんとみずのくんが、アクアラングをつけて、うみの中にとびこみました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、アクアラングにしかけたでんわのせんが、手のひらでつうじあって、はなしができます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
