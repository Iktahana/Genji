    "definitions": [
      {
        "index": 1,
        "gloss": "vein (visible under the skin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何にせよ恵比寿講の帳合いと言うたなら、一文二文の間違いにも青筋を立てて算盤を弾き合うような吝垂れた金持連中の寄合の事で御座いますけに仮令、仕事が夜通しがかりになったにしても、出て来るものは漬物にお茶か、せいぜい握飯ぐらいで、それでもペコペコと頭を下げてお礼を言うて帰るのが普通で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側に戻った松倉十内は青筋を立てて良助を睨み付けた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……か……勝手にせい」　と言い棄てると額に青筋を立てたまま座敷に入って障子をハタを閉めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚咽びかえっているのです、それを見た武の顔はほんとうに例えようがありません、額に青筋を立てて歯を喰いしばるかと思うと、泣き出しそうな顔をして眼をまじまじさせます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫の云い草が機嫌に触ったらしく、真赤になって青筋を立てた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青筋を立てて怒鳴った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青筋たてて空論をたたかわしても、お互い自説を更に深く固執するような結果になるだけのものさ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界大戦は済んだとは云え、何処か知らで大なり小なりの力瘤を出したり青筋を立てたり、鉄砲を向けたり堡塁を造ったり、造艦所をがたつかせたりしている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬、馬、馬鹿つ……」先生は顏に蚯蚓のやうな青筋を立てて、上村の席に近寄つた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイリスは顳※や上眼瞼に青筋のある神経質の小さな顔を怪訝に曇らせる。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先生に診て貰っておれば、きっと治して下さるんだよ」　お座なりの見当違いの説明に、必死の望みを外された政枝は、見る見る顳※に青筋を立てて父親を瞠んだ。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要旨をもう一度明瞭に言っていただきたい」と顔に青筋を立てて言った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんは布団の中から、痩せた青筋の節くれだった大きな手を出したが、手はなかなか伸びそうもない。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは額に青筋を立てて興奮していた。",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と青筋を立てゝ憤られた者、その他学究上の問題で先生の厳しい神経に触れて震え上つた者は多かつた。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を走る電光は、人間の額を走る青筋のやうだ。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤君などは、青筋を立てるほどのことではないだらう。",
              "citation": {
                "source": "よしなし事",
                "author": "〔源内の手紙、原稿料のことなど〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "むき出しにした腕には青筋が病的に思われるほど高く飛び出てはいずっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青筋出して肝癪起した二葉亭の面貌が文面及び筆勢にありあり彷彿して、当時の二葉亭のイライラした極度の興奮が想像された。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利は野暮堅き真面目一方の国なれば、人間の元来醜悪なるにお気が附かれずして、ゾオラが偶々醜悪のまゝを写せば青筋出して不道徳文書なりと罵り叫く事さりとは野暮の行き過ぎ余りに業々しき振舞なり。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤットウのおけいこでござりますかな」　笑止なその光景をみて、やんわりと皮肉に揶揄しながら、ぬっと雪ずきんのままで名人が静かにはいっていったものでしたから、恥ずかしかったのと腹だたしさがごっちゃになったとみえて、敬四郎がどもりどもり青筋を立てながら、当然のごとくに口ぎたなく食ってかかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの曲がった根性叩きなおしてやる」　青筋をたてた藤井が、いきなり片桐の衿をつかんで立たせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その額に浮んだ青筋が鏡に映る。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青筋だよ――と見えないところで夫の冷かす声がする。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髮店に歸ると、源助は黒い額に青筋立てて、長火鉢の彼方に怒鳴つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店に帰ると、源助は黒い額に青筋立てて、長火鉢の彼方に怒鳴つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親はそのたんびにいらいらするような顔に青筋を立てた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　弁護士は、太い青筋の立った手で、猪口をお増に差しつけた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも大日本帝国に生まれたからといって朝から晩まで青筋を立てシカメッツラをして、なんら生産にもならないやかましい議論をして暮らさなけりゃならないという義務もあるまい。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長は顔に青筋を立てた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
