[
  {
    "uuid": "b3be70a1-aecf-556c-aff9-e08361522f55",
    "entry": "改めて",
    "reading": {
      "primary": "あらためて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "another time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日改めてについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改めてという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改めての意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改めてが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改めてを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改めてについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改めての使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改めての定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改めてが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改めてという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改めてという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改めてについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改めてを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改めては複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改めてについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改めてが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改めては重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改めての意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改めては様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改めては興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今や蕪村の俳句は、改めてまた鑑賞され、新しくまた再批判されねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、多少口調を改めて、そんなことを家内に教へた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお鈴さんは口調を改めて言ひ、「せめて、雀の里のお土産のおしるしに、この葛籠のうちどれでもお氣に召したものをお邪魔でございませうが、お持ち歸り下さいまし。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを出立点として、改めて稿を次ぐ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中高山植物の美麗は熱帯の壮大華麗なる花を凌ぐのであるが、高山植物の美観は他日題を改めて説くつもりである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて）　吉田は、そう考えることによって、何かのいい方法を――今までにもう幾度か最後の手段に出た方がいい、と考えたにも拘らず、改めて又、――いい方法を、と、それが汗の中にでもあるように汗みどろになって、全速力で考え初めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も何かしら書きたいことがあって筆を取ったはずであったが、思うことがなかなか思うように書けないので、途中で打切ってさて何遍となく行を改めて更に書出してみても、やはりうまく書けない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして今此遺著を読んで見ると、改めて石川君に逢着したやうな気がする。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と僕が改めて質問したのは、彼が金澤の舊家である古寺から、煤で黒くなつたまひら戸を引きずり出し、玄關や茶座敷の戸にしたのを見た時であつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この發見をしてから後、改めて僕は芥川龍之介の全貌を追懷した。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君の弟子になり、改めて始めから詩を學ばうと決心した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで改めて恩地孝氏にたのんで著者のために田中氏の遺志を次いでもらふことにしたのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳兵衛が、Ｔ「では改めて」　と言って、Ｔ「その刀わしが買います」　二人顔見合わせた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今改めて御禮申します。",
              "citation": {
                "source": "編輯後記（大正十五年三月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして語氣を改めて、「一體實社會を離れて、信仰生活だけに沒頭することが人としての道に適ふのでせうか。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その精神とはどんなものか、それについては章を改めて述べてみたいと思う。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中のおもな事を改めてここに清書しておきたいと思う。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（本居宣長『玉かつま』）　この初めの「古を考うる事」というのを「物理学上のいかなる問題にても」と改めて、もう一ぺんはじめから読み返してみるとおもしろい。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めておふくろ殿にお掛け合いをいたすために、こんにち罷り越した次第であると、式部は形を正しゅうしておごそかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いボンヤリした月のかげに、始め、二三十頭に見えた犬が、改めて、周囲を見直すと、それどころか、五六十頭にもなっていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方ない夜明け迄に一ぺん宿へ引っ返し日が出てから改めて出掛けよう。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと心を改めてこのおわびは致します。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ改めて空からお礼を申しあげます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可、改めて謂え、名を聞こう。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は小嚢から沈子を出して与え、かつそのシカケを改めて遣ろうとした。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ルクレチウスは言葉を改めていう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで自分の書いたものを、改めて自分が読者の立場になって批判し、読者の起こしうべきあらゆる疑問を予想してこれに答えなければならないのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿はもと料理屋であったのを、改めて宿屋にしたそうで、二階の大広間と云うのは土地不相応に大きいものである。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでカン蛙ははじめてルラ蛙といっしょになりほかの蛙も大へんそれからは心を改めてみんなよく働くやうになりました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
