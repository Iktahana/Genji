    },
    "definitions": [
      {
        "index": 1,
        "gloss": "draft",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案文について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案文という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案文の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案文が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案文を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案文について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案文の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案文の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案文が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案文という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案文という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案文についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案文を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案文は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案文について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案文が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案文は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案文の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案文は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案文は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "四　狂歌師岡鹿楼笑名　前記の報条は多分喜兵衛自作の案文であろう。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永元年から天明五年に至る最古の一冊は題号がなく、引用書として『津軽一統志』、『津軽軍記』、『津陽開記』、『御系図三通』、『歴年｜亀鑑』、『孝公行実』、『常福寺｜由緒書』、『津梁院過去帳抄』、『伝聞雑録』、『東藩名数』、『高岡霊験記』、『諸書｜案文』、『藩翰譜』が挙げてある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は凡ての法令の案文は自分で書く風なのであったが、それを修正して発表するには辻次官からの命でいつも私が筆を執った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とあつて、其後に、案文が載つてゐる。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "門下省は封駁の權を有して、若し中書省の案文が不當と認むるときには、これを駁撃し、これを封還することも出來る。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十日の夜、峠の牛方仲間のものが伏見屋へ見えての話に、右の書付を一同に読み聞かせたところ、少々｜腑に落ちないところもあるから、いずれ仲間どもで別の案文を認めた上のことにしたい、それまで右の証文は二人の牛行司の手に預かって置くというようなことで、またまた交渉は行き悩んだらしい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五日には、毛利右馬頭輝元から、秀次公、去春白井備後守を差下、如此之案紙を以、誓紙を沙汰し、入魂いたすべき旨仰せけるに因って、書き上げたる旨を、石田治部少輔を経て言上に及び、併せてその案文なるものを證拠として差し出した。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答案文を一册にコツピーされたものも併せて送つて下さつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土器を取って、羊の生血をそそいだ神酒をすすりあい、やがて呉学人が案文した起誓文を受けて、晁蓋が壇にむかって読みあげた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡京の印でしたら、朱文白文、いろいろと以前に彫ったこともあり、印譜ものみこんでおりますから」　ここでさっそく、蕭譲は密室にこもって、呉用智多星と戴宗が作っておいた偽手紙の案文をもとに、得意の偽筆をふるい、それに金大堅の彫った印を捺して、もう何人の眼にも、それとしか見えない蔡大臣の返信を作り上げた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これに教書の案文をしたためておいた。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
