        "examples": {
          "standard": [
            {
              "text": "私は毎日尼寺について考えている。",
              "source": "幻辞"
            },
            {
              "text": "尼寺という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は尼寺の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には尼寺が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "尼寺を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは尼寺について学習した。",
              "source": "幻辞"
            },
            {
              "text": "尼寺の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は尼寺の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では尼寺が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "尼寺という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に尼寺という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では尼寺についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "尼寺を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると尼寺は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "尼寺について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では尼寺が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に尼寺は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により尼寺の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "尼寺は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に尼寺は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "または私が時々に行く海岸の尼寺をも案内した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女教師は、自分が尼寺に這入らうと思つた事があると云ふ話を、もう十一度繰り返してゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、此の間スタニスラフの尼寺から二人尼っちょが来たんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚ほ其の人が、嘗て修學旅行をした時、奈良の然る尼寺の尼さんに三體授けられたと云ふ。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に奇妙な事だと思つて居ると、或日の事、ウルピノ山中とて、子ープルスの街からは餘程離れた寒村の、浮世の外の尼寺から、一通の書状が屆きました、疑もなき亞尼の手跡で、はじめて仔細が分りましたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、亞尼は、いよ／＼弦月丸が沈沒したと聞いた時、身も世にあられず、私共に濟まぬといふ一念と、其息子の悔悟とを祈るが爲に、浮世の外の尼寺に身を隱したのです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には葉桜を背景にして、大和国分尼寺の遠州系の庭を縮模した、女性的で温雅な池泉が望まれる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの学校の門や鉄柵も、もうとっくに献納したのだから、尼寺のごんごろ鐘だって、お国のために献納したっていいのだと思っていた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、尼寺の庭の鐘楼の下は、村のこどものたまりばだからだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼寺へ来て見て、僕はびっくりした。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主さんと、よく尼寺の世話をするお竹婆さんとが、縄をまるめてごしごしと洗った。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜月二十三｜日　ひるまえ、南道班子供常会をするために尼寺へいった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除が終わって、いよいよ第二十｜回常会を開こうとしていると、きこりのような男の人が、顔の長い、耳の大きい爺さんを乳母車にのせて、尼寺の境内にはいって来た。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それから、また川をどんどんくだっていくと小さい尼寺がありました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男なら、骨でなり、勘でなり、そこは跋も合わせようが、何の事は無い、松葉ヶ｜谷の尼寺へ、振袖の若衆が二人、という、てんで見当の着かないお客に、不意に二階から下りて坐られたんだから、ヤ、妙な顔で、きょとんとして。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間経ったある日、八十二歳の高齢で死んだという讃岐国某尼寺の尼僧のミイラが千日前楽天地の地下室で見世物に出されているのを、豹一は見に行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名音が泉の尼寺へ入って二度目の秋を迎えた時のことであった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この 〔Ho^tel〕 Biron というのは、もと或る富豪の作った、贅沢な建物であるが、ついこの間まで聖心派の尼寺になっていた。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽天地の地下室で、八十二歳の高齢で死んだという讃岐国某尼寺のミイラが陳列されていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伊太利の俗、尼寺に入れんと定めたる女兒をば、夙くより小尼公など呼ぶことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢ある家の事とて、羅馬に名高き尼寺の首座をば、今よりこの姫君の爲めに設けおけりとぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "小尼公は教育の爲めにとて、四井街の尼寺にあづけられ給ひしより、早や六とせとなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より先きわれは四井街の邊を過ぐるごとに、この尼寺の築泥の蔭にこそ、わが嘗て抱き慰めし姫君は居給ふなれ、今はいかなる姿にかなり給ひしと、心の内におもひ續けざることなかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日われは尼寺に往きて、格子の奧にて尼達の讚美歌を歌ふを聽きしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かなる尼寺の垣の内にありて、優しき尼達に交らんことの願はしさよ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど尼寺の心安きには似ず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は尼寺に居給ふとき、「プサルモス」の歌を聽き、又古の聖の上を綴りたる韻語を學び給ひしならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思想といふものも、いかなるが詩となすに宜しかるべきか知るよしなけれど、わが尼寺にありし時、ふと物の懷かしき如き情、遠きに騁する如き情の胸に溢るゝことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば唯だ尼寺に返らんことこそ願はしけれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼寺の人々に知られなば、何とかいはれん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
