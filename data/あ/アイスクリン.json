        "examples": {
          "standard": [
            {
              "text": "毎日、アイスクリンは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスクリンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスクリンに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスクリンが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスクリンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスクリンについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスクリンについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスクリンが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスクリンが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスクリンは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスクリンは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスクリンを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスクリンをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスクリンが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスクリンの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスクリンを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスクリンに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスクリンについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスクリンは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスクリンを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一と六の日は駒ヶ池の夜店があり、丸亀の前にも艶歌師が立ったり、アイスクリン屋が店を張ったりした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、筍をさかさにした形のアイスクリンの器をせんべいとは知らず、中身を嘗めているうちに器が破けてはっとし、弁償しなければならぬと蒼くなって嗤われるなど、いくら眼をキョロキョロさせていても、やはり以後かたくいましめるべき事が随分多かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、筍をさかさにした形のアイスクリンの器をせんべいとは知らず、中身を嘗めているうちに器が破けてハッとし、弁償しなければならぬと蒼くなって嗤われるなど、いくら眼をキョロ／＼させていても、やはり以後かたくいましめるべき事が随分多かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角の山盛りで、黄色に塗った五銭のアイスクリン。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エエひやっこいアイスクリン！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、活動写真館の中売りが「ええアイス、アイスクリン」と呼びながら売っていた、薄味のアイスクリームも、少年の日の思い出だ。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、アイスクリームじゃない、売り声の通り、アイスクリンなのである。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の中売りが売って歩いたのは、正にその黄色で、牛乳も何も入っていない、名前も、アイスクリンだった。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
