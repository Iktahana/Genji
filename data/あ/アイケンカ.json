        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛犬家は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛犬家が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛犬家に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛犬家が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛犬家について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛犬家についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛犬家について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛犬家が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛犬家が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛犬家は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛犬家は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛犬家を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛犬家をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛犬家が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛犬家の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛犬家を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛犬家に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛犬家について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛犬家は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛犬家を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "歴史で一番｜評判の愛犬家は北条高時どのだ子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから高時殿と一対の愛犬家は五代将軍綱吉公だナ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野性の叫び」は一匹の犬を主人公とした小説で、初めは富豪に愛育されていたが、人に盗まれ、売られ、虐使され或は北アラスカの荒涼たる氷原に橇を引き、或は愛犬家に撫育されて人の感情に鍛えられ、文化や野蛮の間に彷徨しながら、遂に天性の野獣性が眼覚め、狼群の長となる、ユニークな物語である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び何か　愛嬌ある退職士官の内気な望み――愛犬家へ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬家も純粋種の規格などにとらわれずに自分で改良を志し、自分の好みの雑種を考案されたら、むしろ楽しみじゃないかと私は思っている。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬家は吠え声で分るものだが、たいがい「遊びましょう」と云ってよその犬に吠えかけているのだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田犬、秋田犬、と大そうな熱であり騒ぎであるが、本当の秋田犬とはこれです、という解答は東京の愛犬家を歴訪して廻ってもなかなか得られない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシントンの出羽号の子供ぐらいが東京で素性の正しい秋田じゃないか、というのが私の東京の愛犬家から探りだした結論であった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や大館の愛犬家にとって、ウチの愛犬がケンカをやらかしては、これ天下の一大事なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田犬に対して純粋で損得ぬきの打ちこみ方や、しかし静かでよく行きとどいた愛情など、まことに愛犬家の最高のタイプと云うことができよう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大館市の愛犬家に直接たのんでも、ホンモノの仔犬はなかなかオイソレと注文に間に合わないのが、普通かも知れない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の愛犬家の手にはいらずに、ブローカーに買いしめられる恐れがありますよ」　と私が云ったが、ヘルプ紳士もその二世も、大館の仔犬の相場をそれ以上つりあげるのに賛成ではないようだった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は秋田犬に仕え、秋田犬の声価のために一生を棒にふることをも喜びとするような、本当に善良で純粋の愛犬家であります。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぐらい信用のできる愛犬家、保存会長がザラにあるものではないのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "良き犬を飼うには、愛犬家の資格というものが確かに必要なものだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、同地方の愛犬家との座談会のとき、この藤岡から西南八十キロの群馬、長野の県境十石峠の下にあたる、神流川上流の上野村字中沢集落には、喜六という老猟師がいて、猪鹿狩りの名犬を飼っており、付近の集落にも猟師が多い話をすると、日本犬愛好者の医師・原徳人さんが、私と探査に同行しようと申し出ました。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は芦安より、もっと山奥の南巨摩郡西山村奈良田部落（現早川町）を調査しようと考え、昭和七年五月甲府の愛犬家小林氏らとともに、奈良田部落に行って、猟師の犬を集めて調査しました。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "“百”は後に、甲府の甲斐犬保存会に種犬に懇望されて寄贈し、同地で亡くなりましたが、私が甲斐犬の審査に行った時、一緒に御嶽昇仙峡に行き、有名なパノラマ台の大岩の上に“百”も上がって、眼下数百メートルの渓谷を平気でながめて、その身軽さと大胆さで、同地の愛犬家たちを驚かせたこともありました。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんの眼の表情は私に向って、「あんたも案外愛犬家の素質があるようですね。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勇敢な愛犬家の顔を確かめて、一とこと口がききたかったのである。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智が知りあいの愛犬家から借りだしてきたもので、警視庁にもよく知られた有名な探偵犬なのです。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
