          ],
          "literary": [
            {
              "text": "無論私は作家自身の心のアスピレーションと作品の上に現れたそれとを混同していない積りである。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と只二人、私の心から芸術に対するアスピレーションも理想も何もぬき、只女としてさし向ったとき、その時丈満ち足りた平和が来る――それ程、彼は小さいのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻苦ということがわかって来る時代、一つのアスピレーションではなく刻苦ということが仕事の上でわかって、おのずから楽しみとなる時代。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
