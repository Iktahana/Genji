        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脂肉について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この脂肉は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "脂肉の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が脂肉について知っています。",
              "source": "幻辞"
            },
            {
              "text": "脂肉は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は脂肉の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "脂肉に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では脂肉が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から脂肉を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "脂肉の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも脂肉が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では脂肉が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "脂肉について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも脂肉は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも脂肉は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で脂肉は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に脂肉について学びました。",
              "source": "幻辞"
            },
            {
              "text": "脂肉の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する脂肉の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では脂肉の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何代か封建制度の下に凝り固めた情熱を、明治、大正になつてまだ点火されず、若し点火されたら恨みの色を帯びた妖艶な焔となつて燃えさうな、全部白臘で作つたやうな脂肉のいろ光沢だつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と同じほどの背丈があり、それに豊かな白い脂肉が盛りついてゐる自分を崩折れさすわけにはゆかないと、気持が立ち直つて来る。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁輪加なんか無論わかりそうにないノッソリした奴が多いのであるが、その中でも代表的と見える色の黒い、逞ましそうな奴が、骰子の目に切った生鰤の脂肉の生姜醤油に漬けた奴を、山盛にした小丼を大切そうに片手に持って、「ええ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どたどたと騒がしゅう振舞って何者じゃ」　四十がらみの、ずんぐりとした好き者らしい脂肉を褥の上からねじ向けて、その主計頭がいとも横柄に構えながら、二万四千石ここにありと言いたげに脇息もろ共ふり返ったのを、ずいとさしつけたのはあの三日月形です。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、入口からひょっこり姿を現わしたのは理髪師のイワン・ヤーコウレヴィッチであったが、その動作はたった今、脂肉を盗んで殴ちのめされた猫みたいに、おどおどしていた。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんてきにかけた鋤鍋へ、平七が巧みな手つきで黄色い脂肉を入れて、熔けたところへ砂糖を加へ、紫を注すと、ジユウツといふ音とともに、湯氣がむら／＼と舞ひ騰り、黒ずんだ天井の眞ん中に貼つてある大神宮の劍先｜神符が、白雲に蔽はれた山寺の塔のやうに、暫く見えなくなつた。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼豚の脂肉――　鶏の丸焼もあるが、ヤカンを下げた連中は値をきくだけで通りすぎちまう。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉や豚の脂肉や鶏の臓物など、見ただけでもむかむかするようなものを、荒噛みでのみこみ、そしてやたらに杯をあけます。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の子は一旦鍋へ豚の脂肉をジューと摺りつけたものでよく炒りましてそこへ豚の湯煮た肉を少さく切って入れて少しお湯をさして味淋と酒と醤油で味をつけてよく煮ます。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "皿の上には食いのこされた豚の脂肉が散らばっていて、蠅が二匹、じッと止まっていた。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、脂肉はすこぶる美味かった。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしくは二、三十貫の脂肉に富む猪が美味い。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔猪は一般に分厚な脂肉は少ないが、仔猪で比較的脂の乗ったものが最も理想的である。",
              "citation": {
                "source": "猪の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこんどは鯨の脂肉のかたまりを一つ取りあげました。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この小さな鯨の脂肉を、こんなふうに中をくぼませます。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中へしっかり巻いた鯨髭を押し込んで、その上にもう一つ脂肉をぎゅっとくっつけるのです。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊がこの小さな球を呑み込むと脂肉はとける、さきのとんがった鯨髭がしゃっきり突立って、熊のはらわたに突きささります。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦の中には、麦粉、肉の塩漬、食用油、脂肉、ブランディ、飲用水代りの淡味の葡萄酒の樽などが、船艙への昇降も出来かねるほどに積みあげられ、十七人の人間では一年や二年で喰い尽されないだけのものが残っていたのだから、そのほうの理由だとも思われない。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ王さまのお手製で、それには山もり乾ぶどう、拇指二つよりかまだふとい脂肉を二塊どしこんだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして軍勢の主君は、脂こき肉の、柔らかき脂肉の馳走、古き葡萄酒の、よく澄める古葡萄酒の馳走を、その人民どもになしたもう……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は脂肉をぞんざいに寄せ集めたように肥えていて、歩くと躯じゅうの肉がだぶだぶ波打って揺れる。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水と油とパンと塩とでできたスープ、少しの豚の脂肉、一片の羊肉、無花果、新しいチーズ、それに裸麦の大きなパン。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝はもと漢朝の旧臣、魏に寄食して、老朽の脂肉を養うとも、心のそこには、なおいささかの良心でもあろうかと、はじめは敬老の念を以て対したが、はからざりき、心身すでに腐れ果て、今のごとき大逆の言を平気で吐こうとは。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
