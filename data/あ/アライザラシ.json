    "definitions": [
      {
        "index": 1,
        "gloss": "faded from washing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗いざらしについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗いざらしの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗いざらしが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗いざらしについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗いざらしの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗いざらしが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗いざらしという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗いざらしについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗いざらしは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗いざらしが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗いざらしは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗いざらしの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗いざらしは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗いざらしは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが今夜のお徳に取り分けて侘しくきこえて、洗いざらしの単衣の襟がなんだか薄ら寒く感じられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際洗いざらしの鉄道工夫の青服などは、適当な背景の前には絵になるものの一つである。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、お洒落な子だったのですし、洗いざらしの浴衣に、千切れた兵古帯ぐるぐる巻きにして恋人に逢うくらいだったら、死んだほうがいいと思いました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きびらの洗いざらし、漆紋の兀げたのを被たが、肥って大いから、手足も腹もぬっと露出て、ちゃんちゃんを被ったように見える、逞ましい肥大漢の柄に似合わず、おだやかな、柔和な声して、「何か、おとしものでもなされたか、拾ってあげましょうかな。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平は、私と同じで、五尺七寸、しかも毛むくじゃらの男ゆえ、たいへん貧乏を恐れて、また大男に洗いざらしの浴衣、無精鬚に焼味噌のさがりたる、この世に二つ無き無体裁と、ちゃんと心得て居るゆえ、それだけ、貧にはもろかった。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清潔な町並みには、どこか洗いざらしたような色あせた印象を受けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に寝かされている男の子のほうは、まるまると肥だちもよくて、ずきんから着物にいたるまでひと目に裕福な良家の生まれらしい節々が見えましたが、右に寝かされている女の子のほうは見るからにやせ細って、そのうえに着物も継ぎはぎだらけの洗いざらしなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目にはその着ている物の色目もはっきりとは知れなかったが、筒袖も袴も洗いざらしのように色がさめて、袴の裾は皺だらけに巻くれあがっていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　洗いざらしだが、さっぱりした半股引に袖なしの××君は、色のいい茄子の漬物をドッサリ盛った小鉢へ向って筵の上へ胡坐を掻き、凝っときいている。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの満ちあふれる家々の中に何千という若い女が洗いざらしの藷のようにごろごろしているのに、自分は二日もすれば薄暗い妙光寺の中で寝起きせねばならないのか。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "下人は七段ある石段の一番上の段に、洗いざらした紺の襖の尻を据えて、右の頬に出来た、大きな面皰を気にしながら、ぼんやり、雨のふるのを眺めていた。",
              "citation": {
                "source": "羅生門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗いざらしたネルの着物で、ことことさっきからキャベツを刻んでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだ洗いざらしたネルを着ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗いざらした鳴戸ちぢみの飛白。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗いざらした紺絣は人間をりりしくみせます。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾沢はやがて新しい雑誌をとりあげて無造作に頁を翻していたが、「今度は己、洗いざらしに自伝を書いたっけ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり日が暮れかけていたが、こっちは、もう冬ぞらがくれかかっているのに、洗いざらしの縞の単衣ものを引ッ張っているだけなんだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで、自分はその日酒を飲んではいたが、いくらかヤケくそな気持から、上野駅まで送ってきた洗いざらしの単衣着たきりのおせいを郷里につれて行って、謝罪的な気持から妻に会わせたりしたのだが、その結果がいっそうおもしろくなかった。",
              "citation": {
                "source": "死児を産む",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し洗いざらしで地質が損じてるのは残念だったが、綺麗でさえあればよく、実際に使用することはないものだった。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝間着は着てるが、洗いざらしのその布地はガーゼのように薄く、それがぴったり絡んでる肉体は、厚ぼったく重々しく、そして柔かな温気を漂わせている。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸浪は洗いざらしの浴衣姿というだらしの無い風をしていたのだった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして七月の熱い日に、初めて夕立がして、その雨がまたじとじと降り続いてる夕方、洗いざらしの浴衣に短い袴をつけ鳥打帽を被った男が、びしょ濡れになってやって来た。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その逃げて来た娘さんに、洗いざらしでもよいわい、何かお前の下裳と胴着かなんぞを、出して上げなされや。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなくこの陰鬱な往来は迂曲りながらに少しく爪先上りになって行くかと思うと、片側に赤く塗った妙見寺の塀と、それに対して心持よく洗いざらした料理屋｜橋本の板塀のために突然面目を一変させた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とまだ夜具の中で新聞を見ている男の方を見返ったのは年のころ三十も大分越したと見える女で、細帯もしめず洗いざらしの浴衣の前も引きはだけたまま、鏡台の前に立膝して寝乱れた髪を束ねている。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗いざらしのぼろきれよりもなおきたならしい。",
              "citation": {
                "source": "枯葉の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "みわたせば、みんな洗いざらしの浴衣の、素足にちびた下駄、もしくはあかくなった夏帽に、これのみは夏のあわれの白靴、腕に抱えた小さな風呂敷包みは、言わずとも昼食べし弁当のあき箱。",
              "citation": {
                "source": "夕がたの人々",
                "author": "西村陽吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
