        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どうか悪しからず御諒察を願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな取止めもない事では雑誌に載せて頂くのは如何かと存じますが御返事までに申上げます、どうか悪しからず願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「決して御客様方の人格を疑うような訳ではありませんが、これも職務で御座いますからどうか悪しからず御勘弁を願います」と云う。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く芳はしき香も悪しからず、花の黄金色なせるも地にこぼれて後も見ておもむき無きならず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日はぜひ諸君に聞いていただかねばならぬ用事があったことですから悪しからず許してください。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか悪しからず」　とできるだけ言葉少なに思いきっていってしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　名刺を返して、「悪しからず……お名前だけ記憶します。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も上京して応援したいんだけれども知つての通りの境遇だから悪しからず思つてくれ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "風月堂のかすてらも悪しからず、引包めて二両ばかり買うが可い。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って到底御用立出来ませんから、悪しからず御了承下さい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻上りのそこの語もきゝなれては、さまでに耳に悪しからず、晩翠湖畔花郷臥城など、親しうする友達の情にほだされて、つひうか／＼と十日許りを旅館に打ち過ごしたり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうでしょうか、此方様にも御存じはなしさ、ただ好い女だって途中で聞いて来たもんだから、どうぞ悪しからず。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――子供同士の喧嘩です、先生、どうぞ悪しからず。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に該カフェー・クロコダイルの醜い営業振りが悉く当局の手によって暴露される事になりましたが、詳細な点はまだ、発表を停められておりますから悪しからず御諒察を願います。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その使ひは意外にも今後北井家では修一さんとの交際を打ち切ることにしたから悪しからずといふ縁談の断りに来たのだつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花は心の様さして悪しからず、ただ貧しき家に生れて、一年村の祭礼の折とかや、兄弟多くして晴衣の用意なく、遊び友達の良き着物着るを見るにつけても、わが纏える襤褸の恨めしく、少女心の浅墓にも、近所の家に掛けありし着物を盗みたるなりとぞ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか悪しからず思ってくれと、彼は頼むように言った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のは言い過ぎで、どうぞ悪しからず思ってください」　案外にもろく折れられて、栄之丞もほっとした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前以ってそれを申したら、お入りはなかろうかと存じて、わざと隠し立してお招きいたした次第、なにとぞ悪しからず……」　三斎はそれを聞くと、はっとなって、急に眼の前が暗くなったように思った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお持ちの象牙も今晩私が担いでお届け致しますから、その辺、どうか、悪しからず……」　こういう意味で私はキッパリと謝絶ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおまた、敬語を抜きにした記録体に致しましたために、無作法に亙るような個所が出来るかも知れませんが、何卒、悪しからず御諒読を願います。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ悪しからず……。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐時代はたるみも少くまたたるみても悪しからず。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、俳諧連歌における各句の接続は多く不即不離の間にあり、密着せる句多くは佳ならず、一見無関係なるが如き句必ずしも悪しからず。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三はちょっと手に取って見たが、その文面だけでは前後の係りがよくわからず、掻い摘んで言うと、せっかくのお言葉だけれど、いろいろ考慮した結果、遺憾ながら希望にそうわけには行かないから悪しからずという意味で、婉曲に拒絶しているのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して出し抜いたわけじゃないんですから、どうぞ悪しからずね。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あれはつまり、天皇というものは法律の上でも無能力なものであるということを自分から承認したことであり、どうぞこれからも悪しからずという挨拶です。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと詳しく申しあげればよいのですが、病臥中で意にまかせませんから悪しからず。",
              "citation": {
                "source": "加藤正宛書簡",
                "author": "一九三三年三月十三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々全体の部会を持つ必要があると考えましたので、専断ながらわれわれ三人で一応右のように決定致しましたから何卒悪しからず御諒承下さると共に御意見御もらし願います。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三一年九月二十日",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等無名作家の名前では効果がないと思ひましたからどうか悪しからず。",
              "citation": {
                "source": "病中雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
