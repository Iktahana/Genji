    "entry": "粗播き",
    "reading": {
      "primary": "あらまき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sparse sowing (seeding)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗播きについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗播きという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗播きの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗播きが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗播きを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗播きについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗播きの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗播きの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗播きが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗播きという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗播きという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗播きについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗播きを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗播きは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗播きについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗播きが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗播きは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗播きの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗播きは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗播きは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は、そんなこともあつたので、北海道へ行つた時、その頃はもう東京では珍しかつた「あらまき」を手に入れ、それを一本横光君のところへ送らせた。",
              "citation": {
                "source": "横光君といふ人",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
