        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルベドについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルベドという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルベドの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルベドが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルベドを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルベドについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルベドの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルベドの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルベドが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルベドという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルベドという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルベドについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルベドを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルベドは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルベドについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルベドが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルベドは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルベドの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルベドは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルベドは興味深い例である。",
              "source": "幻辞"
            }
          ],
