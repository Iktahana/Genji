        "examples": {
          "standard": [
            {
              "text": "毎日、アイオワは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイオワが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイオワに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイオワが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイオワについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイオワについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイオワについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイオワが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイオワが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイオワは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイオワは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイオワを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイオワをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイオワが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイオワの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイオワを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイオワに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイオワについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイオワは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイオワを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "米国セントルイスのナイファー教授が『ネーチュア』二十巻に出したは、アイオワ市に住む友人の騾いつも納屋に入りて燕麦を窃み食う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二｜種の新聞を読む小僧11・３（夕）　今はむかし、米国のアイオワ州、パノラの町のさる銀行支店に給仕を勤めてゐた十五歳ばかしの少年があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまアイオワ州立大学に、この方面の優れた冶金学者がいて、その協力もあって、忽ちにして問題を解決してしまった。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育へ行く前に、アイオワ州立大学で、前に総司令部にいたフォックス博士に会った時、「湯川さんをうちの大学に招聘したかったのだが、一足おくれてコロムビアにとられてしまった。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_427.png、横222×縦200）入る］図‐427　山地から我々は長い平地で、いくらかアイオワ州の起伏した草原に似た場所へ出た。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔二月三日、アイオワ州クリア・レイク発、ＵＰＩ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
