        "examples": {
          "standard": [
            {
              "text": "アイオワ州はアメリカ合衆国最大のトウモロコシ生産地として知られ、広大な農地が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次期大統領選の予備選挙は、アイオワ州の党員集会から始まるのが恒例となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画「フィールド・オブ・ドリームス」の舞台となったのは、アイオワ州にあるトウモロコシ畑だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アイオワ州立大学の研究チームは、再生可能エネルギーに関する画期的な技術を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬のアイオワ州では、しばしば厳しい寒波に見舞われ、住民は厚着で対策する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アイオワ川はミシシッピ川に合流する主要な支流の一つで、州の景観を彩っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "米国セントルイスのナイファー教授が『ネーチュア』二十巻に出したは、アイオワ市に住む友人の騾いつも納屋に入りて燕麦を窃み食う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二｜種の新聞を読む小僧11・３（夕）　今はむかし、米国のアイオワ州、パノラの町のさる銀行支店に給仕を勤めてゐた十五歳ばかしの少年があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまアイオワ州立大学に、この方面の優れた冶金学者がいて、その協力もあって、忽ちにして問題を解決してしまった。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育へ行く前に、アイオワ州立大学で、前に総司令部にいたフォックス博士に会った時、「湯川さんをうちの大学に招聘したかったのだが、一足おくれてコロムビアにとられてしまった。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_427.png、横222×縦200）入る］図‐427　山地から我々は長い平地で、いくらかアイオワ州の起伏した草原に似た場所へ出た。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔二月三日、アイオワ州クリア・レイク発、ＵＰＩ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
