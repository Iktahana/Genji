[
  {
    "uuid": "51944883-aff4-55fb-b6b4-18497716c99f",
    "entry": "穴釣り",
    "reading": {
      "primary": "あなづり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fishing by dropping a line between rocks or concrete tetrapods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴釣りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴釣りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴釣りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴釣りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴釣りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴釣りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴釣りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴釣りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴釣りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴釣りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴釣りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴釣りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴釣りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴釣りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三宅坂の方面から参謀本部の下に沿って流れ落ちる大溝は、裁判所の横手から長州原の外部に続いていて、昔は河獺が出るとかいわれたそうであるが、その古い溝の石垣のあいだから鰻が釣れるので、うなぎ屋の印半纏を着た男が小さい岡持をたずさえて穴釣りをしているのをしばしば見受けた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穴釣りの鰻屋も、この柳のかげに寄って来て甘酒などを飲んでいることもあった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅坂の方面から参謀本部の下に沿って流れ落ちる大溝は、裁判所の横手から長州ヶ原の外部に続いていて、むかしは河獺が出るとか云われたそうであるが、その古い溝の石垣のあいだから鰻が釣れるので、うなぎ屋の印半纏を着た男が小さい岡持をたずさえて穴釣りをしているのをしばしば見受けた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、七歳の頃になると、鰻の穴釣りに、私のうしろを魚籠をさげて歩いた。",
              "citation": {
                "source": "桑の虫と小伜",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴釣りの面白さは分つても、寒さには降参したらしい。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節がおくれては居るが、公魚の穴釣りをする。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴釣りはどうかと思はれるどんより暖い曇天で、富士の姿は全く見えなかつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して穴釣りで公魚が釣れたのである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖の穴釣りの公魚は見込ないものとあきらめては居るが、湖畔に棲んで居る私としては、氷一面の湖水を見ると、矢張り食指動かざるを得なかつた。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖は穴釣りは出来ぬ筈ではなかつたか。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今迄書き続けて来た「高原・釣」に諏訪湖は穴釣り出来ず、その理由は、と随所に説をのべて居たではないか。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云へば四五年も前、秋の公魚釣の時、船宿で『もう何年か前一度穴釣りをした人がありました』と聞いた事があつたやうな記憶がある。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその話をきいたので、その後自分も穴釣りをする気になつて試みて尽く失敗に終つたのであつたのかも知れない。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖で穴釣りが出来る出来ないは私としては問題ではない。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが私の実験からの決論で、諏訪湖は浅過ぎるので氷結すると、公魚の常住する湖底も零度近くなる、従つて諏訪湖の穴釣りは不結果であると信じて来たのである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の決論に曰く「諏訪湖の穴釣りは命がけたるべし」",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "※822　鰻の隠れ家にエサのついた針を送り込む穴釣りという方法を指すか。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の夜『ミネルワ』にておん身が物語聞きしときのうれしさ、日頃木のはしなどのやうにおもひし美術諸生の仲間なりければ、人あなづりして不敵の振舞せしを、はしたなしとや見玉ひけむ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
