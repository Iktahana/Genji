        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗殺者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗殺者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗殺者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗殺者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗殺者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗殺者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗殺者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗殺者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗殺者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗殺者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗殺者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗殺者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗殺者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗殺者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "またたとえば映画の中で一人の男が暗殺者のために思いがけなく射殺されるところがあるとする。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻から出たミネルヴァの昼と夜とを違えた生きものの影が暗殺者の役目をした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば血に塗られたる戦場に暗殺者の切尖に何の正義か宿れるや？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程無政府主義者中から暗殺者を出したのは事實です。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し夫れは同主義者だから必ず暗殺者たるといふ譯ではありません。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗殺者の出るのは獨り無政府主義者のみでなく、國家社會黨からも、共和黨からも、自由民權論者からも、愛國者からも、勤王家からも澤山出て居ります。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "是まで暗殺者といへば大抵無政府主義者のやうに誣ひられて、其數も誇大に吹聽されてゐます。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に暗殺者を出したからとて暗殺主義なりと言はば、勤王論、愛國思想ほど激烈な暗殺主義はない筈であります。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に暗殺者の出るのは、其主義の如何に關する者でなくて、其時の特別の事情と、其人の特有の氣質とが相觸れて、此行爲に立至るのです。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、暗殺者は其時の事情と其人の氣質と相觸るる状況如何によりては、如何なる黨派からでも出るのです。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、同主義者は皆平和、自由を好むが故に、暗殺者を出すことは寧ろ極めて少なかつたのです。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今回の事件を審理さるる諸公が、「無政府主義者は暗殺者なり」との妄見なからんことを希望に堪へませぬ。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、天明や天保のやうな困窮の時に於て、富豪の物を收用するのは、政治的迫害に對して暗殺者を出すが如く、殆ど彼等の正當防衞で、必至の勢ひです。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜の暗殺者が、密約された殺人の命を実行しに来たというのか？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの「荊軻」をみて、はからずもこゝに児玉希望氏の芸術観、言ひ換へれば人生の見方、ともいふべきものを、その図柄の上で発見し、私を少なからず動かすものがあつた、この絵のテーマとして、暗殺者と被暗殺者との対照は難かしい仕事であるにちがひない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識的に解すれば殺しに行く方を、顔、表情、其他をするどく描かるべきである、私はふと暗殺者の武器を握つた手に触れたとき、その手がふつくらと肉付きがよく、豊かに描かれてゐるのを発見して、これなるかなと嘆賞した。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも無残な仕方だが、まだ酷いのはアビシニア人が牛を生きながら食う法で、ブルースはかの国の屠者を暗殺者と呼んだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、外相暗殺者の逮捕されないうちは死んでも死に切れません…………」　松島氏は黙って点頭いた。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "外相暗殺者を逮捕せねばならぬ責任上、わたしは、あなたから、その言葉の意味が聞きたいのです。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は今回の事件の経過を観察したとき、尋常一様の暗殺者の仕業ではないと思いました。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして恐らく更に恐ろしい地獄へ彼を押込んだ暗殺者の熊手の滅多突き或ひは血塗れの衣服へ火の燃えついた時の最初の苦悶は、火焔の死に逢ふべく彼を蘇生させたであつたらう。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近あらわれた元看守のファシストである暗殺者さえ、属する団体は民主化同盟という名をもっている。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即わち自殺者と暗殺者が神の如く敬愛される、愚かな日本民族の持つ唯一の別離の言葉として、「さようなら」の浅薄なニヒリズムはいかにもふさわしい。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコデ以て中津の有志者｜即ち暗殺者は、金谷と云う処に集会を催して、今夜いよ／＼鵜ノ島に押掛けて福澤を殺すことに議決した、その理由は、福澤が近来｜奥平の若殿様を誘引して亜米利加に遣ろうなんと云う大反れた計画をして居るのは怪しからぬ、不臣な奴だと云う罪状であるから、満座同音、国賊の誅罰に異論はない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "カテリナは有名な近親殺害者で、おまけに聖バルテルミー斎日の虐殺を指導した発頭人なんだし、また娘の方は、毒のルクレチア・ボルジアから百年後に出現し、これは長剣の暗殺者と謳われたものだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "錬金魔法師兼暗殺者のオッチリーユは？",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦闘の結果は彼の勝利なりしも、戦後の陣中においてオッチリーユが糸を引いた一軽騎兵のために狙撃せられ、その暗殺者は、ザックス・ローエンベルグ侯のためその場去らずに射殺せらる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
