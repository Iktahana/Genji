        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女房は暮合いに帰って来て、間もなく、へい、お待遠、と台所へ持込んだけれども、お夏の心づけで、湯銭を持たせて、手拭を持たせて、錫の箱入の薫の高いしゃぼんも持たせて、紫のゴロの垢すりも持たせる処だった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、黒い垢すりの甲斐絹が何度となく上をこすつても、脂気の抜けた、小皺の多い皮膚からは、垢と云ふ程の垢も出て来ない。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は手拭と垢すりとを流しへ抛り出すと半ば身を起しながら、苦い顔をして、こんな気焔をあげた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、黒い垢すりの甲斐絹が何度となく上をこすっても、脂気の抜けた、小皺の多い皮膚からは、垢というほどの垢も出て来ない。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は手拭と垢すりとを流しへほうり出すと半ば身を起しながら、苦い顔をして、こんな気焔をあげた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんびとといえども――と言ったがただ一人の例外は、例の千代田の垢すり旗本、愚楽老人だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそば御用、近侍の者たち、ことごとく遠ざけられて、今この御寝の間に額を集めているのは、八代将軍吉宗様を中に、天下ごめんの垢すり旗本愚楽さんと、今をときめく南のお奉行大岡忠相の三人のみ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……垢すり旗下の名で隠然権勢を張る、非常な学者で、また人格者でした。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人呼んで垢すり旗下。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代田の垢すり旗下、愚楽老人の言上したところでは――ナアニ、先祖がしこたまためこんで、どこかに隠してあるんです、という。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらず、垢すり旗下愚楽老人が、お待ち受けしていて、お流し申しあげる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、事実も事実、上様が八代将軍様で、わっしが垢すり旗下じゃというくらいの紛れもない事実にござります。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外では、垢すり旗本、殿中では、この、お羽織お羽織で通ったものです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ピカ日光（発端篇）　亀背で小男の愚楽老人、この上様のお風呂番は、垢すり旗下と呼ばれて、たいへんな学者で、かつ人格者だった。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代田の三助……垢すり旗本。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに、威令ならびなき垢すり旗本なんです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友がゴローの垢すりで生一本に、それでも女の肌だと思うから多少の加減をしてキュキュとこする肌ざわりにでも、思い設けぬ快感を感じ出したものか、いつまでもその肌をこするに任せて、いつまで経っても、もういいよとは言いそうもない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり背が高くなく、痩せこけて、弱々しげな体格をして、髪の毛も赤く、まばらな顎鬚も赤みがかかっていたが、この鬚はささくれ立った垢すりの糸瓜にそっくりであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりなんですか、糸瓜の一件、垢すり糸瓜の一件じゃございませんかね？",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般にガレノスは体育についてのヒポクラテスの教えに従っており、垢すり器を使う利点については１冊の本を書いた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "油を塗った後でタオルと垢すり器を使った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢すり器はふつう鉄で作られていた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルススは最初に発汗、次に温浴、そして最後に頭から冷水、次に垢すり器を使い、油を塗って摩擦をする。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初冬の谷水の中にさらされて、白いあかすりとなり、長くこの世に残るのであろう。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の足の裏のあかをすり落とすあかすりとなるためには、へちまは生命を終わらねばならぬ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡々として、へちまがあかすりになって最後のご奉公をしようと思うのに似ている。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしに油とあかすりを持つてきておくれ。",
              "citation": {
                "source": "スザナの物語",
                "author": "――経典外聖書――",
                "note": "青空文庫"
              }
            }
          ]
        }
