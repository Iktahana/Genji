    "definitions": [
      {
        "index": 1,
        "gloss": "scrubbing grime off (the skin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
