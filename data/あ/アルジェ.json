        "examples": {
          "standard": [
            {
              "text": "私は毎日アルジェについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルジェという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルジェの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルジェが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルジェを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルジェについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルジェの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルジェの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルジェが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルジェという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルジェという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルジェについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルジェを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルジェは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルジェについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルジェが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルジェは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルジェの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルジェは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルジェは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ルイ朝式の服を着たマダムがポケット猿を抱え人に揺られながら、アルジェリアの服装をした楽師風の男と猿の病気の話をしている。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に「地の糧」を書かしめたアルジェリイにおける生産力の横溢と転身の自覚。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、倫敦チャアリング・クロスの敷石もアルジェリアの砂漠も、シャンゼリゼエの歩道も同じ軽さで叩くだろうしベルゲンの土も附けばアラビヤの砂も浴びるだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五、六の、女になり立てのから三十歳前後まで、十人あまりの女群のなかには、アルジェリイかどこか植民地産らしい黒人の女もいた。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "香気のために私は毎朝オウ・ド・コロンを飲んで、頭髪にはゴミナ・アルジェンテンの固化油を使用した。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者は、こんにち日本の銀座にジュリアン・ソレルという服飾店などがあることを、アルジェリア女の口からきくパリまがいのフランス語とひとしく、その人々のためにまたフランスの良心のために汗ばむ思いで見ているわけである。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの作家が途方にくれると、よく主人公をアルジェリーへ旅立たせてしまう。",
              "citation": {
                "source": "文学と地方性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ええとアルジェリアの總督の鼻の下に瘤のあるのを御存じかね？",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "船艙の覆いにまで黒人植民兵を満載して仏領アフリカから急航しつつあった運送船が、アルジェリアの海岸近くでドイツの潜航艇に遣られている。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロリイヌが印度で再婚したことを知つたり、結婚してアルジェリヤに行つてゐた彼女の一番の親友のルイズ・ド・ベエヌがその地で病死したりして、ユウジェニイの晩年は非常に索漠としたものだつた。",
              "citation": {
                "source": "モオリス・ド・ゲランと姉ユウジェニイ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "駐仏ソ大使アルジェールよりパリへ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "西岸のアルジェニヨへ来ると、はじめて湖水がひろびろと見わたされる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化の国では、ビールよし、シャンパンよし、おしるこもよし、巴里の女でもアルジェリアの女でもなんでもいい。",
              "citation": {
                "source": "茶番に寄せて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月、アルジェリヤ、テュニス、埃及への旅に出づ。",
              "citation": {
                "source": "リルケ年譜",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が災害を忘れかし、佳き年今やめぐり来て、フランス汝を解放せん……汝は見るべし、フランスの治下に栄ゆるアルジェリア！",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルジェリアから始めて、コンゴを通り、南端の喜望峰まで、主なところは全部廻ったそうである。",
              "citation": {
                "source": "桃林堂の砂糖づけ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはラプラタ川（＊ウルガイとアルジェンチンの間の大河：河口にブエノスアイレスがある）を遡行する船で何回も岸と何かの連絡がなされる前に出現した。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "1834年７月にすべて健康な800人の兵士が同じ日にアルジェリアのボナで３隻の輸送船に乗船し、一緒にマルセイユに到着した。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムッシュウ・エルアフイはアルジェリイの何処のお生れなんですか。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「私はもと／＼アルジェリイ駐屯軍に召集されて、沙漠のなかの支隊から支隊へ連絡する伝令兵に選ばれてゐたのです。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと／＼アルジェリイの人には静かな生活といふものはないのですから。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アルジェリイは二月に入ると、急に豪雨が続いて、その合ひ間の晴れた日は気温が目立つて上るのです。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『アルジェリイの陸上競技聯盟が私を監理してゐるのですよ。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「翌年、私はアルジェリイ駐屯軍に召集されました。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスへわたり、汽車でスペインへいって、そこからアフリカのアルジェリアへいくつもりだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルジェリアなら、姿をけしてはだかで暮らしても、いっこう寒くはないだろうからね」「アフリカにいくのか？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が、新聞をよめるようになりたいと云ったら、日本の植民地政策は成功しているのに、フランスはモロッコでもアルジェリーでも失敗つづきだ、と云ったマダム・ラゴンデール。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この病気を特に研究するためにアルジェリアに赴いた外科医ムシュー・シャルル・ラブラン（1845-1922）が赤血球の中に病原体を発見するまで何も知られていなかった。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "1880年にラブランという名前の若いフランスの軍医はアルジェで研究していて血液を顕微鏡で検査していて赤血球内にアメーバのような小さな物体があることを発見し、彼はマラリアの病原体であると信じた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩餐の席で出会ったのは銀行家、技師、新聞記者、国際的仲介人、アルジェリアの黒奴売買人的な者ども――すべてフランス共和国の実務家らであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
