    },
    "definitions": [
      {
        "index": 1,
        "gloss": "low-priced",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安価について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安価という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安価の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安価が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安価を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安価について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安価の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安価の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安価が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安価という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安価という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安価についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安価を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安価は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安価について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安価が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安価は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安価の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安価は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安価は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "普通の田舎町らしい――漁師町らしい――気分と、温泉町らしい特異の気分とが不調和に混同して、妙に落付きの悪い安価の印象をあたへる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、まだ現代の女性はイージーでセンチで安価な妥協をして了うのが多い。",
              "citation": {
                "source": "異性に対する感覚を洗練せよ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」は安価なる現実の提立を無視し、実生活に大胆なる括弧を施し、超然として中和の空気を吸いながら、無目的なまた無関心な自律的遊戯をしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも爆弾よりも安価でしかも却って有効かもしれない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの可能性として考えられるものは、軽便で安価な「知識の即売」である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代に隆盛を極めている各方面の通俗的な雑誌はこういう安価で軽便な皮相的な知識を汽車弁当のおかずのごとく詰め込んであるが、ただ自分のちょうど欲しいと思うものを自分の欲しい時に手にいれようとするには不便である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあまりに安価で外聞の悪い意地のきたない原動力ではないかと言われればそのとおりである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな安価な殉情的な事柄に涕を流したのが少し恥かしかったのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は高等学校一年の時、既に粋人たらむ事の不可能を痛感し、以後は衣食住に就いては専ら簡便安価なるものをのみ愛し続けて来たつもりなのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその時初めて恋の楽しさと哀しさとを知りました、二月ばかりというものは全で夢のように過ぎましたが、その中の出来事の一二お安価ない幕を談すと先ずこんなこともありましたっケ、「或日午後五時頃から友人夫婦の洋行する送別会に出席しましたが僕の恋人も母に伴われて出席しました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又一月ばかりは何のこともなく、ただうれしい楽しいことばかりで……」「なるほどこれはお安価くないぞ」と綿貫が床を蹶って言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "安価な感傷と評した人もあったがしかしそれがかなりな真実味をもって表現されている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬は計算用の原稿紙を一まとめにして懐ろにしまいこみながら、馬鈴薯から安価な焼酎と、そのころ恐ろしく高価なウ※スキーとが造りだされる化学上の手続を素人わかりがするように話して聞かせた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、国内で農作が豊年の時は、農作物の値段が下落することを恐れて、植民地や属国から輸入される農作物をその年だけ全部現地で焼き捨てたり、没収したり、安価で買い占めて隠してしまったり、高い輸入税を課してなるだけ国外から入り込まないように努めます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "便利極楽、器械文明が安価に普及されて便利になったことであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度、同銀行蔵掃除について払下げに相成ったを、当商会において一手販売をする、抵当流れの安価な煙草じゃ、喫んで芳ゅう、香味、口中に遍うしてしかしてそのいささかも脂が無い。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千円は安価いものだね。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の貞操をこんな風に簡単に汚されながら、しかもそれが安価な金銭に換算されてしまうのか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父はそれを私独得の「相場の予感に対する口止め料」であるかのように云い聞かせていたが、実は、私という福の神に投げ与える極めて安価な足止め料に相違なかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は元来が安価な人間であるから、大抵の人のものを見ると、すぐ感心したがる癖があるが、此「土」に於ても全くそうであった。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは回教徒の祈祷の姿に擬しつつ実は、聞えて来る活動館の安価な楽隊の音に合わせているのだった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方の木材は良質でしかも安価なので知られてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸の野郎と顔をならべて、似而非道学者の坂田なんぞを見返そうと云った江戸児のお嬢さんに、一式の恩返し、二ツあっても上げたい命を、一ツ棄てるのは安価いものよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で見たものの事を饒舌ったが、」　と民弥は、西片町のその住居で、安価い竈を背負って立つ、所帯の相棒、すなわち梅次に仔細を語る。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは爺っつあんか、俺ァ都田村の吉兵衛って者だ」　「はい……」　「石松つあんとは以前からの友達だ」　「久し振りに二人で一杯やりてえと思って来たんだが……まだ帰って来ねえのか」　「石松が帰って来るので御座いますか」　「なんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて日の暮るまで尋ねあぐんで、――夜あかしの茶飯あんかけの出る時刻――神樂坂下、あの牛込見附で、顏馴染だつた茶飯屋に聞くと、其處で……覺束ないながら一寸心當りが付いたのである。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて日の暮るまで尋ねあぐんで、――夜あかしの茶飯あんかけの出る時刻――神楽坂下、あの牛込見附で、顔馴染だつた茶飯屋に聞くと、其処で……覚束ないながら一寸心当りが着いたのである。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、小栗があたり芋をすゝり、柳川がはしらを撮み、徳田があんかけを食べる。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこには気味の悪い海月や鮹や、恐しいあんかうや、鰐ざめなんかひそんでゐるだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんかを蹴っくり返しましてね。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
