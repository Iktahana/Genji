        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルバーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルバーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルバーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルバーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルバーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルバーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルバーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルバーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルバーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルバーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルバーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルバーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルバーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルバーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルバーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルバーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルバーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルバーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかるに近頃アルバート・スミスという人が天然色の活動写真を発明してこの欠点を補うに到った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年三月、渋柿）　　　　　　　＊　アルバート・ケンプという男が、百十時間ぶっ通しにピアノを弾き続けて、それで世界のレコードを取ったという記事が新聞に出ていた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長五フィート七インチ、体格よし、顔色悪し、黒髪、頭頂に小禿あり、たわわな黒い頬髯口髭、色眼鏡、話し方はやや訥々、失踪時の服装は黒のフロックコート、黒のベスト、金のアルバート鎖、下はハリスツイードの鼠色、ゴム布の長靴に茶褐色のゲートルを重ねる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のアルバート時計鎖、純金で重い。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでアルバート船渠に駆けつけると、なんと船は今朝の引き潮で川へ入り、サヴァナへ帰航の途に着いたと。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわい褐色のベストからは太い真鍮製のアルバート型時計鎖が垂れ下がっていて、先には四角く穴のあいた金属の小片が装飾品としてついていた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に伴れられてアルバート・グリルへ赴く。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーカーの『アルバート・ニャンザ記』に、欧州で鈍な男を驢と呼ぶがエジプトの驢は勘定が巧い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に伴はれてアルバート・グリルへ赴く。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｎは滝の父親の親友であるアメリカ人のアルバートさんの娘ですが、母親が古風な趣味を持つてゐるためか大変淑やかで、朗らかに内気で、そして適度の愛嬌を忘れません。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の年の春頃Ｎの父である山林技師のアルバートさんが設計して建てた小屋です。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバート街にわたしたちの家があったのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばモスクワ芸術座のルージュスキーなんか、役柄は西洋の松助みたいなところだが、革命前、アルバート広場の裏んところへ大きな邸宅をもって暮していた。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、フットボール競技場前の広場へ、アルバート広場に群っている通りな、いろんな物売りが出ていて、あっちから巡査がやって来るのを見るとパッと蜘蛛の子ちらすように逃げ出すところは、活々した日常生活の光景からの断片で、そこのところで笑わないものがなかった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤と白とに塗った古い大教会のあるアルバート広場へ行ったら、雪を焚火のおきでよごして、門松売りのようにクリスマスの樅の木売りが出ている。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の工場で、一分間に数千枚の新聞紙を刷りだす、アルバート会社製の高速度輪転機が、附近二十余軒の住民を、不眠性神経衰弱に陥れながら、轟々と廻転をし続けていた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉雪をとおして遠くに、アルバート街の赤と白で塗った大教会の塔が美しく眺められる。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナースチャがたまに夜映画から帰ると、アルバートの広場で通りすがりの若い男が耳のそばで、「｜行こうよ」とささやいた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、どのくらい沢山｜組合に入ってる娘たちが失業で淫売婦になってアルバートをうろついているか知ってるかい」　ナースチャは知らなかった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いりゃしないやね」――アルバートの広場の赤白塗の古い大教会では、二人の男が鐘楼で受難金曜日の鐘を鳴らした。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンレーは、更に附近の探検を続け、ウガンダのムテサ王に頼んで多数の護衛兵をつけてもらひ、西方のアルバート・エドワード湖を探り、附近の山脈の模様をも調べました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は来月二十四日に、アルバート・ホールで音楽会を催すのですが、それに是非御出演下さい。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアルバート・ホールで是非これをうたって下さい、というお話でした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上そのアルバート・ホールの音楽会には、アドリナ・パティもおうたいになるということもお話になりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奥様には悪いと思いましたが、アルバート・ホールの初舞台より、この南條さんの髪結さんの方がよっぽど草疲れてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして支度万端整いましたので会場のアルバート・ホールに参りました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアルバート・ホールの建物はちょうど両国の国技館のように、四方に高く客席が出来ていて、二万三千人の聴衆がぎっしりつめかけていました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバート・ホールでキングやクインの前で、サー・ヘンリー・ウッドの指揮で日本の歌をうたった有名なマダム三浦です。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私がアルバート・ホールで初演した翌年の一九一五年のことでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのアルバート・ホールで私がお目にかかった時、アドリナ・パティは七十一歳でした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
