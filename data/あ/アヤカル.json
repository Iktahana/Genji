[
  {
    "uuid": "8d86f38b-d62e-583e-a4c6-a0f8ab705b68",
    "entry": "肖る",
    "reading": {
      "primary": "あやかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to share (someone's) good luck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日肖るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "肖るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は肖るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には肖るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "肖るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは肖るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "肖るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は肖るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では肖るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "肖るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に肖るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では肖るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "肖るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると肖るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "肖るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では肖るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に肖るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により肖るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "肖るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に肖るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "うな｜は爺んごに肖るやなぃぢゃぃ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けづな爺ごに肖るやなぃじゃぃ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大倉男はあまり肖ると機嫌が悪かった。",
              "citation": {
                "source": "自作肖像漫談",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曰く、「まず正に言あり、鬼は人の影なり、人は鬼の形なり、影と形と相｜肖る。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者にはこの瑞兆に肖るように洩れなく「鶴の子石鹸」を贈呈するほか、夕陽新聞の半額購読券を配布する。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああ、身震がするほど上手い、あやかるように拝んで来な、それ、お賽銭をあげる気で。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、皆が図書様を取巻いて、お手柄にあやかるのかしら。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「執念の深いもんだから、あやかる気で、生命がけの膚に絡ったというわけだ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "産の安らかさに、児のすこやかさに、いずれ願ほどにあやかるため、その一枚を選んで借りて、ひそかに持帰る事を許されている。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の時に家中やられたのが、たった一人、面くらって水瓶の中へ飛込んだ奴が、不思議に助かったと謂いますからね、よくよく運だ、あやかるだけでも可うございましょう。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから昔尖塔の頂上に板を雄鶏に造って立て、僧徒にこの板が風に随うて動きやまぬごとく少しも懈らぬよう訓えたとジュカンシュは言ったが、グラメー説には、塔頂に十字架に添えて鶏の形を設くるは、ゴット人が雄鶏の武勇にあやかるためこれを軍旗とした遺風という。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼て粉にして飲んでしまおうか、そうしたら些とはあやかるかも知れん、アハハハハ」「オホホホ」「オイ好男子、そう苦虫を喰潰していずと、些と此方を向いてのろけ給え。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして栃木の出世にあやかるやうにと言つて、鱈腹飲んだり、食つたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は単なる善悪ではない、国民精神と名のつくものにあやかるのが善で、そうでないのが悪思想だという風に制定された。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやかる人は選ばねばなりませんね。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の頃はおふくろも、弟も、僕には飽々してる模様ですよ」「そりやア、貴方のひがみだわ」「ひがみですかね……」　加野は実際、富岡のやうな、紙一重のあぶないところを、一生涯、自分の直接性をもつてすり抜けてゆける幸運には、あやかる事も出来ないと思つてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやかるで」「生命の方もじゃが、ま一つの方もなあ。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あやかりたいの、果報者に」「なかなかむずかしゅうございますよ、果報者にあやかるということわね」「ひどく勿体をつけるじゃアないか」　ツト手を延ばすと盃を取り上げ、「まず注いだり。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も勧められたけれども、クリスチャンでも回教徒でもない私は恵みの分け前にあやかる特権を辞退した。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下藤吉郎は柴田と丹羽にあやかるために羽柴秀吉と改名したが、秀吉の御謙遜だといふのは後日の太閤で判断しての話で、改名の当時は全く額面通りの理由であつたに相違ない。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の祖母に八十六歳まで長寿を保った人があったので、それにあやかるためその名を頂戴して、みゑ子と名付けたのである。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常は、酒井藩に伝わる武勇譚などに読み耽っているそうであるが、読書に飽きれば竿をかつぎだして家来を引きつれ、近くの湯野浜海岸はもちろんのこと、遠く鳥海山の裾が日本海へ没する吹浦や有耶無耶関址のあたりまで繰りだして祖先の練武にあやかるのであるという。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の男がこれを手にしたのは、もちろん犬に扮するためであり、犬に扮するのは、犬は産の軽い動物であるから、それにあやかるためであります。",
              "citation": {
                "source": "アイヌ宗教成立の史的背景",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあやかるというのも不遜な話であるが、「詩なき詩論」を考えてみようという気になった。",
              "citation": {
                "source": "詩人への註文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい、やい、色男にあやかるようにこの面をよく拝んでおけ」　芳太郎は、ひらきなおって、「おお、そうか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "長寿にあやかるということはありますが、鶴を食って長生きをしたという伝承はないはずです。",
              "citation": {
                "source": "西林図",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の児には父君にあやかるようにと、旦那様の御姓を無断で一字頂いて、松吉という名をつけました。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子のために、便宜があればそれにこしたことはないが、吉見素子がそれにあやかることは不本意だが、大目にみておくという表情を、ありありと顔にうかべている多計代に玄関まで送られて、翌日伸子は父と藤堂駿平の邸へ出かけた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬のお産は軽いので万物の霊長たる人間様も犬にあやかるようにと五月の犬の日に腹帯を締める。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、俺ぐらいにあやかるように、もう一度、生れ直して来い」　五ツ六ツ、撲るように刀でたたくと、仁吉の体は、魚の臓物のように、船底に俯つ伏して、声も音も消してしまった。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
