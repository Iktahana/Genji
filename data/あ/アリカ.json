        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日在り処について考えている。",
              "source": "幻辞"
            },
            {
              "text": "在り処という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在り処の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在り処が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在り処を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在り処について学習した。",
              "source": "幻辞"
            },
            {
              "text": "在り処の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在り処の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在り処が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在り処という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在り処という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在り処についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在り処を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在り処は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在り処について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在り処が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在り処は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在り処の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在り処は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在り処は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "人間は何と己れの心の在り処を自ら知らぬものかと、今にして驚くの外はない。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりにシカメ面をして涙を拭う真似をしていながら、鼻だけはノホホンとしているために見物には何の感動をも与え得ないヘッポコ役者の表現法とは、その根底の在り処が違うのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、昼間舟の在り処を見定めて、夜行って見ると、舟は何人かが乗り去ったとみえて影もなく、激しい怒涛が暗い岸の砂を噛んでいるだけだった。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、敵の在り処を突き止めると、小躍りしながら、すぐ京を立って、伏見から三十石で大坂へ下った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん彼女は動脈や静脈の在り処は承知していた。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者がうるさいほど注でおしゃべりを繰り広げているのは、資料の在り処をせっせと示しておくことで、次に歴史をたどろうとする人の道案内ができないかと考えているのが一つの理由である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の奥の小さな金の鈴が、新しい可能性の在り処に反応して鳴りはじめると、巨大な幼児はアドレナリンを亢進させてその場を見極めようとしゃにむに這い回った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は必、祭儀の必要から出来たもので、神の在り処でないであらう。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常テレビの「ダイヤル一一〇番」をヒイキにしているその取り次ぎ嬢は、すぐにも警視庁に連絡して、今の電話の在り処を問い質そうとしたが、何となく薄気味がわるくなって来て、ともかくもＵ君の出社を待っていたのだという。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれから気を付けて見ると、それは決して爰だけには限らず、少なくとも京都から東では諸処方々に老木のしだれがあり、その在り処も神社仏閣、その他霊地と謂つてよいやうな場所が多いことは、信州とあまりかはりが無い。",
              "citation": {
                "source": "信濃桜の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白勝ちの赤毛の斑で、顔の至って平めなのが特徴であったが、今以てぶちの在り処まで略々同じ猫が、次から次へと代を重ねて居る。",
              "citation": {
                "source": "どら猫観察記",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした作品の在り処を青空文庫で示していきたい。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "願うところは生活技術の今後の攻究に由って、国の病の在り処がよくわかり、従って皆さまのやさしい心配が、結局政治の上に顕われてくることである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですが、奥さんは必要なもののありかをご存じですか。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "否々彼も人の子なり、我子なり、吾に習いて巧みにうたい出る彼が声こそ聞かまほしけれ、少女一人乗せて月夜に舟こぐこともあらば彼も人の子なりその少女ふたたび見たき情起こさでやむべき、われにその情見ぬく眼ありかならずよそには見じ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、踊りの師匠の歌女代さんのお墓はどこですね」　要りもしない花を買って、半七は歌女代の墓のありかを教えて貰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ほのあかり秋のあぎとは〕ほのあかり秋のあぎとは、　　　ももどりのねぐらをめぐり、官の手からくのがれし、　　　　社司の子のありかを知らず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりは降りるときはわざと巣からはなれて降りるから飛びあがるとこを見なければ巣のありかはわからない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の路は暗くてただ一つ電柱についている燈がそのありかを示しているに過ぎなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは闇のなかでもそのありかをほの白く光らせる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその金を払ったまま、港のありかをきいて外へ出てしまったのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思いたれば、怪しまで、隠れたる児のありかを教うるとさとりたれば、いそいそと従いぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここをわれに教えしを、今にして思えばかくれたる児どものありかにあらで、何等か恐しきもののわれを捕えむとするを、ここに潜め、助かるべしとて、導きしにはあらずやなど、はかなきことを考えぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの土でさえ、舗装の人造石やアスファルトの下に埋もれてしまっているのに、何をなつかしむともなく、尾張町のあたりをさまよっては、昔の夢のありかを捜すような思いがするのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるのような人もありかにのような人もあるというのも事実であって、それはこの世界にさるがありかにがある事実と同じような事実である。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は夜気に触れると咳が出るし、石油のありかもよく知らないから、行ってきてくれと頼むべきだったのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま君がありかを云えば内分で済むのだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は子供も親類もねえと云っていますよ」　十五夜の月の下にさまよっていた若い女は、元八にむかって神明様のありかを尋ねたということを、半七は甚右衛門の話で知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊は人生の喜びのありかがやっと判ったような気がした。",
              "citation": {
                "source": "兵隊の死",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけはなたれた窓から、死んだ女が、人間のありかたをといていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
