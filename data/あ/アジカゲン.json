    "definitions": [
      {
        "index": 1,
        "gloss": "taste (of prepared dish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
