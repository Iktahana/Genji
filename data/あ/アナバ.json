[
  {
    "uuid": "c9ebb09a-9569-5045-99ff-b591376634d8",
    "entry": "穴場",
    "reading": {
      "primary": "あなば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
