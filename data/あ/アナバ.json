      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good place not many people know about",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴場について考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴場という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴場の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴場が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴場を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴場について学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴場の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴場の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴場が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴場という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴場という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴場についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴場を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴場は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴場について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴場が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴場は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴場の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴場は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴場は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一、穴場に三、四枚も札がかかると、もう買うのが嫌になる穴買主義者あり、これも亦馬券買いの邪道。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、穴場の入口の開くや否や、傍目もふらず本命へ殺到する群集あり、本命主義の邪道である。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに穴場へ飛びこむ。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから曳馬でも見てまた直ぐ穴場へ入って馬券を買って……。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればその日の競馬場の空気にも馴れ、穴場の人気の形勢や、曳馬の気配などにもよく注意が行き届くようにもなる。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "況して馬券を買ひに行くと皆さん御承知であらうが、穴場へ二十円突込むと混雑せぬやうに、其女事務員が此方の手をば暫時握つて呉れる。",
              "citation": {
                "source": "競馬興行と競馬狂の話",
                "author": "初代　桂小南",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリも、馬券を買って、的中した歓喜を穴場で味わいたくなるのだ。",
              "citation": {
                "source": "俗即菩提",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリも、馬券を買つて、的中した歡喜を穴場で味はひたくなるのだ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣りの穴場を知っている点では、浦粕じゅうでも指折りの船頭といわれ、どんな場合にも、黒鯛を釣りたいという客を鯊の寄り場へ案内する、などということはしなかった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺が釣りの穴場で、いつも釣舟がいるということを、大蝶丸の者なら知っている筈だったから。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの穴場は深えからな」と忠なあこは話を聞いて云った、「とても機械を揚げるこたあ無理だな」　そして大蝶丸のことには触れなかった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんど釣りに来てくんなよ」と長が云った、「おれもいい穴場を知ってるからねえっ」「ああ、ぜひ近いうちに来るよ」私は長の手を握った、「――どう、まだぼくのことを思いだせないか」「さあねえ」長はたよりなげな微笑をうかべた、「わかんねえなあ」「釣りに来るよ」と私は云った。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあなばかりで――はいはい、七十二でございます、いえ、八十二で。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
