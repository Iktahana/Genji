        "examples": {
          "standard": [
            {
              "text": "私は毎日ＡＲＰＡについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＡＲＰＡの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＡＲＰＡが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＡＲＰＡについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＡＲＰＡの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＡＲＰＡが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＡＲＰＡという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＡＲＰＡについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＡＲＰＡは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＡＲＰＡが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＡＲＰＡは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＡＲＰＡの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＲＰＡは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＡＲＰＡは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "エンゲルバードのものをはじめ、さまざまなコンピューターのプロジェクトを支援していたＡＲＰＡ（国防省高等研究計画局）は、一九六七年春、資金を提供しているすべての研究所のマシンをネットワークで結ぶ計画を発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＡＲＰＡＮＥＴ★によって、自らのＮＬＳが距離の壁を乗り越えてしまうことに、彼は知的な衝撃を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★一九六九年に運用が始まったＡＲＰＡＮＥＴは、その後、研究機関を結ぶＣＳＮＥＴ（Computer Science NETwork）などとの接続によって規模を拡大し、インターネットへと発展していく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゲルバード氏がＡＲＰＡＮＥＴ越しに見た夢は、今、大きく花開いている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレックスの開発作業はＡＲＰＡの援助を受けて進められ、ケイは操作用にキーボードは付いているけれど、プログラミングにはパンチカードを使うしかなかったＩＢＭの１１３０というコンピューターで作業を進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じＡＲＰＡをスポンサーとしていた関係で、ダグラス・エンゲルバートにはすでに一九六七年に会っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＲＰＡは研究を後援している大学院生の会議を、定期的に開いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "対話型のシステムの可能性にいち早く注目して、ＡＲＰＡの情報処理部長としてエンゲルバートのＮＬＳを支援したボブ・テイラーは、一九七〇年にゼロックスが新設した、パロアルト研究所の実質的な責任者として招かれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
