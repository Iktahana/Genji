        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカーノについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカーノの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカーノが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカーノについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカーノの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカーノが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカーノという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカーノについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカーノは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカーノが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカーノは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカーノの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカーノは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカーノは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
