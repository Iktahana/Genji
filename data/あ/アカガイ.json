    "definitions": [
      {
        "index": 1,
        "gloss": "blood clam (Scapharca broughtonii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ざくろの花のような色の赤貝の身だの、二本の銀色の地色に竪縞のあるさよりだのに、子供は馴染むようになった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの朝の潮干は八時過ぎからで日暮れの出汐には赤貝の船が帰ってくる。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "介が動物を挟み困しめた記事は例の『戦国策』の鷸蚌の故事もっとも顕われ、其碩の『国姓爺明朝太平記』二の一章に、旅人が乗馬して海人に赤貝を買い取って見る拍子にその貝馬の下顎に咋い付き大いに困らす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "下人祝してお前は長崎丸山の出島屋万六とて女郎屋の一番名高い轡、その轡へ新しい上赤貝の女郎が思い付いて招かぬに独り食い付くと申す前表と悦ばす所あるはこれに拠って作ったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の演劇で蛙の声を聞かせる場合には、赤貝を摺り合せるのが昔からの習であるが、『太功記』十段目の光秀が夕顔棚のこなたより現れ出でた時に、例の小田の蛙が満洲式の家鴨のような声を張上げてぎいぎいと鳴き出したらどうであろう。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（気分をかえて）えー斧足類は蛤に蜆に牡蠣、あさり、あげまき、帆立貝、赤貝、ばか貝。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤貝にばか貝か大変な御馳走だな。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親　おや、赤貝に青柳が出ていないぜ、おい、どうしたんだ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親　赤貝に、青柳に……。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、斧足類の動物と申しますと、蛤だの、蜆だの、あさりだの、それから赤貝やばか貝でございますの。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（気をかえて）しかし、なぜお前が赤貝やばか貝を暗記する必要があるんだ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その盤台のかげの方に大きい蠑螺や赤貝の殻が幾つもころがっているのが、彼の眼についた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人で飲んだり食べたり、興に乗じて山口へドライヴする、周二君を連れて戻る（君は来庵の用意をしてゐた）、酒と赤貝と菓子とのお土産が貰つて、いよ／＼ます／＼豊富である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒鳴る本人すら訳の解らない啖呵を吐き出しながら、顔中を赤貝みたいにむき出して、笑い崩れるロシヤ人のテーブルを泳ぎ廻った。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "螺でも昔と今は角度が幾分相違してゐるようですし、赤貝でも線の數が少し變つてゐるといふようなことが、貝塚の貝殼を調べて見ればわかります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたいてい赤貝の類の貝殼を刳り拔き、その周圍ばかりを殘して前腕にはめ込むでのでありまして、石器時代の墓場から出る人骨に、この貝輪がそのまゝ腕骨にはまつてゐるのをたび／＼發見されました。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "三州仕立ての味噌汁は、ほかに江戸前のこいなど入れて煮込むやり方もあるし、白魚、赤貝などの軽いもので拍子を取る場合もある。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のある一流のすしやが新橋にあるが、あそこの主人が赤貝のひもなど洗っている時、しゃあと手を動かし、「今日は市場にいいのがたった二十しかなかったんだが、いいね、さすがに」なんてひとりよろこびながら洗ってる。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、本場ものの穴子の煮方が旨いとか、赤貝なら検見川の中形赤貝を使うとかで、よしあしはわけもなくわかるが、とにかくまず材料がよくなくては上等寿司には仕上がらない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一つの新傾向は、女の立ち食い、腰掛食いが驚くほど増えて来て、男と同じように「わたしはトロがいい」「いや赤貝だ」「うにだ」と生意気をやって、噴飯させられることしばしばという次第だ。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊わたしの嗜好からいうと赤貝か赤貝のヒモが一等いい。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊あなごに、赤貝は一個十五銭以上のものを食え。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大きな赤貝の殼を拾って、川の方へ力一杯に投げた。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二席は、その猫が一日、赤貝に手を挾まれて困り、カタコトと音立てて挾まれたままで梯子段を上っていくと、二階にいた耳の遠い婆さんが「誰や、下駄履いて二階へ上がるのは」。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして問題の第三席であるが、この猫、妾宅の飼い猫で赤貝の出来事の直後、湯上がりのお妾のふところに抱かれているうちつい滑り落ち、とたんに股間を見上げて、歯をむきだした猫め「フーッ！",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十七年夏）風船あられ　飯蛸、鯖、魴※、白魚、さより、蛤、赤貝、栄螺、分葱、京葱、鶯餅、草餅、茶飯、木の芽――と、かたへのものゝ記には三月のあぢがこんな具合に列ねてある。",
              "citation": {
                "source": "下町歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうっ、姐さん、赤貝の酸を一枚通してくんねえ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぐろのさしみにトマトの輪ぎり、赤貝の酢のものにチキンライスと、こう赤いものづくめでは、共産党の店だしのようではござりませぬか。",
              "citation": {
                "source": "狂言『食道楽』",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、高皇産霊神は、蚶貝媛、蛤貝媛と名のついた、あかがいとはまぐりの二人の貝を、すぐに下界へおくだしになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかがいはさっそく自分のからを削って、それを焼いて黒い粉をこしらえました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
