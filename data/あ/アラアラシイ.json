        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒々しいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒々しいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒々しいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒々しいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒々しいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒々しいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒々しいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒々しいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒々しいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒々しいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒々しいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒々しいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒々しいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒々しいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "家の方では、大勢の荒々しい足音と、罵る叫び声と、破壊の騒音が渦を巻いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒々しい足音が近づいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　騎者の荒々しい声を残して、馬は、丘を横ぎり、ナターリイの前を矢のように走り抜けてしまった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかに捜して宿をとろうか、それとも今の女のところへ帰ってゆこうか、それはいずれにしても私の憎悪に充ちた荒々しい心はこの港の埠頭で尽きていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは思想もなにもないただ荒々しい岩石の重畳する風景だった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、喚き立てる子供達の当て擦りの下卑た荒々しい言葉が、あの緊密相な男の子の神経にかなり深刻に響いて、彼をいかに焦立たせるかとはらはらして堪らない気もした。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　荒々しい調子で彼の詞を打消しつゝ通りすぎたものがあつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その坊っちゃんが自分を好いていてくれたのかと、お雪は幹男の荒々しい動作を、自分への愛情のはげしさだと、その時ふと思ったくらい、愚かな弱い女だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は現実の世界に在る太陽や、草木や、土や風なぞいうものが、空想の世界にあらわれる太陽や草木風景なぞよりも遥かに単調子な、平凡な、荒々しいものであることを知り過ぎる位知っていた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、墓地の幽霊などに対する恐怖ではなく、神社の杉木立で白衣の御神体に逢った時に感ずるかも知れないような、四の五の言わさぬ古代の荒々しい恐怖感でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その野蛮な荒々しい響からして、急に室内の空気が振動した。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、喚き立てる子供達の当て擦りの下卑た荒々しい言葉が、あの緊密｜相な男の子の神経にかなり深刻に響いて、彼をいかに焦立たせるかとはらはらして堪らない気もした。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこの荒々しい水のすさびに根ざして、七色の虹の、常なき姿が、まあ、美しく空に横わっていること。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獣の荒々しい呼吸づかいさえ感じて総毛立った。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈江は、そんなにも迫った男の感情ってあるものかしらん、今にも堂島の荒々しい熱情が自分の身体に襲いかかって来るような気がした。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　北山は自分でも不思議なくらい荒々しい力で、いきなりカラ子の肩を掴んだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥のゐるのを見て俄かに荒々しい調子をやはらげて、「清水さんがゐたんですか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、荒々しい悲しみに似たものが、ふつと、心の底から湧上つて來るやうであつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、荒々しい悲しみに似たものが、ふっと、心の底から湧上って来るようであった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛政は荒々しい声で、拝郷等は何故に敵を防がぬかと叱ったので、五左衛門尉｜嘲笑って、御覧候え、我々が身辺、半町ほどは敵一人も近付け申さず。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長は気象の荒々しい性急な乱世的英雄で、彼の活躍は実に目覚しかつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その荒々しい毒々しい行ひが彼の神経を尖らしてしまつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い荒々しい土は、すぐにも以前に還ろうとするのだった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年が重い鉄門を開けかねていると、博士の荒々しい怒鳴り声が聞こえ、怒って握り拳を振り回しているのも見えた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と荒々しい声がうなる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒々しい自然と対峙することに馴れていない者には、ひるんでしまうほどの道のりだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがかたくなに荒々しいなかに、なぜこの実ばかりが天使のやうにけがれなく、優しいのか。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の違つたやうな、荒々しい叫声である。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとたんにお嬢さんが、荒々しい叫声を出したのであつた。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、「ふうっ」と、動物はあらあらしい声をたてて、座ぶとんからはねあがった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
