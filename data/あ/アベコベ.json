        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あべこべについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あべこべという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあべこべの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあべこべが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あべこべを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあべこべについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あべこべの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあべこべの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあべこべが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あべこべという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあべこべという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあべこべについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あべこべを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあべこべは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あべこべについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあべこべが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあべこべは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあべこべの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あべこべは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあべこべは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "な、お前がいくら頑張ったって、船長も云ったように、一億円の船会社にゃ、勝てっこないんだから」　セコンドメイトは、デッキの上と橋板の上とでは、レコードの両面見たいに、あべこべの事を云い始めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はすべての印象を反対に、磁石のあべこべの地位で眺め、上下四方前後左右の逆転した、第四次元の別の宇宙（景色の裏側）を見たのであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉はあべこべに云いまくられて、そのくやしまぎれに、お前が禁断のむらさき鯉を売り込んで、荒っぽい銭儲けをしているということを俺が一と言しゃべったら、ここの家にぺんぺん草が生えるだろうとか何とか嚇し文句をならべて立ち去っても、宇三郎はおどろかない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、お香、いつぞや巡査がおまえをくれろと申し込んで来たときに、おれさえアイと合点すりゃ、あべこべに人をうらやましがらせてやられるところよ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の目的といえばもともと自然から学ぶということよりほかには何物もないはずであるのに、いつのまにかこの事を忘れ思い上がった末には、あべこべに人間が自然を教えでもするもののような錯覚を起こす。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純朴な田舎の人たちに都会の成金どもがやたらに札びらを切って見せて堕落させたなんて言うけれども、それは、あべこべでしょう。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻も早く修理したくて、まだ空襲警報が解除されていないのに、油紙を切って、こわれた跡に張りつけましたが、汚い裏側のほうを外に向け、きれいなほうを内に向けて張ったので、妻は顔をしかめて、あたしがあとで致しますのに、あべこべですよ、それは、と言いました。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ清々した」　中腰になって浮かれ立つ赤猪口兵衛の顔を茫然と見上げている半三郎の顔を、あべこべに見下しながらヤット腰を卸した赤猪口兵衛は、汚ない膝小僧を一層大きく剥き出しながら詰寄った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の哲学者が一言二言いったというだけで人間全体が別種の存在に変わって人間界の方則があべこべになるということは想像ができない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これとあべこべに葛飾が犯人である場合も同様だ。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるであべこべね……」　そう云ってＡの細君が笑った。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの、僕の計画では、二人の媾曳を、まざまざと兄さんに見せつけてやるつもりだったのだが、僕はあべこべ兄さんに対して密夫らしい要心をしはじめた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の素晴しい嘘で人を担いだ話や、またはそのあべこべのしくじり話やらをめいめいが語った。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、その人の目は、なにもかもあべこべに見たり、でなければ、物のわるいところばかりを、見てしまうようになるのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな鞄はあべこべにつまらないものばかり詰められて、荷車に積まれたり投げ飛ばされたりしておりました。",
              "citation": {
                "source": "二つの鞄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、お上では格別に驚かれた様子も無いばかりか、あべこべに拾った人間をお叱りになって、「おのれ。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかく見世物の鹿や猪を見つけたかと思うと、あべこべにこっちが見世物にされそうになって、危いところをやっと助かった」　と豚吉が云いますと、ヒョロ子もほっとため息をして、「無茶先生が待っていらっしゃるでしょう」　と云いました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生はヒョロ子に止められるとあべこべにビックリした顔をして、振り上げた金槌を下しながら怖い顔をして云いました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは方角があべこべだ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（丁度西洋と日本では、山と谷があべこべに逆転している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩は音律を重視すべきであると言って、あべこべに僕を説教してくる類いである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たん嘆き始めると、何もかもあべこべな二人の運命に気がついて、果てしもなしに悲しくなつた。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は此のカテリイヌのなかにもおみちを探そうとしてあべこべの違った魅力で射すくめられた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　リサは今しがた新吉に意見したのとはあべこべなことを平気で言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、あべこべでございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それはあべこべで、地味な普段着も何も焼いてしまって、こんな十六、七の頃に着た着物しか残っていないので、仕方なく着ているのだわ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃ、あべこべに男のほうからお助けを乞わなくちゃいけねえ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんこんと諷諫どころか、その大宴会から七日すぎて、十一月の十四日に、こんどはあべこべに相州さまが将軍家にそれこそ本当にこんこんと教へさとされたのでございますから、妙なものでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがしの親戚などは、あべこべにそれがしの懐をねらっているのだから、つまらない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと私たちとは、まるで考へかたが、あべこべなんですもの。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
