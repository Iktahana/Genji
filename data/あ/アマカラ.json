        "examples": {
          "standard": [
            {
              "text": "私は毎日甘辛について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘辛という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘辛の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘辛が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘辛を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘辛について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘辛の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘辛の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘辛が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘辛という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘辛という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘辛についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘辛を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘辛は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘辛について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘辛が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘辛は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘辛の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘辛は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘辛は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "甘辛い樹皮の香りに魂を奪はれた彼等は、シヤベルや箆を携へては朝となく夕べとなく来襲した。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あしもとの地面は、あちこちと土がはね返され、傷つけられた樹根の皮が生々しくむき出されて、甘辛い刺戟の香がつん／＼と鼻先を突いた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、山の蕨が膳に上る季節でありながら、それを甘辛に煮つけてしまつたでは、折角の新鮮な山の物の風味に乏しい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大好きですがどうも胡麻をかけただけでは物足りないので一工夫して、挽肉を味噌、醤油、砂糖で甘辛くどろりと煮て胡麻などの代りにかけていただきます。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘辛い鮮かな味はするけれど、気味は悪い。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘辛い油揚げの中にいっぱいつまった飯、じとじと汁がたれそうなかんぴょうの帯。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に最も手のこんだのをソップだきと云って、一日がかりで甘辛の味のついたソップをつくり、これに獣魚、野菜をぶちこんで食う。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万円の自動車を飛ばし、金にあかして多数の犬を弄んだという金持の文士が、民衆を標榜して打って出でると、それに五千の投票が集まるという、甘辛せんべいみたような帝都の人気を、苦笑しているわけでもないのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、甘辛く味付けして煮て食べるのもよい。",
              "citation": {
                "source": "鮑の水貝",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "原田の買って来た甘辛煎餅をばり／＼やりながら、運動場の芝生に臥転んで、杉が真面目にこんな事を云い出した。",
              "citation": {
                "source": "The Affair of Two Watches",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよう、いま申したとおりです」　道益は、思わずというふうに手で膝を打って、「さてもさても、我が子ながら、なんという智慧｜長けたやつであろう」　痛し痒しの甘辛面で感嘆の声をあげると、道長は自分のことをほめられたのかと思い、いや、それほどでもない、と得意そうに笑った。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ノコキレ」細く壓花の如く、色黄にして味甘辛なりと云。",
              "citation": {
                "source": "他計甚※（竹島）雜誌",
                "author": "松浦武四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、安々とたやすく快楽が享けられるために、彼らは我々のようにその甘辛い刺激が味わえないからである」と。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "食はせるものは、焼きとりの色々で、皮やき、だんご、五味やき、ミンチ等で、僕にはタレも甘辛くていゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに甘い、東京のは甘辛いのだが、こっちのは甘いだけだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
