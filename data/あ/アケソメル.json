          "standard": [
            {
              "text": "明け初めるの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夜が明け初めると間もなくその日は晴れ渡るであろう。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が白々と明け初めるのを待つて、駒平と駿介は急いで身支度をした。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、夜の明け初めるころになって彼には何んとも分らぬことに出会ってしまった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙高山　信越線の列車に乗って、上野駅を午後十一時過に出発すれば、短い夏の夜は牟礼柏原の間で明け初める。",
              "citation": {
                "source": "那須、尾瀬、赤城、志賀高原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝四時うっすらと明け初めると共に直ぐに道を捜し、道の導くままに西黒沢へと下って行った。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "牟礼柏原の間で夜が明け初める。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がほのぼのと明け初める頃、捕方や追手も、あきらめて白鬚の方へ引揚げてしまいます。",
              "citation": {
                "source": "十字架観音",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
