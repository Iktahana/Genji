        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日亜熱帯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は亜熱帯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には亜熱帯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは亜熱帯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は亜熱帯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では亜熱帯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に亜熱帯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では亜熱帯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると亜熱帯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では亜熱帯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に亜熱帯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により亜熱帯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "亜熱帯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に亜熱帯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "現在の日本はカラフト国境から台湾まで連なる島環の上にあって亜熱帯から亜寒帯に近いあらゆる気候風土を包含している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、亜熱帯のそれは何かしら熱気が深く籠っていて、これほどの冷えびえとした舌触りは無かったような気がする。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜熱帯の此処（ニュー・カレドニア）でさえ、私は直ぐに風邪を引く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第２図　支那四川産橙色仰鼻猴　猴はなかなか多種だが熱帯と亜熱帯地本位のもの故、欧州にはただ※爾たるジブラルタルにアフリカに多いマカクス・イヌウスとて日本猴に酷似しながら全く尾のない猴が住んでいたが、十年ほど前流行病で全滅した。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる三大宗教はみな亜熱帯に生まれたのである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "北種は元来、住みよい熱帯や亜熱帯から追い出された劣等種であったろうが、逆境と寒冷な風土に鍛錬されて、自然に科学的方面の発達を来たした。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し漢民族は南種と言っても黄河沿岸はもちろんのこと、揚子江沿岸でも亜熱帯とは言われず、ヒマラヤ以南の南種に比べては、多分に北種に近い性格をもっている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "榕樹、ビンギ、梯梧、福樹などの亜熱帯植物が亭々と聳え、鬱蒼と茂り合った蔭に群った一部落。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そこからは一歩一歩がたかく、それまで栴檀のあいだに麝香鹿があそんでいた亜熱帯雲南が、一変して冬となる。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱帯と亜熱帯とに亘る本島の炎暑も、さほどのものではない。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭は悉く亜熱帯の密林で、椿、夾竹桃、コルク槲、などにまじって、ミモサの花の香が、リヴィエラの春を憶わせた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立は亜熱帯の常緑樹で、ツェラスス、ラウロセラススのなめらかな緑にまじる、マグノリヤの裏葉が美しかった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日みたし切れないむねを持てあましていた平靖号の船員たちも、異色ある亜熱帯地方の風物が、両岸のうえにながめられるようになって、すこしばかし、なぐさめられた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱然たる亜熱帯の沼沢地。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の上にも下にも明治初年ごろのヨーロッパ各国人の居留館が、熱帯・亜熱帯植物の植え込みに囲まれ、もう年代も経ったこととて、塗料もはげたり、さびたりして、しっとり落ち着いて、窓に赤い熱帯らんの花がおいてあったりする。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜熱帯の気候で、水田米作には絶好の地理的条件にあるので、別に不思議なことではない。",
              "citation": {
                "source": "救国論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……汽笛の音をきいてたら、どこか遠いところへ行きたくなってんの」　久我は葵のそばへ椅子をひいてきて掛けながら、「……（風には竜眼の香り、雲にはペタコのこえ、酷熱のいいようなき楽しさ）……僕はもういちど亜熱帯で暮したい。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜熱帯の無風季節は、太陽の直射と、湿気の多い空気とのために、戸外では呼吸をするのも苦しいくらゐである。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　むせるような亜熱帯の花の香りは、あからさまに言えば、彼の胸にきざしている井出夫人へのやみがたい恋情のひとつのかたちなのであるが、彼自身は、そんなことは意識してはいない。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "』一七　綿『織物に使はれる物の中で一番大切な綿は、亜熱帯の棉の木と云ふ植物から採るのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、亜熱帯地方で、冬でも東京の春ぐらい温かく、真夏になると日の光や熱はなかなか烈しく、温度は摂氏三十余度に達します。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや亜熱帯の気候を想う時、如何に琉装が生活に適う合理的なものであるかを信じないわけにゆかないのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と女は言つた亜熱帯なんだが、僕の女よ、眼の前に見える亜熱帯が見えないのか！",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僕のやうに、日本語の通じる日本人が、即ち亜熱帯に生れた僕らなんだと僕はおもふんだが、酋長だの土人だの唐手だの泡盛だの、同義語でも眺めるかのやうに、世間の偏見達が眺めるあの僕の国か！",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は真紅で、無数の花を綴って総状になって咲くのであるが、亜熱帯のコバルト色の空のなかに、燃える焔を高くかざしたように咲いているのは、なんとも言えない美しさで、沖縄では情熱の象徴として珍重されている花なのだ。",
              "citation": {
                "source": "梯梧の花",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその時頭上の高台に二つの人影が、澄みきつた亜熱帯の夕日を背にして、うかびあがつた……人影は、ホンの一瞬、怪しくないはずの人間でもなんだか怪しく思えそうな姿勢でいた。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚和のような北辺と違って、亜熱帯の風物は華麗で、まるで燃え上っているように見えた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "棕櫚、竹、その他明らかに亜熱帯性のものもある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
