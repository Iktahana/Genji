        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "虻について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この虻は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "虻の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が虻について知っています。",
              "source": "幻辞"
            },
            {
              "text": "虻は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は虻の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "虻に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では虻が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から虻を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "虻の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも虻が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では虻が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "虻について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも虻は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも虻は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で虻は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に虻について学びました。",
              "source": "幻辞"
            },
            {
              "text": "虻の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する虻の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では虻の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "槓杆の効用は人の知る通り、昔の力学者が「適当な支点を与えてくれれば地球もころがして見せる」と威張ったのは槓杆の効能を極端に云ったものである、だから適当な槓杆と支点を与えれば虻の力で大象も動く、美人の繊手で横綱も釣上げられる。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏近くなって庭の古木は青葉を一せいにつけ、池を埋めた渚の残り石から、いちはつやつつじの花が虻を呼んでいる。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開けて仰ぐと、溪の空は虻や蜂の光点が忙しく飛び交っている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻や蜂があんなにも溌剌と飛び廻っている外気のなかへも決して飛び立とうとはせず、なぜか病人である私を模ねている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの飛んで行った方角には日光に撒かれた虻の光点が忙しく行き交うていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺り覚まされた虻が茫漠とした堯の過去へ飛び去った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻の声は天地の活気を語り、風の温く軟きが袂軽き衣を吹き皺めて、人々の魂魄を快き睡りの郷に誘はんとする時にだも、此花を見れば我が心は天にもつかず地にもつかぬ空に漂ひて、物を思ふにも無く思はぬにも無き境に遊ぶなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の説として美濃では「ギバは白虻のような、目にも見えない虫だという説がある、また常陸ではその虫を大津虫と呼んでいる。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそばで新聞を読んでいると大きな虻が一匹飛んで来てこの花の中へもぐり込む。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、虻が蜜汁をあさってしまって、後ろ向きにはい出そうとするときに、虻の尻がちょうどおしべの束の内向きに曲がった先端の彎曲部に引っかかり、従って存分に花粉をべたべたと押しつけられる。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし弱い弾性しか持たぬおしべは虻の努力に押しのけられて、虻の尻がその囲みを破って、少し外方に進出するとそこにちゃんとめしべの柱頭が待ち構えていたかのように控えているのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな重大な役目を他人のために勤めたとは夢にも知らない虻は、ただ自分の刻下の生活の営みに汲々として、また次の花を求めては移って行くのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「落ちざまに虻を伏せたる椿かな」漱石先生の句である。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもし虻が花の蕊の上にしがみついてそのままに落下すると、虫のために全体の重心がいくらか移動しその結果はいくらかでも上記の反転作用を減ずるようになるであろうと想像される。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち虻を伏せやすくなるのである。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな虻だのべっ甲いろのすきとほった羽虫だのみんなかはるがはる来て挨拶して行くのでした。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だろうとそこいらを見まわしますと、そこの白壁によせかけてあったサイダーの瓶に一匹の虻が落ち込んで、ブルンブルンと狂いまわりながら、「ドウゾ助けて下さい。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエ子さんはすぐに走って行ってその瓶を取り上げて、口のところからのぞきながら、「虻さん虻さん、どうしたの」　と言いました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻は狂いまわってビンのガラスのアッチコッチへぶつかりながら、「どうしてか、落ち込みましたところが、出て行かれなくなりました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虻さん、お前はバカだねえ。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスがあるから」　と言いましたが、虻はもう夢中になって、「どこですか、どこですか」　と狂いまわるばかりです。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエ子さんは虻が可哀そうになりました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして助けてやりたいと思って、そこいらに落ちていた棒切れを拾って上から突込んで上の方へ追いやろうとしましたが、虻はどうしても上の方へ来ません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から息を吹きこんだり、瓶をさかさまにして打ちふったりしましたが、虻はなかなか口の方へ来ません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのコップに水を入れて麦わらで吸い取って、虻がジッとしているときにすこしずつ瓶の中に吹き込んでやりますと、虻は水がこわいので段々上の方へやって来ました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエ子さんは喜んでもう一いき水を吹いてみますと、どうしたものか虻は又あわて出してブルブルと飛ぶ拍子に水の中へ落ち込んでしまいました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つてセンチメンタリズムに堕することからあぶない所で脱かれてゐる。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　においが有るか無いか、立ちどまって、ちょっと静かにしていたら、においより先に、あぶの羽音が聞えて来た。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　にほひが有るか無いか、立ちどまつて、ちよつと靜かにしてゐたら、にほひより先に、あぶの羽音が聞えて來た。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶない事はありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
