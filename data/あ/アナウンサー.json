        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナウンサーについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナウンサーの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナウンサーが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナウンサーについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナウンサーの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナウンサーが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナウンサーという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナウンサーについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナウンサーは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナウンサーが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナウンサーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナウンサーの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサーは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナウンサーは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、アナウンサーの紹介を聴いたとたん、私は思わず涙を落しました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一昨日「エロチシズムと文学」という題で朝っぱらから放送したが、その時私を紹介したアナウンサーは妙齢の乙女で、「只今よりエロチ……」と言いかけて私を見ると、耳の附根まで赧くなった。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多い話だが、玉音は録音の技術がわるくて、拝聴するのが困難であったが、アナウンサーのニュースを聞いているうちに、「あッ、戦争が終ったのだ！",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの放送では、むしろ観客群集のほうが精神的に主要な放送者であって、アナウンサーのほうは機械的な伴奏者だというような気もするのである。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ拡声器からガヤガヤという騒音が流れだしている中に交じって早口にせき込んでしゃべっているアナウンサーの声が聞こえるだけであった。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹園のアナウンサー　果樹園に大きな望楼が立つてゐた、この望楼は、果樹園の所有者が建てたもので、この国でいちばん声のきれいな、声の高い男が選ばれて、沢山の給料をもらつて、雨の日も風の日も、この望楼の上に立つてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかの曲にかぶせて、アナウンサーの紹介が入る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "活発な声だ、とたんに爆発するようなアナウンサーの声。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "拡声器からは、声なじみの中内アナウンサーの声が一句一句強くハッキリと流れてくる……。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレンの唸、ラジオの拡声器から流れてくるアナウンサーの声。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今警報が発せられる模様であります……」　昨日から、中内アナウンサーは、おおわらわの奮闘だった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百万の市民は、このなじみ深いアナウンサーが、いま何を告げようとするのかと、胸おどらせながら、拡声器の前に集ってきた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロホンの前で、中内アナウンサーは、命令遅しと待つほどもなく、香取司令官は手をあげた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アナウンサーは、司令官の命令を復誦した。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちついて放送せよ」　アナウンサーは大きくうなずいて、マイクロホンに向かって唾をのんだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "受話器から出てくる声は小さいが、まぎれもなく、なじみ深い中内アナウンサーの声……。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信機のスイッチをひねって置けば、この辺でラジオ体操が始まり、江木アナウンサーのおじさんが銅羅声をはりあげて起してくれるのだが――彼、梅野十伍はいつもそうしている。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアナウンスもやがてぷっつりと切れ、暗黒なエーテルの漂う夜空からは、内地の放送局が一つ一つお休みなさいを云って電波を消してゆき、あとには唯一つ、南京放送局の婦人アナウンサーが哀調を帯びた異国語で何かしら悠くりと喋っている声だけが残っていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ体操のアナウンサーの声とともに起き、夜の気象通報とともに睡るような多くのＴ市民たちには全く分らない別の世界なのだ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感情が普遍的だということは、ラジオが一九四七年度のハイライトで水泳の古橋選手を紹介するとき、アナウンサーは古橋選手のレコードで日本もやっと国際的な一つの窓をあけられたように明るくなった、と語った。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし街頭録音はアナウンサーの指導や暗示や整理によって発言の総和が特定の方向にまとめられる弊害が顕著である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "街頭録音の場合アナウンサーが自分の見解によって発言者の言葉を中断したり、カットしたり、モンタージュしたりすることは事実上一種の言論統制であるとして注意を促した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この討論会においてアナウンサーが自分の感情と見解から思いついた質問を羽仁五郎に向って与え、アナウンサーとしての義務の範囲を超えた態度を示したことも注目された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビ画面は切り替わり、アナウンサーはその日、地震に対する大規模な総合演習が行われたことを告げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯切れのいゝアナウンサーのニュースが流れて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナウンサーです。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイッチを入れなさい」　スイッチが入って、ドイツ放送局のアナウンサーの声が高声器から流れだした。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し早過ぎたな、と思つてゐたが、アナウンサーが出て来ない。",
              "citation": {
                "source": "文芸雑談",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、アナウンサーが飛んできて、失礼しましたといつて、済んだといふことを放送したのです。",
              "citation": {
                "source": "文芸雑談",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
