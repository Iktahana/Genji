        "examples": {
          "standard": [
            {
              "text": "私は毎日阿母について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿母という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿母の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿母が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿母を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿母について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿母の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿母の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿母が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿母という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿母という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿母についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿母を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿母は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿母について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿母が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿母は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿母の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿母は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿母は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "阿母さん良さんにお帰へりを願つて下さい。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢は何をおつしやいます今まで彼れ程お待遊ばしたのに又そんなことをヱお心持がおわるひのならお薬をめしあがれ阿母さまですか阿母さまはうしろに。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、阿母さん」　女の児はなにを見たか、母の袂をひいて急に立ちすくんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿母さん、こればかりは堪忍してください」と、歌女代は泣いてことわった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は倒れるまで働いて、きっと阿母さんに不自由はさせまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみよは今年十八で、おちかという阿母と二人で、この裏長屋にしもたや暮しをしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋といっても、寄付きをあわせて四間ほどの小綺麗な家で、ことに阿母は近所でも評判の綺麗好きというので、格子などはいつもぴかぴか光っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の戸には錠をおろして行ったので、誰も内を覗いて見る人もなかったが、それからあしかけ四日目に阿母が一人で帰って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に不思議なことは、おみよは阿母と一緒に家を出た時と同じ服装をしているにも拘らず、その麻の葉の帯が見えなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子もおとなしく稼ぐようだから阿母もまあ、安心だ」「いえ、実はそのお蝶のことに就きまして、今晩お邪魔にあがりましたのでございますが、どうもわたくし共にも思案に余りましてね」　四十女のひたいの皺をみて、半七は大抵想像がついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶坊が何かこしらえて、阿母に世話を焼かせるというわけだね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿母だって覚えがあるだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しいことは阿母さんに話してあるから、おまえも家へ一度帰ってよく相談をして来いと、お蝶はかの女から云い聞かされて来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿母さん、わたくしのような者でもお役に立つなら、どうぞそのお国へやってください」「え。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから又話が進んで来て、いっそ阿母も一緒に行ったらどうだということになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が学校で要る教科書が買えなかったので、親仁が思切って、阿母の記念の錦絵を、古本屋に売ったのを、平さんが買戻して、蔵っといてくれた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、阿母のような返事をする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一人の子が、群集の中から阿母の顔を見つけて、急に恋しくなって泣き出した。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一近い処が、今内に居る、松やの阿母だといって、この間隣村から尋ねて来た、それも年より。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の力と權威を以て、見事に此の女祕藏し見すべし、再び是を阿母の胎内に戻すことこそ叶はずとも、などか其の術のなからんや、いで立處に驗を見せう。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――着物は、茶の勝つた、同じやうな柄なのを着て、阿母のおかはりに持つた、老人じみた信玄袋を提げた、朱鷺色の襦袢の蹴出しの、内端ながら、媚めかしい。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九にはなるまい新姐を前に、一足さがつて、櫛卷にした阿母がついて、此の店へ入りかけた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と櫛卷の阿母が衝と寄つた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――はッというので、近常さん、（阿母喜んで下さい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お媼さんは、七輪の焚落しを持っていらっしゃる、こちらへと、使者を火鉢に坐らせて、近常さんが向直って、（阿母、一番鶏が鳴きました。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　その妹だね、可いかい、私の阿母が、振袖の年頃を、困る処へ附込んで、小金を溜めた按摩めが、ちとばかりの貸を枷に、妾にしよう、と追い廻わす。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　主人は大胡座で、落着澄まし、「吝なことをお言いなさんな、お民さん、阿母は行火だというのに、押入には葛籠へ入って、まだ蚊帳があるという騒ぎだ。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けても、的はないのに、夜中一時二時までも、友達の許へ、苦い時の相談の手紙なんか書きながら、わきで寝返りなさるから、阿母さん、蚊が居ますかって聞くんです。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ちっと居るようだの、と何でもないように、言われるんだけれども、なぜ阿母には居るだろうと、口惜いくらいでね。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあぼちぼち行けといふほどの心持である。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
