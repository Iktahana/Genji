    "definitions": [
      {
        "index": 1,
        "gloss": "senior group member",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄貴分について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄貴分の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄貴分が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄貴分について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄貴分の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄貴分が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄貴分という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄貴分についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄貴分は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄貴分が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄貴分は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄貴分の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄貴分は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄貴分は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いわば私の兄貴分の作家である。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ兄貴分になろうおもたら、刺青にものを言わすのが一番やぜ」「いやだす、いやだす」「わいもいやや」　次郎と三郎は口をそろえて言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、伊藤の兄貴分なのだね。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の兄貴分の大惣ナンチいう奴は棺の中でお経を聞きながらビックリして、ウウ――ンと声を揚げて助かりました位で……イエイエ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあパーソナルコンピューターの世界では、小型化をめぐってこんな時間が流れたが、この余波がワークステーションと呼ばれる一段上の処理能力を持つ兄貴分にも及ぶことは時間の問題だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、あっしが兄貴分の役得で、乗られるんですね」「のぼせんな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば私の兄貴分で、そうして同じように里の頭で、そうして同じようにあるお方に、おつかえしたことがございましたよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかひょうひょうとしながら一匹狼の踏ん切りを腹にためた後藤富雄を兄貴分として、ソフトウエアの土岐泰之、ハードウエアの加藤明を核に配した日本電気の開発チームに、古川はＷＣＣＦで出会った人々に覚えたのと同様の近しさを感じるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "感化院を出がけに兄貴分から注意されて来た牛太郎という女郎屋の改札｜掛はコイツらしい。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹口は好人物の変り者という評判であったが、兄貴分だけに戸若を色々と世話して、着物や金を与えた事が度々であった。",
              "citation": {
                "source": "衝突心理",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょんな事から、元は家来で、今は兄貴分の弁公が、親分を縮尻ると、彼ばかり、もとの土地に居残っているわけにも行かなかった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲よりも兄貴分だと判った乙は、そこの茶代は勿論、それから旅館に連れて行って一切の費用も出してやるし、又土地の者をそこに三日間招待してその費用も乙が負担せねばならぬ。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代日本の演劇は、映画の兄貴分たる資格をもつてゐない。",
              "citation": {
                "source": "「現代演劇論」はしがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じやうによろけてゐる間瀬を兄貴分の花村が押へて、落合さん、俺は君が好きなんだ。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴分の法蓮房は影が薄くなった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "学識は南陽房の兄貴分だという。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのごろのヤミ相場では、いくらもうけても食うに追われ、兄貴分に上前をはねられ、商売のなかった仲間に食物を買って分けてやったりすれば、懐に金のたまらぬことは、これまた本人たちのほうが経験を通してよく承知している。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハハ　ビヨウキ　カエレ」　彼は別れを惜しんでくれる大勢の兄貴分たちを船に残して、暗い思いで大阪駅から汽車に乗った。",
              "citation": {
                "source": "秋空晴れて",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今日は、おいらの兄貴分の、黒門町の伝七がうちへ来合わせていたのを幸い、一緒に来てもらったんだからなア」「えッ。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝次　弥造は俺の兄貴分だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧次　弥造は俺の兄貴分だ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年配ではあるが、金五郎が、兄貴分である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、うちの旦那はんの兄貴分のひとが、来やはる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "早よ、いわんか」「大将の兄貴分の玉井金五郎さんのところへ、江崎満吉一家のなぐりこみじゃ」「なにや？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀家ぽんたんが、一月三十円のみいりではとてもやりきれないので、場末の小屋で稼ごうと兄貴分の鶴家あんぽんに言うと、格が下るから駄目だと「兄貴」が承知しないで、困っているという話は前に書いたが、そんなことが原因してか、やがて二人は「夫婦別れ」をしてしまった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫才では先輩のぽんたんが、齢は下でも兎家ひょうたんこと末弘春吉の兄貴分になった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「就職問題とは違いますから、少し目鼻のつくまでは誰にも秘密にして置く方が宜うございますよ」「それは分っていますけれど、瀬戸君は兄貴分ですから、相談して見たんです。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問才気共に兄貴分の土佐犬は怖かったけれど、北海道の馬は元来甘く見ている。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矮虎、いい加減にしろ」　叱ったのは兄貴分の燕順である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
