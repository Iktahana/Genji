        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗中模索について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗中模索の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗中模索が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗中模索について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗中模索の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗中模索が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗中模索という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗中模索についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗中模索は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗中模索が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗中模索は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗中模索の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗中模索は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗中模索は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "扨その原因を、暗中模索の揚句、社会問題に持つて行つて、其処で解決を得られると思ふ人も相当あるけれども、私にはさうは思はれぬ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、右のことが分つたので歓喜にむせぶ気持でゐるが、又一方、長年求めあぐんで、暗中模索してゐたものが、一時に分つたので、慄へてもゐるといつた状態である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今日私は過去五年間の暗中模索、傷ましき躁宴の後に、聊か芸術の泉なるものが依て以て存する所以に想ひ到つた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、かうした交声曲詩篇の創作は、自身にとつて最初のものであり、日本に於て、その範例を見ることを得なかつたので、眼が見えぬ上に、全くの暗中模索であつた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展第六回の『斜陽』といふ作品は氏の素描が直ぐ絵の完成された表皮に浮びあがり生かされてゐるといふ意味で、いかにも軟らかい仕事なのである、しかしこの作品は、他の山水風景に較べて柔軟に自由に描かれてはゐるが、却つて暗中模索的な、懐疑的な作品なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ここで係長の暗中模索に、やがてひとつの光が与えられた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂経験などをいくら重ねても、それは少しも役に立たずに相変らず暗中模索をやつてゐるもののひとりであつた。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ、新聞は再び警察を攻撃したので、警察や探偵たちは躍起となって活動したが、犯罪の動機がよくわからないために、全く暗中模索の有様であった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が再たび起ち上つてくるまでには、なほ長い暗中模索の時が必要とされたのである。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず手近な翻訳から始めて、暗中模索的に文学によって飯を食う方法を講じようとしてみた。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今までも個人々々の努力である程度の研究もでき、専門の領域で相当の技倆見識をもつやうになれないこともなかつたのだが、そのためには非常な不便が伴ひ、暗中模索の時期が長く、時としては邪道に迷ひ込み、独りよがりに終ることがないとはいへないのである。",
              "citation": {
                "source": "明治大学文芸科に演劇映画科を新設する件",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり自由の魔の手にかかったので、暗中模索、これは迷路だ。",
              "citation": {
                "source": "俗物性と作家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、僕のところなんかでもう解決してしまつてる問題を、暗中模索してゐたり、十年も前に公表されたある研究の結果が、得々と今頃、迂遠な実験で論証されたりしてゐるんです。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは暗中模索であったがどうやら五回目ぐらいから、新しい型を自得するところがあった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、暗中模索でごそごそと永年探って来たのですが、最初のうちはとても困ったものでした。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "388　　　１．社會一般が去就に迷ひ暗中模索をしてゐる状態、築き上げてはまたぶち壞し、出來上つたと思ふと消え行くあはたゞしさ、何等後に殘る成果もないのに無暗に前進したがる傾向――これこそ、明かに現代の姿である。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえにいろいろの学者が単に想像を逞しくして暗中模索をやっているにすぎない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがあれば暗中模索の俺の活動もまた非常に楽になるし、ドーブレクに関係合って無駄骨を折るか折らぬかの見当がつくんだ！",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが皆暗中模索の体為、いくら考えてもまとまりが付かなかった。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が今日まで黒暗々裡に、暗中模索に捕われていた迷宮に、忽焉として一道の光明が現れたのを覚えた。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "依頼心というでもなく、ふと暗中模索する気もちが、ぼくを闇夜へ追い出していたのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　逃走の暗中模索　次のことをよく理解せんには、ドロア・ムュール街の正確な観念を得ておかなければならない、そして特に、ポロンソー街からドロア・ムュール街へはいってゆく左手の角をよく知っておかなければならない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでゆくことのうちには暗中模索の動作がある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
