    "definitions": [
      {
        "index": 1,
        "gloss": "bright red",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の朝も赤し唐辛子　暴風雨の朝、畠の作物も吹き荒され、万目荒寥として枯れた中に、ひとり唐辛子の実だけが赤々として、昨日に変らず色づいているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が赤々と燃えて来る時、人々の身体は暖まり、自然に眠りが催してきた。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちあの蕭条たる自然の中で、たよりなき生の孤独にふるへながら、赤々と燃える焚火の前に、幼時の追懐をまどろみながら、母の懐中を恋するところの情緒である。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし旭日章旗のような光線の放射でなく、大きな火の玉というよりも、全身｜爛焼の火山その物のように、赤々と浮び上った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏刈って、うず高く積重ねておいた乾草が焼かれて、炎が夕ぐれの空を赤々と焦がしていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤々燃える谷のいろ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面の上にはトマトの茂りがあつて、採り殘された實の熟したのが、こゝに一つかしこに一つ、赤々と小さな色を殘してゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその後には大抵赤々とした夕日が殘る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の眉は自から顰んで、紅絹の切で、赤々と押えた目の縁も潤んだ様子。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに、おみき所と言ふのに、三寶を供へ、樽を据ゑ、緋の毛氈に青竹の埒、高張提灯、弓張をおし重ねて、積上げたほど赤々と、暑くたつて構はない。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから赤々と輝く暁の光は、ふたたび訪れてくるであろう幸運の太陽の福音のように思われたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんろでは、火が赤々と、燃えていました。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、胸の上をも、赤々と照らしだしました。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は唇さえ熱く赤々と感じられて来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲から投出したような遣放しの空地に、西へ廻った日の赤々と射す中に、大根の葉のかなたこなたに青々と伸びたを視めて、「さて世はめでたい、豊年の秋じゃ、つまみ菜もこれ太根になったよ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで山車を休まして、一同は赤々と日が暮れるまで盛んに酔つぱらつて踊つたり唄つたりする。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてゴツホの燬きつくやうな太陽が東にあがり西に赤々とくるめき廻る真ん中で、この大麻栗の緑葉の渦巻に、真つ白な花穂がいくつもいくつも垂れ下つて、まるで妊娠になつた綿羊の綿毛のやうに重々しく咲き盛つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、海の上を夕陽の色が眩しく赤々と流れる時刻に、別の軍艦に乗移らせられた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に砂を掘って拵えた急製の炉を囲み、火影に赤々と顔を火照らせ、それでも外からと、下からと沁みこんでくる寒さに外套の襟を立てて頸を縮めながら、私達は他愛もない雑談に耽った。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ獲物が片付く頃は日が暮てしまって、日に焼けた翁の顔が五分芯のラムプに赤々と光る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の句の「あか／＼」は決して「赤々」ではなくて、から／＼と明かるく乾き切り澄み切つて「つれない」のである。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブが赤々と燃えていて、その傍に敬二郎がばったりと倒れていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りのつかれごころで三人とも多く無言のまゝの車の窓に、近く右手に赤々とうち廣がつた野火のほのほが見渡された。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて一度も気絶したことのない人は、赤々と燃え輝いている石炭のなかに、不思議な宮殿やどこか見知ったような顔などを見る人ではない。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の、火は赤々とあって、白魚に花が散りそうでした。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "適当な太さの蝋燭が見当らぬので、わたしは炊事道具の包みから取り出したアルコール・ランプを載せると、恰度自由の篝火の模型の態を呈して、ロビンソンの横顔を赤々と照し出した。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は赤々と照りたれど朝の風寒し。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一赤々々相轉回して、遠く白雲深き谷底に落ち行きぬ。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある木などは葉がすっかり散り尽くして、赤々とした果実だけが真裸で累々と日にさらされていた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
