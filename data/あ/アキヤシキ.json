        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こっちから頼めばとって、昼間掃除に行くのさえ、厭がります空屋敷じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃ、鶴谷殿はじめ、貴下の思召しはさように難有うございましても、別にその……ええ、まず、持主が鶴谷としますと、この空屋敷の御支配でございますな、――その何とも異様な、あの、その、」「それは私も御同然です。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の空屋敷には色んな雜草がのんのんと繁つてゐたが、夏の或る天氣のいい日に私はその草原の上で弟の子守から息苦しいことを教へられた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の空屋敷には、そのじぶん大きな鷄舍が建てられてゐて、私たちはその傍の番小屋で午前中だけ勉強した。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に維新以後はその武家屋敷の取毀されたのもあり、あるいは住む人もない空屋敷となって荒れるがままに捨てて置かれるのもあるという始末で、さらに一層の寂寥を増していた。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれだけのことで遣り取りが済んだのであるが、明治の初年にはこんな空屋敷を買う者もない。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう事情で建ちぐされのままになっていた空屋敷を、わたしの父がやすく買取って、それに幾らかの手入れをして住んでいたのであるから、今から考えるとあまり居ごころのよい家ではなかったらしい。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来がほとんど武家屋敷ばかりであった所へ、維新の革命で武家というものが皆ほろびてしまったのであるから、そこらには毀れかかった空屋敷が幾らもある。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所で訊くと、そこには細井という旗本が住んでいたが、なにかの都合で雑司ヶ谷の方へ屋敷換えをして、この夏から空屋敷になっていることが判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪者どもが徒党して、喜右衛門をこの空屋敷へ誘い込んで、不思議な化け物をみせて嚇しておいて、持参のうずらを奪い取ったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこの五、六日前にも、やっぱり同じ空屋敷で五十両の茶道具をかたられた者があるという噂だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の者ならばそれが空屋敷であることを大抵承知しているが、遠方の者はそれを知らないで、うっかり連れ込まれるのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしもひどい荒れ屋敷だと思っていましたが、まさかに空屋敷とは……」と、喜右衛門も今更のように溜息をついていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおふくろの手前、世間の手前、化け物のこしらえで家を出るわけには行きませんから、やはり商売に出るようなふうをして、杖をついて、笛をふいて、いつもの通りに家を出て、かの空屋敷の台所の六畳を楽屋にして、そこですっかり化けおおせた次第です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも申す通り、六月末の夕方、その仲町通りの空屋敷の塀外に人立ちがした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分そこらの溝へでも這入ってしまったか、空屋敷の庭へでも這い込んだろうということになって、見物人は次第に散ってしまったのですが、なにしろ、それが蛇と小娘と切髪と、不思議な三題｜噺が出来あがっているので、その晩のうちにその噂が新宿から青山の方まで一面にひろまってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体その空屋敷というのは、以前は内藤右之助という三百石取りの旗本が住んでいたのですが、二年ほど前から小石川の茗荷谷の方へ屋敷換えになって、今では誰も住んでいないので、門のなかは荒れ放題、玄関さきまで夏草が茫々と生いしげっているというありさま。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昔は方々にこういう空屋敷があって、化け物屋敷だなどと云われたものです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体ここらは昔から蛇なんぞの多いところでしたが、この一件以来、その空屋敷を蛇屋敷と云い出して、明治になるまで誰も住んでいなかったようです」　老人の話が済んだ頃から、空はだんだんに薄明るくなって来たが、風は死んだように吹かなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして足かけ五年を送る間に、彼の家は空屋敷のように荒れてしまった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう空屋敷には怪談が付き物で、殺された手代の幽霊が出るとか、鬼火が燃えるとかいう噂がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳桂院様は四月の末におなくなり遊ばして、目黒の方はしばらく空屋敷になって居りましたが、その八月の末頃から奥様が一時お引移りということになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち退いた空屋敷とも思わるるなかに、内玄関でこちこち音がする。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは故の空屋敷となる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでありながら立派に腹も切れないとは、よくよく腰が抜けたものだと憤慨する人や、ここで腹を切ったら、それこそ恥の上の恥の上塗りだと冷笑する者や、それらの空気の間で、駒井家は見事に没落して、その空屋敷の前を通りかかった者でもなければ、もう噂をいう人もないという時分になってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸の御家人や旗本の空屋敷が其処此処に売物となっていたのをば、維新の革命があって程もなく、新しい時代に乗じた私の父は空屋敷三軒ほどの地所を一まとめに買い占め、古びた庭園や木立をそのままに広い邸宅を新築した。",
              "citation": {
                "source": "狐",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "向側は一町ほども引続いた練塀に、目かくしの椎の老木が繁茂した富豪の空屋敷。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "表門の潜戸ばかりを開けた家中は空屋敷のやうに寂として居る。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも石置き場の空屋敷などへは、あまりお行きになりませぬよう、願わしいものに存じます」　誠実を面に現わして、諌めるようにそういったのは、その前髪の少年武士であった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
