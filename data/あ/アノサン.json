    "entry": "彼のさん",
    "reading": {
      "primary": "あのさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
