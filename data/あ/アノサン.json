    "definitions": [
      {
        "index": 1,
        "gloss": "that person (mainly used in red light districts)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼のさんについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この彼のさんは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が彼のさんについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は彼のさんの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では彼のさんが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から彼のさんを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも彼のさんが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では彼のさんが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも彼のさんは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも彼のさんは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で彼のさんは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に彼のさんについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "彼のさんの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する彼のさんの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では彼のさんの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "現にあのさん・じょあん・ばちすたさえ、一度などは浦上の宗徒みげる弥兵衛の水車小屋に、姿を現したと伝えられている。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシヤには貴族等の唱へた共産主義の思想もあつたが、あのさん然たる文化の華を開いたのはそれよりも土地平分が基礎となつてをります。",
              "citation": {
                "source": "農民自治の理論と実際",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにさ、あのさんぴんは」と、お豊は立停った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
