        "examples": {
          "standard": [
            {
              "text": "私は毎日庵室について考えている。",
              "source": "幻辞"
            },
            {
              "text": "庵室という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は庵室の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には庵室が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "庵室を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは庵室について学習した。",
              "source": "幻辞"
            },
            {
              "text": "庵室の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は庵室の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では庵室が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "庵室という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に庵室という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では庵室についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "庵室を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると庵室は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "庵室について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では庵室が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に庵室は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により庵室の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "庵室は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に庵室は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "實驗室――彼れの庵室とも、城郭とも、宮殿とも昨日まで思つて、この六年間｜立籠つてゐた實驗室を彼れはいま／＼しげに見まはした。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はどんなメンタルテストをしたかと言うと、自分の腰元の中でも、年頃で一番美人の女を選びまして何やらそっと命令け、かの禅僧の修業している庵室へ行かせました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い腰元は庵室を覗いて見ますと、かの僧は室の中央に静かに坐禅を組んでいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは見込み違いをしていた」と言って、その僧を追い出し、住まわしていた庵室まで穢らわしいと言って焼き払いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）第三景（同じ庵室。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして覆面した一人の男庵室に忍び寄る。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）第四景（前景と同じ庵室。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月は法服姿に戻り庵室の奥の炉で香湯をあたためて居る。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蓮月、塗盥を庵室の中央に持ち出し、中に黄金の仏像を安置する。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恋しき人を見てしより……夢てふものは、」　とちょいと顔を上げて見ると、左の崕から椎の樹が横に出ている――遠くから視めると、これが石段の根を仕切る緑なので、――庵室はもう右手の背後になった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵室の客人なんざ、今聞いたようだと、夢てふものを頼み切りにしたのかな。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の底を捜したら、渠がためにこがれ死をしたと言う、久能谷の庵室の客も、其処に健在であろうも知れぬ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　死骸はその日｜終日見当らなかったが、翌日しらしらあけの引潮に、去年の夏、庵室の客が溺れたとおなじ鳴鶴ヶ｜岬の岩に上った時は二人であった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、庵室つて、こんなに何もないものですか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼夢、かくの如く、いまはつくづく無分別の出家｜遁世を後悔いたし、冬の吉野の庵室に寒さに震えて坐って居ります。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御堂は申すまでもありません、下の仮庵室なども至極その涼いので、ほんの草葺でありますが、些と御帰りがけにお立寄り、御休息なさいまし。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、不躾でありまするが、思召しがござったら、仮庵室御用にお立て申しまする。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　実は先刻お話申した、ふとした御縁で、御堂のこの下の仮庵室へお宿をいたしました、その御仁なのでありますが。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方が、庵室に逗留中、夜分な、海へ入って亡くなりました。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも先代の親仁と言うのが、もう唯今では亡くなりましたが、それが貴下、小作人ながら大の節倹家で、積年の望みで、地面を少しばかり借りましたのが、私庵室の背戸の地続きで、以前立派な寺がありました。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵室から打仰ぐ、石の階子は梢にかかって、御堂は屋根のみ浮いたよう、緑の雲にふっくりと沈んで、山の裾の、縁に迫って萌葱なれば、あま下る蚊帳の外に、誰待つとしもなき二人、煙らぬ火鉢のふちかけて、ひらひらと蝶が来る。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日また散歩に出て、同じ時分に庵室へ帰って見えましたから、私が串戯に、（雪舟の筆は如何でござった。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵室の客人が、唯今申す欄干に腰を掛けて、おくれ毛越にはらはらと靡いて通る、雪のような襟脚を見送ると、今、小橋を渡った処で、中の十歳位のがじゃれて、その腰へ抱き着いたので、白魚という指を反らして、軽くその小児の背中を打った時だったと申します。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって、この庵室に馴れました身には、石段はつい、通い廊下を縦に通るほどな心地でありますからで。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内わきの、左手の庵室、障子を閉して、……たゞ、假に差置いたやうな庵ながら構は縁が高い、端近に三寶を二つ置いて、一つには横綴の帳一册、一つには奉納の米袋、ぱら／＼と少しこぼれて、おひねりといふのが捧げてある、眞中に硯箱が出て、朱書が添へてある。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中の白雲山の庵室へ、佐助がお使者に立ったとやら。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手、築地垣より通路一重を距てて半、紅葉した楓の木の下に、漸く人一人の膝を入れるだけの庵室。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の庵室には上手を向いて老いさらばった老僧が眼を瞑って端座している。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は隣の庵室の聖さま、一人はうちの奥さま。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾いた、壁も戸も無い私の庵室に支柱をして、兎に角私たちは辛うじて安きを得た。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
