        "examples": {
          "standard": [
            {
              "text": "毎日、愛玩物は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛玩物が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛玩物に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛玩物が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛玩物について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛玩物についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛玩物について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛玩物が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛玩物が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛玩物は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛玩物は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛玩物を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛玩物をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛玩物が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛玩物の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛玩物を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛玩物に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛玩物について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛玩物は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛玩物を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "＊　　　＊　これは、我が国では、埴輪人形の昔より、人間や、人間が愛していた動物などの形をつくって、それが生埋めになることからのがれさせて呉れたのであるが、その後、愛玩物としての人形が発達した。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学が特殊な人々の愛玩物ではなくて、私たちすべての生活人の社会生活のいきさつと、心持とそこからの発展を意味するものであればある程、社会人としての文学上の素人の意見は文学に大きい評価の価値を占めてくるものである。",
              "citation": {
                "source": "ディフォーメイションへの疑問",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、何子・何々子と言ふ風の愛称、日本語にも通常用ゐられ――殊に東北語に多い、あの愛称又は愛玩物を言ふ語尾の ko …… kkoo …… ko …… kko ……に当るものがある。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉正にしたところ、いかに自分の女房にしたとこで、承諾も得ないでその愛玩物を差し上げるとは約束をし兼ねる。",
              "citation": {
                "source": "『七面鳥』と『忘れ褌』",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "令夫人なんて、夫にちやほやされるだけの愛玩物に過ぎないし、心などない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
