        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフォリズムについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフォリズムは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフォリズムについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフォリズムの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフォリズムが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフォリズムを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフォリズムが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフォリズムが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフォリズムは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフォリズムは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフォリズムは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフォリズムについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフォリズムの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフォリズムの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフォリズムの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "特に月々の「文藝春秋」に出すアフォリズム風の文字（侏儒の言葉）は、機智のために機智を弄する弄筆者流の惡皮肉で、憎惡的にさへ不滿を感ぜずに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕のやうな人間には、短かいアフォリズムや抒情詩しか書けないのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の著書の中で、比較的初学者に理解し易いと言はれ、したがつて又ニイチェ哲学の入門書と言はれるアフォリズム「人間的な、あまりに人間的な」でさへも、相当に成育した一般の文化常識と、特に敏感な詩人的感覚とを所有しない読者にとつては、決して理解し易い書物ではない。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェの理解に於ける困難さは、彼の初期に於ける少数の著書論文（悲劇の出生など）を除いて、その後の者が多くアフォリズムの形式で書かれて居ることにある。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフォリズムとは、だれも知る如くエッセイの一層簡潔に、一層また含蓄深くエキスされた文学（小品エッセイ）である。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち言へば、アフォリズムはそれ自ら「詩」の形式の一種なのである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（したがつて西洋の詩人たちは、独りニイチェに限らず、グウルモンでも、ジャン・コクトオでも、ボードレエルでも、ヴァレリイでも、すべて皆アフォリズムを書いてる。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　アフォリズムは詩である。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまず記憶に浮かんだのは「侏儒の言葉」の中のアフォリズムだった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、――僕は又苦しみに陥るのを恐れ、丁度珈琲の来たのを幸い、「メリメエの書簡集」を読みはじめた、彼はこの書簡集の中にも彼の小説の中のように鋭いアフォリズムを閃かせていた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等のアフォリズムは僕の気もちをいつか鉄のように巌畳にし出した。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　夢の中で、いかにも萩原さんでも云ひさうなアフォリズムめいたことを私に云つたのは、しかし、芥川さんらしい人だつた。",
              "citation": {
                "source": "二三の追憶",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　「一日辻潤來り、わが生活の荒蕪を見て、唖然とせしが、忽ち顧みて大に笑ひ、共に酒を汲んで長歎す」（「乃木坂倶樂部」小解）「虚妄の正義＊」一卷をなすところの多くのアフォリズムが書かれたのは、さういふ生活の荒蕪のさなかであつたのである。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この言葉は次の箴言集「絶望の逃走」の序のなかで云はれてゐるものであるが、それは前の「新しき欲情」についても、「虚妄の正義」についても、すべてかういふアフォリズムの形式をとつた彼の著書に對して、同じやうに云へることだと思ふ。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼はそれらの「四季」や「コギト」に據る若い詩人たちの大いなる先輩として、それから數年の間に、主としてエッセイやアフォリズムの形式で、新しい詩のために實によく仕事をした。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――例によつて三島由紀夫得意のアフォリズムである。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十年間に彼が得たものといえば、無為のみが人間の精神を自由にする、というアフォリズムだけだった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がひとりの間は、なるほどそれは彼の精神を開放し、自在に自由美の園を逍遙させてくれたが、結婚してからは、せっかくのアフォリズムも妻を苦しめるだけにしか役立たなくなってしまった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "反語や逆説やアフォリズムという作文様式は、この要求から使われるのであって、特に反語や逆説やアフォリズムを使って見たくなったから使う、というものであってはならぬ。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は自分のあたまのよさに酔い、例の浦粕的アフォリズムでしめ括りをつけた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は『カフカの信仰と思想』という著者の序文において、カフカの正しい解釈のためには、アフォリズムにおけるカフカと、物語作品（長・短編）におけるカフカと、この二つの流れを区別しなければならない、という。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼によれば、アフォリズムのカフカは人間のなかの「破壊されないもの」を認識し、世界の形而上的な核心に対して積極的で信仰的な関係をもっている。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、小説および物語のカフカは、恐れと孤独感とのうちでさまよっている人間、つまり、アフォリズムや日記のなかで語っているあの「破壊されないもの」を失った人間、信仰において確信をもてなくなり、錯乱している人間、を示している。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは、アフォリズムに見られるような積極的な言葉を聞かないで正しい道を離れ去るときに現われる、恐るべき処罰を描いている。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、従来カフカのアフォリズムは十分にわれわれ読者の前に提供されていなかった。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
