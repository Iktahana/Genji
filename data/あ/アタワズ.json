        "examples": {
          "standard": [
            {
              "text": "毎日、能わずについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の能わず戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "能わずの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "能わずという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは能わずについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "能わずの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "能わずに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは能わずを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での能わずは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、能わずは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "能わずは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な能わずを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「能わず」という概念について深く考察する必要があります。",
              "source": "幻辞"
