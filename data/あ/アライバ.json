[
  {
    "uuid": "9287c358-b1b4-5c36-b257-194085f9f35b",
    "entry": "洗い場",
    "reading": {
      "primary": "あらいば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "washing place (e.g. for laundry or tableware)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い場について考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い場という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い場の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い場が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い場を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い場について学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い場の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い場の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い場が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い場という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い場という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い場についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い場を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い場は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い場について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い場が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い場は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い場の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い場は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い場は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御承知の通り、仕出し屋のことですから店には洗い場があって、そこには大きい内井戸がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むき出しの板、埃まみれの短い廊下は、台所と洗い場に続いていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして電子化が奪ったのは、洗い場のカレーの皿にへばりついた黄色い染み程度のオレの漢字書き取り能力だけではなかったのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと洗い場で汗を流しちゃどうか、ちょうど湯がわいてるよ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも西瓜をはやく出せ」　義兄は洗い場で身体を洗いながら大声で叫んだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、昨夜｜銭湯へ行ったとき、八百円の札束を鞄に入れて、洗い場まで持って這入って笑われた記憶については忘れていた。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の二号室の附添看護婦が、あの廊下の突当りの手洗い場に行きかけると、あの室の扉が開いて、眩しい電燈の光りが廊下にさしている。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は気が付いて、あの向うの二等病室づきの手洗い場に行ってみましたが、手洗い場の龍口栓は十分に締まっていない上に、床のタイルの上に水滴が夥しく零れておりました。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥だらけのたたきを水洗いしていた使丁がいまいましげに舌打ちしてそれに呶鳴りつけた、「ばか野郎……そ、その泥足は何でえ……」ぴくりと富次は驚くのであるが、その時彼はえり頸を掴まえられてすでに足洗い場に運ばれていた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気をつけると、そこの……旧式の台所で、板敷のところから一段ひくくなってる洗い場の前の置板の上に、おしげが、白い浴衣地の寝間着のまま横倒しに蹲っていた。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浴室は、公衆電話函を二つ並べたようになっていて、入口に近い仕切の中で衣類を脱ぎ、その奥に入ると、白いタイルで張りつめた洗い場になっていて、栓をひねると天井からシャーッと温湯が滝のように降ってくるのであった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまわりも広い大理石の洗い場になっていて、そこに二、三人の人たちが広々と両手両足をなげだして、湯にのぼせた身体をひやしていた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見は気張って、痩っぽちの裸体を風呂屋の洗い場で彼に見せてやった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが自分の家であったら、見知らぬ人に寝起のままの乱れた髪や汚れた顔を見せずとも済むものを、宿屋に泊る是非なさは、皺だらけになった寝衣に細いシゴキを締めたままで、こそこそと共同の顔洗い場へ行かねばならない。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからわたしが小川の洗い場にいると、女の人が丘を下りて来た。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東市でこれ以上チッポケな湯殿はなかろうと思われるぐらい、洗い場もないほどのところだが、私にはこれ以上の広さも必要ではない。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに手洗い場と便所が附いているだけだ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭坑を綺麗にし中に便所や手洗い場を作るのは困難であり、常識的に上品に食事をする方法を準備することはさらに出来ないだろうから、労働時間を８時間ではなく４時間を２回にして、坑夫が食事をとるために家に帰れることにして、坑内で食べ物をとらないようにする。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い場の辺に久野の友人の松田と成沢が立っていた。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い場では半艇身以上先んじていた。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水に起きた主人の治兵衛が、フト昨夜の話を思い出して手洗い場の障子を開けて、丈夫に出来た格子から、月明りにすかして中庭を見やりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワは土地によって井戸または泉を意味し、元は必ずしも大きな水流のことでなかったらしいから、今でも奥羽各地で家々に近い物洗い場、または水汲み場をカワド・カードという方が古いかと思うが、この地方のカワド・ゴードはとにかく交通の衝のことであった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとまえから、洗い場で一人の男が水を汲んでいた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青べかは洗い場の杭につながれて、ゆらゆらとねむたそうに揺れていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは根戸川堤のほうからであり、洗い場でわきあがっていることがよくわかった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い場の騒ぎはなお続いてい、長の叫び声が、その騒ぎを縫うように聞えた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い場の杭につないであった青べかは、もうそこには見えないのである。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は踏段をおりながら、さてはひっくら返したかと思い、洗い場に跼んで水中をすかして見た。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
