          ],
          "literary": [
            {
              "text": "藪入の夢や小豆の煮えるうち　藪入で休暇をもらった小僧が、田舎の実家へ帰り、久しぶりで両親に逢ったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供に御馳走しようと思って、母は台所で小豆を煮ている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺碧のナポリの湾から山腹を逆様に撫で上げる風は小豆大の砂粒を交えてわれわれの頬に吹き付けたが、ともかくも火口を俯瞰するところまでは登る事が出来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆色のセーターを着た助手が、水道のホーズから村山貯水池の水を惜気もなく注いで、寝台自動車に冷たい行水を使わせている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうち、清三は夏休み中、池の水を汲むのを手伝ったり、畑へ小豆の莢を摘みに行ったりした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等と一緒に兵タイに取られ、入営の小豆飯を食い、二年兵になるのを待ち、それから帰休の日を待った者が、今は、幾人骨になっているか知れない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆飯にたいてみた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし汽車に乗って丸亀や坂出の方へ行き一日歩きくたぶれて夕方汽船で小豆島へ帰ってくると、やっぱり安息はここにあるという気がしてくる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日には、なな草のあえもの、十五日には朝早くとんどをして茅の箸で小豆粥を食べる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島と云えば、寒霞渓のあるところだ。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "──小豆島の言葉をそのまままる出しに使っとる。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大きな茶碗で兵営の小豆飯を食わされる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島で汽船に乗って、甲板から、港を見かえすと、私には、港がぼやけていてよく分らなかった。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸されるような暑苦しい谷間の坂道の空気の中へ、ちょうど味噌汁の中に入れた蓴菜のように、寒天の中に入れた小豆粒のように、冷たい空気の大小の粒が交じって、それが適当な速度でわれわれの皮膚を撫でて通るときにわれわれは正真正銘の涼しさを感じるらしい。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島の西方、女木島という島には、海賊の住家だったらしい洞窟がある。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島は、島であるが、同時にまた山である。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑穀屋が小豆の屑を盆の上で捜すように、影を揺ってごらんなさい。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「小豆でございます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆粒くらいの大きさの花火が、両耳の奥底でぱちぱち爆ぜているような気がして、思わず左右の耳を両手で覆った。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、お粥にゆで小豆を散らして、鹽で風味をつけたものであつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、お粥にゆで小豆を散らして、塩で風味をつけたものであった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先ず僕が自己の額に汗して森を開き林を倒し、そしてこれに小豆を撒く、……」「その百姓が見たかったねエハッハッハッハッハッハッ」と竹内は笑いだした。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左のほうには小豆色の東京駅が横たわり、そのはずれに黄金色の富士が見える。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」車夫は輪軸を検せんとて梶棒を下すを暗号に、おでん燗酒、茄小豆、大福餅の屋台｜店に、先刻より埋伏して待懸けたる、車夫、日雇取、立ン坊、七八人、礫のごとくばらりと出で、腕車の周囲を押取巻く。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……だって、椎の木婆さんが、糸車を廻す処ですもの、小豆洗ともいうんですわ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近間ではあるし、ここを出たら、それこそ、ちちろ鳴く虫が糸を繰る音に紛れる、その椎樹――（釣瓶おろし）（小豆とぎ）などいう怪ものは伝統的につきものの――樹の下を通って見たかった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ郷里｜高知では正月の十四日の晩に子供らが「粥釣り」と称して近所の家を回って米やあずきや切り餅をもらって歩いて、それで翌朝十五日の福の粥を作るという古い習慣が行なわれていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
