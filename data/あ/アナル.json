    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナルについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナルという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナルの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナルが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナルを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナルについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナルの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナルの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナルが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナルという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナルという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナルについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナルを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナルは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナルについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナルが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナルは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナルの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナルは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナルは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いっそ、いまは記者諸兄と炉をかこみ、ジャアナルということの悲しさについて語らん乎。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "週刊『ル・リベルテエル』（自由人）月刊『ラ・ルヴィユ・アナルシスト』（無政府主義評論）との事務所になっているほかに、ラ・リブレリ・ソシアル（社会書房）という小さな本屋をもやっているので、店はみな地並みにあるわけなのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の始まる前に『ル・リベルテエル』や『ラ・ルヴィユ・アナルシスト』（無政府主義評論）なぞを会場で売り歩いていた連中だ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "保子に判決謄本とアナルシーと授業料とを忘れないように、ことに授業料を早くと伝えてくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働問題は活溌におこっていて、組合の組織もまとまりはじめてはいたものの、アナルコ・サンディカリズムの傾きがつよく支配していた当時の労働階級自身の政治能力、文化能力はまだ自身の階級の文化についてそれを自発的に提起するほどには発達していなかったのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びる買收の手「ボンズ（坊主）とクレチャン（基教徒）とが寄つて、アナルシスムの修業をするなんて、東洋でなくては見られない風景だネ」　ルクリュ翁はいかにも興味深げであつたが、マダムはわたしの執えうな基教思想に不滿の面持であつた。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナルシストが十字架で惱むなんて、およそ意味がないではありませんか？",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後のダダイズムとか、シュール・リアリズムにあるようなサンジコアナルキズムなどと同じ線にそっているものがそれである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはサンジカリズムないしアナルコサンジカリズムの思想をふりまいてゆき、小野も、三吉も、五高の学生たちも、また専売局の友愛会支部の連中も、革命が気分的であるかぎり一致することが出来ていた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ア、ア、アナ、アナルコサンジカリズムなんか……」　と、やっきになっているけれど、彼はひどい吃りなので、すぐ何倍も大きな高坂の声にかきけされてしまった。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "対馬の伜から材料を貰い、マライタのゴタゴタを書いた「ポート・ダーヴィン・ジャアナル」の新聞記者だ。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚｜為念、従者ラジック・シャアナルモノハ殿下御看護ニ際シ感染本日午後一時三十分死去水葬ノ趣唯今イキトス号船長ヨリノ無電ニ接ス。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
