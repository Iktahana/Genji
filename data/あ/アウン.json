        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これは阿吽の例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この表現を高潮させるには、先ず自分の性格、意志、感情なぞと同時に阿吽の呼吸までも相手にわからぬようにソーッと殺して終うので、この辺は自分の「鼻息を窺っ」ているようにも見えます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりこれから先の行手では、まことに春日遅々たるの想ひで豆粒ほどの土に藹々たる無辺の念を凝らしながら、阿吽の呼吸をはかつて、やがては個性を吹き込み、風格を注ぎ込まうといふ妙境なのである……。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そもそも伊賀流の秘訣というは阿吽の呼吸これ一つじゃ」老人は静かに説き出した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿吽の呼吸で鯨羊羹が切り出されるたび、もち米のほのかに甘い匂いが立ちのぼる。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその度びに頸ががくりとなって「あうん」と返事いたしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月には、モルナールのものをやることになっていますの、その方が私の柄にあうんじゃないかと思っていますの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あうんの呼吸は等質の社会の構成員には居心地のよい慰安であっても、よそ者からすれば無言の排除にほかならない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてオレ達の社会は、あうんの仲良しクラブにとどまっているには小金をため過ぎたのだから。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧劇の芝居を見たつて、作者の創作的燃焼力が、あうんの彼方に感ぜられるものでない限り凡ての観客の夢を潤さぬではないか。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が余計なおしゃべりをするから、杉田がこんな目にあうんだぞ」「なんだって、俺が余計なおしゃべりをしたって。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ二人は、こんなに愛しあうんでしょう※　それはね……なぜ太陽はかがやき子供は生れるかと、尋ねられるように、答えようがありますまい。",
              "citation": {
                "source": "方子と末起",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ありましたとも、大ありだったんですけど……ほんとうに思い出しても腹が立っちゃあうんですよ」「逃げられたんでしょう」「にげ様にもよるじゃあありませんか、マア、斯うなんですよ、私がネ、こないだ新橋に行った時、ステーションにですよ、その時あの玄関に二人女が立ってたんです。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりもうけすぎるから、こんどみたいな目にあうんだ」　そういって、にくまれ口をきく者もいた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それからどんな目にあうんですか。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはワシントンへいって、ブルック先生にあうんだ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かあさんでも生きててごらん、どうして言うことをきかないような子供は、よっぽどひどい目にあうんだぜ――あのかあさんは気が短かかったからね。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしがこんなめにあうんだったら、まっぴらだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるだからきなくさい鉄の香がいたずらに流れて、あうんの声、飛び違える土けむり、玉散る汗、地に滑る血しお……それらが混じて一大殺剣の気が、一刻あまりも山腹にもつれあがっていた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物と舞台と、あんなにいきがあうんですもの――独特ねえ……何て独特なんでしょう！",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　――若旦那さま、あのさえという娘にはお気をつけなさいまし、との方なら誰とでもつきあうんです、と下女のとみが云った。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人を見て悪態をつかねえからそういうめにあうんだ、ざまあみやがれ」「乙女さま、早く」大助はのりだして叫んだ。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ったく、おおぜいのやろうが事故にあうんだから。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は明智が、かならずここへやってくるのを察して、明智をからかうために、「おれをとらえようとすれば、こんなめにあうんだよ。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十面相をとらえようなんて、だいそれたことを考えるやつは、しまいにはこんなめにあうんだよ。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
