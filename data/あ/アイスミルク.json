    "definitions": [
      {
        "index": 1,
        "gloss": "ice milk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイスミルクは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスミルクが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスミルクに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスミルクが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスミルクについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスミルクについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスミルクについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスミルクが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスミルクが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスミルクは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスミルクは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスミルクを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスミルクをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスミルクが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスミルクの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスミルクを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスミルクに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスミルクについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスミルクは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスミルクを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "世間にあるのはアイスクリームでなくってアイスミルクですな、アハハ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスミルクの方ではとてもそんな事が出来ません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームでなくってアイスミルクだと笑われましょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスミルクコゝア、コーヒー立続けに飲む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
