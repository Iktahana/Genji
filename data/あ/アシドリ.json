[
  {
    "uuid": "f3d9a7f6-7588-5a51-aa0b-72bf6983b82a",
    "entry": "足取り",
    "reading": {
      "primary": "あしどり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
