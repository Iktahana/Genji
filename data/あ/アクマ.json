        "examples": {
          "standard": [
            {
              "text": "悪魔は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪魔対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪魔に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪魔がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪魔は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、悪魔の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは悪魔を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により悪魔の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における悪魔の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "悪魔について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日悪魔について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から悪魔を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により悪魔の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは悪魔を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で悪魔に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "悪魔は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "悪魔対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "悪魔に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では悪魔がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると悪魔は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを嘲る悪魔の声も聞えるような気がする。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは私を誘き出す悪魔なんだからね！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬つころの悪魔の杓子野郎が、と彼女はわめいた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪魔の杓子野郎つたら、逃がしはしないから！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハインリヒ・クライの怪奇画からは文明の背後に隠れた災厄の悪魔の呼吸を感じさせられる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あはれ果敢なき塵塚の中に運命を持てりとも、穢なき汚れは蒙むらじと思へる身の、猶何所にか悪魔のひそみて、あやなき物をも思はするよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「押へても押へても押へきれない性慾の発作」それはむざむざと彼の若い生命を喰ひつめた悪魔の手であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿見下ろす大吉の顔に一種残酷な、所謂悪魔的な微笑と云う奴が浮んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室からルーレットの玉の転げる音が、悪魔の囁きのように妾の耳に響いて来ました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はどんな利益を犠牲にしても、悪魔のような久次郎を追い攘ってしまわなければならないと決心した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の白い壁には、日本と朝鮮の地図を両足に踏んだ田中義一が、悪魔のような爪の伸びた長い手で、満洲、蒙古、山東地方を一掴みに掴みとろうとするポスターが、二枚つゞけて貼りつけてある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　おみちの胸はこの悪魔のささやきにどかどか鳴った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっはっはは」　話し手の男は自分の話に昂奮を持ちながらも、今度は自嘲的なそして悪魔的といえるかも知れない挑んだ表情を眼に浮かべながら、相手の顔を見ていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一歩を敢然と踏み出すためには、われわれは悪魔を呼ばなければならないだろう。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ八田は警官として、社会より荷える負債を消却せんがため、あくまでその死せんことを、むしろ殺さんことを欲しつつありし悪魔を救わんとして、氷点の冷、水凍る夜半に泳ぎを知らざる身の、生命とともに愛を棄てぬ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また他の方面で最も自分の周囲の人々を愉快がらせたのは、かの大江山の「酒顛童子」が「恐ろしき悪魔」と訳されたりするのであった。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずこのシュテンドウシがアラビアから来たマレイ語で「恐ろしき悪魔」という意味の言葉に似ており、もう一つ脱線すると源頼光の音読がヘラクレースとどこか似通ってたり、もちろん暗合として一笑に付すればそれまでであるが、さればと言って暗合であるという科学的証明もむつかしいような事例はいくらでもある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞こえてもそれはややもすれば悪魔の誘惑する声としか聞かれないかもしれない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は、ずるい悪魔だ。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その不健康な、悪魔の許にいそいで出掛けた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんは、私の家の悪魔です。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその翌年に女学校を卒業して、つまり、今は、その叔父さんの悪魔のような予言を、死ぬほど強く憎んでいながら、或いはそうかも知れぬと心の隅で、こっそり肯定しているところもあるのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、不精も程度が過ぎると悪魔みたいに見えて来ますよ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタンは普通、悪魔と訳されているが、ヘブライ語のサーターン、また、アラミ語のサーターン、サーターナーから起っているのだそうである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまいましくて仕様が無いから、いろいろ研究しているのですが、いったい、悪魔だの、悪鬼だのというものが此の世の中に居るんでしょうか。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君には悪魔の素質があるから、普通の悪には驚かないのさ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そいつは、悪魔だ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此の世の悪魔を見た。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悪魔でも悪鬼でもない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
