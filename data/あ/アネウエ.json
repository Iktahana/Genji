        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉上について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉上という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉上の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉上が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉上を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉上について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉上の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉上の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉上が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉上という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉上という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉上についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉上を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉上は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉上について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉上が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉上は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉上の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉上は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉上は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "姉上が数々の子供をつれて来る。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上のいくさの話が出て子供等が急におとなしくなったと思うたら、小さいのとせいちゃんは姉上の膝の上ではや寝てしまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上等がかえると御てらしが消えて御神燈の灯がバチバチと鳴る。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは、故郷の姉上から、お餅をこつそり送つていただきました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人にては行くことなかれと、優しき姉上のいいたりしを、肯かで、しのびて来つ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩あり光沢ある虫は毒なりと、姉上の教えたるをふと思い出でたれば、打置きてすごすごと引返せしが、足許にさきの石の二ツに砕けて落ちたるより俄に心動き、拾いあげて取って返し、きと毒虫をねらいたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人顔のさだかならぬ時、暗き隅に行くべからず、たそがれの片隅には、怪しきもの居て人を惑わすと、姉上の教えしことあり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と坂下あたり、かなしげにわれを呼ぶは、姉上の声なりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなればわれ姉上をまで怪みたる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりよく似たれば、姉上と呼ばむとせしが、よしなきものに声かけて、なまじいにわがここにあるを知られむは、拙きわざなればと思いてやみぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えずなればなおなつかしく、たとえ恐しきものなればとて、かりにもわが優しき姉上の姿に化したる上は、われを捕えてむごからむや。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と姉上ののたまうに、縋りつかまくみかえりたる、わが顔を見たまいしが、「あれ！",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は姉上よりたけたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "露に白き襟、肩のあたり鬢のおくれ毛はらはらとぞみだれたる、かかるさまは、わが姉上とは太く違えり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳をのまむというを姉上は許したまわず。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもての方さざめきて、いずくにか行きおれる姉上帰りましつと覚し、襖いくつかぱたぱたと音してハヤここに来たまいつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばかりにいらえて姉上はまろび入りて、ひしと取着きたまいぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上の膝に臥したるあいだに、医師｜来りてわが脈をうかがいなどしつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上は袖もてわれを庇いながら顔を赤うして遁げ入りたまいつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのわれにはかわらじを、何とてさはあやまるや、世にただ一人なつかしき姉上までわが顔を見るごとに、気を確に、心を鎮めよ、と涙ながらいわるるにぞ、さてはいかにしてか、心の狂いしにはあらずやとわれとわが身を危ぶむようそのたびになりまさりて、果はまことにものくるわしくもなりもてゆくなる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "端厳微妙のおんかおばせ、雲の袖、霞の袴ちらちらと瓔珞をかけたまいたる、玉なす胸に繊手を添えて、ひたと、おさなごを抱きたまえるが、仰ぐ仰ぐ瞳うごきて、ほほえみたまうと、見たる時、やさしき手のさき肩にかかりて、姉上は念じたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂｜青光して、はたたがみ堂の空をまろびゆくに、たまぎりつつ、今は姉上を頼までやは、あなやと膝にはいあがりて、ひしとその胸を抱きたれば、かかるものをふりすてむとはしたまわで、あたたかき腕はわが背にて組合わされたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが背をしかと抱きたまえる姉上の腕もゆるみたれば、ソとその懐より顔をいだしてこわごわその顔をば見上げつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰るべくもあらねば姉上は通夜したまいぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を経てわれも姉上とともに来り見き。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たびこのところ決潰せむか、城の端の町は水底の都となるべしと、人々の恐れまどいて、怠らず土を装り石を伏せて堅き堤防を築きしが、あたかも今の関屋少将の夫人姉上十七の時なれば、年つもりて、嫩なりし常磐木もハヤ丈のびつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんも變だ、第一「嬌瞋」を發しようし……そこンところが何となく、いつのまにか、むかうが、姉が、姉が、といふから、年紀は私が上なんだが、姉さんも、うちつけがましいから、そこで、「お姉上。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とその時いふと、お姉上も若かつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばし、お名あがり家ととのうたるのちは、御兄上様御姉上様、何条もってあしざまに申しましょうや。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人にては行くことなかれと、優しき姉上のいひたりしを、肯かで、しのびて来つ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
