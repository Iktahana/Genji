        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この山の上で、朝から夕立に遇っては堪まらないと、多年山登りの経験から気がついて、呆れ顔の導者を促して路を急ぐ、岩角を上ったり、下ったり、偃松や黄花石楠花の間を転がるようにして走ったが、その間に幻影は消え消えながら、三度出た、しかし心配ほどもなく、霧は奇麗に拭われて、雨にはならなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を膝に上げたまま夢に夢見る呆れ顔になった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖に半身を隠して老番頭、呆れ顔の長いのを、擡げるがごとく差出したが、急込んだ調子で、「はッ。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我身｜半はその蝶に化したるかと、お雪は呆れ顔をして身内を見たが、にわかに色を染めて密と少年を見ると、目を開かず。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、慌しく身を退ると、呆れ顔してハッと手を拡げて立った。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と其の呆れ顔を掌でべたりと撫でる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶ちゃん」　池上は、ほろ酔いの下地でもあるのか、わたくしのこの破天荒な仕打ちには何の疑いをも挟まず、少し呆れ顔ながら、とろりとした様子を見せ、抓ねられた痕とわたくしの顔とを見較べて、「正月早々だよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何をする、」と哲学者は呆れ顔をしてほとんど問題を研究する時のように難しく眉を顰めた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、慌しく身を退ると、呆れ顔してハツと手を拡げて立つた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はそんなヘマなことはやらないや」　ペンはますます呆れ顔だった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔いろをかえてどうしたんだ」三ちゃんは現像室からとびだしてきて、敬二少年を呆れ顔で見やった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いささか呆れ顔で、相手を頭の天辺から足の爪先まで、じろじろと眺めながら、チューブは口の中で呟やいた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういって褒めあげた末に、人間は大将を望んでやっと兵卒位にしか出世をしないものだという事や、恐らく○○先生も世が世であれば大名を志望てお出だったであろうがなぞと、呆れ顔に佇んでいた、例の助教師の方へ嫌味をふりかけて、そのくせ人の好い笑顔をむけたりするのだった。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れ顔をしてじッと見ていた小万の前に、吉里は倒れるように坐ッた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事はなかば呆れ顔に反問した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、死後でもなく、また、服毒以前でもないのだがね」「冗談じゃないぜ」と熊城は思わず呆れ顔になって、「これが即死でないのなら、一つ君の説明を承ろうじゃないか」といきり立つのを、法水は駄々児を諭すような調子で、「ウン、この事件の犯人たるや、いかにも神速陰険で、兇悪きわまりない。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "易介は自殺で、この創は犯人が後で附けたのではないだろうか」「そうなるかねえ」と法水は呆れ顔で、「すると、事によったら吊具足は、一人で着られるかもしれないが、だいたい兜の忍緒を締めたのは誰だね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで例の見舞い客に振れ舞う土瓶らの茶碗酒を我々にも飲ませたが、我々はそこへ腰をかけたままで、もう火事の句数句を作る、また主人も作るという風で周囲の他の人々は呆れ顔をしていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばかをいっちゃいかん、いくら子供だって……」とジグスは呆れ顔になり「あのよぼよぼ博士はもちろんのこと、地球上のどんなえらい人間だって、火星へ旅行をしたことのある者なんて一人もあるもんかね。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではその新しい方の分も、全部贋物なんでしょうか」芳本も呆れ顔して口を出した。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長はこの場の様子を見て、いつもながら帆村の手廻しのよいのに呆れ顔だった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はッはッはッ」と、帆村は呆れ顔に笑い出した。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお――」　そう叫んだまま、大隅学士は門の中から飛び出してきた可憐なる少年の顔を、呆れ顔にいつまでも見つめていた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわしの志ぢゃ」　そういって博士は、ポケットから取り出した一つかみの金貨を呆れ顔の、給仕頭の掌にのせてやった。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは……」と戸沢名刑事は帆村の方を呆れ顔で眺めてから、ぶっつけるように云った。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう、晩飯はすんできた――という三人を、校長先生は呆れ顔で見ていた。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大巻先生が感きわまって叫んだから、安福軒は呆れ顔、まさかこの先生二三日食う物も食わずにいるわけではあるまいがと考えた。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右に馳違ふ少年の群を分けて、高等四年の教室へ近いて見ると、廊下のところに校長、教師五六人、中に文平も、其他高等科の生徒が丑松を囲繞いて、参観に来た師範校の生徒まで呆れ顔に眺め佇立んで居たのである。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーシチク　（呆れ顔で）へえ、こりゃ驚いた！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あきれがおで、「ばか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
