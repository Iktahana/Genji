    "definitions": [
      {
        "index": 1,
        "gloss": "aroma",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アロマについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アロマという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアロマの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアロマが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アロマを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアロマについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アロマの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアロマの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアロマが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アロマという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアロマという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアロマについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アロマを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアロマは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アロマについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアロマが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアロマは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアロマの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アロマは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアロマは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ベランダのベラドンナから漂うアロマが部屋一杯に染み渡り、老哲学者の魂を隅々まで静かな寛容の気で満たした。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
