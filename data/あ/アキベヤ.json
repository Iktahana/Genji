    "definitions": [
      {
        "index": 1,
        "gloss": "available room (hotel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "でも、四階には空き部屋と娯楽室があるだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "娯楽室は夕方まで閉まっているはずだし、空き部屋には立ち入るなと、晩餐会後におこなわれた、寮生活のオリエンテイションで注意を受けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここ、空き部屋じゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤバいよ」　いまや、空き部屋への「不法侵入」は、高志の専売特許ではなくなっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、高志は空き部屋に忍びこみたがるんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "空き部屋で、備品倉庫として使われている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきごろまでは、何一つ入れてないがらんとした空き部屋だったのが、今はどうであろうか。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬木くん、きみはたしか二十七号室の空き部屋とその隣の部屋とを検査したはずだが、その隣の部屋というのはちょうど社長室の真下に当たって、石垣とかいう建築士の事務所だというのじゃなかったかね？",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはうっかり、その石垣という人の建築事務所を二十七号室だと思っていましたが、ぼくらの検査した窓のない空き部屋が二十七号室だったのです。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、いよいよ一昨日、職長はわたしに向かって四階の空き部屋二十七号室へ社長を呼び出しておくから、四時五分ごろに来るがよいと申しました。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のところというのは真下の四階の一室で、空き部屋になっていて偶然にこの部屋と鍵が合うので一、二度野田に強いられて、一緒に入って語り合ったことがあったのだった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時近くになるといつの間にか野田がいなくなっていたので、艶子は急いで帰り支度をして四時きっかりに部屋を出て、うまく友達の目を眩まして裏階段から四階へ下りると、そっと空き部屋の前に行ってドアを押した。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、突きつめていくうちに驚くべきことを訊き出したのだ」「本当かい」「本当だとも」「どんなことだい」「艶子はね、社長室から逃げてくると、野田が話があるから帰りに四階の空き部屋へ来てくれと言うので、四時きっかりに部屋を出てその空き部屋に入ったのさ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、彼が占めていた空き部屋の扉を、夜更けて、こっそりと叩く者があった。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い塗料がくすんでる高い天井、幾つかの広告ビラが鋲でとめてあるだけの裸の壁面、コンクリートの床、配置を乱して一方へ片寄せられてる卓子や椅子……見ようによっては空き部屋とも思えるその長方形の広間に、なにか嘲笑の空気が漂っていました。",
              "citation": {
                "source": "道標",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時分は、今私の書斎になって居る陰の多い、庇が長い為に日光が直射する事のない、考えるには真に工合の好い五畳が空き部屋になって居たので、其処がすぐ「お叔父ちゃんのお部屋」に定められて居た。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいだん下の　なん戸を　のぞいたり、　ちょうど　空き部屋に　なっていた　ほこりまみれの　ねどこも　さがしてみたり。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、それは大正末期までのことでかくいう百々子などの知っている頃は、昼間から鼠の眷属が跳梁する、使用不能の空き部屋になっていた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が探していたものとは余りにも違っている――暗く虚ろな空き部屋、そして額の中には多分背が高く白い空のカンバス――こういったものに対しては警戒していたはずだった。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖地には常に空き部屋があります。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは大川に面した長屋の空き部屋で、二人はもう十余日もいっしょに、その部屋へ押籠められていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "分ったことは、あの社長室の直下の四階は、石垣という建築師の事務所、その下の三階は空き部屋だ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の一（発端）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その峡谷に面した部屋は、一日に数分間（というのはちと大袈裟ですが）まあほんの瞬くひましか日がささぬので、自然借り手がつかず、殊に一番不便な五階などは、いつも空部屋になっていましたので、僕は暇なときには、カンヴァスと絵筆を持って、よくその空き部屋へ入り込んだものです。",
              "citation": {
                "source": "目羅博士の不思議な犯罪",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側は壁、左側にはただ一つ、住む人もない空き部屋がある。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いつめられた怪物は、その空き部屋の中へ逃げこんでしまった。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この空き部屋の窓には確か鉄格子がはめてあった。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈は引いてあるに違いないが、空き部屋のことだから、電球がついているかどうかわからない。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、空き部屋に重傷にうめく有本医師を発見した。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一郎はさっと顔色を変えて、教えられた空き部屋の方へ飛んで行った。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきべやを借りうけて、伝六ともども待ちうけているところへ、まもなく三宅平七が伴ってきたのは、大奥｜名代のおしゃべり坊主｜可賀でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
