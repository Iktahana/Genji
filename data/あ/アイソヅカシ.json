        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛想尽かしは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛想尽かしが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛想尽かしに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛想尽かしが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛想尽かしについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛想尽かしについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛想尽かしについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛想尽かしが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛想尽かしが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛想尽かしは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛想尽かしは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛想尽かしを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛想尽かしをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛想尽かしが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛想尽かしの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛想尽かしを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛想尽かしに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛想尽かしについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛想尽かしは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛想尽かしを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二三｜分時前までは文三は我女の夫、我女は文三の妻と思詰めていた者が、免職と聞くより早くガラリ気が渝ッて、俄に配合せるのが厭に成ッて、急拵の愛想尽かしを陳立てて、故意に文三に立腹さしてそして娘と手を切らせようとした……どうも可笑しい。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔母の言艸を愛想尽かしと聞取ッたのは全く此方の僻耳で、或は愚痴で有ッたかも知れん」ト云う所に文三気が附いた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドメートスの卑劣さに愛想尽かしていなければ、父はそんな息子のために喜んで死ぬだろうと思います。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ悪態でも愛想尽かしでも思いきり吐いてくれたなら、さぞさばさばしたいい気持になれるに異いない。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "定太郎のことでいっぱいで、あなたのことなんぞは思って見る暇もないという愛想尽かしだった。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中が透けて釜敷のようになっているんですから、今更彼方にいればなんて仰有っても始まりませんよ」「彼方にいれば、もっと出世していたろうと言うんだ」「彼方にいれば、師匠の娘さんと一緒になっているんでしょうから、そんなこと、私というものゝ顔を潰した愛想尽かしじゃありませんか？",
              "citation": {
                "source": "心のアンテナ",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駒が急に冷淡になって、愛想尽かしと言ってもいいほどツケツケ物を言った原因が、継母のお仙の口からはっきり知ったような気がしたのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方を抱いて、ちゃんと起きて、居直って、あいそづかしをきっぱり言って、夜中に直ぐに飛出して、溜飲を下げてやろうと思ったけれど……どんな発機で、自棄腹の、あの人たちの乱暴に、貴方に怪我でもさせた日にゃ、取返しがつかないから、といま胸に手を置いて、分別をしたんですよ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとできけば、浜子はもと南地の芸者だったのを、父が受けだした、というより浜子の方で打ちこんで入れ揚げたあげく、旦那にあいそづかしをされたその足で押しかけ女房に来たのが四年前で、男の子も生れて、その時三つ、新次というその子は青ばなを二筋垂らして、びっくりしたような団栗眼は父親似だった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの五十両もかわいいお艶のためとはいえ、何もあんなことをしなくてもまともな途で才覚のつかないわけではなかったが、あれも兄へのあいそづかし――いまも胸底ひそかに兄に詫びてはいるもののそれもこれ、一心を賭して乾坤二刀をひとつにせんがためではなかったか？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一｜図に決して、さてこそあの、裏で手を合わせて表に毒づくあいそづかし……お艶も江戸の女であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞやの夜、ともに泣いた弥生さまの涙を察するにつけても、あきもあかれもせぬ栄三郎様ではあるが、ここはひとつあいそづかしをして嫌われるのが第一……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつにはいっそう栄三郎をあきれさせ、あきらめさせるあいそづかしの策であろう――ウウム、いっそおもしろかろう！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おさいが彼にあいそづかしを宣告してから、周囲の者のあてつけやかげぐち、嘲笑やおひゃらかしの集中攻撃を受けた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "残した道具や衣類にみれんはないとしても、あいそづかしの一と言くらい云いに来る筈である。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどんな詰らない頼みでも、彼は必ず頼んだ以上のことをして呉れたではないか、――お祖父さんに寝つかれてからのゆき届いた心づくし、こちらは嬉しそうな顔もせず、しまいには来て呉れるな、とさえ云った、男にとっては耐え難いあいそづかしだったろう。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、未練か」「未練は、ございませぬが……女が、承知してくれませぬ」「ばか者っ」と、一｜喝して、「だから書けというのじゃ、あいそづかしの切れ状を。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
