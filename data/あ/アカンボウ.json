        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "可哀想に前の赤ん坊が目を覚ますたんびにその泣声に目を覚まし、俄かづくりの笑顔で以て赤坊をあやしてやる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問され、博士大いに閉口して、奥さま、生れたばかりの赤ん坊に、おまえは何を建設するのだい？",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ眞の氣品を有してゐるものの如く、奧ゆかしく思はれて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二人の可愛いい男の子と、それから今度生れる赤ん坊とは？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊のめじろが巣から落ちていたときは、助けて巣へ連れて行ってやった。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらめじろは、赤ん坊をまるでぬす人からでもとりかえすように僕からひきはなしたんだなあ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の徳川時代の江戸町民は永い経験から割り出された賢明周到なる法令によって非常時に処すべき道を明確に指示され、そうしてこれに関する訓練を十分に積んでいたのであるが、西洋文明の輸入以来、市民は次第に赤ん坊同様になってしまったのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも兵隊さんの細君らしい人などが赤ん坊を負ぶっているのに針を通してやっている人がやはり同じ階級らしいおばさんや娘さんらしい人であったりすると実に物事が自然で着実でどうにも悪い心持のしようがない。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大掃除の午後の路地の交互点、こわれたおもちゃに葱大根の尻尾、空瓶空ボールの交響楽、マルクス、ムッソリニの赤ん坊の夢を買わないか。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつか赤ん坊をいきなり盥の熱湯に入れて、大火傷をさせた女の話を聞いたことがある。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "驢馬が頭を下げてると荷物があんまり重過ぎないかと驢馬追いにたずねましたし家の中で赤ん坊があんまり泣いていると疱瘡の呪いを早くしないといけないとお母さんに教えました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの書の内容を逐次に点検して、これを現在の知識に照らして科学的批判を試み、いろいろな事実や論理の誤謬を指摘して、いい気持ちになろうとすれば、それは赤ん坊の腕をねじ上げるよりも容易であると同時にまたそれ以上におとなげないばかげた事でなければならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日変わっている顔の歴史を順々にたぐって行けば赤ん坊の時まで一つの「連続」を作っているが、これを間断なく見守っていない他人に向かって子供の時の顔と今の顔とを切り離して見せてそれが同人だという事を科学的理論的に証明しようとしたらずいぶん困難な事だろう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く小さい男の子であるが、中にいつも十五、六の、赤ん坊を背負った女の子が交じっている。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日に尾張町へ泊まりに行くと明るくて暖かでにぎやか過ぎて神経が疲れたが、谷中へ帰るとまた暗く、寒く、どうかすると寒の雨降る夜中ごろにみかん箱のようなものに赤ん坊のなきがらを収めたさびしいお弔いが来たりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この欲望は赤ん坊の時からすでに現われる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそうだと聞かされると同時に三年前の赤ん坊の顔と東京の原町の生活が実に電光のように脳裏にひらめいたのであった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを売っている露店商は特製特大の赤ん坊の頭ぐらいのを空に向けてジャンボンジャンボンと盛んに不思議な騒音を空中に飛散させて顧客を呼んだものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日前とくらべたらまるで赤ん坊と兵隊だ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所で赤ん坊を背負って茶漬を喰っている細君を捕えて詰問した。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ宿に三十歳くらいで赤ん坊を一人つれた大阪弁のちょっと小意気な容貌の女がいた。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は日本人で子供が二人、末のはまだほんの赤ん坊であった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日などにはよく縁側の日向で赤ん坊をすかしている。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして赤ん坊を抱いて下駄ばきで庭へ出る。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンスの生きていたころ、まだ、ほんのあかんぼうだった人たちが、今はもう、かみの毛が雪のように白くなって、まごたちのおもりをしていました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所のわきのせまい部屋にあおむけにねかされて、枕もとに、さっき店でみたおやじさんがすわっていて、そのうしろにはあかんぼうをおぶったおかみさんが、立っていました。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは病気で、あかんぼうは泣き、青い顔のひもじい子供たちは、一枚の蒲団にくるまってかたまっていました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは、母親にお茶やかゆをあたえ、あかんぼうをじぶんの子供みたいに着物を着せ、これからもお世話をしますと約束してなぐさめました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "露店の射的に、おかみさんがあかんぼうをだいて、カンテラのそばにすわっていた。",
              "citation": {
                "source": "新しい町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシがあかんぼうをさらうように、カニ円盤がスーッとおりてきては、少年をはさんで、空へのぼっていくのです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
