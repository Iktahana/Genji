        "examples": {
          "standard": [
            {
              "text": "アブサンについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアブサンは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アブサンの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアブサンについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アブサンは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアブサンの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アブサンに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアブサンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアブサンを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アブサンの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアブサンが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアブサンが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アブサンについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアブサンは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアブサンは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアブサンは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアブサンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アブサンの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアブサンの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアブサンの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紫色の影をつくる腋の下に魅力を感じて立あがると、藍色のアブサン酒を彼女のグラスに注いだ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は強烈なアブサン酒をあおると、彼女に言った。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……あたし……今ね……叔父さんに上げたお薬の残りをアブサントに溶いといたのを……みんな飲んでしまったの」「馬鹿……」「……妾……今から帰って、お医者様にスッカリ白状するわ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み残した一杯のアブサン。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の話が出ると、自分の眼前に、その飲み残した一杯のアブサンがちらついて来て、ああ、あの絵をこのひとに見せてやりたい、そうして、自分の画才を信じさせたい、という焦燥にもだえるのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こういう家にはアブサンを内緒に持っているという話よ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは甘味のあるちょっとアブサンのような味のするものであった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は東京から佛欄西の最も強い酒なるアブサントを仕込んで來て、そればかりをちびり／＼やつてゐたのだが、ゆうべはどうした拍子か興に乘り、非常に飮み過ごした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けふは思つたより書けた、わ、ね」と、お鳥はにこ／＼して出來た原稿の枚數を數へながら、一杯の慰勞がないのも氣の毒だと云つて、強いアブサントを隱した代りに正宗一本だけを注文したのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かう云ふ風で、夜は如何にアブサントを飮んでも却つて眠られず、晝間十二時までも一時、二時までも眠つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し入れには、アブサントの舶來瓶の明いたのが二本ころがつたばかりになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "腸から、また酒やアブサントや待ち合の料理や西洋料理を受けた胃ぶくろに移つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒のごとく、アブサントのごとく、そのにおいの強い間が最もききめがある。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは甘味のあるちよつとアブサンのやうな味のする酒であつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それとも酔醒めの口あたりにはアブサンが好いでせうかな。",
              "citation": {
                "source": "露路の友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笑いながらアブサンを飲む大きな山口の唇が開きかかると、再びダンスが始まり出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏で飲んで食べる、おけさ飯とアブサン。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――絵の具だらけのずぼん・蒼白い額へ垂れさがる「憂鬱」な長髪・黒りぼんの大ネクタイと長いもみあげ・じっと卓上のアブサンを凝視している「深刻」な眼つき・新しい派の詩人とあたらしい派の画家と、新しい派の女と、軽噪と衒気と解放と。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "老酒、アブサン、サンパンぐらいに致しましょうか」「ウワア。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイスキーでもアブサンでも、ジンでも、キュラソーでも何でも持って来い。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アブサントを好む者は、その天然的な芳醇さに惹きつけられるのである。",
              "citation": {
                "source": "「自然」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又或雌の小説家などはテエブルの上に立ち上つたなり、アブサントを六十本飲んで見せました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある雌の小説家などはテエブルの上に立ち上がったなり、アブサントを六十本飲んで見せました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は立上って、スタンドの方へ歩みより、マダムをよんで、アブサンを一杯もらった。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップの水にアブサンが牛乳のように混和してゆくのを、心地よく見つめて、その眼をずらしていくと、すぐ前に、マダムの笑顔があった。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジンやウォトカやアブサンでも日本酒よりはいゝ。",
              "citation": {
                "source": "酒のあとさき",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は三文詩人や落第生みたいな手のつけられない呑んだくれぢやありませんわね……」「ワ、ワシは手のつけられない呑んだくれぢやアよ」　博士は突然クララの膝から立ち上つて走り出し、アブサンの壜を抱えていきなりポン！",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、俺なんざあね、青々とした血管を見るとさね、昨夜呑んだアブサンに再会したやうな……ウウ、金が無いからアブサンなんざ暫く呑まないけれどもさ――ム、まあさう言つた気持にならあ、ね、ね、ね。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
