        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内役について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内役という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内役の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内役が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内役を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内役について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内役の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内役の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内役が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内役という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内役という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内役についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内役を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内役は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内役について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内役が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内役は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内役の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内役は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内役は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それゆゑ、繪本の畫伯もつい、（蓬莱も龍宮も、同じ樣な場所なんだから）浦島さんの案内役も、この石龜に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、絵本の画伯もつい、（蓬莱も竜宮も、同じ様な場所なんだから）浦島さんの案内役も、この石亀に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」日本ノ旅人デス「案内役が陳和卿では不安でございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内役は林野局の局長のＡさんである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に棹さすのが一人、後に櫓をこぐのが一人、客は私と案内役の名鉄のＭ君である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、案内役の島民少年にバスケットの値段を聞かせる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　美和子は、姉の圭子が、このいやな案内役を体裁よく、自分に押しつけたのだと思うと腹が立って仕方がなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、フォークソングの人気を押し上げたＰＰＭ（ピーター・ポール＆マリー）というグループを案内役にボブ・ディランを聞き始め、そこからピート・シーガー、ウッディー・ガスリーとさかのぼっていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、かれはその案内役で、いっさいの勘定はいつでもロイドに負担させていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勿論そのつもりだらう、そしてその案内役は勿論ワタシでなければならないね。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内役の伊勢崎君もその顔を見て流石に腰を浮かした。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に棹さすのが一人、後に櫓を榜ぐのが一人、客は私と案内役の名鉄のＭ君である。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町にいるわたくしの娘が孫たちをつれて躑躅を見にくるとこのあいだから云っていたのですが、それが今日の日曜にどや／＼押掛けて来たもんですから、ばあやが案内役で連れ出して行きましたよ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、確かあの、煙の立っているところでございます」　もう私は、案内役ができなくなりましたので、そう言ってふるえる手で向こうを指差しながら、皆様に先に立っていただきました。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一同が数字の書かれたコンクリートの里程標の立っている処までやって来ますと、案内役の保線課員は片山助役へ、四遍目の事故があったのは昨日の事だからもう後片附けは綺麗に済んでいる旨を断って、現場に関する一通りの説明を始めたんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、もうこれ位で……」　助役はそう言って、部下の機関庫係員や案内役を促しました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日前に此処で案内役の保線課員が彼等に話した推定は全く正しく、その通りに黒い男は豚を縛って、そしてその哀れな犠牲者の前へ沢山餌をバラ蒔いているんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世にあつた頃は飛行国の民主党の一等書記官の役を二十年も務め終せたといふ私の案内役になつた一亡霊がそつと私の耳に囁いたところに依るとあの二人の若者は後世のソフイストの先駆者であるといふことだつた。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のしたたりがなくなって、案内役が休んだでは、追っかけてゆくことが出来ませんからねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う、案内役を逃げたい思う一心で、何でも早う済めばよいと、思うとったけにのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は、来年はひとつアメリカへ出かけような――だから、一処になら僕も行きたいんだよ――一年位ひの予定で……女房子も伴れて行くと好い……案内役になつてやらア――十何年もたつんだね、もう、阿父さんが帰つてから！",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俊夫君の案内役さ」「や、俊夫君、ご苦労様」　と、白井刑事は俊夫君を軽蔑するような口調で言いました。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "下諏訪の桔梗屋で、本社の山中氏と私達父子は、支局の中島氏と、ヒユッテの持主で篤実の山の研究者であり、「山郷風物誌」などの興味ふかい著述をもつてゐる長尾宏也氏といふ霧ヶ峰スキイ場の開拓者として知られてゐる青年が、わざわざ山の案内役におりて来たのに、紹介されたりして、急に心強くなつた。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷氏は二度も私を迎ひに来たが、或る日其の頃政友会の幹部であつた尾崎行雄氏が醍醐寺を訪問するといふので、案内役の渋谷氏が私をも誘つたので其の一行に加はり、所謂醍醐の花見で有名な其の寺を訪れ、宝物を見せてもらつたが、本当の案内役は島文博士であつた。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案内役の夫人についで、やがて融は食堂へおりて行つたが、時間がちよつと早かつたので、ホールで待つことにして、隅の方の椅子にかけた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そう何でもかんでも善哉じゃあ案内役の僕が困るが、いま「女の見世物」ってのが出て来たようだが、じつは、話はこの「女の見世物」と大いに関係があるんで――と言っても、僕がそんなところを君を引きまわすわけじゃないから安心したまえ。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私がたんのうする迄いるには、案内役に立たれた永山氏が多忙すぎる。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
