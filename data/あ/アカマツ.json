    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese red pine (Pinus densiflora)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "帰りがけに、雨も小止みになったので、自動車で韮崎の町を突き切り、釜無川の東岸に沿うて、露出しているところの七里岩を、向う岸の美しい赤松の林から眺めた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石も多いがしかしそれに生え越して瑞々と茂った、赤松、樅、山毛欅の林間を抜けて峯と峯との間の鞍部に出られた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松とちいさな雑木しか生えていないでしょう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水旅館赤松の林をこえて、くらきおほなみはとほく光つてゐた、このさびしき越後の海岸、しばしはなにを祈るこころぞ、ひとり夕餉ををはりて、海水旅館の居間に灯を点ず。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松とちひさな雑木しか生えてゐないでせう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、新富座の一番目「赤松満祐」中幕「勧進帳」二番目リットンの翻案「人間万事金世中」、大入りにて、六十余日を打ち続け、京浜在留の外国人より、引幕を贈りて総見物あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天氣はさつぱりと晴れて赤松の梢にたかく囀鳥の騷ぐをみた愉快な小鳥は胸をはつてふたたび情緒の調子をかへた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとしの秋、ジッドのドストエフスキイ論を御近所の赤松月船氏より借りて読んで考えさせられ、私のその原始的な端正でさえあった「海」という作品をずたずたに切りきざんで、「僕」という男の顔を作中の随所に出没させ、日本にまだない小説だと友人間に威張ってまわった。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水品の美、真に赤松氏利根川図志の記するところの如し。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖から下を覗くと數丈の赤松が繁つて其間に碧漫々たる海が見える。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松は裸が好きで枝葉をだん／＼梢の方へこき上げて行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き当りに見える丘陵は石灰質の白い膚を現わしているところもありますが、大部分雑木に覆われ、丘陵の背にはその後の九十九谷を埋めている赤松の林が波打って来て、その波頭を現すように丘陵の背に柔かい緑の並列の姿を現しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根山の根本のところは松ヶ丘と同じく雑木に赤松を加えて覆われていますが、先きに近づくほど丘陵の岩膚を現わしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松の陰に「山門制戒」の高札も立っている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜面の肌の青草の間に整列している赤松の幹に陽光が反射して、あたりはいや明るみに明るんでいる。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の別荘なぞは倒れて来た上の赤松が洋館の屋根から床へ真つ二つにめり込んで母屋なぞは木つ葉微塵に崖下へ転落してゐたものである。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の芝生や立木や、盆地を隔てた向うの丘、方々の丘の赤松、霧と燈火の九十九谷その他は、歌にある通りである。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の小さな祠や鳥居、赤松や木畫にある庚申薔薇の中門には眞萩や山吹がしだれかかり、その中門から門庭へ出入りができ、そこにはまた木※の植込があり、應接室の窓には八つ手や松ヶ枝が透かして見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は楊と稚松と雑木の緑と鬱した青とで野趣そのままであるが、遊園地側の白い道路は直立した細い赤松の並木が続いて、一、二の氷店や西洋料理亭の煩雑な色彩が畸形な三角の旅館と白い大鉄橋風景の右｜袂に仕切られる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遡航は氷室山の麓は赤松の林と断崖のほそぼそとした嶮道に沿って右へ右へと寄るのが法とみえる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛堂の敷地には亭々たる赤松の五、六がちょうどその前廂の斜に位置して、そのあたりと、日光と影と、白砂と落松葉と、幽寂ないい風致を保っていた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "点綴するには赤松がある、黒松がある、矮樹がある、疎林がある。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりから丘陵の間はやや斜面に展けて赤松の細い幹が縁辺に林立し、怪奇な岩層の風致に一種の繊細味を交えてゆく。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の小さな祠や鳥居、赤松や木槲、楓、柏槙、箱根笹、つくばひのそばの土賊、春日燈籠、通草の棚、すべて歌にある。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその縁故をもって赤松左兵衛督殿に仕え、天正九年千石を給わり候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三年四月赤松殿｜阿波国を併せ領せられ候に及びて、景一は三百石を加増せられ、阿波郡代となり、同国｜渭津に住居いたし、慶長の初まで勤続いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶長五年七月赤松殿｜石田三成に荷担いたされ、丹波国なる小野木縫殿介とともに丹後国田辺城を攻められ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぎ、もみ、つが、ひのきがや、いぬがや、あかまつ、くろまつ、やくたねごよう、こなら、かしは、かしはなら、くぬぎきり、つるまんりよう。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通みなさんのお目にふれる木で言ひますと、（イ）針葉樹に屬するものは、あかまつ、くろまつ、もみ、つが、すぎ、ひのき、かや等。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ松でもあかまつは山に適してゐますが、くろまつは潮風に最も強い木です。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
