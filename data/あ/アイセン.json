        "examples": {
          "standard": [
            {
              "text": "土地の売買を周旋してもらった礼として、仲介人に少なからぬ間銭を包んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "産地から市場へ届くまでに幾つもの問屋が間銭を抜くため、末端価格が跳ね上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかくの骨折りなんだから、これくらいの間銭は取っておくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "融資の実行に際して、書類作成の事務手数料という名目で一定の間銭を差し引かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "興行の取り次ぎを依頼した手前、興行収入の二割を間銭として納めるのがこの世界の慣わしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "荷主と運送業者の間に立つブローカーが取る過剰な間銭が、物流コスト増の一因となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
