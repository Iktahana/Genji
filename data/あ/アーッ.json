        "examples": {
          "standard": [
            {
              "text": "私は毎日アーッについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーッという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーッの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーッが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーッを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーッについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーッの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーッの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーッが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーッという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーッという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーッについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーッを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーッは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーッについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーッが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーッは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーッの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーッは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーッは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "久助君はその爽快味を満喫するため、大きく口をあけて、ハアーッハアーッと呼吸しながら、家まできてしまったのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はじきに過ぎたが、まだ近処を襲っている音だけは、ザアーッと盛んに聞えている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは忽ちカアーッと逆上した。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただアダリーがキアーッと叫んだ悲鳴が聞えただけである。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ガガアーッガガアーッ……助けて助けてッ……」　金剛力に掴まれた中野学士の服地がベリベリと破れ裂け初めた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あ伊豆の大島へ行きましたがね、から、唐人みたようなお百姓でも、刃あたりが違うと見えて、可いなアーッていやあがるんで。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その間に、アーッとため息をもらした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、アーッと小さくため息をもらした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が思わずカアーッとくる匂いだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆はその方へ手を振りあげて、ワアーッと叫んだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度、ワアーッと叫んだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　悪寒が彼の背筋をザアーッ、と走った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "カアーッと逆上せていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "健は暗がりの納屋の中にいて、一人でカアーッと赤くなった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯の火だけでそれを見ていると、寒気がザアーッと身体を走った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビラが撒かれると、みんなはハッとしたように立ちどまったが、次にはワアーッと云って、ビラの撒かれたところへ殺到してきた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッハ、アッハ、アッハ、アーッ。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何者かアーッ」　と又歩哨が叱鳴りました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がサアーッと吹くとブルブルッと身ぶるいの出るほど寒い。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と唾液を嚥み込み嚥み込み相手の顔を白眼み付けたが、その瞬間に……ヤアーッ……と叫んで天井に飛び上りたくなった。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アーッ……アーッと。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アーッハッハッハッハッ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまんま特別三等の寝床の中で足をツン伸ばしてアーッと一つ大きな欠伸をしたもんですが、そのトタンに桑港で知り合いの領事館の人からお土産に貰った小さな紙包みのことを思い出しました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……桔梗様アーッ」と呼ばわった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗様アーッ」と呼ばわった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お頭アーッ」　と呼ぶ声がした。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父様アーッ」　と、お蘭が、その廊下から駆け込んで来た。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
