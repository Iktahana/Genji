        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、椿岳の感嘆者また蒐集家としては以上の数氏よりも遅れているが、最も熱心に蒐集したのは銀座の天居といっては誰も余り知るまいが、天金といったら東京の名物の一つとしてお上りさんの赤ゲットにも知られてる旗亭の主人である。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやその他の月卿雲客、上臈貴嬪らは肥満の松風村雨や、痩身の夷大黒や、渋紙面のベニスの商人や、顔を赤く彩ったドミノの道化役者や、七福神や六歌仙や、神主や坊主や赤ゲットや、思い思いの異装に趣向を凝らして開闢以来の大有頂天を極めた。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重橋前の玉石砂利にオデコを埋めて涙を流す赤ゲット連だよ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して日本人は赤ゲットを尊敬してもらいたい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして日本のブル思想と偽もののプロ思想を全滅さして、すべてを赤ゲット化してもらいたい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も記者と同じようにペンを荷いだ職人で、都会カブレをしなければ飯の喰えない人種である……赤ゲットを尊敬は出来るが、自身赤ゲットになることは容易な事業でない……寧ろ自分の生活の無意義を呪うあまり、こんな議論に落ちて来た事を互によく自覚していたからである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎と火鉢は私の部屋には無かったけれど、今迄敷いていた赤ゲットを、四ツに畳んだのを中央へ持出して、其でも裏反しにして勧めると、遠慮するのか、それとも小汚いと思ったのか、敷いて呉れないから、私は黙って部屋を飛出した。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
