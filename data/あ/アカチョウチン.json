        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "店の軒には紅屋に因んだ赤提灯が、いかにも助かりましたという感じで、京都らしくぶら下っている。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「べにや」の軒の長い赤提灯、円いピンク・ブルウ・レモンイエローの提灯の灯りが、高瀬川の流れに映って、しみじみと春の夜更けの感じだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう遊女屋の間に混って真面目な表造りの医院があったり、とてつもなく大きい赤提灯を軒先に垂らした煙草屋があったり、この郭中で唯一の引手茶屋があったり、しょっちゅう真魚板を叩く音の絶えない蒲鉾屋があったり、だいぶ馴れては来ましたものゝ、まだわたくしには珍らしい世界です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、赤提灯か」　温泉場などでは、怪しい女のいる家には目印の赤い門燈がついていて、赤提灯という通称が春を売る商売の代名詞になっていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、文中商品の項に青提灯とか、赤提灯とかしてありますが、勿論これは真珠を指し示しているのです。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暮れ方、蝙蝠の出盛るころになると新道は急に人足が繁くなって、顔を真っ白に塗った若い女たちが射的屋の赤提灯の下などにちらちら動いていた。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はまだ人影も疎な村道だったのに、もううちの隣りの本屋からはじまって理髪屋、雑貨屋、文房具屋、魚屋、飲屋の赤提灯ずらりと軒並の店で、バスの停留場前の雑貨店は百貨店式にガラスのショウ・ケイスをいくつも並べ、資生堂の化粧品、ネクタイ、バッグ、ホームドレス、パラソル。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか、盛り場で酒を飲み、下宿に戻る途中、赤提灯を軒にぶら下げた売春宿があった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一週間後、一人で酒を飲み、夜｜更けて戻る時、赤提灯の前を通りかかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時過ぎに赤提灯の裏口から忍び出て、下宿に戻った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤提灯の一件は、三田村にも話さなかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大きな赤提灯をぶら下げた売春宿である。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "山門の中心からは、これも巨大な一足の草鞋と、赤提灯とがぶら下げられてある。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田舎者は、なんでも珍しいもんじゃから、……」「もっと珍しいものがありまさあ」　観音堂の横を入り、「一膳めし」という赤提灯の出ている大衆食堂ののれんを潜った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
