    "definitions": [
      {
        "index": 1,
        "gloss": "icy road",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイスバーンは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスバーンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスバーンに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスバーンが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスバーンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスバーンについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスバーンについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスバーンが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスバーンが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスバーンは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスバーンは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスバーンを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスバーンをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスバーンが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスバーンの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスバーンを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスバーンに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスバーンについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスバーンは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスバーンを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
