          ],
          "literary": [
            {
              "text": "何を考えたってお前、己ら手合いは人間様の様に智慧がありあまんじゃ無えから、けちな事にも頭を痛めるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘右衛門の苦悶は絶頂に達したが、頭を痛めるのみでどうすることもできなかった。",
              "citation": {
                "source": "風呂供養の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出し物の選択には、彼らもなかなか頭を痛めるのだ。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時の書物は鵜呑にすると、頭を痛めるやうに胃の腑を損ねる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも毎日見ては段々に面白味が減じて、後には頭の痛む時などかへつて頭を痛める料になる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは謡を聞きあるいは義太夫を聞いて楽しんだのは去年のことであつたが、今は軍談師を呼んで来ようか、活動写真をやらして見ようかとの友達の親切なる慰めはかへつて聞くさへも頭を痛めるやうになつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東京を踏み出すと、その第一には必らず頭を痛める癖があるが、この度は今日になつてそれが始まつた、湖上で頂天から日に照りつけられた爲めであらう。",
              "citation": {
                "source": "道學先生の旅",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその個々の人々の一生及び相互の關係迄吾々は頭を痛める事なく覗ふ事が出來る。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔たりの関は見えぬが、仕切る硝子は透き通りながら、突き抜けようとすれば鼻頭を痛めるばかりである。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、税金で頭を痛めるのは何処様でも同じことでしょうが、税金ではほんとに身を切られるような想いを致します。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純な私は従妹との結婚問題について、さほど頭を痛める必要がないと思っていました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は頭を痛めるという我儘な彼の申し出から二人は歩いた。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
