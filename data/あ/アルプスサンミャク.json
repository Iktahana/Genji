        "examples": {
          "standard": [
            {
              "text": "私は毎日アルプス山脈について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルプス山脈の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルプス山脈が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルプス山脈について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルプス山脈の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルプス山脈が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルプス山脈という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルプス山脈についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルプス山脈は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルプス山脈が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルプス山脈は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルプス山脈の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルプス山脈は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルプス山脈は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "博士は手帳を出して、「あそこに見える高い山脈は月世界のアルプス山脈で、今吾々の足下に拡がっているのが、ベポアー海だ。",
              "citation": {
                "source": "月世界跋渉記",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃場を失った聯合軍はピレネ山脈とアルプス山脈の内側で、悉く殲滅されるであろう。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて僕はやや諸国を遍歴して今アルプス山脈の中にいるのであるが、日本の国土にいるような気もしている。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり新しき次代の世界文明はこのアルプス山脈の周囲からは生れず、何かもっと東のウラル、アルタイ、そして海の中なる日本もまんざらそれに関与出来ぬこともない文明の原動力が潜んで居そうに思うのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このロケット兵団は、アルプス山脈地帯にかたまっている火星兵団を尻目に、空中高く飛出し、示威飛行を始めた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプス山脈中レエザンという村は、人口が四〇〇であるが、その出生は一年わずか八人ほどである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位置はアルプス山脈に位しているが、しかし高過ぎることはないから、おそらく空気は最も清浄で衛生的であった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三群は光の磁気に対する影響で、こは正にアルプス山脈のワイスホルン峰に比すべきものか。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルンに生まれアルプス山脈の傍で育ち山の中を遠く広く歩き回りその荘厳さによって深く感動していた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプス山脈について歌いアルプス住民について書き彼らの単純な生き方は町の住民にとって警告であると宣言した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然における大規模な創造物たとえばアルプス山脈だけではなく彼が徹底的に調べた人間の心臓だけではなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅行の最高の成果は詩「アルプス山脈」であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年ハラーはアルプス山脈への旅行を行い毎回大量の試料を持って帰った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプス山脈が六個も積み重なったようでした。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
