        "examples": {
          "standard": [
            {
              "text": "アノニムについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアノニムは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アノニムの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアノニムについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アノニムは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアノニムの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アノニムに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアノニムが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアノニムを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アノニムの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアノニムが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアノニムが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アノニムについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアノニムは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアノニムは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアノニムは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアノニムについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アノニムの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアノニムの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアノニムの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそれにしても、虚榮心においては相手は「世間」といふもの、詳しくいふと、甲でもなく乙でもないと同時に甲でもあり乙でもあるところの「ひと」、アノニムな「ひと」であるのに反して、名譽心においては相手は甲であり或ひは乙であり、それぞれの人間が個人としての獨自性を失はないでゐるところの社會である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚榮心は本質的にアノニムである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき彼はアノニムな「ひと」を對象とすることによつて彼自身アノニムな「ひと」となり、虚無に歸する。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行はアノニムなものである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "名譽心といふのはすべてアノニムなものに對する戰ひである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま世間の評判といふものはアノニムなものである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノニムなものと抽象的なものとは同じではない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "名譽心はアノニムな社會を相手にしてゐるのではない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがアノニム（無名）のものであるといふのみでない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても、虚栄心においては相手は「世間」というもの、詳しくいうと、甲でもなく乙でもないと同時に甲でもあり乙でもあるところの「ひと」、アノニムな「ひと」であるのに反して、名誉心においては相手は甲であり或いは乙であり、それぞれの人間が個人としての独自性を失わないでいるところの社会である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚栄心は本質的にアノニムである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき彼はアノニムな「ひと」を対象とすることによって彼自身アノニムな「ひと」となり、虚無に帰する。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "名誉心というのはすべてアノニムなものに対する戦いである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま世間の評判というものはアノニムなものである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "名誉心はアノニムな社会を相手にしているのではない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがアノニム（無名）のものであるというのみでない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
