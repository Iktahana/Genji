        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ物語について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ物語の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ物語が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ物語について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ物語の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ物語が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ物語という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ物語についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ物語は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ物語が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ物語は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ物語の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ物語は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ物語は興味深い例である。",
              "source": "幻辞"
            }
