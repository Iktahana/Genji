          ],
          "literary": [
            {
              "text": "そして、召し上がり物にあつものをこしらえてさしあげようと思いまして、あおなをつみに出ました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜も昼もお祖母様が恋しくて泣いてばかりいらっしゃいまして、召し上がり物なども少のうございます」　とも歎いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮はそれ以来健康をおそこねになり、召し上がり物などは少しもおとりにならなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々秋のみのり時になりますと、この神さまの召し上がり物に、生きている人間を一人ずつ供えないと、お天気が悪くなって、雨が降ってもらいたいときには降らないし、日の照ってもらいたいときにも照りません。",
              "citation": {
                "source": "しっぺい太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……暑さは強し……貴方、お身体に触りはしますまいかと、――めしあがりものの不自由な片山里は心細い。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりあがりものの素質をまるだしにしてしまって、だが、その気持ちは子供のような歓びなのだ。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おこぼれを頂戴したその成りあがりものはそう自己弁護するのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、お願ひですから、もつと、どしどし、召しあがりものを召しあがつてちやうだい……。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは生徒の中のよほどの飛びあがりものででもなければやらない仕草だった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分を眼立たせたいためばかりに、ひとり列をはなれて軽業師のような真似をしていた飛びあがりもの！",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ついさっき曾根少佐に対してとった自分の態度が、やはり飛びあがりものの態度ではなかったか、と思ったからである。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしな真似をしてやがると、人が入口からみてるともしらず、やい、だんなさまのお召しあがりもののなかへ何をいれた！",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "塁濠は宏大、天主や楼閣のけっこうさ、さすがに、秀吉を成りあがりものと見くだして、大徳寺では、筑前守に足をもませたと、うそにも、いわれるほどなものはある。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
