    "definitions": [
      {
        "index": 1,
        "gloss": "red wine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どんな姿で、どんな匂いでどんな味で――それが自分達に遇いに来るか客達は赤葡萄酒の渋味の一杯にまず感覚を引立てて無心のうちに待ちうける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困りますですね」と言ったしまは、それでもどっかへ出て行って台附コップへ赤葡萄酒を八分目ほど入れたものを運んで来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食――冷肉・木犀果・ビスケット・赤葡萄酒。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜婦人に慇懃なヒュー先生の方は、自分の棺の架台を、テーブルの上座近くのその位置から、あの包屍布を着た小柄な肺病の女の近くへ移して、上機嫌で彼女の側へどかりと腰を下し、赤葡萄酒を髑髏にいっぱいつぎこんで、以後お心安くとそいつをぐっと飲み干した。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方へレス産の黄｜葡萄酒、北方リオハ産の赤葡萄酒。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北リオハ産の赤葡萄酒！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり好い月夜なので、ドン・ホルヘもつい、うろ覚えの南部ヘレス産の黄葡萄酒・北部リオハ産の赤葡萄酒なんかと、むかし主馬頭夫人がやったように月を仰いで低唱しようとしたところが、やっぱりいけない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北リオハの赤葡萄酒！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの爺さん」は僕等の隣に両手に赤葡萄酒の杯を暖め、バンドの調子に合せては絶えず頭を動かしていた。",
              "citation": {
                "source": "彼　第二",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから梨も砂糖ばかりで煮てはいけませんが赤葡萄酒で煮ると大層結構です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の鍋へ例の通りバターを溶かしてメリケン粉を焦げるようによくいためてまた玉葱の刻んだのを一つその中でいためて狐色にして今湯煮た汁を一合と赤葡萄酒を一合｜注して塩胡椒で味をつけて、湯煮た尾を入れてまた一時間ほども弱い火で煮ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　モヤ、食糧品を売るコムナール〔国営の食堂兼食料品店〕で、赤葡萄酒を買う。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりは、「オオル・リイニュ」とか、「タン・ド・クウヴ」などという名高い赤葡萄酒を産出するブウルゴオニュ州の西南の谷間で、ヴェニス提灯ほどもある大きな葡萄の房が互いに触れあってチリン・カリンと鳴っているのである。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "燕尾服の自殺　――ブルゴオニュの葡萄祭り――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤葡萄酒の盃をほしたまえ」　　　　　　　二　ジョヴァンニは飲んだ酒にやや熱くなって、自分の下宿へもどった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでまあ、ゆつくり腰を据ゑて赤葡萄酒の一杯も飮めるといふわけかな。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．この赤葡萄酒は一壜四マルクだ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その葡萄酒は赤葡萄酒であって、それがこぼれたパリーの場末のサン・タントワヌ★の狭い街路の地面を染めたのであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラレット　　ボルドー産の赤葡萄酒。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "街上に葡萄酒の樽が壊れて、流れる赤葡萄酒を飢えた人々が争って飲む光景。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には肉饅頭だの、ジャム菓子だの、甘パンだの、オレンジだの、赤葡萄酒だの、無花果だの、チョコレエトだのが入ってるのよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は滋養になるビイルのほかに、なお赤葡萄酒を毎日一杯ずつ飲ませたのだけれど、それもなんの役に立ったろう。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの赤葡萄酒が、私には強すぎたのかもしれません。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手には、白布で覆われたテエブルが備えてあって、磔像と七本枝の燭台と、赤葡萄酒を盛った杯と、皿にのせた乾葡萄菓子の一片とが、その上においてある。",
              "citation": {
                "source": "予言者の家で",
                "author": "BEIM PROPHETEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子は一時間読み続けたあとで、赤葡萄酒の杯から、ふるえながら一口飲むと、さらに別の宣言書を手に取った。",
              "citation": {
                "source": "予言者の家で",
                "author": "BEIM PROPHETEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤葡萄酒や麦酒は残っていたが――我々が極端な節酒家であることの証拠である――ビスケットは完全になくなって了った。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはある紳士を知っていたが、その人は赤葡萄酒の通であることを、一生自慢にしていた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはむしゃくしゃまぎれに、赤葡萄酒やシェリー酒をコップでがぶがぶ飲んだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "安土竜太郎がふいに立って外へ出て行ったかと思うと、間もなく赤葡萄酒の――途中で日本製のあくどいレッテルを剥取って――壜を二三本抱えて戻って来る。",
              "citation": {
                "source": "溜息の部屋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤葡萄酒を抜いて、血のしたたるような肉を食い、葡萄酒を飲んだ。",
              "citation": {
                "source": "食べたり君よ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
