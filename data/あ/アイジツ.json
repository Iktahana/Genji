      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "winter daylight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛日は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛日が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛日に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛日が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛日について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛日についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛日について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛日が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛日が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛日は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛日は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛日を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛日をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛日が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛日の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛日を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛日に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛日について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛日は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛日を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "北町の通では、その大きな樫の樹、それの西風に鳴る潮のやうな響、それから綺麗な娘の居た二階家の欄干、愛日学校の小さい生徒の群、それを通り越すと、通りが細く汚くなつて、何の興味をも惹かなくなつて了ふ。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も彼も、もう駄弁の種もすつかり尽き果てゝ稍ともすれば沈黙勝ちな、夜もなく、昼もなき怠惰な村の愛日抄を書かう。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斎の「愛日楼文」は冠山が稿本を借鈔し、小泉侯遜斎片桐貞信の抄する所の詩と与に合刊したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人の藏書の處は、愛日精廬と稱し、最初その藏書志を四卷作つたが、後になつてだん／＼増補して、愛日精廬藏書志四十卷を作つて、自分の家に藏してゐる書籍の最もよいものを解題したので、これは矢張活字で印刷した。",
              "citation": {
                "source": "藏書家の話",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の場所にて釣りたらば、水は浪立ずして、熨したる如く、船も竿も静にて、毛ほどの中りも能く見え、殊に愛日を背負ひて釣る心地は、嘸好かるべし。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤一斎の集『愛日楼文』の如きまた頼山陽の『日本外史』の如き皆｜予め敬所の校閲を俟って然る後刊刻せられたといわれている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "近書の“ある市井の徒”を手にとつて、ぼくは氏の老成さらに健康と愛日の晩生にめぐまれつつあるを知り、遇然、ぼくは又、ぼくの顏を氏に示して、いゝ顏になつたなあ、とほめられたわけである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
