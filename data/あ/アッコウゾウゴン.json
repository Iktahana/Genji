        "examples": {
          "standard": [
            {
              "text": "毎日、悪口雑言について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の悪口雑言戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "悪口雑言の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "悪口雑言という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは悪口雑言について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "悪口雑言の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "悪口雑言に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは悪口雑言を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での悪口雑言は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、悪口雑言は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "悪口雑言は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な悪口雑言を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「悪口雑言」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪口雑言」という概念について深く考察する必要があります。",
              "source": "幻辞"
