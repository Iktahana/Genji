[
  {
    "uuid": "4d257865-d8f2-5693-9c8e-9306593a2f51",
    "entry": "暗示",
    "reading": {
      "primary": "あんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
