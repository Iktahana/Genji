        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗夜行路について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗夜行路の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗夜行路が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗夜行路について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗夜行路の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗夜行路が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗夜行路という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗夜行路についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗夜行路は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗夜行路が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗夜行路は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗夜行路の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗夜行路は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗夜行路は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夜更けていたけれども、それから知人の家に行き、何でもいいから志賀直哉のものを借してくれと言い、「早春」と「暗夜行路」と、それから「灰色の月」の掲載誌とを借りることが出来た。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」　大袈裟な題をつけたものだ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾の道と云えば「暗夜行路」できき知った町の名である。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀直哉の「暗夜行路」は青年から壮年にわたる日本の一知識人の内的過程を描いたものとして意義をもつものである。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」をくりかえしよんだ私たちの年代のものは、千円の本をつくる作家志賀直哉に対し、もし事実であるならば暗然とした心もちがある。",
              "citation": {
                "source": "豪華版",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」前篇を終った志賀直哉は大正十四年ごろから「山科の記憶」その他の短篇を書きだした。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」と前後して「多情仏心」を完結した里見※は、有島武郎の兄弟であっても、武郎とは非常にちがった常識と古さに自分のモラルの土台をかため、自身のまごころ道にそろそろ安住しはじめた形であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと彼の帰つた後、僕はベツドの上に転がつたまま、「暗夜行路」を読みはじめた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「暗夜行路」はかう云ふ僕には恐しい本に変りはじめた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと彼の帰った後、僕はベッドの上に転がったまま、「暗夜行路」を読みはじめた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「暗夜行路」はこう云う僕には恐しい本に変りはじめた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "長篇「暗夜行路」を一貫するものは実にこの感じ易い道徳的魂の苦痛である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」の後篇はこの同氏のテクニイクの上にも一進歩を遂げてゐるものであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから我が誌の創作欄は創刊号において幸田露伴氏の「運命」がかなり問題となったが、大正十年新年号に志賀直哉氏の一大長篇「暗夜行路」出ずるに及んで異常の衝撃を与えた。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間まで長い小説をかいていたとき、伸子がずっと机の上にのせていたのは「暗夜行路」であった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」を思ってみても、その作品の世界は、伸子のいまの生活感情にとって、前方にはなくて、後方にあった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が、ぼんやり息苦しい生活のせまさを感じ、そこを突破したいうずきを感じている、その限界が、「暗夜行路」にも感じられるのであった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを『暗夜行路』の作者がやってのけていることだ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『暗夜行路』の作家は、いつの間にか、偶然の特等席に引退してしまっていたのだ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀直哉の「暗夜行路」後篇についてです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――○――　志賀直哉の「暗夜行路」は、昨年終りの部分が出来て、前・後、完結しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗夜行路」の主人公謙作が京都で鳥毛立屏風の絵にあるような女（この絵覚えていらっしゃるかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、「暗夜行路」は自伝風な作と思われているが、実際はそうでない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伸子」のとき「暗夜行路」がそうでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして「暗夜行路」を書いた時任謙作の志賀直哉には頭を垂れてゐる。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾道時代に構想がはじまる『暗夜行路』は千葉県我孫子でも書き継がれ、完結するのは奈良の志賀直哉旧居でのことであり、松江では志賀直哉が滞在した家にまた芥川龍之介がすごすということなども起こって、エピソードを拾って歩くだけでも大ごととなる。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、約三十分間ほどは、敵に移動を覚られまいとするため、松明もつかえず、ただ打ち振る火縄と星を頼りの暗夜行路だったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼はそこに席のあたたまる間もなく、月江と次郎を茶屋にのこして、またぞろ小仏の二｜更を暗夜行路の人となりました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼岸のない暗夜行路、それが、終生｜辿らねばならない自分の生涯だろうか――と、お綱がホッと息をした時、睫毛の涙の光ではなく、ボウとあたりが明るくみえた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうも致してみるか」　暗夜行路にひとしい。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
