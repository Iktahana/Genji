        "examples": {
          "standard": [
            {
              "text": "私は毎日アミンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アミンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアミンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアミンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アミンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアミンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アミンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアミンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアミンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アミンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアミンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアミンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アミンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアミンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アミンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアミンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアミンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアミンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アミンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアミンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "からいおひやをよばれる、ペハアミントをよばれる、いやはや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の大晦日は林町で二三時頃まで過し、雪の凍ってつるつるする街路を、Ａと小林さんと三人で、頼まれたペパアミントを探し乍ら、肴町を歩いたのを思い出す。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チャアミングよ」というお嬢さんもいれば、「日本人で、こんなに大きい。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　私は早速、このチャアミングな發見を神西清に手紙で書いてやつた。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自分の名前を言はれると、やつとわれに帰つたやうに、「もう、あんなに困つてらつしやるわ」　と、ロベエル・コンシャアルをいたはるやうに、その方へやさしく笑ひかけ、「その女のひとは、チャアミングな方でしたの？",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三十人の可愛らしい楽士が養成され、赤地格子縞の洋装に鳥の羽根のついた帽子を斜めにかぶって、ちょっとチャアミングないでたちで、各所の余興にサービスをして好評であった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応もっともな考え方であるが、老人の食慾減退は、少なくもその大部分は食事中のチアミン即ちビタミンB1の欠乏によるということが知られている。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポウランドの穀物及びカロライナの原棉は、バアミンガムの器物及びグラスゴウのモスリンと交換されるであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてステッテン(24)は重窒素で標識したコリンおよびエタノールアミンを使って実験を行った。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グアニド酢酸（グリコシアミン）を摂取させると、アミノ酸やタンパク質のばあいと違ってクレアチンまたはクレアチニンの排泄が増加した(58)。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　アアミンガアド　その最初の朝、セエラは、室内の生徒全体が自分を熱心に見守っているのを感じながら、ミンチン女史のそばに坐った時、自分と同じ年頃の少女が一人、明るい、懶げな青い眼でセエラをじっと見ているのにじき気が付きました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、アアミンガアド・セント・ジョンって名なのよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とアアミンガアドは飛び上りそうになっていいました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう訳で、アアミンガアドは、いつでも恥しめられたり、泣かされたりしていました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アアミンガアドは頭を振りました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アアミンガアドは、さっきのミンチン女史のように聞き返しました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」客間を通り抜ける時、アアミンガアドは囁きました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアミンガアドはふと立ち止って眼をみはり、息を呑んで、「お話を拵えるんですって？",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアミンガアドは、なぜどうして何を捕えるのだか、さっぱりわかりませんでしたが、セエラの眼付にはすっかり魅せられてしまいました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもいい、きっと面白いことに違いない――アアミンガアドは胸を躍らせながら、爪先立ってセエラの後から戸口に近づきました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アアミンガアドは、セエラから人形へ、人形からセエラへ眼を移しました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方はアアミンガアド・セント・ジョンさんなの。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアミンガアドさん、こちらはエミリイと申します。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "航海の話、印度の話――しかし、アアミンガアドを一番｜恍惚させたのは、お人形についてのセエラの空想でした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアミンガアドは、たいていの子なら声をあげて泣き出すところだが、と思いました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アアミンガアドは微かに口を開けたままでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアミンガアドは、セエラが今にも泣き出すかと思いましたが、セエラはやはり泣きませんでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アアミンガアドは、セエラを見つめるばかりでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
