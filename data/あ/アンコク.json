        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗黒について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗黒の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗黒が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗黒を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗黒について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗黒の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗黒の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗黒が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗黒という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗黒についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗黒は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗黒について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗黒が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗黒は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗黒の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗黒は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗黒は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一、精神といふものは、その根拠を自然の暗黒心域の中に持つてゐる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大石の下になって凍っている雪などを見ると、内部からの光の反射を妨げるために、暗黒で透明で、瀝青の色に見えることがある。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると真赤な血のような色の何とも知れぬものが暗黒の中に現れる。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために暗黒アフリカの真只中にロンドン製品の包紙がちらばるようなことになる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「将に来らんとする私の生活の転機の暗黒面だ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にはそんな暗黒面でない、光明面の思い出はないのかい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルチスタンの印度兵の眼を避けて支那の裏面に磔つけにされた同志が、石塘嘴の不夜城に暗黒な心を抱いて一夜を明すのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海の猥褻な写真帳が閉じられ、四馬路に人気がなくなると市街の電気のスイッチが切られ全市は暗黒になった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は空虚と心の暗黒と、虚無を感じて過去の傷ついた事蹟を振りかえりながら、　――一先ず俺はこれより汕頭に行き、其後ペトロフの軍艦でバルチック海からロシア入りをする決心なのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三紀層、白堊紀、石炭紀、Silurea 紀と地球創成の跡を究めて、遂に太古の暗黒時代に這入つた時、若き研究家であつた彼が、人生の大きな不安に捉はれて、深い懷疑に沈んだ時を私は想像した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮銀行がやっていた、暗黒相場のルーブル売買が禁止されたのが明らかになった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「そうだ、もっと早くから、ルーブル紙幣の暗黒売買を禁止しとかなけゃならなかったのだ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、巨大な暗黒な洞窟が出来て来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "より深い暗黒が、いつも絶えない波動で刻々と周囲に迫って来る。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその一方は理想の光に輝かされ、もう一方は暗黒の絶望を背負っていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうはいっても吉田は、いつも家の中に引っ込んでいて、そんな知識というものはたいてい家の者の口を通じて吉田にはいって来るのだったが、吉田はさっきの荒物屋の娘の目高のように自分にすすめられた肺病の薬というものを通じて見ても、そういう世間がこの病気と戦っている戦の暗黒さを知ることができるのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手にかこまれて、顔で蓋をされた、敷布の上の暗黒のなかに、そう言えばたくさんの牛や馬の姿が想像されるのだった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言った広大な、人や車馬や船や生物でちりばめられた光景が、どうかしてこの暗黒のなかへ現われてくれるといい。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの記事を日蝕に比べる説もあったようであるが、日蝕のごとき短時間の暗黒状態としては、ここに引用した以外のいろいろな記事が調和しない。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最も純潔な尼僧の生活から、一朝つまらぬ悪漢に欺かれて最も悲惨な暗黒の生涯に転落する、というような実験を、忠実に行なった作品があるとする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ数センチメートルの長い火花を写真レンズで郭大した像をすりガラスのスクリーンに映じ、その像を濃青色の濾光板を通して、暗黒にならされた目で注視すると、ある場合には光が火花の道に沿うて一方から他方へ流れるように見える。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、この効果は暗黒にならされた目にあまり強くない光の帯が映ずる場合に特に著しいように思われたのである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる暗黒の影が天地を離れて万象が一度に美しい光に照らされると共に、長く望んで得られなかった静穏の天国が来るのである。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、――どうにも、この相も変らぬ、無際限の暗黒一色の風景は、どうしたことか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトは一面に星一つない寂莫たる暗黒の山々らしい。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外の暗黒と一続きのままシンシンと夜半に近づいて行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして人間世界の戦場は通り越して、他人は勿論のこと自分でもわからない暗黒世界にグングン斬り込み斬り込んで行く。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六つの　ひな僧　一休さんは、六つのとき　いなり山の　きたに　ある　あんこくじと　いう　おてらに　はいって、ぼうさんに　なることに　なりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お母さまは　一休さんを　さむらいに　して、ころしたり　ころされたり　するよりは　おぼうさんに　しよう、と　うばにも　はなして、一休さんを　あんこくじの　ひなそうに　したのでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんこくじの　ひなそうに　なった　一休さんは、しゅうけんと　いう　なまえを　もらって、まいあさ　おしょうさまから　おきょうを　ならいましたが、りこうなので　すぐおぼえます。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
