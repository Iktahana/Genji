        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨気について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨気という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨気の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨気が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨気を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨気について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨気の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨気の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨気が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨気という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨気という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨気についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨気を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨気は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨気について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨気が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨気は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨気の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨気は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨気は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暁を思わせるうす紅色で、雨気を含んだ虚空に、浸み透るように、暈して描かれた自分たちの印画は、この大なる空間を跨いで、谷間へと消え落ちた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見損じて下さいますな」　雨気が除かれたかして星が中天に燦めき出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は凝って青く澄み、大陸のような雲が少し雨気で色を濁しながらゆるゆる移って行く。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　簑虫　八月のある日、空は鼠色に曇って雨気を帯びた風の涼しい昼過ぎであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気が浸通つて、友染が濡れもしさうだつたからである。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れたる日の夕暮など多く見ゆるなるが、雨気を含むものにや。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう天候で、もし降雨を伴なわないと全国的に火事や山火事の頻度が多くなるのであるが、この日は幸いに雨気雪気が勝っていたために本州四国九州いずれも無事であった。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び石のそばに突兀としてそびえた楠の木のこずえに雨気を帯びた大きな星が一ついつもいつもかかっていたような気がするが、それも全くもう夢のような記憶である。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ何処にか雨気が残っておりますなら、向うの霞の中でしょうと思いますよ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吉はそう断念めて、洋傘の雫を切って、軽く黒の外套の脇に挟みながら、薄い皮の手袋をスッと手首へ扱いて、割合に透いて見える、なぜか、硝子囲の温室のような気のする、雨気と人の香の、むっと籠った待合の裡へ、コツコツと――やはり泥になった――侘い靴の尖を刻んで入った時、ふとその目覚しい処を見たのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、雨気はもっと前から落ちて居たのかも知れない。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら底にまだ雨気がありそうで、悪く蒸す……生干の足袋に火熨斗を当てて穿くようで、不気味に暑い中に冷りとする。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の中の七日、珍しく朝凪ぎして、そのまま穏かに一日暮れて……空はどんよりと曇ったが、底に雨気を持ったのさえ、頃日の埃には、もの和かに視められる……じとじととした雲一面、星はなけれど宵月の、朧々の大路小路。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛みたいほどの雨気を帯びた辻の風も、そよとも通わぬ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の晩は、雨気を含んで、花あかりも朦朧と、霞に綿を敷いたようだった。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表に雨気のあるきららが浮いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表に雨気のあるきらゝが浮いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気の多い歳には似合わなく晴れた日の朝でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺は真暗に暮れてしまって雨気をふくんだ風が出た。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気を帯びた南風が吹いて、浅間の斜面を白雲が幾条ものひもになってはい上がる。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気が深く包みはしたが、どの峰も姿が薄い。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月末の暗い夜で、雨気を含んだ低い大空には影の薄い星が三つ四つ、あるか無きかのように光っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、朝、雨気ありたれども思いきりて出づ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い夜で、雨気を含んだ低い雲の間に、うすい天の河が微かに流れていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気を帯びた夕日がぱッと障子を明るく照らして、酒を飲まぬ荻生さんの顔も赤い。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦はもう卯月に入って、昼間から雨気を含んだ暗い宵であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨気を含んだ暗い夜で、低い空の闇を破って啼いていく五位鷺の声がどこやらで聞こえた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よござんすか、わしの方でもまあまけておいて、いくらか譲歩するとしましょう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
