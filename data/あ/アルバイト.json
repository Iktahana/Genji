    "definitions": [
      {
        "index": 1,
        "gloss": "part-time job",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルバイトについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルバイトの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルバイトが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルバイトについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルバイトの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルバイトが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルバイトという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルバイトについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルバイトは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルバイトが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルバイトは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルバイトの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルバイトは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルバイトは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これは科学的のアルバイトというものの本性に関する認識不足から起こる現象である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむなくアルバイトで図書整理の仕事を続け、気にかけてくれたバイト先の人の口利きで、編集プロダクションに紛れ込みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代のミニコミ作りや出版社でのアルバイトでじょじょに慣れていったせいか、私自身はそれほど驚いた記憶はありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、編集プロダクションに籍を置いていた当時は、経験なしに入ってきたスタッフやアルバイトに、「こんなに手間がかかるんですか」と何度か呆れられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古川がアルバイトで勤めていた秋葉原の店に集まる、生まれはじめたばかりのマイコン・マニアの中には、早稲田大学の学生であるという西和彦という名の青年がいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この仕事は、「学生アルバイト」のはずだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の家庭の娘さんはアルバイトを考えずに、専門学校の生活を考えることは不可能になりました。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトを二つもって医学の勉強をしているひとを知っております。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトしている男女学生の生活は、経済安定本部の抽象性の修正者です。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、故人の遺族は思いがけなく主人の身の上におこった悲劇によって、妻は主婦として行手の寒さに身をふるわせ、子息たちは、アルバイト学生の境遇を、自身たちの明日の身の上にうけ入れにくく思っただろうということもありえないことではない。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子の学校などでも一日に百二十本のアイスクリームを売って、汗にまびれてけなげにアルバイトして勉強している学生と、文化的な外見をもちながら、生活の中心が全く腐敗してしまっている女子学生とがある。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまじめな人たちはアルバイトまでして勉強しています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済事情が悪化している今日、学生のアルバイト、主婦の内職、また内職的な意味でのかけもち職業の問題が増えてきて、女性の重荷はましています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトの一種のようにさえ思っている。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素朴な少女の「アルバイト」記録のなかに、人々は、まだ日本の一部には軍国主義が健在であるという事実を告げられている。",
              "citation": {
                "source": "小さい婦人たちの発言について",
                "author": "――『わたしたちも歌える』まえがき――",
                "note": "青空文庫"
              }
            },
            {
              "text": "インフレーションやアルバイトときりはなして、今日のわたしたちの学習生活が存在しないとおり、もし、今日の若い人々が経済事情をけとばしたような抽象的な学生生活を語るなら、その虚構の観念性を、誰よりも先ず若い人たち自身が軽蔑するであろう。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ごろ何かのグラフィックに大学教授の老先輩が男女学生を集めて面白可笑しく学生アルバイト漫談をしている記事がのっていた。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトをとおして学生は勤労者化しつつある。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトをとおして、学生の小市民性は危機にさらされてもいる。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が説明によって理解したところでは、民主革命の推進力である労働者階級を主軸としてその同盟者としての農民、勤め人、中小商工業者、近ごろはアルバイトの必要から勤労生活にとけこみつつある学生、これらを概括して「勤労者文学」の基盤とするといわれたようだった。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その現実の認識に向って青春のヒューマニティーが対決させられるとき、そこに湧く思いこそは、アルバイトして勉学している学生の日々をゆすぶっている日本の青春のひとすじの熱い思いにつながるのである。",
              "citation": {
                "source": "日本の青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとその実現が見られるきょう、男女学生のアルバイト率はどうだろう。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師不足はアルバイトを求める男女学生のために一つの職場を提供している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月謝値上げはアルバイトによってやっと学問をつづけているこんにちの日本の学生にとっては、学問の自由をうばわれることにひとしい。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしばらくすると、経済逼迫のために、古橋その他の有名選手たちが夏休みのアルバイトとして、銀座辺で漬物屋の店をひらくとか、そういう店に働くとかいうニュースがでた。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人に向けられる失業や、女子学生のアルバイトの問題。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに学生結婚していた嫁とアルバイトで食いつなぎながら、僕は出版社だけに履歴書を送り続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究会の末席に加えてもらうようになった僕が、学費と生活費にきゅうきゅうとしてアルバイトに飛び回るのを見て、雑誌を起こしていたリーダーが「うちで働くか」と声をかけてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターがいじりたい一心でプログラミングのアルバイトを始め、天才ぶりを発揮してひっぱりだことなり、高校時代には一年間休学して仕事に没頭している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツとアレンはその後、企業の給与計算ソフトウエアを書き、学校からはクラスの編成プログラムを頼まれて、コンピューターの使用時間とアルバイト料をせしめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
