    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pathos",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀愁は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀愁が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀愁に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀愁が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀愁について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀愁についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀愁について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀愁が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀愁が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀愁は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀愁は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀愁を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀愁をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀愁が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀愁の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀愁を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀愁に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀愁について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀愁は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀愁を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは夢多かりし幼時を過ごしたフランドルの哀愁にも因るのであらう。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しかうして今私は峠の途中に蹲んでゐて、まことにしみじみとした気持だし、それとなく此の世の、何といはうか哀愁が思ひ遣られもするのだ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "莟みの集団の下から、房になった黄色い四弁花が、いま電燈の蒼い光にきらびやかに匂っている、茎は一皮下には、青い血が通っているのではないかと思われるほど透き通って、有らゆる春の緑の中で、最も練り抜かれた緑である、見つめていると、早春の名残といったような淡い哀愁に加えて、物の末期の惨酷を思わせる姿である。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ灰汁のある癖の多い声が向く、それに哀愁もいくらか交る。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）に連れられて、歌劇の女がカカオを喫しているフランスの香のなかに哀愁的な東洋女の花を咲かしたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何故とも知らぬ哀愁を感じてうなだれる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、さすがにどことなく哀愁にみちた空氣。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれをひいていると、歌の文句は何も知らないのにかかわらず、いつも名状の出来ないような敬虔と哀愁の心持が胸に充ちるのを覚える。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木枯らし吹く夕暮れなどに遠くから風に送られて来るラッパの声は妙に哀愁をおびて聞こえるものである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたあとで、テナシティのデッキの上から「あしたは出帆だ」とどなるのをきっかけに、画面の情調が大きな角度でぐいと転回してわき上がるように離別の哀愁の霧が立ちこめる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの心は眞底から哀愁に搖り動かされ、自暴自棄にさいなみ苦しめられた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭苦しい銀子の家も、二階の見晴らしがよくなり、雨のふる春の日などは緑の髪に似た柳が煙り、残りの浅黄桜が、行く春の哀愁を唆るのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの町には、あれほど愛し合った栗栖もいるので、立ち去る時、何となし哀愁も残るのだったが、銀子は後を振り返って見ようともしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその人が本当に敬虔な心の持主であれば、そのほほえみの中には哀愁の色がただよいます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは少年の昔よりして、今も猶私の夜床の枕におとづれ、なまめかしくも涙ぐましき横笛の音色をひびかす、いみじき横笛の音にもつれ吹き、なにともしれぬ哀愁の思ひにそそられて書くのである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならこの詩集には、私の魂の最も奧深い哀愁が歌はれて居るからだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ぼうっとした印象が、美的な快感を損わない程度の軽い哀愁として、読者の胸にいつの間にか忍び込む理由を、客観的に翻訳すると色々な物象として排列されます。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "代って舌鼓うちたいほどの甘い哀愁が復一の胸を充した。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして甘い哀愁に充たされながらいつもの通り、「ちっと女らしくなれ」を真佐子の背中に向って吐きかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌目がこまかいだけが取得の、無味で冷たく弱々しい哀愁、焦れもできない馬鹿正直さ加減。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にも何となく甘苦い哀愁が抽き出されて、ふとそれがいつか知らぬ間に海の上を渡っている若い店員にふらふらと寄って行きそうなのに気がつくと、「なにを馬鹿らしい。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙つて、黙つてゐるために、かへつて、二人とも切ない歓喜の哀愁がふかく胸をとぢたので御座いますね。",
              "citation": {
                "source": "或る男の恋文書式",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後記）王朝時代の末期になつて、文化の爛熟による人間の官能と情感がいやが上にも発達し、現実的には高度の美意識による肉的なものを追ひ求める一方、歓楽極まつて哀愁生ずる譬へ通り、人々、省己嫌厭の不安から崇高な求道の志を反比例に募らせる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすばしこさに似合ふやうな、似合はぬやうな山地のうすのろい唄の哀愁のメロデーを長閑に河面に響かせて筏師は行く。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年ほどの交渉のうちに、若い画家は、かの女の持つ稀有の哀愁を一生｜錨綱にして身に巻きつけ、「真面目なるもの」に落付き度いといひ出した。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の酸鼻戦懐の状を聞き、幼いながらも暗憺たる気持になつて泣きべそをかいてしまつたものだが、久し振りで故郷に帰り、このやうな記録をあからさまに見せつけられ、哀愁を通り越して何か、わけのわからぬ憤怒さへ感ぜられて、「これは、いかん。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、貴下の無学あるいは文章の拙劣、あるいは人格の卑しさ、思慮の不足、頭の悪さ等、無数の欠点をみとめながらも、底に一すじの哀愁感のあるのを見つけたのです。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名を「いあいしゅう」と付してあり、この歌集に「遺愛集」として生かしたのです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
