          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安閑について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安閑という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安閑の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安閑が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安閑を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安閑について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安閑の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安閑の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安閑が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安閑という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安閑という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安閑についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安閑を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安閑は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安閑について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安閑が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安閑は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安閑の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安閑は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安閑は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして丹泉は意気安閑として、過ぐる日の礼を述べた後、「御秘蔵のと同じような白定鼎をそれがしも手に入れました」といった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣も釣でおもしろいが、自分はその平野の中の緩い流れの附近の、平凡といえば平凡だが、何ら特異のことのない和易安閑たる景色を好もしく感じて、そうして自然に抱かれて幾時間を過すのを、東京のがやがやした綺羅びやかな境界に神経を消耗させながら享受する歓楽などよりも遥に嬉しいことと思っていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安閑適の生活が形成されさうにも思はれて来た。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安閑適の一生があの人の今後に続くであらう。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安閑適の生活が形成されそうにも思はれて來た。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安閑適の一生があの人の今後に續くであらう。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいい女だ」「私は急ぎの用を抱えている身だから、こうして安閑としてはいられない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして丹泉は意気安閑として、過ぐる日の礼を述べた後、「御秘蔵のと同じやうな白定鼎をそれがしも手に入れました」と云つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「対手が、あの意気込じゃあ、安閑としていられません。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおあとには、継体、安閑、宣化、欽明、敏達、用明、崇峻、推古の諸天皇がつぎつぎにお位におのぼりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お峰は世間の母親のように、初孫の顔を見るのを楽しみに安閑とその日を送ってはいられなかった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「元親公がそんなことを云われたか、凡そ君辱めらるれば臣死す、禄を食む者が、主を殺させて安閑と生きながらえることができると思われるか、元親公は無下に愚かな人じゃ、飴で小供を釣るような申されようじゃ」　次郎兵衛は肩を揺って笑った。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテモ安閑として内地には居られん」「一体何の幽霊かいね」「缶詰の幽霊たい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神が平常に復して来ると安閑としてはいられなかった。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光景は、何処から見ても平凡な家庭生活者の姿であつて、いきさつを知る者の眼から見たらば怪しげな噂の的になるのは当然だ――と私は思ふと、安閑と椽側の椅子になど凭つても居られなくなつて下駄を穿いて、庭ともつかぬ椽先へ降りた。",
              "citation": {
                "source": "二日間のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽をしたい、安閑を楽しみたいなどと思う者は忘れても富者などになるべきものでは無い。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、粗末な服（褐）を着て、玉のような徳を懐いて、世に隠れて自ら安閑（ノンビリ）としているのは少し行き過ぎである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそうでなく、ただ漠然として心を動かさず安閑（ノンビリ）としているのであれば、それは道教や仏教の徒のするところに近い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵がかように勢いを得ては、もう安閑としてはいられぬ時節じゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のう、大きく申せばお家の大事、また二つにはお身の大事、いずれにしてもただ安閑と眺めてはいられぬ時節じゃで、それがしもこうして密々に訊ぬるのじゃが、どうじゃ、お身。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとえばここへ敵が寄せかけたという時、病気じゃとて安閑と寝そべっていらりょうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父の讒言がだんだん有力なものになって、将軍家から謀叛の疑いをうける以上、塩冶は安閑として都にはいられない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のためとか、風のためとか、一日も安閑としてはいられない漁夫の生活にも、なす事なく日を過ごさねばならぬ幾日かが、一年の間にはたまに来る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁にこそ出ないが、ほんとうを言うと、漁夫の家には一日として安閑としていい日とてはないのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年月をふるといへども、こと訪ふ人もなく、安閑の境界は却つて楽を招き、富貴を願はず、我が惑はぬ年をこそ、秋の夜の長きに老の寝覚のつれづれに思ひ出してしるし侍る。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "安閑としてぶらり遊んでいることは嫌いで必ずしも自分の仕事が銭にならなくても、手と脳とを使って自分の意匠を出して物を製えて見ようというのである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蘆の葉のおもちゃのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれはな、兵隊さ行ぐものばかりが色々な訓練を受けて、んでないものは安閑としてるべ、それじゃ駄目だッてんで、あれば作ったんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岸野農場の小作人十余名は、三日来樽以来、苦闘に苦闘を重ねているが、留守宅の細君等も安閑として日を過ごすことが出来ない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "村へ出て見ると、一軒として大騒を遣つて居らぬ家は無く、鎮火と聞いて孰も胸を安めたやうなものの、かう毎晩の様に火事があつては、とても安閑として生活して居られぬといふそは／＼した不安の情が村一体に満ち渡つて、家々の角には、婦やら、老人やらが、寄つて、集つて、いろ／＼喧しく語り合つて居る。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ穩かならぬ時世になつては、武士は勿論、町人でも職人でも唯安閑としてはゐられない筈だ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
