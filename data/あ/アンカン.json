          ],
          "literary": [
            {
              "text": "香川　だからさ、僕らみたいに学校教育の中にアンカンとしてるだけでは、しょうが無いんだな。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、われわれは、こんな、アンカンとして眺めてはいられません。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは、今や銃後にアンカンとして一日の安きを盗んでいられません！",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
