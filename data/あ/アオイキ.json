    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anxious or pained sigh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "円の面積を算出する公式も、鶴亀算の応用問題の式も、甚だ心もとなくいっそ代数でやればできるのだが、などと青息吐息の態とやや似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず万一、この一件が片付き兼ねる……下手人がわからぬとなると吾々は元よりの事、御主人の松倉様まで、十手捕縄を返上せにゃならぬかも知れぬと言うので、松倉十内様は今のところ青息吐息、青菜に塩の弱りよう……」「ちょっと良助さん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "借金で首がまわらず青息吐息で、火を吹く力もないような情ない顔つきをしている癖に、たべものにわがままは大笑いだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、何も御坐いませんけれど、どうぞ貴下方｜御寛り召上つて下さいまし」　妻の喜は溢るるばかりなるに引易へて、遊佐は青息※きて思案に昏れたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁半の連中は皆な私の手下ぢやわい、何を秘さう、鴨をくわへ込んで、濡手で粟の大儲けの上前とりの大親分は私なんだが、あの騒ぎ以来一味の者共は、吹雪男の亡霊にとり憑かれて青息吐息の有様なのだ。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　連中の青息は穴のあいた風琴のやうに手応えもなくなり、狸腹や狐憑きの姿も消え失せて、阿父は道具立てばかりが依然として艶々しい独り舞台で腕組をしてゐるのが目立つた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのようなぺちゃんこの車になっては、どう詫びて返したらいいだろうかと、日頃は楽天家のネッドも箱車の後から顔をのぞかせて青息吐息であった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十万円握つて瀬戸のところへ駈けつけたまではよかつたが、宿六が追ひかけてきて取り戻されては大変と、温泉へ瀬戸を誘つて豪遊したから忽ちにして文無しとなり、伴稼ぎを始めたが、瀬戸の飲み代で青息吐息、ちつとも面白くない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "所長なんか舌に来たらしいが、口は無論利けないし、青息吐息さ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗っている当人は、英気颯爽の勇ましさに自己陶酔していても、乗せている馬の方では青息吐息なのだそうである。",
              "citation": {
                "source": "軽井沢にて",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から帰ってから、親分は夜の稼ぎに身が入らずに、昼も、まるで腑が抜けたように考えこんでばっかり、青息吐息――十八島田の恋わずらいじゃアあるめえし、人は知らねえが、ぼんのう小僧ともあろうものが見ていて、あっしゃあ小じれってえよ親分。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "係り役人が躍気になって、走りまわっても、得るところは雲のような臆測か、煙みたいな風聞ばかり、事実はおろかとんと方向がつかないのだから、一同奔命に疲れた形で、青息吐息、ほとほと困じ果てていたところへ――。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼にも、ガスや電燈の力借り、天道様の顔もみず、色青白く頸長く、青息吐息に血を混え、吐くぞ悲しき浪花津の肺病娘のうらめしき……」　満堂シーンとして、咳一つさえ聞えない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ今頃は青息吐息で――」「止さねえか、八。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ今頃は青息吐息で――」「止さねえか、八、言い当てられて向っ腹を立てるわけじゃねえが、人の面をマジマジと見ながら、何てエ言い草だ」　平次も呆気に取られて、腹を立てる張合いもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蔵省には黒田閥というのがあったそうだがそれが今度の××問題で動揺し始めて、大臣や内閣は青息吐息だが、世間では却って省内の事情に関して思わぬ知識をこの事件から提供されたので面白がっているようだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎夫婦は、額をつきあわせて、青息吐息である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙じゃもう間に合わないし、電報じゃ充分意思が通じないし、マザーと二人で青息吐息さ」　と寛一君は頻りに弁解を始めた。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の「映画時代」が若し成功して今日迄及んでゐたら――今頃は青息吐息であらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "半死半生の泥ねずみとなって、泣くにも泣けぬ蛾次郎先生、命からがら浜松の城下を、鷲にのって逃げだしたはいいが、夜に入るにしたがって、空天の寒冷は骨身にてっし、腹はへるし、寝る場所のあてはなし、青息吐息の盲飛行、わるくすると先生、雲のなかへ迷子となってしまいそうだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
