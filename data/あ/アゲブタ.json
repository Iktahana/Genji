        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上蓋の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二人は、艇の上蓋をとって、ならんで座席についた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭用の旧式な電気冷蔵箱に、上蓋式のものがある。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二尺に三尺くらいの四角な箱で、その底に冷却管が配置してあって、それに上蓋がついているだけのものである。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷凍装置を働かせながら、上蓋をまくっておく。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋の上蓋は多分丈夫な鉄格子にでもなっているのであろう。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それはただピアノの上蓋の上に、ほかの譜をさがすためにすぎなかった。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく進むアキリュウス、激しき勇氣其胸を滿たし、華麗の精巧の大盾かざし胸の上蓋ひて、＊四つの隆起ある輝く兜ゆるがせば、ヘープァイストス神工が其頂邊に植ゑしもの、　315燦爛として美はしき金の冠毛打震ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "高一のいれられている穴ぐらの入口のところで、がちゃがちゃとかぎの音がし、いきなり入口の四角なあげぶたがあいて、にくいスパイ団長がはいってきました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西側の隅に鍵のてに手すりがあって、そこのあげぶたがたたまれ、半地下室への階子口があいていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室へ降りるあげぶたが密閉されている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手の扉の近くの床板が三尺四方に切り取られて、そのあげぶたが横にずれたところから黒く見える床穴の所へ行き、下をのぞき込む）先生！",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎のゆかが、あげぶたになっているのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、じゅうたんの下ですから、わたしでなければ、どこにあげぶたがあるかさえ、わかりません。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげぶたをあけて、ゆかの下にはいると、そこにもう一つ厚い鉄のとびらがあります。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの書斎のあげぶたを、とうぶんひらかないことですね。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆかが四角く切りぬかれ、あげぶたとなっているのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげぶたを、おろすと、まっくらになりましたが、島田さんが、床下にしかけたスイッチをおして、パッと電灯をつけました。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田さんは天井のあげぶたに、中から、しまりをしながら、「どうです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが一メートル四方ほどのあげぶたになっているのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすきに、小屋の横にかくれて、長い糸で、むこうの木の枝をゆすっていたこじき少年が、糸をはなして、こっそり、戸口からすべりこみ、さっきのぞいておいた床のあげぶたのところへいくと、それをあげて、すばやく地下室へすがたをかくしてしまいました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男は、ぶつぶついいながら小屋へもどってきましたが、あげぶたは、もとのとおりに閉まっているので、こじき少年が、地下室へおりていったことは、すこしも気づきません。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはしごをのぼったところに、大きなあげぶたがついていて、それを、上におしあげると、ポッカリと黒い口がひらきました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵は、少年たちを、おくのほうへすすませて、じぶんは入口のあげぶたのそばに立ちはだかっていましたが、そのとき、なにを思ったのか、クスクスと笑いだしました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういったかとおもうと、明智にばけた怪人は、ヒラリと入口の下のはしごにとびおり、バタンと、あげぶたをおろして、下からカチンと錠をかけてしまいました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、まえもって、あげぶたに錠がとりつけてあったのです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、さけんで、あげぶたのところへかけつけ、両手でそれをあげようとしましたが、びくとも動くものではありません。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、みんなが、あげぶたの板戸のまわりに集まって、たたいたり、けったりして、それをやぶろうとしましたが、ひじょうにあつい板でできた、がんじょうな戸ですから、とても、やぶるみこみがないことがわかりました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、たとえ、このあげぶたをやぶったとしても、あいては、どこかにかくれて、ようすを見ているかもしれません。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠のゾウは、地下室の金庫の中に入れたうえ、その地下室の入口の厚い板のあげぶたにも、厳重にかぎをかけ、家族の者でも金庫のそばへは行けぬようにしました。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
