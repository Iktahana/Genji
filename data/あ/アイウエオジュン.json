        "examples": {
          "standard": [
            {
              "text": "会議の出席者リストは、姓のアイウエオ順に並べ替えておいてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館の本棚は、著者のアイウエオ順に整理されているので、探しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このシステムでは、登録された商品名が自動的にアイウエオ順で表示されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小学生の頃、国語辞典の引き方を習う際、アイウエオ順の重要性を教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電話帳の検索機能は、名前のアイウエオ順で絞り込めるので便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「えーと、この書類はアイウエオ順でファイルすればいいですか？」と新人が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オンラインストアの商品一覧は、デフォルトでアイウエオ順に並んでいます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（但しアイウエオ順）芥川龍之介。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイウエオ順に考えていくことを思いついた彼は、ア、イ、ウ、エ、と心のなかでたどっていき、「オムライス！",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
