        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二六、五、一九、〔以下空白〕五月十九日　　　　　　＊いま汽車は青森県の海岸を走っている。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の夕刊に青森県｜大鰐の婚礼の奇風を紹介した写真があって、それに紋付き羽織｜袴の男装をした婦人が酒樽に付き添って嫁入り行列の先頭に立っている珍妙な姿が写っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に私の兄がいま青森県の民選知事をしておりますが、そう云うことを女にひと言でも云えば、それを種に女を口説くと思われはせぬかというので、却っていつも芝居をしているように、自分をくだらなく見せるというような、殆ど愚かといってもいいくらいの努力をして生きて参りました。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "固苦しく言えば、青森県区裁判所金木町登記所々長の長男である。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、「十一月二日の夜、六時ごろ、やはり青森県出身の旧友が二人、拙宅へ、来る筈ですから、どうか、その夜は、おいで下さい。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから近江、越前、越後、加賀、能登、若狭などとさかんに船で交通をはじめて次第に栄え、外ヶ浜に於いて最も殷賑の要港となり、明治四年の廃藩置県に依つて青森県の誕生すると共に、県庁所在地となつていまは本州の北門を守り、北海道函館との間の鉄道連絡船などの事に到つては知らぬ人もあるまい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森県の県庁を、弘前市でなく、青森市に持つて行かざるを得なかつたところに、青森県の不幸があつたとさへ私は思つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森県といふ名もそこから起つたのではないかと思はれるほど、津軽の山々には樹木が枝々をからませ合つて冬もなほ青く繁つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて明治時代に到つても、官庁は大いに林政に注意し、青森県扁柏林の好評は世に嘖々として聞える。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君は青森県郷土史研究会の会員だつたので、郷土史の文献をかなり持つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞伝和尚の事は、竹内運平氏著の青森県通史にも記載せられてある。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青森県沿革」本県の地は、明治の初年に到るまで岩手・宮城・福島諸県の地と共に一個国を成し、陸奥といひ、明治の初年には此地に弘前・黒石・八戸・七戸および斗南の五藩ありしが、明治四年七月列藩を廃して悉く県となし、同年九月府県廃合の事あり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時みな弘前県に合併せしが、同年十一月弘前県を廃し、青森県を置き、前記の各藩を以て其管下とせしも、後｜二戸郡を岩手県に附し、以て今日に到れり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間土地低平、支流溝渠網の如く通じ、青森県産米は、大部分此平野より出づ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸奥も青森県も津軽と同じものだと思つてゐる人さへあるやうである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽の人、竹内運平氏の青森県通史に拠れば、「この安東一族の騒乱は、引いて関八州の騒動となり、所謂北条九代記の『是ぞ天地の命の革むべき危機の初め』となつてやがては元弘の変となり、建武の中興となつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森県に到達するには、その二倍歩かなければならぬ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その青森県の日本海寄りの半島たつた一つが津軽なのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお婿さんも笑ひながら、「この辺に、青森県の修錬農場があるとか聞きましたけど。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの竹内運平氏は「青森県通史」に於いて、この辺以南は、昔からの津軽領ではなく、秋田領であつたのを、慶長八年に隣藩佐竹氏と談合の上、これを津軽領に編入したといふやうな記録もあると言つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家が多少でも青森県下に、名を知られはじめたのは、曾祖父｜惣助の時代からであった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の青森県農村のさまは全く悲惨そのもの。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今ますます青森県の重要人物らしい貫禄を具えて来ました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森県金木町、山形宗太。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年六月十九日、青森県北津軽郡金木町に生れた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同町小学校を経て、大正十二年青森県立青森中学校に入学。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国はどちらですか」「青森県のＨ市です」「御両親ともそこにおられるのですか」「ハイ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の郷里は青森県の酒造家で、裕福な家らしく聞いていたが、その後の彼女の朗らかな性格や、無邪気な態度を透して、そうした事実を私等は毛頭疑わなかった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
