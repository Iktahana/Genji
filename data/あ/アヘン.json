        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿片について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿片という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿片の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿片が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿片を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿片について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿片の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿片の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿片が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿片という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿片という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿片についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿片を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿片は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿片について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿片が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿片は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿片の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿片は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿片は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども心配そうに、口ごもりながら、「行ってもすぐ帰って来るのでは意味がない、それから、どんな事があっても阿片だけは吸わないように。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末筆ながら、おからだを大事にして、阿片などには見向きもせぬように、とまたしても要らざる忠告を一言つけ加えた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ボードレエルは、酒と阿片とアシッシュとに就いて、その藥物學的比較觀察をした後で、酒がいちばん健全であり、毒物的危險性がない上に、意志を強くするといつて推奬してゐる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿片やアシッシュに比べれば、酒はたしかに生理的であり、神仙と共に太初から有つたところの、自然の天與した飮物である。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私の場合は、用具や設備に面倒な手数がかかり、かつ日本で入手の困難な阿片の代りに、簡単な注射や服用ですむモルヒネ、コカインの類を多く用いたということだけを附記しておこう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の市場では阿片の花が陽気に満開し、薬種屋の前では群集が巡邏に口輪を嵌めている。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯を米良の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は阿片を多量に喫して辛うじて睡眠をとりました。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の阿片窟へもはいつて見た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他愛なく笑ひさざめく男達の前で裸踊する痩せこけた女の顏、血烟立ててコロツと前に轉がつた馬賊の首、死骸のやうに床にのけぞり返つてゐた阿片中毒のロシヤ人の無氣味な瞳の光……。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "處で、阿片なども支那へ行つて通な人から實際の説明を聞くまでは、普通の煙草と同じやうに吸飮そのことに深い享樂があるのだと想像してゐたが、これも初めの内や極端な中毒状態にはひつてからは別として、適度の吸飮は非常な催欲手段となるらしい。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云へば、大概の阿片窟には阿片吸飮を世話する若い女がゐること、日本の徳川時代の或る種の風呂屋の湯女の如く無論その正體は賣笑婦なのだ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その阿片を、私は上海でただ一度生れて初めて吸飮してみた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ヶ月の支那旅行を終つて、いよいよ明日は日本へ歸ると云ふ前夜、向うで知り合つた二三の友人と別宴を交し可成り醉つてゐた處を例の黄苞車でぐるぐる引きまはされたあとなのでどこのどう云ふ處にあつたのか覺えてゐないが、とにかく法租界の暗い裏町にある二流どこの阿片窟だ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どう阿片をやつてみませんか？",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ちよつと形の説明に困るが、大福餅ほどの大きさと形を持つた雁首に火吹竹ほどの柄をつけた阿片吸飮具を左手にとつた女は右手の耳かき樣なもので枕元の小鑵からちやうどにかわを少しゆるめたやうな褐色の半液體をすくひ上げて、雁首の表面の小さな孔の邊へぬすりつける。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まづいもんですね、阿片なんて…………』　やがて寢臺から起き上つて苦笑しながら、私は女達と雜談に耽つてゐる友の側へ歩いて行つた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そりや君、阿片の味がほんとに分るまでには、二月ぐらゐは苦勞しなけりや駄目なんですよ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ四馬路の菜館で廣東料理に舌皷を打ち、或る外國人のバアでリキユウルをすすり、日本料理屋で藝者達の長崎辯を聞き、更にフランス租界の秘密な阿片窟で阿片まで吸つてみた。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　女と、ばくちと、阿片と、支那人の一｜生はその三つの享樂の達成に捧げられる――などと言ふと、近頃の若い新しい中華民國の人達から叱られるかも知れないが、これは或る點まで殘念ながら眞實らしい。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦力達は營營と働く、女――細君を買ひたいために、ばくちをしたいために、阿片を吸ひたいために。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの婢妾の肉に倦きたいために、ばくちに耽る悠悠閑日月を自由にしたいために、豪華な廊房で阿片の夢に浸りたいために。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿片の臭いが鼻にプンと来た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼尻の下った、平ぺったい顔、陋屋と阿片の臭い。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗島は、老人の傷口から溢れた血が、汚れた阿片臭い着物にしみて、頭から水をあびせられたように、着物がべと／＼になって裾にしたゝり落ちるのを見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その俗衆趣味は、ややもすればウェルテリズムの阿片に酔う危険のあったその頃のわれわれ青年の眼を現実の俗世間に向けさせる効果があったかもしれない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何一つ、思い残すことはあらあへんでな」「それは一寸、気がお早いようですね。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
