        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一望千里の滿洲の赤土の原、あかあかと夕燒にてらされ、ひとり馬で歩いて居る猫背の乃木將軍のすがたが、この眼に見えるのだ。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俵には、ライトを強くあててゐるらしく、力士の裸體は、赤土色に見えます。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の新しい畫學生の間に重寶がられるセザンヌ式の切通し道の赤土の崖もあれば、そのさきには又舊派向きの牛飼小屋もあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をとめてよく見ると、半開きの白ばらの花のかげ――肥料をやりたての根本の赤土の上に生れたばかりの小さいひきがえるがよちよちしている。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の岳神は暇な暇な、父の祖神を山中に案内して見せて廻るうち、ある日、山ふところの日当りの小竹原を通りかかり、そこに二坪近くの丸さに、小竹之葉が剥げ、赤土が露き出ているのを見付けると、息子の岳神は指して笑いながらいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄で蹴鋤いた赤土はほかほかしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はいつの間にか来ていて、昨日の雨で洗い流した赤土の上に、二葉三葉銀杏の葉の落ちるのを拾っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかしやがてイスポリの燈台を離れて、エルアルズのコーカサスの山脈が静かに黒海に映るころになって、トレビゾンドの赤土のプラットホームに女実業家達が下車すると夜は神秘に地球はハンモックのなかで眠りだすのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し崖が崩れて、赤土の覗いてゐるあたりから、くすんだ色の低い灌木の生えた丘が遠く續いてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十五度の風が吹くと温帯の風物は赤土色の憂愁に包まれてしまうのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また径の縁には赤土の露出が雨滴にたたかれて、ちょうど風化作用に骨立った岩石そっくりの恰好になっているところがあった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の間に細く赤土が踏みならされてあって、道路では勿論なかった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの道から崖の近道へ這入った自分は、雨あがりで下の赤土が軟くなっていることに気がついた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋲の打ってない靴の底はずるずる赤土の上を滑りはじめた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灌木や竹藪の根が生なました赤土から切口を覗かせている例の切通し坂だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼がそこへ来かかると、赤土から女の太腿が出ていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり切り崩された赤土のなかからにょきにょき女の腿が生えていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚根がぼろぼろした土をつけて下がっている、壊えた赤土のなかから大きな霜柱が光っていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の下積みという言葉を聞くと、赤土のなかから生えていた女の腿を思い出した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、見まわせば、赤土の道幅せまく、うねりうねり果しなきに、両側つづきの躑躅の花、遠き方は前後を塞ぎて、日かげあかく咲込めたる空のいろの真蒼き下に、彳むはわれのみなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中はがらんとして暗くたゞ赤土が奇麗に堅められてゐるばかりでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川岸の赤土の崖の下の粘土を、五とこ円くほりまして、その中に染料をとかし込み、たのまれた鳥をしっかりくはへて、大股に足をひらき、その中にとっぷりと漬けるのでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中はがらんとして暗くただ赤土が奇麗に堅められているばかりでした。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二十分ほどしてから選炭場裏の六十度を描く赤土の絶壁の上に来ると、その絶壁の褶の間の暗がりを、猿のように身軽に辷り降りた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろの新しい画学生の間に重宝がられるセザンヌ式の切り通し道の赤土の崖もあれば、そのさきにはまた旧派向きの牛飼い小屋もあった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のわが家の油絵はどうなったか、それを聞き出す唯一の手がかりはもう六年前になくなった母とともに郷里の久万山の墓所の赤土の中にうずもれてしまっているのであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の上の赤土はまだ風化せずに、どんよりした空の下にあつても赤かつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れはそのかん／＼堅くなつた赤土の上を――彼れならぬ他人のした事業の上を踏みしめ／＼歩いて行つた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんが最後に「よいとな」と大きく調子をとって、車台へ登ると蹴込みに敷いてある獅子の毛皮のようなもじゃもじゃした布の上に「つぁらっ」と擦れる音がして、新らしい後歯がかすかに刷毛でのべた様な赤土のあとをつけた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
