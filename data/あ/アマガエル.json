    "definitions": [
      {
        "index": 1,
        "gloss": "tree frog (esp. the Japanese tree frog, Hyla japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨蛙について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨蛙の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨蛙が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨蛙について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨蛙の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨蛙が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨蛙という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨蛙についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨蛙は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨蛙が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨蛙は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨蛙の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨蛙は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨蛙は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「賤民の増長｜傲慢、これで充分との節度を知らぬ、いやしき性よ、ああ、あの貌、ふためと見られぬ雨蛙。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みつぶされた雨蛙の姿に似てゐたやうであつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みつぶされた雨蛙の姿に似ていたようであった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとある日｜雨蛙がやって参りました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくぢはこの雨蛙もペロリとやりたかったので、思ひ切っていゝ声で申しました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙はひどく笑ひながら「さよならと云ひたかったのでせう。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の年ある日｜雨蛙がなめくじの立派なおうちへやって参りました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくじはこの雨蛙もペロリとやりたかったので、思い切っていい声で申しました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙はひどく笑いながら「さよならと云いたかったのでしょう。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙や青蛙が、そんな離れ業はしなからうと思つたが――勿論、それだけに、蓋も嚴重でなしに隙があればあつたのであらう。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は胸泳といつて雨蛙のやうに兩脚をひらいて泳ぐ方法を好んだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、世の中には羞恥心の全く欠けた雨蛙のような男がたくさんいて、（これは、私にとってあたらしい発見であった。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉に止まっている雨蛙は青くて、壁に止まっているのは土色をしている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、おまえの「雨蛙」のほうが幼い「落ち」じゃないのか。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この「小説八宗」は『雨蛙』の巻尾に載っておる。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、緑雨の傑作はやはり『油地獄』と『雨蛙』であろう。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の上ではまた、雨蛙と蝸牛とが雨を楽んでゐます。",
              "citation": {
                "source": "若葉の雨",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙は聞えた独唱家ですが、蝸牛はまた風がはりな沈黙家です。",
              "citation": {
                "source": "若葉の雨",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙は芸人のやうに着のみ着のままでどこへでも出かけますが、蝸牛は霊場めぐりの巡礼のやうに、自分の荷物は一切合財ひつくるめて、背にしよつて出かけます。",
              "citation": {
                "source": "若葉の雨",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "将監は不思議に思って、声のするところを探しますと、それは刀掛の竹からで、竹のなかに雨蛙が一匹棲んでいました。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "音合せの度がだんだん重なってゆくうちに、雨蛙は節廻しもひどく上手になって、将監が吹くどんな曲にも鳴きつれることが出来るようになったと言います。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」道風の見た雨蛙　　少年少女のために　細かい秋の雨がびしょびしょと降りしきる朝でした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりの雨なので、雨蛙はもう家にじっとしていられなくなって、上機嫌で散歩に出ました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙は竹垣の端からその葉の上へひょいと飛び移るなり、自慢の咽喉で、「け、け、け……」と一声鳴いてみました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙はその声の主が誰であるかをすぐに感づきました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙はこっそり無花果の葉の裏をのぞき込みました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雨蛙はからかわれでもしたようにいやな顔をしました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさくな雨蛙は、それが気に入らないように頬をふくらませていました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雨蛙は相手の気色を見てとって、すっかり機嫌をなおしたようでした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほう、歌の稽古を……」　雨蛙は以前山に棲んでいた頃、程近い人家にまぎれ込んで、竹製の刀架の孔のなかにもぐり込んでいたことがありました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
