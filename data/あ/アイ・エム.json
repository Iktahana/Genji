    "definitions": [
      {
        "index": 1,
        "gloss": "instant messaging (messenger, message)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これはＩＭの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "洞穴のようにうつろな胸、睫毛のない眼、汚点だらけの肌、派手なＫＩＭＯＮＯ、羅物の下着、前だけ隠すための無花果の葉の形の小エプロン――そんなものが瞥見される。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、この満目のＫＩＭＯＮＯです。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンピイは海から来た男で、そしてＰＩＭＰだった――あとで解る――それはいいが、ついうっかりしてるうちに僕も捲き込まれて、その跛足リンプの助手みたいな仕事をしなければならないことになった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるに、この出張売春婦のＰＩＭＰをつかさどるかたわら、第三にそして最後に、彼はほんとの「しっぷ・ちゃん」をも兼ねていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＩＭＰという一つの職業がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、女肉を常食とする点で、リンピイもＰＩＭＰはぴんぷだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、あのＮＡＪＩＭＩの男がまた｜闇黒の海へ出てくるところだというんで、ばいろ・あるとの一つの窓で、ひとりの女が、ひょっと浮んだ彼の体臭の追憶のなかで思い出し笑いにふけっていようというものだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、マルガリイダもＰＩＭＰもなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな中で、モステクノロジー社が売り出していたＫＩＭ―１と名付けられたキットには、日の字型の小さなＬＥＤの表示装置とごく簡単な十六進のキーボードが組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫＩＭ―１を紹介した雑誌の写真を見た後藤は、テレタイプのいらないものを作りたいという開発者の意図にうなずいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "横須賀通信研究所用の教材は、ＫＩＭ―１にならってそれだけで完結して動くものを作ろうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも特に彼らが驚かされたのは、まっとうな企業も数多く存在しているシリコンバレーの中で、一行が彼らとキット式のコンピューターを出しはじめたばかりのＩＭＳＡＩ社のみを訪ねた点だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの年の夏には、アルテアと同じく８０８０を使ったＩＭＳＡＩ８０８０と名付けられた対抗機が登場した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発元のマイクロプロ社を設立したシーモア・ルービンスタインは、アルテアを追って生まれたＩＭＳＡＩの会社を経て、今度はでき上がったマシンで走らせるソフトウエアの会社を起こそうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年の初頭、アメリカに戻ったルービンスタインは、コンピューターキットを売っている店でＩＭＳＡＩを買い求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインはミラードに連絡をとり、ＩＭＳＡＩのマーケティング部長として働くことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで彼は、ベーシックとは性格の異なるオペレーティングシステム（ＯＳ）と呼ばれる基本ソフトをＩＭＳＡＩに載せるために、コンサルティングを依頼していたグレン・ユーイングを通じて開発元に連絡をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩのコンサルタントをしていたグレン・ユーイングから一九七六年に連絡を受けた段階では、ＣＰ／Ｍはすでに異なった四つのシステムで使われるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーイングの用件は、ＩＭＳＡＩが「ＯＳはすぐに間に合わせる」としてすでに売りはじめていたドライブ用に、ＣＰ／Ｍを使わせてほしいという依頼だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＩＯＳの切り離しは自分でやったが、ＩＭＳＡＩのマシンへの対応は彼らに任せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "交渉にあたったＩＭＳＡＩのルービンスタインは、「二万五〇〇〇ドルで何本でもＣＰ／Ｍを使ってよい」とする条件をキルドールが呑んだことに驚かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩをはじめとするライバル機に追われはじめると、アルテアでブームに火をつけたＭＩＴＳのエド・ロバーツは、すぐに会社に見切りをつけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩの時代もまた終わりつつあると考えたルービンスタインは、一九七八年に同社を去ってソフトウエアの会社、マイクロプロを設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインがまずやったのは、自分の二週間前にＩＭＳＡＩをやめていた同社の元ソフトウエア開発部長、ロブ・バーナビーを雇うことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアやＩＭＳＡＩの紹介とこれらにつなぐ入出力機器やシンセサイザーの解説記事を用意し、西は自分の名前では「ＴＶゲーム徹底調査」と題した連載記事を持った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにアルテアやＩＭＳＡＩ用に会場で売られている増設メモリーも、八Ｋバイトや一六Ｋバイトといった大容量のものが主役となっており、果ては一枚の増設ボードで六四Ｋバイトという度肝を抜かれるような代物まで登場していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアを追って登場したＩＭＳＡＩは、ゲアリー・キルドールに海軍大学院で教えを受けた、ゴードン・ユーバンクスの開発したベーシックを載せていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じくリースバックの機器のショップとして生まれた横浜のバイトショップ・ソーゴー、そしてムーンベース、コンピュータラブといった秋葉原のショップが、アルテアや続いて登場してきたＩＭＳＡＩ、ＫＩＭ―１などを並べ、雑誌類を取りそろえてマイコンショップの走りとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "６５０２を発表したペドルはこれを用いた組み立てキット式のＫＩＭ―１を売り出し、続いてコモドール社からＰＥＴとして発表されるマシンの開発に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
