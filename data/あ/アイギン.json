[
  {
    "uuid": "177138bb-e14c-5441-b08b-4382149e3f6f",
    "entry": "愛吟",
    "reading": {
      "primary": "あいぎん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "love of reciting or singing favourite poems or songs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛吟は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛吟が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛吟に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛吟が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛吟について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛吟についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛吟について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛吟が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛吟が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛吟は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛吟は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛吟を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛吟をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛吟が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛吟の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛吟を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛吟に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛吟について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛吟は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛吟を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その頃、室生の創造した新らしい詩が、どんなに深く私を感動せしめたことであらう、私は日夜に彼の詩篇を愛吟して手ばなすこともできなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吟長不飽　　愛吟｜長へに飽かず、閑暮樂無窮　　閑暮楽み窮る無し。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに怨みを買って蟄居のあいだに死んだが、自分の経験を一冊の書に綴りて『桜花物語』と題して子孫に遺したが、その人は常に左の古歌を愛吟した。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア一杯だけと思ふ、よく酔へる、二杯、三杯、十杯、さア、景気よく騒がう、あれも呼べ、これも呼べ、八方に電話をかける、後輩どもをよびあつめ、大威張り、陸上競技の投げ槍などを買ひもとめてバルヂンといふ彼の作中人物の愛吟を高らかに誦しつゝアテナイの市民、アテナイの選手を気どつて我が家に帰る。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア一杯だけと思う、よく酔える、二杯、三杯、十杯、さア、景気よく騒ごう、あれも呼べ、これも呼べ、八方に電話をかける、後輩どもをよびあつめ、大威張り、陸上競技の投げ槍などを買いもとめてバルヂンという彼の作中人物の愛吟を高らかに誦しつつアテナイの市民、アテナイの選手を気どって我が家に帰る。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "『卜養狂歌集』を見るに当時｜士人の狂歌を愛吟したる消息を知るに便なるものあり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ずくめにがんどう提燈、あまり安心のゆける装束ではない、それが軽く頭を下げて、「はからずも愛吟の詩を耳にして、つい口に出ました。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
