        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ化について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ化の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ化が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ化について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ化の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ化が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ化という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ化についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ化は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ化が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ化は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ化の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ化は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ化は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それに昨今のアメリカ化はどうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今日、日本のみならず諸国がアメリカ化されつつある点から見て、アメリカニズムは日本人のみならず世界中の人びとにもしたしみ易いであろうから、従ってある点までの普及性は有するであろうが、その翻訳に依る価値の半減はどうにも出来ない事実であろう。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいが、一ばん始末のわるいのが、ちょいと形だけアメリカ化しかかった欧州移民の若い連中だ。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　マイナスのリバティ　敗戦以来十年後、今や日本は完全にアメリカ化されている。",
              "citation": {
                "source": "自由と進歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対する答えは、きわめて明瞭であって、日本はちっともアメリカ化されていないのである。",
              "citation": {
                "source": "自由と進歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ化された建築ややかましい音楽なども好まれないものに属していました。",
              "citation": {
                "source": "アインシュタイン教授をわが国に迎えて",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済安定本部をはじめとして各行政官庁は、その調査統計業務を急速にアメリカ化せざるをえなかった。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、声をひそめて、蒋介石が、アメリカから二千万円貰ったことに、話を引っぱって行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、此の黄と橙の大きな斑はアメリカから直かに取りました。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "為替相場の変動で邦貨低落の為めアメリカから輸入する製紙用の糊がとても高価くなりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、妻はアメリカからの手紙を受け取りました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前の綴りもアメリカ式であるし、そもそもこの事件の発端はアメリカから来た手紙でした。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならば作業仮説として、その何か・誰かへの恐れが彼をアメリカから出させたと考えてもよい。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは大冊を伏せ、「結社の突然の解体とオープンショウが書類を持ってアメリカから消えた年とが一致する。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカから数年遅れで変化の波が及んでくる日本では、ＤＴＰは本格的なスタートの一歩手前でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塩辛かったかしら」　けさのスウプは、こないだアメリカから配給になった罐詰のグリンピイスを裏ごしして、私がポタージュみたいに作ったもので、もともとお料理には自信が無いので、お母さまに、いいえ、と言われても、なおも、はらはらしてそうたずねた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんだ、アメリカか。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は支那の海岸から、日本の岸へ着いた波だ―』　つづいて浦塩から着いた波や、アメリカから着いた波達が答へた、この国際的な波の笑ひは次第に高くなつていつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアメリカからブラジル、それから大陸にわたつて、イギリス、フランスと浮浪して歩いたやうな人であつた。",
              "citation": {
                "source": "夏",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "東向きの腰高窓には、もう冬といっていい十一月末の日が熱のない強い光を射つけて、アメリカから買って帰った上等の香水をふりかけた匂い玉からかすかながらきわめて上品な芳芬を静かに部屋の中にまき散らしていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石女性尊重の本家本元アメリカから輸入された事は争われぬ」　おさし合いがあったら御免なさい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その人達は何時でも、アメリカから取り寄せて、モーターやボイラーの写真の入った雑誌を読んでいます。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はアメリカから帰ってきたのだ。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "深尾のお嬢さまがアメリカからお帰りになって、このホテルにとまっていらっしゃるという噂を私はきいたのです。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、てっきり、おなくなりになったとばかり思いつめていたお嬢さまが、不意にアメリカからお帰りになって、しかもこのホテルにいらっしゃるときいて、身体中の血が干からびてしまうかと思われる程びっくりしてしまいました。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、新吉へアメリカから来る数々の船の写真帖を耽念に繰り展げた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの奇怪な大きい魚のくちばしがあの水沢のステッキによく似ていることで、アメリカから持って来たというあの珍らしいステッキは、この魚のくちばしで作ったものではあるまいか。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船はアメリカからこのアイスランドへ直航したんでしょう」「そのとおりだ」「そうでしょう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカから手紙だよ。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人といふ奴は、巾着切でも、人殺しでも良い、これはアメリカから習つたのだとさへ言へば、自分の財布を掏られても、女房の心の臓を引抜かれても平気でゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
