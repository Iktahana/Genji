        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "家の娘は四歳であるが、ことしの八月に生れた赤子の頭をコツンと殴つたりしてゐる。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の娘は四歳であるが、ことしの八月に生れた赤子の頭をコツンと殴ったりしている。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教家は赤子の心にかえらねばならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを学生のいうことでも馬鹿にしないで真面目に受け入れて、学問のためには赤子も大人も区別しない先生の態度に感激したりした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戸のあいてる時をねらって赤子の頭を突いてやれ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子をおぶって、それをゆさぶるような足取りをして、麦の芽をふんでいる母親たちの姿が哀れに見えた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、またそういう独創的な仕事の常として「きずだらけの玉」といったようなものが多いから、アカデミックな立場から批評してそのきずだけを指摘すればこれを葬り去るのは赤子の手をねじ上げるよりも容易である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで科学者は眼前に現われる現象に対して言わば赤子のごとき無私無我の心をもっていなければならない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある女性においては、赤子のほかに見出されないような初々しさを染めだす。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子の手をねじり上げることができようか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は赤子の如く大地の上に生まれ出たのだ。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子が醜いやうに生れたばかりの春は醜い。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無際の憐愍と同情とを以て、陛下の赤子に対し公明にして周到なる審判を為すことを理想として居る人人である。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はなにかの事情で赤子をかゝへて、そこに忍んでゐるのであらうと思つた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この婦の日頃ねんじ奉つる観音出でて僧と現じ、亡婦の腹より赤子を出し、あたりの賤の女にあづけ、飴をもつて養育させたまひけり。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音が僧に化してその赤子を救ひ出したといふのは、いかにも昔の伝説らしい。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤子の啼声を恰も通りかゝつた久圓寺の僧が聞きつけて拾ひあげた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女の乳のない寺中で赤子を育てるのは難儀なので、乳の代りに飴をあたへてゐた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕雀、赤子の泣声、犬の吠えるのも旅のあはれだ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のうちには、戀に燃えて薄命に終ツた美人もあツたらう、また慾に渇いて因業な世渡をした老婆もあツたらう、それからまた尚だ赤子に乳房を啣ませたことの無い少婦や胸に瞋恚のほむらを燃やしながら斃れた醜婦もあツたであらう。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い美しい眉も、さも温順に見えたが、鼻は希臘型とでもいふのか、形好く通ツて、花びらのやうな唇は紅く、顎は赤子の其のやうにくびれてゐた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおふくろは、些と眉をひそめ、「柄は大きくツても、尚だカラ赤子なんですから。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も喰い物を与えなかったせいか、美しかった肉付きがスッカリ落ちこけて、骸骨のようになって仰臥していたが、死んだ赤子の片足を半分ばかり生み出したまま、苦悶しいしい絶息したらしく、両手の爪をボロ畳に掘り立てて、全身を反り橋のように硬直させていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青年の親達はどんな人か、どんな育ちかと、かの女は女性にありがちな通俗的な思案にふけって居るうちに、自分のむす子が赤子のとき、あんまりかの女達が若い親だったことを思い出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れ立ての赤子の掌を寵愛せずにはゐられないやうな、女の本能のプチー（小さくて可愛いゝ）なものに牽かるゝ母性愛的愛慾がかの女の青春を飛び越して、食慾に化してかの女を前へ推しやつた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子は針の形をしてゐながら、色も姿も赤子のやうに幼い棘の新芽を、生意気にも可愛らしく思つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその芽が切なく叫んだやうに、赤子の泣き声が桂子の耳の奥に幻聴を起させた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅から自動車で迎へに来たせん子は、赤子を抱いたまゝ会場を廻つたので疲れて、今食堂で何か飲物を摂つてゐる――桂子はたゞ一人闇空の下に立ち現はれてＱ――芸館の屋上庭園を靴の底に踏み締めた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の娘をよそにかたづけて、まず一安心と思っていたら、それがあなた、一年経つか経たないうちに、乞食のような身なりで赤子をかかえ、四、五日まえにあたしのところへ帰って来て、亭主が手拭いをさげて銭湯へ出かけて、それっきり他の女のところへ行ってしまった、と泣きながら言うけれど、馬鹿らしい話じゃありませんか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の唄山村暮鳥みなとのはるのよあめもよひどこからきたのかふながかりみなとのてんまにひがついたひとつぽつちりひがついたみなとのはるのよあめもよひてんまであかごがないてゐた",
              "citation": {
                "source": "港の唄",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
