          ],
          "literary": [
            {
              "text": "彼等の科學智識が一般的に發達してゐることは、一昔前に育つた僕等の大人が、しばしば唖然として舌を卷くほどでさへもある。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日辻潤來り、わが生活の荒蕪を見て唖然とせしが、忽ち顧みて大に笑ひ、共に酒を汲んで長嘆す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者唖然たらざるを得ない。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、その時、親爺の破廉恥さ加減に、暫らく唖然とした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの助平の責任を、何もご存じない天の神さまに転嫁しようとたくらむのだから、神さまだって唖然とせざるを得まい。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり掃溜から出たお話で……」「……やはり掃溜から……イカナ事……」　松倉十内は唖然となった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ」　今度は赤猪口兵衛が唖然となった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に結婚当初、恋愛生活を夫婦愛と間違えていたものは、結婚後二年、三年、五年と経つうちに、余りに身近く打ち融けてお互いに異性としての魅力もなくなり、兄妹のごとく、師弟のごとく、母子のごとく、友達のごとく、感じて来るのに唖然として新婚の快い夢が覚めるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行相顧みて唖然たり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一同聞いて唖然たり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢等呆れ果てて顔見合せ、唖然として言葉無し。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉岡忠一の友人が、そんな馬鹿馬鹿しい目に逢ったかと思うと、実に唖然とせざるを得なかったよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの事に僕は度ぎもを抜かれて了ってしばらくは唖然としていました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は新聞を手に持って、椅子に腰をかけたまま、唖然としてその姿を見上げ見下した。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若崎は唖然として驚いた。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真屋も驚いたが、われわれも唖然とした。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは唖然として見上げてゆく。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手数はかけません」「死骸はどこに隠した……この家の主人の死骸を……」「知りません」　私は内心唖然とした。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここはどこ……」「古木レントゲン病院……」　私は唖然となった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二万円の話はドウしてくれるんですか」「十二万円……何が十二万円だい」「……………」「十二万円儲かる話でもあるのかい」　戸塚は唖然となったらしい。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と気付きながら何も彼も忘れて唖然となった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コイツに習うただけじゃ」　釈宗演和尚唖然。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "馳付けた同志の連中も、手を拍って快哉を叫んでいる奈良原少年の真赤な顔を見て唖然となった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖然として見惚れている仁三郎とその相棒を尻目にかけ、件の小丼を仁三郎の背後のバンコに置き、颯爽として奥へ這入り、店の親爺を捉まえて商売物の棕梠箒で棕梠ハタキを押付けて酒代にすべく談判を始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "箒売は土間の真中に突立ったまま唖然となって、上機嫌の二人を眺めておった……が、やがてガラリと血相を変えると、知らん顔をして指を舐めている仁三郎に喰って蒐った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそばを通ったとき、私は唖然としたのだが、ホームズが私の前に身を乗り出してわざとつっかかり、全部をひっくり返してしまった。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "全然無意味……僕の註文通りに……」　健策は一寸の間唖然となった。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「鮎の鮨とは、」「荘河の名産ですって、」　先達は唖然として、「どうもならん。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　金之助は唖然として、「口の端を拭け、泡だらけだ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目に唖然たるものこれを久しゅうして、「駄目。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
