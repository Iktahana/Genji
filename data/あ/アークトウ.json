        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アーク灯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーク灯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーク灯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーク灯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーク灯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーク灯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーク灯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーク灯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーク灯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーク灯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーク灯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーク灯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーク灯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーク灯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "円筒の外線には小さいアーク灯があって強い一条の光線を送り、写真の膜を通じて筒中のセレニウムを照らす。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近頃マルコニ氏はアーク灯などは用いず従来の火花式を少し変更すれば容易に規則正しい波を生ずる事を発明したと伝えられる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来電気の応用が盛んになるにつれて色々の事に炭を使う、白熱電灯の細い線も炭、アーク灯の中の光る棒も炭である、電話機の受話口の中の最も要用なものは炭でこしらえた丸薬のようなものである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「薄紫きのアーク灯！",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク灯の光は強いけれどそれでは新聞は読み難い。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二三分の後には、もう暗い家の中を抜け出して、アーク灯の光のように白い戸外の夏の日をあびていたのだ。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがまたすぐにそれをはなして、泣きながら、アーク灯の濡れるような光を浴びて走って逃げ出しました。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の前には巨大な杉葉の緑のアーチが建つて、アーク灯といふ大ランプが煌めいた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の隣の勧工場には早くからアーク灯がついていてその光りの色を私は大へん好んだ。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には星、地にはアーク灯、それのみが静かに輝いていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく芝居の前のアーク灯という古めかしく青い電灯がうようよと夏の虫を集め、宗右衛門町の茶屋の二階に暗いランプが点っていたに過ぎなかった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、それを忘れないで……」　そういったかと思うと、Ｘ大使の姿は、俄かに、アーク灯のごとく輝きだした。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると本館の五階の窓が四つほどアーク灯のような真青な閃光でピカピカと明滅しているのであった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに本館の方で、突然金属板を叩くような物音がしたり、アーク灯のようなものがピカピカ輝きだしたりするとは、どうしたわけであろうか。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中サロンもだんだん賑やかになって、女まじりに三、四人、ピアノのそばにやって来たから、御免を蒙って寝室に逃げ出してしまった、庭のアーク灯は昼間のようで、気楽な連中はまだスケートをやっている。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファウルホルンの方角にはシンニゲ・プラッテの附近が際立って明るく、ニーセンの頂上にはアーク灯らしい光が天狼星のように光る。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いアーク灯の光りに輝らされた線路の上に血が滴っている幻が浮んできた。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋のたもとのアーク灯の光のなかを、翅を凍らせた蝶々のやうに、白いショールに顎を埋めた芸者衆が現れては消え、現れては消えしてゐた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは初めまだ温度が充分高くならぬうちに、アーク灯の光の熱線を火球の片側へ水晶レンズで集光したら、その側から先に火花が出始めるかという疑問が起る。",
              "citation": {
                "source": "線香花火",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんなら、寄り添った人影もチラチラ見えよう時刻だが、さすがに元旦からこんな処をうろつく者もないと見え、まだ宵の口ながら森閑と鎮まりかえり、池の汀のアーク灯ばかり徒らに皎々と冴えかえっている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の岸のアーク灯が煌々と冴え返り、青銅の鶴は夜目にも白い幽玄な水の穂をキラキラと夜空に噴き上げる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮絶快絶、船はアーク灯下に照らされるようで、船首、手綱、舷側等は、特に一種名状することの出来ない強い凄い青光を放った。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には緑葉の地に「聖壽萬歳」と白く菊花にてぬきたる大額をかゝげ、天井には隙間もなく列国旗を掛けて、五色のアーク灯の光もあやに、床は鏡の如く磨きたればきら／＼しく照り渡りて、燕尾服、桃紅色服、水色服、扇影、簪光参差として床の上に落ち散りたり。",
              "citation": {
                "source": "燕尾服着初の記",
                "author": "徳富盧花",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後八時過ぎ、電気アーク灯が紫色に輝くころ、急行列車が止まった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に揺れるガス灯の明かりが舗道にゆらゆら、敷石にぼーっと落ち、ほ影が強烈なアーク灯の輝きで消える、そこがコベント・ガーデンだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気アーク灯が照らし出した顔は蒼白で怖がっている。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いアーク灯の炎に照らされて、十数人の男たちがトンネル心壁の天井で作業している。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギラギラ光るアーク灯の明かりの下では赤帽が汗をかきながら、おばけのような青色荷物車で待っている。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、紫のアーク灯からちょっと離れた場所のロンドンは、眠りこけ……。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
