        "examples": {
          "standard": [
            {
              "text": "私は毎日アマービレについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アマービレという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアマービレの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアマービレが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アマービレを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアマービレについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アマービレの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアマービレの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアマービレが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アマービレという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアマービレという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアマービレについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アマービレを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアマービレは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アマービレについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアマービレが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアマービレは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアマービレの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アマービレは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアマービレは興味深い例である。",
              "source": "幻辞"
            }
          ],
