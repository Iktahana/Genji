          ],
          "literary": [
            {
              "text": "待ちに待った朝は来た、朝がいかなる方面から、いかに忍び足に寄って来て、一秒ずつ額を白くしたかは徹夜凝視しても解らない、夜と朝の筋目が判然と目立つほどなら、地球の緯度線が草鞋の爪先に引っかかるわけである、しかも争う可らざるは朝の神秘なり、一たび臨むとき、木偶には魂を、大理石には血を与る。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "とったくらい与るぞ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合もそれは目出度と言うので、いくらか包んで与る者もあり、即吟で無理に一句浮べる者もありさ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家へ行ってから与る。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客が与るというんだから、取っといたらいいじゃないか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それだから戯って与るんだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄嗟の間に思案を定めて、腰に提げたる割籠から食残りの握飯を把出して、「これを与るから手伝って担いで呉れ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな奴でも、俺ア必然仇を取って与る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌うなら嫌うが可い、妾ア必然祟って与るから……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌えば嫌うほど執念深く祟って与るのが当然だアね。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "必然あの人を呼んで、お前さん達に見せ付けて与るから……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し此の女がここの門を潜った所を見ると、妾は何日でも押掛けて来て、頭の毛を一本一本引ッこ抜いて与るから、然う思ってお在なさい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "罷り間違ったらば、其の喉笛にでも啖い付いて与るまでのこと。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "究竟は無心の小児に対って菓子を与ると戯った為に、小児は本気になって是非｜呉れろと強請って来たような理屈である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にも最ッと良い衣類を被せて与る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎にかく何んな奴だか面を見て与るから……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上の分割に与るのは、それは学校を卒業したら、いやでも分割に与るのだ。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち分割のこと、これに与るも不利、与らざるも不利、然らばこれに対処するの策なきか。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がまた世の中へ帰って朝政に与るような喜びは私にたいしたこととは思われないで、そうした恋愛問題のほうがたいせつに思われる私なのですから、どんな抑制を心に加えてあなたの御後見だけに満足していることか、それをご存じになっていますか、御同情でもしていただかなければかいがありません」　と源氏は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "何等の祝福ぞ、末代下根の我等にして、この稀有微妙の心証を成じて、無量の法の喜びに与るを得べしとは。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾れは神にあらず、又大自然の一波一浪たる人にもあらず、吾れは「神の子」也、天地人生の経営に与る神の子也。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼もさうして悔悟してをるのぢやから、君も悔悟するが可からう、悔悟する時ぢやらうと思ふ」「彼の悔悟は彼の悔悟で、僕の与る事は無い。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も亦分け前に与るべきである。",
              "citation": {
                "source": "解嘲",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の度にお文が白いのを鼻紙に包んで与るのを、源太郎は下手な煙草の吸ひやうをしながら、眼を光らして見てゐる。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "陪審人が僧正の夕餐に与るためには、罪人が一人｜絞り殺される――って。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般感覚と云うものが如何ほど我々の心に影響を与るかと云うことをはっきりと感じる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそのひとのお金をあずかると、どうも、責任を感じて僕はうまく酔えません。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンは卜占者にふさわしいようなものものしい学者めいた服装をし、目明きには見えないものが見え、目明きには考えられないものが考えられるとふれて回って、聖マルティンのおるすをあずかる予言者だと自分からいいだしました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩文の造詣と才は、全く天下一品だったので、その方の世話にだけあずかる積りで止宿を乞うていたのであるが、もはや自分の目的が変った以上寺を出て仕舞ってもよかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうわけでこんなおもてなしにあずかるのか先刻からしきりに考えているのです。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
