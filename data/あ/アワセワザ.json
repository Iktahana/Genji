        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日合わせ技について考えている。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は合わせ技の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には合わせ技が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは合わせ技について学習した。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は合わせ技の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では合わせ技が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に合わせ技という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では合わせ技についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると合わせ技は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では合わせ技が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合わせ技は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により合わせ技の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "合わせ技は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に合わせ技は興味深い例である。",
              "source": "幻辞"
            }
