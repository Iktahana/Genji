    "definitions": [
      {
        "index": 1,
        "gloss": "after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフターについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフターは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフターの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフターについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフターは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフターの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフターに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフターが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフターを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフターの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフターが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフターが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフターについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフターは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフターは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフターは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフターについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフターの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフターの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフターの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "当時取りかかっていた仕事は、アメリカのボイジャーからこの年の八月に刊行された、『ザ・デイ・アフター・トリニティー』というＣＤ―ＲＯＭの翻訳でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平岡敬広島市長の陳述『ザ・ディ・アフター・トリニティー』日本語版の発売開始は、一九九六（平成八）年二月のマックワールドエキスポを目標に据えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚的には、ソフトもアフターケアーもハードのおまけだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "10気分よく暮らすのが好きなんだこういうぜいたくな暮らしがね陽射しの明るい夏の午後にこうして怠けているのが〈サニー・アフターヌーン〉キンクス　七月二十八日には、映画にはいけなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子爆弾開発プロジェクトの中心となった物理学者、ロバート・オッペンハイマーの軌跡をたどったドキュメンタリー映画、『ザ・デイ・アフター・トリニティー』を中心に据えたタイトルだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に『ザ・デイ・アフター・トリニティー』を紹介しようとするのなら、この作品がもっぱら片側の声のみを拾ったものであることを自覚するべきだと、しだいにそう思うようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、空色のアフターヌウンに黒い毛皮の外套を着た若い婦人と、先刻銀行で顔を合せた老婦人が、飛鳥のような素早さで自動車から下りて、石段を馳上るなり、厚い扉の裡に姿を隠してしまった。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフターケアはサナトリウム治療と同じくらい重要でありサナトリウム治療は教育、早期発見に始まりリハビリテーションに終わる一連の社会的処置の一環に過ぎない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方ではアフター・デンナー・スピーチという。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しわがれたすごみのある声をはりあげていろんなことをラジオでしゃべり、ロックのレコードをかけ、話にアフタービートをつけるため、ニューヨークの電話帳を、マイクロフォンが乗っているデスクに叩きつけるのを自分の仕事の一部としていたＤＪ、アラン・フリードも、スターだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
