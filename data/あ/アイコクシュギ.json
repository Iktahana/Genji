    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nationalism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛国主義は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛国主義が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛国主義に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛国主義が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛国主義について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛国主義についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛国主義について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛国主義が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛国主義が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛国主義は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛国主義は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛国主義を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛国主義をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛国主義が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛国主義の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛国主義を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛国主義に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛国主義について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛国主義は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛国主義を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この十年間に、文学運動の上では、言文一致の提唱とその勝利があったが、そしてそれは、より直接的に社会生活を反映し得る手段を整えたものと云い得るのだが、作品に於ては、現実は歪曲され、愛国主義は鼓吹された。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肉弾」は熱烈な愛国主義に貫かれている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国主義は、それ自身決して不自然な感情でもないし、浅薄なものでもない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は地主的或はブルジョア的イデオロギーの持主ではあったが、しかし、決してブルジョア乃至は愛国主義の番犬ではなかった。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう奴等は、一とたび帝国主義××が起れば、反対するどころか、あわてはためいて、愛国主義に走ってしまうのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "篤胤は、春満、真淵、宣長と共に国学の四大人と呼ばれてゐるが、その尊皇愛国主義の主張は実行的であつたために、幕府に忌憚され、天保十二年江戸を逐はれ、秋田に帰郷を命ぜられ、その著「扶桑国号考」は絶版となつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は愛国主義者だから、同じ死ぬなら国のために死のうと思ったんだが、ところが、なかなか支那人は殺してくれぬ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしももうじき愛国主義者になるんだから。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい君、ここへ来てくれ、愛国主義者は一番｜豪いのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国主義者を出したからには、誰であろうと恩人さ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ下級社員に愛国主義以外の何がある。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君のように愛国主義者になったんだが、もう僕は君より立派なものさ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、この満蒙事件をキッカケにブルジョア・地主の政府は愛国主義、ファシズムをふりかざし一切の大衆的な働く者の闘争的な力を、根こそぎ押し潰そうとしているのです。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反動的な教化団体の組織（希望社その他）や君が代の暗誦、役人の忠君愛国主義鼓吹の講演、闘争を鈍らすための御用スポーツ、こんなのが唯一の文化的施設だ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠君愛国主義が教化政策の根底におかれている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを現在の社会状態に鑑みて是とする者、愛国主義、或は軍備主義の尊重から、国家滅亡論として極端に拒絶する者。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民生活の収奪のひどさに苦しむ一般の感情に乗じて、きょうの日本のファシストは左からぐるっと右へまわった愛国主義の鼓舞、民族主義、内閣打倒を思っている。",
              "citation": {
                "source": "作家は戦争挑発とたたかう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内では工場が閉鎖され、農村で働き手がなくなって、パンが欠乏し、全く窮乏のドン底に陥っているのに、搾取者どもは、猶も愛国主義をふり立てて、労働者農民を大砲毒ガスの餌じきに送ろうとする。",
              "citation": {
                "source": "ロシア革命は婦人を解放した",
                "author": "――口火を切った婦人デーの闘い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの中にも狂信的な愛国主義者になり切ったものがいたが、そんな青年たちでさえ、助かる程度の戦傷を受けた際は勇ましく、「天皇陛下万歳」を叫び、瀕死の重傷の場合は弱々しく、「お母さん。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実玄竜は体よく愛国主義の美名のもとに隠れて、朝鮮語での述作はおろか言語そのものの存在さえも政治的な無言の反逆だと讒誣をして廻る者の一人なのだ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄竜はそれにつけ込んで愛国主義をふりかざし人々を売りつけながらのさばり廻っているのだった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今はもう朝鮮にも愛国熱は漸次高まって所期の目的は殆んど達せられつつあるのに、愛国主義をふりかざして社会の公安を妨げ到るところで悪事を働く玄竜を、そのまま用いることは大村の威信にも関ることと云わねばならぬ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に彼が拠りどころとして思い附いたのは、愛国主義者という美名のもとに隠れて凡てに向って復讎を計るばかりか、勢威のある大村にかばわれることだったのだ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の主幹となって経営していた雑誌「世界」は、後に「我邦」と改称し、なお藤花学会という愛国主義鼓吹の団体も今は存否如何を知らぬが、孤松氏尽力の形見であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民大衆の愛国心は、所謂「愛国主義者」のデモンストレエシヨンによつて、判断することもできず、官憲や教育当事者の日本精神鼓吹によつて、高め得るものでないのである。",
              "citation": {
                "source": "日本に生れた以上は",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "フアツシヨの名を以て呼ばれる愛国主義が、いかに心ある民衆の希望を、祖国日本より引離しつつあるかを見ればわかる。",
              "citation": {
                "source": "日本に生れた以上は",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来この種の雅致は或一派の愛国主義者をして断言せしむれば、日本人独特固有の趣味とまで解釈されている位で、室内装飾の一例を以てしても、床柱には必ず皮のついたままの天然木を用いたり花を活けるに切り放した青竹の筒を以てするなどは、なるほど Rococo 式にも Empire 式にもないようである。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの意味する愛国主義は、郷土の美を永遠に保護し、国語の純化洗練に力むる事を以て第一の義務なりと考うるのである。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
