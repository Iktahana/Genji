        "examples": {
          "standard": [
            {
              "text": "私は毎日安堵感について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安堵感という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安堵感の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安堵感が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安堵感を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安堵感について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安堵感の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安堵感の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安堵感が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安堵感という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安堵感という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安堵感についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安堵感を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安堵感は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安堵感について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安堵感が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安堵感は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安堵感の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安堵感は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安堵感は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先年なくなつた私の生みの母は、気品高くおだやかな立派な母であつたが、このやうな不思議な安堵感を私に与へてはくれなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道義観の中に動いてゐる間は、彼の人物は自在なのだが――安堵感の上において――倫理感に危まれる様な部分になると、彼の芸は、俄かに自信を失ふ。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが母に見破られずに済んだことに、少年は一様の羞恥と、おびただしい安堵感とを味はつたのである。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切りにも似た安堵感を覚えつつ、私はこの明白にして散文的な出来事を歓迎した。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がこんなにも自分を大事に思ってくれること、また彼といっしょにいる以上、もはや、なにも怖れるものはない、という大きな安堵感のなかで。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禍いは去った、これですっかり終った、という安堵感と、あの方がいかにも哀れに思えたからである。",
              "citation": {
                "source": "やぶからし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩をしなくてもすんだ、という安堵感が、仲仕たちの憂鬱と緊張とを、解いていた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、どきんとして眼を瞠った女が、別人であると知って、或る安堵感をおぼえたのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の風に邦子は安堵感を覚えた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれて初めて体験するほどの安堵感を、彼は覚えた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが急いで服を着ながら感じたのは、ある種の安堵感、家が焼け落ちればもめ事から逃れる方法が見つかるかも。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
