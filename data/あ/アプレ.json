        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アプレについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アプレという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアプレの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアプレが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アプレを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアプレについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アプレの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアプレの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアプレが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アプレという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアプレという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアプレについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アプレを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアプレは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アプレについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアプレが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアプレは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアプレの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アプレは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアプレは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さてそのついでに調べると、小栗の譚は日本の史実を本としたものの、西暦二世紀に、チミジア国（今のアルゼリア）の人アプレイウスが書いた、『金驢篇』の処々を摸し入れた跡が少なくない。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おまえ、エアプレインの〈トライアド〉って曲を知ってるか」　一瞬、慶一はギョッとしたが、それは意外なことをきいたからではなく、あるいはそうかもしれないと感じていたことを、高志が口にしたからだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへピンカートンの友人の米国領事シャアプレスがやってきて、ピンカートンに、歓楽もよいがその結果が恐ろしいと苦労人らしく忠告しますが、結局、他日ピンカートンがアメリカ婦人と正式に結婚する日を祝して乾杯するのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ領事のシャアプレスが訪れてピンカートンから手紙がきたことを話します。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、アプレ・ゲールのデフォルマシオンとして、案外、読者の眼をごまかせるかも知れない。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでいゝ」といふ時機は、非常に遠い将来であるかもわからないが、われわれとしては、たゞ、戯曲のインタアプレエトとしての俳優の素質を、より合理的な方法によつて、より速かに向上させることを努めたいと思ふ。",
              "citation": {
                "source": "新劇協会公演に先だつて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシャ哲学、近代政治、労働組合、アプレ・ゲールの理念、なんでも聞かれないものはない。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意気や壮、名人の大度、フェアプレー。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日手が絶対たるべきものなら、それを避けて出た名人はフェアプレーどころではなく、将棋に忠実誠実でなかつたもので、即ち、負ける当然な性格だつた。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると村山は、さう話がきまれば自分の勝と考へたから、あとは時間の問題、この際トキ子の身をまもることが大切で、話がきまつた以上、求婚者が娘の家に同居するのは間違ひが起り易いから、解決までフェアプレー、ほかの家へ宿をとらうと巧みに話をもちかけて、二人は星野家の真向ひの長屋へ隣同志に別れて下宿した。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争というちょうど手ごろな境界線のような手がかりがあるから、何もかもアプレゲールで片づけるのは、安直に好都合かも知れんが理に合ったことではない。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプレゲールという安直な定義にたよったのは、日本人の人生に対処する目が浅かったせいであろう。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "親を捨てる子、の現象も決してアプレゲールと限ったものではない。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、戦後特に子に捨てられる親が多くなった一因として、親の方にヒガミやヤケが生まれ、忍従やアキラメを失った事実を指摘しうるという点に於て、これこそは戦争の生んだ特異現象の一ツであり、あるいは確かにアプレゲールと称してよろしいものではないかとも思う。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、長いパニックの連続は、彼らを、二千年のアプレゲール、「矛盾的性格」に追い込んでいる。",
              "citation": {
                "source": "大衆の知恵",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをラテン語に訳す時、アプレウスとか、ポエチウスが、subiectum と、「下に」（sub）「置かれている」（iectum）とあてはめたらしい。",
              "citation": {
                "source": "言語は生きている",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてそれはアプレゲールのシュール・リアリズム、あるいはもはや全然肯定のない単なる否定の連続に陥るダダイズムにまでいたるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼等は、申し合せたやうに「アプレた男」のすがたをしてゐた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋の手代とはいえギャバジンの洋服をリュウと着こなして、見るからに少し足りないアプレ型である。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅の奴、アプレの手に負えないノラクラ大学生だと思っていたが、大そう親思いの孝行息子じゃないか。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプレの青年でもヒノエウマは迷信と断じながらもオレは辰年の生れだとか、アイツは寅だから気が強いなぞと無自覚に語り合ってしまうのが自然で、祖父から父母へ、また子へと、家庭の会話の伝統というものが電気センタク機やラジオと甲乙ない生命力を持っているのだ。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くもねえ、姉様だってアプレの癖に……」「こんな老嬢もやはりアプレのうちなのね」「来年から年一つ若くなるんだよ。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、お杉にはスカッとしたところがあるから、アプレじゃないわね」　蓬莱和子は仁科六郎に云った。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、四年目には静かに校門より送りだすべきであろうと思う」「アプレの模範だな」　と誰かが相槌だかマゼッ返しだか分らないことを云った。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプレゲールの絶望感には最適であるから、カストリを飲む金があったら、精神病院へ旅行するに限るのである。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前大戦アプレゲール派のコクトオ氏なども、前代的絶望感によって、鴉片窟へ通った。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクらアプレゲールは祖国なみに廃墟に生れた人間ですからね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前らも、何か、アプレゲールか。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプレゲールは喉がつぶれているワケじゃアねえだろう。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
