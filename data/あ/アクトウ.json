          ],
          "literary": [
            {
              "text": "私はもう自分の悪党にあきれてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く私が悪党を云うた為に民子は死んだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐすぐずしていると、ほんものの方が乗り込んで来るかも知れないというので、無暗に支度を急いだもんですから、乗物までは手がまわらないで、飛んだ唯今のお笑い草となってしまいましたよ」と、お俊はさすがに悪党だけに何もかも思い切りよくしゃべってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場には、悪党上りが集った場所によくある、留置場のような、一種特別な、ざっくばらんな空気がかもされていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　幹太郎は、悪党に対して純なものの正しさを譲るまいと心がけながら云った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ名のある、というのが日本の歌舞伎では悪党を形容する言葉になっているようだが、サタンは、二つや三つどころではない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋には血も涙もない悪党が多い。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなつもりで、世界中を悪党だらけにするつもりで、一生懸命に書いたらしく、この世界が「悪」ばっかりで固まっている世界だ……神様なんてものは唯、悪魔の手伝いに出て来た位のもんだっていう事を、出来るだけ念入りに説明しているんです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑怯者と呼ばれても悪党と罵しられてもビクともしないであろう一種の冒険を、特に「金」というものに対して試み続けて来た人間である。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも相当の悪党じゃったかも知れん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は悪党だが善人を悪党の群に引張りこむほどの悪党ではないんですよ、おぬいさん。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田が黒いばかり、透通るような雪の肌の、骨も見え透いた美しいのに、可恐しい悪党。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに私もあの時分に心得違いをしていたから、見処のあるお前さん、立派な悪党に仕立ててみようと、そう思ったんだがね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ決闘をしろ」　狐が実に悪党らしい顔をして言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（度胸の据った悪党だ、）と泰助は心に思いつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さりとは底の知れぬ悪党なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝むにも、後姿でのうては罰の当ります処、悪党なら、お前様、発心のしどころを。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党のくせに、よくよく思い切りの悪い奴で、そこがやっぱり女ですね」「問題の睡り薬は、どっちの女が持っていたんです」　と、私は最後に訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――あんたは、悪党よ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今更居直ったりして何と云う悪党なんだ！",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘は眉根の※しい悪党みたいな人相だったが、中村はいっそそこが気に入ったと云うのであった。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも特に私の興味を惹いたのは「悪」の字を取扱った小説や講談で、悪党とか、悪魔とか名付けられる人物や、そんな思想を取り入れた読みものは何故だかわからないまま奇妙に惹き付けられて読まされた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党のような顔をしている。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、ひどい悪党もいます」　むす子は母親の眼の前に現実を突きつけるように意地悪く云い放ちながら、握った手では母親の怯えの脉をみていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かのはずみでまた許嫁の話になると、規矩男はまるでかの女が無理にその女性を規矩男に押しつけてでもいるような、云いがかりらしい口調を洩らしたり、少しの間かの女がむっつりと俯向いて歩いていると、規矩男はだしぬけに悪党のような口調で云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい策士かも知れないけれど、決して大きい悪党じゃない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（清蔵）（すっかり悪党らしく落ちつき）静かにしなさい。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰しも、自分の為事でない側の事をそそのかすあくとうに誘われると、よい気になって、つい浮かれずには居られぬものである。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
