    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to blow (of autumn wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "親に似て恐ろしかろうといって、親のわるい着物を引きかぶせてやり、秋風が吹く頃になったら来るよとだまして逃げて行ったのを、そうとは知らず、秋風を音にきき知って、父よ父よと恋しがって鳴くのだ」というのである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍に藪はあっても、竹を挫き、枝を折るほどの勢もないから、玉江の蘆は名のみ聞く、……湯のような浅沼の蘆を折取って、くるくるとまわしても、何、秋風が吹くものか。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食慾は底知れぬほどで、同居人の殘飯は一粒も殘さず平らげ、秋から冬にかけては、しばしば暴力をもつて同居人の食料を強奪するので、若い他の二人は秋風が吹く頃から、又一つ苦勞の種がふえるのであつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食欲は底知れぬほどで、同居人の残飯は一粒も残さず平らげ、秋から冬にかけては、しばしば暴力をもって同居人の食料を強奪するので、若い他の二人は秋風が吹くころから、また一つ苦労の種がふえるのであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子をあけてはゐられないほど秋風が吹く、蓮の葉の裏返つた色にも秋の思ひが濃くゆらぐ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しよう／＼として秋風が吹く、いろ／＼の虫が家の中へまで入つてくる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ身にしむほどの秋風が吹くのではないが、しめっぽく曇る心をばかり持って夫人は日を送った。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十月×日）　秋風が吹くようになった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十月×日）　秋風が吹く頃になりました。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "干杏干胡桃何れも山の信濃の名産、それを並べた店の四尺程のけちな棚を天下の秋風が吹く光景である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は単なる写生の歌ではない、秋風が吹くといふ所に作者が強くあらはれて抒情詩の一体を成すのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛の生繁っているのを靡かす秋風が吹く度毎に、阿太の野の萩が散るというのだが、二つとも初秋のものだし、一方は広葉の翻えるもの、一方はこまかい紅い花というので、作者の頭には両方とも感じが乗っていたものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も祖母の看病の疲れや何かでよくなったり悪くなったりいたしましたが、秋風が吹くやうになりましてから祖母も元気ですし、私も気分がよくなってまいりました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と種彦は戯れながらふと植込に吹入る朝風の響に、「いや暑い暑いといっている中もう秋風が吹くと見える。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ胸郭が急にうつろになって、そこを秋風が吹くような気がする。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の夏には、細君の病状が俄に進んだので、今井は一家を挙げて伊豆の伊東に転地し、秋風が吹く頃まで、そこで暮していた。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
