        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日淡路結びについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は淡路結びの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には淡路結びが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは淡路結びについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は淡路結びの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では淡路結びが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に淡路結びという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では淡路結びについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると淡路結びは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では淡路結びが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に淡路結びは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により淡路結びの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "淡路結びは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に淡路結びは興味深い例である。",
              "source": "幻辞"
            }
          ],
