[
  {
    "uuid": "57b6e5ca-c97a-554e-b6aa-e85fa656c678",
    "entry": "改む",
    "reading": {
      "primary": "あらたむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Nidan verb (lower class) with 'mu' ending (archaic)",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日改むについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改むという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改むの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改むが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改むを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改むについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改むの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改むの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改むが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改むという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改むという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改むについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改むを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改むは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改むについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改むが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改むは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改むの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改むは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改むは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それでもしこれが物理学の教科書か学術論文の中の文句であるとすれば当然改むべきはずであるが、随筆中の用語となると必ずしも間違いとは云われないかもしれない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新七は三代目を門弟の竹柴金作に譲りて、おのれは古河黙阿弥と改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、猿若座にて沢村清十郎は名題に昇進し、四代目沢村源之助と改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大小劇場の数は従来二十二カ所に限られいたるを、更に二十七カ所に改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、在来の興行時間は八時間に限られいたるを延長して、九時間に改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十月、坂東勝太郎、三代目坂東秀調と改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、庚午、小笠原御牧の牧士と、奉行人三浦平六兵衛尉義村の代官と喧嘩の事有り、今日沙汰を経らる、此の如き地下職人に対し、奉行と称して恣に張行せしむるの間、動もすれば、喧嘩に及ぶ、偏に公平を忘るるの致す所なり、早く義村の奉行を改む可きの由仰出され、佐原太郎兵衛尉に付せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土俗の、いひならはしにて忌嫌ふのみならず、役人よりも毎度改むる事、珍らしき事なり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝陵の山川は、其の故に因りて改むる勿れ、天下の臣民は、哭臨する三日にして、皆服を釈き、嫁娶を妨ぐるなかれ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其末に、江天　正に秋清く、山水　亦容を改む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例に依つて例の如き舊い運命に生捕られたくないならば、舊い状態を改むるに若くは無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が若し身體を弱くする原因が何で有るかを知悉しながらも、之を改むることが出來ぬやうに意が弱くて、そして身が弱くては、氣の毒ながら其人は自ら新にする事が出來難いのであつて、從來通りの状態を超脱する事は出來ぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に心の上にあらはるゝものにして、心ありて後に善もあり不善もあり、心なければ何を悔改むるところとせむ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "後軍治と改めその後行度と改む。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘治元年九月陶晴賢（隆房と云ったが、後晴賢と改む）二万七千余騎を引率し、山口をうち立ち、岩国永興寺に陣じ、戦評定をする。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元の命のままに、西上の前軍を承って多くの功績を示したが、義元西上の志が粉砕された事によって、竹千代（弘治二年末義元の義弟、関口｜親長の女をめとる、後元康と称し更に家康と改む）の運命が開れようとは当人も想いつかなかったであろう。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる場合に原作を改むることを、芝居にては曲を曲ぐといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "）僧侶は異教の人の歸依せるをもて正法の功力の所爲となし、看る人に誇れども、その異教の人のまことに心より宗旨を改むるは稀なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し我が期するところの效果にして十分ならば、人々はこれを聽きて、その常に我を遇する手段の正しからざるを悟り、未來に於いて自ら改むるに至るならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "懺悔の苦悶、これを愈すの道はただ己れを改むるより他にはあらじ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど如何にしてかその己れを改むべきか、これ将た一の苦悶なり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　あやまちを改むるにはばかる事なかれだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あやまちを改むるに、はばかる事なかれだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何ですか」　唯継は慌忙く身を開きて、「一つこれで御覧下さい」　鏡面に照して二三の改むべきを注意せし後、子爵は種板を挿入るれば、唯継は心得てその邇を避けたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと改むるに相違ないか」「は」　播磨の返事は唯それだけであった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "反省を新たにする、考ふべし、改むべし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三行削除）　もっとも、過って改むるに憚ることなかれ、とも言う。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし君が、世間での評判のように、きわめて動揺しやすい、いわゆる出来心的の女であったのであらば、すなわち僕とのあのこともほんの一時の浮気であったのであらば、過って改むるに何の憚るところがあろう。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自己の内においての直証の事実という代りに、自己成立の事実と改むべきである。",
              "citation": {
                "source": "デカルト哲学について",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ちは改むるに憚る勿れとは古哲の金言、父が言葉｜腑に落ちたるか、横笛が事思ひ切りたるか。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
