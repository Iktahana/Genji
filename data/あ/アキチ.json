        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空き地は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き地対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き地に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き地がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き地は複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、空き地の症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは空き地を核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により空き地の問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における空き地の表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "空き地について学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日空き地について悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から空き地を分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により空き地の原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは空き地を表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で空き地に関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "空き地は日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "空き地対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "空き地に関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では空き地がテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると空き地は複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで空き地に遊んでゐた鳩を追ひ拂つて、そこへ藁莚を敷いて皆が坐ることにした。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建物は小さな空き地の四方を囲んでいた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "空き地には柵が張り巡らされ、中には雑草のような芝生としおれた月桂樹の茂みがあった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けてから彼の来たらしい方角をたずねると、東の空き地に高さ百余尺の柳の大樹があって、ひと筋の矢がその幹に立っていたので、いわゆる柳将軍の正体はこれであることが判った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから裏の空き地へ出て干物を片づける。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋敷は旧幕臣の与力が住んでいたもので、建物のほかに五百坪ほどの空き地がある。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳をすますと、がさがさという音は庭さきの空き地の方から低く響いてくるらしい。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は持っている枝をとり直して、四つ目垣をまわって空き地へ出ると、草むらはまた激しくざわざわ揺れてそよいだ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと口に空き地といっても、ここだけでも四百坪にあまっていて、そこら一面に高い草が繁っている。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからそれへと探しまわると、五百坪ほどの空き地のうちに都合九ヵ所の穴が掘られていることが判った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい草原同様の空き地であるとしても、ここはわたしの家の私有地で、他人がみだりに通行すべき往来ではない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは近所の男と女とがこの空き地を利用して密会していたのではあるまいか。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の空き地の草むらの中で、犬のけたたましく吠える声がきこえるのであった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝になって父は再び空き地を踏査すると、なるほど新しい穴がまた一つふえていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内の者を寝かしてから、父も身支度して空き地へ出張したが、今夜は風のない夜で、草の葉のそよぐ音さえもきこえなかった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも毎朝一度ずつは空き地を見廻って、新しい穴が掘られているかどうかを調べていたが、最初に発見された九ヵ所と後の一ヵ所と、その以外には新しい穴は見いだされなかった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の想像によると、庭の空き地へ忍んで来て、一度は穴に落ち、一度は犬に追われた女は、この安達の奥さんであるらしく思われた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、取り留めた証拠があるわけではないが、庭の空き地に穴を掘るのは単にいたずらの為にするのではない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの庭の空き地へも誰も忍んで来る様子はなかった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにその下は空き地であったが、もしも住宅に接近していたらば、わたしの家は潰されたに相違なかった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "空き地の草原へ穴を掘りに来た者は、おそらく権七とおいねであったろう。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度はうまくいったぞ」留吉は、宿の二階の窓から、裏の空き地へ帽子を投出しました。",
              "citation": {
                "source": "都の眼",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏には、テニスコートぐらい出来そうな空き地がある。",
              "citation": {
                "source": "芝、麻布",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑場はちょうど墓原に隣った、石ころの多い空き地である。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には高台の空き地に小屋をたてて、踊ったり、跳ねたり、弾いたり、唄ったり、芝居や狂言の真似までもした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず僕の見覚えていた幾つかの空き地さえ見当らなかった。",
              "citation": {
                "source": "年末の一日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　　　三十四　色彩　三十歳の彼はいつの間か或空き地を愛してゐた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は眠を破られた人の腹立たしさを感じながら、柏の下に草を敷いた林間の空き地へ眼を落した。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで先生が先頭になって調神社へ参詣する、それから例の空き地へでて猛烈な練習をはじめた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこに少し空き地が見えるね。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
