        "examples": {
          "standard": [
            {
              "text": "亜富汗斯坦について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この亜富汗斯坦は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が亜富汗斯坦について知っています。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は亜富汗斯坦の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では亜富汗斯坦が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から亜富汗斯坦を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも亜富汗斯坦が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では亜富汗斯坦が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも亜富汗斯坦は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも亜富汗斯坦は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で亜富汗斯坦は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に亜富汗斯坦について学びました。",
              "source": "幻辞"
            },
            {
              "text": "亜富汗斯坦の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する亜富汗斯坦の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では亜富汗斯坦の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "スラビナがわめいている、三人の外国人の腕の中で、アフガニスタンの山脈のような胴体をつねられて悲しみは赤く腫れあがってしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダの声音は印度の夜の国境、ヒンズークシ山脈の下をアフガニスタンに向って疾走する急行列車にもまして叡智がひらめくのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々十二人は皆、東京の政治結社、東亜会から学費を貰って学校を卒業させて貰った者ばかりですが、その中で五人は皆、政府嘱託の軍事探偵になって、主としてアフガニスタン、ベルジスタン、ペルシア、アラビア方面からスエズ、東アフリカ方面の状態を探っていたものです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大将「これはなアフガニスタンでマラソン競争をやってとったのじゃ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の旧友であるヘイタ大佐は、アフガニスタンで私の治療を受けた男なのだが、当時はサリィ州のライギット近くに館をあがなっており、訪ねてこないかとよく誘いを送ってくれた。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらもアフガニスタンで一生分体験してきたからもう結構だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アフガニスタン帰り、ですね。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何がどういうわけで、あの男は私がアフガニスタン帰りと知っていたんだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は驚いていたね、初対面の時、アフガニスタン帰り、などと僕が言ったものだから。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかったのだ、君がアフガニスタン帰りだと。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフガニスタンをおいて他になし。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアフガニスタン帰りだと僕が開口すれば、君は驚いたという次第。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "バートン言う、この説｜理あり、驢は寒地で衰う、ただしアフガニスタンやバーバリーのごとく、夏長く乾き暑くさえあれば、冬いかに寒い地でも衰えずと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシャも印度もアフガニスタンも馬来も、中国を毒殺するために使用されているのと同様です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＶＩＡ・さいべりあ　アフガニスタンという国――とにかく国だろうと思うんだが――の王様が、何かの用で――たぶん鬚でも剃りに――莫斯科からワルソウのほうへ出かけているために、その宮内大臣、侍従、料理部員等の一大混成旅行団の乗用として、いい車はみんな欧露方面へとられてしまった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもへんな話だが、アフガニスタンにしろズズアイランドにしろ、仮にも王さまの御用とあらば致し方ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえアフガニスタン王のために四人乗りの車室しか取れなかったので、途中の駅から入り代り立ちかわり色んな人物が割り込んでくる。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによるとアフガニスタンの王様がまた来たのかと思ったのかも知れない。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルシャやアフガニスタンはすぐ隣りだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二〇年から二二年にかけてレイスネルはアフガニスタンへ外交官として暮した。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイスネルの、豊富な革命的活動の経験、見聞は、「アフガニスタン」「バリケードのハンブルグ」「ヒンデンブルグの国で」となって続々あらわれた。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフガニスタンからアマヌラハンが逃げる前　月六百留で医師を招｜聘して来た。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年一月　アフガニスタンのアマヌラハン、前年の春、イギリス、フランス、ロシアなどを廻って人気者であった。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〃　バルク――現在は北アフガニスタンの小都であるが、古代にはバクトリアの都として、また中世にはブハラやネイシャプールと並ぶ東ペルシアの中心地の一つとして文化の栄えた所。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の寝衣の背中に刺繍されたアフガニスタンの金の猛鳥は、彼を鋭い爪で押しつけていた。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ年に今のアフガニスタン地方に當る迦畢試（Kapisa）國の政府からも、天文に關する文獻を唐の朝廷に送呈して居る。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の屋根、パミール高原中の大魔境「大地軸孔」をさぐるため、近日ロンドンを出発、英印連絡空路により、アフガニスタンのグワダールへ赴く予定。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその間へ自然の障壁のように「大地軸孔」をふくむアフガニスタン領が伸びている。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのおの、二万フィート級以上が立ちならぶ大連嶺が落ち合うところが、いわゆる「パミールの管」のアフガニスタン領である。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
