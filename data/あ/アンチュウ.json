        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗中について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗中という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗中の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗中が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗中を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗中について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗中の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗中の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗中が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗中という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗中という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗中についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗中を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗中は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗中について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗中が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗中は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗中の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗中は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗中は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "扨その原因を、暗中模索の揚句、社会問題に持つて行つて、其処で解決を得られると思ふ人も相当あるけれども、私にはさうは思はれぬ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、右のことが分つたので歓喜にむせぶ気持でゐるが、又一方、長年求めあぐんで、暗中模索してゐたものが、一時に分つたので、慄へてもゐるといつた状態である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今日私は過去五年間の暗中模索、傷ましき躁宴の後に、聊か芸術の泉なるものが依て以て存する所以に想ひ到つた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も墨を敷いたやうなプラツトホームは、ざあ／＼と、さながら水が流れるやうで、がく／＼こう／＼と鳴く蛙の声が、町も、山も、田も一斉に波打つ如く、夜ふけの暗中に鳴拡がる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、大噐氏は全く不知案内の暗中の孤立者になったから、黙然として石の地蔵のように身じろぎもしないで、雨に打たれながらポカンと立っていて、次の脈搏、次の脈搏を数えるが如き心持になりつつ、次の脈が搏つ時に展開し来る事情をば全くアテもなく待つのであった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗中では色の見えぬ事、照らす光によって色のちがって見える事が引証されている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠りの幕がいつの間にか考えている頭の中を周囲から絞り狭めて行って、考えは暗中ただ一点の吸殻の火のように覚束なくなる。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と婀娜な声、暗中に留南奇がはっと立つ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「静に………」といって、暗中の客は寝転んだ様子である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　燃え尽して赤い棒になった早附木を棄てて、お兼を草花の中に残して、滝太郎は暗中に放れて去る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗中降雨を冒して進むこと数里、いよいよ人家の近付いたと思わるころ、風に煽られて暗中に漂う湯の香プンと鼻を打った時には、足の痛みなぞはすっかり忘れて跳べ跳べ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一四）暗中｜水汲隊　いよいよ山巓に近く水が無いものとすれば、胸突き八丁を降って金性水まで汲みに行かねばならぬ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話途切れて宿の亭主は、一服吸わんと暗中を、手探りに、煙管を捜して、「おや、変だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっと暗中に消え、やがて泰助の面前に白き女の顔｜顕れ、拭いたらむ様にまた消えて、障子にさばく乱髪のさらさらという音あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と高く翳せる右手の拳を、暗中よりしっかと扼して、抑留めたる健腕あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、広間の暗中に吸込まれて、誰も居ない。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山家は灯の遲い縁柱の暗中に、刺しに刺して、悶えて揮ふ腕からは、血が垂れた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今は疑うべき心も失せて、御坊様、と呼びつつ、紫玉が暗中を透して、声する方に、縋るように寄ると思うと、「燈を消せ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "那の手紙を見て、何様顏をしてゐるか………おツと、其様なことは何うでも可いとして、これから小時｜暗中の飛躍と出掛けるんだ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "運の面は何様なつらをして現われて来るものか、と思えば、流石に真暗の中に居りながらも、暗中一ぱいに我が眼が見張られて、自然と我が手が我が左の腰に行った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、大器氏は全く不知案内の暗中の孤立者になつたから、黙然として石の地蔵のやうに身じろぎもしないで、雨に打たれながらポカンと立つて居て、次の脈搏、次の脈搏を数へるが如き心持になりつゝ、次の脈が搏つ時に展開し来る事情をば全くアテも無く待つのであつた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苫を上げて、ぼやりと光って、こんの兄哥の形がな、暗中へ出さしった。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女、その暗中に消ゆ一舞台の上段のみ、やや明く残る。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さすが守銭奴の私も、この暗中の、ただならぬ険悪の気配には、へたばった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　社の裏を連立って、眉目俊秀な青年二人、姿も対に、暗中から出たのであった。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに件の幽霊は行燈の火を吹消して、暗中を走る跫音、遠く、遠く、遠くなりつつ、長き廊下の尽頭に至りて、そのままハタと留むべきなり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はしかく活きながら暗中に葬り去られつ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は手に握つて、双の眼で明かに見る采の目を、多勢が暗中に摸索して、丁か、半か、生か、死か、と喧々騒ぎ立てるほど可笑な事は無い。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、政党がさかんだった頃、自身は閣僚になる意志はてんで無く、ただ、誰かこいつと見込んだ男を大臣にするために、しきりに権謀術策をもちい、暗中飛躍をした男がいたが、良い例ではないけれども、まず、おれの気持もそんなとこだったろうか。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゃア、こ、これは、あんちゅう事だ」　寺本医師が電報を覗き込むと、ナニノマチガイカ　オバマシンゾウハイキテイル　ヨクシラベコウ「うむ」寺本医師は唸った。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
