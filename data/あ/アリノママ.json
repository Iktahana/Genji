        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有りのままについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りのままという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りのままの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りのままが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りのままを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りのままについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りのままの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りのままの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りのままが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りのままという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りのままという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りのままについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りのままを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りのままは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りのままについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りのままが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りのままは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りのままの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りのままは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りのままは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはとにかく、以上のような経歴をもつ一私人が「文学」と「科学」とを対立させてながめる時に浮かんでくるいろいろな感想をここに有りのままに記録して本講座の読者にささげるということは、全く無意味のわざでもあるまいと考えたので、編集者の勧誘に甘えてここにつたない筆を執ることにした次第である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して科学者が科学者に固有な目で物象を見、そうして科学者に固有な考え方で物を考えたその考えの筋道を有りのままに記述した随筆のようなものには、往々科学者にも素人にもおもしろくまた有益なものが少なくない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "止水明鏡のごとくにあらゆるものの姿をその有りのままに写すことができなければならない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長短高下をとかく申さで、おのずから其詩品を有りのままに申したる、まことに唐の司空図が詩品にも優りて、いみじくも美わしく御答え申したと、親王も御感あり、当時の人々も嘆賞したのであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自分は、そのことを有りのままに感じ、有りのまゝに表現する自由を持たない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは畜生同志が初めて出会った時の心理状態を有りのままに見せた表現でありますが、遺憾ながら万物の霊長たる人間にも、この性質を発見する事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えい一そのこと、何もかも有りのままにさらけ出してしまいましょう」「そうだ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんこれは、すべて有りのままで、神明に誓って偽りはありません。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこまでは並木の下を、例に因って、畷の松が高く、蔭が出来て涼いから、洋傘を畳んで支いて、立場の方を振返ると、農家は、さすがに有りのままで、遠い青田に、俯向いた菅笠もちらほらあるが、藁葺の色とともに、笠も日向に乾びている。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近松の時代と違って、事実を有りのままに仕組むということは遠慮しなければならないような習わしになっていたので、大工の六三郎は武士に作り替えられて、大和の浪人小柴六三郎という名を番附にしるされた。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筋に上げられた子女、又は記者と語った不良少年で、この心持ちを有りのままに白状したものが珍らしくない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は何もかくさないで有りのままに言ってほしいんですよ。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも有りそうな事件と云うより有った事件を有りのままに纏めた――こう云い度いような作品です。",
              "citation": {
                "source": "二つの作品",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時光寺からは有りのままに届け出て、寺社奉行はその詮索に取りかかったのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、百万遍の迷い言何の益なけれど聞いてつかわすべしとの仰せを幸、おのが心事を偽らず飾らず唯有りのままに申し上ぐべく候。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙を書いた婦人は、何も名文を書こうなんていう野心からでなく、只もう感情を有りのままにさらけ出したものですがね、実にすばらしい傑作です。",
              "citation": {
                "source": "ふみたば",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　レヴコーはこの思ひもかけぬ局面の転換に茫然としてゐたが、それでもさそくの気転で、どうしてその手紙が手に入つたかといふ有りのままの事実を隠して、別の答へを用意するだけの分別はあつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は立ち所に有りのままを答えた。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有りのままを静かに見るべきである。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、あったことを有りのままに、通達なされませぬ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の人工も加えられず、有りのまま、なり行きのままにまかせられて居るので、池は、何時とはなし泥が増して今は、随分遠浅になって居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の事を思う毎に若し私が十年立つ今まで、彼と一緒に、少なくとも折々は会いもし口も利く生活をして来たら、かなり有りのままに自分自身を表わして居る私の今の生活がどの様に変化させられただろうと云う事を興味深く考える。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の他種々の話を、彼は我々が日常の出来事に対して云う通りな静かな事実を有りのまま物語って居る様な口調で話した。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の生活を有りのままに書くやうな芸のない真似はしない。",
              "citation": {
                "source": "ドストエフスキーとバルザック",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば耳朶の如きも大抵仏像に見るように長大に造られ、着衣の衣文も仏像の衣文に近く、決して有りのままの肖像的理念によって出来たものではない。",
              "citation": {
                "source": "本邦肖像彫刻技法の推移",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千代はかねがね私に向つて言ふのであつたが、私の本心が彼女を厭ふやうになつたら憐憫の念をすて生殺しの殺生をせずに一思ひに有りのままを打ち開けてくれと。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ獅子文六さんと会ったら、ゴルフをしなさい安吾さんや、とすすめるから、実は拙者もそのつもりで、十万円だか十五万円だかの金策に頭をなやましている旨を有りのまま伝えた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、母上のあのお手紙をいただいたその明くる日――つまり昨日、まるで申し合はせでもしたやうに千恵がこの目であのやうなことを見てしまつた今となつては、もう何もかも有りのままに申しあげて、あとは宏大な摂理の御手に一切をおゆだねするほかないことを感じます。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "控訴する位ならはじめから、私は事実を有りのままに云うたに違いない。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は恩を知ればこそ人間、受けた恩を仇で返すはさてもさても畜生同然、さあ有りのまま、逐一かくさず、この清盛に聞かせられたい」　言葉は丁寧だが、怒気は言外に溢れ、成親は恐しさに身も縮むばかりであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
