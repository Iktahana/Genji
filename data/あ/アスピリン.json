          ],
          "literary": [
            {
              "text": "アスピリンをどっさり呑めば、けろっとなおるのだが。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここにアスピリンと書いてあってよ――」　こころみに噛んで味ってみる迄もなく、なる程アスピリンに違いなかった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスピリンをどつさり呑めば、けろつとなおるのだが。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉野さんから、アスピリンをもらってのむ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬は、アスピリンという、よく熱をとる薬だそうである。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵太郎君はかぜをひいたのがもとだから、このアスピリンで熱をとれば、すぐなおってしまうと、音次郎君は、医者のように自信をもっていった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妻が歯痛をわずらい、見かねて嘉七が、アスピリンを与えたところ、ききすぎて、てもなくとろとろ眠りこんでしまって、ふだんから老妻を可愛がっている主人は、心配そうにうろうろして、かず枝は大笑いであった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バイエルアスピリンというんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのアスピリンはどうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその中にまじつて、こはれ掛つた椅子にもたれて、アスピリンで微熱を下げながら、自分の運命のやうに窮地に陥ちた王将が、命からがら逃げ出すのを、しよんぼり悲しんでゐたのだつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「床をお取りよ、アスピリンをお飲み」　こう云ってから考えた。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じなのは、幕末頃に生きてゐた何とか三郎といふ男で、悪物｜食ひで評判を取つた程あつて、女房の叔母が亡くなると、火葬にして、その灰をアスピリンか何ぞのやうにすつかり嚥み下してしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜なかに目がさめ、頭じゅうが強直して、眠れず、アスピリンをのみ、睡る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛みの堪へられるうちはアスピリンを服用して我慢する。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかぽかと体が温まつて来ると痛みは大分鎮まり、時には睡眠することも出来るが、烈しくなつて来れば鼻血の出るほど服用してもアスピリンなど効きはしない。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアスピリンを服用し、蒲団の中から首だけを出して毎日を過すのであるが、昼間はそんなに苦しいとも思はない。",
              "citation": {
                "source": "烙印をおされて",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ時、アスピリン見たいな錠剤を一つ飲んで置けば、腹がふくれるといふやうな、さういふ食ひ物を誰か作つてくれないかなあと思ふ。",
              "citation": {
                "source": "衣食住雑感",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスピリンを飮み終日臥床呻吟。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスピリンを飮み、頭から蒲團をかぶつて、うつら／＼しかけると、思ひ出したやうにガタ／＼と來る雨戸の音に脅かされては、睡りを妨げられた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスピリンを飲み、大汗を絞って、ようよう四時過ぎごろに蒲団を出て、それから書けても書けなくても、自分は一時間余り机に向わなければならない。",
              "citation": {
                "source": "死児を産む",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人がまた天津まで私を乗せて行つてくれるのかと思ふと、済まぬやうな、危いやうな気がして、「僕、アスピリンを持つてますが、飲んでみますか？",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、熱はないですよ」　アスピリンは鎮痛剤であることを知らないのであらうか。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数日急に寒くなり、風邪をひいたらしく、ゆうべは熱が出、脈が多くなったので、アスピリン〇・五｜瓦をのんだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人のＳが案内をして呉れる筈である――勿論、前の晩には、アスピリンでも飲んで、ぐつすり眠らなければ。",
              "citation": {
                "source": "偶感一束",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日　昨夜、Ｙ歯がひどく痛み、アスピリンきいて居た間だけやっと眠り、あとはあけ方から泣き声を出した。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、風邪気だと云ってアスピリンをのんだら工合がわるい。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "与里は道でアスピリンを買つてきたのだ。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
