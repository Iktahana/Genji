        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝日新聞社の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先日の朝日新聞社の大展覧会でみた雅邦でもコケオドシとしか見えなかった。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の東京朝日新聞社の建物がなんだかさびしそうな顔をして立っているように思われるのであった。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶※昭和三年夏七月、大阪朝日新聞社の求むるところにより、その旅客輸送機ドルニエ・メルクールに乗じて北九州太刀洗より大阪へ飛翔せんとす。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日新聞記者として永眠して死後なお朝日新聞社の好意に浴しているが、「新聞記者はイヤだ、」といった事は決して一度や二度でなかった。",
              "citation": {
                "source": "二葉亭四迷",
                "author": "――遺稿を整理して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　朝日新聞社に入る　北京から帰朝したのは三十六年の七月で、帰ると間もなく脳貧血症に罹って田端に閑居静養した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七年の春、日露戦争が初まると間もなく三月の初め内藤湖南の紹介で大阪朝日新聞社に入社し、東京出張員として東露及び満州に関する調査と、露国新聞の最近情報の翻訳とを担任した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は東京朝日新聞社の若菜貞爾が住んでいたとかいうことで、格子作りの入口が三畳、それから右へ廻り縁で八畳の座敷がある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮崎氏はその当時、東京朝日新聞社に籍を置いて、小説家として知られている人であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後東京へ帰つてから、東京朝日新聞社に石川を尋ねて小奴の話を伝へると、石川はきまり悪さうに笑ひにまぎらして何とも答へなかつた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十六年の七月、日露戦争が始まると云うので私は日本に帰って、今の朝日新聞社に入社した。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛んで来たブルース夫人は日本及朝日新聞社へ着陸した。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、朝日新聞社からロシア視察旅行に赴き、あちらで発病して、明治四十二年五月帰途の船が印度洋を通っているとき病歿した。",
              "citation": {
                "source": "生活者としての成長",
                "author": "――二葉亭四迷の悲劇にもふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日新聞社が五月さらに優れた作品とロダンの彫刻数点までを加えた展覧会を行った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に大阪朝日新聞社に由って連合大会が催されて以来、関西の各地において婦人の新運動が続々と起りつつあるのを見受けます。",
              "citation": {
                "source": "新婦人協会の請願運動",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また右の大阪朝日新聞社の大会へ東京から出席された平塚らいちょう女史が、帰来直ちに新婦人協会の創立を発表し、主として全国婦人の連合運動を企図されるに到ったことなども、我国の婦人運動が茲に新紀元を画して、初めて実際に現代的意義を持つようになった表徴であろうと思います。",
              "citation": {
                "source": "新婦人協会の請願運動",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　殆どこれと同じ時刻に、有楽町の駅を出た一団の人群にまじって、一人の若い女が朝日新聞社の横から、トラックをよけながら数寄屋橋の方へ出て来た。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、朝日新聞社の人が、一人ずつ両方へ手伝いに来てくれた。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦潮斯徳に駐在して居る東京朝日新聞社の通信員｜八十島氏から贈られた果物の籠、リモナアデの壜、寿司の箱、こんな物が室の一｜隅に置いてあつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之にはクック社の桑港支社長ストークス君やら、朝日新聞社桑港特派員清瀬規矩雄君などが便乗して来たので、陸上の模様明日の見物の次第などを語り合つて、大方賑やかになつて来た。",
              "citation": {
                "source": "検疫と荷物検査",
                "author": "杉村楚人冠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後青々氏は他より一層発達して、殊に達作で、郭公一題二百句などという多作をして我々を驚かせたが余り長く東京には留らないで、帰阪して後大阪朝日新聞社に入って、今も同社の俳句欄を担任している。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより朝日新聞社員として、筆を執って読者に見えんとする余が入社の辞に次いで、余の文芸に関する所信の大要を述べて、余の立脚地と抱負とを明かにするは、社員たる余の天下公衆に対する義務だろうと信ずる。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に朝日新聞社で出版してくれることになつたが、日頃、本のやりとりをしてゐる友人にも、これだけはわざと送らなかつた。",
              "citation": {
                "source": "「由利旗江」を書いた頃の思出",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで朝日新聞社へ渡りの手順を解説してくれと葉書をだした。",
              "citation": {
                "source": "生命拾ひをした話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦潮斯徳に駐在して居る東京朝日新聞社の通信員｜八十島氏から贈られた果物の籠、リモナアデの壜、壽司の箱、こんな物が室の一隅に置いてあつた。",
              "citation": {
                "source": "巴里まで",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日新聞社の『国語文化講座』の企ては、さういふ私の考へをみたしてくれる事業のひとつであつて、われわれの「言葉」を愛し、これを厳しく育ててゆかうとする熱意ある同胞諸君の指針となるものであらうと思ふ。",
              "citation": {
                "source": "「国語文化講座」監修者の言葉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春、朝日新聞社で座談会があつたとき、司会者の岩上順一先生が、私にかう云つた。",
              "citation": {
                "source": "新カナヅカヒの問題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで差押へになつたとき、朝日新聞社が撮影に行つたら、傍への物品に貼つてあつた差押への紙を一枚貼がし、ペロリと出した舌の上へ貼付けて写真を撮つた。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日賞を受く　昭和十二年一月二十五日朝日新聞社から昭和十一年度の朝日賞〔朝日文化賞〕を贈られた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕時計に時間を見ながら、君江はガードの下を通りぬけて、数寄屋橋のたもとへ来かかると、朝日新聞社を始め、おちこちの高い屋根の上から広告の軽気球があがっているので、立留る気もなく立留って空を見上げた時、後から君江さんと呼びながら馳け寄る草履の音。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後この幹が他所へ移され、なんでも東京朝日新聞社の代理部の方へ回ったと聞いたようだが、その後その行き先きがどうなったか私には分らなくなった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
