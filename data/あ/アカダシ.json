        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "着色料の真っ赤な色ではなく、ちゃんと黒ずんだ赤だし、なにより、イチゴが原形をとどめているのが、その証拠だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の川肴料理では、赤だし（味噌汁）椀に、七尾入れることを通例としている。",
              "citation": {
                "source": "京都のごりの茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめこの赤だしが美味しかった。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤だしが出て、今更に、東京では見られない此の演出、大阪独特だな、と思う。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、すしと赤だしとは、果して、合うものだろうか。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十九日（水曜）　十一時迄寝る、此の位眠ったら眼もいくらかよくなりさうなものだが、右眼は、まっ赤だし、左も少し赤くなってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどのは変った料理ばかりで、赤飯に赤だし、そのあとおしることいふ式。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、タンシチュウ二の後、赤だしとオムライスと命じる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園風の豆腐と、こんにゃくの田楽、かやく飯（ぬくずしの冷えたやうなもの）に、赤だし附、淡りしてゝ衛生的だが、腹には応へず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲山の秋はすでに濃く、うるしの木は、真っ赤だし、黄いろい葉には、霜があった。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼は真っ赤だし、胸も袴も泥まみれだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ちかく、道は八幡のへんにかかっていたが、対岸の美豆や山崎あたりの空はまっ赤だし、川面には兵舟の往来がしげく、どうも予定していた鳥羽までは行けそうもない。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうね、夢がさめないッて限りもないんですものね、……はいお待ちどおさま、あかだしお二人さんあがり」",
              "citation": {
                "source": "七日七夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
