          ],
          "literary": [
            {
              "text": "懸命に画をかいて、高い価で売って、遊ぶ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術家は、芸術家同志遊ぶがよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、それでなくても厳しい父と細々し過ぎる母とが、殊に遊ぶこと以外には何にも考へようとはしない耕二に、執拗にも間がな隙がな小言を言ひつめるので、今もやつと許されて出掛けるらしい耕二に沢山の言葉は掛けないで出してやりたかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を思うて岡の辺に行きつ遊ぶ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はこの外にも、君あしたに去りぬ夕べの心｜千々に何ぞはるかなる君を思ふて岡の辺に行つ遊ぶ岡の辺なんぞかく悲しき　という句で始まる十数行の長詩を作ってる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いて宇宙の神韻と化し、縹渺の詩境に遊ぶこともまた楽しみである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ行くときも、酒を飲むときも、女と遊ぶときも、僕は常にただ一人である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の宿題も午前の中に片付けたれば午後半日は思うまま遊ぶべしと定まれば昼飯待遠し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀の遊ぶのを見たりとて面白くもなし湊川へ行て見んとて堤を上る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母や祖母は自分が亀さんと遊ぶことをあまり喜ばなかったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀さんの妹の丑尾さんとはあまり一緒に遊ぶことがなかったようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、遊ぶにはもつて來いのところなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あそこは遊ぶには、いいところだ、それだけは保證します。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚どもは誰に見せようといふ衒ひも無く自由に嬉々として舞ひ遊ぶ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたちまち、その天蓋から一群の魚がむらむらとわかれて、おのおの銀鱗を光らせて滿天に雪の降り亂れるやうに舞ひ遊ぶ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、あんないいところで遊ぶ資格は無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして公園でおとなしくお猿さんと遊ぼうね」「公園に行こうね、おしゃるしゃんとあそぼうね」　子供は、吉田の首に噛りついたまま、おしゃるしゃんと遊ぶことを夢に見ながら、再び眠った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、この辺は人里離れて、猪の遊ぶのに持って来いだ」　翁はそういって、傍の保与（寄生木）のついている山松を見上げた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性が相｜共に遊ぶ娯楽が日本にはあまりになさ過ぎる。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も民子の姿を見れば来い来いと云うて二人で遊ぶのが何より面白かった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭をいぢる時間も、子供と遊ぶ時間も、珈琲店を夜歩きする時間も、彼にとつては皆「頭腦の營養」のためであり、仕事への心がけた準備なのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまた純東洋風の文人として、花鳥風月の趣味に遊ぶ、悟りすました人物のやうにも印象させる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私の旅行というのは、人が時空と因果の外に飛翔し得る唯一の瞬間、即ちあの夢と現実との境界線を巧みに利用し、主観の構成する自由な世界に遊ぶのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼はプノンペンから自動車に搭乗して国境のゴム園に車をカンボジヤの原野、白鷺の飛ぶ直線道路を、水田に遊ぶ水牛のなかを疾走させた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４「知らない支那人と麻雀を遊ぶのはよつぽど注意しなければいけない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のらくら遊ぶのは勿体ないから働きたいのだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロ／＼と遊ぶんが好きで、見つけられては母におこられた。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国を紀州なりと童のいうがままに「紀州」と呼びなされて、はては佐伯町附属の品物のように取扱われつ、街に遊ぶ子はこの童とともに育ちぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり全く遊ぶよりほかに用のない人がステッキ、そうしてステッキだけをかかえていないと板につかないようである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
