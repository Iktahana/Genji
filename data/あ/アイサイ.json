[
  {
    "uuid": "97221de4-1708-5df7-86bb-166f311627d1",
    "entry": "愛妻",
    "reading": {
      "primary": "あいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beloved wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛妻は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛妻が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛妻に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛妻が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛妻について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛妻についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛妻について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛妻が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛妻が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛妻は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛妻は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛妻を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛妻をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛妻が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛妻の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛妻を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛妻に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛妻について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛妻は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛妻を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の語の最初の音が濁音になるのである（「妻問」「愛妻」「香妙」「羽裹」「草葉」など）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "磊落を装っているが、若い愛妻の詩的精神に使役されて、如何にこの噴水構造に苦心したかを暗に談話のうちにほのめかした。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真帖には肺病で死んだ、美しい夫人の小照が幾枚となく貼りこまれてあり、彼にとっては寸時も傍を離すことのできない愛妻の記念であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、だいたいは愛妻家の部類なのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは将門が安穏を得させようとして跡を埋め身を隠させた其の愛妻を敵が発見したことであつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我がリヒヤード・ワグネルも亦、愛妻ミンナと愛犬ルツスを率ゐ、飄然として祖国を去つて巴里に入るや、淋しき冷たき陋巷の客舎にありて具さに衣食の為めに労苦を嘗めぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は幾晩も眠らないで、愛妻を看護する傍、嬰児のために乳貰いに歩いた。",
              "citation": {
                "source": "前妻の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ程のスワンソン氏の物質的起伏も彼の愛妻である美貌のスワンソン夫人の消費生活にはさしたる波動を及ぼさない。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国紳士たる体面はその愛妻に対してさえ容易に崩壊することを許さない。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては書店の主人であったが、愛妻の病没により、哀傷の極は発願して、奮って無一物の真の清貧に富もうと努めた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝あの実母も、百姓などしねえげ、まだまだ死ぬのでなかったべ……」　彼は、若くして死んだ愛妻の死の前後を、その哀しむべき半生を心の中で思い描いた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがデイヴィドに言い及んだ件もある上、大佐の愛妻ぶりは周知のことだが、その話とも反することとなり、第三者が悲劇に立ち入ったことにも触れない。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん――この壁はがんじょうにこしらえてありますよ」そう言って、ただ気違いじみた空威張りから、手にした杖で、ちょうど愛妻の死骸が内側に立っている部分の煉瓦細工を、強くたたいた。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……死んだ愛妻と胎児の墓に、鯉幟を立てて行方を晦ました男……あとに餓死を待つ高齢の祖母……」　といったような記事が、その墓の鯉幟と、蚊帳の前に坐った老婆の写真と一緒に出たのは、あくる日の朝刊であった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八四七年の一月に愛妻ヴァージニアが亡くなりまして、これ以後ポウの不幸は急湍の如くに彼をおし流し、ポウ自身の言葉を借用しますと「或る不思議な切迫した宿命感」のために遂に自ら死を招くに至つたのであります。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は犯した罪のないことは自信しているが、前生の因縁か何かでこんなことにされているのだから、まして愛妻といっしょに配所へ行ったりすることは例のないことだから、常識では考えることもできないようなことをする政府にまた私を迫害する口実を与えるようなものですからね」　などと源氏は語っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣からの返書には若君のことがいろいろと書かれてあって、それによってまた平生以上に子と別れている親の情は動くのであるが、頼もしい祖父母たちがついていられるのであるから、気がかりに思う必要はないとすぐに考えられて、子の闇という言葉も、愛妻を思う煩悩の闇に比べて薄いものらしくこの人には見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きていたいと思っても、それは自己の意志だけでどうすることもできないことであったから、せめて愛妻のために魂だけをこの世に残して置きたい、自分の息子たちの心も絶対には信ぜられないのであるからと、言いもし、思いもして悲しんだがやはり死んでしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、いらいらしくなって来る心を、じっと抑え付けて、湯河原の湯宿に、自分を待っている若き愛妻の面影を、空に描いて見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　湯の宿の欄干に身を靠せて、自分を待ちあぐんでいる愛妻の面影が、汽車の車輪の廻転に連れて消えたりかつ浮かんだりした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎の、こうした愛妻を中心とした、いろ／＼な想像は、重く垂下がった夕方の雲を劈くような、鋭い汽笛の声で破られた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい愛妻の静子が、いかに待ちあぐんでいるにしても。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、もう四十分の後には、愛妻の許に行けるかと思うと、汽車中で感じた焦燥しさや、いらだたしさは、後なく晴れてしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、口の中で呼んで、愛妻に対する意識を、ハッキリさせようとすると、その声が何時の間にか「瑠璃子！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、愛妻に逢う前に、何うかして、乱れている自分の心持を、整えようとした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はボックスの中に瑠璃子と並んで、席を占めながら眼は舞台の方から、しば／＼帰って来て、愛妻の白い美しい襟足から、そのほっそりとした撫肩を伝うて、膝の上に、慎しやかに置かれた手や、その手を載せているふくよかな、両膝を、貪るように見詰めていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、はしなくも、自分の愛妻の静子のことを考えずにはいられなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
