        "examples": {
          "standard": [
            {
              "text": "私は毎日アルティメットについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルティメットの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルティメットが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルティメットについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルティメットの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルティメットが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルティメットという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルティメットについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルティメットは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルティメットが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルティメットは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルティメットの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルティメットは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルティメットは興味深い例である。",
              "source": "幻辞"
            }
          ],
