    },
    "definitions": [
      {
        "index": 1,
        "gloss": "address",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アドレスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドレスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドレスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドレスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドレスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドレスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドレスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドレスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドレスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドレスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドレスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドレスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドレスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドレスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドレスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドレスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドレスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドレスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドレスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドレスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "北原氏が靜岡に遊び、氏の寓居を訪はうとした時、町の何人も蒲原氏の名を知らず、この知名な大詩人の寓居について、一もアドレスを知ることができなかつたさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでアドレスや請求文を書いて、父はイギリスの織物会社からしきりにカタログを取り寄せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えば、君の去った後、僕が他の学生たちと菊屋に飲みに行き、その時、おかみさんに君の部隊のアドレスなんかを、聞かれもせぬのに、ただただお酒をさらに一本飲みたいばかりに、紙に書いて教えてやった覚えがある。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし行けましたら……」　辞退のつもりで陽子は言ったのだ、が彼女らには、承諾の意味に聴えたらしく、ここへアドレスを書けと、手帳を出された。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、アパートの所を書いて渡すと、「こんどの日曜日、夕方の五時に、このアドレスの所へ、自動車で迎えに行きます。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まさしく裏に元園町のアドレスを刷り込んだ前川氏の手紙だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四時間接続にいたる顛末をレポートにまとめ、アドレス変更届に添えて知人に送っていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅメールアドレスなど持たない人のことをデジタルホームレスなどと呼ぶらしいが、インターネットの上にだってホームレスの予備群は立派に育っている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "名簿には全生徒のアドレスがのっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アドレスが書いてなかつたので、そのまゝになつてしまひ、二三年経つて輝子は養子を迎へてゐた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――また小鐘からは頻繁に手紙が来るようになつたが、封書の裏には州と区と通りとホテル気付といふ記号だけが印刷されてあつて、時に応じてのアドレスを書き容れてあつた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「Ｇさんの家は大森にもあるのかしら――」　彼のアドレスは横浜山手である筈だ。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ氏からの手紙は、相変らず横浜のアドレスで来てゐる。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――次のアドレス一目瞭然たるように知らせてほしい。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスコウのアドレスも貰ったが、とうとう訪問する機会がなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お婆さんは、広告に出ていた「日本青年紳士」のアドレスへ私の推薦状を同封した一書を即日正確に飛ばしたものに相違ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "今なら Villa Bijou, Monte Carlo というアドレスだけでファンの郵便が届くだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄原より）　　　初めての説教　あなたのアドレスを忘れたので手紙を出すことができませんでした。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人は、汽車の時間と、先方の別莊のアドレスとを教へてくれて、若し今から私がすぐその方へ行くならば、電報を打つし、二三日して行くならば手紙を出すといつた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六進のキーボードに加え、ＴＫ―80は日の字型のＬＥＤを八個持っており、そのうちの四つでアドレスを、残りの四つでデータを表示する形をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "８０８０の六四Ｋバイトに対して、８０８８では一Ｍバイトのアドレスが可能となっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターはメモリーをバイト単位に区切ってアドレスと呼ばれる番地を割り当て、情報の書き込みや読み出しをこのアドレスを頼りに行っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に八ビットのマイクロコンピューターは、アドレスを指定するための信号線を一六本持っており、一度の動作で最大一六ビットのアドレスを指示することができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ビットに対応した８２３７Ａも、当然これに対応して一度に一六ビットのアドレスを指定できるように作られていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＰＣに使われた８０８８やＰＣ―９８０１の８０８６は、二〇ビットのアドレス指定ができるように機能が拡張されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご感想、ご指摘を、大家さん提供の左記のアドレスでお待ちしています。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
