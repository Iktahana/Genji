        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒事について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒事という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒事の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒事が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒事を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒事について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒事の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒事の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒事が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒事という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒事という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒事についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒事を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒事は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒事について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒事が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒事は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒事の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒事は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒事は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "茶碗酒の荒事なんて、あなた、私を殺してからお飲み。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このチャンポンというのもまた、いまこそ、これは普通のようになっていて、誰もこれを無鉄砲なものとも何とも思っていない様子であるが、私の学生時代には、これはまた大へんな荒事であって、よほどの豪傑でない限り、これを敢行する勇気が無かった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「点ならござれ即点に、素襖の柿のへたながら、大刀の切字や手爾遠波を、正して点をかけ烏帽子、悪く謗らば片つはし、棒を背負つた挙句の果、此世の名残執筆の荒事、筆のそつ首引つこ抜き、硯の海へはふり込むと、ほゝ敬つて白す。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、団十郎が一流編み出したと云う荒事を見て、何と云う粗野な興ざめた芸だろうと思って、彼の腹心の弟子の山下京右衛門が、「太夫様、団十郎の芸をいかが思召さる、江戸自慢の荒事とやらをどう思召さる」と訊いた時、彼は慎ましやかな苦笑を洩しながら「実事の奥義の解せぬ人達のする事じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、団十郎の幼稚な児騙しにも似た荒事とは違うて、人間の真実な動作をさながらに、模している七三郎の芸を十分に尊敬もすれば、恐れもした。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「喧嘩口論、悪人成敗、命ノヤリトリ、白刄クグリ、ヨロズ退屈凌ギトナルベキ荒事ナラバ何ナリトモ御相談ニ応ズベク候間、遠慮ノウ当館ヘ申出デ可然候。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のだんまり、虫の濡場、虫の荒事、虫の所作事、虫の敵討のおもしろさ。",
              "citation": {
                "source": "草の親しみ",
                "author": "刈草の匂ひ　１",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居にしても、荒唐無稽な荒事から自然主義的な人情劇にかわり、明治大正には新劇という少しの芝居もしない自然そのままの芝居になってしまった。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が荒事に慣れない、無類の臆病者の吉之介は兇行後、現場の恐ろしさに慄え上がって一旦は逃げ出して附近の安宿に泊った。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浄瑠璃を語り初めた和泉太夫というのは、高座へ上るには二尺余りの鉄扇を持って出て、毎晩舞台を叩きこわしたそうだが、そんな殺伐なことがまだ戦国時代の血腥い風の脱け切らぬ江戸ッ子の嗜好に投じて、遂には市川流の荒事という独特な芸術をすら生んだのだ。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒事といえば二代目の団十郎にこんな逸話がある。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは或る時座敷に招ばれて、その席上で荒事を所望されたので、立上って座敷の柱をゆさゆさと揺ぶり、「これが荒事でございます」といったら、一同｜喝采して悦んだという事が或る本に書いてあった。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人が先づ運輸通商の便を計つて新領土の民心を収めようとする遣口は兎角武断の荒事に偏する日本の新領土経営と比べて大変な相違である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方は傾城買ひ、江戸は荒事と言ふ風に分野のほゞ定まつたのが、元禄歌舞妓の姿であつた。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その荒事も実は若衆歌舞妓の半面である所の若衆丹前とも称すべきものゝ散文化し平面的になつたものだと思ふ。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も荒事の要素は、丹前以前からあつて狼藉ぶりの中に出て居る。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ先に開いたは「鏡山」で、敵役岩藤の憎態で、尾上の寂しい美しさや、甲斐甲斐しいお初の振る舞いに、あるいは怒りあるいは泣きあるいは両手に汗を握り、二番目も済んで中幕となり、市川流荒事の根元「暫」の幕のあいた頃には、見物の眼はボッと霞み、身も心も上気して、溜息をさえ吐く者があった。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室町御所になつて出来た同朋が、荒事を捨てゝも、多く、社奴・寺奴の方面から出て居たのは、一つの註釈になる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は、荒事趣味である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "即かぶき男の動作を取り込んで、荒事ぶりを編み出し、念仏踊り及び旧来の神事舞・小唄舞を男舞にしたてゝ、をどり出した。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "三江戸の荒事は、金平浄瑠璃と同じ原因から出たらうが、お互に模倣したものとは言へない。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其次は荒事、之は先刻の殺場、責場と違ひまして、之は唯非常に力が強いとか、非常に勇気があると云ふ人物を舞台の上に出して、無論殺伐ではありますけれども、非常に豪放な印象を見物に与へます。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは名高い荒事師だ。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしどもは皆｜船頭に立って戦争を見ていたが、その荒事師は決して蜻蛉返りをしなかった。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜は見物が少いから、荒事師は怠けているのだ。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "血統から、荒事師の祖先から来ている。",
              "citation": {
                "source": "九代目団十郎の首",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒事などゝ言ふものが演じられたのも、決して偶然の発生ではなかつたに相違ない。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
