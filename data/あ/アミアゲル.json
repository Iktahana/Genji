    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to finish knitting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日編み上げるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編み上げるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編み上げるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編み上げるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編み上げるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編み上げるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編み上げるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編み上げるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編み上げるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編み上げるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編み上げるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編み上げるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編み上げるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編み上げるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さて、此処で一言述べて置きたいのは、これまでも、頻繁に問われたことだったが、この長篇を編み上げるに就いて、そもそも着想を何から得たか――と云うことである。",
              "citation": {
                "source": "「黒死館殺人事件」著者之序",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こう考えると、彼の空中に編み上げる勝手な浪漫が急に温味を失って、醜くい想像からでき上った雲の峰同様に、意味もなく崩れてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
