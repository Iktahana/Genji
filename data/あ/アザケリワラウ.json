    "definitions": [
      {
        "index": 1,
        "gloss": "to laugh at someone scornfully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
