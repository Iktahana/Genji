      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "all (that one has)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有りっ丈について考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りっ丈の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りっ丈が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りっ丈について学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りっ丈の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りっ丈が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りっ丈という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りっ丈についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りっ丈は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りっ丈が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りっ丈は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りっ丈の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りっ丈は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りっ丈は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "）労働者農民及び多くの、所謂敵国に向って銃剣を取っていた××を××し、その銃剣のきっさきを、×××、××××××に向けさせる――そういうことを文学の持つありったけの宣伝、××をつくしてその影響を確保拡大することが必要である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間は一面の日あたりで、盤台、桶、布巾など、ありったけのもの皆濡れたのに、薄く陽炎のようなのが立籠めて、豆腐がどんよりとして沈んだ、新木の大桶の水の色は、薄ら蒼く、柳の影が映って居る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中からありったけの一円五十銭だけ、大小の銀貨を取りまぜて掴みだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子はありったけの身のまわりをあわれな人におやりなすったのみか、今はまた何よりもたいせつな目までつぶそうとなさるのですもの。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに、お邸へ連れてお帰りになりますからは、若殿様と御両人を快く添わしてあげて、これまでのような非道なことは忘れてもなさらぬように、それとも不縁に遊ばすなら、光子様に自由を与えて、決して干渉をなさらぬように、お憎みのありったけ、今晩いじめ切っておしまいなさい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはありったけの勇気を奮い起こして、出来るだけ落ち着こうと力めました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……』　Ｙ君は、娘が出て行ってしまうと、さて寝台の上に引っくり返って、ありったけ大声で笑ってみた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンギン鳥の恰好をした手提げのお腹には、勿論ありったけのお紙幣と銀貨とを押しこみました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金が本当に何も無くなった時には、自分のありったけの力を、ためす事が出来て、とても張り合いがありました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからあたしたちは、お金のありったけを気前よくぱっぱっと使って見せなければならなくなるのよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、ふたりの着換えの着物ありったけ、嘉七のどてらと、かず枝の袷いちまい、帯二本、それだけしか残ってなかった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと、ことしの勘定は、」と言って、書附けを差出し、寝ているのを引起して、詰め寄って何やら小声で談判ひとしきりの後、財布の小粒銀ありったけ、それに玉虫色のお羽織、白柄の脇差、着物までも脱がせて、若衆二人それぞれ風呂敷に包んで、「あとのお勘定は正月五日までに。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで又二つ三つやると、又ぺろりと喫ってしまって、直ぐ又手を出すので、子供だちはありったけの虎杖をやったが、老人は幾何喫っても喫いたりないと云うように喫って、「わしは、虎杖が好きで好きでたまらない、どっさりある処へ伴れてっておくれ」　と云った。",
              "citation": {
                "source": "虎杖採り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、これで、ありったけ」　すると、葛岡は、その掌の中のものを、じっと見詰めていましたが、他の手でわたくしの手を執り、一つ振り動かして、「ロマンチックだね」　と言って帽子を振り／＼階段を降りて行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはああいう眼を見ると、なんぼでも、おれの財産ありったけでも、出して、おれの自由にしたい――いう気になるンや。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ありったけの娘子軍は、すでにチャンチャカチャンチャカの鰌すくいに出払ってお留守なのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、弱者と見て傲り、群集を頼み、旅先を茶にして、彼ら観光団の俗悪者は不法を不法と思わず、無礼のありったけを尽したに相違ない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は顔色を失い、早速部屋の中にあった丸太棒を閂の代りに扉にあてがったり、ありったけの椅子や卓子を扉の内側に積み重ねて入口のつっかい棒にしたりして、自身は佩刀を抜いて身構えたまま生きた心地もなくぶるぶる顫えていたという。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どんなに其の時はうろたえて、椅子や卓子や、その他のありったけのがらくたを大掃除の時のように扉の前に積み上げたかを考えると、少年の私はどうしても笑わずにはいられなかった。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その俺が地下に、ありったけの智能を絞って自己の棲処――窖を営む。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井に吊るされた棚には椰子バスケットが沢山並び、室内に張られた紐には簡単着の類が乱雑に掛けられ（島民は衣類をしまわないで、ありったけだらしなく干物のように引掛けておく）竹の床の下に※どもの鳴声が聞える。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者が来ると、蝶子はしかし、ありったけの芸を出し切って一座を浚い、土地の芸者から「大阪の芸者衆にはかなわんわ」と言われて、わずかに心が慰まった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　昔、ラスキンが人から剽窃呼ばわりをされたのに答えて、独創ということも、結局はありったけの古いものからうまい汁を吸って自分の栄養にしてからの仕事だというような意味のことを言った。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、紀久子は自分の用箪笥の引出しの底からそこにありったけの紙幣を掴み出して、それを洋服のポケットに押し込みながら部屋を出ていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、月の世界へあそびにでかけたたましいが、そこへひょっこり帰って来て、東通に残したからだを、ありったけの心あたりを探してみて、みつけなかったら、かなりおもしろいことになるでしょう。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、ありったけの階段を上ったり下りたり、廊下や広間をのこらずかけぬけました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ヨハンネスはいいました、「これがもらったありったけの財産ですが、そっくりあなた方に上げましょう。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それこそありったけのまごころとなさけで、あなたひとりのことをおもってくれる。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでエリーザも、一日、一日と、日がたつにしたがって、ありったけの心をかたむけて、王さまをだいじにするようになりました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、お化……なら、お化で、またその人ならその人で、言いたいことが一切経、ありったけの本箱を引くり返したのと、知っただけの言を大絡にしたのが、一斉に胸へ込上げて、咽喉で支えて、ぎゅうとも言えず、口は開かずに、目は動く。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
