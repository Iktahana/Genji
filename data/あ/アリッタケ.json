[
  {
    "uuid": "7969dec2-cb1f-52e3-95e0-d85d9b69d5ed",
    "entry": "有りっ丈",
    "reading": {
      "primary": "ありったけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
