    "definitions": [
      {
        "index": 1,
        "gloss": "aleph (first letter of Hebrew alphabet)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アレフについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アレフという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアレフの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアレフが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アレフを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアレフについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アレフの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアレフの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアレフが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アレフという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアレフという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアレフについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アレフを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアレフは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アレフについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアレフが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアレフは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアレフの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アレフは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアレフは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その子とともに大ヘブライ学者）の「希伯来略語考」を見ると、それには、Athbash 法・Albam 法・Atbakh 法（Athbash 法―ヘブライＡＢＣの第一字アレフの代りに、その最後の字タウを当て、また第二位のベートの代りに、最終から二番目のシンを当て、以下それに準ずる記法。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Albam 法―ヘブライＡＢＣを二つに区分し、アレフの代りに後半の第一字ラメドを当てる方法。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
