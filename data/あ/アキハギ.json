    "definitions": [
      {
        "index": 1,
        "gloss": "bush clover (that blossoms in the autumn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大正十三年初秋萩原恭次郎",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀や、秋萩の葉末に置ける露のごと、空なれども、中に寫せる月影は圓なる望とも見られぬべく、今の憂身をつらしと喞てども、戀せぬ前の越方は何を樂みに暮らしけんと思へば、涙は此身の命なりけり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方の萩は秋萩でして、右片双には中年の婦人を用いました。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "このわたりの野に、鴨頭草のみおい出でて、目の及ぶかぎり碧きところあり、又秋萩の繁りたる処あり。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時『うつろはんことだに惜しき秋萩に』というのをお歌いになった宮様を若い人たちに見せたかったよ」　と言うではないか。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七九八）秋萩を散り過ぎぬべみ手折り持ち見れども不怜君にしあらねば　（巻十。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句の、「なりにけるかも」というのは、「秋萩の枝もとををに露霜おき寒くも時はなりにけるかも」（巻十・二一七〇）、「竹敷のうへかた山は紅の八入の色になりにけるかも」（巻十五・三七〇三）、「石ばしる垂水のうへのさ蕨の萌えいづる春になりにけるかも」（巻八・一四一八）等の如くに成功している。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌に比べると、「秋萩を散り過ぎぬべみ手折り持ち見れども不楽し君にしあらねば」（巻十・二二九〇）、「み冬つぎ春は来れど梅の花君にしあらねば折る人もなし」（巻十七・三九〇一）などは、調子が弱くなって、もはや弛んでいる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この巻（一五五〇）に、湯原王の、「秋萩の散りのまがひに呼び立てて鳴くなる鹿の声の遙けさ」も家持の歌に似ているが、家持の歌のまさっているのは、実際的のひびきがあるためである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの皇子の御歌は、「秋萩は咲きぬべからし吾が屋戸の浅茅が花の散りぬる見れば」（巻八・一五一四）というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウレシという語も、「何すとか君を厭はむ秋萩のその初花の歓しきものを」（同・二二七三）などの用法と殆ど同じである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長歌は、「秋萩を妻｜問ふ鹿こそ、一子に子｜持たりといへ、鹿児じもの吾が独子の、草枕旅にし行けば、竹珠を繁に貫き垂り、斎戸に木綿取り垂でて、斎ひつつ吾が思ふ吾子、真幸くありこそ」（巻九・一七九〇）というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅の花咲き散る苑にわれ行かむ」（同・一九〇〇）、「秋萩の咲き散る野べの夕露に」（同・二二五二）等の例がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○秋萩の枝もとををに露霜置き寒くも時はなりにけるかも　〔巻十・二一七〇〕　作者不詳　初冬の寒露のことをツユジモと云った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "類似の句には、「何すとか君を厭はむ秋萩のその初花のうれしきものを」（巻十・二二七三）がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の書では秋萩帖が手本に取り入れられている。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の書で、とりわけ心酔されたものに「秋萩帖」のあることは、一議に及ばぬところであろう。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "道風の「秋萩帖」に学んだ跡も見られるが、「秋萩帖」以上に美しい。",
              "citation": {
                "source": "良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕やみにほのかな庭のすみの秋萩に目をとめるものもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋萩の」の句は、萩の花はもう大分末になって花の色もさめかけた、うすら寒い風が人を吹くというのでありまして、萩の花の盛りのころは風は心ありげに萩を吹くように思えたのが、もうこのごろは萩には関係なくただ蕭条として人に吹く、というのであります。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後三年は、畑作りと「秋萩帖」の手習いなどに日を送らむことを病妻と誓い合えればなり。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきはぎとあきをつけるのも、聯想を避けたのであらう。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
