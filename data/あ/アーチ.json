    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アーチについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーチという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーチの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーチが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーチを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーチについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーチの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーチの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーチが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーチという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーチという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーチについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーチを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーチは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーチについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーチが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーチは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーチの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーチは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーチは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして店々の飾窓には、いつもの流行おくれの商品が、埃っぽく欠伸をして並んでいるし、珈琲店の軒には、田舎らしく造花のアーチが飾られている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてサイレンが鳴りやむと、夜の急行列車が都会のアーチの門をくぐるように動きだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアーチ形の風景のなかを弾丸のように川烏が飛び抜けた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんなこともこのアーチ形の牢門のさせるわざなのであった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人達の湯にはまた溪ぎわへ出る拱門型に刳った出口がその厚い壁の横側にあいていて、湯に漬って眺めていると、そのアーチ型の空間を眼の高さにたかまって白い瀬のたぎりが見え、溪ぎわから差し出ている楓の枝が見え、ときには弾丸のように擦過して行く川烏の姿が見えた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーチになった祭壇のすぐ下には、スナイダーを楽長とするオーケストラバンドが、半円陣を採り、その左には唱歌隊の席がありました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍、アーチストとアクターとを何の気なしに滑らして、色の黒い未醒画伯とうとう俳優となってしまった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が二本の榧の木のアーチになった下を潜ったら不思議な音はもう切れ切れじゃなくなった。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁を塗った側面と、背景に二つのアーチがあって、そこから以前の時代と同じ装飾が見えました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮浪者がアーチの下で眠っています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレンのポーチとか、ロザリのアーチとか。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葉の緻密な紫※のアーチを抜けた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとやがてそのアーチの処へ西洋諸国の人にとっては東洋の我々が思うのとは違った感情を持つところの十字架の形が、それも小さいのではない、大きな十字架の形が二つ、ありあり空中に見えました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとやがてそのアーチの処へ西洋諸国の人にとっては東洋の我の五輪の塔同様なものです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑の杉の葉のアーチには、鰊がいる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで海岸道路には蝦夷松の葉で飾られた歓迎門が濃青い簡素なアーチを作って、私たち観光団一行をウエルカムした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと二度目のお茶が出てから、「今の鯨の肉は、鯨の尾の附根に当る処で、肉の層がアーチ型になっている処です。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらワトソン君、俺たちがあの文書偽造犯人の、アーチェ・スタンフォードを捕えたのは、あの近所だったよ。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらワトソン、その付近で偽造犯のアーチィ・スタンフォドを一緒に捕まえた。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き当たりの前に、低いアーチ型の天井がついた廊下が分岐していて、実験室に至るのである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び込め、アーチィ、飛び込むんだ、絞り首だ！",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ花と青葉でこしらえた、アーチのようなものでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵夫人のいるところから幾段も上の方、水門のアーチの中に、盛装をしたメントーニその人の好色漢らしい姿が立っていた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一ツ曲って突当りに、檜造りの玄関が整然と真四角に控えたが、娘はそれへは向わないで、あゆみの花崗石を左へ放れた、おもてから折まわしの土塀の半に、アーチ形の木戸がある。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこのもみじは、実際、そこからが自慢なんですが、足も停めず、視めもせず、アーチ形に中の透く、燃え立つ炎のような中へ、消え失せた体に入ってしまった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりも豪いのはグラスゴウ附近カムプシーちゅう所の牧師アーチブルド・デンニストンで、一六五五年その職を免ぜられ、王政恢復（一六六〇年）の後復職した。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ基督教一統後も歐洲に人柱が行はれた二三の例を擧げれば、ヘンネベルグ舊城の壁額（レリーヴィング・アーチ）には重賞を受けた左官が自分の子を築き込んだ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前八時頃に十番の通りへ出てみると、末広座の前にはアーチを作っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の住んでいる家というのは高架線のアーチの下を、家らしい恰好にしただけの、すこぶる風変りな住宅だった。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
