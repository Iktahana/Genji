[
  {
    "uuid": "77cbc5e1-9367-520f-b8d0-52b7dbba9f22",
    "entry": "アーチ",
    "reading": {
      "primary": "アーチ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
