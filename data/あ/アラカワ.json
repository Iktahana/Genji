        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗皮について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗皮という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗皮の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗皮が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗皮を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗皮について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗皮の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗皮の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗皮が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗皮という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗皮という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗皮についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗皮を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗皮は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗皮について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗皮が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗皮は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗皮の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗皮は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗皮は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」小沼農場　赭いガサガサした粗皮の椴松、蝦夷松、たもの木などの丸太で組立てた樺太庁農事試験場の歓迎門は流石に簡素であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掘り出して鉈ではつり、唐臼でつき、水に浸けて粗皮を取去り、底に溜つたものを握つて食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掘り出して鉈ではつり、唐臼でつき、水に浸けて粗皮を取り去り、底に溜ったものを握って食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
