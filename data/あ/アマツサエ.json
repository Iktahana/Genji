        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日剰えについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "剰えという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は剰えの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には剰えが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "剰えを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは剰えについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "剰えの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は剰えの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では剰えが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "剰えという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に剰えという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では剰えについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "剰えを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると剰えは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "剰えについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では剰えが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に剰えは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により剰えの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "剰えは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に剰えは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "剰え髪は乱れて頬にかかり、頬の肉やや落ちて、身体の健かならぬと心に苦労多きとを示している。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "這奴横紙を破っても、縦に舟を漕ぐ事能わず、剰え櫓櫂もない。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰え陰々として、裳は暗く、腰より上の白き婦人が、長なる髪を振乱して彳める、その姿の凄じさに、予は寧ろ幽霊の与易さを感じてき。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰え貴い血まで見せた、その貴下、いきれを吹きそうな鳩尾のむき出た処に、ぽちぽちぽちと蚤のくった痕がある。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中儂の、最も感情を惹起せしは、新聞、集会、言論の条例を設け、天賦の三大自由権を剥奪し、剰え儂らの生来かつて聞かざる諸税を課せし事なり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "常ならば東海道の五十三｜駅詩にもなるべき景色ならんに、柿色の筒袖に腰縄さえ付きて、巡査に護送せらるる身は、われながら興さめて、駄句だに出でず、剰え大阪より附き添い来りし巡査は皆｜草津にて交代となりければ、切めてもの顔｜馴染もなくなりて、憂きが中に三重県津市の監獄に着く。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに昇は何の道理も無く何の理由も無く、あたかも人を辱める特権でも有ているように、文三を土芥の如くに蔑視して、犬猫の如くに待遇ッて、剰え叔母やお勢の居る前で嘲笑した、侮辱した。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰え、最初は自分の名では出版さえ出来ずに、坪内さんの名を借りて、漸と本屋を納得させるような有様であったから、是れ取りも直さず、利のために坪内さんをして心にもない不正な事を為せるんだ。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の後ろには、あちこちに山のように積みあげた穀堆が列をなして並んでいたが、それはもうかなり長いこと積んだままになっているらしく、その色が焼きの悪い古煉瓦のようで、天辺にはいろんな雑草が生え、剰え横からは灌木の繁みが凭っかかっている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分らの解放せられた喜びを忘れて婦人の解放を押え、剰え昔の五障三従や七去説の縄目よりも更に苛酷な百種の勿れ主義を以て取締ろうというのは笑うべき事である。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は周囲の事情が刻々に自分に不利に展開し、剰え立派な自白と云うものがあるので、最早云い逃れられぬ羽目に陥っていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、一方、現在｜瀰漫するところの大衆作家諸君の作品は、史上実在の人物、例えば近藤勇の名前を方便上借り来って、史実を曲げ、気儘な都合よき事件を創造し、剰え勝手なる幽霊主人公を自由自在に操り来り操り去る等、歴史小説としては許されざること甚だしきものが少くないのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の人は天台宗の達者である上に剰え諸宗に亙ってあまねく修学して智恵の深遠なること常の人に越えている。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰え、二日以来足の痛みは、今朝宿を出た時から常ではないので、この急峻な山道では一方ならぬ苦痛を覚えた。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は両者の間に何等本質的な区別を見ず、剰え、槓杆・鉋・螺旋・楔等の単純な機械力を機械と呼んでいるのである。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となってあれに先を越されて剰え、我々が支配として頭に頂かねばならぬとは情けない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にそう云う自責の心持、―――こんな貧弱な饗応をしたのでは相済まない、何がなもっと喜んで戴くことは、―――と云う心持があった矢先に、左大臣からあゝ云う風に云われ、剰え「物惜しみをするな」とまで云われたのがぐっと答えて、左大臣が所望とあらば、どんな物でも差出す料簡になったのであった。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因って吉長から諸大名へ遣わした證書の類を数多取り寄せて、使用してある印判を調べてみると、全く彼の云う通りに違いないので、嫌疑は直ちに晴れたのであったが、新八郎は虚偽の申立てをなし、剰え謀判の罪を犯したことが明白になり、身柄を吉長に下げ渡されて即時に首を刎ねられた。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで秩序を履んで請願をしてきた無類に従順な良民に、乱暴を加え、剰え兇徒嘯集というような悪名を着せるのは以ての外である。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "一曲終ると、「ああ」　虚無僧は、ここは野中の一軒家と、安心しきっているらしく独り言に――「四十｜不惑というが、おれは四十を七つも越えてからあんな失策をやって、禄を離れ家名をつぶし、剰え独りの子まで他国へ流浪させてしまった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中にも書いてある、まるで何だ、親か、兄弟にでも対するように、恐ろしく親切を尽してやってな、それで生命を助かって、おめおめと帰って来て、あまつさえこの感状を戴いた。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ、身のほどを弁えずして、百四、五十里、二百里近く離れたままで人を咒詛う。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かかりし後、へいげんはその簪の花を汚され、あまつさえ掌中の珠を奪われたるなり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ……その年は何処も陽気が悪かったので、私は腹を痛めていた。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あまつさえ、地震の都から、とぼんとして落ちて来たものの目には、まるで別なる乾坤である。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　――お稲です――　と云って、振向いた時の、舞台の顔は、あまつさえ、凝えたにせよ、向って姿見の真蒼なと云う行燈があろうではないか。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまつさえ、乱暴とも狼藉とも申しようのない、未練と、執着と、愚癡と、卑劣と、悪趣と、怨念と、なおその上にほとんど狂乱だと申しました。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親御様へお心遣い……あまつさえ外道のような老人へ御気扱、前お見上げ申したより、玉を削って、お顔にやつれが見えます。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あまつさえ、目の赤い親仁や、襤褸半纏の漢等、俗に――云う腸拾いが、出刃庖丁を斜に構えて、この腸を切売する。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ、水底に主が棲む……その逸するのを封ずるために、雲に結えて鉄の網を張り詰めたように、百千の細な影が、漣立って、ふらふらと数知れず、薄黒く池の中に浮いたのは、亀の池の名に負える、水に充満た亀なのであった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
