  {
    "uuid": "52329413-cc7d-5575-a169-dd42e0b81ba8",
    "entry": "あんま師",
    "reading": {
      "primary": "あんまし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "masseuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あんま師について考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんま師の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんま師が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんま師について学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんま師の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんま師が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんま師という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんま師という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんま師についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんま師を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんま師は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんま師について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんま師が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんま師は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんま師の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんま師は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんま師は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その他、しじみ屋、下駄の歯入れ、灰買い、あんま師、衣紋竹売り、説経祭文、物真似、たどん作り……そういった人たちが、この竜泉寺名物、とんがり長屋の住人なので。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
