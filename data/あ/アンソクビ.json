    "definitions": [
      {
        "index": 1,
        "gloss": "(Judeo-Christian) Sabbath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安息日について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安息日という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安息日の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安息日が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安息日を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安息日について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安息日の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安息日の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安息日が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安息日という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安息日という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安息日についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安息日を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安息日は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安息日について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安息日が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安息日は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安息日の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安息日は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安息日は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "信心深いイワンは安息日の礼拝に出席するのを怠るようなことはなかったとしても、その他の日は、一日爐ばたに寝そべって独将棋をしたり、遊園地へ行って観覧車に乗ったり、さもなければ二階の窓から遠方の嶺に雪の積っている山を眺めたりして、気儘に暮すばかりでありました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに人間の安息日があります。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一日は、僕たち二人の安息日だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日にして、安息日。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意深い人なら、毎安息日の朝の八時ごろから十時ごろまでの町の妙にひっそりした様子に気のつかぬはずはない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし市の近辺が週日にさえこんなに混んでいるとすれば、安息日にはどんなにそれがひどいことか！",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は安息日の兵隊のやうに烏頂天になつたのです。",
              "citation": {
                "source": "ランプの便り",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時安息日に、国教寺院の勤行終ると直ぐこの派の説教始まり、その都度欠かさずこの犬が来たからメソジスト犬と称えられた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百十二年の三月十八日、救世主のエルサレム入城を記念する棕櫚の安息日の朝の事。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安息日が過ぎて神聖月曜日が来たのだ。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は土曜のことで、あなたの猶太人は安息日を守りませうから何も早くお起きになることはありませんよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "安息日５・24東京日日（夕）　今日は日曜日だ、おまけに雨がふつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みだらな不行跡な振る舞は安息日を涜すものだといふので、二人の夫婦は二時間ばかり警察に拘留されたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "多忙しい身でないと一つ聞きに出掛けたい……安息日すら守ることも出来ないような始末ですからな……尤も自分の信仰だけはこれで出来てる積りなんですけれど……基督だけはちゃんと見失わない積りなんですけれど……」　教会の空気に興味を失った捨吉にも、こうした信徒の話は可懐しかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑然紛然とした空気の中で、伊勢崎屋へ来て就く奥のチャブ台の前で、十年一日のような信仰に生きて来た真勢さんがそれとなく捧げる食前の祈祷に、人知れず安息日を守っているということは、更に捨吉を驚かした。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が、小ざっぱりとした安息日の盛装で教会の広場に現われると、真先に見つけて近づいて来たのは仕立屋のカールであった。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これね、安息日の祈草と云うのよ。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の散歩の趣を久しく忘れていた僕には、常に変わらない町の色が、暑さと雑沓とに染めつけられない安息日のごとく穏やかに見えた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "安息日の日曜に商売の市の立つのも私には面白かつた。",
              "citation": {
                "source": "イーサル川",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の安息日に、お前がたはこの不思議をまのあたり見るであろう」　その夜、弟子たちはいろいろに考えた。",
              "citation": {
                "source": "魚と蠅の祝日",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の深みにすむ神の子等の安息日を見よ、かれらの上に祝福と平和あれ」コラムが叫んだ。",
              "citation": {
                "source": "魚と蠅の祝日",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩仕事があるの」「いや、今晩は安息日だ、その代り明日は早いんだ」　それで自分でもホッとして、とも子の口からまじめな話や愚かな話が際限もなかった。",
              "citation": {
                "source": "歩む",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、めっそうもない、安息日にでござる。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "その儀式のヤソ教に異なるは、第一に、『旧約全書』のみを用いて『新約全書』を用いざると、第二に、経文および唱歌みなヘブライ語を用うると、第三に、土曜日をもって安息日と定め、金曜日の晩と土曜日の朝とに礼拝式を行うと、第四に、堂内に入るものは帽子を脱することを禁ずると、第五に、男女その席を異にする等なり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "770昔は沈んだ安息日の静けさの中に、ゆくりなく天の愛の接吻が己にせられた。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだが、それは家系的な病気と見なすべきものか（わたしには鬚を剃りながら眠ってしまい、起きていて安息日を守るために日曜日には地下室でジャガイモの芽を摘んでいなければならなかった伯父がいた）、それともチャーマーの『英詩集』の大冊を飛ばさずに読もうとくわだてた結果だか、どうも見当がつかないのだ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がある安息日にカペナウムの会堂で、悪鬼につかれた一人の人をいやした時、人々は皆驚いて、「これ何事ぞ、権威ある新しき教なるかな。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、モーセの律法の中に安息日の制度があり、「安息日には何の業務をも為すべからず」と規定されている。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の調理も労働であるとして、安息日には炊事は禁ぜられた。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
