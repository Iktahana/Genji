    },
    "definitions": [
      {
        "index": 1,
        "gloss": "state",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有様について考えている。",
              "source": "幻辞"
            },
            {
              "text": "有様という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有様の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有様が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有様を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有様について学習した。",
              "source": "幻辞"
            },
            {
              "text": "有様の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有様の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有様が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有様という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有様という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有様についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有様を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有様は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有様について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有様が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有様は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有様の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有様は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有様は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、観念なぞ、無用の長物といつた有様である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の如く、交際ばかりがうまくて、仕事はその交際のお景品のやうにしてゐるインテリが、インテリの中で比較的景気のよい方に属するといふが如き、そんな有様では、もともと冠履転倒である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の観る限りにおいて、現今社会は恐ろしく修辞的であり、謂はば人々は如才なさ、抜目のなさを獲得しようとする時にばかり、全的に活気を呈するといつた有様である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふのが、これが都より田舎へ出すのであれば、何音楽会に行きました、何展覧会に行きました等々の、謂はば事件があるわけですが、こちらでは、何を豊富に感じてゐるとも、それが事件の形を採りませんので、書くことがまるでないやうな有様にもなるのだと、今更思ひ知る次第です。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、件の青年をＡとし、相手の青年をＢとするとして、二人の交游がどんな有様を呈するであらうか、以下そのことを誌してみたい。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿のない作品といふやうなものが充満してゐて、身動きも出来ない有様である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "話といふやうなものはてんでないで、話をしてゐても、その話が相手の気に触りはしないかといふことが念頭に浮ぶや、実に手の腹を返すが如く話頭を転ずるのだが、それでまた相手が妙にも思はぬといふ摩訶不思議な有様である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、それはおまへの今ゐるのが何の変哲もない峠道のことで、闇夜のことだし草一本満足には見えぬ有様だからだらうなぞ思ふ人もあるかも知れぬ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、あんな有様でしかもなお日本が勝ったら、日本は神の国ではなくて、魔の国でしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの海岸の城下まちにも、大砲の音が、おどろおどろ聞えて来て、まちの人たちも、生きたそらが無かったのでございましょうが、私は、そんなこととは知らず、ただもう妹のことで一ぱいで、半気違いの有様だったので、何か不吉な地獄の太鼓のような気がして、ながいこと草原で、顔もあげずに泣きつづけて居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな案配であるから、彼の天才を信じるも信じないも、彼の技倆を計るよすがさえない有様で、私が彼にひきつけられたわけは、他にあるのにちがいない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芸術史上の折々に於て、殆んど技巧ばかりが芸術の全部かの如き有様を呈した。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪賢い小商人がいちばん活々して生きてゐるといふ有様だ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）だから、短歌や俳句には、既に盛るに不適当な感性が現代にはあると多かれ少なかれ感じられてゐるにも拘らず、歌人俳人の方が詩人よりも遥かに身過ぎ世過ぎは楽だといふ有様である。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実我々が詩作の場合に、我々の周囲に一杯ある短歌や俳句の影響は余りにも浸入するといふやうな有様なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父が――父の養父――がお人好し過ぎて他人のために財産といふものを全部使ひ尽して、自分の住家といふものは古い家を買つて建てたやうな有様であつたことを能く父は祖父の生前言つてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の有様では、今後五十年後の我が文学は予想するだに忌はしいものとなるのではあるまいか。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩では食へぬといふ言葉は、東西古今にある言葉であるが、日本の今日のやうに、煙草銭も出ぬといふ有様は東西古今にはないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句を読むと、田舎の閑寂な空気や、夏の真昼の静寂さや、ひっそりとした田舎家の室内や、その部屋の窓から見晴しになってるところの、広茫たる一面の麦畑や、またその麦畑が、上風に吹かれて浪のように動いている有様やが、詩の縹渺するイメージの影で浮き出して来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と下女とで静かに暮していた処へ急に二人も増したのみならず、姪はいたずら盛りの年頃ではあり、家内は始終ゴタゴタするばかりでほとんど何事も手につかぬような有様であった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく一身を立てさせようと思えばこそ、祖先伝来の田地を減らしてまで学資を給してくれた父を、まあ失望させたような有様で、草深い田舎にこの年まで燻ぶらせているかと思うと、何となく悲しい心持になってしまうのだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杓子野郎は振返つてみるとこの有様なので、――ここぞとばかり彼は思つて、直ちに跳んで返した。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、私は釣りの帰りに、硝子のない硝子戸から、その家の有様を通りすがりに眺めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり大小の群星には二つの党派があってそれぞれの根拠地より出でて互いに入り乱れつつも目ざす処に馳せ行くがごとき有様である。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年大西洋航路などでは速力の増すとともに賃金も著しく上がったが、それにもかかわらず争うて快速力の船を選ぶ有様だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様は丁度静かな池の面に一つの石を投げ込んだ時、そこから起った波が次第に大きな輪となって拡がって行くようなものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子夫妻が父の祖神の翁に顔を合すとき、大体話は山の生産の模様、山民の生活の状況、それ等を統ねて行く岳神としての支配の有様、そのようなものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで細川方の領将も、山名方の領将も国元の様子が心配なので取る物も取りあえず京都から引返すという有様。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし全般に通じようとすれば勢い浅薄に流れ、もし蘊奥を極めんとすれば勢い全般の事は分らずにしまわなければならぬような有様である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
