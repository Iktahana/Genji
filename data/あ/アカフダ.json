          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこでは黒百合のような貴婦人が、オペラバッグから紙幣束を出して、百｜法の青札を買い、二十歳にもならないしとやかな娘が、赤札に自分の運命を賭けているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんは妾に数枚の赤札を買って下さいましたが、みるみるルーレット係の役人の手によって、玉の転げる音と共に消えてしまいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝ほど、今すこし前のまだ暗いうちに、御城内から大至急の赤札付きの御差紙が参りまして、年｜老っておりまする父、半左エ門へ即刻、出頭せいとの御沙汰で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、気の毒だ／＼と呟きながら、其家のあらゆるものに「差押へ」の赤札を貼つたのである。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人を呼び出さぬと、有無なく、この五つの酒倉に差押への赤札を貼るべき権利を持つてゐる者ですぞ。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤札の第一号のカワカミ氏は、ばかに鄭重に風呂場へみちびかれた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口に委員がいて、彼の赤札第一号に、口をあいてはあーと大きな息をはいてみてくれという。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……三月廿九日　からりと晴れてゐる、まだ腹工合はよくないが、いよいよ出立した、停滞する勿れ、行程三里、相ノ浦、川添屋（三〇・中）物乞ふとシクラメンのうつくしいこと恋塚といふ姓、夫婦株式会社といふ看板、町内規約に依り押売・物貰・寄附一切御断りといふ赤札。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車には満員の赤札が下がっていたが、停車｜場で二三人降りた人があったので、とにかく乗ることだけは乗られた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い方の山は、其日々々に処理して行くもので、その一番上に舌を出したように、赤札の張ってある一綴の書類がある。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は課長がまだ腰を掛けないうちに、赤札の附いた書類を持って行って、少し隔たった処に立って、課長のゆっくり書類を portefeuille から出して、硯箱の蓋を取って、墨を磨るのを見ている。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤札のは直ぐに取り扱う。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報は大抵赤札と同じようにするのである。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――箇展で赤札つけといてね」「こっちは光子さん」　自分の肖像　　　対照　大掃除　サイドボードを動かす　上の下らぬ大額をおろす。",
              "citation": {
                "source": "生活の様式",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャーッ」　女の人は、白札がヨメに行きたし、赤札がムコもらいたし。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、白札がヨメもらいたし、赤札がムコに行きたし、だそうだから、じゃア、赤札をつけなさい、と私が入れ智恵したら、ボク、両方ぶらさげて行きます、エヘエヘと高木青年は答えた。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高木青年は私の入智恵に従い赤札をつけていたが、「ダメですよ。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も女も赤札が全然ないですよ。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろやっていることがミランドール（一種の骨牌戯）だし、いつも冷静にしているから、手違いのしようがないのだが、それでいて、しじゅう負けているのだからね」「だって君は、一度も赤札に賭けようとしなかったじゃないか。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話では、すまないことなんだよ……あいつらが集めていた赤札（軍票ドル）を、青札（本国ドル）と換えてやったら、それがガン札だなんて、ムチャな言いがかりをつけるんだから……」　正面玄関の扉があくたびに鳴るブザーが、ほのかな音をつたえた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　工芸室は国展の名物で、いつも楽しみにして出掛けるが、良くて安いものは、招待日の朝出掛けて行って、既に赤札とはどう云うわけだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤札はどんな種類であれとても少なかった。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤札青札で二十ルーブリ、どこから出てきたと思います？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りにあつても赤札が附いてゐるのを見たら心残りがするであらう。",
              "citation": {
                "source": "赤絵鉢",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
