    "definitions": [
      {
        "index": 1,
        "gloss": "red tag (esp. one attached to sold goods or discounted products)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
