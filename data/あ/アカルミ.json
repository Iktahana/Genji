    "definitions": [
      {
        "index": 1,
        "gloss": "bright place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "長の年月、海を見るたびに、おぼろに感じてゐたことが、急に明るみに出た感じ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつとり霧も立罩めて　　その上に月が明るみます、と、犬の遠吠がします。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の炎天も、この谷間までは迫って来ないと見えて、白剥山を一つ超えて、東俣の谷へ来ると、未だ若葉、青葉の新緑が、生々しかったが、ここまで溯ると、濶葉、細葉は、透明を含んだ、黄の克った、明るみのある嫩い緑で、霧の雫にプラチナのように光った裏葉を翻えしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るみへ出て影を※ぎとられるか闇に骨まで呑み込まれてしまうかだ。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の霧のうすれの明るみに松の生え並ぶ白州の浜が覗かれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（年老いた「歎きの女」が若い死者を案内するところの「歎きの國」は、はつきり埃及として考へられるべきではなくして、單に死の意識の沙漠のごとき明るみのなかへのナイル地方の反映として考へられるべきでありますが。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空の明るみを映す田の水や、處處の雜木林の影が蒼黒い夜の闇の中に浮き上つて見え出した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒く濁つた海は果敢ない空の明るみを波の背に映しながら、絶えず往き來する小蒸汽の蹴波に搖いでゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍色の雲に少し明るみが差して、うすれ日が幽かに洩れて來た。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして海峽の波がその明るみを映して銀色に光り始めた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを握んで明るみへ引出して展開させるとそこからまた次に来る世界の胚子が生れる。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは突然その家の前の明るみのなかへ姿を現わしたのだった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は明るみを背にしてだんだん闇のなかへはいって行ってしまった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は暮れかけていたが、その方はまだ明るみが残っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして当時の学界へのパッスを所有していた他のルクレチウスの子孫ヘルムホルツによって始めて明るみに出るようになった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にその異妖な感じの本源を、誰かが突き止めて明るみにサラケ出したら、妖怪実さんが、「ギャッ」と叫んで寂滅しはしまいか。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「俳諧」の中に含まれた「さび」や「しおり」を白日の明るみに引きずり出してすみからすみまで注釈し敷衍することは曲斎的なるドイツ人の仕事であったのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの読み物は自分の五体の細胞の一つずつに潜在していた伝統的日本人をよびさまし明るみへ引き出すに有効であった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は喀痰を紙に受けていくらかの明るみにすかしてみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ晝ながら時のすゝむにつれて明るみの増すやうに、同じ夜ながら更の闌けるにつれて闇は深まつて行く。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、信ずる一念が明るみを心に染み亘らせます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷いさえ退けばそこに自然と悟りが明るみを増して来るのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は爪先から頭の天辺迄慄えていた、しばらくすると其処の濡れた壁にへばり着いていたような黒い影が明るみの中に現われて、こっそりと彼に近寄って来た。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの陰は深い瑠璃色に、もろもろの明るみはうっとりした琥珀色の二つに統制されて来ると、道路側の瓦屋根の一角がたちまち灼熱して、紫白の光芒を撥開し、そこから縒り出す閃光のテープを谷窪のそれを望むものものに投げかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建物の明るみから前へ逆に照り返されて威厳を帯びた銅像が、シルエットになって見える。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、やっぱり出来ないで……時々ここへ来ては未練がましく出したり取り散らしたりして見るのですけれど……」　明るみに出て、陽の光を真正面に受けると、今まで薄暗いところで見た娘の貌のくぼみやゆがみはすっかり均らされ、いつもの爛漫とした大柄の娘の眼が涙を拭いたあとだけに、尚更、冴え冴えとしてしおらしい。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本料理店清涼亭の灯も明るみ出した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ちゃんと、それを知っていますから、こうして縁側の明るみに出されて、恥ずかしいはだかの姿を、西に向け東に向け、さんざ、いじくり廻されても、かえって神様に祈るような静かな落ちついた気持になり、どんなに安心のことか。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々その暗い表情のどこかに、曇天の薄れ陽のような明るみが射しかけることもあるが、それはすぐに消えて、また、元の落著のない暗さに戻ってしまう。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の庭には枇杷の実がやうやく明るみかけてゐた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
