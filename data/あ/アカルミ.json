        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
