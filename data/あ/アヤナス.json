[
  {
    "uuid": "95762455-2f22-5273-ab0f-bfb38b6d6f2a",
    "entry": "彩なす",
    "reading": {
      "primary": "あやなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to decorate with many bright colours (colors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日彩なすについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "彩なすという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は彩なすの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には彩なすが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "彩なすを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは彩なすについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "彩なすの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は彩なすの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では彩なすが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彩なすという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に彩なすという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では彩なすについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "彩なすを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彩なすは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "彩なすについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では彩なすが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彩なすは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により彩なすの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "彩なすは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に彩なすは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "むりやうの圓寂しととに降るや、白き夜霧の、月そそぐ影に彩なすあたり……移らざれ、『時』のまどけさや。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔水と濃きなだれの風や〕水と濃きなだれの風や、　　　　むら鳥のあやなすすだき、アスティルベきらめく露と、　　ひるがへる温石の門。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真そこから泣き、笑い、怒り、怨み、拗ね、甘ったれ、しなだれかかり、威し、すかし、あやなす事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのづから外るゝ水には、何もたまらず流れたり……」　すると鶴巻が、敗惨の私をあやなすやうに、追ひかぶせて、「こゝに伊賀伊勢両国の官兵等、馬筏押し破られて、六百余騎こそ流れたり――」　などゝ私達の兼々の愛誦章を続けた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこれは、天眼通とみえまするな」揶揄するように将右衛門、「だがその眼力、狂っていやしょう」「これさこれさ」と柴田三郎兵衛、あやなすようにいい出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、これは彼女の最も名誉とすべき事柄であるが、彼女はこの連中を実に巧みにあやなす術を心得てゐたので、彼等のうち誰ひとり、自分に競争者があらうなどとは夢にも考へてゐなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、もともと彼女は、自分の尻を追ひまはす連中をあやなすのが大好きで、さういふ手合を引き入れてゐないことは稀らしかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "うみは単に客として言語をあやなす為に採られたばかりであるが、此種の者もかりに此部類にこめておかう。",
              "citation": {
                "source": "和歌批判の範疇",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお可し可し、おお可し可し、ネロちゃんかや、ネロちゃんかや、おお可い子だ、おお可い子だ……」　口笛が止むとあやなす声が、こう密々と聞こえてきた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拗ねる者をあやなす引け目もないはず。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄人が素人をあやなす手はあれにきまったものなのだが、こっちが真剣でかかればかかるほど、その結果が翻弄ということになってしまうのを、兵馬も今は気がついているでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍らにお給仕役をつとめながらの若い老尼が、あやなすように話しかける。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四国外交団をあやなすこともその一つであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉はかつて我儘で身の修らない年上の女と同棲した時の経験もあるので、下手に出て女をあやなすことには馴れている。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ若いくせにあんまり強情な娘で、それに殿様がお優しくいらっしゃるので、いい気になりましてねえ、そばで見ていてもはがゆいようでございますから、この婆あがちょくちょく搦手から攻めているんでございますよ」　とおさよはなんとかしてあやなす気でいっぱいだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――」そんな、渡してしまつたものを先方が返す筈もなし、受け取る筋でもないことは分つてゐながら、庄造が母親に甘えるやうに、母親も見え透いた気休めを云つて、子供を賺すやうな風に庄造をあやなす癖があつた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――」そんな、渡してしまったものを先方が返す筈もなし、受け取る筋でもないことは分っていながら、庄造が母親に甘えるように、母親も見え透いた気休めを云って、子供を賺すような風に庄造をあやなす癖があった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は意識を五彩あやなす錯然とした或る夢幻的な心持に、たびたび誘おうとした。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしエルンストの主な才能は、二人の兄の性質を知りぬいてることと、二人を巧みにあやなすこととであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弱い人ですね、そんなことでは仇は討てませんよ」　東雲はあやなすようにいったのを、兵馬はかえって意味深く聞いて、「全く……」　東雲はしげしげと兵馬の面を見直しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は、それから後で、またうまくあやなす法もあろうというものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、言わねえこっちゃねえ」　この時は、もう烈しくゆすぶることをやめて、寝る子を母があやなすように、米友のあしらい方の手加減が変りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "足弱の子供をあやなすため、焼け残りの古本屋で、角力の古雑誌を買ってあてがう。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実の光と線とのあやなす、それゆえ深く官能的な絢爛無比な幻耀世界へのいざないである。",
              "citation": {
                "source": "北のはての地に",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
