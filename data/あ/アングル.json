        "examples": {
          "standard": [
            {
              "text": "私は毎日アングルについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アングルという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアングルの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアングルが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アングルを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアングルについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アングルの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアングルの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアングルが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アングルという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアングルという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアングルについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アングルを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアングルは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アングルについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアングルが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアングルは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアングルの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アングルは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアングルは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たうとうおしまひには日頃から大好きだつたアングルの橙色の重い本まで尚一層の堪え難さのために置いてしまつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうおしまいには日頃から大好きだったアングルの橙色の重い本までなおいっそうの堪えがたさのために置いてしまった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、白い上っぱりを着た写真師が助手をつれて入って来て、ベッドに仰むきに臥ている自分の右側のおなかの傷に向って高いところからアングルをとって写してゆく。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体｜英吉利の国土にアングルス人種がどれほどいたかと尋ねたら、その数たる甚だ少く、また英国に於て有為あるいは有名な人々を列挙して、その中にアングルス人種に属するものが何人あるかといえば、その割合の寥々たるには一層驚かざるを得ない。",
              "citation": {
                "source": "民族優勢説の危険",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃米国の代表的詩人として名高きホイットマンの如きアングルス種でもなければサクソン種でもない。",
              "citation": {
                "source": "民族優勢説の危険",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは特にその部落を作ったこともあるが、一般人民と混って住み、丁度アングル人、サクソン人その他ピクト人、ブリトン人らが今日英国と称する島に共に住して段々血も混り、今では彼らは、一種確定せる特別な民族たることを誇るに由なく、かえってよく他の長所を吸収する包容力あることを自慢せると同じである。",
              "citation": {
                "source": "民族優勢説の危険",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを撮りたいのが病みつきで、全体の新しいカメラアングルの美を何んとか一つ、再現してみたいと発心したんだが、どうもそれがね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、鈴木澄子氏来、トライアングル love についての苦しさの話。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アングルを「何て本ものみたいにかくだろう」と軽蔑と嫌悪をもって云っているのは面白い。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと映画のアングルとモンチャン（註　モンタージュ）に学んでいいと思われる。",
              "citation": {
                "source": "「壇」の解体",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "モティフだって求めて奇を探らなくても、同じモティフを堂々と人間的解釈の新しいアングルでアフル手がいくらでもある。",
              "citation": {
                "source": "「壇」の解体",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、これは僕のアングルのヴァイオリンと云つたやうなもの。",
              "citation": {
                "source": "ランプの下で",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と月通つてアングルを観たといふものは、アングルだけについて話すことを許される。",
              "citation": {
                "source": "巴里素描",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジングルベルを、タンバリンやカスタネットや大鼓やトライアングルで合奏した。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュートやアングル族の住む北の海辺の砂丘から肌黒いバスクの漁師どもが網を投げてすなどりする南の方まで、グラッドロンの名は人を沈黙させた。",
              "citation": {
                "source": "髪あかきダフウト",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその千島アイヌは、さらに東方なる柬察加をチュプカすなわち日出処と称し、その住民なるカムチャダールを、チュプカアングルすなわち日の本の人と呼び、自己をルーントモングル、すなわち西に住まえる人と云っているとのことである。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の傾かぬうちにと、石塔に打掛けられた稲束を取りのけ、二三のアングルからカメラに収めたが、さてそこで窟のほとりに佇んで、改めてエケレジヤ（教会）の壮観に眺め入つたのである。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アングル随想録一九二八年六月七日（熱海）　大いなる熱が私を解放した。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十九日　暑すぎる時には日覆を半ば引いて、ヴェランダの午後の一時間あまりを『アングル』とともに過すのが私の日課になつた。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『アングル』の鼠色の表紙の親しい感触を指の腹に感じながら何といふ和んだ気持。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッサンについてのアングルの感想は深い啓示に満ちてゐる様に思へるのだが、どうも私の心のすべての弦を一どきに鳴りひびかせると迄は行かないのである。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は海や町の湯気を眺め、それから色彩についてのアングルの言葉を読む。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アングルの言葉、――「生ける肉体中には白いものは皆無である。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アングルを読む昼さがり。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十九日　高原に移つてから一ぺんも手にしなかつた『アングル』を読む。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな私にとつてアングルの言葉は初めのうちは過分のアンファーズに満ちてゐる様に感じられた。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアングルがこの章にこそ一番つよい熱意をもつてゐたからなのだ。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アングルはデッサンに生きた画家だつた。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
