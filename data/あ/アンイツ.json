        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安逸について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安逸という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安逸の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安逸が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安逸を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安逸について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安逸の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安逸の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安逸が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安逸という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安逸という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安逸についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安逸を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安逸は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安逸について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安逸が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安逸は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安逸の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安逸は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安逸は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そしていつかそれに気がついてみると、栄養や安静が彼に浸潤した、美食に対する嗜好や安逸や怯懦は、彼から生きていこうとする意志をだんだんに持ち去っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雲はなにかそうした安逸の非運を悲しんでいるかのように思われるのだった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚図々々と都会生活の安逸にひたっていたのが失敗の基である、その点やはりあなたがたにも罪はある、それにまた、罹災した人たちはよく、焼け出されの丸はだかだの、着のみ着のままだのと言うけれども、あれはまことに聞きぐるしい。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に大才厚徳の士であつても、矢張り必ず安逸好適の状態のみを以て終始する事は出來ない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "境遇變轉して、南船北馬日も足らずといふやうな困難流離の生活をする者が、意氣銷沈するかと思へば、卻つて然も無くて、美妾左右に侍り、膳夫廚に候するといふやうな安逸の生活を續けるものが、勇往の氣永く存するかと思へば卻つて※弱で、やゝもすれば腸胃病乃至神經衰弱やなんぞに罹つてゐるものが多い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に婢僕にかしずかれて快い安逸を娯しむか。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家事多ければ、必らず、能く天下を理する人起るなり、国家徳乏しければ、必らず、聖浄なる君子世に立つなり、国家安逸ならば、必らず、彼の一国の公園とも云はるべき詩文の人起るなり、若し此事なくば国家は半ば死せるなり、人心は半ば眠りたるなり、希望全く無き有様に近きなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "之なければ放縦懶惰安逸虚礼等に流れて、覚束なき運命に陥るものなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "快楽と安逸は人間の必然の希望なり、然れども熱意は快楽と安逸とを放棄して、苦痛に進入せしむることあり。",
              "citation": {
                "source": "熱意",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰平と安逸とは人心を駆つて遊蕩に導くは古今歴史上の通弊なり。",
              "citation": {
                "source": "粋を論じて「伽羅枕」に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康で余り安逸を貪ったことの無い花子の、いささかの脂肪をも貯えていない、薄い皮膚の底に、適度の労働によって好く発育した、緊張力のある筋肉が、額と腮の詰まった、短い顔、あらわに見えている頸、手袋をしない手と腕に躍動しているのが、ロダンには気に入ったのである。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、其の新しい・きびしいものへの翹望は、何時か快い海軟風の中へと融け去つて、今は唯夢のやうな安逸と怠惰とだけが、懶く怡しく何の悔も無く、私を取り圍んでゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そんな事をあても無く想像して見るだけで、真正面からこれについて考える気力が無く、大掃除を一日延ばしにして怠けている安逸さで、一日一日、それとの直面を惧れ避けているのであった。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、その新しい・きびしいものへの翹望は、いつか快い海軟風の中へと融け去って、今はただ夢のような安逸と怠惰とだけが、懶く怡しく何の悔も無く、私を取り囲んでいる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門の技芸の外には、世間に役立つ程の学才智能があるのではなし、銭勘定さえ知らない程に世事に疎かった能役者は幕府の禄こそ多くなかったが、諸大名からの夥しい扶持を得て前記の如き贅沢な安逸に耽っているのであるから、すべての禄に離れて、自活を余儀なくされた能役者の困惑は言語に絶するものであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を作り、財を貯え、安逸なる一町民となるも、また人生の理想であると見られぬことはない。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに對して奢侈は人の原徳を喪失するに至らしむる所以であり、又奢侈は安逸遊惰と因果の醜循環を形づくるものである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中には、ことに君が少年時代を過ごした都会という所には、毎日毎日安逸な生を食傷するほどむさぼって一生夢のように送っている人もある。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去の生活は安逸と愉悦とにみちていた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、小路、安逸の、醜辱の、驕慢の森の小路よ、あだなりしわが世の友か、吹風は、高樫の木下蔭に声はさやさや、涙さめざめ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、小路、安逸の、醜辱の、驕慢の森の小路よ、あだなりしわが世の友か、吹風は、高樫の木下蔭に聲はさやさや、涙さめざめ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "艱難な生活を経た作者が、艱難に捉へられた形のあるのは、その作者の為めに恥づべきことであると同じやうに、生活に苦労のない作者が富貴安逸に捉へられるといふことも、矢張恥づべく改善すべきことである。",
              "citation": {
                "source": "雨の日に",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の安逸さへあれば……。",
              "citation": {
                "source": "雨の日に",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ／＼、早いな、と思つたが、大望を抱いてる身の、宛然初陣の曉と云つたやうな心地は、目がさめてから猶温かい臥床を離れぬのを、何か安逸を貪る所業の樣に感じさせた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ／＼、早いな、と思つたが、大望を抱いてる身の、宛然初陣の暁と云つたやうな心地は、目がさめてから猶温かい臥床を離れぬのを、何か安逸を貪る所業の様に感じさせた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務が済めば遊蕩的な無駄話に耽る彼等の安逸さに彼女も同化してゐた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
