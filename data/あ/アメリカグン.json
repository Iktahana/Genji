        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ軍について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ軍の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ軍が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ軍について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ軍の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ軍が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ軍という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ軍についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ軍は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ軍が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ軍は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ軍の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ軍は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ軍は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それで、碇泊中のアメリカ軍艦へ行ってダイナマイトを貰おうとしたが拒絶され、やっと、難破船引揚業者（前々年の大｜颶風で湾内に沈没したままになっている軍艦二隻をアメリカがサモア政府に寄贈することになったので、其の引揚作業のため目下アピアに来ている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ注に、欧州大戦のときフランスに出征中のアメリカ軍では驢馬のいななくのを防ぐために「ある簡単なる外科手術を施行した」とある。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（４）Fort Moultrie ――チャールストン港の防御のために一七七六年に建てられ、まだ竣功しないうちにアメリカ軍の William Moultrie（一七三一―一八〇五）大佐がここに立て籠ってイギリス軍を防いだので、その名が付せられた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼の父の代になって――というよりも数年前、このアイスランドがデンマーク領たることを御免蒙り独立してしまってからは、イギリス軍やアメリカ軍の進駐となり、古い淋しいアイスランドは急に夜が明けたように賑やかになった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車軌道を横ぎって、濠端に出ると、大勢の人が、アメリカ軍の兵士も交って、濠の鯉を見ていた。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "モン・フォーコンはドイツ軍の有力な陣地の一つで、それをアメリカ軍が占領したので、アメリカの建てた高い戦捷記念石柱が聳え立っている。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱の頂上の台座には左手に炬火を捧げた男の像が立ち、下の台石には一九一八年にアメリカ軍の占領した四つの地名が刻んである。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アメリカ軍は戦争の終末に近づいて不用意に勢って飛び込んで、かなりひどい犠牲を払ったのだということだ。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日アメリカ軍が使っている爆弾は液体爆弾なんだ」「液体爆弾？",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによって、たとえ徐々にせよ、アメリカ軍隊を撤退させるべきであって、何もかもそして常に、アメリカにのみ頼ろうとするのは、それこそ亡国根性である……。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアメリカ軍の諸事業（アメリカ軍のためのもの）は、いずれも適切なものばかり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がかつて戦争中、大いに進言、力説したところのものが、今アメリカ軍によって行なわれるのを見て感慨無量だが、お役人や軍人指導者達もさぞや別の意味で感慨無量であろう。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアメリカ軍が使っているジープといわれる小型のものだった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンモックだったのか」　源一はアメリカ軍人の簡易生活におどろきながら、少佐のハンモック吊りを手つだった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に合衆国の初代の大統領となったジョージ・ウォシントン（一七三二―一七九九）は当時アメリカ軍の総指揮官であって、独立戦争開戦以来各地に転戦していた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると九月初旬になって、小樽港をアメリカ軍事基地として「提供」したらどうかという横浜調達庁のかねての勧誘にたいして、市議会は断乎、港湾軍港化反対決議を通過させた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永六年六月三日（西暦では一八五三年七月八日）、アメリカ軍艦四隻について浦賀奉行戸田伊豆守が、閣老阿部伊勢守へ報告した一節であるが、このへん繰り返し讀むと、當時幕閣の複雜な對外事情がわかるやうで、なかなか苦心の文章である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、深夜アメリカ軍艦を訪れ、祕密渡航を企て、捕はれた吉田寅次郎らの如き、尠くとも「進取」があつたのである。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、もとのようにしていただく」　そんなことをいっているとき、さっきの労働服を着たアメリカ軍が五人ばかり、前後になって入ってきた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の力説する再軍備反対、戦争反対、アメリカ軍事基地化反対などにこちらが賛成して、では、じっさいに、どうすればよいかと考えると、さっぱりわからなくなる。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんアメリカ軍の統合参謀本部といったようなところで決定され、トルーマン大統領がサインをして、軍の専門部に命令がくだされたのだろうと察しられる。",
              "citation": {
                "source": "アメリカ人に問う",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして来年一月からはトルーマン氏にかわって、大戦中アメリカ軍の首脳者の一人であったアイゼンハワア氏が大統領になる。",
              "citation": {
                "source": "アメリカ人に問う",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはアメリカ軍医から狼瘡という難病の診断をうけて三六一病院に入院し、次いで私は、巣鴨病院に入院した。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヴァナの公衆衛生はゴルガス博士の手にあり、９月のあいだに市から黄熱病を一掃し、アメリカ軍撤退の後に少しの発生はあったが、その後は何世紀にもわたって存在した天罰を受けないですむようになった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "何世紀ものあいだ流行病の巣窟であり、アメリカ軍による占領の後でも１月のあいだに1000人あたり71人の生命を要求したパナマ市を掃除することそのものが実際に大きな仕事であった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこい日本が軍隊持つてだな、もしアメリカとほかの国が戦争になれば、日本軍はアメリカ軍に一人手に組み入れられるんだ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は敗戦後七年間も国連軍（その主力はアメリカ軍）の占領下にあり、引きつづいて現在も、かなりの程度までアメリカの圧力の下にあるのですから、われわれはそれにたいして、何かの形でか抵抗を感じざるをえないので、われわれの意見もそのことに関することが主となるのは当然です。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は独立を回復したが、しかしその独立は条件つきのもので、アメリカとのあいだには安保条約があり、日本内地には強力な、数多くのアメリカ軍事基地がある。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
