      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secret feud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗闘について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗闘という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗闘の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗闘が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗闘を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗闘について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗闘の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗闘の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗闘が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗闘という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗闘という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗闘についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗闘を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗闘は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗闘について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗闘が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗闘は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗闘の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗闘は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗闘は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして、葬儀場は時として高官の人が盛装の胸を反らす晴れの舞台となり、あるいは淑女の虚栄の暗闘のアレナとなる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯盤の間に於ても暗闘と暗闘とがひつきりなしにつづく。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に気の早い内弟子はもう後釜をねらって暗闘を初めているらしい事なぞをおしゃべりの女中からきいた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実に於て母と義母との間には堪へざる暗闘があつたのであつた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "田川夫人と葉子との暗闘は表面には少しも目に立たないで戦われていたのだけれども、それが男たちに自然に刺激を与えないではおかなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の性格はこの暗闘のお陰で曲折のおもしろさと醜さとを加えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ならば、それは唯暗闘、黙闘の心的光景である。",
              "citation": {
                "source": "社会と自己",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闘的ないさかいはあったが、見ともなく喧嘩するようなことはなくて終ったのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "発会当時およびその後のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思ふと私は、債権者としての田舎に於ける自分の名前を今更のやうに思ひ出したり、私の山や田畑をめぐつて幾人もの強慾者連が、血で血を洗ふ暗闘を巻き起した光景などが、虚空のスクリインにまざまざと展開されたりした。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "森家の雇人と彼等との間にも百合子を中心にして絶え間のない暗闘が繰り反された。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸賞競馬に優勝すると凡そ一ヶ年分の生活費が賞金として獲得出来るといふ仕組であつたから、季節が迫るに伴れて村全体が競馬の熱に浮されて、様々な暗闘やら策略やらで渦巻いて異様などよめきが漂ひはじめるのが慣ひであつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行田や熊谷の小学校には、校長と教員との間にずいぶんはげしい暗闘があるとかねて聞いていたが、弥勒のような田舎の学校には、そうしたむずかしいこともなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、なぜこんな事件が起ったかというと、この宗旨の本山の方に何か面倒な事件があって、こんにちの詞でいえば、本山擁護派と本山反対派の二派にわかれて暗闘を始めていたというわけなんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "都におけるいろいろな暗闘、陥擠、戦争、権勢の争奪、それからくる嫉妬、反感、憎悪。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故に平和な神の教会にまで果しなき暗闘を賦与し、富める長老と貧しい執事とを争わすだろう。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この間には、多少生活感情上の暗闘がなかった訳ではありませんが、彼女は、稀な美貌と事務的敏腕を兼備し、その上、著名な良人を持ち、ロンドンでも数少ない程、調ったよき家庭の主婦であると云う素晴らしい調和で有名な一人の女性となりました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の先生たちは大人の世界でどんな暗闘があったか知らないが、少なくとも子供たちに対しては正しく、公平であり、道の師範であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子は、世界が違う気楽な若者と暗闘する岡本の気持がわかるような気がした。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へ男に何かの収入の道がついたとしても、彼女は決して母親の希ふやうな、嫁になりおほせる事が出来ない事を思ふ程、さうして、母親が必然に自分の思ふ通りになるものと極めてゐる気持を考へれば考へる程、これから先きの長い双方の暗闘が、とし子の心を暗くするのであつた。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清子は毎夜のように持ちあがる、二人の間の暗闘――許す、許さぬの絡みあいを思った。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの四、五年は播重と呂昇との暗闘であった。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が、首を縊らねばならぬ原因も云われないし、また、加害者の名も口に出せないとしたら、この一座の暗闘状態は、案外深刻なのかもしれんよ。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女らしいひねくれ、固執、暗闘で、二人の愛するものが心を悪くさせられて居るのを見るのは辛い。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論表面は病室見舞であつて、何の不思議もないのであるが、かうして三人の暗闘が夕方毎に募つて行くのを、成瀬は浅ましいとも思ひながらしかしやはり興味深く眺めるのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には将棋は分らないが、心理の闘争があるはずで、強者、十年不敗の名人が追ひこまれてゐる、心理の複雑なカケヒキが勝負の裏に暗闘するに相違ない。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはミチ子をめぐる彼と私との暗闘が最後的場面へ抛り出されたのだ。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大暗闘　なにしろその異人たちはなかなか力があって、マルモ探検隊員は圧迫されがちであった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれは心の底の底での暗闘で、つひには、征服されなければならないものでした。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから線路の左がわで、ぐゎあん、ぐゎあんとうなっていたでんしんばしらの列が大威張りで一ぺんに北のほうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから線路の左がはで、ぐわあん、ぐわあんとうなつてゐたでんしんばしらの列が大威張りで一ぺんに北のはうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
