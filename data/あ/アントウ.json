[
  {
    "uuid": "9e83eccc-f4bd-594f-ab04-242f9cdfac40",
    "entry": "暗闘",
    "reading": {
      "primary": "あんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
