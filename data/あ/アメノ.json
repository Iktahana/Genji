        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天のについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "天のという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天のの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天のが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天のを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天のについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "天のの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天のの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天のが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天のという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天のという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天のについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天のを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天のは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天のについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天のが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天のは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天のの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天のは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天のは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああ、わが故郷にあるの日、終日怒りうゑを感じ、手を高く蒼天のうへに伸ぶ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる意外、何たる青天の霹靂だらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "広庭の牡丹や天の一方に　前の句と同じように、牡丹の幻想を歌った名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の一方に」は、「天一方望美人」というような漢詩から、解釈の聯想を引き出して来る人があるけれども、むしろ漠然たる心象の幻覚として、天の一方に何物かの幻像が実在するという風に解するのが、句の構想を大きくする見方であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔思ふ草の庵の夜の雨に涙なそへそ山ほととぎす」これは「盧山雨声草庵中」といふ句のある白楽天の漢詩を日本風に訳したものだと言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に軒端の廻燈籠と梧桐に天の河を配した裏絵を出したら幸運にそれが当選した。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い高い梯子が立ってその上に天の戸が開けていた、王がそれを登りつめて最後の段に達した時に起こされたのだと言う。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲書きのおじさん大黒天の耳を書く所。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時これ金と云えばこの四時間何金に当るや知らねどあくびと煙草の煙に消すも残念なり、いざや人物の観察にても始めんと目を見開けば隣りに腰かけし印半天の煙草の火を借らんとて誤りて我が手に火を落しあわてて引きのけたる我がさまの吾ながら可笑しければ思わず噴き出す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の一挙一動は寒天のような濃厚な媒質を透して伝播するのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかのと言つて、私の宿命をお前たちの宿命にまで引下げようとしてゐるが、しかし、天の配劑、人事の及ばざるところさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十いくつの石段を登り、だらだらの坂を半丁ほど登り、有頂天の歡喜があるとしたら、市民とは實に幸福なものだと思ふ。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二勺より路は黒鉄を鍛へたる如く、天の一方より急斜して、爛沙、焦石、截々、風の噪ぐ音して人と伴ひ落下す、偶ま雲を破りて額上｜微かに見るところの宝永山の赭土より、冷乳の缸を傾けたる如く、大霧を揺るよと見る間に、急瀬上下に乱流する如くなりて、中霄に溢れ、片々｜団々、がり、故郷を望んで帰り去なむを私語く。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の汽車は、箱根｜火山彙を仰ぎ見て、酒匂川の上流に沿い、火山灰や、砂礫の堆積する駿河｜小山から、御殿場を通り越したとき、富士は、どんより曇った、重苦しい水蒸気に呑まれて、物ありげな空虚を天の一方に残しているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天空に浮遊するかの如き、嶮にして美なる林道を「天の浮橋」と呼ぶそうであるが、何よりも喬木林の陰森さにおどろかされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水が飲みたあい」　と、炎天の下で乾物になりさうな程も、焙られて怒鳴りながら駆けて、帰つた子供たちは、井戸に飛びついてポムプを押すのだが、井戸からは一滴の水も出ないのだ。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照されて映し出した色彩の盛観に見惚れてゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて見ると不忍弁天の社務所が池の方へのめるように倒れかかっているのを見て、なるほどこれは大地震だなということがようやくはっきり呑込めて来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁天の前に電車が一台停まったまま動きそうもない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照らされて映し出した色彩の盛観に見惚れていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう扁平な板のような天体の中央に居て八方を眺めたと仮定すると、板の面に沿うた方向には沢山の星が重なって帯のように見えるはずでこれがすなわち天の河である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれだけの研究によって天の河を距るに従って星の密集の度が減ずる模様がよほどよく分って来たのである。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし太陽も満天の恒星も全く動かぬというのは、実は、嘘ではないまでも人を見て法を説く小乗の方便である。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽はまた地球その他の遊星を率いて天の一方リーラ星座に向って突進している。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れもおし詰まった二十六日の晩、妻は下女を連れて下谷摩利支天の縁日へ出かけた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的百貨店、ウェルトハイムの大飾窓に煌めく満天の星、神木の木の下の女神を取巻く小鳥、獣類、人間の小児、それらを囲る幽邃な背景が、エンジンの回転仕掛けで、めぐる、めぐる。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はまっ白なやはらかな空からあめのさらさらと降る中で虔十がたゞ一人からだ中ずぶぬれになって林の外に立ってゐました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
