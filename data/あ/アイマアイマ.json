        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は海を見ては合間合間に、その人影に注意し出しました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の合間合間にすら、少しの油断も出来ない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその手助けの合間合間に、説教をするのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基は家柄なり、性分なりで、もとより学問文章に親んで、其の鋭い資質のまにまに日に日に進歩して居たが、豪快な気象もあった人のこととて合間合間には田猟馳聘をも事として鬱懐を開いて喜びとしていた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ、真に烈しい啖呵をきりながら、合間合間に、自分達の左様な経歴などをさしはさんでは見得を切つてゐるのです。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "難かしい面白くない本の合間合間には雑誌をよむ。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐息の合間合間に丁子の香りがした。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浜町という所は――この附近全体がそうではあるが――恰も五本の指をひろげた様に細高い丘が海中に突出して、その合間合間が深い入江となって居るという風の所である。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荒木又右衛門」や「鳴門秘帖」でも読むような積りで、仕事の合間合間に寝ころびながら読んでほしい。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "争議団のうちの小作人で、最初日和見のものも随分いたようであったが、日々の交渉、集合による訓練、労農党員の「社会問題講座」の開設等によって、（これは忙しい合間合間に行われたが、その効果では著しいものがあった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "口笛を吹いたら、それが何んなに澄み渡つて響くことだらう、余程心して極めて低音に吹き鳴すのが適当だらう――音田は、波の合間合間の底知れぬ静寂さに吸ひ込まれさうな思ひで凝つと息を殺してゐた。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかといつて、その合間合間に下級吏員や椎茸の値段を考へたところで少しも差支はない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず私たちは時間の合間合間に砂糖わりの豌豆豆を買って来て教場の中で食べる。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんも合間合間に何か言っていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり俺は芸術家だぞとか、俺は生え抜きの芸術理論家だぞとかいう、一種の我慢が、その篤実な考察の合間合間に顔を出すのではないかと思う、そうでなければああいう誤解は一寸出来にくいように私は考える。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "合間合間に、小さい子供が一輪車に片脚をのせて転って行った。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "話しの合間合間に交えられる手振も徳田さん独特だし、その手の指には網走の厳しい幾冬かが印した凍傷の痕があるのである。",
              "citation": {
                "source": "熱き茶色",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その席は、例のお仲間の卓子を正面に見るようなところだったので、彼は牌を握る合間合間に顔をあげて、星尾助教授の手の内を後からみたり、川丘みどりの真白な襟足のあたりを盗み視して万更でない気持になっていた。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "合間合間にどっと、血の沸くような鯨波があがる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は涙をぼろぼろ零しながら、敵に投げつける呪詛の文句の合間合間に神に祈った。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のすぐの左隣の机に座って、時間の合間合間にはいつも黙りこくって『改造』を読んでいた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その合間合間には喘息が起る……といった調子でなかなか忙がしかったのであるが、しかしその態度は依然として悠々たるもので、彼れもこれ一と昔の夢という風に、明暮れ試験管と血液に親しんでいた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩がちぎってくるような吹雪の合間合間に、しだいに遠ざかってゆく鈴の音、犬の声。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先生、近頃じゃわっしも、臥床に入ると、爪先から脈の音が聴えるようになりましたが、そうするとお母ろが、毛孔から海の匂いを吹き入れてくれて、すっかり雲のように、わっしを包んでくれるんですよ」二、裏向きお岩　それは狂気の合間合間に現われる、綺びやかな夢幻のようなものだった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然かは知りませんが、それが六つある、刺葉の合間合間に符合しているのです。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読経の合間合間に経輪がまわっている。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリュートの音が、ひょろひょろと蒼穹に消えると、その合間合間に、乾からびた木戸番の「呼び込み」が、座員の心をも、何かそわそわさせるように、響いて来た。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杯と、生物の多い新鮮な料理の箸との、合間合間に、田代さんは、杉本へ言葉をかける。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空想の合間合間には、これが自分の選ぶべき娘だろうか、もっと他に優れた娘がいはすまいかと、世界中の処女をよせ集めて、その顔を一つ一つ覗いてみたい気がするのだ。",
              "citation": {
                "source": "春の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
