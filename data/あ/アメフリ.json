          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨降りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨降りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨降りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨降りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨降りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨降りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨降りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨降りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨降りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨降りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨降りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨降りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨降りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨降りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨降りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨降りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨降りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨降りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨降りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨降りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある夕、雨降り風｜起ちて磯打つ波音もやや荒きに、独りを好みて言葉すくなき教師もさすがにもの淋しく、二階なる一室を下りて主人夫婦が足投げだして涼みいし縁先に来たりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "副業雨降りしぶくひるすぎを、　　青きさゝげの籠とりて、巨利を獲るてふ副業の、　　　銀毛兎に餌すなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月七日――「昨日も今日も南風強く吹き雲を送りつ雲を払いつ、雨降りみ降らずみ、日光雲間をもるるとき林影一時に煌めく、――」　これが今の武蔵野の秋の初めである。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三円だけ渡して来る」　五月十一日　今日は朝から雨降り風起りて、湖水のような海もさすがに波音が高い。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一（考える）「すた、去年なも、ずいぶん雨降りだたんとも、ずいぶんゆぐ穫れだます、まんつ、おらあだりでば大谷地中でおれのこれぁとったもの無ぃがったます。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にも晴天だからいいようなものの、これが雨降りでもあったものなら、たまったものではない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨降りの中では草鞋か靴ででもないと上下は難しかろう――其処を通抜けて、北上川、衣河、名にしおう、高館の址を望む、三方見晴しの処（ここに四阿が立って、椅子の類、木の株などが三つばかり備えてある。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨降りの休み日が二十一度、その中六度は外套を透して、長靴の中へ流れ込む程の豪雨であった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こんな工合では、やがてのことも我々は、雨降りの映画を見ればビショ塗れになるだろうし戦争の映画を見れば多数の見物が悶絶してしまう程に、効果的なフィルムが市場に出現するに違いありますまい……検閲制度ですか？",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る雨降りの、急に冬がやって来たかのように冴え々々とする晩のことであった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕の室から程近い玄関口の方に当って時折、するどく、けれども何となく物悲しい余韻をひびかせて、犬が吠え立てるのであって、僕はあまり雨降りの夜に犬の吠声を聞いた事がなかったもので（むろんそれは人通りの少い故にもよるのだろうが）――ちょっと訝しく思ったのでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がふったら御褒美をやるぞ」「僕はいりませんから、雨降り坊主にやって下さい」　太郎はすぐに半紙を一枚持って来て、平仮名でこんなことを書きました。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨降りあとじゃ、川へいて、雑魚なと、取って来なはれ、あんじょ、おいしゅう煮て、食べまひょ」継ものをしていた母親がいった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節季節によって、鮴、川鯊、鮠、雨降り揚句には鮒や鰻も浮出てとんだ獲ものもあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが丁度翌日は雨降りになった。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに雨降りの晩は傘の出し入れもしなければならず、濡れた傘のじっとりした手ざわりがたまらなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨降りや雨上りの時は、蹄がすべる。",
              "citation": {
                "source": "馬地獄",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の葉つぱは雨降りや生きる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知のようにきょうの午後は雨降りでした。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のように、今日の午後は雨降りで、患者は外来の人だけでした。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう雨降りの日には、くっきょうなものがあったとおもって、それをくつの上にはきました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "……以前車の通った時も、空でないと曳上げられなかった……雨降りには滝になろう、縦に薬研形に崩込んで、人足の絶えた草は、横ざまに生え繁って、真直に杖ついた洋傘と、路の勾配との間に、ほとんど余地のないばかり、蔦蔓も葉の裏を見上げるように這懸る。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日一昨日雨降りて、山の地湿りたれば、茸の獲物さこそとて、朝霧の晴れもあえぬに、人影山に入乱れつ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ・Ｃ様　きょうも雨降りになりました。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷の雨塚とは太古のいまだ開けざる頃の人の住家もしくは墓穴のたぐいを、むかし氷の雨降りたる時人々の隠れたりしところならんと後のものの思いしより呼びならわせし名にやあるべき、詳くは考うべき由なし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石原にていよいよ堪え難きに、雨降り来り日暮るるになんなんたり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日は雨降りさうにもなし。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの事にて候へども、ながあめふりて夏の日ながし。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
