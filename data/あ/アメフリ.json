[
  {
    "uuid": "d3285e9a-fded-594c-802c-c5951b30bc1a",
    "entry": "雨降り",
    "reading": {
      "primary": "あめふり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
