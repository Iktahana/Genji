    "definitions": [
      {
        "index": 1,
        "gloss": "autumn festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは晩春の頃からころころと啼き始めて、やがて湧き立つ様に野をこめる蛙の声が、どんなにめずらしくなつかしく、かやの稚い心をそそる夜も、秋祭りの野太鼓が、しきりに響いて渡る頃であっても、かすか乍らも澄み透って一縷の哀調を運ぶ横笛の音なのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）末弟は、東京でいい恥さらしをしているそうだのう、とただそれだけ、話題に上って、ふっと消え、火を掻き起してお茶を入れかえ、秋祭りの仕度に就いて話題が移ってゆく、という、そんな状態ではないかと思う。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日曜の朝、目黒の父の家の夫人からわたくしに秋祭りがあるから遊びに参れとの使いです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの子柄の様子を見に、秋祭りの招待に事寄せて、わたくしを観察したのですけれども、結果は取止めになったのだと、しまはわたくしに言い聞かせました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りにはまだ間があり、夏祭りは過ぎてしまいました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしいので、一旦は流行りましたが、そう長くは続かないので、後には両国を引き払って、諸方の宮地や寺内で興行したり、近在の秋祭りなぞへ持ち廻ったりしていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘らが、秋祭りに笛を吹いて通る美しい若衆を見て、いちように深く思いこがれる身となりました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝はすこしの小力を自慢して、秋祭り小相撲などをとっているが、そんな小さな料簡では所詮だめ、真の大力をほしくば夜ひそかにわが太平山に来たり籠もれよと、声朗らかにいわれます。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の村の秋祭りには、あなた方のことをお祈りになって御馳走をおこしらえになり、若い連中をおよろこばせになったそうです。",
              "citation": {
                "source": "二人の弟たちへのたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで水の底で助けて帰されたことを、薬売りが咄しますと、主人も驚いたには違いありませんが、その御主人の言葉に「毎年秋祭りの前後に、はげしい山おろしが吹荒れると、中妻のおばあさんが来たということを、里の者は何の訳か言いつたえている。",
              "citation": {
                "source": "糸繰沼",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百稲千稲にひき据ゑおきて、秋祭爾奉〔牟止〕…参聚群りて…たゝへ詞｜竟へまつる……（龍田風神祭）この「秋祭」は、今言ふ「秋祭り」ではなく、秋の献りものとして奉らむと言ふ意であらう。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会地方では、祇園囃子の面白い八阪の祭りに次第にかぶれて、秋祭りには疎に、夏の方には力をこめる様になつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　秋祭りと新嘗祭りと秋の祭りは、田舎の賑ふ時である。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京などの秋祭りは、夏のが早いだけに、まだ残暑のいらつく間に行うてゐる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りは、農村の大事であるけれど、最古くからあつたものかは疑はしく、山地に這入つてからの発生で、新嘗は冬に這入つてから行はれたものであるらしい。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りは、古げに見えて、田植ゑ時の神遊びよりも遅れて起つてゐる、と言はれさうである。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社が神道の中心となるに連れて、秋祭りは、農村の大行事となつて行つた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても、早稲の新嘗と村の守り神との関係が、色々に変化しながら、秋祭りを複雑化したのであつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りなる新室ほかひがすむと、直に翌日から春になつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此秋祭りの分れ出た元は、冬の祭りであつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、冬祭りに二通りあつて、秋祭りと関係深い冬祭りは、寧、やつぱり秋祭りと言つてよいものであつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも時には、秋祭りの意義の冬祭りと、春祭りの条件なる冬祭りとが、一続きの儀礼らしくも見える。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、秋祭りの直後に冬祭りがあり、冬祭りにひき続いて春祭りがあつて、其が、段々間隔を持つ様になつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りを主とする田舎の村々でも、夏祭りを疎かにする処はなかつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此も秋祭りと入り紊れてゐるが、順序正しく言へば、夏のものである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして山の方は、寧、秋祭りに曳くべき物であつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りを今一つ狭めて言へば、先人たちも言うた通り、新嘗祭りであるが、此には、前提すべき条件が忘れられてゐる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地方化で、神嘗祭りの為に献つた荷前の残りの初穂を、地方の社々の神も試み喰べられたのが、秋祭りの起りである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りの太鼓をめあてに、細道を行くと、落し水は堰路にたぶついて、稲子は雨の降る様に胸・腰・裾に飛びつく。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
