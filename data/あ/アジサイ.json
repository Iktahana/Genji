    "definitions": [
      {
        "index": 1,
        "gloss": "bigleaf hydrangea (Hydrangea macrophylla)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
