        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "揚げ足の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "迂濶にそれを否認して、飛んだ揚げ足を取られるのも口惜しいと思ったからであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはいわゆる「揚げ足取り」の態度であって、まじめな学者の態度とは受け取られない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は別にウェルズの揚げ足をとるつもりでもなんでもない、ただ現在の科学のかなり根本的な事実と牴触するような空想と、そうでない空想との区別だけははっきりつけておいたほうが便利であろうと思ったからしるしておくだけである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　僕はこう問い詰められてちょっと文句に困ったがすぐと『そんならなぜ先生は孟子を読みます』と揚げ足を取って見た。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の殺されているのはいいとして、どこで本人が殺されているのか、肝心の方角をいわねえんで、だんなだっても急ぎようがねえんだよ」「つべこべと揚げ足取るなッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもそういちいちと、つまらねえところで揚げ足を取らなくたってもいいでやしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ日が暮れるまでには間があるよ」「いちいちと揚げ足を取りなさんな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここで詰まらない揚げ足をとっていて、肝腎の本題が横道へそれてはならないと思ったので、わたしは笑いながらまた言った。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を知らぬ者は彼の評論を揚げ足取りの尻取りのと云う。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の祭りの夜のかけあひ文句――いはゞ揚げ足取りのやうなもの――から出ました。",
              "citation": {
                "source": "古代生活に見えた恋愛",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも素子は私の揚げ足を取ったりして、執拗に絡んで来る。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしはいけないの、すぐ揚げ足をとる癖があつて……」　意外に素子がすツと折れて、幾島は拍子抜けがしたらしく、不機嫌に尖らした口をそのまゝお道化面にして、「どうも、こゝぢや工合が悪いや。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく譲りてばかりいては、唯物連中の揚げ足取りは、必ず逃げ口上のように評する恐れあれば、今ここに一言だけ述ぶることにいたします。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乃公は何も掲示の揚げ足を取りに行ったんじゃない」　と杉浦君は苦笑いをしていた。",
              "citation": {
                "source": "恩師",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが勿論そんなことは、揚げ足取り以外に、今大した苦情にはならないだろう。",
              "citation": {
                "source": "デカルトと引用精神",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内的物価騰貴が投機思惑によるものであるかのような云い方は、忽ち揚げ足を取られる点だろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こういう熟語や文法の上での揚げ足取りはどうでもいいとして、例えば作用運営（この対句か熟語の合成かも少し変だが）のみではいけないから、大いに吏道を振粛する、と云うことになるらしいのだが、して見ると庶政の（だろうと判読）作用運営以外に吏道なるものがあるように取れるようだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん私は自然人間の立場から、エラスムスが嘲笑ったような「瞬間、無遠慮、揚げ足取り、および関係」についての哲学論争からより、ロジャー・ベイコンの実験からもっと希望があると言っているのである。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、この当時、母の胎内にみごもっていたか、いなかったかさえわからない徳冨蘆花という文学者の文字づかいの揚げ足までもちゃんと心得ている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふだんはあんな風に人の前で大阪弁を使ってみせたり、揚げ足を取ったりするようなことはめったにないんだ。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々揚げ足を取る」「ハッハヽヽ。",
              "citation": {
                "source": "田園情調あり",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がのびていれば布袋だ」　と照彦様は腹いせにあっぱれ揚げ足を取ったつもりだったが、「オホホホホ、それは福禄寿のことでしょう？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは自慢じゃないが、尋常科の時に海へ落っこった女の子を助けて、お上からごほうびをもらったことがある」「川へ落っこった子だっていったぜ」　と尾沢生が揚げ足をとった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と事務員は直ぐに揚げ足を取った。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と菊太郎君は久子夫人に頭の働きを見せる積りか、突如揚げ足を取った。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはデレンマの角だ」「揚げ足を取るなよ」「君はその通り万事上の空だ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「覿面な効果を求めて極端な実例を持出すものだから、揚げ足ばかり取られるけれど、先ず大体｜然ういった風のものさ」　とお父さんはもう草臥れている。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお父さんは揚げ足を取った。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "対等なら揚げ足を取って、ひどい目に会わせてやるんだけれど」　と松本さんはお株を始めた。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｄ「比喩のあげあしを取るのは馬鹿だ。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
