        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日文目について考えている。",
              "source": "幻辞"
            },
            {
              "text": "文目という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は文目の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には文目が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "文目を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは文目について学習した。",
              "source": "幻辞"
            },
            {
              "text": "文目の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は文目の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では文目が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "文目という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に文目という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では文目についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "文目を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると文目は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "文目について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では文目が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に文目は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により文目の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "文目は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に文目は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『甲子夜話』五一に、吉宗将軍小金原に狩りして、自ら十文目の鉄砲で五月白と名づけた古猪の頭を搏ち、猪一廻りした処を衆人折り重なって仕留めた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "文目もおぼろ、蕭やかに、噫、蕭やかに、つくねんと、沈黙の郷の偶座は一つの香にふた色の匂交れる思にて、心は一つ、えこそ語らね。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "文目もおぼろ、蕭やかに、噫、蕭やかに、つくねんと、沈默の郷の偶座は一つの香にふた色の匂交れる思にて、心は一つ、えこそ語らね。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして火事装束、草鞋掛で、十文目筒を持つて土橋へ出向いた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同心等の持つてゐた三｜文目五｜分筒が煎豆のやうな音を立てた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御祓筋から高麗橋までは三丁余あるので、三｜文目五｜分筒の射撃を、大塩の同勢は知らずにしまつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本は堺筋西側の紙屋の戸口に紙荷の積んであるのを小楯に取つて、十｜文目筒で大筒方らしい、彼黒羽織を狙ふ。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟が中流に出てから、庄司は持つてゐた十｜文目筒、其外の人々は手鑓を水中に投げた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文目も知れぬ闇であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで酒窖の中のやうに真暗で、物の文目も分らなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人を咒わば穴二つ、いい気味だ、態ア見ろ」　じっと穴の中を見込んだが、文目も知れぬ闇の底から冷たい風が吹いて来るばかり、老人の姿は見えなかった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠱の露文目もわかぬ夜の室に濃き愁ひもて釀みにたる酒にしあれば、唇にそのささやきを日もすがら味ひ知りぬ、わが君よ、絶間もあらぬ誄辭。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひわかつぞげにも命なる、力なる、思ひなきこそ文目なき死にはあるなれ、かくもあらば、さらばわが身は世にも幸あるさ蠅かな、生くといひ、將た死ぬといふ、その孰れともあらばあれ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で重量の名稱を一匁（一文目）といふ如きは、支那の錢の名稱を逆に使用したものである。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "只文目で面白い目を見て、あなたが厭な心持になっては気の毒だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ主題を繰り返しながら、最後の一文目がけてじわじわとサスペンスを盛り上げる手法が最高です。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "日食のうち、夜のうち、文目もわかたぬ暗がりのうちには、最も強い人々にとってさえ不安がある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そこには別に恐ろしいものがいる訳ではなく、ただ文目もわかぬ闇があるばかりであった。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、襖の奥は文目も分かぬ暗闇だ。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、彼を取り囲む文目も分かぬ暗闇が、云うばかりなく心細かった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い竹藪の迷路は、文目も分かぬ闇となった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、遂には文目も分かぬ真の闇にとじこめられてしまった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "文目もわかぬ闇の中に、彼の煙草の火が、ポッツリと赤い点を打っていた。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか夕闇があたりをこめ、たださえ暗い密室は文目もわかぬ闇となっていた。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に骸骨の着物に燃え移っていた焔も消えて、地下室は再び文目もわかぬ暗闇になった。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むさしや」といふ家のはなれを借りて根合せならねど、あやめの歌合といふを試みけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやめは、池のこのもかのもに咲き誇れり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て、梅津の君は、あやめも知らぬ戀人は、このわたりにはあらじかし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
