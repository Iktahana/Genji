[
  {
    "uuid": "91a8cb69-46c0-5f0c-99d9-f4d2fd604bb1",
    "entry": "甘い",
    "reading": {
      "primary": "あまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sweet-tasting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何故ならば、芸術の存在理由は芸術自身の裡にあること、恰も塩ッからいものが塩ッからく、砂糖が、甘いが如きものであり、恍惚は恍惚であれ、恍惚は直接｜他に伝達出来るものではなく、恍惚の内部がよく感取され、即ち他の恍惚内部との相関関係に於て僅かに暗示・表現することが出来るに過ぎないから。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は出際にお客さんがありはしたし……明日立つたら……」　母が「甘い」とよく彼が言ふので、また言はれはしまいかと思つて、遠慮深さうにさう言つた時、彼はさすがに「甘い」とはいはれなかつた、却つて自分の方が「甘い」だつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや、そんな大したことぢやあないから……」　カタクナなくせに甘い奴だ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の楕円形をした食えない部分があってその頭にこれと同じくらいの大きさで美しい紅色をした甘い団塊が附着している。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無責任に大げさな、甘い觀念論で、諸君を騙さうとして居るのでは無い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、この娘の「可哀想」は、このごろの彼女の一つ覺えで、何を見ても「可哀想」を連發し、以て子に甘い母の稱讚を得ようといふ下心が露骨に見え透いてゐるのであるから、格別おどろくには當らない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして狸は、ああ世の中なんて甘いもんだとほくそ笑む。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな井伏さんを見て、井伏さんを甘いなと、なめたら、悔いる事があるかも知れない。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、猫入らずまで混ぜてあったのだが、兎に角私は、滅茶苦茶に甘いものに飢えていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙や蝸牛などのグロテスクなものを薄気味悪い思いをしてまで食べなくとも、巴里には甘い料理がいくらもある。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘味についても、たとえば、茶のうちでは玉露に「甘い優美な趣味」があるとか、政よろしきを得れば天が甘露を降らすとか、または快く承諾することを甘諾といったりする時には、甘味は有価値的意味をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、「あまっちょ」「甘ったるい物の言い方」「甘い文学」などいう場合には、甘味によって明らかに反価値性が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "独断の「甘い」夢が破られて批判的知見に富んだ「いき」が目醒めることは、「いき」の内包的構造のところで述べた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "｛１｝『船頭部屋』に「ここも都の辰巳とて、喜撰は朝茶の梅干に、栄代団子の角とれて、酸いも甘いもかみわけた」という言葉があるように、「いき」すなわち粋の味は酸いのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒に甘い点をつける先生は甘く見え、辛い点をつけるほどえらい先生らしく見えるかというと、あながちそうでもないのであるが、学位の場合は少しちがうものと見える。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が大きくなって恋をする、といったような甘い通俗的な人情映画であるが、しかし映画的の取扱いがわりにさらさらとして見ていて気持のいい、何かしら美しい健全なものを観客の胸に吹き込むところがある。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泉」は多くこの種の映画と同じように甘いと辛いとの中間を行っている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして全体の感じはどうであるかというと自分はちょうど主和絃ばかりから出来た音楽でも聞くか、あるいは甘いものずくめの料理を食うような心持がするのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会の評というと、徹底的に賞めちぎるか、扱き下ろすかどっちかにしないと、体をなさないかもしれないが、これは批評でも何でもないのだから、こんな甘い、だらしのないものになっても致し方がない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南国の甘い夏を包んでいるような柑子が好い。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し感傷的な、あまい事なども書かれてありますから。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君は、女には、あまいからな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幼い時よくそれを口に入れては父母に叱られたものだが、その幼時のあまい記憶が大きくなつて落魄れた私に蘇つて來る故だらうか、全くあの味には幽かな爽かな何となく詩美と云つたやうな味覺が漂つてゐる。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀み返してみると、あまい所や、ひどく不手際な所などあつて、作者は赤面するばかりである。",
              "citation": {
                "source": "『女性』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幼い時よくそれを口に入れては父母に叱られたものだが、その幼時のあまい記憶が大きくなって落ち魄れた私に蘇えってくる故だろうか、まったくあの味には幽かな爽やかななんとなく詩美と言ったような味覚が漂って来る。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに長い夏もやがて末になって、葡萄の果も紫水晶のようになり、落ちて地にくさったのが、あまいかおりを風に送るようになりますと、村のむすめたちがたくさん出て来てかごにそれを摘み集めます。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十日「ドッドド、ドドウド、ドドウド、ドドウ、　ああまいざくろも吹き飛ばせ、　すっぱいざくろも吹き飛ばせ、　ドッドド、ドドウド、ドドウド、ドドウ　ドッドド、ドドウド、ドドウド、ドドウ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドッドドドドウドドドウドドドウ、あまいざくろも吹きとばせ、すっぱいざくろも吹きとばせ、ドッドドドドウドドドウドドドウ、ドッドドドドウドドドードドドウ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂東あべ川、市村しるこ、渠はあまい名を春狐と号して、福面女に、瓢箪男、般若の面、……二十五座の座附きで駈出しの狂言方であったから。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は二階の喫茶室のあまいジャズ音楽が流れている階段を登って行きながら、「四階か、偶数だよ、今日は奇数に縁のある日だが、はじめて偶数が出たわけだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
