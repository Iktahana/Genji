          ],
          "literary": [
            {
              "text": "もう、それが五年にもなるかと知り、自分をおもふと呆気にとられるのであるが、この雑誌の成長と、あのころ知合つた人達の上を思ふと、大した時日だつたと考へられるのだ。",
              "citation": {
                "source": "〔無題〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな意味のことを母親が洩してゐると聞くと、呆気にとられるだけだつた。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろきました伊之助、きょろ／＼と両人のお若さんを見まわし呆気にとられる。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、別段、ヘッヘッヘッ」と、孔明氏が呆気にとられる隙も洒々とぬかしたものだ！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無言、呆気にとられるヤス子を見つめ、そして、ヤス子の手を静かにとって、ゆっくりと甲に接吻した。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、突然呆気にとられる母の顔に苦い思ひをしながら、出発してしまつたのだ。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一段落つくのを待ち、そのとき迄は全然念頭にもなかつたことを急に思ひついて言ひ、婆さんの呆気にとられるのを尻目にサッサと帰つて来たのであつた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "居並ぶ大小名、呆気にとられる。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、突然呆気にとられる母の顔に苦い思いをしながら、出発してしまったのだ。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一段落つくのを待ち、そのとき迄は全然念頭にもなかったことを急に思いついて言い、婆さんの呆気にとられるのを尻目にサッサと帰って来たのであった。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れてはゐるし呆気にとられるわけでもないが、どうすることも出来ないので、伊豆は薄い唇を兎も角微笑めく顫ひに紛らして、ねちねちした愚痴を一々頷くよりほかに仕方もなかつた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気にとられる人々の眼前で、彼は全力をだしきってソノ子のお尻をヒッパタいて、ことぎれてしまった。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きなら諦らめてゐられるほど、女の心は単純だもの」　左門は呆気にとられるのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶巓や、混乱や、呻吟や、慟哭や、それらの健全な激しいものは、医しあたはぬ宿命のもとにあるべき筈のものでせうね」　野々宮の語気の冷めたさに、左門は呆気にとられるのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄室の石の一ツの大きさだけでも呆気にとられるね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "友だちは、これを見て呆気にとられると、金持ちはますます得意になって、「このとおりだ。",
              "citation": {
                "source": "金持ちと鶏",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授閣下をはじめ、われわれ一同が、（両手をひろげて）こう呆気にとられるぐらい、ずぶりと深みへはまってごらんなさい！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう因縁でこうまで心の深いひとにめぐりあったものかと、呆気にとられるばかりであった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤五郎のほうでは拍子ぬけがして呆気にとられる始末だった。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "永代経",
                "note": "青空文庫"
              }
            },
            {
              "text": "……はじめての経験なんで、うまく感じをいいあらわすことはできないが、とにかく、呆気にとられるくらい愉快だった。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな、見ちがえるように健康そうになり、互いの顔をながめては呆気にとられるのだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "来い」　呆気にとられる祐吉を後に飛出す平次。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れてはいるし呆気にとられるわけでもないが、どうすることも出来ないので、伊豆は薄い唇を兎も角微笑めく顫いに紛らして、ねちねちした愚痴を一々｜頷くよりほかに仕方もなかった。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士になぞなれるはずはないと見切りをつけていたのに、二ツ小説を書いただけで新進作家ということになってしまって、当人自身が呆気にとられる始末であった。",
              "citation": {
                "source": "世に出るまで",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜生ノ衛門　（あまりに烈しい語気に呆気にとられる）丘の上にはいつの間にやら、清原ノ秀臣が悄然として佇立している………その豊かにたれた直衣の裾は烈しくも風にはためいている。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨勢博士だって、頼みやしない」　今度は私が呆気にとられる番であった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験を唯一の生命とする医学の領域へ怪しげな心霊学の学説をひっぱり出してきたんだから、あっけにとられるのも無理はない。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寺男は、これには、あっけにとられるばかりでした。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう複雑なやりかたもあるものかと、そのつど、剛子はあっけにとられる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんどは秋作氏のほうがあっけにとられる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
