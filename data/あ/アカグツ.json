        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "騎兵聯隊や上肢の運動や、下級官吏の赤靴のことや、山沿ひの道を乗手もなく行く自転車のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の間に流行っているらしい太いズボン、変にべたっとした赤靴。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦稈帽を鷲掴みに持添へて、膝までの靴足袋に、革紐を堅くかゞつて、赤靴で、少々抜衣紋に背筋を膨らまして――別れとなればお互に、峠の岐路に悄乎と立つたのには――汽車から溢れて、風に吹かれて来た、木の葉のやうな旅人も、おのづから哀れを催し、挨拶を申すうちに、つい其誘はれて。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手をポケットに突込んだまま……紺の背広、鼠色のオーバー、黒の襟巻き……茶の中折れが飛んで……赤靴が片っ方脱けおちてて……顔半分を真赤に濡らして……それを凝視した儘、私は棒のように突立った。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと言ふのも、丁度雨あがりか何かであつたゝめで、二里の路に、旅に出る前に買つた赤靴も何も彼もめちや／＼にして了つた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "パトリツクと云へば、｜翼のある白馬に打ちまたがつて、地獄の魔王から「如意の剣」を奪ひとるクリステンデムの「赤靴下」だ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボヘミヤン・ネクタイ、合オーバ、（少し穢れた流行｜色の薄茶）それから羅紗の合帽子（少し穢れた流行色の薄茶）手には杖、足には赤靴、栄養不良らしい蒼黒い顔、唇と来たら鉛色である。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人で通りの人通を歩いてゐる、或る銀行の前の、老い朽ちた椎の木蔭の鉄柵のところで、赤靴を磨かせてゐるＴ―を見た。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "役員はフロックコウトに赤靴だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付に赤靴ばきの陪審員の正直な熱心さが感じられる　例えばこんな質問のうちに。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とそこに、袖丈の短い洋服からシャツのはみでた無骨な手に黒革の手提トランクを提げ、真新しい赤靴を穿いて突つ立つてゐる男は、別れた妻の三番目の弟の修一ではないか。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十二月×日）　赤靴のひもをといてその男が座敷へ上って来ると、妙に胃が悪くなりそうで、私は真正面から眉をひそめてしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月×日　赤靴のひもをといてその男が上って来ると、妙に胃が悪くなりそうで、私は真正面から眉をひそめてしまった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤靴を履き頭髪を分けをり年頃二十六、七歳位運転手風の好男子なり、男の黒つぽき外套のかくしと女のお召コートの袂には各々遺書一通あり、尚女のコートの袂には白鞘の短刀を蔵しあり。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも切り立ての脊廣に赤靴をはいて、ゲイトルもかけてゐなければ洋傘も持つてゐなかつた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日になると、敏子は、軽快な茶色ウールのスーツを着、キッドの赤靴をはいて、楽しげに出かけました。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩躯に薄茶の背広を着け、赤靴をはいた貴公子だ。",
              "citation": {
                "source": "美音会",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「店へ行って、一｜番上の棚に、赤靴が一｜足あるから、あれを持って来な。",
              "citation": {
                "source": "杜松の樹",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井が子供の赤靴を黒く染めたという事柄が、何だか彼にはおかしかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の規則を知らないで拵らえた赤靴を規則通りに黒くしたのだという説明を聞いた時、彼はまた叔父の窮策を滑稽的に批判したくなった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい赤靴なんか穿き込んで厭にお客さんぶってるもんだから誰かと思ったら。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤靴のような米国ヴォカリオンの『魔王』（〔Der Erlko:nig〕）は古レコード屋で二十円以上ということであるが、これは恐らく先のニキシュ伴奏の『ハイムウェー』に次ぐ名盤で、シューベルトの『魔王』をこれほど巧みに歌っているレコードを私は知らない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
