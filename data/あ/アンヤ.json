        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗夜について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗夜という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗夜の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗夜が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗夜を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗夜について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗夜の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗夜の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗夜が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗夜という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗夜という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗夜についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗夜を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗夜は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗夜について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗夜が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗夜は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗夜の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗夜は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗夜は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "道幅二間ばかりの寂しい町で、（産婆）と書いた軒燈が二階造の家の前に点ている計りで、暗夜なら真闇黒な筋である。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、その当時の記録に、「第×××聯隊が、逐次暗夜を辿りつゝ城門に近づかんとするや、俄かにその北側にあるＴ病院内より支那兵の猛射を受け、危険極まりなきに到ったが、該建物が病院たるの性質にかんがみ、一時、その措置に窮した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一｜貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……顔馴染の濃い紅、薄紫、雪の膚の姉様たちが、この暗夜を、すっと門を出る、……と偶と寂しくなった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、祖母に導かれて、振袖が、詰袖が、褄を取ったの、裳を引いたの、鼈甲の櫛の照々する、銀の簪の揺々するのが、真白な脛も露わに、友染の花の幻めいて、雨具もなしに、びしゃびしゃと、跣足で田舎の、山近な町の暗夜を辿る風情が、雨戸の破目を朦朧として透いて見えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お柳は暗夜の中に悄然と立って、池に臨んで、その肩を並べたのである。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "た※｜渺々として果もない暗夜の裡に、雨水の薄白いのが、鰻の腹のやうに畝つて、淀んだ静な波が、どろ／＼と来て線路を浸して居さうにさへ思はれる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光は暗夜に怪獣の眼のごとし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど他には一人も客がなくて無月の暗夜はこの上もなく閑寂であった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ近来少数ではあるがまじめで立派な連句に関する研究的の著書が現われるのは暗夜に一抹の曙光を見るような気がして喜ばしい。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　立花は思わず、膝をついて、天井を仰いだが、板か、壁か明かならず、低いか、高いか、定でないが、何となく暗夜の天まで、布｜一重隔つるものがないように思われたので、やや急心になって引寄せて、袖を見ると、着たままで隠れている、外套の色が仄に鼠。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児も憚るか楽書の痕も無く、朦朧として暗夜にも白い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これで出来なきゃ、日本は暗夜だわ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それじゃ暗夜の礫だわ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の枝の所々、濁つた月影のやうな可厭な色の靄が搦んで、星もない……山深く谷川の流に望んだ思ひの、暗夜の四谷の谷の底、時刻は丁ど一｜時頃。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前樣、此の暗夜に、われらの形、崖の樣子、消えた瓦斯燈の見えますのも、皆其の一つの影なので。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心も暗夜の手を取合つて、爾時はじめて、影を捉る魔ものの話は、坂の途中で、一人の盲人に聞かされた事を申して、其の脊恰好、年ごろを言ひますと、婦は、はツと、はじめて目の覺めたやうに成つて、さめ／″＼と泣出しました。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途すがら、遠州｜灘は、荒海も、颶風も、大雨も、真の暗夜の大暴風雨。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お柳は暗夜の中に悄然と立つて、池に臨むで、其の肩を並べたのである。",
              "citation": {
                "source": "三尺角拾遺",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時は濡れたやうな眞黒な暗夜だつたから、其の灯で松の葉もすら／＼と透通るやうに青く見えたが、今は、恰も曇つた一面の銀泥に描いた墨繪のやうだと、熟と見ながら、敷石を蹈んだが、カラリ／＼と日和下駄の音の冴えるのが耳に入つて、フと立留つた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長尾原で夕食をなし、これから草津まで暗夜の強行軍。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木は何事の変化もなく、もとより痛苦や、不安の姿もなく、記憶し初めた三十年前からの壮大なる木振の儘、今は暗夜の空につつたつて居る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しや暗夜なら松明を、点して威勢は好からんなど、語り合いつつ畦伝い、血の痕を踏んで行く程に、雪の下に近づきぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、その貝の口を細く開いた奥に、白銀の朧なる、たとえば真珠の光があって、その影が、幽に暗夜に、ものの形を映出す。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人目を忍んで、暗夜を宮歳と二人で来た、巽は船のへりに立つと、突然跳起きて大手を拡げて、且つ船から転がり出した六蔵のために驚かされた。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十畳と八畳に、廻縁を取廻して、大い巳の字形に、襖を払った、会場の広間は、蓮の田に葉を重ねたように一面で、暗夜に葉うらの白くほのめくのは浴衣である。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "引手も馬方もない畜生が、あの大地震にも縮まない、長い面して、のそり／＼と、大八車のしたゝかな奴を、たそがれの塀の片暗夜に、人もなげに曳いて伸して來る。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「――わかたなは、あんやたい――」若旦那は、ありがたいか、暖かな、あの屋台か、五音が乱れ、もう、よいよい染みて呂律が廻らぬ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文子はおやとなつかしそうに、十吉つあんやおまへんか、久しぶりだしたなアと、さすがに笠屋町の上級生の顔を覚えていてくれました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
