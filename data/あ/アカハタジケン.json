        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」之は赤旗事件の時に桃木に宛てた端書である。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪では雜誌「基督教世界」にも關係して居たが、その東京へ來て前の電報新聞の婦人記者となるや暫時の間は眞面目に働いて居た、幸徳秋水と相知り相許すに至つてから、愈其名を記される樣になつたのは、實に此の赤旗事件以後の事である。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の一つは往年の赤旗事件である。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで再び赤旗事件当日のことに立ちもどる。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この赤旗事件の時、幸徳君は郷里（土佐中村）に帰っていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西園寺内閣の倒れた原因の一つは、社会主義を寛容し過ぎて、ついに赤旗事件まで起こさせたという非難であったという。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一方には赤旗事件で金曜会の連中が一掃され、一方にはまた、電車問題の凶徒｜聚衆事件が確定して、西川、山口等、多くの同志が投獄され、その他の人々は手も足も出しようがなく、運動は全く頓挫の姿を呈した。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉が初めて来たのは赤旗事件の監房生活から出獄して間もなくだった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その組織後間もなく、例の赤旗事件のために、僕等日本の同志の大部分が投獄され、そしてそれと同時に和親会の諸同志の上にも厳重な監視が加えられて、会員のほとんど全部は日本に止まることができなくなってしまった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして当時のありがたい旧刑法のお蔭で、新聞紙条令違犯の二件を除く他の三件は併合罪として重きによって処断するということで、電車事件の二カ年もまたすでに勤めあげた屋上演説事件の一月半もすべて赤旗事件の二カ年半の中に通算されてしまった。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後赤旗事件でまた未決監にはいった時、ある日そとの運動場で散歩していると、男三郎が二階の窓から顔を出して、半紙に何か書いたものを見せている、それには、「ケンコウヲイノル。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉の巻　うんと鰯が食えるぜ　が、また半年も経つか経たぬ間に、こんどは例の赤旗事件で官吏抗拒治安警察法違犯という念入りの罪名で、その事件の現場から東京監獄へ送られた。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤旗事件」で、堺君等が千葉の監獄へ送られたと聞くや、土佐に静養して居た幸徳は上京した。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤旗事件のことども　明治四十一年五月十九日、わたしは刑期が滿ちて巣鴨監獄の鐵門を出ました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことほど左樣にこの『赤旗事件』は不可解な大騷動になりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦輝館前の赤旗事件はそれから數日後のことであり、神田署は五十名餘りの警官を豫め伏せておいたのです。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再度の入獄　赤旗事件が勃發してから間もなく幸徳は上京したと思ひます。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそれから間もなく、千葉監獄に護送され、そこで赤旗事件で先入してゐた堺、大杉、荒畑、山川や、別口の西川などと久しぶりで對面し、入浴と體操でいつも一しよになりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに狭量神経質の政府は、ひどく気にさえ出して、ことに社会主義者が日露戦争に非戦論を唱うるとにわかに圧迫を強くし、足尾騒動から赤旗事件となって、官権と社会主義者はとうとう犬猿の間となってしまった。",
              "citation": {
                "source": "謀叛論（草稿）",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉栄の場合は、「赤旗事件」で千葉監獄にはいっていて、大逆事件のときはシャバを留守にしていたのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤旗事件の前ですね」と砂馬は言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが「赤旗事件」で、その前に、同じ年の一月に「屋上演説事件」というのがあった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
