        "examples": {
          "standard": [
            {
              "text": "毎日、アッパーについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社のアッパー戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "アッパーの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "アッパーという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアッパーについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "アッパーの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "アッパーに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちはアッパーを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界でのアッパーは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、アッパーは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "アッパーは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々なアッパーを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「アッパー」という概念について深く考察する必要があります。",
              "source": "幻辞"
