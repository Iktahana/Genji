          ],
          "literary": [
            {
              "text": "オホホホホ」　私は頭の痛いのを忘れてガバとはね起きた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の頭の痛いのが治ったよ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう夜なか、さては頭の痛い昼間、種々雑多な疑問が苦しく心にせめかけた。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１用のソフトウエアを何に収めて供給すべきかという点も、サードパーティーには頭の痛い要素だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本線の媒体がはっきりしていない点は、ＰＣ―９８０１用のソフトウエアを開発する側にとって頭の痛い問題だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪をひきそうに頭の痛い気持ちだった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それからその日と、その晩の一夜は何も喰べずに眠ったり醒めたりして、あくる朝の御飯も頭が痛むのでそのままにしていましたが、あんまりお腹が空いて来ましたので、お昼のを頂きますと大変にお美味くて頭の痛いのがすっかり癒りました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更に正木博士の弁力に身ぶるいさせられつつ、今一度、頭の痛い処に手を遣った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の痛い原因には私もはいってゐることと恐縮してゐます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の痛いのもなほつた。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩三　　銀が頭の痛いのはお前の知つたことぢやない。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幾は、年頃の時代から、頭の痛いことさえ知らなかった。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、頭の痛い女の人は、それを拒絶した。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も描き進むうちに頭の痛いことは忘れてしまっていた。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿を書くために二時間も机に坐っていると頭が痛くなってくるが、頭の痛い時でさえイーゼルに向って絵具をいじっていると三時間ぐらいは夢中に過ぎてしまう。",
              "citation": {
                "source": "ゴッホについて",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子が熱を出して薬をのまされ、あれこれと欲しいものを食べさされているのを見て頭の痛い子が三人も四人も出てきて、自分も晩飯はほしくないという。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用繁多でお疲れになったのですね」「そうだろうね、頭の痛いことなどは殆んど覚えないので、はじめはちょっと驚いたよ」　助左衛門はこう云って苦笑したが、そのとき持っていた箸が手から落ちた。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
