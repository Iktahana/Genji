        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アポフィーゼについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアポフィーゼの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアポフィーゼが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアポフィーゼについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアポフィーゼの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアポフィーゼが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアポフィーゼという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアポフィーゼについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアポフィーゼは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアポフィーゼが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアポフィーゼは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアポフィーゼの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アポフィーゼは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアポフィーゼは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
