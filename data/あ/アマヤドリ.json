    "definitions": [
      {
        "index": 1,
        "gloss": "taking shelter from rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨宿りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨宿りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨宿りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨宿りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨宿りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨宿りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨宿りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨宿りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨宿りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨宿りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨宿りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨宿りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨宿りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨宿りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "林の中は、雨宿りの鳥獸で大混雜である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雨宿りに駈込んだ知合の男が一人と、内中、此の店に居すくまつた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出でて快げに新開地を歩み行けば、松の木蔭に雨宿りして、唯濡れに濡れたる一個の貧翁あり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡樣の裏の渡し場へ出ようと思つて、見當を取違へて、あちらこちら拔け裏を通るうちに、ざんざ降りに降つて來た、ところがね、格子さきへ立つて、雨宿りをして、出窓から、紫ぎれのてんじんに聲をかけられようといふ柄ぢやあなし……」「勿論。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はははは、お言葉には及びません、饂飩屋さんで泊めるものは、醤油の雨宿りか、鰹節の行者だろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の出盛る頃に運悪い夕立が来て、売物の扇子を濡らしてはと慌てゝしまいこみ、大風呂敷を背負ったまゝあるしもたやの軒先に雨宿りした、が、何の因果かそこは妹のまつ枝が女中奉公している家だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中は、雨宿りの鳥獣で大混雑である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、花屋さんの軒下に、肩をすくめて小さくなって雨宿りしています。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍が剣術の道具を肩にかついで道場から帰る途中、夕立になって、或る家の軒先に雨宿りするのですが、その家には十六、七の娘さんがいてね、その若侍に傘をお貸ししようかどうしようかと玄関の内で傘を抱いたままうろうろしているのですね。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と素直に、私と並んで豆腐屋の軒下に雨宿りして、「津軽でしょう？",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草ももう吸い飽きて、拱いてもだらしなく、ぐったりと解ける腕組みを仕直し仕直し、がっくりと仰向いて、唇をペろぺろと舌で嘗める親仁も、蹲んだり立ったりして、色気のない大欠伸を、ああとする茜の新姐も、まんざら雨宿りばかりとは見えなかった。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、傘なくしてまちの家の軒下に雨宿りしている冠氏の姿を認めた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から内を出て、随分｜遠路を掛けた男は、不思議に遥々と旅をして、広野の堂に、一人雨宿りをしたような気がして、里懐かしさ、人恋しさに堪えやらぬ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……巫山戯た爺が、驚かしやがって、頭をコンとお見舞申そうと思ったりゃ、もう、すっこ抜けて、坂の中途の樫の木の下に雨宿りと澄ましてけつかる。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雨宿りをさせてもらいましょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が揃って、蚊帳の中を廊下際で、並んで雨宿りをする姿で立った処へ、今度は静に悠々と取って返す。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雨宿りに駈込んだ知合の男が一人と、内中、この店に居すくまった。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――折からのざんざ降で、一人旅の山道に、雨宿りをする蔭もない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはうまい、と言いますと、電車を待って雨宿りをしていたのが、傘をざらりと開けて、あの四辻を饅頭屋へ突切ったんです。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「傘では凌げません、雨宿りに、この中へ消えましょう。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は柳橋へ半七を迎えに出たのであるが、途中で夕立にふり籠められて、そこらの軒下に雨宿りをして、小降りになるのを待ってお照の家へゆくと、どこで行き違ったか半七はもう出てしまった後であったので、また引っ返して自身番へくると、この始末である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春、案内の男のみは知りて、縁もゆかりもなき山林の吏に、雨宿りの好意あふれて、導者の家に宿るといふまゝに、預けて置いてくれよとて、洋傘を貸したるが、今もあるかとの事也。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの桜の下に弁天さまが二十四体雨宿りしているようだが、おまえさんがご信心の腰元弁天はどの見当だ」「それが、じつはおかしいんでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "急激に自分たちの世界を打ち壊されて了って、よその国のよその軒先に、雨宿りしているようなこの六七年の生活が、それほども平七の心から、肉体から、弾力を奪いとって了ったのである。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤崎さんはある寺の門の下に這入って、雨宿りでもしているようにたゝずんでいると、時々に提灯をつけた人が通ります。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから雨宿りなぞというものは色々の縁をひくものですよ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鬘賣六助はかづらを掛けたる棒を持ち、いづれも欅の木の下に雨宿りをしてゐる。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孃樣は梅若の茶店で、雨宿りをしておいでなされます。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はだんだんに強くなって来たので、彼は雨宿りをするようなふうをして、隣り屋敷の門前に立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　べつの　ひには　まんまるした　おおぐもが　あまやどりに　きておりまして。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
