        "examples": {
          "standard": [
            {
              "text": "私は毎日荒くれ者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒くれ者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒くれ者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒くれ者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒くれ者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒くれ者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒くれ者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒くれ者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒くれ者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒くれ者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒くれ者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒くれ者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒くれ者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、荒くれ者の船長が彼の哀れな腕を嗤っただけあって、船の仕事は辛かった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宇陀には、兄宇迦斯、弟宇迦斯というきょうだいの荒くれ者がおりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命は建がそう言いおわるといっしょに、その荒くれ者を、まるで熟したまくわうりを切るように、ずぶずぶと切りほうっておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てっきり、私を襲った荒くれ者の一団が、帽子と鳥を持ち去ったのだと思っておりました。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして君のもとへたどり着いたわけだが、その途上、棍棒を手にした荒くれ者に襲われた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる荒くれ者でも神に対してする神妙な態度を見れば、いぶせき宿もまた頼もしいような感がした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこれと文句をいっているところへ、興福寺では、荒くれ者で聞える坊主が二人、鎧に長刀、大刀をかいこんであっという間もなく延暦寺の額をたたき割って、「うれしや水、鳴るは滝の水、日は照るとも絶えず」と陽気にうたいながら、南都の坊主の中に引き揚げていった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のさらなる話では、館にはたいてい週末に客があるらしく――『あらくれものたちですぜ』――とりわけ赤髭の紳士、つまりウッドリがいつもいるらしい。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            }
          ]
        }
