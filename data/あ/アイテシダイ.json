[
  {
    "uuid": "f6658ac4-13ff-5bc0-826d-2324d6e18317",
    "entry": "相手次第",
    "reading": {
      "primary": "あいてしだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
