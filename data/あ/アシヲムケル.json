[
  {
    "uuid": "faa96955-c590-5c35-87d7-2b9991becdac",
    "entry": "足を向ける",
    "reading": {
      "primary": "あしをむける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
