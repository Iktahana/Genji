        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "案内人なしにいい加減な道を歩いていると道に迷うてとんでもない災難に会わなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人として権威の価値は明らかであるが、同時に案内人の弊害もある事は割合に考える人が少ない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの案内人の流儀をあまり徹底させては、本当に科学を学修しようというもののためには非常な迷惑である事は申すまでもない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヶ国語を話してトーマス・クックの案内人を勤める伊太利男爵もあれば刺繍とピアノを教へる嫁入学校を拵へて一儲けする波蘭伯爵もある。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の案内人が甚だ怪しい物騒千万なもので、此方から差出す手を向うから引捉んで竜宮の一町目あたりへ引込もうとするか何様かは知れたもので無いのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「案内人が迎えに来ないうちに、逃げようじゃないか」と小八は女の手をぐっと握った。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼のうちはせい／″＼山中を見物しときなさい、話は夜でも出来ますから――という先生の指図に任せ、私たちは宿の主を案内人に連れて、弁当持参で所々を見物して歩きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼に身を投げた竜女を弔うため、麓の村では毎年、命日に赤飯を蒸してこの沼に投げ込んでやるのですが、赤飯は失せて、容器の殻だけが渚に漂い寄る、それがこれですという案内人の説明でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺商主祀天喩一隊商が曠野で颶風に遇った時、野神に供うる人身御供として案内人を殺した。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人を失った隊商等の運命は如何。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ所々に雪の残っている川岸を進むこと数日、ようやく北海の碧い水が森と野との向こうに見え出したころ、この地方の住民なる丁霊族の案内人は李陵の一行を一軒の哀れな丸太｜小舎へと導いた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人達はしばらくその両方を見比べていたが、やがて、そのくねくね曲った方の一方に攀じのぼると、背中に負って来た棒や板や蓆などを、その枝と枝との間に打付けて、忽ち其処に即製の桟敷をこしらえ上げて了った。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はその仲買人を誰だかわからないかのように見つめていて、私は案内人の顔に表れた驚愕から、これはけしてその雇い主の平生の表情ではないと知った。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と怒りに顔を赤くする案内人とともに、我々は玄関の石段へ降りてくる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案内人は驚き戸惑い、声を張り上げる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、フェリアも自分を取り戻し、すぐれた案内人および精力的な狩人として頭角を現した。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人が、落石はこのあたり春の時期にはよくあることだと言うも、聞く耳持たなかった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえとうとう、私がマイリンゲンに戻っているあいだは、言伝を持ってきた若いスイス人が同行する案内人として残ることに決まった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして案内人を雇ふこと、明日の夜泊る丸沼の番人への土産でもあり自分の飮み代でもある酒を買つて來て貰ふことを昨夜更けてから宿の主人に頼んだのであつたが、今朝未明に起きて湯に行くと既にその案内人が其處に浸つてゐた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人夫小屋の側を通らうとして不圖立ち停つた案内人が、「ハハア、これだナ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　事ごとに眼を見張る私を笑ひながら、初め不氣味な男だと思つた案内人は行く／＼種々の樹木の名を倦みもせずに教へて呉れた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と案内人はそれらの森の木を數へた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案内人もつゞいた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案内人が側で呟いた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度十疋になつたを折に舟をつけて家の方に歸らうとすると一疋の魚を提げて案内人も歸つて來た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人に訊ねると、これが菅沼、丸沼、大尻沼の源となる水だといふ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして案内人を雇うこと、明日の夜泊る丸沼の番人への土産でもあり自分の飲み代でもある酒を買って来て貰うことを昨夜更けてから宿の主人に頼んだのであったが、今朝未明に起きて湯に行くと既にその案内人が其処に浸っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
