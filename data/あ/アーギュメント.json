        "examples": {
          "standard": [
            {
              "text": "私は毎日アーギュメントについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーギュメントの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーギュメントが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーギュメントについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーギュメントの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーギュメントが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーギュメントという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーギュメントについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーギュメントは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーギュメントが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーギュメントは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーギュメントの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーギュメントは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーギュメントは興味深い例である。",
              "source": "幻辞"
            }
          ],
