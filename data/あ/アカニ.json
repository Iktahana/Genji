        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "木戸にまた高く札うち、蓮葉なる金切ごゑと老いたるが絶えず客よぶ、――と見る、ただ赤丹剥げたる閻魔王、青き牛頭馬頭、講釈のなかばいちどにがくがくと下顎鳴らす。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜けき夕の心やりか、※乃一ふし歌ひさして、ほのかに笑まひぬ、水馴棹にくだくる小波をあとに見つつ人皆煩らふ空のもとに、自然の愛子か、君はひとり赤丹穗に見る顏の色に、心の平和うかがわれぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅の花というと、花合せの赤丹を思い出すような人間に、風流気なんかあるわけはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅の花といふと、花合せの赤丹を思ひ出すやうな人間に、風流氣なんかあるわけはありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赭土（あかに）のほに」など言ふ文句も、赭土の示す「ほ」と言ふ事で、神意の象徴をさす語である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど孤児はボロをまとい、あかにまみれ、哀れな格好をしているから、憐れみ、さげすみ、下に見るにふさわしいようであるけれども、この哀れな格好になったのは、大人の路上生活者と違って、自己の過失によって招いたのではない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも新聞を読んだろうが、絲満って男は、古今未曽有のあかにしだったんですぜ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかにしであればあるほど、反動も大きければ爆発も異常だ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしあ、……あかにしだが、これで、いちめん純情なところもある男さ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、天眼通だ」「何んだえ騷々しい」「あかに漬つて、櫛が一つ――こいつは鼈甲ですよ」　八五郎は飴色の大振りな櫛を一つ、水あかをきつて陽にすかしてゐるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこと警察に聞かれたら、大石先生だってあかにせられるよ」「あら、へんなの。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "の質問に答えて、一日でげっそり頬のおちた彼は、青いひげあとをなでながら、「いや、どうもこうも、いま考えるとあほらしいんじゃけどな、すんでのことにあかにならされるとこじゃった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時のアルバトロス号の航海日誌は今キミの所有物だが、わしが次のくだりを発見した」　船長が取り上げた羊皮表紙の日誌には符号やら科学記号が書かれており、手あかにまみれたページを開いて、読んだのが次である。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の毛はしゅろぼうきのようにのび、顔はあかによごれ、カーキ色の服はボロボロにやぶれた子供たちです。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロボロにやぶれた服を着て、あかによごれた浮浪少年でした。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟は、荷足舟ぐらいな、脚の浅い舟であったが、もう壊れかけていて、水あかに浸されているとみえ、危ないほど傾いでいる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
