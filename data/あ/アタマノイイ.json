            }
          ],
          "literary": [
            {
              "text": "しかし実に頭のいい先生だと思って敬服していた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん仰向けに寝ていて描いたのだと思うがなかなか威勢のいい地図で、また頭のいい地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はすべての歌人に望むように宇都野さんの場合にも、どうかあまりに頭のいい自己批評から作歌の上に拘束を加えて、鮮明な自然の顔の輪郭が多少でも崩されるような事のないように祈りたいと思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからこそ恐ろしく頭の悪い博士もあれば、図抜けて頭のいいよく出来るただの学士も捜せばいくらでも居るであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、西鶴のような頭のいい観察者が、真の武士道の中の美点をも認めることが出来なかったとは想像されない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世の頭のいい史家でヨーヨーとマルクスの関係を論ずるものが出ないとも限らない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい、要領のいい点は、そういうところもあるだろうが、そうばかりとも思われない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人は頭のいい人種である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの祖先にも、少なくも芸術の上では、恐ろしく頭のいい独創的天才がいた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演芸風聞録の頭のいい記者はたぶんこの意味で書いたに相違ないのであるが、これにこれだけの注釈をつけることも出来るのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいいひとは、たいてい、こんな表情をしてゐるものです。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる頭のいい人は、言わば足の早い旅人のようなものである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は、言わば富士のすそ野まで来て、そこから頂上をながめただけで、それで富士の全体をのみ込んで東京へ引き返すという心配がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は見通しがきくだけに、あらゆる道筋の前途の難関が見渡される。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、研学の徒はあまり頭のいい先生にうっかり助言を請うてはいけない。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の悪い人は、頭のいい人が考えて、はじめからだめにきまっているような試みを、一生懸命につづけている。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人には恋ができない。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は批評家に適するが行為の人にはなりにくい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人には他人の仕事のあらが目につきやすい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人で人の仕事のあらはわかるが自分の仕事のあらは見えないという程度の人がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい学者はまた、何か思いついた仕事があった場合にでも、その仕事が結果の価値という点から見るとせっかく骨を折っても結局たいした重要なものになりそうもないという見込みをつけて着手しないで終わる場合が多い。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合にも頭のいい人は人間の頭の力を買いかぶって天然の無際限な奥行きを忘却するのである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にもう一つ、頭のいい、ことに年少気鋭の科学者が科学者としては立派な科学者でも、時として陥る一つの錯覚がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老科学者の世迷い言を読んで不快に感ずる人はきっとうらやむべきすぐれた頭のいい学者であろう。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のほうは頭のいいようなのが映画を志す、男の頭のいいのは他の方面にいくらも道があってみんなそのほうへ行ってしまう、といったようなこともいくらかあるのではないかという気がする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし男のほうにも自分の知っているだけでも四五人くらいは相当頭のいいのがいるようであるが、平均の上で多少そうした傾向がありはしないか。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "変に頭のいいやつは。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と西洋の頭のいい奴が言ったそうである。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪は頭のいい事にあった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ、あたまのいい君にも似合わないぜ」「一体どうしたというんです。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
