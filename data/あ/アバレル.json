        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暴れるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この暴れるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "暴れるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が暴れるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "暴れるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は暴れるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "暴れるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では暴れるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から暴れるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "暴れるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも暴れるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では暴れるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "暴れるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも暴れるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも暴れるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で暴れるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に暴れるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "暴れるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する暴れるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では暴れるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "衣服はびしょぬれになる、これは大変だと思う矢先に、グイグイと強く糸を引く、上げると尺にも近い山※の紫と紅の条のあるのが釣れるのでございます、暴れるやつをグイと握って籠に押し込む時は、水に住む魚までがこの雨に濡れて他の時よりも一倍鮮やかで新しいように思われました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に行ってひとつ俺は暴れ放題に暴れるだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐がつく、蔦が搦む、蜘蛛の巣が軒にかかる、旦那は暴れる、お若は遁げる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おとなりのマメリューク・スルタンの国でパルチザン共がストライキを起こして暴れるので鎮めに行ったのさ」「よけいなことじゃなくって？",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アデノイドがある子は暴れるということを聞いたので、入院して切ることになったのさ」　ここでかの女はまず、くっくと笑った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この娘がそういうものになって暴れるときの壮観をちょっと想像したが、それも一瞬ひらめいて消えた火のような痛快味にしか過ぎないことを想い、さしずめ、「まあそんなに思い詰めないでも、辛抱しているうちには、何とか道は拓けて来ますよ」と云わないではいられなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうかして、座敷へ飛込んで戸惑いするのを掴えると、掌で暴れるから、このくらい、しみじみと雀の顔を見た事はない。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "年老いたる二三の漁夫は心配さうに小走りに走つて往つて、この暴れる神體を宥めようとした。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒ぐ事、暴れる事、桟敷へ狼を飼ったようです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「牛も半死半生、もう暴れる元気もなく、おとなしく引摺られて行った。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査や兵隊までが仮装と間違えられる位、大あばれに暴れるんだぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "可厭だい、おりよう、と暴れるのを揉んで廻ると、やがてお家の前へ来たというのが、ちょうど廂、ですわ。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「体はもうすっかり良いのかい、」「ええ、」「お前は駄々ッ子で、鼻ッ端が強くって、威勢よく暴れるけれど、その実大の弱虫なんだから心配だよ、この頃は内で姐さんと喧嘩はしないか。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう日には、己は今夜は暴れるから、君はおとなしくして寝ろと云い置いて、廊下を踏み鳴らして出て行く。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古賀の獣は縛ってあるが、おりおり縛を解いて暴れるのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の上はただ狂い暴れる風と雪と波ばかりだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬣を風になびかして暴れる野馬のように、波頭は波の穂になり、波の穂は飛沫になり、飛沫はしぶきになり、しぶきは霧になり、霧はまたまっ白い波になって、息もつかせずあとからあとからと山すそに襲いかかって行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘立小屋の中で風雪の暴れるのを聞くやうな生活、それで十分だ。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れるなら幾らでも暴れて見るがよい！",
              "citation": {
                "source": "美智子と歯痛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れるようだったら、何時かの部屋へ監禁してしまえ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いつもは鼠が居間で暴れることはないはずだのにと考えていると、若杉さんはようやく、鼠が暴れる原因がわかりました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども父親の飮めばきつと暴れるといふ惡い癖に子供の時からこりごりさせられ、又その爲に貧困のどん底を泳がせられた彼は、酒の惡癖を心から恐れいとはしいものに思ひ込んだがために、幸にも自分は決して酒に呑まれるやうなことはなかつた。",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝ、外にはますます吹雪の暴れる事よ。",
              "citation": {
                "source": "日の光を浴びて",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「レデイがパパの膝で暴れるなんて、甘過ぎるぜ。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの小学校では体操を教えなかったから、生徒の運動といえば唯むやみに暴れるだけであった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつきまして、これから帯刀様御邸へお迎えに出るところでござりました」「そんなに暴れるのか」「伺いますと、正に破天荒。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、みんながみんな悪い人間じゃあない、維新の際に命をすてて働いたのもあるのですが、何分にもごろつきのような奴がまじっていて、これが歩兵を笠に着て乱暴を働く、三人か五人固まって歩いて、芝居｜町で暴れる、よし原で喧嘩をする、往来で女にからかったりする。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう大勢が駈け集まって暴れる奴を押さえ付けて縄をかけてしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れるやうだつたら、何時かの部屋へ監禁してしまへ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれる子熊の横顔へ防寒｜長靴をはいた人間の足がいくつも飛んで来る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
