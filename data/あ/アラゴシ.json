        "examples": {
          "standard": [
            {
              "text": "私は毎日粗漉しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗漉しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗漉しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗漉しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗漉しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗漉しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗漉しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗漉しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗漉しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗漉しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗漉しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗漉しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗漉しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗漉しは興味深い例である。",
              "source": "幻辞"
            }
