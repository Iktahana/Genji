          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そんな人生に消極的な気持ちのあなたが僕のような煮え切らない青年に、英雄的な勇気を煽り立てるなんてあなたにそんな資格はありませんね」　復一は何にとも知れない怒りを覚えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、事件の開始早々にもかかわらず、もう、愚にもつかない実際家出の探偵小説家を掴まえてきて、それにくだくだしい推理談的な感想を述べさせているところなどを見ると、降矢木一族の底知れない神秘と関聯させて、この事件をジャーナリスチックにも、煽り立てる心算のように思われた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それゆえ若かさを惜しめと申すのじゃ」　と、片里は少人の心持が、自分の思う方へと傾いてゆくのに益々よろこばされて、煽り立てるように言うのでした。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "文久元年の六月を迎えるころで、さかんな排外熱は全国の人の心を煽り立てるばかりであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみと攘夷なんてことを煽り立てるものがあるから、こんな目にあう。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "お清を前にして酔っ払ってゆくことは、捨鉢な好奇な気持を煽り立てる力となったが、お清が室から出ていった後は、どうにも出来ない淋しさに囚えられた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大塚先生の講義はその熱烈な好学心をひしひしと我々の胸に感じさせ、我々の学問への熱情を知らず知らずに煽り立てるようなものであったが、それに対して岡倉先生の講義は、同じく熱烈ではあるがしかし好学心ではなくして芸術への愛を我々に吹き込むようなものであった。",
              "citation": {
                "source": "岡倉先生の思い出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつと俯向きながら自分の美しい處女期がもう粉微塵になるのを期待するやうな、慘たらしい氣持を考へると、私はあたりから理由もない怒りが私を煽り立てるやうな氣がした。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の好奇心を鎭める代りに煽り立てるやうな何かゞ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりああして大金を放り出して、乾ききっている吾々の前へ出しておくのは、吾々のよわみを知って、とても手出しができまいとたかを括っての仕事だ、金銭は欲しいとはいわないが、その仕向け方が癪じゃありませんか……というようなことを煽り立てる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何とかして彼に死の恐怖を忘れさせ、「木村トイウ刺戟剤」を利用して嫉妬を煽り立てることに懸命になっていた。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう支那浪人がいるために、排日抗日をどのくらい煽り立てることになったか分らない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "またアテナイ人は、これが彼らの都において甚だ重んぜられたためにいかに世を毒したかを覚り、人の感情を煽り立てるその重要な部分を、序説および結語とともに削除させた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえってこれを助長し、邪説を煽り立てる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし王倫と林冲の二人の舌火が、あやふやな妥協にでも終りかけたら、この呉用が横ヤリを入れ、三寸｜不爛の舌さきで、二人の舌戦を煽り立てる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはジャネットの肉体的にも遊び廻るほど愈々冴えて来る若さを一層強く示嗾して新吉をあおりたてることに努める必要があると思った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　泣き伏す事は、一層彼の人の胸をあおりたてるようだったけれど、私は自分がみじめに思えて仕方がなかった、別れた男との幾月かを送った此部屋の中に、色々な幻が泳いでいて私をたまらなくした。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ床だけは、迷彩をほどこした鋼材の動く滑走路がまん中をつらぬいているので、異様な気分をあおりたてる。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを抑え固めて自分の欲するところに従わせようと努めれば努めるほど、ますますこの高貴な金属＊のわがままをあおりたてるばかりである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
