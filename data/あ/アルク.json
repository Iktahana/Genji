        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩くについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩くという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩くの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩くが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩くを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩くについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩くの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩くの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩くが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩くという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩くという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩くについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩くを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩くは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩くについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩くが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩くは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩くの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩くは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩くは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その廊下を歩く限りの人が、その条の右か左かを通るんだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、長いことはない、四五年の寿命だが、高等学校の文芸部の我鬼大将であつたこと以外に如何なる文学的経歴をも有しない男が、雑文家だの、批評家だの、評論家だのといふ肩書の下に、世間といふ舞台をのし歩くのである。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな暑いのに外を歩くのはつらいものです。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラソルをさして歩くと、少したすかるかも知れませんが、男がパラソルをさして歩いている姿は、あまり見かけませんね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下を歩くのに足の裏が冷たからうといふ思ひやりの樣であつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場はそれから近くだつたのだが、とても直ぐ電車になぞ乗る気にはなれなかつたので、ともかく私は次の駅まで、開墾されたばかりの、野の中の道を歩くことにした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が低く、セカセカと腰から下だけで歩く、時折首が怖ぢ気のついたやうに揺れる。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書は夜中、朝寝て正午頃起きて、それより夜の十二時頃迄歩くなり。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は左様ならともいはずに下宿の方に歩んだ、十間も歩くと襲はれるやうに走り出した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は町を歩く毎に、いつもこの町の音楽の前に聴き惚れて居る。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に野外や近郊を歩くときでも、彼はなお目前の自然の中に、転寝の夢に見る夢を感じて古寺やほうろく捨る芹の中　と、冬日だまりに散らばう廃跡の侘しさを咏むのであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利のナポリ辺へ行くと、市街の家並が不均斉で、登つたり降りたり、中庭を突つ切つたり、路地から路地へ曲つたりする迷路のやうな市街が多いといふことを聞いてゐるせいか、伊香保の町の裏通りを歩くと、何となく南欧の田舎町といふ感じがする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただむやみに歩くだけの道ならあるが、散歩といふ感じを特に持つやうな所は附近にない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君はこの空ら風の中を突兀として、忙しそうな往来の人を眺めて歩く。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かなしに神田で覘いてみた眼鏡の中の大通りを思い浮べて、異郷の巷を歩くような思いがする。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に沿うて二町くらい歩くと王宮橋の西詰に出る。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも黒紋付に、歩くときゅうきゅう音のする仙台平の袴姿であったが、この人は人の家の玄関を案内を乞わずに黙っていきなりつかつか這入って来るというちょっと変った習慣の持主であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内へ向かう人数につれてぶらぶら歩く。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだしで歩くと、足の裏がいやにぬらぬらする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかなの脊中を踏んづけて歩くなんて、野蠻きはまる事ぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顏をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがかう腰をかがめて歩くのは、決してとしのせゐぢやないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは荷物を持つて歩くのは、きらひです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の岳はもう眼の前に立っている、山の空気が稀薄で透明になっているから、それが近いように見えていて、歩くに遠いのが解る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽虫が飛び、甲虫が歩く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び廻る自動車も、忙しそうに歩く行人も、右往左往に悲叫遁走する、あらゆる生物の、混乱の姿ででもあるかのように取られた。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼砂が足の指先に、ザクザク障るので、闇の中でも裾野を歩くという意識があるだけだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前の方から喧嘩を吹っかけたんじゃねえか」　私は、実は歩くのが堪えられない苦しみであった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その役にも立たない、腐った古行李をもう担いで歩くのが、迚も重くて、足に対して堪えられない拷問になって来た。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは足を打ち貫かれた兵卒が、歩ける訳がないのに歩くのと同じだと思い込んでいた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
