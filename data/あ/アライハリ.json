        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い張りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い張りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い張りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い張りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い張りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い張りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い張りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い張りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い張りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い張りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い張りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い張りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い張りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い張りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「こんなに汚れたから、新しいの買って下さい」　父は本と私の顔を等分に見くらべていたが、「そんなら私が洗い張りしてあげる」　と言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは近所の洗い張りでもしようかと云うし、私は女給と芸者の広告がこのごろめについて仕方がない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは近所の洗い張りでもしようかと云うし、私は女給と芸者の広告がめにつく。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい庭さきでは、洗い張り作業をしているひとたちもいました。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはるは縫物をとてもよくし、私など洗い張りした着物はいちいち軽井沢へ送っておはるに縫ってもらっていた。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先生の宅へ出はいりをするついでに、衣服の洗い張りや仕立て方などを奥さんに頼んだ。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮を脱いで、肉を脱いで骨だけで涼みたいものだと英吉利のシドニー・スミスとか云う人が苦しがったと云う話があるが、たとい骨だけにならなくとも好いから、せめてこの淡灰色の斑入の毛衣だけはちょっと洗い張りでもするか、もしくは当分の中質にでも入れたいような気がする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、これで家じゅうさっぱりして、お恭ちゃんが使っていた布団類の洗い張りも出来ていいわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの家でも、女は夜なべに、子供の足袋の穴や洗い張り物を、眼をいたくして針の先でかがっていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん誰にも相談せんと、自分ひとりであんだけの段取り工夫しなさって、ただ電話かけるのんに女の声やったらいかん思て、お梅どんに訳話して出入りの洗い張り屋の男頼んだ。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よごれたまま押込んで置いた彼の衣類を出して、次つぎに解いて洗い張りをし、巧みに仕立て直した。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、すこし洗い張りをせんならんので、糊を炊いておこうと思うて……」「ふウン」　夫から、喧嘩に手を出すな、といわれたマンは、暴漢どもが飛びこんで来たら、たぎり立った糊を、頭から打っかけてやろうと考えているのだった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い張りをした袷のようにさばさばとした顔つきだった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張板を立てて、襤褸を洗い張りしていたお次は、気の毒そうに、そっと寄って。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、自分の帯とか春着の小袖とかならばとにかく、洗い張りをした二官の袷を仕立て直しているのですから、お蝶としてはしおらしい。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い張り屋さんのように、本式にハリシンが張ってあった。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
