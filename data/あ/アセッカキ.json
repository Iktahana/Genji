          ],
          "literary": [
            {
              "text": "そのとき汗っかきとみえて豆絞りの手拭で汗拭きながら、その男は表の樋をつたって流れる雨音に負けないような大きな声で自分のほうが勝手にゲラゲラ笑いだした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗っかきの具合もまた同断だった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "短気で一徹で、汗っかきで我儘。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は、彼がわたし以上に汗っかきでないかぎりは、その額に汗してパンをうるということは必要ではない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは母に似てひどく汗っかきなことです。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ母はまれな汗っかきでした。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、僕も汗っかきなのです。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は人から随分汗っかきだねと云われると、いつでも「ええ、親譲りでね。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗っかきということは、悪い感じのものではありませんね。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕よりひどい汗っかきの渡辺の背中がグッショリ、さはれない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
