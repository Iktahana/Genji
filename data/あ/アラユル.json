        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日凡ゆるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は凡ゆるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には凡ゆるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは凡ゆるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は凡ゆるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では凡ゆるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に凡ゆるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では凡ゆるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると凡ゆるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では凡ゆるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に凡ゆるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により凡ゆるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "凡ゆるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に凡ゆるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "従つて芸術の話の登場する凡ゆる場合、其処には二つの神があつて、その一つは芸術の神であり、他の一つは料理屋女将の神ともいふべき神である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論これは、多かれ少かれ凡ゆる詩人について云へることで、私自身についても云へることである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（凡ゆる道は天に通ずる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、私はその愉悦たるや、濃淡の差こそあれ、凡ゆる人間に在ると思ふのである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（凡ゆる誤謬は直観自体の中にはない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、凡ゆる思惟の矛盾は、その対象自体の中にあるのではない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ゆる人間の姿態と、あらゆる色彩の閃きと、また凡ゆる国籍の違った言葉の抑揚とが、框の区切りの中にぎっしり詰っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟はこれに対してます／＼執拗になり、果ては凡ゆる侮誣の言葉を突きつけて兄に向つた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞ良い考えはないもんかな」　お前はしきりに首をひねっていたが、間もなく、川那子メジシンの広告から全快写真の姿が消え、代って歴史上の英雄豪傑をはじめ、現代の政治家、実業家、文士、著名の俳優、芸者等、凡ゆる階級の代表的人物や、代表的時事問題の誹毀讒謗的文章があらわれだした。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてものの凡ゆる愛と匂とに眞實をこめた自分の詩は汎く豐富にしてかぎりなき深さにある自然をその背景乃至内容とする。",
              "citation": {
                "source": "風は草木にささやいた",
                "author": "風は草木にささやいた",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も訪れられてゐるから、村の僕の住家に彼も泊ることもあり、会食もする位だから、事務以外の話も聞くのであるが、彼の口から聞く凡ゆる話――彼は美術にも演劇にも文学にも通じ、また己れの恋愛談やら、物凄いエロテイツクな話もするのであるが、一向僕の心を打たないのである。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「モダン・ライフの円卓子で、たつた今宣讐の盃を挙げて――と申すのは、世の凡ゆる佳人と、折々に胸をかすめるであらう諸々の憂ひと悲しみと嘆き――とを、その一盃を唇に触れゝば忽ち爽かに拭ひ去り、二度触れるならば、常住の健やかさを、三度には、不老の悦びを――そのやうな類ひ稀なる清廉に法て完全なる！",
              "citation": {
                "source": "〔モダン紳士十誡〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ゆる教授から私が直接の言葉を掛けられたのは、先生のそれが最初で、そして最後であらう。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して斯る善は凡ゆる類ひの人物の上にも可能なるものなり。",
              "citation": {
                "source": "嘆きの谷で拾つた懐疑の花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ゆる部分々々の留釘を換へ、錆を落し、油磨きをかけて組立直して見ると、何とまあこの千八百年代の新型自転車は再び春に回り合つたのを微笑むかのやうにれきろくとして走り出すではないか。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで凡ゆる場合にこの嚏のためには因果な難を被つてゐる、枚挙に遑ないほどの――。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、小学でも中学でも凡ゆる学科のうちで綴り方と作文が何よりも不得意で、幾度も〇点をとり、旅先などから母親にでも手紙が書き憎くかつたのであるが（母は私のハガキでも、私が戻るとそれを目の前に突きつけて、凡ゆる誤字文法を指摘した。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の最近の作品を見ると、実にも悠々と文学的なる凡ゆる技巧を征服して、はつきりと一つの境地に達しようとしてゐる観が窺はれるのであつた。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の者は、凡ゆる力を惜まずに此工場で働くことに依つて、希望に充ちた新生活を展く決心だつたから、この時も町へ帰らうともせず、寧ろ此上もない祝福を抱いて、たくましい原始生活と闘ふてゐた時のことである。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "被掠奪者に対しては罪を感ずるが、凡ゆる努力をした後の、最後の饑のための掠奪に対しては天に恥ぢる要はない筈だ。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は凡ゆる人の言葉を、凡てそのまま」と私はその手紙の中で思はずそれに傍点を打つた。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台も椅子も卓子も自然木を組合せた態の石造りに似て、使用者の凡ゆる感情をも甘えさせはしなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、凡ゆる人間に対する強さを養はなければならなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ゆる彼の酔態を私は戦竦をもつて毛嫌ひしてゐる者であつたが、その光景を見損つたのは稍遺憾の思ひであつた。",
              "citation": {
                "source": "老猾抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尨大な研究録を此処に批瀝するわけには行かないが（未だ私は、一年あまりを費したが彼の青年時代の行状に就いて少しばかりの参考を得たに過ぎないが――）、彼は天狗の羽ばたきを耳にするために凡ゆる生活を犠牲にして、世にも不思議な、いとも勇敢な生活を送つてゐる。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、小學でも中學でも凡ゆる學科のうちで綴り方と作文が何よりも不得意で、幾度も〇點をとり、旅先などから母親にでも手紙が書き憎くかつたのであるが（母は私のハガキでも、私が戻るとそれを目の前に突きつけて、凡ゆる誤字文法を指摘した。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて、それは、人間界の凡ゆる現象に對して、統一的な解釋、「見方」をもつべきものであることは無論である。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは抽象的でも具体的でもない、又あらゆる習慣、あらゆる思索の便宜に作られた言葉、あらゆる名辞以前にあるものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる外的概念、あらゆる学校教育なぞが人を誤らせる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる『文明』を嫌ったヘルンは、反対にあらゆる自然を深く愛した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
