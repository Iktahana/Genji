    "definitions": [
      {
        "index": 1,
        "gloss": "blue eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "闊き窓の下鋪板に達するまでに切り開かれたる、丹青目を眩したりけん壁畫の今猶微かに遺れるなど、昔の豪華の跡は思はるれど、壁の下には石灰の桶いくつともなく並べ据ゑられ、鋪板には芻秣、藁などちりぼひ、片隅には見苦しき馬具と農具との積み累ねられたるを見る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界が恐ろしい危険から救われる」　教授が青目を輝かせて俺を見た。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあおめえの親類の話じゃあねえか」「よせよ」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあおめえ、こんで俺らも若けえ時にや面白えのがんだよなあ」と爺さんの肩へ靠れ掛るものもあつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおめざめでしたか、あんまりよくお寝みでしたから、お午餐も差しあげませんで」　と言いながら、ばあやが夕食を運んできた。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあもうなんにも訊くめえが、おれの方じゃあおめえを他人と思わねえから、唯ひと言云って置くことがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの方から云って聞かせてもいいが、それじゃあおめえの為にならねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『南も参るので御座いますがね、どうしても出なければならない講義がありましてね、私ばかり参りましたの、皆様が大よろこびで大変で御座いましたの、奥様まあおめでたう御座います。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一文も出来ないで、よくまあおめおめ帰って来られたもんだね。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろくもないといった顔、不愉快そうに濡れ燕を鞘へ納めた左膳は、「おめえか……えらく出世をしたものだなア、どういういきさつで、そんな身分になったのか知らねえが、おらあおめえには用はねえのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあお駒、いつもいうことだが、人間にあ二種あってな、人を使う身と、人様に使われる身と、これあおめえ、はっきり別れているんだぜ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もうけがあってもなくても、これあおめえ、今のうちに手を引いたほうが利口だろうぜ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみつかんばかりにことばをつないで、「実あさっき、おれあおめえのからだを見るために、ああしていっしょに湯にへえったのだが、あれならどうして、振り事でも所作でも、融通のきくいいからだだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあおめでとう、大層立派に御化粧が出来ましたね」「ええ去年の暮｜御師匠さんに買って頂いたの、宜いでしょう」とちゃらちゃら鳴らして見せる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあおめえさんの身の上でも聞かせてくだせえ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らあおめえん介抱まじゃあ請合わねえぞ」と云いながら、誰かがひどく彼の肩を揺った。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おめえはみじん子が好きだったな、これはお負にしとくよ、けどなあ、三年子、おめえのような仕合せな金魚は、この年になるまで未だ一度も見たことがない、永い間この商売をしているけれど、病気もしないで何時もおめかしして歩いているのは、まあおめえくらいなもんだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、与八さん、おめえは感心だよ、おめえの真似はできねえ……まあ、早い話がおめえは聖人だね、支那の丘という人と同格なんだね、聖人……大したもんだよ、だが、聖人にしちゃあおめえ、少し間が抜けてらあ……」「なあに」　与八は相手にならないで、藁をすぐっているらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むろん牝鶏が生みます」「じゃあおめえはどうだ、うう、おめえはなにから生れて来ただえ、木の股かえ」「もちろん母親からでございます」　杢助は煙草をふかし、ふんと云った。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米櫃も空っぽみてえだが、米もねえのか」「――おれは嘘は云わない」「じあおめえどうしてるんだ」「――ごらんのとおりさ」「だって飯は食ってるんだろう」「――今日で三日、なにも口へは入れない」「しようがねえなあ」　男は太息をついてこちらを眺めた。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないでおくれ栄ちゃん、おらあおめえだけが頼りなんだ、とあの眼つきで叫んでいたのだ。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おらあおめえなんか嫌えだよ、女なんか、おいら大嫌えだ、ついて来るなよ」「そんなに怒らないでよ」　おちづは哀しげに云った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまのは虎さんの知合いかね」「屋敷へ来ている客よ」「長い滞在かえ」「なに来たばかりだが、――おらあおめえのことを待ってたんだぜ」　二人は店の中へ入り、飯台に並んで腰を掛けた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、おらあ時間は幾らでもあるんだ、旦那と江戸へいっているときにゃあだめだが、こっちにいるときゃあ暇なんだ、おらあ旦那のお草履をつかむだけが役なんだからな、――まあおめえも一杯やんねえな」「おらあ酒はごく弱いんだ」　万三郎はいかにも飲みにくそうに、受けた盃を舐める程度で返した。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああおめえ弥兵衛か、来ただかね。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおめでたい人たちだわ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きびがわりいのなんのって」とあとでその男が云った、「あいつの眼は生きた人間の眼じゃあねえぜ、ありゃあおめえしんだんじんの眼だ、おらあ賭けてもいいが、あいつの躯に流れてる血は氷みてえにつめてえぜ、きっと」　平さんは三度のめしに、漬け物と味噌しか喰べない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあおめえは、たけぞうが幼名だったのか」「そうです」「十七歳頃にも、そう呼んでいたか」「はい」「十七の時に、おめえ、又八という男と、関ヶ原の戦へ出やしなかったか？",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが子供のことであるから自分に免じて寛してくれ、と武蔵が代って詫ると、無法者は、「兄か、主人か、何か知らねえが、じゃあおめえの名を聞いておこう」　と、いう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "子をたずねる愛執の闇、生みのわが子をさがしあるく母性のまよいに、ふしぎな錯覚を起しているお時は、相手のはにかみにも気がつかず、ただ（もしやこの子が）と思う一途に、「じゃあおめえは、両親を持っているかね。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
