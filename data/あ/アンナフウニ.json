        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あんな風にについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんな風にの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんな風にが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんな風にについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんな風にの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんな風にが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんな風にという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんな風にについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんな風には複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんな風にについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんな風にが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんな風には重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんな風にの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんな風には様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんな風には興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんな風になったのも、そのせいかも知れなかったよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あんな風になら、一人で幾生涯でも生きて見られようじゃありませんか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その革命の背後には幾千、幾萬の犧牲者があんな風にして苦しんでゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな風に気持が転換できるといいなど思って熱心になることもあった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それにしても明日子は何の為めにあんな風にぼくに話さねばならなかったのか、そんな疑問は矢張り残っていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日子があんな風にぼくに言ったのは、ぼくの同情をひいてぼくを誘惑するためだったのか、そう思って、「誘惑なんかされませんよ」と言うと、轡川は、「そうですかね。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君は加平君ところの牛小屋が、いぜん、だんだん傾いて来て、壁が蛙の腹のやうに外側にふくれ、とうとうある日つぶれてしまつたのをよく知つてゐたので、自分の家があんな風になるのはかなはないと思つて、ハモニカも歌もやめてしまつたのであつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、良寛禅師の書を、あんな風におもていさらしておくのは、勿体ないことです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は自分もどうかあんな風にえらくなってやって行きたいものと思ったのである。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文体なども人を真似るのがいやだったから、あんな風にやって見たに過ぎない。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わいは昔蝶子はんのことあんな風に言ったけど、悪う思いなや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝といふやうな固まつた概念のある國に、夫に對して姑の事をあんな風に云つて何とも思はぬ女がどうして出來たのか、西洋の思想から見ても、母といふものは神聖なものになつてゐるから、夫に對して姑を侮辱しても好いと思ふ女は先づあるまい。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻もあんな風に気が狂ってしまう。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの姉妹はいつ頃からあんな風になったのですか。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな風に賞められると、かえって何だか頼りない気が致しますの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな風に書いたら僕が、喜ぶとでも思ふのか、喝！",
              "citation": {
                "source": "Ｓ・Ｉ生へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、昨夜あんな風にされたままでは済まぬという気持はひそかにあった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よその新聞に書かれたぐらいで気にしたらあかん」「でもあんな風に書かれましたら、……」「どない書きよっても構へんやないか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の手もあんな風に動いたらなあ」　そして突然そんな風に云いながら、彼はぷいと席から立つのである。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あんな風にしているうちに、あの人はほかの人たちへあのことを話さないかしら？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと、あんな風にしてゐるんだから……」　と上田君が、さゝやくのであつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな風に、お化けの世界ときめつけてしまつたところにも、必然性もなく、おどけたたぐひのおもしろさもなかつた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど妾、妾と違つてあんたは、あんたが口で云ふことは何時も思ひのまゝのことをきつぱりと云ふ人だといふことを思ひ込んでゐるので、あんな風に空とぼけられると思はずカツとしてしまふのよ。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆにあんな風に発見されてテレ臭くもあり、業腹でもあつたので、頭から否定してやつたのだが、ほんとは私は、Ｆの云つた通りこいつに一言ことばを教へてやらうと思つてゐたのだつた。",
              "citation": {
                "source": "鸚鵡の思ひ出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が、阿母や清親の奴と、あんな風になつて此方へ来たものゝ、俺は決してお前を甘えさせはしないよ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、最も平凡な犯罪者の心理で、あんな風に証人の一役を買って出た――と言うわけさ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「みんなあんな風に思つてゐるのよ。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をあんな風に好く書いていたゞいて、大変有難いんですの。",
              "citation": {
                "source": "彷徨へる",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ若しも私を嫌っているなら何うしてあんな風にする事が出来よう。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論こつちでは、そこのやうに、汚い恰好をして、年中、あんな風に働く必要はない。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
