    "entry": "アーティキュレーション",
    "reading": {
      "primary": "アーティキュレーション",
      "alternatives": [
        "アーティキュレイション"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
