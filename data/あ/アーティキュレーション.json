    },
    "definitions": [
      {
        "index": 1,
        "gloss": "articulation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アーティキュレーションについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーティキュレーションの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーティキュレーションが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーティキュレーションについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーティキュレーションの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーティキュレーションが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーティキュレーションという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーティキュレーションについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーティキュレーションは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーティキュレーションが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーティキュレーションは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーティキュレーションの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーティキュレーションは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーティキュレーションは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だが、あとに残った音声は、やはりアーティキュレーションがよくなかった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの直観は決して単一な直観ではなくて、一定の具体的内容に分割され得る処の、その意味に於てはアーティキュレーション（分節・音述）を持った処の、テーゼ・命題でなくてはならぬのは尤もだろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、ただの直観ならば、つまり一個のケオスに他ならない筈だから、その内容がまだアーティキュレーションを有っていない、節に別けた分析された言葉や文章になっていない筈だ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
