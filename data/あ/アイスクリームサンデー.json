        "examples": {
          "standard": [
            {
              "text": "すみません、このメニューの「アイスクリームサンデー」を一つお願いします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日は暑いから、おやつの時間にみんなでアイスクリームサンデーでも作ろうか！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "特製チョコレートアイスクリームサンデーは、濃厚なチョコレートソースとフレッシュフルーツがたっぷり乗っていて、見た目も華やかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏限定！トロピカルフルーツをふんだんに使った、爽やかなアイスクリームサンデーが登場しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「やったー！お誕生日プレゼントに、大好きなアイスクリームサンデーを買ってもらえた！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あのカフェのアイスクリームサンデーは、バニラビーンズ入りのアイスクリームと、自家製キャラメルソースの組み合わせが絶妙だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "デザートは、定番のチョコレートパフェにするか、それともフルーツたっぷりのアイスクリームサンデーにするか迷うところだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
