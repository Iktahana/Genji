[
  {
    "uuid": "9bf09495-b655-5b56-a632-ec7f6908339d",
    "entry": "姉夫婦",
    "reading": {
      "primary": "あねふうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's older sister and her husband",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉夫婦について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉夫婦の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉夫婦が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉夫婦について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉夫婦の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉夫婦が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉夫婦という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉夫婦についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉夫婦は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉夫婦が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉夫婦は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉夫婦の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉夫婦は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉夫婦は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「勝子（姉夫婦の娘）がそこらにいますで、よぼってやっとくなさい」と義母が言った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば最後の場面でお染が姉夫婦を見送ってから急に傷の痛みを感じてベンチに腰をかけるとき三味線がばたりと倒れるその音だけを聞かせるが、ただそれだけである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども新宿駅で私が切符を買おうとしたら、すでに嫁の姉夫婦が私たちの切符（二等の切符であった）を買ってくれていたので、私にはお金が何も要らなくなった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦も貧乏のどん底だった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦は真女児の詞に道理があるので疑いを晴らして、「さる例あるべき世にもあらずかし、はるばるとたずねまどい給う御心ねのいとおしきに、豊雄｜肯わずとも、我々とどめまいらせん」と云って、豊雄の傍に置き、そのうちに豊雄にすすめて結婚さした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦はたしか六十に近いだろう、家のさびしくなったも無理はない。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はけっしていやな心持ちはせぬけれど、両親もずいぶん達者なほうだったし、姉夫婦は働き盛りで予らの家におったころには、この大きな家もどよむばかりであったのだ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は姉夫婦と予らと五人つれ立って父の墓参をした。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦も無言である、予も無言である。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんすぐ九十九里へいこうよう」「さあお父さんてば早くいこうよう」　予も早く浜に行きたいは子どもらと同じである、姉夫婦もさあさあとしたくをしてくれる。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏に従って寺へ来ずに、姉夫婦といっしょに京へはいってしまったことを佐は謝した。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは炉の前で姉夫婦と東京の話などをしていると、突然に外からおばんの声を聞いたのであった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか姉夫婦と喧嘩でもして、飛び出したのじゃあねえか」「いや、それですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、怪我人といえば彼の次郎兵衛、姉から知らせてやったのでしょう、この一件が無事に済んだ事を知って怱々に江戸へ戻って来ましたが、江戸はおそろしい所だと云ってすぐに故郷へ帰ろうとするのを、姉夫婦にひき留められて、例の蝋燭問屋の万屋へ奉公することになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の姉夫婦の悲惨な最期は、当時東京の各新聞にも精しく報道されましたから、『千葉町の夫婦殺し』なる事件は、閣下の御記憶の中にも残って居ることと存じます。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い義兄の病気も、夏に向うに連れて段々快方に向うようで、一夏養生を続けたならば健康を恢復するだろうと姉夫婦も私も私達の父母も、愁眉を開いて居たのでありました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、こうした小康を欣んで居た時、あの怖ろしい運命が姉夫婦を襲いかけて居たのであります。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から考えますと、小使は姉夫婦が殺されたことは、知って居たのでしょうが、そうした怖ろしい惨事を、自分の口で知らせると云う嫌な仕事を避けたのでしょう。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は、姉の家へ急ぎながらも、姉夫婦が殺されたとは、夢にも思いませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ強盗に襲われた為に、気の弱い姉夫婦が、どんなに強い激動を受けただろうかと、そればかりが心配でした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦の衣類などの中で目覚しいものは、皆私の家へ預けてありましたから、盗られたとしてもホンの小遣銭位だろうと思いましたから、その点は、少しも心配いたしませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、姉夫婦が強盗に襲われた跡始末をして居るのだと思いました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一刻も早く顔を見せて、姉夫婦に安心させてやろうと思いまして、勢よく姉の家の門の中へ飛び込みました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、障子一枚の向うに姉夫婦の屍骸が横わって居るのを、マザマザと感じました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は姉夫婦を殺された無念と悲しみとで一刻もじっとして居られんように思いました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉夫婦が、悲惨な最期を遂げたのも、つまりは千葉県警察の怠慢であるように思いまして、私は此の刑事を頭から罵倒してやりたいようないらいらした気持をさえ感じました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は母が必死に頼むにも拘わらず、姉夫婦の惨死の現場へは、母を行かせませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が、生きて居ましたら、まだ三年や四年は生き延びただろうと思いますに付けても、私は姉夫婦を殺した強盗は同時に私の母の生命をも縮めて居ったのだと、思われずには居られませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯行の表面では姉夫婦だけが殺されたことになって居ますが、私は母もその同じ犯人に惨殺されたものだと云う感銘を受けずには居られません。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの公判延の被告箱の中に、傲然として起立して居る男を見ました時、私は姉夫婦の惨死の光景を見た時と同じような戦慄を感ぜずには居られませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
