        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もし首相が、文学青年的な愛読書を列挙したとしたら、一部の青白きインテリは喜ぶかもしれないが「銭形平次」を読むと言い切ったほどの人気は湧かなかったであろう。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白きインテリの嘆きはここから実は一種のインテリ宣言の意味をさえ持つようになって来た。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し残念｜乍ら我々の仲間は、骨の髄から青白きインテリで、一代に一千万円の巨富を築き上げた国府金弥老人と対抗するほどの、金も智慧も持っている筈はありません。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "音盤の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ腹の立つことですが、私ども青白きインテリどもは、諦める外は無い運命でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "音盤の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田さんとしても、文学青年的なむずかしい本の名前をあげたとしたら、青白きインテリは喜んだかも知れないが、捕物帳だよと答えたほどに、大衆の人気は沸かなかったに違いない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
