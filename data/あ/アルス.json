        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "集中の詩篇は主として「地上巡礼」「詩歌」「アルス」「卓上噴水」「プリズム」「感情」及び一、二の地方雑誌に掲載した者の中から抜粋した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うわけは、今度｜漸く稿を集めて僕の体系ある自由詩論の一冊を、アルスから出版することになったからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして脱稿と共に、アルスから出版する約束になっていた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして長い経過の結果、今度始めて、漸く僕の多年宿願した著述『詩の原理』が、この九月にアルスから出版されることになった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時作る所の『波』一篇は、白秋氏に激賞され、後選ばれて、アルス社『日本児童詩集』にのりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豹と雲　　　　初版　　昭和四年八月　　アルス版（絶版）白秋全集第四卷　詩集※　昭和六年一月　　アルス阪（絶版）",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ弟の配慮で、アルスから鎌田敬止君が来てくれた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、アルスに一旦手渡したのが第二の「雀の卵」であつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "書肆アルスにとつては全く再び興るか否かの分れ目であつたのだ。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "当の七日の正午には、私は桜木町から税関の岸壁を目ざして駛っている自動車の中に、隣国の王やアルスの弟や友人たちに押っ取り巻かれて嬉々としている私自身を見出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その夜は肌を刺すような寒さで、我々はアルスターを着込み、首巻きでのどをくるんだ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの数秒で、アルスターとスカーフにくるまれ、戻ってきた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジイ・フィロゾフィイ・デス・アルス・オップか。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体アルス・オップとはなんだい。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホンヤクノコトデ　タノミアルスグ　キテクレ」　彼は、わたしの部屋の壁、ライフル銃もロビンソンもオルゴールも、ペナントも、昆虫標本の額も、みんなどこかへ棄てられて、それらのものゝかゝつてゐた痕だけ白い壁に、途徹もない論文の抜き書ばかりが落書されてゐるのを発見した。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも大杉は改造社とアルスから近刊する著書の校正や書足しの原稿に忙殺されていたのだそうだ。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルスキン Erskine of Linlathen は「宗教と道徳とは良心の背後に人格を認むると否とに由って分れる」といっている。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は心を殺して、アルスター・コートの下から発煙筒を取りだした。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのとき歩道には幾人かいたが、挨拶したのはアルスターをまとった細身の青年らしく、急ぎ足で去っていった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは両手の使ひわけだが、アメリカのチヤアルス・シユワツブは人一倍器用な性で、ピアノに向かふと左手では“Yankee Doodle”を弾き、右手では“The Star-Spangled Banner”を打ちながら、同時に口笛では“Home, Sweet Home”を吹くさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヤアルス・デイツケンスは、死ぬる少し前にガツヅヒルの花園で篝火をたいて、自分が一生の間に受けとつた名高い人達からの手紙をそつくりとりまとめて、その中で焼き捨ててしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜び勇んだバルザックはアルスナール図書館近くの屋根裏に一部屋をかり、寝台と机と二三脚の椅子と、餓え死しないだけの仕送りとをもって、愈々「ナポレオンが剣によって始めたところを筆によって成就する」ため、復古時代から七月革命を経て、複雑きわまりなく推移しつつあったパリの生活へ飛びこんだのであった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや自動車の急流ひきも切らないウェストミンスタア橋の方角からあれよという間に一台駈けぬけてきたＴＡＸＩが、リジェント街とチャアルス街の角にぴたりと静止すると、そこの石造建築物のまえに手荷物とともにひらりと地に下り立った男女の東洋人があった。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、チャアルス街とリジェント街の角は、帝国空路会社の倫敦における「｜空の家」、いわば空の旅客の集合場である。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "このチャアルス街｜空中館、飛行旅客の待合室へ踏みこんだ刹那、ひとつの正直な反省的｜心状が、電波のように私の全身を走り過ぎたことを私は告白しなければならない。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "野枝さんは殺される少し以前に、アルスから出た大杉君と共訳のファーブルの自然科学をまこと君に送ってくれた。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館「アルス」から降るイルミネーションで、外套の肩と胸とを赤く照らされながら、歩いている通行人。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
