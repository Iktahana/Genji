        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨蓋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨蓋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨蓋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨蓋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨蓋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨蓋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨蓋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨蓋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨蓋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨蓋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨蓋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨蓋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨蓋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨蓋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
