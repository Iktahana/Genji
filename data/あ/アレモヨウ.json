        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒れ模様について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒れ模様の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒れ模様が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒れ模様について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒れ模様の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒れ模様が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒れ模様という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒れ模様についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒れ模様は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒れ模様が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒れ模様は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒れ模様の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ模様は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒れ模様は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから自分の馬車まで歩いていき、見るとあたりには誰もおらず、夜はいまだ荒れ模様。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　また、申し合せたかのやうに意地悪く、暑い好い天気ばかりが続いてゐるのにも係はらず、海は毎日不気味な荒れ模様を保つてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方から進んで傍の者の心を掻き乱さうとでもするやうな調子で、「あゝ、退屈で堪らないなア……」と、突然筒抜けた声で叫んだり、こんなに好い天気だといふのに如何して斯う海は毎日荒れ模様なんだらう？",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に沿うて、汽車は山腹を潜っては出、潜っては出、出た時にやや荒れ模様の海の景色が右手に眺められる。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻から荒れ模様になっていた空が、夜になると、ひどい風雨となった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻から荒れ模様になつてゐた空が、夜になると、ひどい風雨となつた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い冬の荒れ模様の空の下を奇妙な列が行く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れ模様の海は薄明りの中に絶えず水沫を打ち上げてゐた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにも関らず、この荒れ模様の森林には、何か狂暴な喜びを眼ざまさせる力があるらしかった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度家々の空に星明りも見えない荒れ模様の夜です。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど家々の空に星明かりも見えない荒れ模様の夜です。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れ模様なら少々延ばそうじゃないか」「荒れればなお愉快だ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉢巻をしめて頭上に松明をさしこみ、これに火をともして荒れ模様の夜の海を半刻あまりも泳いできたのである。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "偵察機ＥＳ一〇一号は荒れ模様の海面に、奇妙な形をした鋼鉄浮標とも潜水艦ともつかぬものが浮いているのに気がついて、急いで僚機にあいずを送った。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人声も、雨音も、荒れ模様に加つて来た風の響きも、もう姫は聞かなかつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人声も、雨音も、荒れ模様に加つて来た風の響きも、もう、姫は聞かなかつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人声も、雨音も、荒れ模様に加って来た風の響きも、もう、姫は聞かなかった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　九月になると、すこし荒れ模様の雨が何度となく降ったり止んだりしていたが、そのうちにそれは殆んど小止みなしに降り続き出した。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　黒川圭介が、事によると自分の妻は重態で死にかけているのかも知れないと云うような漠然とした不安に戦きながら、信州の南に向ったのは、丁度二百廿日前の荒れ模様の日だった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで凪いでいた天候が、あやしく荒れ模様になってきて、静かな夏の航海にも、ときとして突然おそいかかることのある嵐のきざしが見えてきたときだ。",
              "citation": {
                "source": "船旅",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日から降り出した雨は夜中から雷雨に変わり、強い風も来て、荒れ模様は二日も続いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "明る朝は少し荒れ模様であったが、日が出ると静穏になった。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春とはいえ、まだ海は荒れ模様で、島伝い浦伝いの航路を続けて、備前の児島に着いたのが、二月の十日頃であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し荒れ模様の空の下では、殆んど黒い濃緑色だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候のいい頃だからいいようなものの、朝から荒れ模様であった空が、午後には暴風雨となった。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　洋装の女は、精も根も尽き果てたように、岩の上に腰を下して、美しい瞳に、荒れ模様の海をつくづく眺めて居ります。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝探しに夢中になるにしても、あまりに気高いこの婦人は、反ってこう、荒れ模様の海を背景に劇的な感慨に耽るにふさわしい人柄でした。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "診断は左のろくまくに故障があってレントゲンの陰影を見ることと、咳のため気管に甚だしい荒れ模様が見られるということであった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の激しい、荒れ模様の朝だったけれども、Ｋはこれから控えている一日のことに腹をたてながら、七時にはすでに事務室に行ったが、イタリア人の訪問にかかりきりにさせられるまえに少なくともいくらかの仕事を片づけるためであった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "オープンショウの午後の用件を聞いていたので、荒れ模様の暗い夕闇が鏡や緑色の植木の周囲に立ちこめてくると、その用件から何か思いがけないことがあつてひどく長びいているのだなと想像した。",
              "citation": {
                "source": "古書の呪い",
                "author": "THE BLAST OF THE BOOK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
