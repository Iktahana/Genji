        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "殺風景な病室の粗末な寝台の上で最期の息を引いた人の面影を忘れたのでもない、秋雨のふる日に焼場へ行った時の佗しい光景を思い起さぬでもないが、今の平一の心持にはそれが丁度覚めたばかりの宵の悪夢のように思われるのである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって空に星はあったが、電光が白い柱を、谷の中に投げては、夜営の人々をおどろかした、夜半には、秋雨が音なく注いだ、川縁に転がっている流材を焚火にして、寒さを凌いだ、針葉樹の切崖で囲んだ、瓶のように窄い谷底からは、天も谷川ほどの細さで流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨の山の靜けさ、松の葉から落ちる雨滴が雜木の葉を打つ幽かな音は、却つて山の靜寂を増す。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそぼふる秋雨ににじんで、更にしっとりとした情趣を帯びていた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の季題の「おぼろ」「花の雨」「薫風」「初あらし」「秋雨」「村しぐれ」などを外国語に翻訳できるにはできても、これらのものの純日本的感覚は到底翻訳できるはずのものではない。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからたとえば踊りつつ月の坂道ややふけて　はたと断えたる露の玉の緒とでもいったような場面などがいろいろあって、そうして終わりには葬礼のほこりにむせて萩尾花　母なる土に帰る秋雨　これらの映画を見たあとで国産の「マダムと女房」を見た。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は薄曇つたまゝで、三日の間はつきりした日の目を見せなかつたから、今日あたりは秋雨のやうなうすら寒い細雨が降るのだらうと彼れは川上から川下にかけてずつと見渡して見た。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起因を按ずるに、去年秋雨の降くらす、奥の座敷に、女ばかり総勢九人、しかも二組になって御法度の花骨牌。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨のしょぼしょぼと降るさみしい日、無事なようにと願い申して、岩殿寺の観音の山へ放した時は、煩っていた家内と二人、悄然として、ツィーツィーと梢を低く坂下りに樹を伝って慕い寄る声を聞いて、ほろりとして、一人は袖を濡らして帰った。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯の毛で胡粉を刷いたような女の膚の、どこか、頤の下あたりに、黒いあざはなかったか、うつむいた島田髷の影のように――　おかしな事は、その時｜摘んで来たごんごんごまは、いつどうしたか定かには覚えないのに、秋雨の草に生えて、塀を伝っていたのである。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それから春風秋雨、ここに十年の月日が流れました。",
              "citation": {
                "source": "十年",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　さて、私たちの歩みが薄紫の花のむらがる馬鈴薯畠の前に来たところで、何か親しい秋雨のような細かな霧雨も降り出して来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨めかしい、燐のにおいの小雨である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し聞きたるは、この夏の事、筆にものして世の人の同情を請はんと思ひたちしは、今日土曜日の夜、秋雨紅葉を染むるの時なり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球戦の入場券一枚を手に入れるために前夜からつめかけて秋雨の寒い一夜を明かす勇敢な人たちの話は彼を驚かし感心させた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃路ではすでにそのころ秋雨のようなものが降っていたのに、私のめぐった線は明るく白じらしく晴れていた。",
              "citation": {
                "source": "夏秋表",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨がざっと降って来る。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……腹ぐあいの悪い時だし、秋雨もこう毎日｜降続いて、そぞろ寒い晩にはこれが何より甘味い。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は秋雨しとしとと降って、この悲しげな雨の寂しさに堪えないで歩いてる人もあろう、こもってる人もあろう。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……第三篇に、能楽仲間の土場六、矢場七という二人が、自分らの友達を嚇かすために、ズウフラという機械を借りて来て、秋雨の降るさびしい晩に、遠方から友達の名を呼ぶので、雨戸を明けてみると誰もいない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕎麥は爽かで且つ細く強い秋雨がしと／＼と洗つて秋風がそれを乾かした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はもう何時位であつたか知れなかつたが秋雨が止まず降り注いで居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　秋雨がしと／＼と朝から降りつゞいて居る。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩人ならば秋雨｜蕭々とか何とか歌うべきところであろうが、我れわれ俗物は寒い方が身にしみて、早く酒でも飲むか、温かい物でも食うかしなければ凌がれないというので、船を出ると早々にかの飯館に飛込んでしまったのである。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とお山は言棄てて、コートの裾を※げながら、ゴタ／＼した秋雨の町を菊坂の方へ急いでゆく。",
              "citation": {
                "source": "絶望",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "じめじめと降り続く秋雨に湿った夜風が細々と通って来て、湿気でたるんだ障子紙をそっとあおって通った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは秋雨にぬれた冷たい空気に吹かれすぎたからのことと思っていたが、座について見ると、悪いのは顔色ばかりではない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の佗人　二日二夜の間びしょびしょと降りつづけた秋雨は、三日目の朝になって、やっと霽れあがった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条とした秋雨が降ったり止んだりしている夕ぐれだった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しく死んで行った不幸な友のことを憶ふのも、秋雨のなかを酒場の方へ歩いて行って、秋雨を淋しがるのと似てゐた。",
              "citation": {
                "source": "滑走",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
