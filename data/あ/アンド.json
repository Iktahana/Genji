        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日＆について考えている。",
              "source": "幻辞"
            },
            {
              "text": "＆という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は＆の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には＆が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "＆を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは＆について学習した。",
              "source": "幻辞"
            },
            {
              "text": "＆の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は＆の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では＆が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "＆という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に＆という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では＆についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "＆を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると＆は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "＆について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では＆が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に＆は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により＆の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "＆は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に＆は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "付け加えると、現時点での負債の総額が、確認できる限りでは八八ポンド一〇シリング、一方でキャピタル＆カウンティーズ銀行の預金残高は二二〇ポンドある。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ウェストハウス＆マーバンクの外商ですから、フェンチャーチ街でいちばん大きなクラレット輸入業者になります。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ郵便でフェンチャーチ街のウェストハウス＆マーバンクから手紙が届き、その知らせの内容は、人相書があらゆる点でうちの社員のジェイムズ・ウィンディバンクと一致。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはドレイパ・ガーデンズのコクソン＆ウッドハウスの店に職を持っていたんですけれど、この春先にご存じだと思いますけれどベネズエラ公債でやっちまいまして、どっと傾いてしまったんです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンバード街のでっかい株屋のモウソン＆ウィリアム。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "『最近までコクソン＆ウッドハウスにお勤めで？",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウソン＆ウィリアムズ社で殺人。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてより有名金融会社モウソン＆ウィリアムズには総額一〇〇万ポンドをゆうに超える有価証券が保管されており、経営者はその責任から万一の場合に備えて最新型の金庫を用い、建物内に昼夜武装警備員を置いていた。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの件についての覚え書きの末尾には短い追記があって、そこにつけた記録によれば、ヴァイオレット・スミス嬢は大きな財産を相続し、現在はウェストミンスタのかの有名な電気業者モートン＆ケネディの社長たるシリル・モートンの妻であるという。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールド・ジューリ四六一一月一九日　　　吸血鬼の件拝啓　当社依頼人ロバート・ファーガソン氏（ミンシン横町の紅茶卸ファーガソン＆ミュアヘッド経営者）より同日付の書簡にて当社へ吸血鬼に関して照会がございました。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬具モリソン＝モリソン＆ドッド　ＥＪＣ拝「マティルダ・ブリッグスとは妙齢の女の名ではないよ、ワトソン。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイカー街一一月二一日　　　吸血鬼の件拝復　一九日付のご来信について、当方、貴社依頼人ロバート・ファーガソン氏（ミンシン横町の紅茶卸ファーガソン＆ミュアヘッド経営）の調査を請け負い、案件を無事解決したことを恐れながらここに申し上げます。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはモーティマー商店、煙草屋、新聞の小売店、シティ＆サバーバン銀行コバーグ支店、菜食料理店にマクファーレン馬車製作会社の倉庫。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "シティ＆サバーバン銀行が我が友人の質屋と背中合わせになっていると。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、フォークソングの人気を押し上げたＰＰＭ（ピーター・ポール＆マリー）というグループを案内役にボブ・ディランを聞き始め、そこからピート・シーガー、ウッディー・ガスリーとさかのぼっていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代の半ば、ＡＴ＆Ｔ（アメリカの電話の元締め）のベル研究所（エレクトロニクスのエデンの園）は、マサチューセッツ工科大学、ゼネラル・エレクトリック社と共同で、大型コンピューターをたくさんのユーザーが同時に、しかも快適に使えるようにするプロジェクトを進めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時電気通信を一手に握っていたＡＴ＆Ｔは、独占禁止法の縛りによってコンピューターへの進出を禁止されていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの方言の生まれたＵＮＩＸの中で、本家のＡＴ＆ＴのシステムＶとカリフォルニア大学バークレー校で育ったＢＳＤは二大勢力となっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多くの方言が生まれていたＵＮＩＸに関しては、カリフォルニア大学バークレー校のＢＳＤと本家であるＡＴ＆ＴのシステムＶ、さらにマイクロソフトがパーソナルコンピューター用に開発していたＸＥＮＩＸを統合して決定版を作る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤのＸ８６互換への挑戦は、その後チップス＆テクノロジーズ、サイリックス、テキサス・インスツルメンツといった追随者を生み、競争相手の出現によってインテルは製品の大幅な値下げを迫られた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本家の技をなぞったうえに、画面上での訂正や文書の保存、カット＆ペースト、欧文ならスペルのチェックと、従来のタイプライターをはるかに超えてみせた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ叫ぶんでも〈トゥイスト＆シャウト〉とは、大ちがいだ」「それ、聴いたことない」　と、柾生が期待をこめていった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーター＆ゴードンの〈ゴー・トゥ・ピーシズ〉を聴きながらベッドをなおし、パジャマを脱いでいると、点呼は居室です、というワラのアナウンスがまたはいり、ハーマンズ・ハーミッツの〈キャント・ユー・ヒア・マイ・ハートビート〉になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャン＆ディーンの〈ポプシクル〉が流れてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママズ＆パパズの〈マンデイ・マンデイ〉と、スペンサー・デイヴィス・グループの〈キープ・オン・ラニング〉だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開け放った室内からは、ヴォリュームをしぼったラジオでかかる、ポール・リヴィア＆ザ・レイダーズの〈ハングリー〉が、蜩の乾いた声のあいだを縫って流れてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオは、サム・ザ・シャム＆ザ・ファラオウズの〈リル・レッド・ライディング・フッド〉を流している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "13だから、いいつづけるだろういつまでもここで暮らすと〈フェリー・アクロス・ザ・マージー〉ジェリー＆ザ・ペイスメイカーズ「あれ、まったくおなじ形なんだね」　ワラが、ヴェランダの手すりにもたれて、三階部分の工事に入った、新しい寮を見ながらいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかな救いは、まず、今年はじめに〈ジェニー・テイク・ア・ライド〉をヒットさせた、ミッチ・ライダー＆ザ・デトロイト・ホイールズが、〈デヴィル・ウィズ・ア・ブルー・ドレス・オン／グッド・ゴリー・ミス・モリー〉という、信じられないほど強力なヒットをだしたことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「居間」からは、ママズ＆パパズの〈マンデイ・マンデイ〉が流れてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
