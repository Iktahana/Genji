            {
              "text": "私は毎日安堵について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安堵という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安堵の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安堵が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安堵を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安堵について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安堵の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安堵の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安堵が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安堵という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安堵という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安堵についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安堵を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安堵は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安堵について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安堵が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安堵は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安堵の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安堵は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安堵は興味深い例である。",
              "source": "幻辞"
            }
