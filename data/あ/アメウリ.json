[
  {
    "uuid": "55c6a866-963f-5469-a39b-93dc539d159c",
    "entry": "飴売り",
    "reading": {
      "primary": "あめうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "candy vendor (esp. an Edo-period candy vendor who sold candy while walking around playing the flute or another musical instrument)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日飴売りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴売りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴売りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴売りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴売りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴売りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴売りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴売りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴売りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴売りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴売りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴売りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴売りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴売りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴売りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴売りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴売りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴売りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴売りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴売りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お前みたな気イで冷やし飴売りに歩いてたら、飴が腐敗ってしまう……」　言って、他吉はふと眼をひからせた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治時代までは鉦をたたいて売りに来る飴売りがすこぶる多く、そこらの辻に屋台の荷をおろして、子どもを相手にいろいろの飴細工を売る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飴細工と※粉細工とが江戸時代の形見といったような大道商人であったが、キャラメルやドロップをしゃぶる現代の子ども達からだんだんに見捨てられて、東京市のまん中からは昔の姿を消して行くらしく、場末の町などで折りおりに見かける飴売りにも若い人は殆ど無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飴売りのまだ相当に繁昌している明治時代の三月の末、麹町の山王山の桜がやがて咲き出しそうな、うららかに晴れた日の朝である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは其の頃の往来にしばしば見る風景の一つで、別に珍らしいことでも無かったが、近づくにしたがって私に少しく不思議を感じさせたのは、ひとりの老人がその店の前に突っ立って、飴売りの男と頻りに話し込んでいることであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又お邪魔に出ようと思いまして……」「さあ、いらっしゃい」　老人は飴売りに別れて、わたしと一緒にあるき出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飴細工が器用に出来るので、芝居の休みのあいだは飴屋になって稼いでいるんです」　成程その飴売りは三十前後の小粋な男で、役者の紋を染めた手拭を肩にかけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴売りは年ごろ二十二三の、色の小白い、人柄の悪くない男で、誰に対しても愛嬌を振り撒いているので、内心はなんだか薄気味悪いと思いながらも、特に彼を忌み嫌う者もなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも飴売りはちっとも忌な顔をしないで、何か子供たちに冗談などを云っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真っ昼間の往来で、いつまでも飴売りのあとを付け廻しているわけにも行かないので、半七はその人相を篤と見定めただけで、ひと先ずそこを立ち去るのほかは無かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから人足、手伝い、仲仕の類を稼いで、あらん限りの苦労をした揚句、鉋飴売りの商売を覚えて、足高盥を荷ぎ荷ぎ故郷へ帰って来たが、帰って来てみると故郷は皆死絶えたり零落してしまったりしてアトカタもない。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり押入の向側から鉋飴売りの足高盥を取出しかけたが又、押入の中へ投込んだ。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "来たら出来るだけ身軽にしとかんと不可んと思いまして、慣れた者の飴売りの身支度をして待っておりますと……ヘエ。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮｜緘しの金モール燦然たる飴売り服や、四角八面のフロックコートを一着に及んで、左様然らばの勲何等｜風を吹かせるのが、どう考えても吾輩の性に合わなかったんだね。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……内地で鮮人と云えば、土方か飴売りしかないもんと思ってる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兵さんの家の隣の小屋にいた飴売りの親爺と、かけ落したと言うのだった。",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで豆をちらばしたようだともいうところから、豆店の名が出たのだろうが、住んでいる連中というのがまた法界坊や、飴売りや、唐傘の骨をけずる浪人や、とにかく一風変った人たちばかりだったので、豆店はいっそう特別な眼で町内から見られていた。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴売りや風吹く秋の女竹やまふ人の今日鋏する柘榴かな　病を養つて伊豆に客なる梶井基次郎君より返書あり、柘榴の句は鋏するのところ、剪定の意なりや収穫の意なりや、弁じ難しとお咎め蒙つた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅に飴売りに出る着物、笠などと道具がある。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの家は母子二人ぎりで、母が飴売りに出て生活ているのだと直ぐわかる）お蔦（三十三、四歳）子の愛にひかされて、独り身で、細々と生計を立てている。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三春を退国してから、おれはいかにもして槍ひと筋の武士に成ろうと誓った、その流浪中のことだったが、天竜川に沿った或る貧しい旅籠宿で、飴売りをする老人の述懐を聞き、はじめて夢から覚めたように思った。",
              "citation": {
                "source": "足軽奉公",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の多くはごく貧しい人たちで、たいていが飴売りとか、縁日商人とか、旅を渡る安旅芸人などだから、少し長く降りこめられでもすると、食う物にさえ事欠き、つい他人の物に手を出す、という者も稀ではなかった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に夫婦づれの飴売りがいて、女が鉦と太鼓を叩き、男がみだらな唄をうたい、往来のはげしい通りを稲妻形に、踊りあるいていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『なぜと云って、あの杜鵑管を、どうして、飴売りなどが、持って居りましょう。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、あの飴売りは、三郎様の密使でしょう』　八雲は霊覚者の宣示のように、信念のあることばで云った。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、乞食すがたに身を窶した劉唐だの、飴売りの王｜矮虎だの、また、小粋な茶屋女に化けた一丈青と、顧のおばさん。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴売りの太鼓までが、哀歌のように寂しく流れてゆくのだった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからすぐ夫婦して大坂を立ち、道中の路銀とてないので飴売りの胴乱をかけて、子の乳となる妻の糧を、一銭二銭と働きながら、きょうやっと、小倉まで辿り着いたところだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼は、飴売りの胴乱を肩にかけた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴売り傀儡師　さきごろ、下加茂の茶荘へふたりの密使が訪れてきて以来、次いで、二条城、或いは所司代の千本屋敷へ、江戸からの密書密使のたえまがない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
