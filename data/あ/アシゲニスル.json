          "literary": [
            {
              "text": "じゃが枕を足蹴にするということがあるか。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを追繰返し、引繰返し、悪体交りには、散々聴せて、了局は口返答したと云つて足蹴にする。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　神さまが乗り移っている最中に私を足蹴にするような大それたやつは、今晩までの命も危ないぞ。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彼女の知っている範囲では、夫は始終飲んだくれていて、丁半が病みつきで、敗けるときまって彼女を足蹴にするのが癖だった）信者達の親愛は日毎に加わった。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯部の玄関にて生酔本性違はぬ処を示し、吾太夫を足蹴にするも面白し。",
              "citation": {
                "source": "明治座評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾太夫を足蹴にする処も、重左衛門に理窟をいふ処も性がある様でない様な工合実に妙なり。",
              "citation": {
                "source": "明治座評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不浄の家にいられるか」　と、やにわに足蹴にする。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武士たるものの魂を足蹴にするとは何事だ」「ナニ？",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
