[
  {
    "uuid": "7e4a37f8-f548-5289-8166-c3efb9eb597f",
    "entry": "粗々",
    "reading": {
      "primary": "あらあら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roughly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗々について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗々という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗々の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗々が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗々を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗々について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗々の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗々の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗々が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗々という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗々という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗々についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗々を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗々は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗々について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗々が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗々は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗々の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗々は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗々は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お組がその儀は心得た、という顔で、（後で閉めたんでございますがね、三輪ちゃん、お才はんが粗々かしく、はあ、）　と私達を見て莞爾しながら、（駆出して行きなすった、直き後でございますよ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黒い黄の交った粗々しい毛並には雨霧が降っかかり、内側の白い皮までがすべすべと冷えきって何か無気味な、その納壺の奥には網が網臭く積まれ、土間には赤子を負った赤い髪の目の大きな女の子が、ただむっつりと時化波の荒海を眺めている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗の木はいつしかガツシリした姿勢と粗々しい木肌とを持つた立派な一本立の木になつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体庭樹といふものの多くが、人間の好みに適応するやうに囚へられ、撓められ、造り替へられてゐるのに比べて、雑木はその持味の素朴さ、粗々しさ、とげとげしさの感じが失はれてゐないだけに、それにとり囲まれてゐると、どうかすると人をして山林の中に棲遅してゐるやうな幻想を抱かしめるものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って十五六にして「粗々技能有」と伝えられている位、師に対抗出来た小次郎は立派な達人であったらしい。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の輪郭は、人の不幸を同情なしに見ることに馴れている人たちのそれのように、硬くて粗々しかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "因ニ云フ、確乎タル証拠ナシト雖モ、旧来ヨリ言伝ヒ聞伝ヒヲ参考スルニ、山野等ノ名称粗々縁故アルモノヽ如クナレバ、記シテ後来ノ識者ニ俟ツノミ。",
              "citation": {
                "source": "尾瀬の昔と今",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな粗々しい仕方で嘘と顔を突き合わせたのは生まれてはじめてであった。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この白熊が自分を粗々しくなでまわしたり、怖ろしさで気が遠くなりそうな汚らわしい抱擁をするような時にも、その機嫌を損じまいと言葉の端々にまで気を配りながら、心にもない笑顔を作ったり強いて満足らしい身振りを取り繕わなければならなかった。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関で急に粗々しいベルの音がしたのである。",
              "citation": {
                "source": "マリ・デル",
                "author": "MARI D'ELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "止つてはまた二三間ほど粗々しく走つた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つてもそれは、いづこを指すともさだめのない、曠野の風みたいな粗々しいものには違ひなからうがね。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正に粗々っかしい人ね」　と台所へ窘めに行った。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ行って来るよ」「叔父さんは真正に粗々っかしいわね」　と八千代さんは千吉君の姿が門から消えた時、見たまゝの感想を洩らした。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚した顏、亂れた服裝（彼の上衣は、まるで取つ組み合でもして背中から裂けてしまつたかのやうにだらりと腕から垂れ下つてゐた）、絶望したやうな、蹙め顏、粗々しい逆立つた頭髮等は巧みに人相を變へてはゐたが、私にはロチスター氏であることが分つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方を殺さなかったところがお手柄さ」「落ちついているようだが、案外｜粗々っかしい爺さんだね」「しかしその頃は若かったのさ」「一体幾つだろう？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　コミックの女のように肩をゆすって彼女は立ち上ると、部屋の把手をあらあらしく廻した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあらしく頭を壁に押しつけてもがいた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "風起こりて木の葉あらあらしく鳴りつ、梢より落つる滴りの落ち葉をうつ音雨のごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当を言ったら、僕なんかあなたに怒られたら生きているかいもないんですからね」「あらあら、そんなこと」軽便鉄道の木でつくったシグナレスは、まるで困ったというように肩をすぼめましたが、実はその少しうつむいた顔は、うれしさにぽっと白光を出していました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所のおじさんの鳥さしが来て、私ン処の橋の詰で、榎の下で立留まって、六本めの枝のさきに可愛い頬白が居たのを、棹でもってねらったから、あらあらッてそういったら、叱ッ、黙って、黙って。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から見たまま振向きもしないで、急込んで、「あらあら流れるよ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあら、キャンキャンほえて、おこってる！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は、お前がいやになつた、とあらあらしく呟くのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあらしく手首をつかんで脈をしらべた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無表情の看護婦があらあらしく秤器をうごかす。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あらあら、惚れたの、おかしいなあ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると女は突然あらあらしく扉口の方へ出て行った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰彼の差別も容赦もあらあらしく、老若男女入りみだれて、言い勝ちに、出任せ放題の悪口をわめき散らし、まるで一年中の悪口雑言の限りを、この一晩に尽したかのような騒ぎであった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいと言い言い、あらあらかしくと書きおさめて、硯の蓋を重しに置いて出て行く。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
