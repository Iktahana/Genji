        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒々しさについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒々しさの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒々しさが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒々しさについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒々しさの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒々しさが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒々しさという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒々しさについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒々しさは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒々しさが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒々しさは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒々しさの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒々しさは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒々しさは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "非常な速さで、誰も掛声ひとつ発するものとてもなく、唯不気味な息づかひの荒々しさが一塊となつて、丁度機関車の煙突の音と聞違ふばかりの壮烈なる促音調を響かせながら、一陣の突風と共に私の眼の先をかすめた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な速さで、誰も掛声ひとつ発するものとてもなく、唯不気味な息づかいの荒々しさが一塊となって、丁度機関車の煙突の音と間違うばかりの壮烈なる促音調を響かせながら、一陣の突風と共に私の眼の先をかすめた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏの母には其樣な荒々しさが無い。",
              "citation": {
                "source": "烏帽子山麓の牧場",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨めな礦夫の生活をかいたもの、北海道の終身刑囚の脱獄、金龍館で、一時あれほど盛っていた歌劇団の没落と俳優たちや周囲の不良群の運命、等々――そのなかでも、離散した歌劇団の歌手たちに絡んだ、頽廃的な浅草の雰囲気を濃い絵具で塗り立てた作品の、呼吸の荒々しさと脈搏の強さには、庸三もすっかり参ってしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの作家によって意企されている美しい荒々しさというようなものが、八〇年代のロシア・インテリゲンチアの世界観に対して、新たな階級の感情として生れたゴーリキイの初期のロマンティシズムとは全く異った性質をもつものであると感じる。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の自分たちの身の上に蒙った生活破壊のおそろしい被害は、中国の婦人たちの上にどんな荒々しさでふりかかっていたかということを知らされた。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煉瓦女工」は、荒々しく切なく、そしてあてどのない日本の下層生活を、その荒々しさのままの筆力で描き出して、一種の感銘を与えた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに心の平静をこぼちほしいままな荒々しさや働きのない懶惰な気分のなかに住むことは、もっとも不幸に感ぜられます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの波止場人足や浮浪人、泥棒、けいず買い等の仲間の生活は、これまで若いゴーリキイがこき使われて来た小商人、下級勤人などのこせついた町人根性の日暮しとまるでちがった刻み目の深さ、荒々しさの気分をもってゴーリキイを魅した。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイの「幼年時代」（岩波文庫・米川正夫氏訳）には、一層荒々しさと暗さがむき出しな貧しい環境の中で人間的な稚い魂が目撃した恐怖と、それに対して闘った自立の精神の芽生えの雄々しさがある。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、吉村隊の惨虐を筆頭として、それに類する数々の軍国主義教育の荒々しさ、殺戮性への抗議として読者の心にアッピールした。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（のろのろとして居る和田）和田の不自然な緊張と荒々しさが自分の心を苦しめた。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声にも、身ぶりにも、眼の中にも、昔のやうな荒々しさは、二度と影さえも現さなかつた。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は、ぴいんと額に小石を投げられたやうな厭な気持ちで、おせいの荒々しさを眺め、階段を降りて行く、富岡の後へついて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒々しさが地べたから湧いて迫って来るような眺めである。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「社会的には体面も満足させる良人をもっていて、自分の気持に対してまで偽善的だったりしたら、あんまり通俗小説だわ」　若くて青年ぽい良心の自覚やそれを譲るまいとする荒々しさから宏子は、溢れそうな涙を無理やりのみ込んだ猛烈さで、飛びかかるように云った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、兄の十四郎の荒々しさを怖れると同じように、やはり私の眼も――。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきざしの荒々しさ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の魂の荒々しさが今さらのように感じられます。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂木曾は、ギフの方だろう、荒々しさ、くらさ、しつこさがある、ギフの方が。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、オーエンの所謂「あやまって支配されつつある者」の無智と荒々しさを、正しく美しく従順な性格にかえてゆこうとする「新見解」に重大な関心と魅力を発見した。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君のやうな若い人と話すことが大好きになつたよ」　木訥な青年教師は持前の荒々しさで闇の方へ振向いた。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女の作業が長い山の芋をムリにも引きぬくような無法な荒々しさになり、とうてい詩情のまじる余地がないと見てとって手を離した。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は武蔵野を散歩しながら、もはや人々の立ち去つたアトリヱへ戻つて、物憂い白昼をすごしながら、静かな夜をむかへながら、私の決意は然し激浪の荒々しさで秋子と私との結婚の事を追ひまはしてゐた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さういふことは分らないが、発作の後は、動作に神経病患者通有の荒々しさが現れたとか、性的に大胆な不道徳を現すやうになつたとかいふ噂はきいてゐるよ」　二九太は苛々した激しさで頷きながら、性急な語調でなほも質問をつづけた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪悪といふ内省が絶えないためか癇癪を起すやうな気分となり、自棄じみた荒々しさで無礼なくらゐ露骨に野蛮に蕗子の身体を取扱つても、意志のない人形のやうに自由になつた。",
              "citation": {
                "source": "雨宮紅庵",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに熊襲の武勇も荒々しさもこの土地にはなくて、あるとすれば熊襲の愛嬌の方だけである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「会ひません」　落付きにも拘らず、彼の言葉に、ぶつきらぼうな荒々しさが、ぬけなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは、本当にもう戦争はいやだし、人間らしくない怒号で狩りたてられることはいやだし、なんぞというとすぐ激昂する、あらあらしさはうんざりです。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、女が昨今のような社会の生産のために働いているとき、それと並んで女に対する封建的なあらあらしさが公然横行するとすれば、その何かの徴候として戒心されるべき社会的な意味があるのである。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
