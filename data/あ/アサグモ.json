  {
    "uuid": "3e56aab2-a4b1-5260-9e74-ce9b03133d99",
    "entry": "朝雲",
    "reading": {
      "primary": "あさぐも",
      "alternatives": [
        "ちょううん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "morning clouds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝雲の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたしは赤い朝雲のうしろに引きさがったのです」第十一夜「婚礼の祝宴がありました」と、月が話しました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "下秋の朝雲あさ燒くる、眞日の光の奇異しくも、あめつちなべて黄變して、草もゆるがぬ日を一日。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝雲を破る太陽の如く、深夜を掃照するサーチライトの如く、全篇の生気を一挙に躍動させ初めるのだから大したものである。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の朝雲は晴れた。",
              "citation": {
                "source": "妻",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国の深さを思わせるような朝雲が、見あげる山の松の梢ごしに奇しく眺められた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山越えに、××国の方へ渉ろうとしている学生は、紫だった朝雲が、まだ山の端に消えうせぬ間を、軽々しい打扮をして、拵えてもらった皮包の弁当をポケットへ入れて、ふらりと立っていった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は山崎朝雲氏が入門された時分のことになります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝雲氏は私の弟子となる以前に、もはや相当仕事が出来ていた人です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝雲君等と同じく手を取って教えた人ではない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹藪に伏勢を張ッている村雀はあらたに軍議を開き初め、閨の隙間から斫り込んで来る暁の光は次第にあたりの闇を追い退け、遠山の角には茜の幕がわたり、遠近の渓間からは朝雲の狼煙が立ち昇る。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "文子の父金井朝雲は、左門の古い政友であり、詩友であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金井朝雲はそのころ写真に凝つてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが朝雲の好みによつて、彼等が農夫であればその働いてゐる自然の姿を、また彼等が子供であればその遊んでゐる自然の姿を、彼等に予告することなしに撮すならはしを持つてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無意識を装ひながら意識してゐる彼等のつらさはなかつたのだが、朝雲は隠れをはせてゐるつもりか、一途に無念無想のていで、この上もない下手な手つきで延したり縮めたり長々と機械をいぢくつてゐるばかりである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の写真機が現れると、ちかごろは犬の奴もよけて通る」と、朝雲は笑ひながら言つてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左門が訪れていつたとき、暮方ちかい曇天の下で、折から朝雲は写真機をぶらさげ、ちやうど散歩から帰つてきたところであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "底冷えのする暮方ちかい庭に立つて、長々と機械をいぢくる朝雲のレンズの前に立ちながら、左門の思ひ得たひとつのことは、この暮れやうとする曇天のたそがれよりも、彼自身の行路の方が、すでに暮れてしまつたといふ悲しさだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左門はむしろ一思ひに金井朝雲を訪ねていつて、文子の事情を洗ひざらひ語つてをくのがよくはないかと考へた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い光を帯び乍ら、頭の上を急いだは、朝雲の群。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海より朝日差すところ朝雲高くそびゆる富岳をもって象徴せられた日本は滅亡した。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山のけぶるを見れば　思ふさびしさ朝雲雀　あまた啼きたつおほ野らに、休戦のらつぱ　ひゞきわたれりかけりつゝ、伏しつゝ思ふむなしさは、われくるしゑと　告げがたきかも雨あとの朝け　さやかなり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらがひの語を黙して　あまりさびしさ雪祭り　花祭り三河路の山のそゝりを　見つくして、新野平をくだり来にけり朝雲の流れするどき　をちの峰　霽れゆくを見て　くだり居るなり天龍の川ぞひ長く　歩み来し峡のなだりの　明るき紅葉花宿雪かたき谷をおり行く人ごゑの　あはれにひゞく　夜の山々大釜にたぎり来る湯や。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、陽はようやく、朝雲をやぶって、視界を仄かに染めていた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝雲龍寺を出発した請願の一行が、川俣で無理無体な阻止を受けた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をさまして、朝の勤めをすますと、きれいに掃かれた青蓮院の境内には、針葉樹の木洩れ陽が映して、初秋の朝雲が、粟田山の肩に、白い小猫のように戯れていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "・梅と椿とさうして水が流れてゐる・庚申塚や左は街へ下る石ころ・あさぐもりの垣根の花をぬすまうとする　太陽、生きものが生きものを殺す・寝覚しめやかな声はあたゝかい雨・ハムは春らしい香をかみしめる（樹明君に）　二月十七日サイレンが鳴る、お寺の鐘が鳴る、そしてしめやかな雨の音。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
