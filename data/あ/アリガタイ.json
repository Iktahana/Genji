        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有難いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有難いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有難いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有難いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有難いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有難いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有難いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有難いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有難いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有難いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有難いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有難いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有難いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有難いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有難いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有難いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有難いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有難いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有難いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有難いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "京都は嘗つて小生自身二年間ゐて、詩人にとつては有難い土地だと思つてゐるので、京都あたりからもつと面白いものが出てもよかりさうなものだと、かねがね思つてゐたが、仲々出なかつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ有難い仕合せである。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の御用聞きが現れて、何なりと御手伝ひしませうと云ふと、有難いが「あれを何処これを何処と、片附けるのは却々自分でないと分らないから」と、それをニコ／＼しながら、長々とやるのでその御用聞きはしまひには僕の顔を見て笑つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま考へると「おどさ」の有難いところばかり思ひ出され、残念でなりません。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま考えると「おどさ」の有難いところばかり思い出され、残念でなりません。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、他の事ではいざ知らず芸術では伝統といふものは大変有難いものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が八釜しいまで鳴いているが車の音の聞えぬのは有難いと思うていると上野から出て来た列車が煤煙を吐いて通って行った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先達て「歯」のことを書いた中に「硬口蓋」のことを思い違えて「軟口蓋」としてあったのを手紙で注意してくれた人があったが、こういうのは最も有難い読者である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういえば、それはそうであるが、何故にそれがそれほど有難いかはわれわれにはよくは分らない。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹名を書いた札のついてゐるのは有難いが中々一度見た位では覚えられさうもない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りに強い日常の刺戟に疲れたものゝ眼には此のやうな眺めが又なく有難い。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹名を書いた札のついているのは有難いがなかなか一度見たくらいでは覚えられそうもない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この発明はよほど有望で追々広く用いられるだろうという話、とにかく船嫌いには有難い福音である。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫はさほど有難いとも思わぬ様子でしたが、それでも嫌とは言わず、船の中へ隠れました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では、ただ頼みにする人、有難い人と思っている積りだが、心の底ではもう恋が成熟しきっている。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼はたいして有難いとは思わなかった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に特有なこの有難い公共設備の入口の暖簾を潜って中へはいると、先ず番台からかけられる声からが既によほどゆるやかなものである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この有難い設備と習慣とがなかったら東京市民の顔は今頃どんなものに変化しているだろう。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難い事には万物相関の影響は収斂級数で表わされ、履歴の影響は漸進的に消滅し、しかして人間の官能には限界が存している。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは実に有難い事である。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと見ていると、何かしら嬉しいような有難いような気がして来る。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理をしたくても出来ないという有難い状況に常住しているのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｔ「大吉が俺がまこと武士なら　先祖伝来の千五百石　戴いて、錦糸堀に　くすぶってるわ」　と言い放ち、更に、Ｔ「有難い事に　俺は武士じゃない」　半次が「武士でなかったら何ですい」　大吉、Ｔ「自由気儘の　悪たれ小僧よ」　言い度い事言って了うと大吉出掛けようとするので、　五郎蔵がとめた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくあれだけに行つてゐれば、原作そのものの内容は受け取れずとも、映畫的に面白いだけでも有難い。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、口ではちよつと云へない特種の強い匂ひは持つてゐるが、それはいい葉卷のやうな嬉しい薫りでもなく、また格別舌に觸れて有難い風味を持つてもゐなかつた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によるとこれは青虫でも捜しているのではないかと思われた、もしそうだとすると有難い訳だと思った。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし読者のうちでこの謎の意味を自分の腑に落ちるようにはっきり解説してくれる人があったら有難いと思うのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実におもしろい事で、また盛んなことで、有難い事で、意義ある事である。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして信州のひとも、伊豆のひとも、つつましく気がきいて、口下手の笠井さんには、何かと有難いことが多かった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ないほどありがたいことでした』と、その追懐談の中で沁々と語っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
