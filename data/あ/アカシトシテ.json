        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「彼品は船の上の人の帰り次第、それがしが其人に逢い、かくかくの仔細で、かくかくの場合に臨んだ、其時の証として仮りに持帰った、もとより御身の物ゆえ御身に返す、と其人に渡す。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は拍子嫌いの我儘流諸氏、もしくば地拍子天狗の諸氏にとっては共に不愉快な記事かも知れぬが、翁の歿後、翁の訓言が如何に強く響き残っていたかという例証としてここに掲げておく。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ印刷本と写本の外見が同一であることが、彼らの目には商業的成功の保証と同時に、技術的勝利の証として映ったのではなかろうか」　インターネットとリンクした電子本を作るためのすべての鍵を与えられながら、私は半年以上も新しい本の姿を確定できませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは結局、努力の絶えない堆積は、やがては物質上に変化を与える例証として、認識するに十分ではないか。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は相人の言葉のよく合う実証として、今帝の御即位が思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い例証としては、「待月」などゝいふ作品がそれであるこの作品は、後向立姿の婦人が月の出を待つてゐる図であるが、この作画の方法は大胆極まるもので画面の上から下まで、建物の柱を通じ人物の体を縱に両分してゐる構図なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて上に引いた至親の同姓婚を畜生が慙じて自害自滅したのが事実ならば、ある動物に羞恥の念ある証としてすこぶる有益だが、これを例に採ってことごとく同姓婚を行うた古人を畜生劣りと罵るべきでない。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこんな気持ちに対する反証として、よくロシアの啓蒙運動が例を引かれるようだ。",
              "citation": {
                "source": "広津氏に答う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも私は丁度同時にバージーンの修辞学を或る外国人から授かって、始終講義を聞いていた故、確かにその一部をバージーンから得たらしき（坪内君には聞いて見ないが、）『小説神髄』を余りに驚かなかったが、シカシ例証として日本の作物を挙げて論じられた処は面白くも読みかつまたお庇で蒙を啓いた処もある。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから千曳きの考証としては、この筆者のいわく、千曳とは凡そ大なる石を云へり、古事記に最後其妹伊邪那美命身自追来焉爾千曳石引塞其黄泉比良坂云々。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どんなことがどこへどう祟って行くか分らない一例証として、ちょいとその話をして見よう。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、母の将来の生活の幾分かの保証として、多少これに附加するところなければならぬ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三月二十二日）　大阪の雑誌『宝船』第一号に、蘆陰舎百堂なる者が三世｜夜半亭を継ぎたりと説きその証として「平安夜半翁三世｜浪花蘆陰舎」と書ける当人の文を挙げたり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も奇とすべきは、柏軒近視の証として、彼蘭軒が一目小僧に逢つたと云ふに似た一話が伝へられてゐることである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源家八幡太郎の子孫に武人の夥しきも、能力遺伝の実証として見るべし。",
              "citation": {
                "source": "徳育如何",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟我が人文のなお未だ鄙陋を免れざるの証として見るべきものなり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを、あるいは私の個性の自発を促した機縁として述べるか、あるいは私の議論の旁証として述べるかに過ぎないのです。",
              "citation": {
                "source": "婦人も参政権を要求す",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの問題については、以前から他の機会でしばしば述べていますから、今は略しますが、唯だ文化主義の学者たちが女子のためにこれらの要求を奨励される一証として次にリップスの言葉を引用して置きたいと思います。",
              "citation": {
                "source": "婦人改造の基礎的考察",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうでなければ、『古代丁抹伝説集』などの史詩に現われている妖術精神や、その中に、黴毒性｜癲癇性の人物などがさかんに例証として引かれている――そのくらいの事は、当然憶えてなければならないはずだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの例証として、最も多く読まれてるらしいドストエーフスキーの代表作を取ってみよう。",
              "citation": {
                "source": "作家的思想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃従来松山藩へ幕府から与えている領地家督相続の証として黒印ある書面（即ち将軍の御判物）悉皆を朝廷へ納付せよとの御沙汰があったので、それを入れたる長持を私がこの京都行のついでを以て保護して行けとの命を受けた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど予はその例証として、今日も猶予が胸底に歴々たる一場の光景を語らざるを得ず。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人々はみんな私の講演を聴いたものばかりで、いずれも私がここで述べた失望を打ち消すような事実を、反証として書いて来てくれたのである。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、該同盟の証として、イスパニヤ人の仇敵にして最悪の海賊たるオランダ人追放の件。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は透谷が友人に対して深厚なる同情を傾くるを常としたる人物なりしことの一証として左の事を語らんと欲す。",
              "citation": {
                "source": "透谷全集を読む",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（拙訳『実証哲学』下巻一〇二頁）　然るにコントは他の所に於ては、寧ろ分業を以て社会の優越性の徴証としてゐる。",
              "citation": {
                "source": "社会的分業論",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にその一々を贖いの過程と見て行けば、その贖いのための顕証として、歓喜の相をそこに多少とも示さねばならない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルシエヴイキ制度の腐敗や濫用や無能は、当然信頼の出来る働き手の欠乏が責任を負ふのだと云ふ屡々繰返されたボルシエヴイキの此の言葉が、ウソだと云ふ例証として、私は此の話をするのだ。",
              "citation": {
                "source": "死んだ魂",
                "author": "エマ・ゴオルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは英国と連合国に対し、正義の名において、彼らの宣言の実証として、彼ら自身の利益に沿って抗議の声を上げてきました。",
              "citation": {
                "source": "日本の全ての方々へ",
                "author": "マハトマ・ガンジー　Mahatma Gandhi",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもデスデモーナは、愛のあかしとしておくられたハンカチーフは、つまるところ一枚のものであるハンカチーフにすぎないのだということを、どうして見ぬかなかっただろう。",
              "citation": {
                "source": "デスデモーナのハンカチーフ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
