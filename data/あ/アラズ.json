[
  {
    "uuid": "b85ed13c-2c0c-5f35-b110-dd8c14f53ff5",
    "entry": "非ず",
    "reading": {
      "primary": "あらず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "not",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日非ずについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "非ずという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は非ずの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には非ずが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "非ずを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは非ずについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "非ずの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は非ずの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では非ずが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "非ずという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に非ずという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では非ずについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "非ずを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると非ずは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "非ずについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では非ずが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に非ずは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により非ずの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "非ずは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に非ずは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を忘れた時にも猶存するものは、作用に非ずして対象のみであり、斯かる時近時の芸術が方法的となり、恰かも結構な骨に紙の肉を張つたやうであることは、首肯出来る所であらう。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれが有害となる場合は必ずそれ自身が有害なるに非ずして、感傷が感傷に楯つき、性慾が性慾に楯つくからだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは神の御意に非ず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がかつて風流論を書き、風流生活、風流即芸術の茶道精神を唱導した所以も此処にあるし、句作を余技と認めながら、しかも余技に非ずと主張する二律反則の自己矛盾も、これによつて疑問なしに諒解できる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵に非ず債鬼に非ず「見よ！",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがこの園内に來れることは彼等の動物を見るに非ずわれは心の檻に閉ぢられたる飢餓の苦しみを忍び怒れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――郷土望景詩――虎虎なり曠茫として巨像の如く百貨店上屋階の檻に眠れど汝はもと機械に非ず牙齒もて肉を食ひ裂くともいかんぞ人間の物理を知らむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし人生は過失なるも、我が欲情するものは過失に非ず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ひて、迎へられんとには非ず、従ふことのみ学びとなるべく、学びて汝が品格を高め、そが働きの裕かとならんため！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火は、薪木の性と見え、時折、ぷちぱちと撥ね、不平そうに火勢をよじりうねらすが、寂莫たる天地は何の攪き乱さるる様子もなく、天地創ってこのかた、たそがれちょうものの待つ、それは眠るにも非ず覚めたるにも非ざる中間に於て悠久なるものを情緒に於て捉えようとするかれ持前の思惟の仕方を続けている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山海万里のうちに異風なる生類の有まじき事に非ず」と云ったとしてある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも日本の文壇が、過去に意味してゐる如き小説――自然派末派の流れをくむレアリズムの小説――が、到底本質上に於て詩と兩立できない文藝、詩を殺すに非ずば成立できない俗物主義の文藝であるのを考へ、君のために慄然たる杞憂を感じた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、これは諷刺に非ず、格言に非ず、一篇のかなしき物語にすぎず、されど、わが若き二十代の讀者よ、諸君はこの物語讀了ののち、この國いまだ頑迷にして、よき通事ひとり、好學の白石ひとりなきことを覺悟せざるべからず。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが身ひとつのための貪慾に非ず、名知らぬ寒しき人に投げ与えむため、または、かのよき人よろこばせむための金銭の必要。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが生まれいでし心は親兄弟、もしくは羅馬法皇が自分のために都合よく作り出せる所謂『神の心』には非ず。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕も矢張、牛肉党に非ず、馬鈴薯党にあらずですなア、然し近藤君のように牛肉が嗜きとも決っていないんです。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "年輩四十｜幾干、骨格の逞しい、頭髪の長生た、四角な顔、鋭い眼、大なる鼻、一見一癖あるべき人物で、其風俗は官吏に非ず職人にあらず、百姓にあらず、商人にあらず、実に北海道にして始めて見るべき種類の者らしい、則ち何れの未開地にも必ず先づ最も跋扈する山師らしい。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人独り居るは好ましきことに非ず、余は他の室に乗換へんかとも思つたが、思い止まつて雨と霧との為めに薄暗くなつて居る室の片隅に身を寄せて、暮近くなつた空の雲の去来や輪をなして回転し去る林の立木を茫然と眺めて居た。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからこの制度を改めるに非ずんば、千万言を費しても文化の普及と云ふことは駄目であります。",
              "citation": {
                "source": "農民文化といふこと",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非ず、この時、両国の雪。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "非ず、湖の冬を彩る、紅の二葉三葉。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「非ず、私が欲する処はの、熊にあらず、羆にあらず、牛豚、軍鶏にあらず、鰻にあらず。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て閣下の子分に非ずと雖も、また多少の因縁なきにしもあらず。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸楽を夢想すべき時代に非ず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国が日清戦争に於て日露戦争に於て、世界の歴史を飾るべき光栄ある大勝を得しは、兵器の力彼に勝りしが為にあらず、黄金の力彼より大なりしが為にも非ず、其最大原因は、我が勇敢なる祖先の伝へし日本武士魂が、遺憾なく発動せし結果に他ならず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはいへ、禍を隣人に及ぼすといふにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津の君も今は物もいはで彳めるを、玉枝の君と妾とは目見合せてをり、さすがに恐しからぬにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
