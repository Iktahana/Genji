        "examples": {
          "standard": [
            {
              "text": "私は毎日亜爾然丁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は亜爾然丁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には亜爾然丁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは亜爾然丁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は亜爾然丁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では亜爾然丁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に亜爾然丁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では亜爾然丁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると亜爾然丁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では亜爾然丁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に亜爾然丁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により亜爾然丁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "亜爾然丁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に亜爾然丁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もちろんそれはもう十幾年も昔のことであろうが、来月初めにはブエノスアイレスの大使館員に嫁いでいる娘さんを訪ねて、亜爾然丁へ出掛けるという。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "南米、主として亜爾然丁、ウルグァイ方面よりの来信電報すこぶる多く、二、三日前には、国境ヴェステルバーゲンの税関からも、厚い封書が三度ばかりきたことがある。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月早々｜亜爾然丁へ行くもクソも、あるものか！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか倶楽部で逢った時、亜爾然丁の娘のところへ行くといっていたのは真っ赤な偽りで、伯爵と一緒にモンテヴィデオへでも逃亡するつもりであったろう。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村は、なじみの男刈りにした肥っちょの娘と、独逸麦酒をしこたま飲んだあとで、アルゼンチン・タンゴを怪しげな身振りで踊っていた。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと忙しく説明し乍ら女は馴染みのタンゴ楽手のアルゼンチン人や友達の遊び女達の出入する度に挨拶の代りに舌を出したりした。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジル、アルゼンチン等に到りし話も聞きたれば、斯く思はるゝ也。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "現行書目にしも、英独仏露伊西以外、和蘭、瑞西、波蘭、瑞典、那威、澳太利、匈牙利、葡萄牙、墨西哥、アルゼンチン、将た印度、波斯、中央亜細亜あたりまでの各国書目を一と通り揃えていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜助にはそんな声なんか、アルゼンチンでしているようなものだった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、アルゼンチンにも、アメリカにも、こんなところはありませんよ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にアルゼンチンのサンタ・フェー（〔Santa Fe'〕）にいる、昔は戦争好きで今は平和なインディアンの一族アビポン人（Abiponer）や、また南アフリカのブッシュメン族（〔Buschma:nner〕）もかつて宇宙開闢の問題に思い及んだことはないようである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際ペンクラブ第十四回大会は、この年九月五日から十日間、アルゼンチン首府、ブェノスアイレスに開催され、日本からはじめて島崎藤村、有島生馬の二氏が代表として出席した。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゼンチンへ行き、そしてかえり、今日の苦しい世界を通って来た老藤村が、果してどのように洗われた感覚をもって、日本の自然を生活の間につかみ直すか、多くの関心を抱いているものの一人である。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、まあ、それほど志望者が多いもんだから、ちゃんと闘牛学校まで出来ていて、未来のベルモントを夢みる青少年の群――なかにはアルゼンチンあたりから留学してるのもある――に、初等闘牛史、怒牛心理学概論、闘牛道徳、闘牛作法、扱牛法大綱なんてのを講義したり実修したりしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゼンチンの国際ペンクラブの大会に藤村氏が出席したからには、能うかぎり進歩的効果のあげられることを、私たちはまじり気ない心持で希望している。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゼンチンに永くいて、南北のアメリカの広さを知っている筈の南が洩す嘆声だと思うと、矢代は、自分の激しかった驚きも、よほどこれで正しかったのだと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Revistra Geografica Americana――アルゼンチン地理学協会の雑誌だ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "南緯二十度から二十七度辺にまでかけ、アルゼンチン、パラグァイ、ボリヴィアの三か国にわたり、密林あり、沼沢あり、平原ありという、いわゆる庭園魔境の名のグラン・チャコ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、フォルモサの密林の北をながれて、ながらくパラグァイ、アルゼンチン両国の境界争いの場所だったことは、諸君も知っておることだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、国際法でいう先占の事実というやつが、パラグァイ、アルゼンチンのどっちにもない訳である。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先占を、一九三二年の夏の終りごろに、いよいよアルゼンチン政府が決行することになった。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "パタゴニア人に保護区政策をとれと、アルゼンチン政府と喧嘩をした……」　「知ってますとも。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには現にもう現われている種族があるといって……、アルゼンチン人の大部分である雑種児の血と、いま同国の南部、パタゴニア地方で、絶滅に瀕しつつあるパタゴニア人の血とを比べたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、アルゼンチン人にはある化石素が、パタゴニア人にはない。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三上は、それをアルゼンチン政府攻撃に利用して、パタゴニア人の減少は自然的な原因ではなく、冷酷なアルゼンチン政府が保護区をつくらずに、むしろ滅んでしまうのを願わしく思っているのだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな訳で、三上はアルゼンチン政府にたいへん憎まれておりました。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、たぶんアルゼンチンのどこかに秘密囚となっているのだろう――と、私はそう考えて南米へまいりまして、これでも、手を尽してどんなに探しましたでしょう」　額を支えた手で、卓子がかすかに揺れている。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゼンチン各所監獄を転々とした末に、政治犯四名とともに「蕨の切り株」へ連れてこられて機関銃弾で追われながら沼地へと追いやられた。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜Revistra Geografica Americana――アルゼンチン地理学協会の雑誌だ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
