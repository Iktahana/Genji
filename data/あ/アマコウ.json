        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日阿媽港について考えている。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は阿媽港の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には阿媽港が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは阿媽港について学習した。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は阿媽港の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では阿媽港が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に阿媽港という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では阿媽港についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると阿媽港は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では阿媽港が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に阿媽港は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により阿媽港の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "阿媽港は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に阿媽港は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この伊留満の一人に化けられたと云ふのは、正物のその男が、阿媽港か何処かへ上陸してゐる中に、一行をのせた黒船が、それとも知らずに出帆をしてしまつたからである。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗字は――さあ、世間ではずっと前から、阿媽港甚内と云っているようです。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内、――あなたもこの名は知っていますか？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えばつい二三年以前、阿媽港日記と云う本を書いた、大村あたりの通辞の名前も、甚内と云うのではなかったでしょうか？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただどうか阿媽港甚内は、世間一般の人間と余り変りのない事を信じて下さい。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なるほど阿媽港甚内に、こう云う事を頼まれたのでは、手軽に受合う気にもなれますまい。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内は、忍術を使う、――誰でも皆そう云っています。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ阿媽港にいた時分、葡萄牙の船の医者に、究理の学問を教わりました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ手短に事実だけ云えば、わたしは阿媽港に渡っていた時、ある日本の船頭に危い命を助けて貰いました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしにも、御尋ね者の阿媽港甚内にも、立派に恩返しが出来る愉快さは、――いや、この愉快さを知るものは、わたしのほかにはありますまい。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは阿媽港甚内と云うものです。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内は盗人ですが、今夜突然参上したのは、少しほかにも訣があるのです。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大十字架の星の光は阿媽港の空には輝いていても、日本の空には見られません。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でも御座いましょうが、この頃世上に噂の高い、阿媽港甚内と云う盗人がございます。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはあの阿媽港甚内に一方ならぬ大恩を蒙りました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ突然はいって参ったのは、雲水の姿に南蛮頭巾をかぶった、あの阿媽港甚内でございます。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう云われて見れば、かれこれ二十年にもなりましょうか、まだわたしが阿媽港通いの「ふすた」船の船頭を致していた頃、あそこへ船がかりをしている内に、髭さえ碌にない日本人を一人、助けてやった事がございます。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ればそれが今日では、あの阿媽港甚内と云う、名代の盗人になったのでございましょう。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに阿媽港甚内でも、そう云う金があるくらいならば、何もわざわざわたしの宅へ、盗みにはいるにも当りますまい。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうでございましょう、この頃｜往来の話を聞けば、阿媽港甚内は御召捕りの上、戻り橋に首を曝していると、こう申すではございませんか？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内の首ではございません。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも阿媽港甚内というのは、倅だったのでございましょうか？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしもあの阿媽港甚内に一家の没落さえ救われなければ、こんな嘆きは致しますまいに。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、わたしの曝し首は、阿媽港甚内と呼ばれるでしょう。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがあの阿媽港甚内、――これほど愉快な事があるでしょうか？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内、――どうです？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが阿媽港甚内なのです。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前宰相の伽羅を切ったのも、甲比丹「ぺれいら」の時計を奪ったのも、一夜に五つの土蔵を破ったのも、八人の参河侍を斬り倒したのも、――そのほか末代にも伝わるような、稀有の悪事を働いたのは、いつでも阿媽港甚内です。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内のほかに、誰が内裏なぞへ忍びこみましょう？",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽港甚内はこの首なのだ、あの天下に噂の高い、日本第一の大盗人は！",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
