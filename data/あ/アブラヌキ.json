    "definitions": [
      {
        "index": 1,
        "gloss": "pouring boiling water over fried dishes to remove excess oil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油抜きについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油抜きは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油抜きの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油抜きについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "油抜きは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油抜きの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油抜きに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油抜きが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油抜きを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油抜きの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油抜きが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油抜きが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油抜きについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油抜きは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油抜きは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油抜きは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油抜きについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "油抜きの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油抜きの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油抜きの理解が必須です。",
              "source": "幻辞"
            }
