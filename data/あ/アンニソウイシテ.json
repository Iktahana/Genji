[
  {
    "uuid": "420501d9-439e-56d6-986a-214ae9dc02cd",
    "entry": "案に相違して",
    "reading": {
      "primary": "あんにそういして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
