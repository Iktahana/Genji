    },
    "definitions": [
      {
        "index": 1,
        "gloss": "contrary to one's expectations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案に相違してについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "案に相違してという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案に相違しての意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案に相違してが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案に相違してを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案に相違してについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "案に相違しての使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案に相違しての定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案に相違してが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案に相違してという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案に相違してという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案に相違してについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案に相違してを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案に相違しては複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案に相違してについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案に相違してが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案に相違しては重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案に相違しての意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案に相違しては様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案に相違しては興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、案に相違して、惣兵衛ちやんは竹を下手くそに削つてゐるばかりだつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを看て取った政宗は案に相違して、何様にも乗ろう潮が無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが案に相違して火はますます熾んに燃え、蟇の苦悶は増すばかりであったから、さすがの五右衛門も、「助けてくれ、あッ、熱ウ、熱ウ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新米の古賀氏は何の「箙」ぐらいと思っていたのに案に相違して震え上った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄案に相違して、諸方に斥候を放つと、旭山城に謙信の伏兵あるを知り、茶臼山の陣を撤して海津城に入った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』以後の精神的及び物質的苦悶に富んだ二葉亭の半世の生活からは最少し徹底した近代的悲痛が現れなければならないはずであったが、案に相違して極めて平板な不徹底な家常茶飯的葛藤しか描かれていなかったのは畢竟作者の根本の芸術的興味が去ってしまったからであろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、差押へだとすると屹度執達吏が来るのかと思つてゐたが、案に相違して、洋服を着たその若い役員は、「ぢや差押へして行きます」と、云つた。",
              "citation": {
                "source": "差押へられる話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平のお殿さまからのお差し紙でござえますから、きっとまた何か突発したにちげえござんせんぜ」　しかし、案に相違して、そのお差し紙は、あすの吉例上覧お能に、警固のため出頭しろとのご命令書でしたから、ようやく納まりかかった伝六太鼓がまた鳴りかけようとしたとき――、今度はやさしくおとなう声がありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもこれが名人の口から飛び出せばもうしめたもんだから、すぐにもしりからげになって駆けだすだろうと思われたのが、案に相違してことごとくほっぺたをふくらませると、つんけんとそっけなくいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん、あのしいの木の下のうちですよ」　しかるに、その二階家の前まで行くと、表へいっぱいの人だかりがしているのみか、もうとっくにあばたの敬四郎が手配をつけてほとぼりもさめているだろうと思ってきたのに、案に相違して、中ではまだしきりにどたんばたんとやっているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案に相違して、高志はむずかしい顔で黙りこくっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままで行ったならば、日本の首都は今に大晦日の北京のようになりはしまいかと思われたが、案に相違して一時の現象で済んだのは芽出度い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人者の、やわら取りのというからは、どんな逞ましい強そうな男かと思えば、それはまだ廿二三歳の町人風で、色の小白い痩せぎすの、小二才とか青二才とかいいそうな、薄っぺらな男であったので、市兵衛も案に相違して、しばらく呆れてその顔をながめていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、案に相違して、林田でも、又他の同志でもなく、全く知らない中国人の顔だった。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は案に相違して、むしろ歯が浮くような厭味を感じた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は勝手元の廊下にある梯子段を上り、荷物の散らかっている上がり口の三畳を突っ切って、いきなり部屋へ躍り込んでみたが、案に相違して、そこには瑠美子と北山がいるだけで、清川の姿も葉子も見えなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館では、きっと昔の人のかいたいい作品が数多く観られることであろうと楽しみにして出かけてみたが、中へはいってみると案に相違して何もこれというほどの観ごたえのあるものがなかった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "案に相違して、ちやんと一等の乗車券と寝台券をポケットから出して見せたものだから、彼は無言のまま、渋々ながらも私のために寝台を用意してくれた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は明日にも、『さあ、これを持って行って、鱈腹のんだり、楽しんだりしろ』ってんで、何千という大金が貰えると思っていたのに、案に相違して、ただ待てというだけで、時期の指定もしてくれないという訳なんです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ですから卒業論文なぞも無論、その頃まで学術用語と称せられていた独逸語で書かれている事と期待されておりましたのに、案に相違して、その頃まではまだ普及されていなかった言文一致体の、しかも、俗語や方言｜混りで書いてあるのでした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は柏木の狭山といえば多分、誰でも私の職務上の名声を知っている筈だから、滅多な者は寄り付くまいと思って履歴書、身元証明不要と出しておいたのであるが、案に相違して碌なものはやって来なかったので、私は些かならず自尊心を傷けられたものであった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今度は案に相違して、その玻璃房は、二重屈折の三稜鏡だった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験に試験を重ねたタンクが、とつぜん戦線に驚異的に出現して、あの、前世紀動物のような、怪物的な鋼鉄製の巨体をゆるがせて猪突した時、案に相違して、ドイツ方はあまり愕かなかった。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをズッと鼻先へ出し、「お武家様え、火をひとつ」　案に相違して紋太郎は少からず閉口したものの貸さないということも出来ないので無言で煙管を差し出した。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が会議の席では案に相違して滔々と生徒厳罰論を述べたから、おや変だなと首を捩つた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが会議の席では案に相違して滔々と生徒｜厳罰論を述べたから、おや変だなと首を捩った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「案に相違して、あなたはこの船に二人も正直な人間を乗せましたね、――あの人とジョン・シルヴァーと。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし帳場では案に相違して、その電話はホテル外から懸ってきたんだという。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
