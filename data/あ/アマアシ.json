        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rain intensity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨脚について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨脚という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨脚の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨脚が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨脚を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨脚について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨脚の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨脚の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨脚が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨脚という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨脚という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨脚についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨脚を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨脚は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨脚について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨脚が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨脚は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨脚の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨脚は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨脚は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "東方を顧れば、箱根足柄にかぶさる雲から、雨脚のような光線が流れて、大裾野は扇の地紙のように、森や小阜の折目を正しくして、黄色に展開している。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばか……どこまで行くんだ……ばか、きちがい……小初……先生……小初先生……ばか……ばか……」　風の加った雨脚の激しい海の真只中だ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も見舞ひにくる者もない、さうした日の午後など、私は病後のうら寂しい氣持で窓際の椅子に凭りながら、靜かな雨脚を眺め暮してゐるのであつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武井さんが草花を買ひに行つた留守に、私は一人寢臺を靜に降りて、椅子に凭りながら烟るやうな雨脚を通して見える、向う側の病室をぢつと眺めてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風桜風にとぎるゝ雨脚や、　　　　　みだらにかける雲のにぶ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト、すぐ裏に田が見えて、雨脚も其処へ、どう／＼と強く落ちて、濁つた水がほの白い。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけ器用に忍びあしを使ひ、葉藏の枕元まで近寄つていつたが、硝子戸のそとの雨脚をまじまじ眺めてゐるだけであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面暗くして波浪上らず、雨脚矢のごとく湖上を打つ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきは雨脚が繁くって、まるで、薄墨で刷いたよう、堤防だの、石垣だの、蛇籠だの、中洲に草の生えた処だのが、点々、あちらこちらに黒ずんでいて、それで湿っぽくって、暗かったから見えなかったが、少し晴れて来たから、ものの濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく視めたが、牡鷄がパツと翼を拂いて、雨脚がやゝ繁く成つたから、歩行き出すと、蘆の根を次第高に、葉がくれに、平屋のすぐ小座敷らしい丸窓がある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れ落ちても雨脚は弱らなかった。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は大社の大鳥居のまえの居酒屋で酒を呑みながら、外の雨脚と小走りに走って通る様様の女の姿を眺めていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたびのれんをはじいて外へ出てみると、娘はいなくていっそうさかんな雨脚と、押し合いへし合いしながら走って通るひとの流れとだけであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨脚も白く、真盛りの卯の花が波を打って、すぐの田畝があたかも湖のように拡がって、蛙の声が流れていた。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきは雨脚が繁くつて、宛然、薄墨で刷いたやう、堤防だの、石垣だの、蛇籠だの、中洲に草の生へた処だのが、点々、彼方此方に黒ずんで居て、それで湿つぽくツて、暗かつたから見えなかつたが、少し晴れて来たからものゝ濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならばどしゃ降りのひと雨でもあって、これ等の非自然の花野が激しい雨脚に撩乱と踏みしだかれ、わたくしはまたフルスピードのハイヤーに乗っていて、この中を突き進む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い白い雨脚を見ながら、私は、昔の支那人の使つた銀竹といふ言葉を爽かに思ひ浮かべてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い白い雨脚を見ながら、私は、昔の支那人の使った銀竹という言葉を爽かに思い浮かべていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物音に交って人声も細ぼそと聞えてきたが、窓の外の雨脚に注意を向けている南の耳には入らなかった。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は面を染めて、影が袖に透る……霽れるどころか、次第に冷い雨脚から、三人を包んで、雫も落さない。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事な鮒よ、ぴちぴちと躍って、宙に雨脚を刎ねるようである。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨脚が他人のものゝやうに堅苦しく、痛かつた。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはたゞ一種異樣の感にうたれ、われ我を忘れて枯坐しけるに、雨脚はやう／＼我に遠ざかりて、軒より直下する點滴、水晶簾を下して、雨の名殘をとゞめ、空は早くも瑠璃をみがきて、一痕の凉月、御嶽の上にさやかなり。",
              "citation": {
                "source": "八鹽のいでゆ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地は陰鬱な雨脚で灰色になったガラス窓を背景にして突っ立ちながら、黙ったまま不安らしく首をかしげた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの音のすさまじさに縁側に出て見ると、庭さきから直ぐ立ち竝んだ深い杉の木立の中へさん／＼と降り注ぐ雨脚は一帶にただ見渡されて、木立から木立の梢にかけて濛々と水煙が立ち靡いてゐる。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "29日脚、雨脚、雲脚といふ。",
              "citation": {
                "source": "香ひの狩猟者",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい窓の明りのところだけ、四角に限つて、雨脚が見えた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「道理でガラドウ達がやつて来ないと思つたら……」　見霞む野面の果から、激しい雨脚の轟きの音が朦々たる雲を巻き起し風を交へやがては雷鳴を加へて疾走して来た。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と不意にその時奥の室の襖がサラリと開いたかと思うと、涼しい美しい女の声で、「まあまあしばらくお待ちください」と、呼び止めるのが聞こえて来た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
