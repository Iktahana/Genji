[
  {
    "uuid": "f1aeaf80-eb70-55ad-8d36-c83bd569a944",
    "entry": "雨脚",
    "reading": {
      "primary": "あまあし",
      "alternatives": [
        "あめあし",
        "うきゃく"
      ],
      "is_heteronym": true
    },
    "grammar": {
