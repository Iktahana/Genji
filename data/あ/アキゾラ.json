    "definitions": [
      {
        "index": 1,
        "gloss": "autumn sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "港市の秋石崖に、朝陽が射して秋空は美しいかぎり。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夏の終りに病後の一月餘りを過した時の事を思ひ浮べて、此處の晴れ晴れしい秋空を想像してはいけない。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の上にはまだ冷冷とした朝靄が罩め渡つて、雨上りの秋空は憂ひ氣に暗んでゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ると、灰色の秋空の下に、函館の町が一目に見える。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のほうのバックには構内の倉庫の屋根が黒くそびえて、近景に積んだ米俵には西日が黄金のように輝いており、左のほうの澄み通った秋空に赤や紫やいろいろの煙が渦巻きのぼっているのがあまりに美しかったから、いきなり絵の具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色夜叉中編のお宮は、この姿で、雪見燈籠を小楯に、寒ざきつゝじの茂みに裾を隱して立つのだから――庭に、築山がかりの景色はあるが、燈籠がないからと、故らに据ゑさせて、右の裝ひでスリツパで芝生を踏んで、秋空を高く睫毛に澄して、やがて雪見燈籠の笠の上にくづほれた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・陽がとゞけば草のなかにてほほづきの赤さ・つく／＼ぼうしもせつなくないてなきやんだ　　　改作追加・秋空の井戸がふかうなつた・雲が澄む水を汲むげんのしようこの花　九月五日秋晴、終日寝ころんで読む、牧水の紀行文集を読んでゐると一杯やりたくなる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月七日秋空一碧、けふも休養する。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "開店広告の赤い旗が、店々の前にひるがえり、チンドン楽隊の鳴らす響が、秋空に高く聴えているのである。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に絵画の鑑賞には、常に静かな秋空があり、澄みきった直感があり、物に動ぜぬ静観心と叡智の行き渡った眼光がある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、眼をさますと、秋空がたかく澄んでゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熙々として照つてゐた春の陽は何時か烈しい夏の光に變り、澄んだ秋空を高く雁が渡つて行つたかと思ふと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煕々として照っていた春の陽はいつか烈しい夏の光に変り、澄んだ秋空を高く雁が渡って行ったかと思うと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通の出入口へ、どっと潮のように馳り退いて、居まわりがひっそりする、と、秋空が晴れて、部屋まで青い。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突兀と秋空を劃る遠山の上を高く雁の列が南へ急ぐのを見ても、しかし、将卒一同｜誰一人として甘い懐郷の情などに唆られるものはない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "リング上で高々と右手を突き上げ、天井も落ちよとばかりに腹の底から搾り出す会心のダーッの叫びを、久しぶりに聞かせてもらったなあと、渋茶をすすりながら秋空にしみじみと思う今日このごろである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、あの鳴沢イト子さんの白布に包まれた美しく光る寝棺を見送ってから、僕はもう、マア坊だの竹さんだのの事はすっかり忘れて、まるできょうの秋空のように高く澄んだ心境でベッドに横たわり、そうして廊下では、塾生と助手が、れいの如く、「やっとるか。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥行手の丘々の彼方に大山脈の連峰が紺碧の秋空にくつきりときり立つてゐるＲ村は、その連峰の一つであるヤグラ岳の麓に蹲まつてゐるのだ。",
              "citation": {
                "source": "ピエル・フオン訪問記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りしも霽れ渡りたる秋空の下、町はづれなる林巒遠く夕陽を帯びたり。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、晴れた秋空を静かに見あげて、眩暈ひを覚えた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れに晴れ、澄みに澄んだ秋空のもと、濛々と立ち昇る白煙を草鞋の下に踏んだ時の心持をば今でもうら悲しいまでにはつきりと思ひ出す。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れ渡った秋空にその煙の靡いているのを見ると、続けて来た話を止めて、ツイ両人とも立ちどまってぼんやりと瞳を凝らさねばならぬ静けさが感ぜられた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりからお十三夜の豆名月は、秋空｜碧々として澄み渡った中天にさえまさり、宵風そよぐみぎわのあたり月光しぶく弁天の森、池面に銀波金波きらめき散って、座頭の妻の泣く名月の夜は、今がちょうど人の出盛りでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "吝ったれた兄哥　魚市場のすぐうしろにある、無線電信のポールを秋空高く仰いだ向う岸の築地三丁目以南、起生橋を中心としてベタ一面に並んだ店は、いかさま彼ら兄い連の御蔭で繁昌しているものと見えた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高層建築の上に濁った秋空が、茫漠とした観念のやうに横はってゐた。",
              "citation": {
                "source": "舌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの花火を私は、秋空の星雲と見紛ふたらしい。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は高く晴れた秋空を見、老衰した母親を見、小ざつぱりとした絣に着かへた自分の姿を鏡に映して見て、現實に我ものとなつた自由をたしかめることができた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
