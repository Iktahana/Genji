        "examples": {
          "standard": [
            {
              "text": "私は毎日菴羅について考えている。",
              "source": "幻辞"
            },
            {
              "text": "菴羅という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は菴羅の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には菴羅が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "菴羅を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは菴羅について学習した。",
              "source": "幻辞"
            },
            {
              "text": "菴羅の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は菴羅の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では菴羅が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "菴羅という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に菴羅という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では菴羅についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "菴羅を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると菴羅は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "菴羅について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では菴羅が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に菴羅は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により菴羅の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "菴羅は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に菴羅は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大千世界を見ること、掌中の菴羅果の如くすといふ程の意氣が無くてはならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんらくじにて、もりかねの、うたざらゑあり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんらも今あれアたとい東京へ行くにしたってはずかしい思いはしないに」と、ろくに手を通さない紋附や小紋のようなものを、縫い直しにやると言って、一ト背負い町へ持ち出して行かれたことなどを、くどくどと零した。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度でも、朝の内にいぢめられてゐた方がその日一日あんらくなやうな氣がし、泥でも藁繩でも打つかけられるままにされてゐる。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもお八つ時の出物が濟んでしまへば、無人あんらくのさかひだつた。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんらあ甕（油甕）、あんびん（水甕）、ちゅうかあ（酒｜土瓶）、からから（酒注）、わんぶう（鉢）、まかい（碗）、その他、壺、皿、徳利、花活、香炉、湯呑、等色々の小品が出来る。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんぽこは白く子供の顔はあんらくそうであった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだしゞゅう世の中がさわがしく、あるときはとおく都や江南の御陣へお出かけになったりしまして、いちにちとしてあんらくにおすごしあそばしたこともないのでござりますから、おなじはちすのうてなの上でいつまでも仲ようくらしたいとおのぞみになるのも、決してごむりではござりませぬ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁いっぱいの本だなに、むずかしい本がズラッとならび、部屋のまんなかには、大テーブルがあって、そのまわりに、ふかふかとしたあんらくいすが、いくつもおいてあります。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
