        "examples": {
          "standard": [
            {
              "text": "私は毎日アルバムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルバムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルバムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルバムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルバムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルバムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルバムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルバムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルバムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルバムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルバムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルバムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルバムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルバムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルバムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルバムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルバムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルバムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルバムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寫眞師がアルバムをひろげながらうるさく撮影をすゝめる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバム　（淺見淵氏）　平板な嫌ひはあるがその落ちついた筆致は作者がともかくあるところまでゆきついた人であることを思はせる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本の新鮮なのや褪色した黄色、裝幀本の菫がかつた褐色、それからアルバムの幅の廣い緑色など、それ等すべてのものが調和し、效果を上げ、それぞれの役割をしつつ、何一つ缺くるところのない全體を形づくつてゐるのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて写真屋のアルバムで知らぬ人の顔について同じような経験をした事はあったが、生まれて四十余年来自分の肩の上についている顔についてこんな経験をしようとは思わなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は一つ、私のアルバムをお見せしましょう。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客の接待にアルバムを出すというのは、こいつあ、よっぽど情熱の無い証拠なのだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にあしらって、ていよく追い帰そうとしている時に、この、アルバムというやつが出るものだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども君を、このままむなしく帰らせるのも心苦しくて、謂わば、窮余の一策として、こんな貧弱なアルバムを持ち出したというわけだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、家内が、その残っているわずかな写真を整理して、こんなアルバムを作って、はじめは私も、大袈裟な事をする、と言って不賛成だったのですが、でも、こうして出来上ったのを、ゆっくり見ているうちに、ちょっとした感慨も湧いて来ました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバムの最初のペエジには、たいてい、その人の父母の写真が貼られているものですが、私のアルバムにはそれも無い。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たいていのアルバムには、その持主の赤児の時の写真、あるいは小学生時代の写真などもあって興を添えているものだが、私のアルバムには、それも無い。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、このアルバムを見ただけでは、人は私を、どこの馬の骨だか見当も何もつかぬ筈です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、うすら寒いアルバムですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると芹川さんは、いきなり、いやっと言って私からアルバムをひったくってしまったので、私には、すぐははあと、気がつきました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に移り、彼らの隣の部屋に落ちつくと、明日子はぼくの持っていたレコードのアルバムを見て、聴かせてくれといい、フランクのピアノ五重奏とヴェトーヴェンの第八シンフォニイを掛けながら、三人で音楽の話などをした。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　智子は直ぐに立ってアルバムを出して来た。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も何かしら容易ならぬ不安を感じて、アルバムをめくる指さきがおののいた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小布施は先程から桂子の入つて来るのを足音で知つてゐたのに、わざと絵葉書のアルバムに眼をむけ続けてゐたが、かういはれると、眩しさうに眼を瞬いて、はじめて桂子を見上げた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君どう思ふ」　小布施はその証拠のやうにペラ／＼とアルバムの頁を繰つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故、今ごろそんなアルバムなんか持ち出してるの？",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アルバムは桂子が外国へ行つてる間、根気よく小布施によこした絵葉書を挟んで置いた部厚な集成である。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はその時の執念が、こんなに沢山の絵葉書の通信文の殆ど一つ一つにも一貫して通つてゐる、と小布施は今さらアルバムを桂子の前へ押しつけて云ふのである。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「むかしのアルバムを、繰りひろげて見ているような気がします。",
              "citation": {
                "source": "一問一答",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　しかし、いろ／＼合せて、もう千｜余枚を數へる印畫のアルバムを時｜折繰眺めるのは、樂く愉快である。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は洗面所で嗽いして、顔も洗わず部屋へ帰って押入れをあけ、自分の行李の中から、夏服、シャツ、銘仙の袷、兵古帯、毛布、運動靴、スルメ三｜把、銀笛、アルバム、売却できそうな品物を片端から取り出して、リュックにつめ、机上の目覚時計までジャンパーのポケットにいれて、朝食もとらず、「三鷹へ行って来る。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この助役さんは貴方へ一週間にいちどずつ、親兄弟にも言わぬ大事のことがらを申し述べて、そうして、四週間に一度ずつ、下女のように、ごみっぽい字で、二、三行かいたお葉書いただき、アルバムのようなものに貼って、来る人、来る人に、たいへんのはしゃぎかたで見せて、私は、涙ぐむことさえあります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきは寝てからも読むと見えて、そのアルバムを、蒲団の下にかくしていて、日曜の朝でございます、私は謙さんを起しに行って、そうして、そのアルバムを見つけ、謙さんは、見つけられて、たいへん顔を赤くして、死にものぐるいで私からひったくりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
