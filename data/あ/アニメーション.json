        "examples": {
          "standard": [
            {
              "text": "私は毎日アニメーションについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアニメーションの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアニメーションが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアニメーションについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアニメーションの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアニメーションが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアニメーションという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアニメーションについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアニメーションは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアニメーションが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアニメーションは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアニメーションの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アニメーションは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアニメーションは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして三つ目が、アニメーション。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰を落ちつけたのは、東京にある特殊効果専門のＣＭ制作会社、アニメーションスタッフルームです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、もともとがアニメーションの開発ツールとして生まれたディレクターは、文章の取り扱いには強くありませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルのいい音がさまざまに扱えて、アニメーションの再生ができ、外部のＡＶ機器が制御可能というのが、ここでいう「拡張」の中身だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな道具には、本の何千頁に相当する資料や、絵、アニメーション、音など、あらゆる形態の情報を収めておくことができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "映像と音のマジックを目指したアニメーション映画「ファンタジア」の制作に際して、ディズニースタジオは新しいステレオ音響システムの開発を予定していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラフィックス、音に加えて、アニメーションや動画、そしていつかは人の話す言葉までを取り扱い、五感に訴えるさまざまな情報を相互のマシン間でやり取りする環境を用意するためには、積み上げるべきソフトウエアの技術は山ほど数え上げることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一こまの計算に、まる一晩かかるありさまで、数秒のアニメーションを完成させるまでに大変な時間を費やすことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビットマップ方式による高解像度の表示機能を前提として、グループはウインドウ環境を備えた言語、スモールトークを開発し、マウスを組み込み、文字や数値にとどまらず、グラフィックスや音、アニメーションなどさまざまな形式の情報を取り扱う実験を繰り返していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドの背後には巨大なパネルスクリーンが備え付けられ、白黒の昔の恐怖映画にカラフルなオリジナルのアニメーションがちぐはぐに編集されているという実験映画じみたアバンギャルドなフィルムが上映されている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
