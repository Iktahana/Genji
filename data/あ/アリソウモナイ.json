        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有りそうもないについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りそうもないの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りそうもないが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りそうもないについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りそうもないの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りそうもないが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りそうもないという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りそうもないについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りそうもないは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りそうもないが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りそうもないは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りそうもないの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りそうもないは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りそうもないは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそういう処でも「絶対の自由」などという夢のようなものはおよそ有りそうもないようである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士が大小をさゝずに来たなどというのは、常識から考えても有りそうもないことですから、こゝの家で隠したと云う疑いはすぐにかゝる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時に家老の隠居があって、大層政治論の好きな人で、私が家老の家に行たらば、その隠居が、ドウも公武の間が甚だ穏かでない、全体どうも近衛様が爾うも有りそうもない事だとか、或は江戸の御老中が詰らないとか云うような慷慨談を頻りに云て居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共雑誌に出て居るのを見ただけではそう私のすくものでは有りそうもない。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は不可能を信ずる事は出来る、がしかし有りそうもない事を信ずる事は出来ぬ』と言うた人の心持ちと同じ所に居りますのじゃ」「それはあなたが逆説と呼ぶ所の事ではないのですか？",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            },
            {
              "text": "一代前の云い置きなどを歯牙にかける人はありそうもない。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューインガムを噛む税関吏の顔は日本人から見れば俳諧があるかもしれないが税関吏の胸の中には一滴の俳諧もありそうもない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋を穿いたんじゃありますめえか」　松吉の報告によると、その古着屋も師匠の家もみな平屋の狭い間取りで、どこにも隠れているような場所がありそうもない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし単に説の奇矯であり、常識的に考えてありそうもないというだけの理由から、この説を初めから問題ともしないでいたずらに嘲笑の的にしようとする人のみ多い事にも疑いをいだかないわけには行かなかった。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえかなり真空になってもゴム球か膀胱か何かのように脚部の破裂する事はありそうもない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは現在の場合結果の桁数を変えるほどの影響がありそうもないことは少しあたってみてもわかると思う。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一自分自身にさえ子供の時と今との連鎖を完全に握っている人はありそうもない。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "構造物の材料や構造物に対する検査の方法が完成していれば、たちの悪い請負師でも手を抜くすきがありそうもない。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様の御用とって、お前、医者じゃあなし、駕籠屋じゃあなし、差迫った夜の用はありそうもない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ八つの小池に、ほとんどうっちゃり飼いにされながら、毎年、池の面が散り紅葉で盛り上るように殖えて、種の系続を努めながら、剰った魚でたいして生活力がありそうもない復一親子三人をともかく養って来た駄金魚を、何か実用的な木っ葉か何かのように思っていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣鴨辺に弥勒の出世を待っている、真宗大学の寄宿舎に似て、余り世帯気がありそうもない処は、大に胸襟を開いてしかるべく、勝手に見て取った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何本目かの煙草に、火を点けながら、前川は実感をそのままに、「美和子さんなんかに、煩悶なんかありそうもないですがね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて何人も実験せずまた将来も実現する事のありそうもない抽象的な条件の下に行なわるべき現象の推移を、既知の方則から推定し、それからさらに他の方則に到達するような筋道は、あるいは小説以上に架空的なものとも言われぬ事はない。",
              "citation": {
                "source": "科学者と芸術家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、警察の思いつくのはこの程度で、まったくありそうもないが、それ以外の解釈もまだまだ信憑性がない。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずなお君に訴えようとするのは、とにかく僕の訴えをまじめに聞いてくれる者は、やはり君をおいてほかにありそうもないからだ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右近には立って行くだけの力がありそうもないので、閨に近い几帳を引き寄せてから、「もっとこちらへ持って来い」　と源氏は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の孟など、ありそうもない物が新しく支那で見出されて学者を驚倒させた例多く、支那の生物はまだとくと調査が済まない。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「持ち歩いているなど、ありそうもない。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸考えると、ありそうもないこういうことが現実に存在する。",
              "citation": {
                "source": "科学の精神を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本の方でも礼を言って、二度と来て見る機会のありそうもないこの下宿の主婦にも別れを告げた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しにそんな、先に人家のありそうもない、野中の畦路のような個所へ乗り入れようとしたのか――追跡者二人は、ぼんやり顔を見合わせて停ち止まっていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "めつたにありそうもない場合だが不可能とは云えない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーロック・ホームズ曰く『全くありそうもないことでも不可能な事柄を全部ある事実からひき去つた後に残つたことは、真に起つた事実と考えなけりやならん』とね」「じや君は犯人二人説をとるのかい」「ところが簡単にそうはいかない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからひろ子が母を殺すなどということはありそうもない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この偶然は決して、ありそうもない、めつたにあることじやない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
