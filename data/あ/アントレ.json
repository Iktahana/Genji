        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アントレについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アントレという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアントレの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアントレが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アントレを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアントレについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アントレの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアントレの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアントレが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アントレという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアントレという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアントレについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アントレを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアントレは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アントレについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアントレが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアントレは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアントレの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アントレは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアントレは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御主人が今朝の散歩にそれを持って梟山へお出掛けになっている以上、まだお読みになってはいなかったんでしょう……」　大月はそう言って、再び考え込みながら、アントレーの鳥肉を牛の様に噛み続けた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アントレアを過ぎ、ヴィポリの町で招かれて私たちはヴァンテカイネン氏の客となる。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寿　　アントレエ！",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アントレ」　と、低い声が聞えた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アントレまでは、さっきのきまりどおりよ」「じゃ僕が葡萄酒とデセールをうけもつ」　つましい献立ながら、商談をしながら、それでもパリ市民らしく、昼飯を味っている中年の男女がこみあっている店内には、やすものの葉巻の匂いが立ちこめていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式な晩餐はオードブル、アントレ３皿、ロースト２皿、デザートの７コースからなっていた(7)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八二〇年か二一年ごろ、アントレピードという小さな定期｜編纂物を当時編集していたジャンリー夫人が、プティー・ピクプュスの修道院の一室にはいりたいと願ってきた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレートにはアントレのほかにご飯が三スクープにサラダが一スクープつきますというワン・センテンスが、プレート・ランチ・メニューの下に書いてあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、グリル・チキン、スパゲティ、ピカタ、アントレコット等、行く度に色々食ったものであった。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時半食堂へ、流石此処のはうまい、オルドヴルからアントレー二皿その他色々コーヒー迄一と通りコースを辿ったが何となく堪能しなかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
