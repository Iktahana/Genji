[
  {
    "uuid": "67a92329-286f-524e-a521-b8a3ebcbad34",
    "entry": "網元",
    "reading": {
      "primary": "あみもと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "traditional fishing master (provided equipment and sometimes lodging in exchange for labor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網元について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網元という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網元の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網元が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網元を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網元について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網元の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網元の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網元が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網元という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網元という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網元についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網元を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網元は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網元について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網元が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網元は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網元の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網元は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網元は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "網元を「ムラギミ」と云って、そこの親爺の、嘉平と利吉という二人が、ガミ／＼子供を叱りつけた。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年、網元の嘉平と利吉は、落ちぶれて死んじゃったが、その時は気持がよくって胸がすっとした。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松葉屋』も、『網元』も、『庄屋』も、証拠不十分で不起訴になった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、何くわぬ顔をしていた米は、五稜郭に近い某と云う網元の妾になった。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時網元の主人は、先妻を亡くしているうえに子供もないので、子供が生れたなら本妻になおすつもりをしていた。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網元の主人は非常に喜んで、出産の日を待っていたが、米の妊娠は真箇の妊娠でなくて、病名も判らない奇病であった。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網元の主人が火鉢の傍でうつらうつらしていると、米の姿が見えて来て何か云ってしきりに謝った。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由良の漁場では東京の網元が焼失してしまっており、網の修繕が出来ず、油も高くて来ないところへ、復員の子が一人増し、米は何としても久左衛門の家から都合をつけずにはいられない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも××の海岸にズラリと軒を並べている※友とか｜○金とかいう網元へ船を漕ぎ付けた漁師が、仕事をさしてくれと頼むかね……そうすると店の番頭か手代みたような奴が、物蔭へ引っぱり込んで、片手で投げるような真似をしながら「遣るか」と訊く。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした各地の網元の背景には皆それぞれの金権、政権が動いているのだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小網元の倒産が踵を接して陸続する。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……売る奴は大抵炭坑関係かその地方の人間で、買う奴は専門の仲買いか、各地の網元の手先です。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は網元をして田地も可なりあったが、みな飲んでしまったそうである。",
              "citation": {
                "source": "初秋海浜記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "正覚坊の像がいよいよでき上がった夕方、平助は村の網元の家へ行って、そこの御隠居に、一部｜始終のことをうち明けました。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人達は、網元の御隠居から平助の話をきかせられて、大変気の毒がりました。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「網元の家にゴロ／＼して、漁師ですよ」「そうか」男はタバコを吸って考えていたが、「キミの原稿を本にするわけにはいかないが、どうだい、ここで働いてみないか」「あなたは誰ですか」「社長さ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "左近が泊りこんでいる網元もこんな口の達者な親方で、泣き落すのと脅かすのとの中間ぐらいの適当な言葉で野郎どもを働かすのに妙を得ている。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "由之はすでに武道教師をやめて、網元、船元であり、新興実業家でもあれば、顔役でもあった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の村長は昔から選挙の習慣があったそうだし、網は共有であって特定の網元はなく、土地も共有であったという。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便配達の三三さん、小坪で網元といわれている吉兵衛、その息子の吉青年……その辺が画室の常連だが、そういう組合せでは、いたずらに煩わしいばかりで、精神を高めてくれるような、なんの寄与もしない。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこってことは、いえねえが、おれが掘出したんだ」　見識だといいたいところだが、眼も素養もない二十三の網元の伜に、味の深いこの美しさがのみこめようわけはない。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "金十郎は宮古に腰をすえ、網元の帳付の手伝いをしながら、消息をたずねまわったが、その年の暮までには、たよりらしいものも聞かれなかった。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "へエ、生れは行徳で、親は網元でございました」「道樂に身を持崩して、東海坊の弟子になり、大法螺の相槌を打つてトウセンボウとか名乘つたんだろう」「へエ――」　日頃にもない平次の舌の辛辣さ、定吉の東山坊は面目次第もなく頭を下げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小樽時代に増毛の網元の娘と正式に結婚した。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと可哀想なのは細君で、一ぺんも便りをよこさないといって、増毛の網元の親爺さんがおこっていたが、みんな途中で取られてしまったらしい。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘエ、生れは行徳で、親は網元でございました」「道楽に身を持崩して、東海坊の弟子になり、大法螺の合槌を打ってトウセンボウとか名乗ったんだろう」「ヘエ――」　日頃にもない平次の舌の辛辣さ、定吉の東山坊は面目次第もなく頭を下げました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "加部小ツルがチリリンヤ（腰にリンをつけて、用足しをする便利屋）の娘であり、木下富士子が旧家の子どもであり、ヘイと返事をした香川マスノが町の料理屋の娘であり、ソンキの岡田磯吉の家が豆腐屋で、タンコの森岡正が網元の息子と、先生の心のメモにはその日のうちに書きこまれた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "網元の森岡正が、正らしい考えで、「そんなら先生、船できたら。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは網元だからこれからだって毎年いくでしょうがね。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヤノの婚家は村の網元をしている家であった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
