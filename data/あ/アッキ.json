        "examples": {
          "standard": [
            {
              "text": "毎日、悪鬼について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の悪鬼戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "悪鬼の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "悪鬼という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは悪鬼について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "悪鬼の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "悪鬼に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは悪鬼を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での悪鬼は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、悪鬼は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "悪鬼は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な悪鬼を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪鬼」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "感覚だけの人間は、悪鬼に似てゐる。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝かつても自分に殆んどない要素である故遂に推察出来ず、疑心悪鬼を生じ、芸術家を憎むに到る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚だけの人間は、悪鬼に似ている。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の井戸の底には、埃が溜つてゐる事も何も忘れ去つて、泥んこの水の中を、四つん匍ひになつて匍ひ廻り、こねまはして、「水が飲みたあい」と怒鳴りながら帰つた時は、おふくろが、洗濯を思ひ出さざるを得ない、悪鬼羅刹の形相に化し終つてゐるのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の心は悪鬼のやうに憂欝に渇いてゐる。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の心は悪鬼のように憂鬱に渇いている。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイアボロス、ベリアル、ベルゼブル、悪鬼の首、この世の君、この世の神、訴うるもの、試むる者、悪しき者、人殺、虚偽の父、亡す者、敵、大なる竜、古き蛇、等である。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪鬼どもが彼の手下である。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタンでは無くとも、その手下に悪鬼というものもあった筈だ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊村君は、私を、その召使の悪鬼だと言おうとして、ものを知らぬ悲しさ、サタンだと言ってしまったのかも知れない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書辞典に拠ると、「悪鬼とは、サタンに追従して共に堕落し霊物にして、人を怨み之を汚さんとする心つよく、其数多し」とある。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、あなたにこんなに看破されて、こんな、こんな、」まぬけた悪鬼なんてあるもんじゃない、と言おうとしたのだが言えなかった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまいましくて仕様が無いから、いろいろ研究しているのですが、いったい、悪魔だの、悪鬼だのというものが此の世の中に居るんでしょうか。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悪魔でも悪鬼でもない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私達二人は生きながら悪鬼となって、人情を軽蔑したあなたを始め、釈迦仏教団の人々に向って生々世々怨みをなすが、これは如何だ？",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い世界にただ一つや二つの悪鬼｜羅刹の姿を増そうとも、仏の御目にそれが何の障りをなすものぞ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）神職　いよいよ悪鬼の形相じゃ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "来れる二個の眷属は三界無宿の非人にて、魔道に籍ある屠犬児、鳩槃荼、※舎闍を引従え、五尺に足らざる婦人ながら、殺気｜勃々天を衝きて、右の悪鬼に襖を開けさせ、左の夜叉に燭を持たせ、栄華の空より墜落して、火宅の苦患を嘗めつつある綾子を犯す乞食お丹、自堕落の態引替えて悪魔の風采凜々たり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鬼、畜生、夜叉、悪鬼、毒蛇と言わるる私が身に、袖とて、褄とて、恋路を塞いで、遮る雲の一重もない！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪鬼の面を見たからであった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったら、微笑が、そのまま凍りついて、みるみる悪鬼の笑いに変っていった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つたら、微笑が、そのまま凍りついて、みるみる悪鬼の笑ひに変つていつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、くやしい」と、それはそれはひどくお怒りになって、さっそく女の悪鬼たちを呼んで、「さあ、早く、あの神をつかまえておいで」と歯がみをしながらお言いつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の悪鬼たちは、「おのれ、待て」と言いながら、どんどん追っかけて行きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲生氏郷自ら長槍を揮って戦い、胸板の下に三四ヶ所｜鎗疵を受け、十文字の鎗の柄も五ヶ所迄斬込まれ、有名な鯰尾の兜にも矢二筋を射立てられ乍ら、尚も悪鬼の如く城門に迫って行ったとあるから、兎に角強いものである。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逃がすものかい」　広巳は悪鬼のようになって追っかけた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "骸骨の形をして脅すような容貌をした悪鬼の姿や、そのほか実に恐ろしい画像などが、一面にひろがって壁をよごしていた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "右へ――左へ――遠く広く――悪鬼の叫びをあげて！",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその色彩がいまや驚くほどの強烈な光輝を帯びて、しかも刻一刻とその光輝を増し、その幽霊のような悪鬼のような画像を、私の神経より強い神経をさえ戦慄させるほどの姿にしたのだ。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いついらっしゃったんです、　さあっきっからあすこに居たんですか。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
