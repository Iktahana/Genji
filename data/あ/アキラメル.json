    "definitions": [
      {
        "index": 1,
        "gloss": "to give up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もしこの上にして育たぬようだったら、山よ、わたしは諦める。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつでも、そのことについては諦めることが出来る。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど民子は私にそう云われて見れば自分の身を諦める外はない訣だ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「そうだ、綺麗さっぱり諦めるんだ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "にがく笑って、これが世の中、と呟いて、きれいさっぱり諦める。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチというと相方かな（これはしまったと思って、渡瀬は素早く奥さんの顔色を窺ったが、案外平気なので、おっかぶせて言葉を続けた）相手かな……相手になれないと諦める気ばかり先に立つのです。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って死ぬのを嫌がっても、人間は死ななければならないので、何とかして諦める理由を考え出します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力勉強して切って廻し、それで出来なければ諦めるだけのことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども被告となつて見たら云ひたい丈のことを云ひたくもなるであらうし、云ひ尽した上の判決なら仮令判決が無理だと思つても諦めることが出来るであらう。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、市郎は容易に諦めることは能なかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、諦めると言えば嘘になる。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それで、私の周囲の人々は、私にあの人を諦めるようにといろいろ説いて聞かせ初めました。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを諦める、といふほど積極的に気を働かす女でなく、いつもその儘、その儘のところに自分を当て嵌めた生活を、ひとりでにするたちの女だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という細君の言葉は差当って理の当然なので、主人は落胆したという調子で、「アア諦めるよりほか仕方が無いかナア。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウム、諦めることは諦めるよ。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それを思った時、はっきりあの人を諦めることが出来ました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう諦めるより外仕方がありません。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはおまえの肉体も諦めるし、わたしの結婚の申込なぞ、おまえがいろ／＼探して試みてよいところが見付からず、最悪の場合に転げ込む休息所として、数多い中に一枚加えといて呉れゝばそれで有難いと思っている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、幼稚でも済んだ昔なら仕方がない、諦めるさとまたいう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても考えてみれば、四谷左門の娘御が、楊枝店の雇女になるなんどは、これも時世時節と諦めるか。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当座はどの人にも未練があって、きょうは何処からか便りがあるか、あすはふらりと帰って来るかと、そんなことばかり言い暮らしていたのですが、それもふた月と過ぎ、三月と過ぎ、半年と過ぎてしまっては、諦められないながらも諦めるのほかはありません。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、一年過ぎ、二年を過ぎて、近江屋の夫婦は諦められないながらに諦めるのほかはなかった。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "義助もまったく諦めるのほかはなかった。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、消極的に命なりと諦める気持とは大分遠い。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに運の尽きと諦めるさ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長、園井、自分、この三人しか社にいなかったが、園井はもはや昇給のことは諦める気持を十年養って来て、いまはもっと大きな野心で、ふくれあがっている。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "村口多鶴子を諦めるのは未だ早いと思ったのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで吾々も昆虫と同様明日の事など心配せずに、その日その日を享楽して行って、一朝天災に襲われれば綺麗にあきらめる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういう事もありませんが、なにしろ不慮の災難だからあきらめるよりいたしかたがありませんよ……」「けれど、なぜ鳥のまねなんぞしたのでございましょう。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のジャーナリズムに不満をいだく人はかなりに多いようであるが結局みんなあきらめるよりほかはないようである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
