  {
    "uuid": "1523bc37-58fe-5c2d-b9a6-d3609142ac36",
    "entry": "洗い",
    "reading": {
      "primary": "あらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
