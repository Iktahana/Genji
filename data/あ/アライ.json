        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "斯の如き男にとつて、世間は荒いか、さもなくば衒学的に思はれたであらう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪交りの荒い頭髪は何時も三四分位に刈揃へられ、さうした顔面の上に「ワ」の字型に懸つてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方を仰ぐと、赤沢岳が無器用な円頂閣のように、幅びろく突ッ立って、その花崗岩の赤く禿げた截断面が、銅の薬鑵のような色をして、冷めたく荒い空気に煤ぶっている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は荒い毛の獣の皮を着ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後も、男は、得意の弓矢の業をもって、麓に住む荒い獣を半殺しの程度にして狩り取り、湧玉の水のほとりに待受けていて、女を見ると、屠り殺した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくしてもまだ口ではいい出せず、弓矢をもって代弁させなければならない、荒い男の高ぶった憶しごころを女ははじめて憐れとみた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはこの前の湾のところだけ泳いでいましたがそのうちだんだん川にもなれてきて、ずうっと上流の波の荒い瀬のところから海岸のいちばん南のいかだのあるあたりへまでも行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらすなおに私たちに貸し、自分はまた上流の波の荒いところに集っている子供らの方へ行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると子供らは、その荒いブリキ色の波のこっち側で、手をあげたり脚を俥屋さんのようにしたり、みんなちりぢりに遁げるのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、もう私たちはすっかり川の心持ちになれたつもりで、どんどん上流の瀬の荒い処から飛び込み、すっかり疲れるまで下流の方へ泳ぎました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘り取るのが済んであの荒い瀬の処から飛び込んで行くものもありました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横縞のうちでも縞の荒いいわゆる碁盤縞は「いき」の表現であり得ることがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしケープからシドニーへの荒い旅路は遂に彼の南洋行を思い止まらせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの砂山を越えて遠い長い渚を歩いたりして荒い日本海をも紹介した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒いブラッシの使いようである。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重硝子の窓の外には、きつきつたる肌ざわりの荒い岩のような、黒竜江の結氷が星空の下に光っていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　副官が這入って来ると、彼は、刀もはずさず、椅子に腰を落して、荒い鼻息をしながら、「速刻不時点呼。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井翁は綿服ながら小ザッパリした衣装に引きかえて、この老人河田翁は柳原仕込みの荒いスコッチの古洋服を着て、パクパク靴をはいている。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この縞はたぶん紙を漉く時に繊維を沈着させる簾の痕跡であろうが、裏側の荒い縞は何だか分らなかった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮屈な坑道の荒い岩の肌から水滴がしたゝり落ちている。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干潮で荒い浪が月光に砕けながらどうどうと打ち寄せていました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の児が一人いて、なにか荒い遊びをしているらしかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を稽古する人が上達するに従ってだんだん荒い馬を選ぶようになる心理もいくらかわかったような気がする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だからこそ、これに菓子を与え、おかゆを作り、荒い言葉一つかけるではなし、腫れものにさわるように鄭重にもてなしてあげたのだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、普段は、とても気軽な、さっぱりしたひとなのですが、かっと興奮すると、聞いて居られないような極端な荒い事ばかりおっしゃるので、私は悲しくなります。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはこの前の湾のところだけ泳いでゐましたがそのうちだんだん川にもなれて来て、ずうっと上流の波の荒い瀬のところから海岸のいちばん南のいかだのあるあたりへまでも行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらすなほに私たちに貸し、自分は又上流の波の荒いところに集ってゐる子供らの方へ行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が足をあらい水はつめたく陽は射している。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の空気は陰鬱で重くるしい、田舎の手触りはざらざらして気もちがわるい、わたしはときどき田舎を思ふと、きめのあらい動物の皮膚のにほひに悩まされる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
