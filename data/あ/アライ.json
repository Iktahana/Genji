    },
    "definitions": [
      {
        "index": 1,
        "gloss": "washing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗いについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗いという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗いの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗いが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗いを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗いについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗いの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗いの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗いが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗いという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗いという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗いについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗いを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗いは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗いについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗いが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗いの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗いは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗いは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "塵埃にくすぶった草木の葉が洗われて美しい濃緑に返るのを見ると自分の脳の濁りも一緒に洗い清められたような心持がする。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労も不平も洗い流して蘇ったようになって帰る暗闇阪は漆のような闇である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日よりの疲れ一時に洗い去られしようにてからだのび／＼となる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手洗い口すゝぎなどするうち空ほの／″＼と明けはなれたるが昨夜の雨の名残まだ晴れやらず、蚊帳をまくる風しめっぽきも心悪からず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶ヶ岳から短沢へ下りて来た自分は、先ずこの清い流れに嗽ぎもし、頭も洗い、顔も拭いた、気が遠くなるような悪臭の蕕草を掻き分けたことや、自分の肩から上を気圏のように繞ぐっていた蚋の幾十｜陣団やに窒息するかと苦しんだことも、夢の谷へ下りては、夢のように消えて、水音は清々しい。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シバヤナギ、タチヤナギ、いろいろな名があろう、幹の皮は、皺だらけで、永年洗い落したことのない垢……青苔が、厚くこびり粘いている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この板を適当な酸で洗えば、還元した銀は洗い落されるから青い粒の裏だけが透明になる。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはそれを汀まで持って行って洗いそれからそっと新聞紙に包みました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底の泥などは潮流に洗い流されて岩があらわれています。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はいつの間にか来ていて、昨日の雨で洗い流した赤土の上に、二葉三葉銀杏の葉の落ちるのを拾っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めに己が洗い浚い饒舌ってしまって、それから向うが話し出した。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスボロス海峡で過去の汚いものを洗い清めて東西の国境に足をまたげ、土耳古の空を見上げたときは現代の世界が実業家によって支配されるってことが非常に僕を得意にしてケマル・パシャが尻に錨をつけて黒海を泳ぐさまさえ可笑しかったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五時頃、会社が引ける時分になると、急に起きて、髪を直し、顔や耳を石鹸で洗いたてて化粧をした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた茶碗を洗い、土のついた芋の皮をむいた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昭和十一年建てられた当時、墨の色もはっきりと読取られたものであるが、軟かい石の性質のためか僅か五年の間に墨は風雨に洗い落され、碑石は風化して左肩からはすかいに亀裂がいり、刻みこまれた字は読み難いほど石がところどころ削げ落ちている。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年兵の食器洗い、練兵、被服の修理、学科、等々、あとからあとへいろ／＼なことが追っかけて来るのでうんざりする。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いが、もとは相当にものが良かったらしい外套の下から、白く洗い晒された彼女のスカートがちらちら見えていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が家の横なる松、今は幅広き道路のかたわらに立ちて夏は涼しき蔭を旅人に借せど十余年の昔は沖より波寄せておりおりその根方を洗いぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今夜のお徳に取り分けて侘しくきこえて、洗いざらしの単衣の襟がなんだか薄ら寒く感じられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、仕出し屋のことですから店には洗い場があって、そこには大きい内井戸がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が過ぎても、かれは白地一枚のほかには洗い替えの浴衣すら持たなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ十分というわけには行きませんが、少しは種を洗い出して来ました」と、多吉は得意らしく云った。",
              "citation": {
