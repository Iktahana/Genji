    "definitions": [
      {
        "index": 1,
        "gloss": "enthusiast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末になると、全国からクラシックカーの愛好家たちが自慢の愛車を駆ってこの広場に集まってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は熱心な切手愛好家として知られ、国内外のオークションで希少な逸品を熱心に探し求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この登山ルートは険しい岩場が連続するため、十分な装備を整えた熟練の愛好家にのみ推奨される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新製品の発表を控え、カメラ愛好家のコミュニティでは新機能に関する期待と予測が飛び交っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近は若い世代の間でも、デジタルにはない温かみのある音色を求めて、アナログレコードの愛好家が増えているようです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は熱狂的な観劇愛好家で、新作の上演が決まると真っ先に初日のチケットを確保する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "住宅街の一角にあるその小さなカフェは、店主が焙煎したこだわりの一杯を求める珈琲愛好家たちの隠れ家となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "文化主義的音楽愛好家などは、時代のキザな流行熱で鹿鳴館時代のハイカラの如く、何の根柢もありはしない。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なぜって、僕は今まで、あまり道楽のない男だったんですから、月々ある程度の出費は、何とも思いませんし、貴女のお姉さんを後援するなんて、僕にとっては嬉しいことですし……それに圭子さんは、僕を演劇愛好家に定めてしまっているんだし……」「まあ、いやだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我が友人は熱心な音楽愛好家だった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は写真愛好家で、事に触れては地下室に姿を消している。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来先ずベル研究所内に玉抜き愛好家が増えはじめ、さらに研究所の壁を越えて電話会社でも使われるようになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつ僕は、今月こゝまで読んだものゝうちで、おそらく多くの文芸愛好家が見落しはしないであらうかとおもつた佳作に出遇つたことを吹聴して置きたい。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい斑紋を持ち、若しくは珍しい形をした万年青が生じると愛好家はその非常な価値を認めるが、しかしその万年青をつくづく研究して見ると決して偶然に生じたものではなく、やはりその系統の中にその高貴な由緒を持っていた事が発見される。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際紙風船倶楽部　世界各国の紙風船の愛好家の集りに、国際パン倶楽部といふのがあつた、倶楽部では四年目毎に、各国順番で総会を開らくことになつてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前の夜訪ねて來た人たちを中心とした土地の文藝愛好家達で、歌會とは云つても專門に歌を作るといふ人々ではなかつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前の夜訪ねて来た人たちを中心とした土地の文芸愛好家達で、歌会とは云っても専門に歌を作るという人々ではなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人もまた美術愛好家であって、夏雄さんの彫り物では鏡蓋、前金具、煙管など沢山に所持しており、また古いものにも精通しておられ、柏木貨一郎というとその頃の数寄者仲間には知られた人で、同氏が所持していたものといえば、それを譲り受けるにも人が安心した位、信用のあった人でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説の読者は、活動写真の愛好家と同じように、一種の群団的批評家である。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、時の隔りを忘れて、熟読に没頭する歴史の愛好家であつた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、作者自身からいつか聞いた身の上話の断片――田舎の中学生であったころからの芸術愛好家であり、ダダイズムの油絵を描き、上京後は新聞社に入って政治記者もやったという作者の生きてきた道を、おのずから思い浮かべたのであった。",
              "citation": {
                "source": "作家への課題",
                "author": "――「囚われた大地」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文学愛好家の大多数は、モウパッサンの作品より尠くしかバルザックを読んでいないという実状にあったと思う。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サント・ブウヴは、バルザックが「従妹ベット」の中のパンセラスに関しての芸術論で「客間で大成功をして、大勢の芸術愛好家に相談をされて、批評家になってしまった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の芸術愛好家なら、仏教の信仰をそのものとして奉持しなくても、美から来る霊的欽仰を仏像とその作者とに対して抱かずにはおられない。",
              "citation": {
                "source": "宝に食われる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから文学サークルが目下小説を書いている人たちだけの中心勢力で指導されていて他のより多くの人はいわゆる文学愛好家の水準にとどまって、心まかせの投書雑誌向きな詩や小品ばかりを書いているという状態は、できるだけ早く発展させられなければならないでしょう。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき横浜の方から宮本百合子の作品の話がでて、宮本百合子の作品は、多くの場面で話題になっているが、松田解子の作品については多く語られない、松田解子の文学の庶民的なよさは周囲の初歩的な文学愛好家のグループによい影響を与えているのにとの話がありました。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サークルの文学愛好家たちを、その範囲で高めてゆくことはもとより必要である。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども文学の面では愛好家と云われる人の間にブルジョア風な文学趣味がかなり浸透しているとき、民主主義の方向における批評のよりどころがはっきりつかまれていなかったら、愛好家たちが文学愛好そのものから変革された階級的人生に入ってゆく可能が、どういう風に予想されるだろう。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学は文学者と文学愛好家だけのもちものではなくなってきている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人知れず自負している通り、多くの古陶器愛好家などが陥り易い、病的な所有慾には煩わされていなかった。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その朗らかさには一面執念づよい愛好家の神経質が附随していた。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名曲鑑賞」は、レコードを焼失した日本の洋楽愛好家にとって愛されているプログラムの一つである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国鉄詩人のほかに多くの職場に詩愛好家のグループができている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の文芸愛好家は、かう云ふ偽者の毒手にかからないやうに注意して貰ひたいと思つてゐる。",
              "citation": {
                "source": "偽者二題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "観劇漫談　どんなくだらない展覧会でも、決して見落したことがないという絵画愛好家がある如く、本当の芝居好きという人物になると、如何なる芝居でも、芝居と名のつくものは何から何まで見て置かぬと承知がならないという。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大阪では、新らしい近頃の文楽座以外では先ず、どの劇場もまだまだ、充分の原料を設備して愛好家を待っている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあお兄さんに悪いのね」「どうしても東京へゆくのか」「もしお兄さんに悪いのなら、あたし独りでもいくわ」　じゃあいこうかねと云い、彼はりつ子の雪を払ってやった。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
