        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日羊駱駝について考えている。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は羊駱駝の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には羊駱駝が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは羊駱駝について学習した。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は羊駱駝の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では羊駱駝が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に羊駱駝という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では羊駱駝についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると羊駱駝は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では羊駱駝が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に羊駱駝は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により羊駱駝の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "羊駱駝は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に羊駱駝は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お前さんたちがどんなに田舎者見てえな恰好をしてたって、番頭に化けたって、腰弁に化けて居たって、第一、おめえさんなんぞ、上はアルパカだが、ズボンがいけねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "パナマらしい帽子にアルパカの上衣を着て細身のステッキをさげている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがアルパカの黒背広に黒の小さな鞄を肩から引き掛けて、「さようなら、行ってまいります。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の壁の幾つかの煤けた硝子窓からは、流石に強烈な日光が流れ込んで、そこらの麦稈帽や鳥打帽や赫ら面や鼈甲縁の眼鏡やアルパカの詰襟のぼんの凹などが一時にくわっと燃え立って、それらがその光線を壁の影へ越えると、また後から後からと来る浴衣や、女帽や桃色のスカートに明って揺れて熾った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の黒いアルパカが吹かれる、吹かれる、吹かれる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は黒のアルパカで、頭にはハンケチをかぶっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、長髪に黒のアルパカの上着を着て、ボヘミアンネクタイをした、画家らしい男が、そう附け加えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は黒のアルパカ〔薄地の織物〕の上着に、縞セルのズボンをはいて、麦藁帽子をかぶっていた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、長髪に黒のアルパカの上着を着て、ボヘミアンネクタイをした、画家らしい男が、さう附け加へた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の或るものは、粗末な紺絣の単衣に股引をはいてゐたが、或るものは汚い詰襟の夏服に巻ゲートルなぞを捲きつけ、或るものはまたちやんとしたアルパカの上衣に白のズボンといつた、会社の勤人らしい風をしてゐた。",
              "citation": {
                "source": "フアイヤ・ガン",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」前の方にゐたアルパカの背広をつけた一人が、首を傾げながら考へてゐたが、一同を振返つて、「誰か知つてゐるかね。",
              "citation": {
                "source": "フアイヤ・ガン",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いアルパカの外套を着て、古びて形のくずれた丸い柔い旅行帽をかぶったマリアは、単身その重い箱を持って満員の列車に乗りこんだ。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "断髪の方の髪の工合をコートがなおしてやって居る　通行人　ポートフォリオを抱えた爺、学生、アルパカの上っぱりをきた職人、若い女――浴衣、すあし、唐人まげ　特に若い女断髪の方をしきりに見てゆく　男却って感情あらわさず　女皆　おや、何とか何とか思ってすぐ。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は玉羅紗とかアルパカだの、カシミヤだのの、いゝウール地が澤山あつたものだが、この頃は手に取つてみると、ぞつとするやうな寒い手ざはりのウール地ばかりであつた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は鼠色のアルパカの軽い背広の上衣に黒い袴を穿き、レジヨン・ドノオル（勲一等）の赤い略章を襟に附けて居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になると、勤人は一齊に、白いずぼんに白い靴、アルパカか何かのぺらぺらした上着を着て、凉しい顏をして居るのが普通だが、三田は四月頃から引續いて、たゞ一着の紺サアジだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもあのぴかぴか光るアルパカや、縫ぐるみの狐のやうな白ずぼんに白靴も、いゝ好みでは無いと、負惜みはいふものゝ、紺サアジの色の褪せた間着姿も、決して見た目のいゝものでは無かつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色のアルパカの上衣にも、喞筒で注ぎかけたような血の跡が……。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルパカのタキシイドを着てひょっこり賭博場から出て来たのは、多分昨夜、コン吉から、三十｜法ばかり巻きあげたあの憎い｜玉廻しであろう。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度や三度の誰何を受けるのは常であったが、足の指のはみ出した破れ靴や夏冬着通したアルパカの上衣に、折鞄など持っている僕の姿は、自分ながらも誰何したいのであったから、その筋の眼には余計にそうであったろう。",
              "citation": {
                "source": "楽になったという話",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちラマとアルパカとは、熟練した飼い手に管理されて方々の牧場を廻って歩く。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ会社から帰ったままの茶のアルパカの背広服を着ていた私は、上衣の襟を立て、前のボタンをすっかり篏めて、カラーとワイシャツが目立たぬようにし、麦藁帽子を脇の下に隠しました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、黒目鏡をかけ、つけ髭をつけ、古風なアルパカの背広を一着に及んで、黒の折鞄に繻子の洋傘という、保険の勧誘員か、集金人みたいな中老人が、カフェの前をうろうろしている。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「波越君、拙い変装だなあ」　アルパカの男はびっくりして振向いたが、明智の変装は流石に手に入ったもので、暫らくは見分けがつかぬ程であった。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭に立つのは白粉のお化け然たる肥大漢、それから十五六間あいだを置いて、アルパカ黒眼鏡の怪老人、赤い長靴の運転手、つづいて兵隊上りの番頭さんといった恰好の刑事君。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「表の戸を閉めましょう」　突然、黒いアルパカの上衣に、白ズボンという、下廻りの会社員見たいな男が、大声でどなって、さっさと戸を閉め出した。",
              "citation": {
                "source": "Ｄ坂の殺人事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
