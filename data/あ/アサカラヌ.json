    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deep (of emotions, connections, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浅からぬの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "遥々我を頼みて来し、その心さえ浅からぬに、蝦夷、松前はともかくも、箱根以東にその様なる怪物を棲せ置きては、我が職務の恥辱なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのずからなる因縁浅からぬように思われて、再び墓に香をささげた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな芸者だったか、たしかに印象浅からぬものがあったが忘れてしまった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少からず、地獄、極楽、娑婆も身に附絡うていそうな婦人、従うて、罪も報も浅からぬげに見えるでございます。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは友の誤解嘲笑は、彼にとりて浅からぬ手傷であるからである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浅からぬ下の思ひを知らねばやなほ篝火の影は騒げる　だれが私の人生観を悲しいものにさせたのだろう」　と源氏のほうからも恨みを言った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとはいたわしき限りよと、あわれを覚えしが恋の初め、はからずもこの玉琴殿と、浅からぬ縁をむすび申した。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと浅からぬ御恵もて、婢女の罪と苦痛を除き、この期におよび、慈悲の御使として、童を遣わし玉いし事と深く信じて疑わず、いといとかしこみ謝し奉る」と。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近頃それがしの宮殿下が我々の夥伴を召されて浅からぬ御寵愛を忝ふするは我々の世の中に出る機運が熟したんだね。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に古川は留学前は大隈侯の書生であって、義弟西源四郎は伊藤公の知遇を受けて終に公の※馬となった浅からぬ縁故があったから、もし些かでも野心があったらドンナ方面にでも活躍出来たのである。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのずからなる因縁浅からぬように思われて、ふたたび墓に香をささげた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私の家内は黒川俊子嬢とは浅からぬ因縁があり、非常に秀才だといふ噂を兼てから聞かされてゐた。",
              "citation": {
                "source": "追悼記",
                "author": "原杞憂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方ではさっぱりそういうことは知りませんでしたが、私とは関係の浅からぬ後藤貞行君を通じて右の趣を承知したのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて家持ちとなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことをつよく感じる人々は、同時に、この二人の作家が全く対蹠的に一生を送ったことについても、浅からぬ感銘を与えられているのではなかろうか。",
              "citation": {
                "source": "あられ笹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此働き盛りの時に於て、或は人道の為めに、或は事業の為めに、或は恋愛の為めに、或は意気の為めに、兎に角自己の生命よりも重しと信ずる或物の為めに、力の限り働らきて倒れて後ち已まんことは、先ず死所を得たもので、其の社会・人心に影響・印象する所も決して浅からぬのである。",
              "citation": {
                "source": "死生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼々待望の好機でありますから、全力をつくして本分をつくしたいと思いますが、皆さんとは養成の時代からの浅からぬお馴染みであります。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、何もかも、只、浅からぬ因縁だと言っているじゃあありませんか――何でも話を聴くと、どこかに隠れているうちに、横山五助とかいう、お屋敷出入りの悪ざむらいにつけまわされ、操を守るために、その男を、突ッ殺したとかいうことで――」　闇太郎が、そこまで言うと、三斎が、「えッ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿川屋敷の井に沈んでゐる椀も、河童と因縁の浅からぬものなのである。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、河童に関係浅からぬ相撲に、骨を脱して負ける者の多い処から、愈河童と草人形との聯想が深まつて来た、と思はれる。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち小膝を礑と撲ち、「爰によき計こそあれ、頃日金眸大王が御内に事へて、新参なれども忠だちて働けば、大王の寵愛浅からぬ、彼の黒衣こそよかんめれ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岩本が美代子を自分の女房にと衣子にそれとなく申入れていたのだが、商売柄、女のことでは浅からぬ経験があるくせに、持って生れた性格は仕方のないもので、性格だけの手法でしか女の観察ができないためか、衣子に内々嫌われていることに気がつかない。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の家は加藤家の浪人の血をひいた軽い士の末で、代々田舎の惣庄屋をして居て、農には元来縁浅からぬ家である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草も亦心浅からぬ花である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は余にも縁浅からぬ座敷である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば川島｜未亡人にも武男にも浅からぬ信任を受けて、今度も未亡人の命によりてはるばる佐世保に主人の負傷をば見舞いしなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウチの奴とお前とは、私というものに浅からぬ因縁があることだし、ウチの様子をお前には見せておきたいと思いたったのでね。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御愛顧の大恩もあり、また浅からぬ因縁もあるホトケの法要にオツトメにも参じませず心苦しくは存じておりましたが、重ねて不調法をはたらいてはと心痛いたしましてな。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで富山の薬は私の生活史に浅からぬ因縁もあるものだから、戦争前にふと古本屋の店頭に「富山売薬業史資料集」という三冊つづきの本をみつけて、特別の必要があるわけでもないのに買いもとめたこともあった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュガ公は、名附親としての浅からぬ因縁があるにはあるが、その当時からここで茂太郎と知合いになっている動物は――茂太郎が来なくなってから後に生れた動物はいざ知らず、その以前からの馴染は、早くも茂太郎の訪れを見て宙を飛んで集まって来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『このねぬる朝妻船のあさからぬ契を誰にまた交はすらむ』いえいえ白拍子は二度とふたたび枕を交わそうとはしませんでした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
