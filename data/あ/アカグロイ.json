    "definitions": [
      {
        "index": 1,
        "gloss": "dark red",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "赤黒い顔に鉄縁の眼鏡を掛け、紋付羽織が好きで何時もその広い胸ははたけられてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、以前見覚えた、両眼真黄色な絵具の光る、巨大な蜈※が、赤黒い雲の如く渦を巻いた真中に、俵藤太が、弓矢を挟んで身構えた暖簾が、ただ、男、女と上へ割って、柳湯、と白抜きのに懸替って、門の目印の柳と共に、枝垂れたようになって、折から森閑と風もない。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　親父はその晩、一合の酒も飲まないで、燈火の赤黒い、火屋の亀裂に紙を貼った、笠の煤けた洋燈の下に、膳を引いた跡を、直ぐ長火鉢の向うの細工場に立ちもせず、袖に継のあたった、黒のごろの半襟の破れた、千草色の半纏の片手を懐に、膝を立てて、それへ頬杖ついて、面長な思案顔を重そうに支えて黙然。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛が伸び過ぎて領首がむさくなっているのが手拭の下から見えて、そこへ日がじりじり当っているので、細い首筋の赤黒いところに汗が沸えてでもいるように汚らしく少し光っていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の赤黒い変な顔を見ると、あまりの事に悶絶するかも知れない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月｜※々……」　と聞いてみると国原は、酒腫れに腫れた赤黒い入道顔を撫でまわした。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると森までががあっと叫んで熊はどたっと倒れ赤黒い血をどくどく吐き鼻をくんくん鳴らして死んでしまうのだった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその広い赤黒いせなかが木の枝の間から落ちた日光にちらっと光ったとき小十郎は、う、うとせつなそうにうなって谷をわたって帰りはじめた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちょうど二年目だったがある朝小十郎があんまり風が烈しくて木もかきねも倒れたろうと思って外へ出たらひのきのかきねはいつものようにかわりなくその下のところに始終見たことのある赤黒いものが横になっているのでした。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と炎天に、赤黒い、油ぎつた顏をして、目をきよろりと、肩をゆがめて、でくりと通る。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　絨毯を縫いながら、治兵衛の手の大小刀が、しかし赤黒い電燈に、錆蜈蚣のように蠢くのを、事ともしないで、「何が、犬にも牙がありゃ、牛にも角があるだあね。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が三疋、赤手拭、すッとこ被り、吉原かぶり、ちょと吹流し、と気取るも交って、猫じゃ猫じゃの拍子を合わせ、トコトンと筵を踏むと、塵埃立交る、舞台に赤黒い渦を巻いて、吹流しが腰をしゃなりと流すと、すッとこ被りが、ひょいと刎ねる、と吉原被りは、ト招ぎの手附。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜垣の主人は、鼈四郎を連れて、鴨川の夕涼みのゆかから、宮川町辺の赤黒い行灯のかげに至るまで、上品や下品の遊びに連れて歩るいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩誤れば嫉妬の赤黒い血に溶け滴りさうな濃艶なところで危く八重咲きの乱れ咲きに咲き止まつてゐた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓一ぱいにあんなに見事に咲いていた桜の花も、おおかた散ってしまって、いまは赤黒い萼だけが意地わるそうに残っている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」言いながら彼は股の毛をわけて、深い赤黒い傷跡をいくつも私に見せた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちを見ると、いぜんここに家があったじぶん、花畑になっていたらしい一角に、小さな赤黒いさびしげな花が、二、三本あった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに男か女か、わからないような、むっとした赤黒い顔をしている。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば赤黒い散文的な俗物に、少しずつ移行していたのである。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は「春」で、下部に前景として赤黒い鳥居の上半が出で、その傍に半ば開いた桜の花の樹が枝を張る。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扁い、膩ぎつた、赤黒い顔には、深く刻んだ縦皺が、真黒な眉と眉の間に一本。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に、母の小言などは屁とも思はぬ態度やら、赤黒い顔、強さうな肥つた体、巡査、鉄砲、雁の血、などが一緒になつて、何といふ事もなく叔父を畏れる様な心地になつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかも真中に、ズキリと庖丁目を入れた処が、パクリと赤黒い口を開いて、西施の腹の裂目を曝す……　中から、ずるずると引出した、長々とある百腸を、巻かして、束ねて、ぬるぬると重ねて、白腸、黄腸と称えて売る。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その養子というのは、日にやけた色の赤黒い、巌乗づくりの小造な男だっけ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔には九邇坂の土を、そこの土は、上土は赤く、底土は赤黒いけれど、中土の、ちょうど色のよいのを眉墨にして、色｜濃く眉をかいている。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍のような海の水も島へ近づくにしたがって、まるでコーヒーのような色に濁っているのは、島のなかに大きな河があって、その下流が海にむかって赤黒い泥水を絶え間なしに噴き出しているからであった。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡の硝子は微塵に砕けて、瞬間はっとつぶった彼の眼の裏には赤黒い渦のような影像がはげしく廻転した。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の横に新しいフリージャの花を飾ったアダリーが、湯気の立つ赤黒い液体を湛えた青い茶碗を二つ載せた銀盆を目八分に捧げて這入って来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "体重百四十｜斤に近い、六尺豊かの図体で、大一番の菜葉服の襟首や、袖口や、ズボンの裾から赤黒い、逞ましい筋肉が隆々とハミ出しているところは、如何にも単純な飾り気のない性格に見える。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
