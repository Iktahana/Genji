        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日晏如について考えている。",
              "source": "幻辞"
            },
            {
              "text": "晏如という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は晏如の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には晏如が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "晏如を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは晏如について学習した。",
              "source": "幻辞"
            },
            {
              "text": "晏如の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は晏如の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では晏如が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "晏如という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に晏如という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では晏如についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "晏如を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると晏如は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "晏如について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では晏如が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に晏如は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により晏如の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "晏如は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に晏如は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私なんか煩悩だらけで、とても、ものごとを単純に考えて、晏如として居られないんです。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従容として逼らず、晏如として、宜しく大位に登るべし、と云えるは、一｜言や鉄の鋳られたるが如し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀には科學上に所謂安定性の物質のやうに、十年一日の如くして晏如たる人も有るが、多くは新を追ひ舊を棄てんとするの傾が有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな――時に不可解な――ものの中に（組織、慣習、秩序）晏如と身を置いてゐる氣易さ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己ノ私利ヲ目的トスル資本制度ニ依頼シテ晏如タルコトハ、今日及ビ今後日本ノ國際的危機ノ忍ブ能ハサル所ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に若し、その愛によって衆生を摂取し尽したという意識がなかったなら、どうしてあの目前の生活の破壊にのみ囲まれて晏如たることが出来よう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しかかる約束にある智的生活が生活の基調をなし、指導者とならなければならぬとしたら、人間は果して晏如としていることが出来るだろうか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして晏如としている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其が真の価値批判に於て高価なものであるなら、所謂現代が嘲笑する伝統に晏如として自信ある認定を与えながら、如何に喋々され、絶叫される傾向であっても、其が無価値ならば、最後の唯一人として否定し得る、其の定見が総ての点に欲しいのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇ろに近親に感謝し、厚く良友に感謝し、普く天地に感謝し了へ、晏如として我が生を終へなむ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語を晏如としてやつてゐられなくなつた落語家。",
              "citation": {
                "source": "落語家たち",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら以上論じ尽した理由によると、どうしても見ず知らずの他人の手に赤ン坊を渡して、母親が晏如としている筈がないからである。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既成大家を奮起せしめて、一の固定心境に晏如たらしめず、更にその進展に志ざさせるものは、この声である。",
              "citation": {
                "source": "野に声なし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "円らかな、てらいのない、晏如とした心持……。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに吾々が晏如として眠れる間に武器を持つことその事の故のみで、吾々多数の意志は無の如くに踏み付けられるならば、先ず公平なる暴力を出発点として、吾々の勝敗を決せしめるに如くはない。",
              "citation": {
                "source": "二・二六事件に就て",
                "author": "河合栄治郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして晏如としてゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでかういふ問答の結果がどうかと言へば、仲間同志の禅坊主だけ寄り集つて、彼奴は悟りの分らない担板漢だなどと言つて般若湯で気焔をあげてもゐられるけれども、然し、かういふ約束の足場は確固不動のものではないから、内省の魔が忍びこんでくる時には晏如としてはゐられない。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな誓ひが人と鬼との間にあつた後、村々の人は、石城の中に晏如として眠ることが出来る様になつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに明朗快闊、すべからく男性たるものかくの如く晏如たるべしといいたいところである。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは旧習に晏如としている人たちに対する軽い羨望嫉妬をさえ感じないわけには行かなかった。",
              "citation": {
                "source": "草紅葉",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは果してよくケーベル先生やハーン先生のように一生涯他郷に住み晏如としてその国の土になることができるであろうか。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "人一たび勢利の巷に奔馳するや、時運に激せられて旧習に晏如たる事｜能はず。",
              "citation": {
                "source": "礫川記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も氏は尚ほ晏如として市廳に眠る。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も氏は尚ほ晏如として市庁に眠る。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ道也先生がこの一点の温気なき陋室に、晏如として筆硯を呵するの勇気あるは、外部より見て争うべからざる事実である。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳的には潔癖であるとさえ思い習わしていた自分が、汚穢に充ちた泥溝の内に晏如としてあった、という事実は、自分の人格に対する信頼を根本から揺り動かした。",
              "citation": {
                "source": "転向",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味与力で相当に敵も作っている笹野新三郎が、家族から縄付を出して晏如としていられる道理はありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨降りあとじゃ、川へいて、雑魚なと、取って来なはれ、あんじょ、おいしゅう煮て、食べまひょ」継ものをしていた母親がいった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あんじょう思うておくんなはれや。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで夫婦にならはったら、直ぐにな、別に店を出してもらうなり、世帯持ってそこから本店へ通うなり、あの、お爺はんと、三人、あんじょ暮らして行かはるように、私がちゃと引受けた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
