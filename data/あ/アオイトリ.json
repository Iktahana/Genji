        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「青い鳥」の森の場面ぐらいの事ではあるまい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーテルリンクの青い鳥は、月光の下で見ると青い鳥だが、それを捉へて晝間見ると、普通の平凡の鳥になつてる。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の時に、柏木の叔父さんが、私の綴方を「青い鳥」に投書して下さって、それが一等に当選し、選者の偉い先生が、恐ろしいくらいに褒めて下さって、それから私は、駄目になりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、あの、「青い鳥」に綴方を掲載せられてからは、急に臆病な、いやな子になりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年前に、私の下手な綴方を無理矢理、「青い鳥」に投書させたのも、此の叔父さんですし、それから七年間、何かにつけて私をいじめているのも、此の叔父さんであります。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が女学校の三年生になった時、突然、「青い鳥」の選者の岩見先生から、私の父に長いお手紙がまいりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鳥や青い鳥が、大きいのも小さいのも、長く二列にならんで、ボートのあとから飛んできました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光の夜に捉へた青い鳥は、日光の下には影も姿もなく消えうせて居た。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは青い鳥をにぎつた瞬間の、力強いコブシの感覺である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の青い鳥を今度こそほんとに握ることができるのだ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアテルリンクじゃありませんが、人生の幸福はやっぱり翼のある青い鳥じゃないでしょうか」と規矩男は言葉の息を切った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ピイ、チョコ、キイ、キコと鳴く、青い鳥だの、黄色な鳥だの、可愛らしい話もあったが、聞く内にハッと思ったのは、ある親島から支島へ、カヌウで渡った時、白熱の日の光に、藍の透通る、澄んで静かな波のひと処、たちまち濃い萌黄に色が変った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥、小鳥、なぜなぜ青い。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな青い鳥が左側の巌の尖にとまって、く、く、くと耳に染みるように鳴いた。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥はまだ、く、く、くと鳴いていた。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥は鳴きながら巌の尖を伝って右へ右へ往った。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥は巌の一方へ廻ってやはり尖を伝って往ったが、巌が次第に低くなって四辺に荊棘の茂った処へ往くと見えなくなった。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい、青い鳥は、果して舟の横浜に着くまでに死んでしまつた。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても灰色の鳥を青い鳥に見ることが出来ないのである。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢を見てゐて、青い鳥を夢の中に尋ねてゐるのである。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それは「僕の故郷のケンタツキーの家」「｜悲し、悲し、悲し」「青い鳥」「カドリール」「星条旗の下に」等であつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは女の神さまらしい一人の西洋の女が、青い鳥籠の戸を開けて、木の上に棲つてゐる七羽の赤い小鳥を呼び入れてゐる図案で、すべてが、色の珍らしいさま／″＼の布を貼り合はせて画にしてあるのであつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒の中折れは何か気味悪そうに青い鳥打の話をきいていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥打帽が二三度話をやめて記者をジッと見ていたが、突然声をかけた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとを見送った青い鳥打は記者の方を向いた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥せんだんの葉越しに、青い鳥が鳴いた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
