        "examples": {
          "standard": [
            {
              "text": "暴れだすについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この暴れだすは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が暴れだすについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は暴れだすの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では暴れだすが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から暴れだすを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも暴れだすが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では暴れだすが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも暴れだすは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも暴れだすは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で暴れだすは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に暴れだすについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "暴れだすの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する暴れだすの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では暴れだすの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "誰か俺の体をおさえていてくんな、俺が暴れだすといけないから……」　と、たいへんな騒がはじまった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは狂人のやうに暴れだすところだつたが、大勢の者に抑へつけられてしまつた。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてここにたつたひとつの心配といへば、この気違が泡盛飲むといふことだが、こればつかりはいかさま婆羅門の秘巻によつて修養つんだ御人であらうが、なんのはづみで暴れだすか知れたものではないのである。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつもきまって、何かひどく暴れだす前にそうなるのでした。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黒い筋金入りともいうべき身体と、いつも暴れだす用意のある底のすわった眼付で世間に立ちむかい、長い間、人知れぬ苦闘をつづけてきたので風格に確固としたヴァリュウがつき、六十歳を越えていると見ぬける人間はそう沢山はいなかったが、どうしたのか、最近、気持になんとなく違和ができて会社へ出る気もしない。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ苦しがって今に暴れだすだろうと思っていたのが、これじゃアさっぱりおもしろくないから、竹田の失望は小さくございません。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばお渡御のすむ一刻ほどのあいだは、全町まっ暗にしてしまうということだが、そんな暗闇の中で斬ってかかれるわけのものじゃないから、暴れだすとするならお渡御がすんで篝がついてからか、ひとの顔が見えるようになった白々明けにちがいない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって暴れだすと手に負えないから、たいていの者が泣きねいりということになった。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定は溜めるし、酔うと諄く女たちにからむし、ちょっと気にいらないことがあると暴れだすし、これが侍かと思うような人ばかりであった。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人だけは暴れだすとみられたらしい。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにを待ってるんだろう、やつらが暴れだすのをか、それならいますぐだっていい筈じゃないか、やつらは公然と禁制の博奕をやっているし、そのため幾人かの役人が買収され、もっこ部屋の中がめちゃめちゃになってしまった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は日雇い労働者だったが、もとは坑夫などもしたことがあるそうで、酔って暴れだすと手がつけられなかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れだすと、大勢の武士でも、手がつけられなかった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、急に防戦のそなえをしたが、足場はわるし道は暗いし、牛馬は暴れだすし、まだ敵を見ぬうちから大混乱を起していた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○を押さえると△があばれだす。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○を押えると△があばれだす。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自然があばれだすと手がつけられないことを忘れがちである。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれだすかと思っていた泰文は、意外に素直に勅を受け、二十騎ばかりの伴を連れて宇治の平等院でひとしきり水馬をやったうえ、一糸纏わぬすッ裸で裸馬に乗り、京の大路小路を練りまわしたうえ、悠然と敦賀へ下って行った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ととどろいて、着物があおられ、木の葉が吹き飛ばされたが、爆風もここまで来るとよほど弱くなっていて、牛があばれだすほどではなかった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりあばれだすのかと思ったら、そうではなく、両足の間にひっ挾むようにして、じっと鶏をおさえつけている。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれだすときの癖なので、なにを言うつもりなのかと、サト子は遠くから叔母の顔を見まもった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれだすかと案じられた泰文は、意外にも素直に勅を受け、二十騎ばかりの伴を連れて加茂川でひとしきり水馬をやってから、一糸纒わぬすッ裸で裸馬に乗り、京の大路小路を練りまわしたうえ、悠然と敦賀へ下って行った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻や娘には手を出さなかったが、千太郎があばれだすたびに、二人ははだしで逃げだすより仕方がなかった。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
