[
  {
    "uuid": "99f0cc00-b475-5382-ba66-37d1e3d8409d",
    "entry": "荒波",
    "reading": {
      "primary": "あらなみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "raging waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒波について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒波という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒波の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒波が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒波を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒波について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒波の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒波の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒波が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒波という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒波という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒波についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒波を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒波は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒波について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒波が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒波は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒波の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒波は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒波は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "両方の舟が荒波蹴立てて急ぐ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒波、どッと押し寄する処。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夜中に荒波が岸をはい上がってテントの直前数メートルの所まで押し寄せたときは、もうひと波でさらわれるかと思った。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来｜伏木直江津間の航路の三分の一は、遙に能登半島の庇護によりて、辛くも内海を形成れども、泊以東は全く洋々たる外海にて、快晴の日は、佐渡島の糢糊たるを見るのみなれば、四面※茫として、荒波山の崩るるごとく、心易かる航行は一年中半日も有難きなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）吹つのる風の音｜凄まじく、荒波の響きを交う。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう荒波の音に紛れて貴女の耳には入りません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うら若き母に伴はれし幼兒の、他の乘るに、われもとて肯かざりしに、私は身弱くて、恁ばかりの船にも眩暈するに、荒波の海としならばとにかくも、池の水に伏さんこと、人目恥かしければ得乘らじとよ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は水嵩も豊で、両岸に咲く一重桜の花の反映の薄べに色に淵は染んでも、瀬々の白波はます／＼冴えて、こまかい荒波を立てゝゐる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巖にも山にも碎けないで、皆北海の荒波の上へ馳るのです。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は――白晝、北海の荒波の上で起る處の此の吹雪の渦を見た事があります。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌にも山にも砕けないで、皆北海の荒波の上へ馳るのです。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は――白昼、北海の荒波の上で起る処のこの吹雪の渦を見た事があります。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていても激しい荒波である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は海を、遠い荒波を、通り過ぎる目の前の浜の小石を眺めている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬より下、地中海の荒波寄するあたりまで、この流には橋もなし、また索むとも舟もあらざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の才覚一つで人生の荒波を乗り切ってきただけに、手の届かない何かにたやすく首を捻られるのがやりきれないのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "府下の同業者なども、これまで幾度かあった不景気騒ぎには、さいわいにその荒波に触るるの厄をまぬがれてきたのだが、去年という大厄年の猛烈な不景気には、もはやその荒い波を浴びない者はなかった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　七月となり、八月となり、牛乳の時期に向かって、不景気の荒波もようやく勢いを減じたが、幼女を失うた一家の痛みは、容易に癒ゆる時はこない。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はさもさも物臭さうにふところ手のまゝ脊骨を棒のやうに突つ張らせてぶつ／＼いつてゐたが、銑太郎は物をも言はず先に立つて、夫々の手に提電灯の用意をすると、家内の者の眼を盗みながらカビ臭い土蔵脇の忍口から、颯つとばかりに荒波の中へ跳び込むやうに身を交して走り出た。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやその荒波の中にもまれて虐まれてそして呼吸も絶え果てゝ了つてゐる。",
              "citation": {
                "source": "波の音",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "明鯛から鱈、鱈から鰊、鰊から烏賊というように、四季絶える事のない忙しい漁撈の仕事にたずさわりながら、君は一年じゅうかの北海の荒波や激しい気候と戦って、さびしい漁夫の生活に没頭しなければならなかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の荒波の中に浮きつ沈みつしてゐるのである。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をしゃべったって、お前等には分りもしないだろうが、ともかくだ、日本帝国の大きな使命のために、俺達は命を的に、北海の荒波をつッ切って行くのだということを知ってて貰わにゃならない。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、室内は、荒波にもまれる小舟のように上下左右に、はげしく揺れ、壁土は、ばらばらと落ちる、窓ガラスは大きな音をたてて壊れる。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なしでは、とてもこの世の中の心の荒波はわたつて行けないのだから。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上尾貞七と謂ふのは、根本三之助などと同じく、一時は非常に逆境に沈淪して、村には殆ど身を措く事が出来ぬ程に為つた事のある男で、それから憤を発して、江戸へ出て、廿年の間に、何う世の荒波を泳いだか、一万円近くの資産を作つて帰つて来て、今では上塩山第一の富豪と立てられる身分である。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "判断と生きる方向とを文学的に求めてゆかず、浮世の荒波への市民的対応の同一平面において、その意味で「結婚の生態」は、今日の現実では作家が、文学をてだてとしてどんなに常識的日常性を堅めてゆくかという興味ある一典型をなしているのである。",
              "citation": {
                "source": "今日の読者の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は滝となつて落ちる荒波弥彦神社。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直で、感情が豊かで、諸芸がよく出来て、宗教心が深いこと、しかし実務上の処世術にうとく、余程がっちりと努力しなくては世間の荒波を乗り切り難いような性格――これが私たち同胞が親から享け継いだ遺伝である。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから外の国でのように家庭を城にして、それで浮世の荒波を防ぐというものではない。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
