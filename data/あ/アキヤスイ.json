        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、また一方、大衆にわかりやすい常套手段をいつまでも繰り返しているのでは飽きやすい世間からやがて見捨てられるという心配に断えず脅かされなければならない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがしっくり箝まっているとも思えないのであったが、田舎に残っている老母が、どこでも尻のおちつかない、物に飽きやすい彼の性質を苦にして漢学者の父の詩文のお弟子であったその先輩に頼んで、それとなし彼を戒めたので、均平も少し恥ずかしくなり、意地にもそこで辛抱しようと決心したのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "院は御恋愛の上で飽きやすいとか、気がよく変わるとかいうことはない方で、珍しい篤実性を持っておられます。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは重大なことではない、お由の躯の持っている魅力は稀なものであるが、美味なほど飽きやすいもので、その特徴の稀なものであることが、却って彼には鼻について来ていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう母であったが、ひとつだけどうにもならぬものがあった、それはものに飽きやすい気質だった。",
              "citation": {
                "source": "日本婦道記",
                "author": "梅咲きぬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とその飽きやすい気質を惜しまれたものであった。",
              "citation": {
                "source": "日本婦道記",
                "author": "梅咲きぬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンペン草　子供が古い名に飽きやすいこと、または誰よりも鋭敏に新らしい名の面白さに共鳴することが、物の名の盛んに変化し、また地方的に区々になる昔からの原因だったようである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんきでいたずらな、ものにあきやすい子供を、ゆっくりとひきとめて、身体のためにもなるように、のちのちに悪い習慣も残さないように、そうして楽しく食事をさせるのには、よほど気転のいることです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
