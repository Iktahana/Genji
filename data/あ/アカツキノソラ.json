        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暁の空に大宮表口の裾野原は、うす紙をはがすように目がさめる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁の空に負けて赤黄いろく萎びかけたシャンデリヤの下で小田島が帳場の男に、イベットが確に泊って居るかどうかを尋ね合せて居ると、二三組の男女が玄関から入って来た。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の鳴る音がサツときこえて、微白い暁の空気が二階へと下りて行く窓からそつと覗かれた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほの白い暁の空気、他界をそれと聯想させるやうな静かな空気、それに誘はれて行けば、さう大して悲しいことでもないやうに思はれた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報は出ないが、しかし油断はならないぜ」　　　暁の空襲警報　茨城県｜湊町の鮪船が四｜艘、故郷の港を出て海上五百キロの沖に、夜明を待っていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上に出ると、頬に、払暁の空気が刺すように感じた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十×年八月八日　晴れ　小便に起きたついでに、明り取りの窓から暁の空を透かしてみると、憎らしいほど霽れ渡った悪天候である。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田先生のいわゆる「暁の空が白むように」いつの間にか、現象の本質が段々と頭の中に浮き出して見えて来たのである。",
              "citation": {
                "source": "凍上の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じように、非常に複雑な現象で初めは何が何かちっとも分らないような事柄が、「休養」をしながらぼつぼつと実験をしている中に、暁の空がいつ明けるともなく白んでくるように分ってくるというのが多くの場合研究の完成ということになるのである。",
              "citation": {
                "source": "米粒の中の仏様",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ひとまず貴公にお返し申すによって、快く納められい」　左膳の頬に皮肉な笑いが宿って彼は独眼をすえて栄三郎を見つめながら、しばらくキッと口を結んでいたが、やがて純粋無垢な若侍の真意が、暁の空のごとく彼の脳裡にもわかりかけたものか、たちまち快然と哄笑をゆすりあげて、「うむ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日月の光で、あるいは闇夜の星の光で、あるいは暁の空の輝きで、朝霧のうちに、夕靄のうちに、黒闇のうちに、自由にこの堂を鑑賞することができる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかに雨が夜になって木曜島をよぎり、早暁の空には涼しい気配がみちて、晴天に山の気がかもし出されたのであった。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日月の光で、或は闇夜の星の光で、或は暁の空の輝きで、朝霧のうちに、夕靄のうちに、黒闇のうちに、自由にこの堂を鑑賞することが出来る。",
              "citation": {
                "source": "月夜の東大寺南大門",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寐はぐれた、眠りそこねた暁の空気の中に、梅の花を認めたというだけのことである。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそは、完全に僕が勝利を得た様ですね」　暁の空に高らかに響く明智の笑い声。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わあッと、暁の空に向って、突然、諸声があがった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "内蔵助すら、瞼へ、指先を当てたまま、やや暫く、暁の空の移りゆくのも知らなかった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで精密にし得るかは人にもより、またそれほどの要求も無かったろうが、ともかくも霜月二十三夜の前後、月の半輪が暁の空に、傾く頃が冬至であり、またおそらくは西洋のクリスマスでもあった。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁の空の下に見た恋人の鮮麗な血は、お綱に美しい誘惑であった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
