[
  {
    "uuid": "2704abe9-7429-5b26-b674-7fea238a15db",
    "entry": "愛くるしい",
    "reading": {
      "primary": "あいくるしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
