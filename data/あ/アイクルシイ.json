    "definitions": [
      {
        "index": 1,
        "gloss": "lovely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生まれたばかりの赤ん坊が、愛くるしい瞳でじっとこちらを見つめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カゴの中で丸まって眠る子猫の姿は、見ているだけで心が洗われるほど愛くるしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て、あのパンダの赤ちゃん！ なんて愛くるしいのかしら」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのご当地キャラクターは、愛くるしい表情と丸みを帯びたフォルムで、老若男女から絶大な人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "孫娘が慣れない手つきで一生懸命にお辞儀をする様子は、実におかしくも愛くるしいものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の愛くるしい笑顔は、職場の張り詰めた空気を一瞬で和ませる不思議な力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小さな手足をバタつかせながら喜ぶ大型犬の幼少期は、何物にも代えがたい愛くるしさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幼い彼は命取らるる水とも知らず、地平と等しい水ゆえ深いとも知らずに、はいる瞬間までも笑ましき顔、愛くるしい眼に、疑いも恐れもなかったろう。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "目鼻立の愛くるしい、罪の無い丸顔、五分刈に向顱巻、三尺帯を前で結んで、南の字を大く染抜いた半被を着て居る、これは此処の大家の仕着で、挽いてる樟もその持分。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　与平という親仁は、涅槃に入ったような形で、胴の間に寝ながら、仏造った額を上げて、汗だらけだけれども目の涼しい、息子が地蔵眉の、愛くるしい、若い顔を見て、嬉しそうに頷いて、「晩にゃ又柳屋の豆腐にしてくんねえよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たばこ屋の娘で、小さく、愛くるしいのがいた。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片眼が少し爛れているが、愛くるしい女の子だ。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹セルの単衣、水色｜縮緬の帯を背後に結んだ、中背の、見るから蒲柳の姿に似ないで、眉も眦もきりりとした、その癖｜口許の愛くるしいのが、パナマの帽子を無造作に頂いて、絹の手巾の雪のような白いのを、泥に染めて、何か包んだものを提げている。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目鼻立の愛くるしい、罪の無い丸顏、五分刈に向顱卷、三尺帶を前で結んで、南の字を大く染拔いた半被を着て居る、これは此處の大家の仕着で、挽いてる樟も其の持分。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　與平といふ親仁は、涅槃に入つたやうな形で、胴の間に寢ながら、佛造つた額を上げて、汗だらけだけれども目の涼しい、息子が地藏眉の、愛くるしい、若い顏を見て、嬉しさうに頷いて、「晩にや又柳屋の豆腐にしてくんねえよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな無邪気な愛くるしい少女が、こうして、警察に追い廻されているという事が、たまらなく残酷な、恐しい事のように思われて来たのであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が熊の子のようで、愛くるしいので、きょうだいたちが、何かとかれにかまいすぎて、それがために、かれは多少おっちょこちょいのところがある。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの給仕女に一人の悧發さうな顏をした、たいそう愛くるしい少女が居た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの給仕女に一人の悧発さうな顔をした、たいそう愛くるしい少女が居た。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ可憐な、愛くるしい、かなしげなものがこの世にはゐることか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "菰を厚く巻いてやるプールの中へ、差し込む薄日に短い鰭と尾を忙しく動かすと薄墨の肌からあたたかい金爛の光が眼を射て、不恰好なほどにも丸く肥えて愛くるしい魚の胴が遅々として進む。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロココ式の陶器の絵模様の感じのする、装飾的で愛くるしい美しい青年だつた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュウピッドという愛くるしい子をさえなした。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそうかい、あんたの母様はな、何でもこのあたりに評判の美い女で、それで優しくって、穏当で、人柄で、まことに愛くるしい、人好のする、私なんか女じゃが、とろとろとするほど惚れていました。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空色の愛くるしい大きな眼だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これの返事が思った通りなら、君はまたひとつ愛くるしい事件を君の記録に加えられるよ、ワトソン。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と愛くるしい件の口許で、べそを掻くような（へ）の字｜形。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と例の愛くるしい口を結んで眉根を寄せ、吐息をついて歎息した。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　固くなって聞いていた、二人とも身動きして、お若は愛くるしい頬を支えて白い肱に襦袢の袖口を搦めながら、少し仰向いて、考えるらしく銀のような目を細め、「何だろうねえ、杉や。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼ない彼は命取らるゝ水とも知らず、地平と等しい水故深いとも知らずに、這入る瞬間までも笑ましき顏、愛くるしい眼に、疑ひも恐れもなかつたらう。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ二三本酒壜の並んでゐるのを見たので、それを取つて冷のままちび／＼飮んでゐると、二十歳位ゐの色の小黒い、愛くるしい顏をした娘が下の溪から上つて來た。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白の丸顔で、愛くるしい少年でした。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれほどかまをかけてみても、利発そのもののような愛くるしいまなざしを伏せるだけで、ほとんどその片鱗をさえ伝えようとしなかったものでしたから、いよいよ右門が疑いの雲を深めているとき、通しの早駕籠かなんかで勢いよく駆け帰ってきたものは、深川へ行った伝六でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
