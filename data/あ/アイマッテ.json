        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを利他と言いまして、自利、利他、相まって、完全な人生を出現させようと仏教は説いております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此他種々の怨が、甚助の弁と相まって、勝豊に父を裏切らせるもととなったのである。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つもりつもった疲労と負傷とが相まって、私は衰弱しきってしまい、そのため、おびただしい数の負傷兵と一緒にペシャワールの基地病院へ後送された。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえどこか超然として見えた祖母の心のあり様は、手書きの文字面と相まって、一つ一つの歌によく感じとることができました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏が鳥井零水という匿名で、ドゥーゼの「スミルノ博士の日記」「夜の冒険」の二作をひきつづき『新青年』に連載しはじめたとき、原作の優秀と、訳文の巧妙とは相まって、私は、いまだにあの時ほど、雑誌の出るのを待ちこがれた経験はない程である。",
              "citation": {
                "source": "小酒井不木氏",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中氏の一字一句いやしくせぬ訳筆と相まって近来会心の書物であった。",
              "citation": {
                "source": "ルヴエルの『夜鳥』",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗史家的な考証癖と、文章における一種のペダントリー〔衒学〕とが相まって、「調べた」作品である割合に、氏の作品は効果が希薄である。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳の明晰と相まって、その心は広く厚く、老成した君子のおもかげがある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし富者も貧者も消費者も生産者も、互いに相まっておのおのその責任を全うするに至らなければ、完全に理想的なる経済状態を実現するを得ざること言うまでもなきことである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀ぶら道中記（二）　警醒社は教文館と相まってキリスト教的色彩の濃い店である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋の袴に水干立烏帽子、ものめずらしいその扮装は、彼女の技芸と相まってその名を高からしめた。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが実現された暁にはあのあたり一帯に水上陸上相まって、他と趣を異にした特殊の景情を現出すべく、公園や遊歩場というものを持たないわれ／＼牛込区民や、麹町区一部の人々の好個の慰楽所となるであろう。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に電車終点附近近来の発展は驚くべきで、戸塚方面から球場前を抜けてここへ出る道路が開けたのと相まって、やや場末的な感じながらもそこにまた一廓の繁華な盛り場を形造り、早稲田の中心鶴巻町通りの繁華を、次第にそこに移動せしめつつあるが如き観もないではない。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬深い私には、その桂子外泊という一事が、前の三日外泊と相まって、いちばん胸にこたえた。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、博士の性格的な風貌と相まって、博士の達識ぶりを、いちだんと引き立たせて見せていた。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕焼けのかがやきと相まってより以上に美くしく見える女達の衣の色は前よりも一層はげしく賞め言葉を受けた。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜視めいた眼が宙に据って、頬の血色の乏しさと相まって、一寸人の気を惹く。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も古くて、しかも最も新しい太陽を迎えようとする思いは、日一日と急な時勢の潮流と相まって、各人の胸に入り乱れた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方偽装されたこの書の政治的無関心と、他方倒幕派そのものから「攘夷」のスローガンを陰に抛棄させた「慶応」度必至の内外諸政情と、相まって驚異的な十万の読者大衆をこの書に獲得させたのである。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "この開展せる瑩白色花蓋六｜片の中央に、鮮黄色を呈せる皿状花冕を据え、花より放つ佳香と相まって、その花の品位きわめて高尚であることに、われらは讃辞を吝しまない。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして住宅会社の活躍と相まって、みるみるうちに、千八百軒建ったわけである。",
              "citation": {
                "source": "防寒戸",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も地方を巡回するについては、実際その地方地方について研究いたす考えでござりますが、諸君方の御報道と、私が見聞したところと、双方相まって研究いたしたならば、大いに研究を助くることであろうと思います。",
              "citation": {
                "source": "妖怪学一斑",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにここの水は水晶のように澄んでいて、水浴者のからだはもっと不自然な雪花石膏の白さに見え、拡大され、ゆがんだ四肢と相まって奇怪な効果を生じ、ミケランジェロ流の画の好素材になる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの逍遥と絶えざる研究とが相まって、彼は博学な好古趣味者となった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これら全てとポートゥックスト農場のこととが相まって、この地に悪評をもたらした。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時下、幸運にも空襲の被害に遭わなかった尾道には名刹古刹が所狭しと建ちならび、それらが縦横無尽に石段で繋がれている風景は穏やかな海と相まって、名勝として広く人々に知られている。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして上位者たちの腐敗は――一般の不安――跳梁する死によってこの都市のおちいった非常事態――と相まって、下層の人たちのある道徳的荒廃をひき起した。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、レンガが積まれ、次第に頭を現わし、大潮と相まって、工事は順調に進んでいる。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷のような空気と名状しがたい悪臭とが相まって、この部屋は忌まわしい感じがした。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが仏教の渡来ということもあいまってわが国におけるこれらのゲームの絶滅をかろうじて阻止することができたのかもしれない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
