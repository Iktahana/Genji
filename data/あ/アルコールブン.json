        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルコール分について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルコール分の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルコール分が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルコール分について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルコール分の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルコール分が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルコール分という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルコール分についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルコール分は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルコール分が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルコール分は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルコール分の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルコール分は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルコール分は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "実際蘭人達は日本酒、殊にアルコール分の強い泡盛は飲めなかつたのである。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み慣れぬアルコール分のおかげで血のめぐりがズンズンよくなるのを感じながら……。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達の前には、ビールが、美和子と相川さんの前には、バーテンの創案の、アルコール分の少いアヴェック・モア・カクテールが運ばれた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに貧乏生活をしている時でも、コイツとアルコール分だけは座右に欠かさなかったものだが……もはや死ぬまでに何本というところまで漕ぎ付けたんだから、一つ勘弁して頂きたい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿のように疲れた身体を強いアルコール分がグングン馳けめぐるために、谿谷全体がぐるんぐるんと回転するように思われる両眼を見据えて、忠平の死顔を夢のように覗き込んだ。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれは普通の珈琲でなくてウイスキーを割ったものであることが、飲んだ後から解ったので、酒に弱い私は慌てて水瓶を持って来させて、コップで二三杯立て続けに飲んでアルコール分を弱めようとしたがもう遅かった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだアルコール分が頭脳の中に残ってる心地がして、煙草もまずく、食事もまずく、ぼんやり新聞の活字を眼で追いながら、夜中のこおろぎの鳴声を心に聞いた。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アルコール分さえあれば、何でも結構。",
              "citation": {
                "source": "窓にさす影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは腹をふくらすと共に、アルコール分を落着かせ、話題を少くさした。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿はアルコール分を吸収するもの故に酒の酔を醒ますの功あり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、では、あいつ待ちきれなくなって、早くもこっそりと小船に乗るかなんぞして、岸へ抜けがけをして、あのアルコール分を身体の中へ仕込んで来たのだな、そうと解釈するほかはない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、そうしてアルコール分をしっくりと体内に仕込んで帰って、いい気持で寝床にもぐり込むはずのところを、その仕込んだ分量が超過したものだから、ついにあの呂律となり、あのステップとなってしまったのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、マドロスにこうもアルコール分が廻った場合に、この船内では遺憾ながら、それを制裁する実力を持ったものが一人もありませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のところでは、手をつけるより、手をつけないで自然の鎮静を待つよりほかはないと船頭はじめ眉をひそめて、苦々しく思っているのだが、あいにくそのアルコール分はいよいよ沸騰するだけで、いつ鎮静の時を得るか分らないもののようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ小判たったひと晩いてくれろ」という古川柳があるが、ほんとうに当時の私は、腹中のお酒よせめて明日のお昼頃までとどまっていておくれ、そうしたら私は明日の朝の一回のアルコール分だけ助かるのだからと衷心から祈りたい思いでいっぱいだった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコール分は含まれていなくていいのだし、飲んで酔おうというのとは異なるから、かんざましでよいわけである。",
              "citation": {
                "source": "鍋料理の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "又醫員のハヾトフも時々來ては、何故かアルコール分子の入つてゐる飮物を止せ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "また医員のハバトフも時々来ては、何故かアルコール分子の入っている飲物を止せ。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "発案者たる大家さんはひとりで気分を出して悦に入るが、長屋の衆はアルコール分がないから滅入るばかりだ。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした話題転換は随処に見られるが、一例を挙げれば、『六号室』を読んだスヴォーリンが、何か物足りない感じがすると言って来たのに対してチェーホフは、「それはアルコール分の不足だ」という頗る的確な表現を与えるのだが、そこでくるりと身をかわす。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、最悪の場合にも、私は附添婦に顧み、或は強要して、毎夕、一リットルばかりの酒か、それと相当量のアルコール分を注入してもらえばよい。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫酸を入れることによって詐欺的に（アルコール分が）強く見えるようになったビールは、それに酢酸バリウムか塩酸バリウムを滴下することによって、白い沈殿（硫酸バリウム）を生ずる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェーホフは、相手が漠然と感じている不満に、「それはアルコール分の不足だ」という頗る的確な表現を与えるのだが、そこでくるりと身をかわす。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐突なようですが、私がまるでアルコール分に弱いというのは不便のようで、つまらないようで、でも、私のためになっているでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時は知らず、老いてたるみ、皺に包まれた老婆の全身を埋めた刺青の醜怪さから、若い女の起誓をこめた、腕や、内股の名前や、花札や、桜なぞの刺青から、アルコール分の摂取とか、湯に入った時にだけ浮き出る商売女のぼかし彫や、隠彫なぞを見ても全く何の興味も覚えなかった。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年（大正十五年）の六月、百瀬慎太郎氏と二人、案内者北沢清志をつれて大町から富山へぬけた時、二人とも至って酒が好きなくせに、およそアルコール分を含んだものとては一滴も持たずに出かけたものである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは焼酎の強いので、アルコール分が六十度もある、と屋台のおやじが自慢していた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコール分六十度なら、ほかにもっと強い酒があるだろう。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、大酒飲みだったから、身体中がアルコール分になってしまって発火したんだそうだ」「はゝあ」「自然爆発という奴で、強い酒を飲む西洋人には時稀ある現象だそうだが、日本では初めてだと言って医者が感心していた。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
