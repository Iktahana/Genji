        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "然るに近代の多数の南画家の展覧会などに出した作品例えば御定まりの青緑山水のごときものを見ると、山の形、水の流れ、一草一木の細に至るまで実に一点の誤りもない規則ずくめに出来ている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細い幹は鮮かな青緑で、その葉は華奢でこまかに動く。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦爛たる孔雀玉の紫と瑠璃と、翡翠と、青緑。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十騎を一組として四組に別れ、赤黄青緑の服色を別つ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待つた定めの騎士は赤袍を先とし黄青緑と順を逐うて左方より疾騙して場に出づれば、評決場より直に相圖の旗を擧ぐる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼れ目の前に青緑を呈わし、その枝を園に蔓延らせ、その根を石堆にからみて石の家を眺むれども、もしその処より取除かれなばその処これを認めずして、我は汝を見たる事なしと言わん……」とある。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし清麗そのものの『青緑』には、殊に小品ものでは接してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "南に面をむけて瞳をあげると、東方に寄った空がまず透明な淡い白光を現わし、水色を帯び、ややしてあわい青緑色に澄み光って来る。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚びく雲があれば雲のふちを色どり、金粉をはじく金色の征矢を放ち、東天は俄かに青緑の空と、くれないの旭光とで絢爛を現出するのであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠懸　　　　　　ガブリエレ・ダンヌンチオ白波の、潮騒のおきつ貝なす青緑しげれる谿をまさかりの真昼ぞ知す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガブリエレ・ダンヌンチオ篠懸白波の、潮騷のおきつ貝なす青緑しげれる谿をまさかりの眞晝ぞ知す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろを振りむくと、青緑色の山の額や肩や腰が、深い雲霧の隙を偸んで私達の足の疲れを犒つてくれる。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "唇はほほえみ、つぶった双眼の縁は、溶きもしない鮮やかな草色に近い青緑色で、くっきりの西洋絵具を塗ったように隈どられて居る。",
              "citation": {
                "source": "或日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると青緑色の靄が立罩めた薄暗い光線の中に、瘡蓋だらけの醜い背中が露出された。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧のやうな小雨がじめ／＼と時雨れると、何處からともなく蛙のコロ／＼と咽喉を鳴らす聲が聞えて來ると、忽然、圭一郎の眼には、都會の一隅のこの崖下の一帶が山間に折り重つた故郷の山村の周圍の青緑にとりかこまれた、賑かな蛙鳴きの群がる蒼い水田と變じるのであつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば満洲辺で鉄斎の半切画を一枚見て感心し、鉄斎はいつもこればかりやっているのだと早合点するようなもので鉄斎はもっと力作もやれば、随分綿密な青緑山水の大幅もやるのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中のオークルジョスや青緑のペンキか何かが塗られた古風な木造の洋館がトンボ釣りの私の心をいたく刺戟したものであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "画は青緑の設色です。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあなたの心の中にも、――」「山石の青緑だの紅葉の※の色だのは、今でもありあり見えるようです」「では秋山図がないにしても、憾むところはないではありませんか？",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはうつくしい青緑色の閃光だった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては諸官能倦じ眠りて、ひとり千歳を廢墟に埋もれし古銅の花瓶の青緑紺碧に匂ふが如きを覺ゆることあり。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒々しい青緑色の稲妻が天井裏にまで飛びあがった。",
              "citation": {
                "source": "白蛇の死",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "色古浜の着物、綴錦の帯、目立たない派手好みに、帯留の孔雀石の青緑色が、しっくり付いていた。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の水の色は青緑色の海水の如く、「キトロイ」と稱する陶槽を用ゐて此地の住民が之を利用して居つたことは、紀元一世紀の「希臘のベデカー」であつたパウサニアスが夙に記して居る處である。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "森に埋まった丘陵の青緑は反射する日光を映発して金色を彩っている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青緑の海が逆立ちになっている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天空の帯の下に、これも左に細く右へややひろがった青緑の海が動いている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
