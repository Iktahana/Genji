        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "吾子の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かりそめに叱りうべしや吾子といへどこの天地のひとりの男の児　この歌は下手ですが子供を叱ったあとの気もちです。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子を許すではないが政は未だ児供だ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親というものはどこの親も同じで、吾子をいつまでも児供のように思うている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子も真の親の様に思ってくれ私も吾子と思って余所の人は誰だって二人を兄弟と思わないものはなかったほどであるのに、あとにも先にも一度の小言をあんなに悔しがって夜中泣いて呉れなくともよさそうなもの。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一揆等は氏郷に対して十分｜畏れ縮んで居り、一揆の一雄将たる黒沢豊前守という者は、吾子を名生の城へ人質に取られて居るのを悲んで、佐沼の城から木村父子を名生に送り届けるから交換して欲しいと請求めたので、之を諾して其翌月二十六日、其交換を了したのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "有馬、金森、いずれも中々立派に一器量ある人々であり、他の人々も利家が其席を尊くして吾子の利長利政をも同坐させなかった程だから、皆相応の人々だったに疑無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は其子を兼盛の胤では無いと云張り、兼盛は吾子だと争ったが、畢竟これは母が其子を手離したくない母性愛の本然から然様云ったのだと解せられもするが、又吾が手を離れた女の其子を強いても引取ろうとするのはよくよく正しい父性愛の強さからだとも解せられるのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子が受領すべきは、緇き衣と大なる帽となり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈るは吾子の健やかならんことのみなり。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑さは海辺の別荘へ、冬の寒さは暖かな山の温泉へ、何不自由なく過ごせる華やかな今の身の上――それに今の母は強いて綾子を欲しいと願つた程なのであつたから、それこそ玉のやうに大切に、吾子のやうに慈しむでゐるのであつた。",
              "citation": {
                "source": "秋雨の絶間",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉山平助氏に　死ぬ覚悟の押売　▼婦人公論十二月号で杉山平助氏が、『漢口攻略従軍記』を『戦線より吾子に送る手紙』の形式で書いてゐる、この戦地通信は相当枚数の原稿紙を、雑誌社に手渡してゐるから、文章で飯を喰つてゐる人間が、量的に原稿を売る目的はまづ達成してゐるわけである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦の學者今度の櫓下の白骨一件などにあふとすぐ書籍を調べて書籍に見えぬから人柱抔全く無かつたなどいふが、是は日記にみえぬから吾子が自分の子でないといふに近い。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子つれて來べかりしものを春日野に鹿の群れをる見ればくやしき葉を喰めば馬も醉ふとふ春日野の馬醉木が原の春すぎにけり奈良見人つらつら續け春日野の馬醉木が原に寢てをれば見ゆつばらかに木影うつれる春日野の五月の原をゆけば鹿鳴く　思ひ起し、書きつらねて行けばまことに際がない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと海の吾子をおもひて、物怖に胸こそさわげ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑問に悲しみ亂れ、わが泣けば馴寄り水｜如し、『吾子よ、吾ぞ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と思つたか知らぬが、この暑中休暇は東京で暮す積だと言つて来たのを、故家では、村で唯一人の大学生なる吾子の夏毎の帰省を、何よりの誇見にて楽みにもしてゐる、世間｜不知の母が躍起になつて、自分の病気や静子の縁談を理由に、手酷く反対した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と思つてか知らぬが、この暑中休暇を東京で暮すと言つて來たのを、故家では、村で唯一人の大學生なる吾子の夏毎の歸省を、何よりの誇見で樂みにもしてゐる、世間｜不知の母が躍起になつて、自分の病氣や靜子の縁談を理由に、手酷く反對した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子の声にぎやかにくるこの朝の眼ざめのかなしみふき消す如く　おとうさんの歌です。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子のＩに『お前が大学校を卒業する迄、私が無事でいたら、何もかも話して上げる』と云ったのは、Ｔ子が吾子可愛さの余りに、色々と考えまわした揚句に、とうとうそこまで気をまわしていた何よりの証拠だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "釋迦如來皆是吾子等云々。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "非吾子若孫也（『宋史』卷三百十六）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来は「吾子」と言葉を無暗に使用する人もあるが、あれはまた「可愛いい子よ」と呼び掛ける言葉であつて、源氏の中の会話に「あが君」と云つてある所は殊更媚びて云ふ必要のある場合に限られてある。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『齋へる』は此處では、萬葉集卷十九の、『大船に眞楫しじ貫きこの吾子を韓國へ遣る齋へ神たち』の例と同じく、『齋ひ護りて平安にあらしめ給へ神だちよ』（古義）といふ意味である。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは姉が須永に対する義理からでもあろうが、一つは自分に子のできないのを苦にしていた矢先だから、本気に吾子として愛しむ考も無論手伝ったに違ない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、臣の弟｜吾子籠、此事を知れり」と奏上した。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子籠の御答へには「倭の屯田は天子の御田です。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子の皇子と申しても掌る事は許されぬ事になつて居ます」と答へたのは、倭ノ直氏人の中、神聖な物語を継承する資格即｜語部たる選ばれた力が吾子籠にあつたのだ。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家長を祝福した前段と、吾子たちと呼びかけた饗宴に列座してゐる人々に対して言ふ詞章と、とこよたちと言ひかけた客人に申す詞との三段である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二段は、かくの如く出来あがつた新室の作業に、共に働いた同族の人たちに呼びかけて、吾子たちと言つて、酒を勧めるのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
