    "definitions": [
      {
        "index": 1,
        "gloss": "to stop walking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼はそのまま外へ出たが、足を止めるのが恐ろしいので足の向くままに歩いた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのまま外へ出たが足を止めるのが恐ろしいので、足の向くままに歩いた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーロック・ホームズはその店先で足を止める。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の家を云っても好いじゃないの」　小女はちょっと足を止めるようにしたが、すぐ歩き出した。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かい風がうなりを立てて吹きつけて来ると、車夫は思わず車をあおらせて足を止めるほどだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きかけた足を止めると、お婆さんの顔は見えなかったが、言うことはよく聞えた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都には自由党の支部に長岡以来の渋谷黙庵氏がゐたが、帰りに立寄るやうに言つてよこしたので、白峰氏の家に一両日足を止めることにした。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "融はその時は子供に遠慮するやうに、買ふことを止めたが、しかし何うかすると、鞄屋の前に足を止めることが、其の後も時々あつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると栄さんはそういうときの癖で、一寸足を止めるようにして片方の手のひらをひろげ空をうつような恰好をしながら、在りますよ、ホラ、お寺へ出る迄に蕎麦屋があったでしょう、と私よりは永く住っていたその界隈を説明した。",
              "citation": {
                "source": "まちがい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪訝そうに足を止める新らしい通行人も、演説者の狂気を知ると安心して顔を崩した。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は気のせいか、額へ羽搏った蝶の形が、冷やかに澄んだ夕暮の空気を、烏ほどの大きさに切抜いたかと思いましたが、ぎょっとして思わず足を止めると、そのまますっと小さくなって、互にからみ合いながら、見る見る空の色に紛れてしまいました。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふとこの奇蹟に気がつき、洞穴のまん中に足を止める。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし白は引き返すどころか、足を止めるけしきもありません。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ニーチェ――　他の一人は絶頂に足を止めると、昂然と頭をあげて断崖の彼方を一｜睨みし、さてその上で口を結ぶと、黙って平原のほうに帰って来た。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に彼はふと足を止めると、不審そうに行く手を透かして見た。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　牧野は思わず足を止めると、ちょいと耳を澄ませて見た。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女が、犬に追われているらしいぜ――」　と、先棒が、いって、足を止めると、「なに、美女が犬に――おッ、なるほど――犬だって、美女は好きだあな」　と、答えて、「おい、ねえさん、駆けちゃあ駄目だ、逃げちゃあ駄目だ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な仆れ木が横仆わり、それがやっぱり足を止める。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇協会の客足を止めることが、決して前衛座の成功をもたらす唯一の手段ではあるまい。",
              "citation": {
                "source": "幕が下りて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月｜余経った頃には塾生の数も八十人を越し、※唔の声道に響き行人の足を止める程であった。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、常に足を止めることが出来ないのです。",
              "citation": {
                "source": "新しい国語教育の方角",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも、それを商ふ男の、人を喰つた口上が暇な散歩者の足を止めるらしい。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "池内は振り返って足を止めると、三枝は日頃にない落ちつかない声で、「あのね、今日は飛行中一寸頼んで置き度い事があるんだがな」と言った。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ははっとしたが、足を止めるまもなく、先日の提灯はもう無くなってることを知って安堵した。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖のこちらで足を止めると、「おはいりなさい。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原にいっても、いちばん高い木のとがった、頂へ、ちょっと足を止めるばかりなんだ。",
              "citation": {
                "source": "ぴかぴかする夜",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなと思って足を止めると、狂乱じみた若い女が、その歌をうたって歩いて来る。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この陰謀は大きいぞ　両国橋の橋詰めのほうへ、歩いて行く儒者ふうの老人を、「本郷の殿様」と呼ばれた武士は、疑念を差しはさんで見守ったが、足を止めるとつぶやいた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の理由のない圧迫が、浪人の足を止めるからである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでわれわれのあとからついて来る群衆の数が相応になると、さっそく演芸を始めるが、ほんの二、三人気まぐれな冷やかしのお客だけだとみると、わざわざ足を止める値打ちもないので、かまわずずんずん進んで行く。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
