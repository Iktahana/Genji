        "examples": {
          "standard": [
            {
              "text": "私は毎日歩き始めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩き始めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩き始めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩き始めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩き始めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩き始めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩き始めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩き始めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩き始めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩き始めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩き始めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩き始めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩き始めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩き始めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ここから土地の案内に精しい輿水象次氏が一行に加わって、泥道を歩き始める。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一運は、ブリッジをあちこち歩き始めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人、一緒になつたので、「お前たちはお父さんの先きにお歩き」　さう云つて、私たちは県道を歩き始めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不要……」「不要……」　變にむかつ腹の立つやうな氣持でかう繰り返しながら、うるさく迫つてくる俥引達を振り向きもせずに、更け鎭まつた大通のうす暗い歩道の上を、水島君と私とは俯向き勝ちに歩き始めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處から私の泊つてゐるＭホテルまではまだ七八町の道程だつたが、送らうといふ水島君の詞を強ひて斷つて、薄暗い並木の蔭を私は一人俯向き勝ちに歩き始めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」船から小さな棧橋に飛び降ると、二人はかう頷き合ひながら左へ折れて、磯傳ひの道を歩き始めた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばやっと歩き始めた子ねこが、足を踏みしめて立とうとする時に全身がゆらゆら揺れ動くのもこれと似たところがある。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ暫らくして雨に濡れまさる彼れは又川上の方へ向いて街道を歩き始めた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして軈て所天の傍を離れて、椽側を彼方此方と歩き始めた。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて立ツてゐても爲方が無いから、後へ引返す積りで、ぼつ／＼歩き始めたが方角とても確と解ツてゐなかツた。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は山岸猛雄――これも仮名です――という男で、やはり私とおなじ下宿屋に止宿しているのですから二人は肩をならべて歩き始めました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に夜はますます更けて来る、――人々の影はますます少なくなって来る、――彼はますます焦ら立ったもののように、室の中を歩き始めた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、街をゆっくり歩き始めた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそくならんように」そういうと彼は、そのままトランクを持ってスタスタ歩き始めた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に孔雀と美智子と艶子さんは手をとり合つてそろ／＼と歩き始めました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして腕組をしたまま再び靴跡の上を、アテもなく歩き始めた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがていまいましそうに舌打すると、少からず取乱れた足取で大股に歩き始めた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はやむを得ず、かつかつと鳴る二人の靴の音と、自分の上草履の音とをさびしく聞きながら、夫人のそばにひき添って甲板の上を歩き始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、Ｋ君は私を促しましたので、私も速座に賛成の意を表して、二人は（私が回れ右をして）、肩を並べて歩き始めました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗らうとしたが、ふと止めて、彼はスタスタと歩き始めた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また彼は何やら思ふと、一寸立止つただけで引戻さずに歩き始めた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の運轉が止まつてゐるので、舊街道の埃道をてく／＼と歩き始めた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島はあと※しだ、と思ひ捨てながらとつとゝ踵をかへして歩き始めた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじやア／＼降つてゐる雨の中を大股に歩き始めた。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧の姿は見えないが、そのまま山に入り込んでゐる大きな道が正しくその方角についてゐるものと思はれたので、私は賃金を渡すと直ぐ大股に歩き始めた。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた急ぎ足に歩き始めた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとぼとぼと歩き始めると、船にいたよりも私は身体のふらつくのを感じた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、病院の廊下を、大股でゆっくりと歩き始めた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二が牛と、またあるきはじめたとき、泉が何かを知らせる様に、ぐうっと鳴り、牛も低くうなりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二が牛と、又あるきはじめたとき、泉が何かを知らせる様に、ぐうっと鳴り、牛も低くうなりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
