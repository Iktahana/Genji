        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森中学に通つてゐたのです。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森中学に通っていたのです。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝七時八分青森行に乗る。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森湾沿岸の家の屋根の様式は日本海海岸式で、コケラ葺の上に石塊を並べてあるのが多い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車から見た青森市の家はほとんど皆トタン葺またはコケラ葺の板壁である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森市の家屋とは著しい対照である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森湾口に近づくともう前面に函館の灯が雲に映っているのが見られる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森から乗った寝台車の明け方近い夢に、地下室のような処でひどい地震を感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つてから山形、船川港、弘前、青森、津輕海峽を越えて室蘭と寄り道しながら、眼差す苫小牧へと着いたのが七八日頃、それから九月へかけてのまる一ヶ月ほどを妹夫婦の家に暮した。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、私は妹とともに再び津輕海峽を越えわたつて、青森、仙臺と妹の旅疲れを休めながら、十七日の朝、五十日近い北國の旅を終へて、東京へ歸りついた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二六、五、一九、〔以下空白〕五月十九日　　　　　　＊いま汽車は青森県の海岸を走っている。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊青森の町は盛岡ぐらいだった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊船はいま黒い煙を青森の方へ長くひいて下北半島と津軽半島の間を通って海峡へ出るところだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右を見定めて、鍋を片手に乗らうとすると、青森行――二｜等室と、例の青に白く抜いた札の他に、踏壇に附着いたわきに、一｜枚思懸けない真新い木札が掛つて居る……臨時運転特別車但し試用一｜回限り。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の夕刊に青森県｜大鰐の婚礼の奇風を紹介した写真があって、それに紋付き羽織｜袴の男装をした婦人が酒樽に付き添って嫁入り行列の先頭に立っている珍妙な姿が写っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたところは、青森市の寺町です。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森の中学校を出て、それから横浜の或る軍需工場の事務員になって、三年勤め、それから軍隊で四年間暮し、無条件降伏と同時に、生れた土地へ帰って来ましたが、既に家は焼かれ、父と兄と嫂と三人、その焼跡にあわれな小屋を建てて暮していました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに私は、その焼跡の小さい住宅にもぐり込むのは、父にも兄夫婦にも気の毒で、父や兄とも相談の上、このＡという青森市から二里ほど離れた海岸の部落の三等郵便局に勤める事になったのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文体」という雑誌に載っていたあなたの短い小説を読んでから、それから、あなたの作品を捜して読む癖がついて、いろいろ読んでいるうちに、あなたが私の中学校の先輩であり、またあなたは中学時代に青森の寺町の豊田さんのお宅にいらしたのだと言う事を知り、胸のつぶれる思いをしました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、日本は無条件降伏という事になり、私も故郷にかえり、Ａの郵便局に勤めましたが、こないだ青森へ行ったついでに、青森の本屋をのぞき、あなたの作品を捜して、そうしてあなたも罹災して生れた土地の金木町に来ているという事を、あなたの作品に依って知り、再び胸のつぶれる思いが致しました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月にはいってから、私は用事があって青森へ行き、偶然、労働者のデモを見ました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会問題や政治問題に就いてどれだけ言い立てても、私たちの日々の暮しの憂鬱は解決されるものではないと思っていたのですが、しかし、私はあの日、青森で偶然、労働者のデモを見て、私の今までの考えは全部間違っていた事に気がつきました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、私は芸者遊びなど大いにするようになったが、なぜだか弘前で遊ぶのは気がひけて、おもに青森の芸者と遊んだ。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森では夜学校の生徒の奴らが餞別にくれた新しい下駄をおろして、久しぶりで内地の土を歩いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧なさいまし、大阪の大火、青森の大火、御承知でありましょう、失火の原因は、皆この洋燈の墜落から転動（と妙な対句で）を起しまする。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二二ヽ六ヽ二ヽ）青森挽歌　三仮睡硅酸の溶け残ったもやの中につめたい窓の硝子からあけがた近くの苹果の匂が透明な紐になって流れて来る。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森だからといふのではなく大てい月がこんなやうな暁ちかく巻積雲にはひるとき或いは青ぞらで溶け残るとき必ず起る現象です。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その皺くちゃな寛い白服ゆふべ一晩そんなあなたの電燈の下でこしかけてやって来た高等学校の先生青森へ着いたら苹果をたべると云ふんですか。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
