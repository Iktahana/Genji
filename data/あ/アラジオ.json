        "examples": {
          "standard": [
            {
              "text": "私は毎日粗塩について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗塩という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗塩の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗塩が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗塩を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗塩について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗塩の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗塩の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗塩が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗塩という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗塩という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗塩についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗塩を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗塩は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗塩について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗塩が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗塩は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗塩の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗塩は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗塩は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「青りんごを作るには」―――「ハシバミの実の大きさの緑青（verdigris）を細かく潰し、半パイントの蒸留酢および１粒の明礬をとり、少しばかりの粗塩（bay salt）を加える。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "真のダーラム（イングランド北東部）辛子と呼ばれている品物はふつうは、辛子、普通の小麦粉、一部トウガラシ、粗塩、の混合物を水でペースト状にして直ぐに使えるようにしたものである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "２オンス半のトウガラシ、１-1/2ポンドの粗塩、８ポンドの辛子粉、および１-1/2ポンドの小麦粉を、粗塩を前もって溶かしておいた必要量の水で硬いペーストにしたものがいわゆるダーラム辛子であって壺に入れて売られる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし苦汁分の多い日本の粗塩も、またそうすてたものではない。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば鯛のうしおなどは、私は粗塩のほうが好きである。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海沿岸の東北北陸の各地で、広く庶民の間に愛用されている塩魚の出し汁、というよりも秋田のしょっつる鍋といったほうがわかりよいのであるが、あの素朴にしてつつましやかな塩汁の味も、日本の粗塩から生れたものではないかと思う。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっつるのあの少しえがらっぽいようなうら悲しい味は、粗塩を使うところからきているもののように、私には思われる。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう魚の料理の場合に、粗塩のほうがかえってよくあう場合があるのは、ちょっとおもしろいことである。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
