        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背のあたりに白斑二つ三つある赤毛のめす子である。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は木村の、色のさめた赤毛布を頭からかぶって、肩と肩を寄り合って出かけました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、毛のすり切れた、そして、いくらか、白らけた赤毛布の上に高い枕で横たわって、とけるように、まどろんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　親爺は、かなり久しく赤毛布の上でまどろんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹三郎は磨いた煙槍をくわえて、赤毛布の上に横たわり、酒精ランプを眺めながら、恍惚状態に這入ろうとしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、おそろしく大きい赤毛の犬が、ポチに向って猛烈に吠えたてた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチは、れいによって上品ぶった態度を示し、何を騒いでいるのかね、とでも言いたげな蔑視をちらとその赤毛の犬にくれただけで、さっさとその面前を通過した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛は、卑劣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛は、ポチの倍ほども大きい図体をしていたが、だめであった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチは、逃げてゆく赤毛を少し追いかけ、立ちどまって、私の顔色をちらと伺い、きゅうにしょげて、首を垂れすごすご私のほうへ引返してきた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山裾の細い雪みちを、さっきの赤毛布を着た子供が、一しんに山のうちの方へ急いでいるのでした。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいとおもってみんながあたりを見ると、教室の中にあの赤毛のおかしな子がすまして、しゃんとすわっているのが目につきました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛の子どもはいっこうこわがるふうもなくやっぱりちゃんとすわって、じっと黒板を見ています。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪鞋をはいて歩く男のその濡れた藁は重さうにぐつしより濡れて、凍傷を防ぐための赤毛布の脚絆は水を吸ひ飽きたスポンヂのやうに水氣でふくらむ。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいとおもってみんながあたりを見ると、教室の中にあの赤毛のおかしな子がすましてしゃんとすわっているのが目につきました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛の子どもは一向こわがる風もなくやっぱりじっと座っています。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『こら、その赤毛、入れ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりはせまわってふらふらしているとこなどを、ヘルマン大佐になど見られようもんならさっそく、おいその赤毛、入れ、なんて来るからねえ、いくら面白いたって少し疲れさえなおったら出発をはじめるんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かきねのずうっと向うで又三郎のガラスマントがぎらっと光りそれからあの赤い頬とみだれた赤毛とがちらっと見えたと思うと、もうすうっと見えなくなってただ雲がどんどん飛ぶばかり一郎はせなか一杯風を受けながら手をそっちへのばして立っていたのです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物が夜のようにまっ黒、縮れた赤毛が頭から肩にふさふさ垂れまっ青な眼はかがやきそれが自分だかと疑った位立派でした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛はじゃらんと下に垂がりましたけれども、実は黄色の幽霊はもうずうっと向うのばけもの世界のかげろうの立つ畑の中にでもはいったらしく、影もかたちもありませんでした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山裾の細い雪みちを、さつきの赤毛布を着た子供が、一しんに山のうちの方へ急いでゐるのでした。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰の落葉が、屋根越に――　日蔭の冷い細流を、軒に流して、ちょうどこの辻の向角に、二軒並んで、赤毛氈に、よごれ蒲団を継はぎしたような射的店がある。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱顔、蓬なる赤毛頭、緋の衣したる山伏の扮装。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁臺のまんなかにあぐらをかいて坐つたまま大きい碾茶の茶碗でたいぎさうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どほり、午後の四時頃、上野公園の菊ちやんの甘酒屋を訪れたのであるが、馬場は紺飛白の單衣に小倉の袴といふ維新風俗で赤毛氈の縁臺に腰かけて私を待つてゐた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お誂え通り、皺くちゃな赤毛布が敷いてあって、水々しい婆さんが居ますね、お茶を飲んで行きましょうよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と古畳八畳敷、狸を想う真中へ、性の抜けた、べろべろの赤毛氈。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
