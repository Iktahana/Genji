        "examples": {
          "standard": [
            {
              "text": "私は毎日安牌について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安牌という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安牌の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安牌が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安牌を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安牌について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安牌の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安牌の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安牌が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安牌という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安牌という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安牌についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安牌を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安牌は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安牌について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安牌が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安牌は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安牌の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安牌は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安牌は興味深い例である。",
              "source": "幻辞"
            }
