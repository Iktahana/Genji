    "definitions": [
      {
        "index": 1,
        "gloss": "to get",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有り付くについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有り付くという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有り付くの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有り付くが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有り付くを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有り付くについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有り付くの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有り付くの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有り付くが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有り付くという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有り付くという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有り付くについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有り付くを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有り付くは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有り付くについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有り付くが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有り付くは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有り付くの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有り付くは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有り付くは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで彼女達い有り付くと、玄人ともつかず素人ともつかぬ新しい味わいがあるね。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は何々教師の免状を取れば、此くらゐの月給に有り付くと云ふので、先づ算盤をせゝくつて、計算した上で教育する。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは何々教師の免状を取れば、これくらいの月給に有り付くというので、先ず算盤をせせくって、計算した上で教育する。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはさうと薬にしろ食物にしろ、君はどうして有り付く事が出来るね。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "「選択」してる内に、外の仲間が、それにありつくんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "渓流で小ざかなをつかみ取りにしたり、野獣を射止めて思わぬ珍味にありつくこともおりおりはあるそうである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りあってくれない奴だの、ばかにして話に乗らない奴だの、自分の金の不足になったことだけを知っていて、油を搾ろうとする奴だのにかかってはまったく面倒だ……それとももう一度婆やを泣かせようかとも思ったが、はした金にありつくのに、婆やの長たらしい泣き言を辛抱して聞いているのはやりきれない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い込んで思うさま甘めえ御馳走にありつくんだてったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「春時分は、筍が掘って見たい筍が掘って見たいと、御主人を驚かして、お惣菜にありつくのは誰さ。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽が西の海に入って、麺麭の大樹の梢に大蝙蝠が飛び廻る頃になって、漸く此の男は、犬猫にあてがわれるようなクカオ芋の尻尾と魚のあらとにありつく。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "静養かたがた女で間に合う家業でつないで、そのうち一株ありつく算段で、お伽堂の額を掛けたのだそうである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに給仕も寝てしまったから、もう一本蝋燭にありつく望みもないからな――。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう前のような職にありつくことは出来ないかと思いました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の点は、ピイクロフトがこの盛大なる結構な会社の職にありつく時、宣誓書を書かされたと云うことだ。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の口にありつくまでそりゃもう苦労のし通しでしたので。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪にくッつけてさ、それ、大かぶにありつく、とか云って、買手が喜ぶものだそうだ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その例外に太い握り飯にありつくのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、そればかりではない、つい二年前、大学を出てから職業にありつくまでの半年間を、彼はやっぱり図書館で暮していたのだ。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か私には、私だけ気のつかない非常な欠陥があって、それは他人には一目でわかるので、そのために私はどこへいっても職にありつくことができないのだろうとすら私は考えました」「とうとう恋しい民子にもあわずに、生存の戦いに敗れて自滅してゆくのだと思うともう世の中が急に真っ暗になったような気がするのです。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だん／＼私には、交通費や飯にありつくために出掛けることさえ余裕なくなり、その喫茶店には三日に一度、一週間に一度、十日に一度という風に数少なくなって行った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……じゃあここらで、昼食にありつくとしようか」　そこで私達は物置の外に出た。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に行って暦が売れるか、ある職業にありつくかするまでは、餓を忍んでも暮さなければならないような境遇であった。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四二　陽がもう全く暮れてから、ようやく食事にありつくと甲谷は再び元気になった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは家主の用意してくれた簡単な食事にありつく。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりにて御飯にありつく、うまかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……呉郎さんを訪ふ、不在、山口へ出かけて、Ｓ君から切手を貰つて手紙を出す、Ｕ君から当面の米代を借りる、途中一杯ひつかける、とてもうまい一杯だつた、帰つて来て、さつそく米を買うて御飯にありつく、何だかがつかりした！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかりの収入にありつくようになってからは、そのなかからいくらかずつ割いて贈ることも怠らなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村は不景気の風に吹きまくられて、百姓はその日のパンにさえありつくことが出来ません。",
              "citation": {
                "source": "村からの娘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はそれでいいとして日本の兵卒があれでは堪まるまいって※　この土煙のなかを引きずり廻わされて、ぼろい儲にありつくのは君一人さね、あ、は、は、………………」　隊長は眼のなかへ飛び込んで来る土煙を、ハンカチで払いのけながら、濶達に笑った。",
              "citation": {
                "source": "シベリヤに近く",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明さんから、ポケツトマネー（五十銭玉一つ）頂戴、それでやうやく煙草、焼酎にありつく。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
