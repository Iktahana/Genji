    "definitions": [
      {
        "index": 1,
        "gloss": "announcement (esp. over public-address system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナウンスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナウンスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナウンスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナウンスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナウンスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナウンスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナウンスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナウンスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナウンスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナウンスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナウンスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナウンスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナウンスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナウンスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "既にして場内アナウンスの少女の声が、美しく神秘的である。",
              "citation": {
                "source": "星の劇場",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオのアナウンスみたいな手紙の書き方をお許し下さい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオが湯気に籠りながら、山の初日の出見物の光景をアナウンスする。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――今月のプラネタリュウムの話題は、星の旅、世界一周でございます」　こんな意味の女声のアナウンスが終ると、美しい音楽がはじまり、場内はだんだんに黄昏の色に染まって、西の空に一番星、二番星がぽつりと浮かび、やがて降るような星空が天井に映しだされた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな意味の女声のアナウンスが終ると、美しい音楽がはじまり、場内はだんだんに黄昏の色に染って、西の空に一番星、二番星がぽつりと浮かび、やがて降るような星空が天井に映しだされた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "１Ｂ／ＮＯＴＥの発売に先だって、同社はＰＣ―９８０１にくっつける例の奇妙なＴＲＯＮキーボードの予約販売をアナウンスしていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、日が暮れかかり、六時一〇分まえに二階食堂に制服着用で集合、というアナウンスをきいたときには、さすがにさびしさを覚え、どうしてこんなところにきたのだろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーター＆ゴードンの〈ゴー・トゥ・ピーシズ〉を聴きながらベッドをなおし、パジャマを脱いでいると、点呼は居室です、というワラのアナウンスがまたはいり、ハーマンズ・ハーミッツの〈キャント・ユー・ヒア・マイ・ハートビート〉になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平部員ではかわいそうだと、高志が「技術主任兼アナウンス担当兼書記」に任命してあげたからだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎朝「局」でやっていた、起床放送のアナウンスも、「晴用」と「雨用」のふたつのテープに録音して、寮事務室の「おっさん」たちに、まかせきりにしてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、この機会をはずさずに、火星探検のテレビジョン放送をやるから、すぐに世界各国へアナウンスをしてくれたまえ。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをアナウンスされた全世界は震駭した。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの気象通報は、中国大陸にあった高気圧が東行してかなり裏日本に迫り、北西風が強く吹き募ってきたことを報じた上、Ｔ市地方は二、三日うちにまた雪になるでしょうと有難くない予報をアナウンスした。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアナウンスもやがてぷっつりと切れ、暗黒なエーテルの漂う夜空からは、内地の放送局が一つ一つお休みなさいを云って電波を消してゆき、あとには唯一つ、南京放送局の婦人アナウンサーが哀調を帯びた異国語で何かしら悠くりと喋っている声だけが残っていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月　十五日　十月三十日にアナウンスするにきめた。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　（一）　Lake George.　（一）　西、　一、いやな手紙　一、牧田の追跡　一、帰紐、　一、その夜　一、クレアモント　一、アナウンス　一、仕事　その他　一、故国よりの手紙　一、相談　一、かえる。",
              "citation": {
                "source": "「伸子」創作メモ（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその時点では、価格も当初のアナウンスよりは、かなり高めになっている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、ＰＣ―８００１発売のアナウンスのあったあと、コンポＢＳの値引きが始まっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勢いにさらに拍車をかけようと、ＴＫ―80ＢＳのアナウンスと同時に、機能はそのままに定価を従来の八万八五〇〇円から六万七〇〇〇円へと切り下げたＴＫ―80の廉価版が、ＴＫ―80Ｅの名称で発表された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発グループによる事前の働きかけによって、出荷までに五〇種類のＰＣ―６００１用のプログラムがサードパーティーから発売され、近々に二〇〇種類まで拡大されるとアナウンスされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八一（昭和五十六）年八月、ＩＢＭ ＰＣの発表と同時に自らの製品としてＭＳ―ＤＯＳ１・０を発表したマイクロソフトは、一九八二年四月、ＧＷベーシックのアナウンスを行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日立は四〇字×八行（二四〇×六四ドット）を表示できる液晶の部品供給をアナウンスしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その二つのコンピューターを、私に作らせてもらえませんか」　機内に響くアナウンスの声を押さえ込むように、稲盛和夫がそう言った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考出品された段階で、出荷開始予定は一九八二年の春、予価は基本構成で約八〇万円とアナウンスされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内版の発表に合わせて、アドバンスト・パーソナル・コンピュータ（ＡＰＣ）と名付けてアナウンスするこのマシンの売り物として、端末グループはＩＢＭの大型用端末３２７８の機能を備えている点と、ＣＰ／Ｍ―86とＭＳ―ＤＯＳの採用を強調しようとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月半ばに予定されているデータショウの直前にアナウンスすると決まったスケジュールを睨んで、発表時点で六〇種類の対応ソフトがあると打ち上げ、データショウではＮ―10を並べた日本電気のブースでアプリケーションの宣伝を行うプランが練られた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "米ＩＢＭは急成長を遂げたＰＣの上位機種として、ハードディスクを内蔵したＸＴを一九八三年三月に発表する一方で、同年十一月、低価格版のＰＣジュニアをアナウンスした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前がたがあっちでフリーボラスな心持で知らなかっただろうが、お前方のアナウンスに対して、誰から祝が来たかと云うのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「アナウンスをいたします。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして……「アナウンスいたします。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
