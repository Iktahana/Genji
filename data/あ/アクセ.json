        "examples": {
          "standard": [
            {
              "text": "アクセは日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "アクセ対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "アクセに関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品ではアクセがテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からするとアクセは複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、アクセの症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルはアクセを核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新によりアクセの問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学におけるアクセの表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "アクセについて学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日アクセについて悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点からアクセを分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究によりアクセの原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちはアクセを表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室でアクセに関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "アクセは日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "アクセ対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "アクセに関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品ではアクセがテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からするとアクセは複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "聞きながら、大きいガツテンガツテンを、アクセントをつけてやつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセントはどうか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセントでは、だめか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに最近の「忘れちや厭よ」や「あなたと呼べば」等は歌詞に強いアクセントをつけ、その言葉の方の面白味で、専ら聴者を興がらす様に工夫されてる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忘れちやイヤーヨ」といふ、イヤーに於ける強いアクセント等、皆歌詞を主眼にして、音楽の旋律をこれに附加して居るのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の言ふことも、さう、そんなこともあるよ、とＫ君は獨特のアクセントで言つてたいてい贊成してくれる。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し進んだのになると、鼻や小鼻の曲線のあるデリケートな抑揚をつかまえて、これを少しアクセンチュエートする事によって効果を挙げ、あるいは手足の機微な位置によって複雑な感情を暗示するものもある。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの店の店員や主人は「石油ランプはドーモ……」と、特に「は」の字にアクセントをおいて云って、当惑そうな、あるいは気の毒そうな表情をした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、その聲はアクセントこそ違つてゐたが、はつきりした日本語だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄のひゞきと、滑桁の軋音の間から英語のアクセントかゝったロシア語が栗本の耳にきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が口にする「アナタア」には、露骨にこびたアクセントがあった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食らう時かたわらよりうまきやと問えばアクセントなき言葉にてうましと答うその声は地の底にて響くがごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい炭取りくらいの大きさの竹かごを棒切れの先に引っかけたのを肩にかついで、跛を引き歩きながら「丸葉柳は、山オコゼは」と、少し舌のもつれるような低音で尻下がりのアクセントで呼びありくのであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして観者の頭の中の映画に強いアクセントを与え、同時に次の進展への衝動と指針を与える。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや錯覚かと思って注意してはみたが、どうも老人の唄の小節の最初の強いアクセントと同時に頸を曲げる場合が著しく多い事だけは確かであるように思われた。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセント分解についての詳細は下記URLを参照してくださいhttp://aozora.gr.jp/accent_separation.html-------------------------------------------------------第一双の眼の所有者（むしゃくしゃした若い古物商。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれの暗示する言語が東京のそれでもなく、どこのそれでもなく、故郷の然も私の家族固有なアクセントであることを知りました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "内蔵助が「目的はたった一つ」という言葉を繰り返す場面で、何かもう少しアクセントをつけるような編集法はないものかと思われた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉のよくわからないせいもあろうがいったいに前のスターンバークの「モロッコ」などに比べて歯切れが悪くてアクセントの弱い作品のように思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に自分の頭の中のどこかのすみを他の同窓のだれかれの影が通り過ぎてすぐ消えたのかもしれない、そうして中でもいちばん早くなくなったＳ君の記憶が多少特別なアクセントをもって印銘された、その余響のようなものがこの夢のＳ君出現の動機になったのだと仮定すると不思議でなくなる。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがなんだかどなりつけるかまたしかり飛ばしでもするような強烈なアクセントで天地に鳴り響いたのであった。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿蘭陀の通事たちに、シロオテの日本へ渡って来たわけを調べさせたけれど、シロオテの言葉が日本語のようではありながら発音やアクセントの違うせいか、エド、ナンガサキ、キリシタン、などの言葉しか聞きわけることができなかったのである。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセントのおかしいイタリア人の声が次第に高くなる。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず試みに「炭俵」上巻の初めにある芭蕉｜野坡の合奏を調べてみると、「むめが香にのっと日の出る山路かな」の発句にはじまって、「屏風の陰に見ゆる菓子盆」の揚げ句に終わる芭蕉のパートにはいったいにピッチの高いアクセントの強い句が目に立つ。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのあまりに不自然に強調された手首のアクセントが自分には少し強すぎるような気もした。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この抽象と強調とアクセンチュエーションは、人形の顔のみならず、その動作にも同じ程度に現われる事はもちろんである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て来る画面も出て来る画面もみんな一様に単に絵の具箱をぶちまけたような、なんのしめくくりもアクセントもないものでは到底進行の感じはなくただ倦怠と疲労のほか何物をも生ずることはできないであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
