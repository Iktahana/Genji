        "examples": {
          "standard": [
            {
              "text": "私は毎日在りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "在りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は在りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には在りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "在りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは在りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "在りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は在りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では在りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "在りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に在りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では在りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "在りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると在りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "在りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では在りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に在りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により在りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "在りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に在りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
