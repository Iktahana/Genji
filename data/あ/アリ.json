        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日蟻について考えている。",
              "source": "幻辞"
            },
            {
              "text": "蟻という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は蟻の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には蟻が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "蟻を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは蟻について学習した。",
              "source": "幻辞"
            },
            {
              "text": "蟻の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は蟻の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では蟻が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に蟻という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では蟻についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "蟻を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると蟻は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では蟻が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に蟻は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により蟻の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "蟻は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に蟻は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たとえば裏の竹藪に蛇が出たとか、蟇が鳴いてるとか、蟻の山が見つかったとか、梅の花が一輪｜咲いたとか、夕焼が美しく出ているとかいうようなことを、だれか家人の一人が発見すると、一々それをヘルンの所へ報告に行く。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の部屋の窓を夜どおし明けはなして盗賊の来襲を待ち、ひとつ彼に殺させてやろうと思っているのであるが、窓からこっそり忍びこむ者は、蛾と羽蟻とかぶとむし、それから百万の蚊軍。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の真正面あたりに、土塀に近く植つてゐる古い大きい柿の樹の根元には、蟻達が忙しさうに働いてゐる。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハータ、ターコ、コーマ、ハート……」そこまで読むと彼女は、ほんの今まで見てゐた、群から一寸外れて歩いてゐた蟻は、もうどのへんに行つただらうと思ひながら柿の樹の根元を見る。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もう、どれがどの蟻だか分らなくなつてゐる。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛蟻とぶや富士の裾野の小家より　広茫たる平原の向うに、地平をぬいて富士が見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山麓の小家の周囲を、夏の羽蟻が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この表現効果の主要点は、羽蟻という小動物。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち読者は、羽蟻という言葉によって、そうした高原地方の、夏の日中の印象を与えられてしまうのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし羽蟻は絵に描けない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足許に白蟻ほどの小粒なのが、空から投げだされて、算を乱して転がっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此夏、鮎釣りに泳ぎ渡つた際、大きな蟻に臍を食ひつかれて愕いた、竜宮岩も紅葉の間に浮んで、静もりかへつてゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことに驚いてゐる私の臍に蟻が食ひついたのである。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな真つ黒い山蟻といふ奴である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "臍といふものは人間の重心であるから、この蟻はその運搬の技法からいへば、完全に近かつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、悲しいかな、私の方が蟻より大きかつたものだから、蟻の足は岩に届かないで、私の臍の近くでつゝぱつてゐるだけだつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると外にも大小の蟻がゐるのである。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは堪まらぬ、と私は早々に蟻を払ひ落して、岩を伝はつて逃げ下つた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間に食ひついた最初の蟻だらう、それは。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の可能性に盲目な點では人間も蟻も大してちがはない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の見た蟻や蜜蜂のやうに個體の甲と乙との見分けが付かなくならなければ其の「集團」はまだ本物になつて居ないと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せんざんこう、蟻食いの類に過ぎぬ。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけなさいまし」　嵌り込んだら最後、まるで飴にかかった蟻のようになるのであると言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉をつたい歩く蟻にとりては一粒一粒の雨滴の落つる範囲を方数ミリメートルの内に指定する事が必要なれども、吾人人間には多くの場合にただ雨量と称する統計的の数量が知らるれば十分なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に肝心な研究費はいつでも蟻の涙くらいしか割当てられない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月二十七日『東京朝日新聞』）　　　　　　　　　二十七　　　　　　蟻の知覚　蟻が温度の変化に対してどれだけの感覚力をもっているかという事を調べた人の説によると、大抵の蟻は摂氏の〇・五度くらいなわずかな変化でも識別するそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十二日『東京朝日新聞』）　　　　　　　　　三十七　　　　　　ロシアの蟻　露国のカザン大学は古来有名な科学者の出た処である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――額をみ給へ――一度は神も客観してやりました――不合理にも存在価値はありませうよだが不合理は僕につらい――こんなに先端に速度のある自棄　々々　々々下駄の歯は僕の重力を何といつて土に訴へます「空は興味だが役に立たないことが淋しい――精神の除外例にも物理現象に変化ない」ガラスを舐めて蠅を気にかけぬ",
              "citation": {
                "source": "（古る摺れた）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
