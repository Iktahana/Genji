    "definitions": [
      {
        "index": 1,
        "gloss": "protecting the skin from becoming rough",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒れ止めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒れ止めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒れ止めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒れ止めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒れ止めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒れ止めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒れ止めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒れ止めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒れ止めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒れ止めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒れ止めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒れ止めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ止めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒れ止めは興味深い例である。",
              "source": "幻辞"
            }
          ],
