        "examples": {
          "standard": [
            {
              "text": "私は毎日歩み寄りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩み寄りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩み寄りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩み寄りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩み寄りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩み寄りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩み寄りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩み寄りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩み寄りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩み寄りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩み寄りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩み寄りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩み寄りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩み寄りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのかわり、――」立ちあがって、つかつか太宰のほうへ歩み寄り、「ばけもの！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（絵具入の箪笥に歩み寄り、紙巻を一本取りて火を付く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徐に戸の口に歩み寄り、徐に戸を開き、退場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は徐に煖炉に歩み寄り、その上なる素焼の瓶を取りて絵具入の箪笥の上に据え、それに翁草の花を挿す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかと歩み寄りて何者ぞと声かけ、燈をかかげてこなたの顔を照らしぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかはり、――」立ちあがつて、つかつか太宰のはうへ歩み寄り、「ばけもの！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯は、すぐに笑いを鎮めて、熊本君のほうに歩み寄り、「読書かね？",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（ふらふらと門に歩み寄り、内を覗ひながら。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五　小親わが方に歩み寄りしが、また戻りぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言いかけて少し歩み寄りたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし行人で二人の姿を見て佇む様子に動くこゝろがあるらしいと見て取れば彼等は、乞食のカンで察して猶予なく歩み寄り、「一銭頂戴な」と掌を差出すのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　美和子は、姉の泣き顔を一目見ると、急に前川夫人に対して、猛然たる敵意を感じたらしく、その可愛い眼に、殺気を漂わせ、部屋の内にはいって、姉の傍に歩み寄りながら、「お姉さま、どうしたの？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　駐在巡査は歩み寄りながら大声に言った。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉田は歩み寄りながらいった。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は、この方を自分の夫だと思っているのだわ」　看護婦の一人は彼女に歩み寄りながら言った。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　級長の杉村が田中のほうへ歩み寄りながら訊いた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして寝台へ歩み寄り、しばらく見つめていたが、壁を上から下へ眺め回した。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部は何も言わずに扉の方へと歩み寄り、呼子を吹いた。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は窓際へ歩み寄り、賑やかな通りを見下ろした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時母上も歩み寄りてのたまふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "式畢りて後、われは友の側に歩み寄りしに、彼は明日こそと云ひもあへず、走り去りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "君等の歩み寄り給ひしときは、われ早くこゝに坐して涼を貪り居たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは暫くこれに注目せしに、少女は我前に歩み寄りて、傍なる小卓を指し、おん敵手にはなるまじけれどと耳語きたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は我傍に歩み寄りて、おん身も人々の歡を分ち給はずや、われ若しおん身の憂はしき面を見て別れ去らば、尼寺に入りて後に屡※御身の上を氣づかふならん、かくてはおん身我に罪障を増させ給ふなりと宣給ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方も亦直ちに我を認め得つとおぼしく、何の猶豫ふさまもなく、我側に歩み寄りて我胸を抱き、めづらしきかな、アントニオ、われ等の相別れし夕は賑やかなりき、われ等は祝砲をさへ放ちたり、されど想ふに我等の友情は舊の如くなるべしといひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは、さっさと帰るのだが、きょうは、お膳をベッドの傍の小机に載せて、それから伸び上るようにして窓の外を眺め、二、三歩、窓のほうへ歩み寄り、窓縁に両手を置いて、僕のほうに背を向けたまま黙って立っている。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に歩み寄りて一間ばかりに近けば、貫一は静緒に向ひて慇懃に礼するを、宮は傍に能ふ限は身を窄めて密に流盻を凝したり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川は机の傍に歩み寄りながらいった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤十郎　（引き付けられたように、歩み寄りながら、じっと死顔に見入る。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仙人は静かな足どりで、驢馬のいる方へ歩み寄りました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
