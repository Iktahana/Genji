[
  {
    "uuid": "b1335df8-6db7-5adf-b62a-826c0fe8f469",
    "entry": "安住",
    "reading": {
      "primary": "あんじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "living in peace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安住について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安住という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安住の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安住が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安住を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安住について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安住の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安住の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安住が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安住という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安住という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安住についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安住を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安住は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安住について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安住が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安住は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安住の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安住は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安住は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "而も猶一方、その「修辞的」だけにも安住しきれないものがあつて、かくて観念的要求といふかそれとも宗教的要求といふかともあれさうした要求と、修辞的要求とは互ひに反動的関係に立つて、個人の内部で鬩ぐのである。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、田舎の川べりにでも住んで、夏は縁台を出して夕顔の花をみてゐるといふ、あの消極的平安の中に安住しなければならないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対的安住の世界が得られないまでも、せめて相対的の確かさを科学の世界に求めたい。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正統的教養の楽園に安住する専門的物理学者の目から見れば、あまりに空想をたくましゅうした叙述が多かったように見えるかもしれない。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今度襲われる地方がどの地方でそれが何月何日ごろに当たるであろうということを的確に予知することは今の地震学では到底不可能であるので、そのおかげで台湾島民は烈震が来れば必ずつぶれて、つぶれれば圧死する確率のきわめて大きいような泥土の家に安住していたわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の知っている人の内でも、たぶんそうらしいと思われるほどの長時間をこの境地に安住している人はある。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の領土に安住を求むるか、センセーションを求めて奇を弄するかに迷わざるを得ないのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い所から下を見てあざわらふ、そんな卑劣な惡魔的な態度に安住すべきでない。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ　先つきのお話のやうに、今のところは村の出這入りが多少あつても『新らしい村』などの場合と違つて、家族と一緒に暮すのですから、割合に居着き易いと思ひますが、それに土地が自分のものにはなるし、暮し易くはなるしするのですから、段々安住する気になると思ひますが。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはあなたに捉えられてそこに安住するとき、却てあなたを罠ごとわたしの生命に浄化する便りになることがわかったのです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで母の存在と自尊心によってのみ生きて来たのであるから、その時、母を冒涜されることによって同時に自尊心を傷つけられたということは、彼にとって敢て誇張するならばもはや安住すべき世界を喪ってしまったことを意味するのである。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平はこの年になっても持前のわがままがぬけず、別にこれと言って希望もなく、今後の生活の設計があるのでもなかったが、そうかと言ってそこに全く安住している気にもなれず、絶えず何か焦躁を感じていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の安住する世界はいつも美しい、夢のやうに不可思議で、夢のやうに美しい。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈もそれの境地に安住すれば快楽であり、却つて詩興の原因でさへあるといふことを、私は子規によつて考へさせられた。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれよりも健康で精力に弾ち切れさうな肉体を二つ野の上に並べて、枝の鳥のやうに口笛を吹きかはすだけで、充分愛の世界に安住出来るほど徹底して理解し合つた男性と女性とでありたく思ふのです。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も安住を許されない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然もかれはこの物質上の貧困によつて却つて現世の念慾を絶つを得、瞑思一徹、心に無限の富を得るに至つて、彼や、人の悶々｜措く能はざる極貧の境涯に淡然として安住するを得るに至れり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以来、幾何学的な解剖と固形的な認識とを以て万有のとゞめを刺したとする西欧文化に養われて来た私たちの頭が、何でこゝに安住出来ましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども、読者よ請ふ汝の謹厳なる眼を開けよ、宇宙の大精神は一定の塲所に安住せず。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に疲れた者、倦んじた者、刹那の間だけでもぐツすり一と安心して眠つて見たい――然し又死人の安住は得たくない――睡いやうでも、いつも覺めてゐる自分の神經の働らきが、地上を離れては、一層自分の目前にちらついて見える。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "持って生れた平和な性から、不満な家庭の味気なさに安住することに努め、内にも外にも、人間らしい色彩を失いかけていた彼である。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮も、高麗、新羅、百済、任那など互に攻略して、其処も安住の地でないので、彼等の中には、交通のやうやく開けたのに乗じ、山紫水明にして、気候温和なるわが国に移住帰化したものが多かつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第二章　ユタの華　ここには、モルモン教徒が道中どのような試練や苦しみに耐え、そして安住の地へ辿り着いたかを詳しく書かない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀の安住は、戀の幸福は、死と生を超越しなければ得られないものであつたらうか。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "矛盾撞着……信仰のない生活は、いかりを持たない船にひとしく、永遠に安住のないことを深刻に恥じた。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら彼は境遇の異常な刺戟から寸時も其の身を安住せしむる餘裕を有たなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に安住の場所を失うた胎兒は自然に母體を離れて出ねばならなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も安住をゆるされない。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、論理的抽象観念の超感覚圏から、悪魔に対する贖罪金を支払つて、精神生活上の最下級の安住地であるべき可見世界に渡りをつけて再び矛盾と闘ふべき情熱に欠けてゐた。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
