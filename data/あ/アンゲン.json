    "definitions": [
      {
        "index": 1,
        "gloss": "Angen era (1175.7.28-1177.8.4)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安元について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安元という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安元の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安元が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安元を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安元について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安元の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安元の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安元が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安元という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安元という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安元についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安元を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安元は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安元について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安元が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安元は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安元の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安元は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安元は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一　斉衡元暦の地震、安元の火事　日本の地震で最初に文献にあらわれているのは、「日本書紀」の允恭天皇の五年七月、河内国の地震で、次が推古天皇の七年四月の大和国の地震である。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「方丈記」にも、「去にし安元三年四月二十八日かとよ、風烈しく吹きて静かならざりし夜、亥の時ばかり、都の巽より火出で来りて、乾に至る。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三斎の歿年から推せば、三回忌は慶安元年になるからである。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "建久四｜癸丑年に十九なら安元元｜乙未年すなわち未歳生まれで寅歳でない、『東鑑』は偽りなしだから『異本曾我物語』は啌で寅歳生まれで虎と名づけたでなく寅時にでも生まれたのだろ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一話一言』一六に、『会津旧事雑考』より承安元年｜辛卯を耶麻郡新宮の神器の銘に、弥勒元辛卯と記した由を引き、三河万歳の唱歌に、弥勒十年辰の歳、諸神の立ちたる御屋形と唄うも、いずれなき事にはあらじかし、とある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "永正三丙寅と承安元辛卯、いずれも弥勒元年とするもその十年は乙亥か庚子で辰の歳じゃない。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち小便については別に諸方の例を挙げ置いたが（立小便と蹲踞小便）、その後見出でたは、慶安元年板『千句独吟之俳諧』に「佐保姫ごぜや前すゑて立つ」、「余寒にはしばしはしゝを怺へかね」、まずこれが日本で女人立ち尿の最古の文献だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶安元年板『千句独吟之俳諧』には「枕上の時鶏に夢を醒されて」「南蛮人の月を見るさま」と時鶏の字を用い居る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その長は中務少輔安吉にして脇坂淡路守安元の養子となりたる人也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「治安元年八月廿八日　以石泉御本写之已了　康平六年七月　於平等院　奉受此経　仏子快算」とあり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "多紀氏宗家では暁湖元は此年の武鑑奥医師の下に「多紀安良法眼、父安元、二百表、向柳原」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安元は柳庭元堅が此年二月十三日に歿して、子｜雲従元で、其父楽春院は元堅である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の事ではっきりとは覚えていないのだが確か安元三年四月二十八日位であったと思うが、風の物すごく吹いている日で、遂には大嵐となった日の事である。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いにし安元三年四月廿八日かとよ、風烈しく吹きてしづかならざりし夜、戌の時ばかり、都のたつみより火出で來りていぬゐに至る。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ松野殿へ、弘安元年五月一日に與へられたのには、日月は地におち、須彌山はくづるとも、彼女人、佛に成らせ給ん事疑なし。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十七日（弘安元年）　同二年十二月二十七日は、尼が初春の料の餅をおくつたと見えて、十字（蒸餅）五十まい、くしがき一れん、あめをけ（飴桶）一、送給畢。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従三位藤原ノ朝臣泰文は「悪霊民部卿」という忌名で知られている藤原ノ忠文の四代の孫で、弁官、内蔵頭を経て大蔵卿に任ぜられ、安元二年、従三位に進んで中納言になった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』によるに、仲哀天皇の崩年は壬戌の年で、多分晋の恵帝泰安元年の壬戌のことと察せられる。",
              "citation": {
                "source": "石上神宮の神宝七枝刀",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "室町時代文安元年の「下学集」に、穢多屠児河原者　とある。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "延暦寺の散所法師については、わずかに岩橋小弥太君から示された『応安嗷訴記』の、応安元年八月廿五日政所集会議曰、　重可被相‐触寺家事来廿八日神輿入洛事、三塔既令一同之間、更不有予議之処、西坂路次、険※無極之条、穴太散所法師原存奸曲故也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそう古いことを言うようですが、あの杉並木は、慶安元年に駿河の久能山に葬った権現様を、御遺言で日光山に改葬し、東照宮を御造営の折り、譜代外様を問わず、諸侯きそっていろいろな寄進をなされた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永元年から慶安元年まで二十余年の苦心で植えたのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一例として『弁註』の著者天桂（慶安元―享保二〇、一六四八―一七三五）が「葛藤」の注中に記した言葉を引こう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜川の軍　安元三年三月五日、藤原｜師長は太政大臣、その後を重盛が襲って内大臣に任命された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで話は二年程さかのぼって安元元年｜加賀守に任ぜられた師高という男があった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "折柄行われる予定の日吉の祭礼をとりやめると、安元三年四月、御輿を陣頭に京へくり出して来た。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "安元三年七月二十日出家、同二十六日、信俊下向とあるところで、少将は始めて源左衛門尉信俊がここを訪ねたことを知った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金渡し　安元の頃、重盛は、九州から妙典という船頭を呼び寄せ、人払いして親しく目通りをしたことがある。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる安元以来、多くの大臣公卿を殺し、あるいは流し、法皇を押しこめたり、第二皇子高倉宮を討ちとるなど、悪逆非道の行ないを尽している平家の残された悪行は、都うつりだけである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰文は悪霊民部卿という通名で知られた忠文の孫で、弁官、内蔵頭を経て大蔵卿に任ぜられ、安元二年、従三位に進んで中納言になった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
