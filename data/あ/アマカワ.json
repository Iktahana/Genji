    "definitions": [
      {
        "index": 1,
        "gloss": "cuticle (of a nail)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘皮について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘皮という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘皮の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘皮が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘皮を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘皮について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘皮の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘皮の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘皮が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘皮という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘皮という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘皮についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘皮を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘皮は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘皮について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘皮が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘皮は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘皮の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘皮は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘皮は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "渋茶、甘茶、渋糟、甘糟、渋皮、甘皮などの反対語の存在も、この対立関係を裏書する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働が持つあらゆる苛酷さと嚴しさを通り、甘皮を剥いたそれの核心に觸れた上での喜びを期待してゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の足許は申すに及ばず、私の膝の上まで甘皮が散っている。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のほうに向き、鼻の先へ手を持って行ってにおいを嗅いだり、爪の甘皮をむしったりしていたが、妹が立って行くと、「今日は、なんだったんだい」　と探るような眼つきをした。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りで庵を訪ねた主人の前へ、一色道庵の示した丸藥の成分と言ふのは、人參、松樹甘皮、胡麻、※苡仁、甘草の五味だけ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "一色道庵はこの丸藥と同じ物を作れと言はれ、林の中の大名の下屋敷の離屋に十日も留められたさうで御座います」「フ――ム」「本田蓼白と伊東參龍の見分けた成分は、松の甘皮と胡麻と甘草で、一色道庵はその上人參と※苡仁を見つけた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "人參、甘草、※苡仁、それに胡麻と松の甘皮、――其處までは誰でも解るが、殘りの二味がむづかしい」「何を言はれるのぢや、飛んでもない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りで庵を訪ねた主人の前へ、一色道庵の示した丸薬の成分というのは、人参、松樹甘皮、胡麻、※苡仁、甘草の五味だけ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "一色道庵はこの丸薬と同じ物を作れと言われ、林の中の大名の下屋敷の離屋に十日も留められたそうでございます」「フーム」「本田蓼白と伊東参龍の見分けた成分は、松の甘皮と胡麻と甘草で。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "人参、甘草、※苡仁、それに胡麻と松の甘皮、――そこまでは誰でも解るが、残りの二味がむつかしい」「何を言われるのじゃ、とんでもない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "横擲りに擲った切先が少し残ったものですから、ホンの甘皮ばかり、そのほかは西瓜を輪切りに切り損ねたのが斜めにパックリ口があいたようなものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも彼の鼻の頭には、線香花火でやけどした程の火ぶくれが出来て、甘皮の破れた皮膚の下からほんの僅かばかり血が滲んだ。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はしばしばこの女の全身の甘皮が、自分の肌へ肉｜襦袢のようにすっぽり被さってしまった気がして、それを残らず洗い落すのに多少の未練を感じながら、やっぱり自分が思ったよりも彼女を愛していることを意識しないではいられなかった。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘皮を一枚張ったようにぱさぱさ乾いている顔の上を、夜風が冷やかに撫でて行く。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黄味は天然の色で、楮の甘皮から出てくるものであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楮の甘皮が人に代つて染めてくれたのである。",
              "citation": {
                "source": "和紙の教へ",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
