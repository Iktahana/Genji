        "examples": {
          "standard": [
            {
              "text": "ネットワークの安定化のため、各モジュール間に高性能な光アイソレータを挿入する設計が採用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この信号処理回路では、外部ノイズの影響を最小限に抑えるために、バッファリングとアイソレータの使用が不可欠です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "出力信号の純度を保つため、このデバイスには低損失のRFアイソレータが組み込まれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遺伝子解析の精度を高めるため、細胞培養の過程でコンタミネーションを防ぐアイソレータが使用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "病原体の拡散を防ぐため、隔離病棟には高度な陰圧アイソレータが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "生産ラインでの部品の誤動作を防ぐため、電気的に分離されたアイソレータが配置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
