    },
    "definitions": [
      {
        "index": 1,
        "gloss": "light snow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日淡雪について考えている。",
              "source": "幻辞"
            },
            {
              "text": "淡雪という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は淡雪の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には淡雪が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "淡雪を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは淡雪について学習した。",
              "source": "幻辞"
            },
            {
              "text": "淡雪の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は淡雪の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では淡雪が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "淡雪という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に淡雪という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では淡雪についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "淡雪を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると淡雪は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "淡雪について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では淡雪が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に淡雪は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により淡雪の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "淡雪は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に淡雪は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "垂玉の乳房ただ淡雪のごとく含むと舌にきえて触るるものなく、すずしき唾のみぞあふれいでたる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皮膚に触れると淡雪のように溶ける素絹のように濡れて薄く包む。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のあたたかみで淡雪の上つらがつぶやく音を立てながら溶け始めた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂玉の乳房ただ淡雪の如く含むと舌にきえて触るるものなく、すずしき唾のみぞあふれいでたる。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來――歸途に此の線をたよつて東海道へ大※りをしようとしたのは、……實は途中で決心が出來たら、武生へ降りて許されない事ながら、そこから虎杖の里に、もとの蔦屋（旅館）のお米さんを訪ねようと言ふ……見る／＼積る雪の中に、淡雪の消えるやうな、あだなのぞみがあつたのです。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり南天の實に色鳥の音信を、窓晴るゝよ、と見れば、ちら／＼と薄雪、淡雪。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来――帰途にこの線をたよって東海道へ大廻りをしようとしたのは、……実は途中で決心が出来たら、武生へ降りて許されない事ながら、そこから虎杖の里に、もとの蔦屋（旅館）のお米さんを訪ねようという……見る見る積る雪の中に、淡雪の消えるような、あだなのぞみがあったのです。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外はしとしと淡雪に沁みて悲しむ雨の糸。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそうかえ淡雪の光るさみしさ、うす青さ、白いシヨウルを巻きつけて鳥も鳥屋に涙する。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡雪や通ひ路細き猫の恋（昭和五年三月、渋柿）　　　　　　　＊　桜の静かに散る夕、うちの二人の女の子が二重唱をうたっている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔作者の言分〕（「淡雪」の作者）牧野信一　海野武二氏の批評に就いては、その観点の差異が全く対蹠的なものであり、不断抗議を述べるとならば寧ろ簡略に申しがたく、この場合は残念ながら黙つて通り過ぎるより他方法も見出せないのであります。",
              "citation": {
                "source": "〔作者の言分〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊島与志雄君の『生あらば』、久米正雄君の『エロスの戯れ』、谷崎精二君の『淡雪』この三つをも読んで見た。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こゝで言ふ他は、単に他人といふほどの意味ではない）　この三篇の中では、『淡雪』が一番すぐれた感じを私に与へた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、人間を観察する力がかなりにすぐれてゐて、『淡雪』の中の女でも、斉田でも皆なはつきりとよく描けてゐた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『淡雪』もセンチメンタルではあるが、これは一層さういふ気がする。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、全体の調子は、『淡雪』『生あらば』に比して、わるくすれて、無邪気な落附いたところが段々なくなつて行つてゐるやうなのを私は見た。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠にちらりほらりと、いまだに降りつづけている淡雪を浴びながら、庭先伝いに歩みよると、うち騒ぐ色も見せずに、烱々とまなこを光らしながら、いま一度三つの窯を見比べました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外には何時の間にか淡雪がちらついてゐた。",
              "citation": {
                "source": "淡雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は嘗て潔の病室を訪れたとき、やはり淡雪が降ってゐたことを憶ひ出した。",
              "citation": {
                "source": "淡雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "口へ入れると淡雪のやうに溶けて、しかもねつとりと身につくやうに甘い。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとってみるとしっとりとしたしめりを含んでい、掌の上ですぐにも溶けてしまうような淡雪だった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし南側が崖になつてゐるやうな所は、霜が淡雪のやうに白くおいて、辷つて轍に落ち込むと薄氷が音して碎けた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つむよりとける春の淡雪だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡雪が意いがけなく、また降って来たりしたが、春の日光に照されて、直にびしょびしょ消えて行った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鈴子ひとつ歌をつくって見せろ」「紫にかそか匂いておもほゆる今朝の淡雪消えまく惜しも」「ふーむ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝窓をあけたら、黄色い初冬の草の上にまだらな淡雪があった。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩まで、その中で、小さい自分の相手になって、玉を転したり、笑ったり、時には腹を擽ったりした、白い手の、大きい金の耳輪を下げた、母とは違う若い女房の、悠くりした腰袴の裾につらまって、始めて、歩廊の淡雪を踏んだときの驚き。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・雪の茶の木へ雪の南天　あんたが泊つてくれて春の雪・雑草はうつくしい淡雪・雪へ雪ふる春の雪・雪のしづけさのつもる・晴れて雪ふる春の雪　春の雪をあるく・春の雪ふるふたりであるく　雪の水仙つんであげる・わらやねしづくするあわゆき　三月十三日雪がつんでゐる、そして雪がふる、敬坊と二人で雪をしみじみ観た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
