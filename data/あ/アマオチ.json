        "examples": {
          "standard": [
            {
              "text": "私は毎日雨落ちについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨落ちの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨落ちが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨落ちについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨落ちの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨落ちが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨落ちという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨落ちについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨落ちは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨落ちが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨落ちは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨落ちの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨落ちは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨落ちは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しとしとと雨は降る、雨落ちの音が、ぽちゃりぽちゃりと落ちはじめた。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝吉はまず雨落ちの石へそっと菅笠を仰向けに載せた。",
              "citation": {
                "source": "伝吉の敵打ち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹くともなく渡る風のせいであろう、そこここに散っている桜の花も、いつの間にかこっちへ吹きよせられて、今では、雨落ちの石の間に、点々と白い色をこぼしている。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また実際そのお島婆さんの家と云うのが、見たばかりでも気が滅入りそうな、庇の低い平家建で、この頃の天気に色の出た雨落ちの石の青苔からも、菌ぐらいは生えるかと思うぐらい、妙にじめじめしていました。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "※子は、急に引きしまった顔になりながら、何故あんなに急に飛び立ったのかと少し延び上って外をすかして見ると思い掛けず隅の雨落ちの所に洋傘を半つぼめにしたお久美さんが立って居た。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と振り切る様にして又元の雨落ちの所から下へ下りた。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梯子を貸して貰ひ度いが――」　裏の物置から持つて來た九つ梯子を雨落ちに据ゑると、一番上は丁度雨戸の欄間に屆きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蝉丸の香爐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここでございますよ、親分さん」　店と奥の境、ちょうど庭木戸を入った雨落ちのところに、番頭和助の死体が、菰を被せてありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "三千両異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梯子を貸して貰いたいが――」　裏の物置から持って来た九つ梯子を雨落ちに据えると、一番上はちょうど雨戸の欄間に届きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから素直にこわして雨落ちも、お隣に落ちないようにしたんだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじの老夫妻は裏へとびだして、雨落ちの底の下へ土下座をしていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、例の奥まった所にある石神の拝殿に腰かけていた一つの人影が、名月や池をめぐりて夜もすがら――そんなふうに、ふところ手をして、秋草の間をあるいていたかと思うと、いつか、千蛾の部屋の窓明りをぬすんで、その雨落ちの下に、盲蜘蛛のようにかがみ込んでいました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当主なる老人の話に、この人四十あまりのころ、おひで老人の息子亡くなりて葬式の夜、人々念仏を終りおのおの帰り行きし跡に、自分のみは話好きなれば少しあとになりて立ち出でしに、軒の雨落ちの石を枕にして仰臥したる男あり。",
              "citation": {
                "source": "遠野物語",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "石堂十馬と仁木於義丸のふたりが、やがて、がんじ縛めにした若い男を縁の雨落ちの辺にひきすえた。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "庇から落ちる雪解の雨垂れがきらきらと美しく光っては、あまおちの小石を賑やかに叩いていた。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
