        "examples": {
          "standard": [
            {
              "text": "毎日、呆気らかんについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の呆気らかん戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "呆気らかんの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "呆気らかんという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは呆気らかんについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "呆気らかんの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "呆気らかんに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは呆気らかんを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での呆気らかんは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、呆気らかんは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "呆気らかんは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な呆気らかんを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「呆気らかん」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "心の配線を固定して、あっけらかんと信じ切っていたことを私が疑い始めたのは、ある毛色の変わった〈本〉を知ってからでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先行きをいささか暗く考えがちの頭領と、あっけらかんと磊落な姐さんの個性が浮き上がって見えるようで、ロンが現れる前の小澤家の物語も、続けて読みたくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後学生運動の潮が引く中で一九七〇年代の初頭に訪れたあっけらかんとした空白の頼りなさは、古川より二年早く生まれたこのオレに取ってもズンとこたえた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とあっけらかんと田原氏。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "留吉があっけらかんとして見物しているうちに、帽子はいつの間にかまた留吉の頭の上へのっかっていました。",
              "citation": {
                "source": "都の眼",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に公認されたクラブでもなく、またもともと公認されようなどとかけらも思っていないこの集まりのメンバーは、利用できそうなスペースがあるとそこに群れはじめ、追い出されるまではしごくあっけらかんとそこに居座った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな余裕はないと強ばったままの背中の向こうから、あっけらかんとした鼻歌が聞こえてくる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっけらかんとしていられやアしません。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっけらかんとしているところは、どうしても誰かに知恵をつけられて、一夜づくりの言葉手形を濫発したものに違いないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が、あっけらかんとしている途端に、四辺の稲叢のかげから、同じような程度の遊び人｜体の（旅装の）男がのこのこと出て来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は売ろうと言ってわざわざ追いかけて来、一方はいくらでも糸目なしに買おうと申し出でたらしいのに、その取引が行われずして、一方は手ぶらで門内へ入り、一方は、あっけらかんとして、物品をストックしている体は少し変です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大して美人というわけでもないがね……」と言いながら、男爵は、あっけらかんとしている青年の前へ、一葉の写真を出したのであった。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アルカージイが六枚目の小判をまるまる坊さんの手に渡すと、坊さんは奥さんに向ってこう言いました、――「何をあっけらかんとしておるのじゃ、婆さんや？",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は『あっけらかん』と呼ばれるヴァンサン爺の戸口の前を通る。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなを迎えにかい」――『あっけらかん』が言う。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっと御供物を供えるお祈りが始まったぐらいなものだよ、どうしたって」「もうすんだころさ、たぶん」――相手の心も知らずに『あっけらかん』はこう言うのである。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのところはバカみたいにあっけらかんとしているけど、そのうちに身にしみてわかるようになるのだろう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……むこうが追いこみにかかっているというのに、こっちは、あっけらかんと口をあいて眺めているというんじゃア、月番の北の番所としちゃ、じつにどうも遣瀬のねえ話なんで。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "咸臨丸受取",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして黄色に染められた芝草の上に、あっけらかんと立っている婦人を後にして、うんうん車を押した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それがすなわち、屋根からなんぞ這いこんだのではない証拠」　ひょろ松は、あっけらかんと顎十郎の顔を眺めていたが、大きな息をひとつつくと、感にたえたというような声で、「こりゃ、どうも。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向取り止めなくなって、あっけらかんと口を開いていたのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　グライドがあっけらかんと言った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっけらかんと言うので、メアリが思わず笑った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリの宴会を欠席した理由は詳しく言わなかったが、いきさつをあっけらかんに語った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ人があっけらかんと言った。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "躾のいい英国人なら、朝食前に煙草は吸いませんけど」　スリム氏があっけらかんと言った。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの国王だ」　レックミア侍従があっけらかんと言い、お詫びのかけらもない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び、あっけらかんと気楽な童顔に戻った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
