          ],
          "literary": [
            {
              "text": "一日汗水たらして働いた後にのみ浴後の涼味の真諦が味わわれ、義理人情で苦しんだ人にのみ自由の涼風が訪れるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやぢが汗水たらして稼ぎためた大きな身代に倚りかゝつて愚図々々してゐる中には、ひとりでにその身代が手前のものになるから、それで飯を食つて死んでしまへば、この上なしの極楽だ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗水たらして一日働いても、今日今日をやっと過ごしているだけだが、おれたちはかたわなばかりで、なんにもしないで遊びながら、町の人たちがつくり上げたお金をかたっぱしからまき上げることができる。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗水たらして激しく山登りをして来た上に、握飯には有付けず、塩からい冷肉を無暗にパク付いたので、迚も堪ったものではない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらが汗水たらして洗ったネタを、だんなときちゃ、ただのひとにらみで当てるんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がせっかくこの寒い中を汗水たらしてかぎ出しにいってきたのに、フフンはねえでやしょう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "売れるからますます多く作り、安いからますます読んで、自分たちの汗水たらしてとった金を払って自分たちをますます狭い低い隷属的な生活へ追い込む文化の影響を受けて行くという状態にあるのである。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザック自身が、自分の文体をもてあまし、汗水たらしてそれと格闘した有様は、すべての伝記者によって描かれ、まざまざと目にも浮ぶばかりであるが、バルザックは文学作品における表現というものに対しては或る識見を抱いていた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場ではどうかというと、男と同じに汗水たらして働くのに、賃銀は半分ぐらいしか取れぬ。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の全部をあげて汗水たらして働いているのも、いつの日か、誰か一人の詩人に、ほんの一行の生きたしるしを書かしめるためかもしれない、と思うことは誤りだろうか。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農家がせっせと汗水たらして働き通す生涯の労働の大部分は、戒壇院の位牌の位置を現在のまま維持するためか、もしくは、自分の代に前より一段とも上にあげたいがためといって良い。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、坂口安吾という三文ダラク論者が、汗水たらして、夏目漱石は低俗軽薄文学也とヤッツケてみても、その坊ちゃんとか猫とかは、すでに国民の血液の一部と化しつつあるではないか。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四十何年も汗水たらして、歯をくいしばるようにして貯えた二万五千という金が、このさき二年間もつかどうか。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自転車で汗水たらして坂道をこぐ。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木が一人で汗水たらしているからである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあとは心をとり直し、思いだすたびに幻を払いつつ、ただ懸命に荷造りにうちこみ、その時までは指図するだけで、めったに自分で手をださなかったが、それからは自ら先に立って荷造りし、人のぶんまで汗水たらして働きまくったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、そればかりじゃない、僕はこの十年というもの、まるで牡牛みたいに汗水たらして、その借金をきれいに済したんだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーニャ　この二十五年のあいだ、僕はこの土地の差配をして、汗水たらして、せっせと君に金を送ってやった。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人、チョッと気押されて立ち止る）そりゃ、汗水たらして俺達が育てたお稲だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "べら棒め、汗水たらして働いて取る金だ、お情で戴くのじゃねえ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たださえ働き者ではない彼等は、こうやって汗水たらして一日働いた幾倍かの物が今に来るのだというような思いに心をゆるめられて村全体にしまりのない気分が漲り渡り始めた。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五年（一九一六）の夏、先生の亡くなる年の夏などは、いつもよりはひどく暑かつたが、先生が汗水たらしてうんうん言ひながら全紙に大字などをかいてゐるところを見て、なんだか瀧田が憎くなつたことさへあつた。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "この県こそ少年が汗水たらして尋ね廻ったところではないか！",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人、チョッと気押されて立止る）そりゃ、汗水たらして俺達が育てたお稲だ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、これまで、沖仲士をして来て、どうして、こんなに、みんなが汗水たらして働いとるのに、生活が楽にならんのかと、不思議でたまらなかったんです。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
