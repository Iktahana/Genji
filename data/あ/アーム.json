        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アームについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アームという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアームの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアームが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アームを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアームについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アームの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアームの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアームが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アームという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアームという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアームについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アームを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアームは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アームについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアームが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアームは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアームの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アームは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアームは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たとへば僕は一千九百十九年の七月に、アメリカのヂャイアントアーム会社の依嘱を受けて、紅宝玉を探しにビルマへ行ったがね、やっぱりいつか足は紅宝玉の山へ向く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば僕は一千九百十九年の七月に、アメリカのジャイアントアーム会社の依嘱を受けて、紅宝玉を探しにビルマへ行ったがね、やっぱりいつか足は紅宝玉の山へ向く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光を線に延ばして奇怪な形に編み上げたようなアームチェーアや現代機械の臓腑の模型がグロテスクな物体となって睥睨し嘲笑し、旧様式美に対する新様式の反逆を直截簡明に宣言している一群の進撃隊のようだ。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は善悪と云ひ、或は陰陽と言ひ、或は光暗と云ふが如き、ペルシヤのむかしに、アームズトの神、アハメルの神ありし如く、イスラエルのむかしに、ヱホバ神と悪魔とを対比せし如く、顕著なると顕著ならざると、一神と多神との区別あり、あらざるとに拘らず、彼の元を二にするの性は此観念に離れざるなり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "□ショオの「アームス、エンド、マン」を腕と人と訳した人は論外だが、坪内先生監修の訳本に「武器と人」としてある、然しアームス、エンド、マンは古来よりの成語で「いくさと人」と訳すべきものださうだ。",
              "citation": {
                "source": "TZSCHALLAPPOKO",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮長室のドアをあけて最初に目にしたのは、窓を背にしてアームチェアに坐り、頭のうしろで手を組み、こころもち顔を上にむけ、目をつぶった寮長だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのクリーム色に塗られた近代風のドアが開くと、その一間住宅であるアパートメントの瀟洒な布張のアーム・チェアに細君がかけて編物をしています。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時レコードはショパン独特のあの婉麗極まりなきトリオの部分を奏ではじめている所だつたが、私はいそいでアームをあげてそれから廻転を止め、そのまままた応接間に戻つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アームストロングの推進器と、貴様等の幽霊の力とドッチが強いかだ……フフン……」　二人の運転手が同時に肩をユスリ上げた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アームストロング・ウィットウァース機の車輪一度地をはなれれば、鵬翼欧亜の空を駆り日本へと近付いてゆく。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヴアーリーと云ふのはコート・オヴ・アームと言ひまして、軍服に一種の標が付くのです。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋のコート・オヴ・アーム、日本の紋所皆同じことです。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソファー、アームチェア、ライチングデスク、それらの物は鞣革と、紫檀とで出来て居りました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の奥のアーム chair に居ると（火をつけずに）手摺の太い線が手前にくっきりと濃く見えて、階下の灯が手摺の横棧の一番ひくいところ迄明るく見えている。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたのしく話をし、丁度二十一日に、キングズアームスホテルのカクテルパーティーに私招待されていましたので、令嬢をさそったのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "合衆国の水師提督アームストロングは憤って、広東の港口にある四か所の砲台を破壊した。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大きなアームチェアにポコンと埋って、大人しくパンを噛っている子供を抱き上げた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――私は彼女をもとのアームチェアに下しながら云った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　テーブルの　はしに　すてきな　みどりの　アームチェアが　あったんだけど、　それが　まるで　アリスの　せきみたいに　みえてね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とぷんすかアリス、そうしてテーブルのはしにあった大きなアームチェアにどしん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丸太の残りはまだ、ストラットン（今のアームズハウス）ファームから、ブリスターズ・ヒルに至る現在の埃っぽい公道の下に横たわっているにちがいない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さまも和一郎も、感情的にひっかかってごたついてばかりいたってはじまらないから、わたしは、実務的なことは実務的に片づけた方がいいでしょうと云っているだけだのに」　泰造は、ひとことも口を利かずアーム・チェアにもたれて腕組みをしている一方の手で、ときどき目立たないように上歯の義歯を動かしている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーのムッソリーニの独裁と、プロレタリアートの階級としての独裁をごっちゃにしていて、伸子がその点をさすと、木村は、どっちだって、独裁――ディクテーターシップというからには同じことさ、と云ってアーム・チェアの上に胸をはった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のものとは対照的に、床には美しいトルコじゅうたんが敷かれ、ソファ、革製のアーム・チェア、書類整理用の棚がある。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブスマン　失礼して――（アームチェアを引き寄せる）ガル博士　どうか――ファブリ　ぼくも――アルクイスト　船旅はいかがでしたか？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "（右手のドアの前にアームチェアとテーブルを引っ張ってくる）　爆発音が聞こえる。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一人の紳士がおり、気楽そうにアームチェアに凭れていた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
