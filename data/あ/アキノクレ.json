        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "花時が終わって「もも」が実ってやがてその※が開裂した純白な綿の団塊を吐く、うすら寒い秋の暮れに祖母や母といっしょに手んでに味噌こしをさげて棉畑へ行って、その収穫の楽しさを楽しんだ。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、人間、歩幅四・五フィートで難なく歩けるのなら、もう黄葉秋の暮れ、というわけでもあるまい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそれはいつも秋の暮れがたの、昨今の季節に於てであつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそれはいつも秋の暮れがたの、昨今の季節に於てであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　姫君さまはこの世をはかなみ奈良の法華寺にて尼になって、母上や若君の菩提をとむろうていられましたが、去年の秋の暮れふとおゆくえがわからなくなり、手をわけて捜しましたところ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩の声を聞いても宇治の山陰の家ばかりが恋しくて、おほかたに聞かましものを蜩の声うらめしき秋の暮れかな　と独言たれた。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃のやうな秋の暮れ方、燈ともし前の一時を私はきつと、たあちやんの背に負はれる。",
              "citation": {
                "source": "日記より",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋の暮れに別れしより、しばらく相見ざりしを、浪子が父に請いて使いして招けるなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ちゃんは、紅茶の空きかんの中へ、ガラスのおはじきを入れていましたし、正ちゃんは、ほうじ茶の紙の空き袋の中へ、ガラスのおはじきも入れていれば、また、秋の暮れにお宮の大きな木の下で拾った、銀杏の実も入れていました。",
              "citation": {
                "source": "友だちどうし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぐる年の秋の暮れから正月へかけて、ひときわ眼立った辻斬がたださえ寒々しい府内の人心を盛んに脅かしていた。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "血｜塗れになった美しい奥さんが真っ蒼な顔をして立っていたと言えば、ずっと以前、去年の秋の暮れ、あの土砂降りの雨の晩に大戸を叩いて阿母と話をしていった女の人というのと寸分も変りのない姿でございます。",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
