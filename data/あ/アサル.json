    "definitions": [
      {
        "index": 1,
        "gloss": "to fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "興津を過ぐる頃は雨となりたれば富士も三保も見えず、真青なる海に白浪風に騒ぎ漁る船の影も見えず、磯辺の砂雨にぬれてうるわしく、先手の隧道もまた画中のものなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は「成功」なぞという言葉が特に取出されて流行し、娘たちはハイカラ髷という洋髪を結っている時代で虫食いの図書遺品を漁るというのはよくよく向きの変った青年に違いなかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "開くでもなしに、弁当を熟々視ると、彼処の、あの上包に描いた、ばら／＼蘆に澪標、小舟の舳にかんてらを灯して、頬被したお爺の漁る状を、ぼやりと一｜絵具淡く刷いて描いたのが、其のまゝ窓の外の景色に見える。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長い指を苛立たしげに慄わせて、幾度となく焦点を更えては、何時迄も、何時迄も、大東京の市街の表に刻まれた一つ一つの物蔭を丹念に漁るつもりらしかった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の魚介類は、漁師の漁る灯火の下に、群をなして集つて来るし、山野に生棲する昆虫類は、人家の灯火や弧灯に向つて、蛾群の羽ばたきを騒擾する。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加茂川は、やや水嵩増して、ささ濁りの流勢は河原の上を八千岐に分れ下へ落ちて行く、蛇籠に阻まれる花｜芥の渚の緑の色取りは昔に変りはないけれども、魚は少くなったかして、漁る子供の姿も見えない。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうあきらめて私は叔母と共に住む家庭の日常生活を普通に送り乍ら、その間に旅行案内や地図を漁ることも怠らなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなものの中にも餌があるのか、烏が下り立って、嘴で掻き漁る。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々が此所へ来ると野性と出鱈目をむき出しにして、もっと／＼と興味を漁るために揉み合う。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ東京近くにて青鼠頭魚といふものは、春の末夏の初頃より数十日の間、内海の底浅く沙平らかなる地にて漁るものの釣に上るものを指して称へ、また白鼠頭魚とは青鼠頭魚の漁期より一ト月も後れて釣れ初むるものをいふ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "心弱き女房も、直ちにこれを、怪しき海の神の、人を漁るべく海から顕われたとは、余り目のあたりゆえ考えず。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな心弱いものに留守をさせて、良人が漁る海の幸よ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女三　入道も、一類も、色を漁るのでございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、次第に畜生、横領の威を奮つて、宵の内からちよろりと攫ふ、漁る後から嘗めて行く……見る／＼四つ手網の網代の上で、腰の周囲から引奪る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人娘を女房に貰おうかと思うと、すぐに、あのデパートで幅切れを漁る浅間しさが眼について、よう貰い切れなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがお艶のため専ら古典の歌詞歌曲を漁るに対し、彼はモダンを研究してお艶の芸を培った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたたかな砂浜には人が多ぜいいかなごを漁る網を曳いて居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれからは注射がもう趣味同然になって、注射液を買い漁る金だけは不思議に惜しいと思わず、寺田の鞄の中には素人にはめずらしい位さまざまなアンプルがはいっていたのだ。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ過ぎり街にゆく者、――婆羅門の苦行の沙門、あるはまた生皮漁る旃陀羅が鈍き刃の色、たまたまに火の布巻ける奴隷ども石油の鑵を地に投げて鋭に泣けど、この旱何時かは止まむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また思ふに、古代の胆を捉へることはあながち古語死語を漁ることではない。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古代の膽を捉へることは、あながち古語死語を漁ることではない。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌十二万石｜殿の若子はさもあらばあれここに六騎の町の子我は註、石場は字石場町、六騎とは平家の六騎、ここに落ちのびて漁る。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャボールを立つ前の日、Ｍ技師と私は、土産物の島民の編物を漁るために、低い島民の家々を――もつと正確にいへば、家々の縁の下を覗き歩いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャボールを立つ前の日、Ｍ技師と私は、土産物の島民の編物を漁るために、低い島民の家々を――もっと正確にいえば、家々の縁の下を覗き歩いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き家鴨、五羽ばかり、一列に出でて田の草の間を漁る。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷺、獺、猿の類が、魚を漁るなどとは言ふまい。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大潟で漁る名物だ、と八郎が私に云った。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同想の類句に冬ざれや小鳥のあさる韮畠　というのがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはわれわれの「知覚には限界がある」からである、と言って、遠い小山に緑草をあさる羊の群れがただ一抹の白い斑にしか見えないという、詩人らしい例証をあげている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の雫の、糸のごとく乱れかかるのは、我が身体ばかりで、明の床には、夜をあさる蚤も居らぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
