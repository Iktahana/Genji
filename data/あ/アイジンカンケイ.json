        "examples": {
          "standard": [
            {
              "text": "毎日、愛人関係は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛人関係が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛人関係に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛人関係が物語の中心となっています。",
              "source": "幻辞"
            },
            {
