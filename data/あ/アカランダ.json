          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中で一番威張れる者が、その赤らんだ薄い皮膚の眼蓋の上にロイド眼鏡を掛けて、彼女が襖を開くや愛相よく「今晩は」と言つた時、彼女は漸く何だか嬉しくなつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜寒で赤らんだ頬を両手で撫でながら、笑みかけようとしたらしかったが、少し殺気だったその場の様子にすぐ気がついたらしく、部屋の隅をぐるっと廻って窓の方に行って坐った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこで柿江は自分の顔がきゅうにあつくなって、酔った時のように赤らんだのを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先きだけ赤らんだ小さい指が器用に、黒ずんだ板の上を走つて、かゞんだり立つたりする度に、お末の体は女らしい優しい曲線の綾を織つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると青扇は、酔いですこし赤らんだ眼のほとりをいっそうぽっと赤くして、苦しそうに笑いだした。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い綺麗な女中が心持ち赤らんだ顔を此方へ向けてにつと笑つた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し前から彼の顔は酒のために染まった赤らんだ色合いを失いつつあったが、いまや、驚いたことには、それがまったく恐ろしいくらいの蒼さになっているのを私は認めた。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯でほんのりと赤らんだ素足に古藤の目が鋭くちらっと宿ったのを感じながら、障子を細目にあけて手をならした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの荒唐な奇怪な心の adventure をかえってまざまざとした現実の出来事でもあるかのように思いなして、目の前に見る酒に赤らんだ事務長の顔は妙に蠱惑的な気味の悪い幻像となって、葉子を脅かそうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには処女のように美しく小柄な岡が雪のかかった傘をつぼめて、外套のしたたりを紅をさしたように赤らんだ指の先ではじきながら、女のようにはにかんで立っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、日頃｜傲岸不遜な、人を人とも思わない勝平であるにも拘わらず、話しかけようとする言葉が、一つ／＼咽喉にからんでしまって、小娘か何かのように、その四十男の巨きい顔が、ほんの少しではあるが、赤らんだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、日頃傲岸不遜な、人を人とも思はない勝平であるにも拘はらず、話しかけようとする言葉が、一つ／＼咽喉にからんでしまつて、小娘か何かのやうに、その四十男の巨きい顔が、ほんの少しではあるが、赤らんだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ六時頃、父上が、外気の寒さで赤らんだ顔を上機嫌にくずし乍ら、「どうですね、仕度は出来ましたか」と、何か紙包を持って帰宅されるだろう。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室のベッドのなかで、妻は赤らんだ顔をしていた。",
              "citation": {
                "source": "苦しく美しき夏",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私の目にふれる壁の上の赤らんだ蔦の葉や枯れのこる葉鶏頭が幻か何かのやうにおもへて来た。",
              "citation": {
                "source": "二つの死",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に近頃は見越しの松に雪よけの縄がかかったり、玄関の前に敷いた枯れ松葉に藪柑子の実が赤らんだり、一層風流に見えるのだった。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康に赤らんだ円い顔で、黙って立って礼をする夕暮どきの透明さ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち彼女の二重瞼の眼は我知らずつり上った二つの眉毛の下で次第次第に大きくなり、寒さで赤らんだ鼻のさきとともに、びっくりした野兎のような表情になった。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死体をやや斜めにすると、ドロリと重たげに流れ出した血液で、たちまち屍光に暈と赤らんだ壁が作られ、それがまるで、割れた霧のように二つに隔てられてゆき、その隙間に、ノタリノタリと血が蜿くってゆく影が印されていった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう云われて見ると、黒々と盛り上った高地の上には、聯隊長始め何人かの将校たちが、やや赤らんだ空を後に、この死地に向う一隊の士卒へ、最後の敬礼を送っていた。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は赤らんだ麦藁帽のように旧時代を捨てなければなりません。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤らんだ耳朶にかかった二三本の遅れ髪がかすかにふるえていた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有名な温泉もそんな風にちよつと入口から覗いたきりでは、なんだか天然石で出來た湯槽の中に、男だか女だか得體の知れないやうな赤らんだ塊りが湯氣のなかに蠢いてゐるのが醜く眼に映つただけだつた。",
              "citation": {
                "source": "「浴泉記」など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管を咥え、かちりと打った石の火がぼッと赤らんだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もったいぶってしゃしゃ張りだす例の久慈恵介は、先刻の衝げきがまだ彼の頭から完全に消えず、赤らんだ瞳をきょとんとさせているだけであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は赤らんだ麦藁帽のやうに旧時代を捨てなければなりません。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子はお前さんの子ですのね」「そうして戴けたら、わたし嬉しいですけれど――いい子だこと」　お里は青ぶくれのした嬰児の頬に自分の赤らんだぽた／＼した頬をすりあてていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、君の隣に坐っているのはね、――」　譚は老酒に赤らんだ顔に人懐こい微笑を浮かべたまま、蝦を盛り上げた皿越しに突然僕へ声をかけた。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "北よりには浅間山がまだ一面に雨雲をかぶりながら、その赤らんだ肌をところどころ覗かせていた。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　獅子がまるであからんだ栗のいがの様な顔をして笑ひころげました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
