        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒武者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒武者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒武者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒武者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒武者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒武者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒武者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒武者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒武者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒武者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒武者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒武者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒武者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒武者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒武者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒武者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒武者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒武者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒武者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒武者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「ふふふふ、弱いなうお前等は……」　定めてあの張作霖がそんな風に相好を崩してのけぞり返つただらうと思ふと、その昔馬賊の荒武者だつたといふ人のよさも想像されて、無殘な爆彈に血染められたと言ふその最後が傷ましくも感じられはしないだらうか？",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ると氏郷に随って来た蒲生源左衛門、蒲生忠左衛門、蒲生四郎兵衛、町野左近将監、新参ではあるが名うての荒武者佐久間玄蕃が弟と聞えた佐久間久右衛門、同苗舎弟源六、綿利八右衛門など一人当千の勇士の面々、火の中にもあれ水の中にもあれ、死出｜三途主従一緒と思詰めたる者共が堪り兼ねてツツと躍り出た。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の茶と学問の奨励は、元亀天正の荒武者たちの品性を高めるためであり、同時に、幼時から粗暴と云はれる自らの性行の反省修養のためであつたとも考へられる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時私が、電報で応援を求とめられて駆けつけて見ると、あの人は二人の荒武者に詰め寄られて、或る手ごわい談判に攻められてゐる最中でした。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒武者は茶飲み茶碗か何かで酒をあをりながら、あの人を、おどしたり、すかしたり、様々に弁舌を弄して強談判を持ちかけてゐるのですが、決して埒があきません。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒武者は、業を煮やして、稍ともすれば大声を挙げて、自分達が、如何に物凄い、人を人とも思はぬ、世の中で何も俺達は怖ろしい者を知らぬ！",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と私は吃驚りして、なるべく彼等の反感をそゝらぬやうにと念じながら、一生懸命に和やかな顔をして、稀大の荒武者の傍らに坐りました。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、実に実にねんごろに説き伏せるのですから、荒武者だつて、鬼ではないのだから、坐り直つて、静かに盃をとるより他はなくなるのです。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒武者達は、立あがつたり、畳を拳骨でなぐつたり、そして盃をとり直させられたりしたか、思つても大変なことでしたが、たうとう二人の荒武者は、「あゝ、俺は頭が痛くなつてしまつた！",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いとも鄭重に促すのですが、荒武者は上向けに倒れて、目を瞑つたまゝ、低く唸るだけで、決して起きあがらうとはしません。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になつて荒武者が引きあげると、あの人は、仲直りの盃を交さないうちは此方が不承知だ！",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳をふさぐやうにして荒武者は逃げ出しました。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出かけて、街角の居酒屋をのぞいて見ると、そこの店先きに、先刻の二人の荒武者が、さし向ひで、何となく黙りこくつて、盃を手にしながら腰かけてゐました。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ声がすると、荒武者は私に向つて、慌てゝ手を振つて、とるものもとりあへず姿をかくしてしまひました。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大唐の天子から、引き離され、荒武者どもの手にかゝつて果敢なくなる、悲しい楊貴妃の古事が、なぜにそなたの氣に叶ふのぢや。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何処の家でも、冬が近づくと、門先に鎮西八郎為朝の家と筆太に誌した表札と、平家蟹の甲羅を荒武者の顔と擬して、眼口を描いて掲げるのが慣ひであつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時には僕は面白くて思わずメガホンを執って荒武者たちに声援を浴せたりするのであるが、舟ばかりを欲しがっている友達の胸の中を思い返すと直ぐに僕も変になって、事務的に旗の上げ下しを手伝ったり、黙々として気象観察や潮流図の日誌を記したりするのであった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういわれたので僕は、その自分の姿勢を験べて見ると、自分は窓｜枠に片脚をかけ、右の拳を月光の中に、悪人の脇腹を突いた荒武者のそれのように力一杯に突き出し、上体を虎のように前方に乗り出し、そして左手の拳で自分の頤を突きあげているままの生人形に化していたのである。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、手に手に半月刀を翻す一団の荒武者が阿修羅の如く猛り立つて魚の腹を裂き、氷塊を詰め込み、見る間に魚の山をとり崩して行く鮮やかさなどは観る者に息もつかせない花々しさである。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "親は子を、妻は夫を、男とあらば是非とも太鼓打ちの荒武者として彼処に立せたく、希はぬ者とてはなかつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "轣轆たるバラルダの廻転と、荒武者が此処を先途と打ち鳴らす竜巻村の大太鼓の音が人波を分けて、行列を導いて行く。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中私は、それ自らが豪勇無比な荒武者となつて、従横無尽に花々しい筆端の刃を揮つて、群がる者共を手玉にとつて薙ぎ倒し、こばから首をちよん切つて、さしもの竜巻村に平和の風を吹かせるといふ、痛快至極な冒険譚であることを知らずに、彼等は、左う云ふと、一様に恍惚の眼を細めて深々と息を吸ひ込んだ。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……舟が、流れのまゝに大きく迂回して、木立の蔭にかくれようとする角に差しかゝつた時、私が彼方の丘を振り返つて見ると、さつき慌てゝ閉められたあの家の窓から、幾人もの悪人が重なり合つて、切りと帽子やハンカチを打ち振りながら、恰も出陣の首途についた荒武者との別れを惜しんでゐるかの模様であつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけだつたのなら自分もあの時花々しい荒武者になつて此処ぞと云はんばかりの腕を奮つてやれば好かつたものを！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は大兵肥満の荒武者で、大きな竹刀の中に電線ほどの筋がねを三、四本入れていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遉がの動坂一派の荒武者どもも、この豪快な金庫の鍵？",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その常陸の旦那は荒武者なんだってね」　と薫が言ったので弁は笑ったが、心では姫君がかわいそうに思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしとむるむぐらやしげき東屋のあまりほどふる雨そそぎかな　と言い、雨を払うために振った袖の追い風のかんばしさには、東国の荒武者どもも驚いたに違いない。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を二台持って来たのであって、例の東国の荒武者が、七、八人、多くの僕を従えていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
