    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese parasol-tree (Firmiana simplex)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "最初に軒端の廻燈籠と梧桐に天の河を配した裏絵を出したら幸運にそれが当選した。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に冬木立の逆様に映った水面の絵を出したらそれは入選したが「あれはあまり凝り過ぎてると碧梧桐が云ったよ」という注意を受けた。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "募集した絵をゆっくり一枚一枚点検しながら、不折や虚子や碧梧桐を相手に色々批評したり、また同時に自分の描いておいた絵を見せたりして閑談に耽るのがあの頃の子規の一つの楽しみであったろうということも想像される。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた低気圧が来て風が激しくなりそうだと夜中でもかまわず父は合羽を着て下男と二人で、この石燈籠のわきにあった数本の大きな梧桐を細引きで縛り合わせた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この梧桐は画面の外にあるか、それとももうとうの昔になくなっているかもしれない。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭は一隅の梧桐の繁みから次第に暮れて来て、ひょろ松檜葉などに滴る水珠は夕立の後かと見紛うばかりで、その濡色に夕月の光の薄く映ずるのは何とも云えぬすがすがしさを添えている。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には梧桐を動かしてそよそよと渡る風が、ごくごく静穏な合の手を弾いている。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかい馭者は窓のないカキ色の囚人馬車を梧桐のかげにひき入れたまま、しづかに読み耽る……こころもち疲れた馬の呼吸……短く刈つた栗毛の光沢から沁み出る臭の奇異な汗ばみ、その上にさしかくる新聞紙の新しい触感、わか葉の薄い緑の反射。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "透かせ、また、梧桐の穂にさく蕾、窓ちかき幹立の濃きあはひを。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヂオ風景黄ろい月、花は碧梧桐、　　蝶蝶だ、まるで、奴らは。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧梧桐の花房が鳴る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀羽根、梧桐の芽よ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "梧桐のかげに客待をしてゐる人力車夫にも、銀座の横町に荷を下すバナナ売の半纏にも硝子屋の白い斜面の日覆にも、愈夏らしい強い光が照りつけて、早や日中から張りわたした虫売の露店の薄い天幕のかげにも幽かに鈴虫が鳴きはじめる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜、楓、椎、梧桐等の立木。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造の据わっている所からは、二三本寄せて植えた梧桐の、油雑巾で拭いたような幹が見えている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤い椿白い椿と落ちにけり」（碧梧桐）でも父の説に従えばなるほど「言うただけ」である。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は廊下の窓際に斜に置かれて、小雨のふる中に垂れ下った梧桐の葉の淋しさを眺めて居た。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は自ら慰めてこんなことをいうものの、子規子没後は虚子、碧梧桐と歌われているその虚子君の口から、子規子が迷惑なるべくやに思わるといわるることを予ははなはだ口惜しく思うのである、親友に敬意を欠くの恐れがあるからあまり理屈はいうまい、ただ生前先生から聞いた二、三の話を紹介して、世人の判断に任せておく。",
              "citation": {
                "source": "竹乃里人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きて、庭の方へ築き出してある小さいヴェランダへ出て見ると、庭には一面に、大きい黄いろい梧桐の葉と、小さい赤い山もみじの葉とが散らばって、ヴェランダから庭へ降りる石段の上まで、殆ど隙間もなく彩っている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたゝかい小春日の日光に、窓下の梧桐の葉末までが麗はしく輝いて見えた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "風もないのに梧桐の一葉はハラリと地に落ちた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓側をかすめてハラリと散つた梧桐の一ト葉を、私は湖に泳ぐ魚かと怪しむだり、朝母が活けて呉れた床の間の花を水底の藻かと思つたりしました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑｜濃かに生茂れる庭の木々の軽々なる燥気と、近き辺に有りと有る花の薫とを打雑ぜたる夏の初の大気は、太だ慢く動きて、その間に旁午する玄鳥の声｜朗に、幾度か返しては遂に往きける跡の垣穂の、さらぬだに燃ゆるばかりなる満開の石榴に四時過の西日の夥く輝けるを、彼は煩しと目を移して更に梧桐の涼き広葉を眺めたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "件のバオバブ一名猴の麪包の木はマレー群島の名菓ジュリアンと同じく、わが邦の梧桐の類に近きボムバ科に属し、アフリカの原産だが今はインドにも自生す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちに芥川龍之介氏の「支那游記」をよむと、同氏もここに画舫をつないで、槐の梧桐の下で西湖の水をながめながら、同じ飯館の老酒をすすり、生姜煮の鯉を食ったとしるされている。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川氏の来たのは晩春の候で、槐や柳の青々した風景を叙してあるが、わたしがここに立寄ったのは、秋もようやく老いんとする頃で、梧桐はもちろん、槐にも柳にも物悲しい揺落の影を宿していた。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "梧桐の葉などは、いつもならば、黒くしなびてカラ／＼と一風に散つて了ふのであるが、今年はそれすら美しく黄ばんだ色を見せてゐる。",
              "citation": {
                "source": "初冬の記事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "梧桐の葉が落ちて落ちて為方がなかつたのをも、漸く子供等が燃やして了つた。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで、中々あゝは行かないから……あの梧桐の刈つたあとを見ろ、あのヒラヒラした葉一枚でも、ちやんと意味があつて残してあるんだから、決して考へなしに刈られてゐるんではないんだから』朝雨　その綺麗に掃除された庭に、朝雨が降つた。",
              "citation": {
                "source": "夏",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　梧桐の葉が余り繁りすぎたので、植木屋を呼んで少しばかり伐らせた。",
              "citation": {
                "source": "娟々細々",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
