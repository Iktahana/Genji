    "definitions": [
      {
        "index": 1,
        "gloss": "high laced shoes or boots",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日編み上げについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "編み上げという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編み上げの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編み上げが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編み上げを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編み上げについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "編み上げの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編み上げの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編み上げが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編み上げという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編み上げという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編み上げについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編み上げを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編み上げは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編み上げについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編み上げが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編み上げは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編み上げの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編み上げは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編み上げは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしまた他の半面の考え方によれば、科学者の知識は「物自身」の知識ではなくて科学者の頭脳から編み上げた製作物とも云われる。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評家自身の芸術観から編み上げた至美至高の理想を詳細に且つ熱烈に叙述した後に、結論としてただ一言「それ故にこれらの眼前の作品は一つも物になっていない」と断定するのもある。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光を線に延ばして奇怪な形に編み上げたようなアームチェーアや現代機械の臓腑の模型がグロテスクな物体となって睥睨し嘲笑し、旧様式美に対する新様式の反逆を直截簡明に宣言している一群の進撃隊のようだ。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも編み上げますと、私には一生こんなものが入らないものと気がつきました。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、僕があなたのお傍に行きつくまでに、いま一度、ミネルバのアフガンを編み上げなければなりません。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、此処で一言述べて置きたいのは、これまでも、頻繁に問われたことだったが、この長篇を編み上げるに就いて、そもそも着想を何から得たか――と云うことである。",
              "citation": {
                "source": "「黒死館殺人事件」著者之序",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この堯典の記事は天文の實地觀測に立脚せるものには非ずして、占星思想より編み上げられ、十二宮二十八宿の智識と、陰陽思想とがその根底となりしものなるを知るべき也。",
              "citation": {
                "source": "『尚書』の高等批評",
                "author": "特に堯舜禹に就いて",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらに足の底に膨れ上る豆の十や二十――と切り石の鋭どき上に半ば掛けたる編み上げの踵を見下ろす途端、石はきりりと面を更えて、乗せかけた足をすわと云う間に二尺ほど滑べらした。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんがこの瞬間にこの美しい画を捕えたなら、編み上げの踵を、地に滅り込むほどに回らして、五年の流を逆に過去に向って飛びついたかも知れぬ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こう考えると、彼の空中に編み上げる勝手な浪漫が急に温味を失って、醜くい想像からでき上った雲の峰同様に、意味もなく崩れてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝ぎりの水兵の服を着て、編み上げ靴をはきたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古着屋さんは美濃の国から出てきた人ですが、明治学院にかよっているわたしの学生時代に、くつ屋をしていまして、編み上げのくつを一足造ってくれました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴も襟のまわりの面倒なところさえ大方は編み上げられているので、後はほんの一手間で仕上げてしまうことができるのだ。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "スェータは山室弘再加入の予告が劇場の壁に貼り出されたその翌日、見事に千代子の膝の上に編み上げられた。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛糸で丹念に編み上げた私のオーバーなどは展覧会のたびごとに出品されたので、その間じゅう私はくしゃみをしていたものだ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速深く編み上げた藁靴を穿いて、雪で吹き閉された戸を開けて外へ出た。",
              "citation": {
                "source": "不思議な鳥",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって我々の編み上げた旅程もまた経験相応に平凡でした。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　以上は神話や民間説話の一々についてのことであるが、もしそういうような物語が一つの大なる組織に編み上げられている場合には、そこに何らかの意図がはたらいていることを看取しなければならぬ。",
              "citation": {
                "source": "神代史の研究法",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッケンジーはフリーボーン教授にこれは先住民の民話から拾い上げられた恐怖だと説明した――原住民たちは、晴れた空の下長い間隔を置いて砂を吹き渡る強風についての、奇妙な神話を編み上げていたからだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌ふ唄や、その奏でる曲や、その編み上げられた紙入れや、飜譯出來る佛蘭西語の本を誇つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『田園交響楽』の第二楽章の終りに、オーケストラが夜啼鶯と郭公と鶉の啼き声を聴かせることは人の知る通りであり、確かにこの交響曲のほとんど全部が自然のいろいろな歌声とささやきで編み上げられているともいえる。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は泥も付いていないプリュネル[11]の編み上げ靴を履き、まるで鰻の様に道路から彼女の台所へ忍び入っていて、ゴリオ氏のアパルトマンはどこかと尋ねた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは生地の荒い編み上げ靴を履いた何人かの男が階段を登って来る音のようだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと南の冬の短い都邑で、編み上げた暦が彼らにも送り届けられ、彼らもまた移ってきて幾代かを重ねるまで、その暦の春を忘れることができなかったのである。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、新しい袴と黒い沓下とあみあげの靴をはき、いままでの毛布をよして羅紗のマントを洒落者らしくボタンをかけずに前をあけたまま羽織つて、その海のある小都會へ出た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、新しい袴と黒い沓下とあみあげの靴をはき、いままでの毛布をよして羅紗のマントを洒落者らしくボタンをかけずに前をあけたまま羽織つて、その海のある小都会へ出た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、おなじようなガラス器があり、それの中に見られたものは、よく見ないとわからないほどの細い針金でもって、だ円形のかごのような形を、あみあげたものだった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
