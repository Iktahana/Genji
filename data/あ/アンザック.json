      {
        "index": 1,
        "gloss": "ANZAC (Australian and New Zealand Army Corps during WWI)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日ＡＮＺＡＣについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＡＮＺＡＣの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＡＮＺＡＣが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＡＮＺＡＣについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＡＮＺＡＣの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＡＮＺＡＣが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＡＮＺＡＣという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＡＮＺＡＣについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＡＮＺＡＣは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＡＮＺＡＣが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＡＮＺＡＣは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＡＮＺＡＣの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＡＮＺＡＣは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＡＮＺＡＣは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
