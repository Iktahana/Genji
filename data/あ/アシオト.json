    "definitions": [
      {
        "index": 1,
        "gloss": "(sound of) footsteps",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "前の舗道を過ぎるヒキズルやうな足音が嫌な気がする。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「併しあの二番目の子は良かつた、あの子が生きてさへゐれば……」――　渡り廊下を駆け寄つて来る看護婦の足音がした。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　パタパタパタと眠さうな足音が隣の間でして、障子が開くと、そこに突つ立つて耕二が欠伸一つした。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコと足音が後頭に響くと、先刻父と話してゐた弟が来て、トランプをしようと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関先に夫らしい足音がすると、先刻から火鉢に凭つて時計ばかりみてゐた妻君は、忙しげに立ち上つて玄関に行つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気のない深夜の町を、ひとり足音高く通って行く。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の水が子守歌のように、高くなり、低くなって、私たちの足音を消して、後から追い冠せて来るときには、一行はまた、森の中の人となっていた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に籠つて寐轉んで居ると、すぐ近くの階段や廊下を往來する人々の足音が間斷なく聞こえ、それが丁度御會式の太鼓のやうに響き渡り、音ばかりでなく家屋全體が其の色々な固有振動の週期で連續的に振動して居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體どうして、かういふ風に連續的に足音や地響きが持續するかといふ理由を考へて見た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯々面白いのは、此の何萬囘の足音が一度にかたまつて發しないで、實にうまく一樣に時間的に配分されて、勿論多少の自然的偏倚は示しながらも統計的に一樣な毎秒平均足音數を示してゐることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、宿屋の階段の連續的足音の奇現象を觀察することの出來たのは思はぬ拾ひものであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の近づく足音を聞くと振返つて何だかひどく落ち付かぬ風を見せた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐあとから、こつこつ可愛らしい靴の足音がして、パン屋の七つになる女の児が、パンとお砂糖でつくった猫を持って来て呉れた。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味の音景氣よく聞えて亂舞の足音これよりぞ聞え初ぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も声を掛けなかった、三人も菓子とも思わなかったか、やがてばたばた足音がするから顔を出してみると、奈々子があとになって三人が手を振ってかける後ろ姿が目にとまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼童思慕詩篇肖像あいつはいつも歪んだ顔をして、窓のそばに突つ立つてゐる、白いさくらが咲く頃になると、あいつはまた地面の底から、むぐらもちのやうに這ひ出してくる、ぢつと足音をぬすみながら、あいつが窓にしのびこんだところで、おれは早取写真にうつした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか」　その時、階段を駈け上る足音と、鶴吉の声が聞える。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝水車の処　人の足音に六助驚いて去る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして枕邊をヒタヒタとゴム足袋で石段を下りる人の足音が響いてくるのだ。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉め切った雨戸をがたごと鳴らしては、虚空へ舞上ってゆく、気味の悪い風の絶間に、鋭く聞き耳をたてて、昼間から出たまま帰って来ない子供達の足音を待っている母親の心は死ぬ程不安の念にさいなまれていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の望み、それが主人の帰る足音であるという願いもかき消されてしまった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子を下り行く足音留る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の遠い所で砂利を掻いてゐる熊手の音も、側を歩く人の足音も、近い所で時計が十二時を打つ音も聞える。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっしりした男の足音が、水泳場の方へ昇って来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、云うとそのまま扉が固く閉ざされてアダの足音は遠く消えてしまうのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は空虚な心の劇場に未来の演出を約束すると、苦しみにたえかねて米良を抱きしめると力の抜けた足音を廊下に残して去った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊る足音が次第に彼方に去って夜が重なった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明のあしおとが近づく。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯は稀だが俺達のあしおとを聞いて、茱萸や連翹の木蔭から雉子や山鳥やかけすの類が頓狂な声を立てゝ飛び立つたり、間もなく蕨の芽が萌えようとしてゐる夢のやうに伸び渡つた草原を一散に駆けて行く野兎の姿が点となるまで見極められるなどといふことは、珍らしくない。",
              "citation": {
                "source": "春の手紙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端に溝板を踏むあしおとが近づいて、隣りのおかみさんに挨拶する男の声がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            }
          ]
        }
