    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lipstick that actors put on their earlobes, cheeks and corners of eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛敬紅は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛敬紅が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛敬紅に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛敬紅が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛敬紅について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛敬紅についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛敬紅について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛敬紅が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛敬紅が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛敬紅は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛敬紅は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛敬紅を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛敬紅をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛敬紅が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛敬紅の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛敬紅を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛敬紅に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛敬紅について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛敬紅は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛敬紅を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
