    "definitions": [
      {
        "index": 1,
        "gloss": "forgive me",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この度はこちらの手違いで多大なるご迷惑をお掛けし、誠に相済みません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「せっかくのお言葉ではございますが、私の力量ではお役に立てそうもなく、相済みません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「お忙しいところを長々とお引き留めしてしまい、全く相済みません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「お預かりしておりました品をうっかり傷つけてしまい、何と申し開きしてよいか、ただただ相済みません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「ご厚意を無にするような振る舞いをしてしまい、返す返すも相済みません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "毎度、御面倒ばかりお掛けして相済みません。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ黙って聞き手になるから」「どうも相済みません」「済むも済まねえもあるもんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見それ申して相済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」給仕、（周章てゝ来る）「はいはい、相済みません。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手紙はお返しいたします」「……ハ……たしかに……」「……で……あの新聞の原稿は、お持ちになりまして……」「相済みません。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか機関を見られるようで、気がさすから、目立たないのが可かろう、銀流でもかけておけと、訳はありゃしねえ、出来心で遣ったんだ、相済みません。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらこれから石滝へ行くから、お前あとから取りに来ねえ、夕立はちょいと借りるぜって、そのまま乗出したもんだからね、そこいら中騒いでた徒に相済みませんを百万だら並べたんで。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいはい相済みません。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも相済みません。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くどうも相済みません。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉｜頻りに天窓を掻きて「へい、どうもお待遠様、誠に相済みません、しかし、御前様やっとのことで知れました。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何うも相済みません。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへ、どうも相済みませんで、お客様には何とも申し訳ございませんが、じたい、こうしたいきさつでがして、へい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも誠に相済みません。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもいろいろ御迷惑をかけて相済みません。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもまことに相済みません。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、話が長くなりまして相済みませんが、ホームズ先生、いよいよ最後、つまりある夜、酔った伯父が家出をしたまま帰ってこないのです。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし誰が何と云っても、僕等二人の事は養父が決定て行った事ですから、絶対に動かす事は出来ない訳です……今更村の者の噂だの、親類の蔭口だのを問題にしちゃ、養父の位牌に対して相済みませんし、第一品夫自身がトテモ可哀想なものになるのです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十五年壬寅正月鏡花一「どうも相済みません、昨日もおいで下さいましたそうで毎度恐入ります。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「実は母親が参ります筈なんでございますが、一体このとかく病身な上、貧乏暇なし、手もございません処から、相済みませんが失礼をいたしまして、」といいかけてまた額の汗を。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういたしまして相済みません、私あね、先生、書生や車夫なんぞが居るてますから、掴出す位なことはするだろうと思ってね、そうしたら一番｜撲倒しておいて、そいつを機に消えようと思ったんだが、まるで足腰が立たねえんです。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に相済みません、何てっておわびのいたしようもないのでございます。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに相済みません」　定めてシラを切るのだろうと思いのほか、余りあっさりと砕けて出たので、半七も少しく当てがはずれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも相済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、桂庵の手にかかるのは忌でございますし、津の国屋さんへだしぬけに出ますのも何だか変でございますから、まことに御無理を願って相済みませんが、どうかお師匠さんのお口添えを願いたいと存じまして……」「ああ、そうですか」　文字春も少しかんがえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも皆さんに御無沙汰をして相済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜ふけにお邪魔をいたしまして相済みませんが、荒木様の御子息様からおあつらえの掛物はまだお出来に相成りませんか」と、伝兵衛は坐り直して訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それぢやどうも相済みませんでございますね」　お婆さんはすぐに「ですがね、あれも漸く片がつきましてね」　と分らぬことをいうて独で悦んで居るやうである。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその前に先づ懦れず会釈して、「どうも取んだ麁相を致しまして、何とも相済みませんでございます。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまはごていねいに早馬をいただいて、あいすみませんでしたね」　姿より先に、かしましい声を飛ばせながら、大道せましと右に左にからだを振って、霧の中をこちらへ駆けつけてきたのは、　あの男です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
