        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "永い間雨曝しになつて居るらしい鐵の構造物はすつかり赤錆がして、それが青いトタン屋根と美しい配合を示して居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の鉄のブラインドには赤錆が吹き始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の逞しき手に、赤錆ついた大出刃を不器用に引握って、裸体の婦の胴中を切放して燻したような、赤肉と黒の皮と、ずたずたに、血筋を縢った中に、骨の薄く見える、やがて一抱もあろう……頭と尾ごと、丸漬にした膃肭臍を三頭。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……別に鉄槌、うむ、赤錆、黒錆、青錆の釘、ぞろぞろと……青い蜘蛛、紅い守宮、黒｜蜥蜴の血を塗ったも知れぬ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女　ええ、錠の鍵は、がっちりささっておりましたけれど、赤錆に錆切りまして、圧しますと開きました。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "題のない歌南洋の日にやけた裸か女のやうに夏草の茂つてゐる波止場の向うへ　ふしぎな赤錆びた汽船がはひつてきたふはふはとした雲が白くたちのぼつて船員のすふ煙草のけむりがさびしがつてる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "題のない歌南洋の日にやけた裸か女のやうに夏草の茂つてゐる波止場の向うへ　ふしぎな赤錆びた汽船がはひつてきた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう言えば、その地蔵は水垢で全身赤錆びて、眼鼻立ちなどそれと判別しかねるくらい擦り切れていて、胸のあたりの袈裟の模様も見えなくなってしまっている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま下の洗面所に顔でも洗いにゆくと、目に入るものは、赤錆いろの鉄分の強い坪ばかりの池の水と、萎えきって生色のない八つ手の一、二本である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤錆びた一つの岩塊が鋭く浪の中から起つて立つてゐるにすぎなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女　えゝ、錠の鍵は、がつちりさゝつて居りましたけれど、赤錆に錆切りまして、圧しますと開きました。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄屑の油や細かい粉で散々に穢れているが、刃先の方には血痕らしい赤錆が浮いている。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さほど高いといふでないが他とやゝ離れて孤立し、あらはに禿げた山肌は時に赤錆びて見え時に白茶けて見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤錆だらけの牡蠣殻だらけのボロ船が少しも恐ろしい事アないが、それでも逃がして浦塩へ追い込めると士気に関係する。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、驚いたことには小刀が悉皆赤錆になっております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "鋳物の仕事をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大河の水は岩礁を割いた水道のコンクリートの堰と赤錆びた鉄の扉の上を僅に越えて、流れ注いで、外には濁つた白い水沫と塵埃とを平らかに溜めてゐるばかりだ。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雪の積っていない軌条を追い求める様にして、もうひとつの達磨転轍器を切換えた私達は、とうとう臨港線の赤錆た六十五｜封度軌条の上へ疾走り出た。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "船籍、ブエノス・アイレスと白ぺいんとが赤錆で消えかかって、足の下の吃水線には、南あめりかからくっ附いて来た紫の海草が星と一しょに動いていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の中央に物置小屋みたいなものがあり、横のあき地に赤錆のついた古金網、ねじ曲った鉄棒、寝台の部分品のこわれなどがウンと積まれている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根や垣がさっと転覆した勢をその儘とどめ、黒々とつづいているし、コンクリートの空洞や赤錆の鉄筋がところどころ入乱れている。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度、雨が降りしきっていましたが、向うから赤錆びたトタンの切れっぱしを頭に被り、ぼろぼろの着物を纏った乞食らしい男が、雨傘のかわりに翳しているトタンの切れから、ぬっと顔を現しました。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根や垣がさつと転覆した勢をその儘とどめ、黒々とつづいてゐるし、コンクリートの空洞や赤錆の鉄筋がところどころ入乱れてゐる。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度、雨が降りしきつてゐましたが、向から赤錆びたトタンの切れつぱしを頭に被り、ぼろぼろの着物を纏つた乞食らしい男が、雨傘のかはりに翳してゐるトタンの切れから、ぬつと顔を現はしました。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の者は、そのうす汚れた布片れにくるんであった、赤錆のついた鉄棒か斧が、真暗の湯殿に立って、若し誰でも来たらと身構えて居る男の背後にかくされてある様子を思うと、ほんとに背骨の一番とっぽ先が、痛痒い様な感じを起して来る。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪先上りの所所には、赤錆の線路も見えない程、落葉のたまっている場所もあった。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く見れば、浅間はただなだらかで端正に裾をひいているが、近づいて見ると、緑色の上着の胸を寛げて、自己の履歴を語るように、焼け爛れた赤錆色の四角な肌を露出している。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはもう赤錆のふいた亜鉛葺の納屋が一棟あった。",
              "citation": {
                "source": "悠々荘",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして赤錆びた鉄の扉を開いて、腹這になるやうな形をして一度奥を覗き上げた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨恨者の復讐の剣は赤錆のまま、破廉を秘めた市民の胸へ公然と突き刺された。",
              "citation": {
                "source": "碑文",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪先上りの所々には、赤錆の線路も見えない程、落葉のたまつてゐる場所もあつた。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
