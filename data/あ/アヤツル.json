[
  {
    "uuid": "72904ffd-ccff-5838-a9a7-5c6bd539462b",
    "entry": "操る",
    "reading": {
      "primary": "あやつる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to operate (e.g. a machine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日操るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "操るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は操るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には操るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "操るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは操るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "操るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は操るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では操るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "操るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に操るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では操るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "操るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると操るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "操るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では操るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に操るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により操るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "操るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に操るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "西洋人の曲馬師らしいのが居てそれが先ずセロを弾く、それから妙な懸稲のようにかけ渡した麻糸を操るとそれがライオンのように見えて来る。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベットを操る間絶えず胸に描いていた美しい、魅力のある内地が、あの封筒一ツに覆がえされてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛の角を出して、櫓を操るものありとせよ、青螽の流るゝ如き発動汽艇の泳ぐとせよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そんなことを言っても誰一人判って呉れるものはないのだから彼はただ、ときどき顔を背けて苦笑するだけで、縁あれば道伴れとなり縁なければ別れて一人となる機会の操るままに任せ、自分だけは切れそうになる思惟の糸を継ぎ継ぎ一向きにかの神秘の把握に探り入った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "穉い方は、両手に舷に掴まりながら、これも裸の肩で躍って、だぶりだぶりだぶりだぶりと同一処にもう一艘、渚に纜った親船らしい、艪を操る児の丈より高い、他の舷へ波を浴びせて、ヤッシッシ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有触れた銀流し、汚い親仁なら何事もあるまい、いずれ器量が操る木偶であろう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面を操ること、草履を突つ掛けたよりも輕うして、横にめぐり、縱に通つて、漂々として浮いて行く。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――　不思議な光景は、美しき女が、針の尖で怪しき魔を操る、舞台における、神秘なる場面にも見えた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……島へ渡した細綱を手繰って、立ちながら操るのだが、馴れたもので、あとを二押三押、屋形船が来ると、由を聞き、魚を視て、「まあ、」と目を※ったきり、慌しく引返した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の惜からぬ身には、操るまでの造作も要らぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜は西洋臭し、三崎は品が落着かず、界隈は間に合わせの俄仕入れ、しけものが多うござりますので、どうしても目量のある、ずッしりしたお堅いものは、昔からの藤沢に限りますので、おねだんも安し、徳用向きゆえ、御大家の買物はまた別で、」　と姥は糸を操るような話しぶり。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、お仏壇と、それから、蔦ちゃんが庭の百合の花を惜がったから、莟を交ぜて五六本ぶらさげて、お源坊と、車屋の女房とで、縁の雨戸を操るのを見ながら、梅坊主の由良之助、と云う思入で、城を明渡して来ましたがね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "独木舟を操るに巧みでない遊牧民は、湖上の村の殲滅を断念し、湖畔に残された家畜を奪っただけで、また、疾風のように北方に帰って行った。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨木舟を操るに巧みでない遊牧民は、湖上の村の殲滅を斷念し、湖畔に殘された家畜を奪つただけで、又、疾風の樣に北方に歸つて行つた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、棹で操るがごとくになって、夥多の可心持に乾いた亀の子を、カラカラと載せたままで、水をゆらゆらと流れて辷った。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫂を操る十六大士のお姿も、追々はっきり見えて来た。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは何の木の花だね」「漆の花だなも」で、巧に棹を操る舳の船頭である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "絃を操る手も休めない。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒婦とか色魔とかが異性を操る事の自由自在さは全く驚くべきものがあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云われてみれば、温和しく純真な美沢に、美和子を操る力など、最初から無かったことに、今更のように気がついて、新子は更に、味気ない気になった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女道楽の主人が、嫉妬ぶかい夫人を、操る手管を考えるように、夫人は、良人と新子と新子の姉との三人をどんなに扱うべきかを心ひそかに考えているのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気の好い休日には娘の操る車に、村のあらゆる階級の若者、主に娘達が乗り込んで、屹度何処かへ遊びに行く。",
              "citation": {
                "source": "一九三〇年型",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが手先を操る当の黒幕は決して捕まらない――疑われすらしない。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「衆生既信伏質直意柔軟、一心欲見仏、不自惜身命、」と親仁は月下に小船を操る。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と深切におっしゃりながら、団扇使の片手｜煽に、風を操るがごとくそよそよと右左。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国婦人が住んでいてね、私なんぞにゃ朗々としか聞えんが、およそ目には見えんで、各自はその黒髪の毛筋の数ほど、この天地の間に、天女が操る、不可思議な蜘蛛の巣ぐらいはありましょう、恋の糸に、心の情が触れる時、音に出づるかと思うような、微妙な声で、裏若いのが唱う。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く廊下に操る布の、すらすら乱れて、さまよえるは、ここに絶えんず玉の緒の幻の糸に似たらずや。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――　不思議な光景は、美しき女が、針の尖で怪しき魔を操る、舞台に於ける、神秘なる場面にも見えた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……島へ渡した細綱を手繰つて、立ちながら操るのだが、馴れたもので、あとを二押三押、屋形船へ来ると、由を聞き、魚を視て、「まあ、」と目を※つた切、慌しく引返した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　九官鳥の口まね　せんだって三越の展覧会でいろいろの人語をあやつる九官鳥の一例を観察する機会を得た。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
