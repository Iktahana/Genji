        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で、「青」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "季節の変化とともにこの傾向が顕著になる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からこの風習が形成された。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でこれは欠かせない材料とされている。",
              "source": "幻辞"
            },
            {
              "text": "観光地を訪れる際にこのポイントを押さえておくべきだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で、「青」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "わが知らぬ、とほきとほきとほき深みにて　青空は、白い雲を呼ぶ。",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが何を話したか別段記憶しないが、ともあれみんな文学青年が先輩を詣でた式のことで、主人は間もなく退屈した。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主調色は青であり、あけぼのの空色であり、彼自身の讃ふべき語を以てすれば、「鋼青」である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその気質としては、動物よりも植物を、夏よりも冬を愛し、――『鋼青』を『苹果』を、午前のみそれを愛したのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪萩原朔太郎青くしなへる我が指のリキユールグラスにふるるとき生れつきとは思へども侘しく見ゆる爪形をさしも憎しと思ふなり",
              "citation": {
                "source": "爪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ金性の肉のおとろへ、みやま瀧ながれ、青らみいよいよおとろふ、いのれば銀の血となり、肉やぶれ谷間をはしる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いまするどく鋭刃を合せ、手はしろがねとなり、われの額きずつき、劍術は青らみつひにらじうむとなる。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いゆき萩原朔太郎青いぞ、ゆきはまつさを、もも、さくらぎに花咲かず、青いこなゆき、光る山路に泣きくらす。",
              "citation": {
                "source": "青いゆき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼天萩原朔太郎いつしんなれば、あふむけに屍體ともなる、つめたく合掌し、いんよくいちねん、きりぎりす青らみ、もはら、雀みそらに殺さる。",
              "citation": {
                "source": "蒼天",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔甘藍の球は弾けて〕宮沢賢治甘藍の球は弾けて青ぞらに白雲の房呑屋より二人の馬丁よろめきてあらはれ出づる",
              "citation": {
                "source": "〔甘藍の球は弾けて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔青びかる天弧のはてに〕宮沢賢治青びかる天弧のはてにきらゝかに町はうかびて六月のたつきのみちはいまやはた尽きはてにけりいさゝかの書籍とセロを思ふまゝ〔以下空白〕",
              "citation": {
                "source": "〔青びかる天弧のはてに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が這入つて行くなり、「さあお相手しませう」とその男は云つた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりやあお前が成績を悪くするからだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日もこりやあお午からは暑くなりますよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも聞こえはしませんよ、……お休み、それあおまへの妄想ですよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "覘いている竹村君の後ろをジャン／＼と電車が喧しい音を立てて行くと、切るような凩が外套の裾をあおる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千住よりの小蒸気けたゝましき笛ならして過ぐれば余波｜舷をあおる事少時。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
