[
  {
    "uuid": "1a8636a5-dbd2-59a1-baf9-503d15e6725e",
    "entry": "合鍵",
    "reading": {
      "primary": "あいかぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "duplicate key",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合鍵は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合鍵が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合鍵に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合鍵が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合鍵について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合鍵についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合鍵について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合鍵が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合鍵が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合鍵は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合鍵は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合鍵を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合鍵をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合鍵が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合鍵の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合鍵を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合鍵に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合鍵について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合鍵は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合鍵を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "広東政府の大官である彼に向って米良はお互の心の合鍵を交換するとうやうやしく敬礼した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、居るに違いないが……ままよ念のためだと、急がわしく、馳せ行きて北の台と名づけたる高楼の、怪しげなる戸口に到り、合鍵にて戸を開けば、雷のごとき音ありて、鉄張の戸は左右に開きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※互に心合鍵に、早瀬見送る。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「（つかん事を聞きますけれど、鋳掛屋さん、錠の合鍵を頼まれて下さいますか。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（でも、合鍵は拵えて下さいまし、大事にそれを持っていて、……出来るだけ我慢はしますけれども、どうしても開けたくってならなくなりました時に、生命にかえても、開けて見とうございますから。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あ猿坊のように、ちょろりと影を畝って這出して、そこに震えて立っている、お道姉さんの手に合鍵を押つけた。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、私と云うものは……若奥様には内証だが、その高崎の旦那に、頼まれまして、技師の方が可い、とさえと一言云えば、すぐに合鍵を拵えるように、道中お抱えだったので。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "合鍵をもっていたので、あけて中にはいった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夏子はカラ子の肩につかまって、ハンドバッグから合鍵を出そうとする手を泳がせていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ポケットを探って取出した部屋の合鍵が、掌にひやりとした感触を与えるほどの時候になっていた。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは事務所内のあらゆる鍵の合鍵と、堅固なる部屋と金庫のある位置とに関しての知識を得んがために、利用したるなり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、君は、いつの間にこれが持ち込まれて、隣室の戸棚へ仕舞われたかを知らなかっただけさ」　そして笑いながら大月は、ポケットから鍵束を出して合鍵を求めると、素早くスーツ・ケースの蓋を開けた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼等は寄々相謀つた揚句、合鍵を鋳造することに決したが、何しろ二百年も前から伝はる錠前なので到底今日のものでは役に立たぬことが解つて改めて、入念の家探しに没頭してゐる時だつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お嬢様は、今年十七でいらっしゃいます」「有難う」夏山警部補は満足そうにニヤリと笑うと、「ではもう一つ、他でもないが、堀見家の人々は、皆んなこの別荘の合鍵を持っているね？",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィッロイ・シムソンは厩番を薬で眠らせ、どうかして合鍵を手に入れて、誘拐し去る目的で馬をつれ出した。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕えられた時、厩舎の合鍵を持っていましたか？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "合鍵は目的を達した上は、どこへかすててしまったものと考えられます。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでわたしは合鍵を借りて、二十七号室と石垣建築事務所とを境するドアを開けました。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこれは僕の秘蔵の手製合鍵である。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が持っていた鍵によって、小函がハルピン虎の手にあることを知り邸内に忍びこんで、トランクを合鍵で開けて盗み出し、出ようとするところをハルピン虎に見つかったのだった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "賃銀を払つて、合鍵を出してドアをあけスイッチをひねるとまず一息というので机の前に腰かけてスリーキャッスルをすいはじめた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして合鍵で扉を開いて中に這入って、泥酔して睡っている岩形氏に麻酔か何かを施してモルフィンの注射をして、自殺か他殺かの判断を迷わせるために色々な小細工をした。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のみならず一度閉まっていた扉がどうして開いたのでしょう」「合鍵はこのホテルに別なのがあります」　検事の言葉がだんだん鋭くなって来た。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬢次様は曲馬団を出がけに、持って行く隙がおありになりませんでしたので、ただ、あなた方の合鍵で明けられないように、錠前だけ壊して行かれたのです」　ストーン氏はちょっと唇を噛んだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝早くお母さんに合鍵を渡して、ゴンクールの寝室から生命がけでこのブローニングを取って来てもらったのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、とっさのあいかぎができあがったのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この針金のあいかぎをつくるのには、いろいろなコツがあって、ひじょうにむずかしいのですが、小林君は、練習をかさねて、いまでは、それができるようになっていました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといって、ほんものの小林は、あいかぎを持っていないので、牢から出られっこないのですからね。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、牢屋の外にいる小林君は、あいかぎがなければ、あけられないなどと、うそをついているではありませんか。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あいかぎで錠をひらいて、鉄ごうしの戸をひらき、牢屋の中へ、はいっていったのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
