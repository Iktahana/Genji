        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粗玉について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗玉という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗玉の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗玉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗玉を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗玉について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗玉の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗玉の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗玉が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗玉という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗玉という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗玉についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗玉を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗玉は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗玉について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗玉が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗玉は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗玉の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗玉は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗玉は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――やあ、あらたまったな、なんだい。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か思い当ることでも有るらしく今まで少し心配そうな顔が急に爽々して満面の笑味を隠し得なかったか、ちょッとあらたまって、「実は少々貴姉に聞て見ることがあるのよ、」　と一段小声で言った。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　海野は太くあらたまりてさもものありげに問懸けたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の言う事は、いつも嘘ばかりで、ちっともあてにならないけれど、でも此のあらたまった言葉一つは、固く信じようと思った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』お絹にも話あり、いそいそと中庭から上がれば叔父の顔色ただならず、お絹もあらたまって『叔父さんただいま、自宅からもよろしくと申しました。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が慇懃にあいさつする言葉を打ち消して、『いやそうあらたまれては困る。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから、あらたまって謙遜りつつ言ったのである。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伊沢はあらたまった口を利き、寒いから一つと言って猪口を差すので、銀子も素直に受け、一つ干して返した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時銀子は藤川のお神にちょっとお出でと下へ呼ばれ、若林の傍を離れて居間へ行くと、お神は少しあらたまった態度で、「若ーさんもお前はんが知っての通り、このごろひどい思惑はずれで蒼くなっていなさる。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の悲しみや怒りや恥を、たいてい小説で表現してしまっているので、その上、訪問客に対してあらたまって言いたい事も無かった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、あの額縁の画についての夫婦の相談や、この長火鉢の位置についての争論を思いやって、やはり生活のあらたまった折の甲斐甲斐しいいきごみを感じたわけであった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といやにあらたまったみたいな、興ざめた事を言い出すので、私はひどく恰好が悪くなり、「でも、あなた、お変りになったわよ。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポローニヤス、急にあらたまって、どうしたのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」姉さんは、あらたまった顔つきになり、「兄さんは、お前に何か言ったの？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）（あらたまって）なぜですか？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とあらたまった口調で言った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、わたくし、急にあらたまるあなたの口調おかしくて、ふとんかぶってこらえてばかりいました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＴ君は、あらたまつて私にお辞儀をして、「ビールのはうが、いいんでしたかしら。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄がへんな顔をしてゐるので、説明してあげようかな、とも思つたが、あまり馬鹿々々しい話なので、あらたまつて「高山帰り」の由来を説き起す勇気は私にも無かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、暫く變にあらたまつた沈默を續けました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御堂の中では何んとなく気もあらたまります。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの三寶ヶ辻まで引返すと、丁どいつかの時と殆ど同じ處、その温泉の町から折曲一つ折れて奧の院參道へあらたまる釣橋の袂へ提灯がふうわりと灯も仄白んで顯はれた。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と妻は突然、あらたまったような口調で言い、「父さんは、いつでも本気なのか冗談なのかわからないような非常識な事ばかりおっしゃるんだもの。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わかい医学研究生は、学校の試験に応ずるような、あらたまった顔つきで、そう反問した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わかい医学研究生は、学校の試験に応ずるやうな、あらたまつた顔つきで、さう反問した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あらたまった顔つきになって、わざと、大袈裟にきょろきょろしてみる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段、あらたまった感慨もない。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
