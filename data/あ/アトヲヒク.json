    "definitions": [
      {
        "index": 1,
        "gloss": "to be moreish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日後を引くについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "後を引くという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は後を引くの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には後を引くが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "後を引くを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは後を引くについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "後を引くの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は後を引くの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では後を引くが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "後を引くという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に後を引くという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では後を引くについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "後を引くを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると後を引くは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "後を引くについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では後を引くが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に後を引くは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により後を引くの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "後を引くは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に後を引くは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "仮令これを一時の事と見ても、その影響はかなり永く後を引く虞れがある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七　飲み出すと、いつも後を引く癖のある小林が、浅井と二、三番も碁を闘わしてから、帰って行ったのは、大分遅くであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺されたッ……と思った一刹那の一念は、後を引くってえじゃないか」　親方が何気なく、剃刀を磨ぎに行った。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても世の中のことは、何時までも後を引くものである。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぺん遣ったら後を引くし、もし遣らないと、呪ったりくだらぬことを言いふらしたり、色んな仕返しをはじめるんだ。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "切られては買い切られては買い後を引くものと見えて、凧揚げのことをつぶらかしというくらいだ」「身上を潰すのかい？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「負け碁は兎角あとをひく也」で、良正は独力の及ぶ可からざるを以て下総介良兼（或はいふ上総介）に助勢を頼んで将門に憂き目を見せようとした。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれだけの大事件があっても、後になってそれがあとをひくというようなことがほとんどなかった。",
              "citation": {
                "source": "長岡と寺田",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を斬るとあとをひく。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その波も事変がすぎてみると、たいしてながくあとをひくというほどではなかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
