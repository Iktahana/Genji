    "definitions": [
      {
        "index": 1,
        "gloss": "raising and lowering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上げ下げの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして今見た人形のように手を上げ下げした。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫は黙って吸わせたままに、足を上げ下げして、おとなしく泳いでいたが、小初ほど水中の息が続かないので、じきに苦悶の色を見せはじめた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ぐれ庫裡へ行燈の油を取りに行く僧も、薬石と名づけられる夕飯を取り囲んで箸を上げ下げしている衆僧も、饑え渇ける異形のものとしか見えなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式だけは完全な流眄をして「どのくらい目方があるか量ってみてよ」　柚木は二三度膝を上げ下げしたが「結婚適齢期にしちゃあ、情操のカンカンが足りないね」「そんなことはなくってよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告一人の力では労銀の上げ下げをどうすることも出来ない事であるのだから。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女乞食は痩せた両肩をぐい／＼と上げ下げし、唇を片頬へ釣り寄せて、わたくしを小莫迦にした表情を見せたのが最初でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、崖の上の下り勾配にかかると、跛でも引くように、首を上げ下げして、歩調を乱すようにしては立ち止まるのであった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ手を皿のあたりに習慣的に上げ下げして振っていたのだが、とうとうその無意識に一様な運動は効き目がなくなってしまった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "９　balancez ――舞踏で同じ場所にいて足を上げ下げすること。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突のなかは『煙突掃除器』で上げ下げした。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラッシを家じゅうのあらゆる煙穴に上げ下げした。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の兄上は帆綱を握って、舵座にいる父上の合図どおりに帆の上げ下げを誤るまいと一心になっている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強弱に応じて帆を上げ下げする様子もない。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と繰り反しながら、洋盃をそのやうに上げ下げして、苦心の程を語つてゐるうちに、感傷家になつてしまつた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう云つた樫田の声で私は目を開いて見ると、私は小鳥の箱を胸先きに構へて、洋盃のやうに、そして昇降機のやうに静かに上げ下げしながら首を傾げてゐたのであつた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、彼は、そつと左手をふところに忍ばせて、右手では飽くまでも磊落を装ふて、徐ろに酒盃を上げ下げしながら、秘めた手の平をぴつたりと胸に圧しあてゝ、微かな鼓動を窺つて見たりした。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ふと、今自分が盃を上げ下げしてゐる膳に気づいて、そんな思ひ出に走つた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "如才が無くッてお世辞がよくッて男振も好けれども、唯｜物喰いの悪いのが可惜瑜に疵だッて、オホホホホ」「アハハハハ、貧乏人の質で上げ下げが怖ろしい」「それはそうと、孰れ御結構振舞いが有りましょうネ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽くなつたらしい尻を上げ下げする動作に重大な務めを終へたあとの安堵を見せながら、また穴のまはりをくるくると廻つた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一般的標準であつたが、葉の質、その日の天候、火の※り工合等によつて多少温度を上げ下げしなければならなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずパネル上に並んでいるスイッチを上げ下げし、ごく短い機械語のプログラムを手作業で入れていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは先生が、まるで羽根を抜かれた鳥のように、絶えず両手を上げ下げしながら、慌しい調子で饒舌った中に、「諸君にはまだ人生はわからない。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのうちに今一挺、新しいのを買ってやるよ」　呉一郎は、それでも何かしら不安そうに鍬の上げ下げを凝視していたが、間もなく独言のように口籠りつつつぶやいた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが、窓を開けるだけに呼びつけておいて、あの位置にするまでに、それは何度上げ下げしたことだったでしょう」　クメルニツキーの大迫害――。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片眼を閉じて、筒先を上げ下げしつつ、軒下の中央へ、駕が止まって、お由羅の立出るのを、一発にと、的を定めていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを上下へ上げ下げする。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チン、チン、チン、カン、カン、カン、ヒュー、ヒューと音楽の音は次第次第に調子を早め、上げ下げをする老婆の手がそれに連れて速くなる。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり老婆は左右の手を上へ下へと上げ下げする。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと外出にも女中が付き、箸の上げ下げにも作法があった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鹿の歌」は、鹿がお辞儀する様な頸の上げ下げ、跳ね廻る軽々しい動作を演じる様に出来て居る。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
