        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おい、相輿じゃあ足も伸ばせやしない。もう少し向こうへ寄ってくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二人は狭い相輿に揺られながら、道中、密かに今後の策を練った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宿場町では、旅費を節約するために相輿で峠を越える旅人の姿も珍しくなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "贔屓の芸妓を連れての相輿は、当時の通人にとって粋な振る舞いの一つとされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大男二人での相輿は、前後の担ぎ手にとってこの上ない重労働であったに違いない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかくの相輿なんだ、そう堅苦しく考えずに道中を楽しもうじゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
