    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rib",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "肋骨について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この肋骨は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "肋骨の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が肋骨について知っています。",
              "source": "幻辞"
            },
            {
              "text": "肋骨は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は肋骨の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "肋骨に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では肋骨が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から肋骨を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "肋骨の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも肋骨が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では肋骨が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "肋骨について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも肋骨は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも肋骨は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で肋骨は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に肋骨について学びました。",
              "source": "幻辞"
            },
            {
              "text": "肋骨の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する肋骨の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では肋骨の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "肋骨みな瘠せ軍鷄の如くに叫べるを聽く。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沢が、濶く、峡間に延びて、峡流の分岐したのが、幾筋となく蜿ねり、枯木が、踏み砕かれた、肋骨のようになって、何本も仆れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさま、この福慈岳は火を背骨に岩を肋骨に、砂を肉に附けていて少しの間も苦悩と美しさと成長の働をば休めない大修業底の山なのでございますわ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山一つさえその通り――「まだそのときのわたくしは、きしゃな細火を背骨にし、べよべよ撓るほどの溶岩を一重の肋骨として周りに持ち、島山の中央の断れ目から島地の上へ平たく膨れ上っただけの山でした」　世の中は、ただうとうとと、あま葛の甘さに感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から噴き流れて凝った血が、岩となって二枚目の肋骨としてまわりに張っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども自分の胸から噴き流れて凝った血は、三枚目の肋骨となって、まわりに張っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇って壊れた自分を観ると、そこにはまた第四の肋骨が出来上っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは只今、最初から数えて八枚目の肋骨まで出来ております。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい苦労は確にしたのだな」　それに凝りずに、娘はなおも苦労を迎えてそれを支えた成長の肋骨を増やす積りでいる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてる筈ぢゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なれば、君の感情は恐怖の一刹那に於て、正しく君の肋骨の一本一本をも数へ得るほどの鋭さを持つてゐるからだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　戸外に彼女がでると、萎黄病のように燻んでしめった月が建物の肋骨にかかっていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸には肋骨が一つ一つ數へられた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらわな肋骨の辺には皮が擦り剥けて赤い血が泥ににじんでいるところがある。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何も云わず、ぶくぶくした手が剣身を握りとめないうちに、剣は、肋骨の間にささって肺臓を突き通し背にまで出てしまった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてる筈じゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、いわば安全弁のような役目をして気持ちよく折れてくれるので、その身代わりのおかげで肋骨その他のもっとだいじなものが救われるという話である。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸は貧弱で、肋骨が醜く浮いて見えているので、やはり病後のものと思われたにちがいない。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてるはずじゃないか」　大学士はあわてて走って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてる筈ぢやないか。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため後脳をひどく打ち肋骨を折って親父は悶絶した。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い柱から肋骨のように左右相対に細長い水盤が重なって出ている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "着膨れてはいるが、大きな体格はあまり丈夫ではないらしく、左の手を癖にして内懐へ入れ、肋骨の辺を押えている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父子はここに腰を卸して、見るとも無しに瞰上げると、青い大空を遮る飛騨の山々も、昨日今日は落葉に痩せて尖って、宛ら巨大なる動物が肋骨を露わした様にも見えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肋骨から背中へかけて痛々しい鞭の瘢痕が薄赤く又薄黒く引き散らされていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬々と乱れた髪毛と髯の中から、血走った両眼をギョロギョロと剥き出して、洗濯板みたいに並んだ肋骨を撫でまわしてゼイゼイゼイゼイと咳をした。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯幹は大きいが、みな痩せて背中まで肋骨が透けて見える。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体が足の先きから死に、手の先きから死にして行かうとも、最後に残つた肋骨一本へでも、生きた気込みは残して見せようぞ――。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの爺いさん、岩の肋骨を攫まえていないと、あなた、谷底へ吹き落されてしまいますぜ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その着物が、すっと姿を消しているのを発見する度毎に、肋骨を一本失ったみたいな堪えがたい心細さを覚える。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
