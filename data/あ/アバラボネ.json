[
  {
    "uuid": "c228a17e-ffc4-5c93-bf64-d9fed4917d57",
    "entry": "肋骨",
    "reading": {
      "primary": "あばらぼね",
      "alternatives": [
        "ろっこつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
