        "examples": {
          "standard": [
            {
              "text": "駅の自動改札でＩＣカードをかざして通過する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ＩＣカードの残高が少なくなってきたので、券売機でチャージした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "最近では、交通機関だけでなくコンビニや自動販売機でもＩＣカードが使える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「お支払いはＩＣカードでお願いします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この会社の社員証はＩＣカードになっており、オフィスの入退室管理にも使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "マイナンバーカードのような公的な身分証明書もＩＣカードの一種である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "万が一ＩＣカードを紛失した場合は、すぐに利用停止の手続きを行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ＩＣカードの採用でフロッピーディスクの駆動装置を外し、現状のノートブック型をもう一つ絞り上げるのは当然考えられるところ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともブラインド・タッチ可能なＩＣカード機は、現状のユーザーには極く素直に受け入れられるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＣカード・ベースで重量は一キログラム以下。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
