          ],
          "literary": [
            {
              "text": "花は茎梢に一花ないし数花｜点頭して咲き、反巻せる花蓋面に暗点がある。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点が道元の思想において残されたる暗点である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
