    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sweetish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こう見ねえ、斯うやって這いずって居る蠅を見て居ると、己れっちよりゃ些度計り甘めえ汁を嘗めているらしいや。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空の空なるかな総て空なり」「空なるかな」が甘めえ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い込んで思うさま甘めえ御馳走にありつくんだてったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甘いでしょう」「甘めえ」「もう一つあげましょう」「有難う」　お雪ちゃんは、まだ幾つも目籠の中に忍ばせているらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを側面から望み見て、それは誰れもよく言うように、世の中は存外甘めえもんだナと独りでそのおかしさを噛み潰していた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フ、フ、フ、甘めえもんだぜ、銭形の。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手槍がありや抛つてお目にかけますぜ、猪や熊だつて一と突きだ、人間なんざ甘めえもんで」　仁助がヌケヌケとそんな事を言ふと、「兄哥、餘計なことは言はない方がいゝぜ、俺だつて、銛なら抛るが」　吉三郎はニヤリニヤリして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "どんど燒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間が玉子から生れると思つてゐるから、親分も甘めえものだ――そんなことは本草學にもねえ事だよ」「何んだと」「兎も角も、新六さんを縛つて行くと、親分の引つ込みがつかなくなるぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの死",
                "note": "青空文庫"
              }
            },
            {
              "text": "親は甘めえから何んにも知らねえが、お近さんくらゐは知つて居るだらうよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん、女なんて甘めえや、自分のことだというとすぐ情熱的な眼つきをしやがる。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はま……だれかおれを呼んだら、便所にいるってそういえよ」「いや裏の畑に立ってるってそういってやらア」「このあまめ」　省作は例の手段で便所策を弄し、背戸の桑畑へ出てしばらく召集を避けてる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『このあまめ、いつになったら斃ばりやがるんだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまめ、ここまで来ても、やっぱり逆さに落ちて行きゃがった。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、しぶといあまめ、こうして浮上らせてくれるぞ」　野蛮な刑事がいきなり手を伸ばして、竹筒の切口を押えた。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
