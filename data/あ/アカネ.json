        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "とかくするうち東の空白み渡りて茜の一抹と共に星の光まばらになり、軒下に車の音しげくなり、時計を見れば既に五時半なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚味の雲の奥で、日が茜さしたのか、東の空が一面に古代紫のように燻んだ色になった……富士の鼠色は爛れた……淡赭色の光輝を帯びたが、ほんの瞬く間でもとの沈欝に返って、ひッそりと静まった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお残る茜の空に一むれ過ぎて、また一むれ粉末のまだら。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になって陽がかなたへ傾くと、富士も丹沢山も一様の影絵を、茜の空に写すのであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして椎茜という言葉を造って下の五におきかえ嬉しい気がしました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆう日あざやかにぱっと茜さして、眼もあやに躑躅の花、ただ紅の雪の降積めるかと疑わる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず休んで、」　と三足ばかり、路を横へ、茶店の前の、一間ばかり蘆が左右へ分れていた、根が白く濡地が透いて見えて、ぶくぶくと蟹の穴、うたかたのあわれを吹いて、茜がさして、日は未だ高いが虫の声、艪を漕ぐように、ギイ、ギッチョッ、チョ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、南天の實の溢れたやうに、ちら／＼と其の底に映るのは、雲の茜が、峰裏に夕日の影を投げたのである。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "篝火焚くか、と根が燃えて、眞紅の梢が、ちら／＼と夕の茜をほとばしらす。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同士討　　虐殺　　二重の壁　　赤城様――得三様　　旭一　急病　雲の峰は崩れて遠山の麓に靄薄く、見ゆる限りの野も山も海も夕陽の茜に染みて、遠近の森の梢に並ぶ夥多寺院の甍は眩く輝きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と震聲で、慌てて、むつちりした乳の下へ、扱帶を取つて卷きつけながら、身體ごとくる／＼と顛倒して※る處へ、づかと出た母親は驚いて、白晝の茜木綿、それも膝から上ばかり。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持て余しておりました処へ、ちょうど荷車を曳きまして、藤沢から一日｜路、この街道つづきの長者園の土手へ通りかかりましたのが……」　茜色の顱巻を、白髪天窓にちょきり結び。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう姿が隠さりょう、光った天窓と、顱巻の茜色が月夜に消えるか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と夜具風呂敷の黄母衣越に、茜色のその顱巻を捻向けて、「厭な事は、……手毬を拾うと、その下に、猫が一匹居たではねえかね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青田の高低、麓の凸凹に従うて、柔かにのんどりした、この一巻の布は、朝霞には白地の手拭、夕焼には茜の襟、襷になり帯になり、果は薄の裳になって、今もある通り、村はずれの谷戸口を、明神の下あたりから次第に子産石の浜に消えて、どこへ灌ぐということもない。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何時迄待っても、夕方になってやがて浜辺や松林の景色が物悲しく茜色に染まって、日が暮れかけても、幸子は帰らなかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が夕映で茜色になり、空の茜が海にうつつて、海もあかくなつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "空と海の茜が消えて、岩の蔭はもう暗かつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、両手に余る位、花がたまつたとき、腰が痛くなつた良寛さんは、立ちあがつて、いつの間にか、空が日暮の茜に染まつてゐるのを見た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹も石も片側茜色になつて、反対側に影をひいた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆふ日あざやかにぱつと茜さして、眼もあやに躑躅の花、ただ紅の雪の降積めるかと疑はる。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜の姉も三四人、鬱金の婆様に、菜畠の阿媽も交って、どれも口を開けていた。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草ももう吸い飽きて、拱いてもだらしなく、ぐったりと解ける腕組みを仕直し仕直し、がっくりと仰向いて、唇をペろぺろと舌で嘗める親仁も、蹲んだり立ったりして、色気のない大欠伸を、ああとする茜の新姐も、まんざら雨宿りばかりとは見えなかった。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええええ、その董、露草は、若様、この度の御旅行につき、白雪の竜馬にめされ、渚を掛けて浦づたい、朝夕の、茜、紫、雲の上を山の峰へお潜びにてお出ましの節、珍しくお手に入りましたを、御姉君、乙姫様へ御進物の分でござりました。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になると、その金属の冷たい手触りを喜びながら、植民地の新開地じみた場末の二階の窓から、茜色の空を眺めてはハモニカを吹くのであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝術感及び實感の交錯は芝翫の八重垣姫、茜屋のお園の演伎の際、屡※東京座や歌舞伎座の大入場の喧噪として現はれたものである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイ、笈摺もな、兩親のある子やゆゑ兩方は茜染……」の一段になつて、予も始めて、はつと幻想の世界に落ち込んだやうな心持がした。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山の裾野にあかねさす紫匂ふ花あやめかも櫻草の花によく似る紫の花めでつゝも名を知らずけり花あやめしみ咲きにほふ紫の花野を來れば物思もなし紫の雲ゐる野べに朝遊び夕遊びます二荒の神湯の滝を見、湯本に遊びて帰る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中あかねさす西日は照れどひぐらしの鳴き蟲山に雨かゝる見ゆゆくゆく一人の少女のいと艶なるに逢う。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にばかり涼んでいちゃあ埒があかねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
