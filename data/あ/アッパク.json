        "examples": {
          "standard": [
            {
              "text": "毎日、圧迫について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の圧迫戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "圧迫の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "圧迫という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは圧迫について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "圧迫の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "圧迫に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは圧迫を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での圧迫は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、圧迫は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "圧迫は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な圧迫を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「圧迫」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "当時の露国海軍のブルータルな勢力の圧迫が若い頭に何かしら強い印銘を与えていたかもしれない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば美術や音楽の方面においていわゆる官学派の民間派に対する圧迫といったようなことについて、具体的の実例をあげていわゆる官僚的元老の横暴を語るのであったが、それがただ冷静な客観的の噂話でなくて、かなり興奮した主観的な憤懣を流出させるのであった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理の圧迫が劇しい時には弱虫の本性を現してすぐ泣き出すが、負けぬ魂だけは弱い体躯を駆って軍人党と挌闘をやらせた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深さが何万尺あるか測られない、この中に何か潜力的な、巨大な物が潜んでいる、そうして生物を圧迫する――化性の蝙蝠でも舞い出そうだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの底には、もしくは外には、都会がある、群集がある、燈火、音曲、寄席、芝居がある、群集と喧噪の圧迫から遁げて、天涯の一角に立ったときに、孤独と静粛の圧迫！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく卵が出来上がるまでには管の内側から始終に圧迫を受けている。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから輸卵管の割に卵が大き過ぎるほど圧迫が烈しいので卵の後方が小さく尖って来る。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の間、待ち焦れ、恋ひ慕ひ、あらゆる寂寞と閨怨とによつて刺戟しつくした揚句、今また息も詰るやうな歓喜の圧迫によつてこの自分を苦しめさいなまんとする、敵よ！",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの場合にはそのしびれた脚や腕の根元に近いところに着物のひだで圧迫された痕跡が赤く印銘されているのでそこを引っかき摩擦すればしびれはすぐに消散するのである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気圧の急変で鼓膜を圧迫されるのをかまわないでいたら、熱海海岸で車を下りてみると耳がひどく遠くなっているのに気がついた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教案が生徒を圧迫する度が少なければ少ないほど、生徒は卒業の資格を得やすいだろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この圧迫するような感じを救うためには猿股一つになって井戸水を汲み上げて庭樹などにいっぱいに打水をするといい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帽子外套の列が、どういうものか自分にはよほど遠い世界の帽子外套の列であるような気がして、軽い圧迫を感じさせられた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複製の技術としての絵画はとうの昔に科学の圧迫を受けて滅亡してしまった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭く南画などとは云わず、一般に芸術というものが科学などの圧迫に無関係に永存し得べき肝心の要素に触接しているように思われるのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時少年の心に、この人生をおもちやにしようとしてゐる、色の蒼い弱々しい小娘に対する恐怖が、圧迫するやうに生じて来た。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、うわ手な、罪人を扱うようなものゝ云い方は、変に彼を圧迫した。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、圧迫せられた意気の揚らない老人が発する声とはまるで反対な、力のある、反抗的な声だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし店によってはまだいつものように点燈していたにもかかわらず、町の暗さが人を圧迫するように思われた。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕末勇士などに扮した男優の顔はいかなる蛮族の顔よりもグロテスクで陰惨なものであるが、それが特別に民衆に受けると見えてそれらの網目版が至るところの店先で自分をにらみつけ、脅かし圧迫した。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の色は強烈でありながらちゃんとつりあいが取れていて自分のような弱虫でも圧迫を感じない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう中に交じってみると、自分がただ一人間違ってまぎれ込んだ異国の旅人でもあるような心持がして何となく圧迫を感じるのである。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近、瑞典マッチの圧迫を受けてぷり／＼している不機嫌な支配人は、彼がむしろ支那人に肩を持つ癖があるのを責めて、皮肉な辛辣な眼つきをした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山東兵は、南は、北伐軍に圧迫された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、戦争が絶滅するのは、最も多く圧迫された最後の階級であるプロレタリアートが、自ら解放されながら、全人類をも一般に階級制度から解放した時でなければならない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、プロレタリアートは、現在の戦争に対しても、それが、吾々を解放へ導くものであるか、或は、吾々をなお圧迫するものであるか、その歴史的特殊性を分析することが必要である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑圧者、搾取者に対する、被圧迫階級の戦争には、吾々は同感せざるを得ない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "べつに変ったところもない、普通の親船にすぎなかったが、しずかにしずかに八幡丸を、あっぱくするように近寄ってきた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むねを寝台であっぱくされ、枕であごを支え、手にも支えをもたらせても、やりきれない自分の重量で私はうむうむうなった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
