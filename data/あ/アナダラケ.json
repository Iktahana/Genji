[
  {
    "uuid": "b7bbd858-a46b-5d1f-8108-28708e03ad1d",
    "entry": "穴だらけ",
    "reading": {
      "primary": "あなだらけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "riddled with holes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴だらけについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴だらけの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴だらけが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴だらけについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴だらけの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴だらけが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴だらけという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴だらけについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴だらけは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴だらけが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴だらけは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴だらけの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴だらけは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴だらけは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いわゆる見やすい観念などと称するものは、例の『常識』『健全な理知』（gesunder Menschenverstand）と称するものと同様にずいぶん穴だらけなものかと思います。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実際の探偵小説がそれほどに必然的な実証の連鎖を示しているかというと、そうではなくて、たいていの場合には、巧みにそうらしく見せているだけで、実は大きな穴だらけのものがはなはだ多い。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさん、どうもありがとう」と、穴だらけの外套を頭からかぶって外へ出た。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁と障子の穴だらけな中で、先生は一驚をきつして、「何だい、これは。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは、氣をつけて居るのだから、臺所、もの置は荒しても、めつたに疊は踏ませないのに、大地震の一搖れで、家中、穴だらけ、隙間だらけで、我家の二階でさへ、壁土と塵埃と煤と、襖障子の骨だらけな、大きなものを背負つて居るやうな場合だつたから堪らない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて、三本の白線のはいった穴だらけの帽子を無造作に掴んで、のそっとはいって来たのは、果して梶鶴雄だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は叔父がこんな近い処に住んでいようとは夢にも思わなかったので、子供心に不思議に思いながら叔父に跟いて中に這入ると、上り口は半坪ばかりのタタキで、あと十畳ばかりの板の間に穴だらけのリノリウムを敷いて、天井には煤ぼけた雲母紙が貼ってあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、」「はあ、はあ、」「薄汚れた帆木綿めいた破穴だらけの幕が開いたて、」「幕が、」「さよう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをまた、八百屋のまえに捨てに行ってもいいが、再び、よそのおばさんに、あれ風呂敷おとしましたよ、と注意を受けたならば、私は、たちまちその親切を謝し、この穴だらけの風呂敷を拾って家へ帰らなければならぬ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも颯と夜嵐して、家中穴だらけの障子の紙が、はらはらと鳴る、霰の音。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな蒸暑さでも心得は心得で、縁も、戸口も、雨戸はぴったり閉っていましたが、そこは古い農家だけに、節穴だらけ、だから、覗くと、よく見えました。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴だらけの障子紙へ、穴から抜けたように、すらりと立った、霧のような女の姿。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡蠣殻を載せた板屋根、船虫の穴だらけの柱、潮風に佗びてはいるが、此の辺の漁師の親方の家とて普通の漁師の家よりはやや大型である。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、佐助はさすがに白雲師匠の教訓を忘れなかったのか、鳥人の術なぞ知った顔は一つも見せず、専らアバタの穴だらけの醜い顔を振りまわして行くと、案の定人に好かれた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてさうなつて見ると、私の記憶は穴だらけで、到底對話を組み立てることは出來ない。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、籠に水を汲み溜めようとするようなもので、穴だらけな生活の中へ消えて行ってしまうのであったが、父親も母親ももう、耕平が砂利貨車に働くことを止めようとはしなかった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その札はぐしゃぐしゃと何かに噛まれたに相違なく、ほとんど穴だらけになっていた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、一面に嬰児の掌ほどの穴だらけで、干潟の蟹の巣のように、ただ一側だけにも五十破れがあるのです。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蚊帳のこの古いのも、穴だらけなのも、一層お由紀さんの万事｜最惜さを思わせるのですけれども、それにしても凄まじい、――先刻も申した酷い継です。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お夏の手は、愛吉の焼穴だらけの膝を擦った。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで見たが、名札を見ようという気もなし、扉はその字が読めるようにこっちへ半ば開けてあったんですが、向うには、附添と見えて、薄汚い、そういっちゃ悪いが、それこそ穴だらけの袷を素膚に着た、風体のよくない若い男が、影のように立っていました。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂の巣のやう穴だらけで、炉の煙は幾条にもなつて此処からも潜つて壁の外へ染み出す、破屏風を取のけて、さら／＼と手に触れると、蓑はすつぽりと梁を放れる。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、きみは結構な町の畳からと言ったけれど、母親の寝ていた奥の四畳は破障子の穴だらけだ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大豆打にかつ轉がつた見てえに面中穴だらけにしてなあ」剽輕な相手は益惡口を逞しくした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡戲者ばかりだから障子は何時も穴だらけだ。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフィル人の説に、昔創世の神イムラ金の馬に乗り、魔王ユシュ鉄の馬に乗り、競走するに勝負決せず、創世神無数の鼠を作り出し、鼠が地を穿ち穴だらけにしたので鉄の馬踏み込んで足立たず、ついに金の馬の勝ちとなったというも似た話だ（ロバートソンの『クルジスタンのカフィル』三八四頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ穴だらけでたいへんおもしろくできあがっていると言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆びたトタン板一枚の、穴だらけの庇の下で両肩をすくめ、本郷車庫行きのバスを待つ慶一のまえで、タクシーが急停止し、うしろのドアが開いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
