    "definitions": [
      {
        "index": 1,
        "gloss": "love for one's school or alma mater",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
