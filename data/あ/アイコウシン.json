        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛校心は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛校心が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛校心に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛校心が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛校心について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛校心についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛校心について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛校心が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛校心が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛校心は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛校心は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛校心を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛校心をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛校心が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛校心の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛校心を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛校心に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛校心について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛校心は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛校心を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「かやうな都会の私立中学にあつては、編入者や退学者が大変多いために、生徒の愛校心は至つて乏しいのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正門が立派でなければ愛校心が湧くものではない」といつて是迄の木の門は打倒され、石の門が建てられた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、小学校、中学校、高等学校を通じて、ついに愛校心というものが理解できずに終りました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛校心なきものは日本男児にあらず」　こうした校訓というものが、いつの頃からか五ヶ条ばかりあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の愛校心と、ファッショや右翼団体的な愛国心とは同じ偏したものだ。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愛校心とか、自由主義思想とかいう名目の下ではなく、面白いからであった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団というものは、スポーツから独立して、勝敗だけを旨としており、愛校心という名をかりて、いたずらに戦闘意識をもやしており、あの校歌だの応援歌というものは、坊主のお経によく似ているなア。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育者の権威に煩わされなくなった時代には儕輩の愛校心を嘲り学問研究の熱心を軽蔑した。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから特別な「愛校心」が産まれたり、又勇敢な「応援団」が出来上ったりするのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程野上氏には之で見ると、あまり「愛校心」はなかったようだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の見込は何うしても帝大出だよ」　と山下さんは一向帝大｜栄えもしていないのに、無暗と愛校心が強い。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
