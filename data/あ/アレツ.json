        "examples": {
          "standard": [
            {
              "text": "私は毎日亜列について考えている。",
              "source": "幻辞"
            },
            {
              "text": "亜列という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は亜列の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には亜列が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "亜列を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは亜列について学習した。",
              "source": "幻辞"
            },
            {
              "text": "亜列の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は亜列の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では亜列が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "亜列という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に亜列という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では亜列についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "亜列を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると亜列は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "亜列について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では亜列が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に亜列は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により亜列の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "亜列は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に亜列は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ほれ、これ見れ」　といひながら皆の見てゐる前で蟆口から五円札の何枚かを取り出して見せてゐたが、急に顔色をかへて、慌てゝ蟆口から根こそぎ中のものを取り出して、「あれつ」　といふと立ち上つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれつぱかしの遊びがなんだ、」と云つて腹を立て、「それにしても松田さんこそお気の毒な。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は、ひどい風が雨を横なぐりにふきつけて、びゅうびゅうあれつづけています。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲り角でひよつと逢ふ時それが口輕な女房であれば二三｜歩行り過しては「どうしたえ、勘次さん彼女げ焦れたんぢやあんめえ、尤も年頃は持つゝけだから連つ子の一人位は我慢も出來らあな、そんだがあれつ切り來なくなつちやつて困つたな」と遠慮もなく揶揄うては、少し隔たると態と聲を立てゝ其の句を唄つたりする。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "すごいんだなあ○ぢや、あそこが火星の天｜文台ですかさうです　行つてみませう○御紹介します　こちらが火星天文台の所長さんです僕　星｜野テン太郎ですわたし　星野ニャン子よ僕は　星野ピチです○僕のお父さんは　地｜球の天文台で研究してゐますこれはこれは　ようこそ　星野さんは私よく存じてをりますあれつ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "○こないだは　あなたのお父さんと月野｜博士と髯のひつぱりつこをやりましたねあれつ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にふれるものがみんな燃えちまふわわあ　みんなすごい熱だ○あの病気はつまりペチャ　クシャうむ、それでペチャ　ペチャそれだから　ペチャクシャどうも大ぶ病気が重いのぢや○あれつ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれつ　引つかいたな○あつ！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、『あれつ、てめえは。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木兎はあれつぱなしにして来たけれど？",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『田舎には、もう、あれつきり、行つたことはないかえ？",
              "citation": {
                "source": "ある日",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱりあれつ切りにして置けばよかつたのですわね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、あれつきりの奴ぢや。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は関なんて、あれつ許の金を使ひ込んで、すぐ免職になるのは気の毒な位なものさ」といふ句があつたのから推したのである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だ、あれつぱかしの物に、いつまで拘泥はつてゐるんだらう。",
              "citation": {
                "source": "質物",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、あれつぱかりの僅かの間に、家の中にいる人間が庭に出て駿太郎にあんな残酷な真似をして、何くわぬ顔して家の中に戻つてくるなんてことは全く不可能だという信念をおこさせることになるのだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あのおやぢを責めることも出来ねえさ、奴さんは馬鹿で、あれつきりの人間だからなあ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗したのかなあと、あれつきり話をきくことが出來なかつた、赤十字社の看護婦のことをきいた。",
              "citation": {
                "source": "日本橋あたり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、あれつきり私の見かけなかつたＡ公使のお孃さんと、いつか櫻の澤を一しよに散歩してゐたもう一人のお孃さんとが立つてゐる。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらなくちや、君、さうさ、やらなくちや、君、大した勢だな、ぞくぞくするよ、全く、――全く」独り言のやうに語尾を低くしたが、又調子を高めて、「それで、君はあれつきり高等学校を中途で止したのだねえ。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、あれつきり。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の方へもあれつきりなんだがね……」と、Ｔが私が坐るなり云ひ出した。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "志岐　　お前は、あれつきり、そのことについちやなんにも云はんなあ。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と答へられたので、いささか虚を衝かれた形だつたが、英子がそばから、「兄さんはあれつきりなのよ。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後あすこも経営難で一時は閉鎖しちやつたりした事があるがね、あれつきりになつたら、美緒なんか、こんな病気にまでなる位に骨を折つて創立した所だしね、あきらめがつかないんで、とてもヤキモキしてゐたんだ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なるほど、赤井達は、あれつきりで、会へないかもわからんのだ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（逆さに覗く）より　あれつ！",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、越前屋はあれつ切りですかえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一枚の文錢",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく來てくだすつたわね、あれつきりかとも思つてゐたのよ。",
              "citation": {
                "source": "汽車で逢つた女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれつぽちの事で苦しめる柄でもないのに。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
