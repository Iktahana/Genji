        "examples": {
          "standard": [
            {
              "text": "毎日、徒事について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の徒事戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "徒事の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "徒事という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは徒事について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "徒事の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "徒事に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは徒事を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での徒事は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、徒事は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "徒事は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な徒事を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「徒事」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうしてその科学界を組織する学者の研究と発見とに対しては、その比較的価値｜所か、全く自家の着衣喫飯と交渉のない、徒事の如く見傚して来た。",
              "citation": {
                "source": "学者と名誉",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の永い間の焦燥、憂慮、省察、求信、之等は決して徒事では無かつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも徒事でねえように思われる。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われもフエデリゴも心に此遊の徒事ならざりしを喜びあへり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは徒事であった。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若輩は徒事に趨るもの多し。",
              "citation": {
                "source": "「或る女」についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは概ね皆｜徒事であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし腕に切創のある上田が捕へられて見れば、海間の心づくしも徒事になつた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――週に六日、毎日六時間ばかり、何等かの社会的な生産的な勤労に徒事し、それで生計を立て、その他の時間を、随意に自由に使用する。",
              "citation": {
                "source": "今日の条件",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校で無理に教へる學問などよりも遙に尊いものが、あの小篇の中に潛んでゐる事を思ふと、自分は海外留學の徒事でなかつた事を滿足に思ふのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海の下は地獄へ底抜けの、行くも帰るも徒事では通れない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎はただ手持無沙汰の徒事とばかり思って、別段意にも留めなかったが、婆さんは丹念にそれを五六寸の長さに縒り上げて、文銭の上に載せた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは時々、徒事でなかつた。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも徒事ではあるまいが、おかしな心理といわざるをえない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼徒事靜養瞑坐而已、則與此學脈背馳。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時安心して天下唯一の美味に親しんでみることは決して徒事ではないと思われるのである。",
              "citation": {
                "source": "河豚食わぬ非常識",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ無用の徒事たるのみに非ず、複雑なる北斎の作品に関する複雑なる評論をして更に一層の繁雑を来さしむるの嫌あればなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世に徒事の多きは啻にこの事のみではない。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を買って酔を催すのも徒事である。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "烟草を喫するのもまた徒事。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "書を購って読まざるもまた徒事である。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んで後記憶せざればこれもまた徒事にひとしい。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生徒事の多きが中に、避姙と読書との二事は、飲酒と喫烟とに比して頗廉価である。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の書きものは一言半句正に何にもならない徒事徒言に過ぎないと思ひますが、これに「滑稽」ともいふべきものありとすれば、日常、夢にも右にいつた「山」とか「海」とかいふモノを感じたことのない塵埃の中の人間が誌した雑記として、あるひは多少その塵のカンジは出てゐるかも知れないといふことです。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども岡田はいっこう気にもとめない様子だったから、おおかたただの徒事だろうと思っていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "※の中でお前の顔を己に向けてくれたのも、徒事ではなかった。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "8690しかし口で言うのは徒事だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまになって見ると何の為に永い間はたらいてばかりいたか、徒事にすぎないことに思われた。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
