        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、藍革は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは藍革が重要です。",
              "source": "幻辞"
            },
            {
              "text": "藍革に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では藍革が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で藍革について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から藍革についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では藍革について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では藍革が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では藍革が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に藍革は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において藍革は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に藍革を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に藍革をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で藍革が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、藍革の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は藍革を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は藍革に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で藍革について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から藍革は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは藍革を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やってみると、あいかわらずちっとも聞こえない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちはあいかわらずどんどんやって行きます。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、もう駒を並べましたね、あいかわらず性急ね、さあ、貴下から。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらずお達者で……」　役員は狼狽して身を正し、奪うがごとくその味噌漉し帽子を脱げり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちさはあいかわらず元気百パア、私も食気百パアというところ。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは、あいかわらず、かた足で立っていて、もう一方の足を高くあげていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、あいかわらず、水の上に浮びながら、波のまにまにゆられて、船室の中をのぞいていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "死神はあいかわらず、大きなからっぽの目で、皇帝をじっと見つめていました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お花たちは、はいってきませんし、音楽はあいかわらず美しく鳴りつづけています。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず、しあわせな気持でした。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまは、あいかわらずブンブンうなりながら、踊りまわりました。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、機の上には、あいかわらず、糸一本はられません。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりに、また、同かの、それ、みぎの、れいの、あいかわらず、歯をいたむなりけり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音次郎君は久助君といっしょになっても、あいかわらず拍手をつづけながら、じぶんひとりのつまらない考えを追って歩いていた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんはあいかわらず、壁の方に顔をむけてご飯をたべるのでありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず、海も見える、城も見える。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はあいかわらず急ぎ足で仕事に出ていきます。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬はあいかわらずそれをくわえてかえっていきました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカレンをだきかかえて、馬車のなかへいれましたが、足はあいかわらず踊りつづけていたので、カレンはやさしい奥さまの足を、いやというほどけりつけました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の上は、ひっそり人音もなくなりました、ただ、舵とりだけが、あいかわらず、舵をひかえて立っていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどむすこはあいかわらずお話をしながら、世界じゅうながれあるいていました、でも、マッチのお話のようなおもしろい話はもうつくれませんでした。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、鏡はあいかわらず、しかめっつらしながら、はげしくぶるぶるふるえだしたものですから、ついに悪魔どもの手から、地の上へおちて、何千万、何億万、というのではたりない、たいへんな数に、こまかくくだけて、とんでしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみの木は、あいかわらず、ふかいためいきのかわりに、パチ、パチいいながら、森のなかの、夏のまひるのことや、星がかがやいている、冬の夜半のことをおもっていました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず、対手さえありゃいがみ合うんだよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず女の出来ない精進男に、すじか、竹輪か、こってりとした処を食わせたい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黄肌鮪だか、鬢長鮪だかと一緒に、悪酒を、なめ、なめ、「あいかわらず、この体だ、といううちにも、一昨々年までは、台湾に一艘帆を揚げていたんだよ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――（あいかわらず腎臓が不可ませんでな。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は芝居も活動写真も、あいかわらず興行を続けていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
