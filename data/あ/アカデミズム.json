        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "エグジスタンシアリスムという言葉は、巴里では地下鉄の中でも流行語になっているということだが、日本では本屋の前に行列が作られるのは、老大家をかかえた岩波アカデミズム機関誌の発売日だけである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川幕府のアカデミアであった林氏の儒学とそのアカデミズムとは、全く幕府の権力に従属した一つの思想統制のシステムであった。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、昔の東大の「よき日よき大学」によきアカデミズムがあったのなら、どうしてケーベル博士は大学の教授控室の空気を全く避けとおしたということが起ったろう。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大学は、どのようなアカデミアであり、アカデミズムをもっているだろうか。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちの日本からは、正しい人民のアカデミアとアカデミズムが生まれてゆかなければならない。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミズムとジャーナリズムという対語も、この見方で行くと気に入らない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが長期建設策としてひとつの希望を述べるならば、それは民間アカデミズムというべきものを形成発展させることである。",
              "citation": {
                "source": "自己を中心に",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん官学的ないし講壇的アカデミズムのようなものではない。",
              "citation": {
                "source": "自己を中心に",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の文化史を見れば、民間アカデミズムは、たとえば徳川時代の儒者の間にも国学者の間にも存在したもので、それがかえってその時代の真のアカデミズムであった。",
              "citation": {
                "source": "自己を中心に",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日官学や講壇のアカデミズムの頽廃が見られるとき、民間アカデミズムの擡頭こそわが国の文化の発達にとって重要な意義を有するものではなかろうか。",
              "citation": {
                "source": "自己を中心に",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミズムに対してジャーナリズムには独自の意義があるように新刊書を読むということにもそれ自身の意義があるのである。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまた、アカデミズムを嫌い、一九七〇年代のアメリカ社会に対してある種の疑問を抱いていたのだろうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "真船氏の如きは、実にその先駆者の一人であることを自覚してゐていいので、僕などは、今日では、寧ろ、退いて、演劇のアカデミズム樹立に余生を献ずる決心をしてゐる。",
              "citation": {
                "source": "批評家・作家・劇場人",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換へれば、国家の文化的基礎を築き、その水準を常にある程度まで高めて行くといふ機能は、アカデミズム本来の使命である。",
              "citation": {
                "source": "わが演劇文化の水準",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあべこべが三木清で、この人の碁は、乱暴そのものゝ組み打ちみたいな喧嘩碁で、凡そアカデミズムと縁がない。",
              "citation": {
                "source": "文人囲碁会",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の演劇界の現状は、誰がなんといはうと、正しい意味でのアカデミズムの欠如が唯一の弱点であつた。",
              "citation": {
                "source": "演劇統制の重点",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のやうに演劇の歴史が云はば中断されてゐて、クラシックと近代的なものとの繋がりが非常にもろい国では、演劇に於けるアカデミズムの確立がともかく急務だと思ふ。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに今云つたやうな理想がピカデリーに或る程度実現されて、ピカデリーそのものとしてはまづわれわれが満足するやうなものができても、それはまだやつとアカデミズムの第一歩だと思ふ。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアカデミズムといふものがやがてハツキリ樹立されれば、その限界といふものをむろんもちながら、なほ且つ一般演劇界に与へる影響は大きく、そこでアカデミズム本来の役割を果してゆく。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒウザン会は、丁度その頃、新進気鋭の士の集合であり、当時洋画会の灰一色のアカデミズムにあきたらぬ連中の息抜き場であった。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリズムとアカデミズム。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリズムは、普通それが任意の視角からどう見られようと、イデオロギー論の問題として取り上げられるのでなければ、統一的に解明出来ないのであるが、之をイデオロギー論の視角から取り上げると、之に対立するものは是非ともアカデミズムでなければならない。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処でアカデミズムも亦、一方に於て、現在の大学や研究所というインスティチュートを生産し之によって又生産される処の、イデオロギーの現代に固有な歴史的一形態であると共に、他方に於て古来存在するイデオロギーの本質的な一契機でもなければならない＊。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のアカデミズムは欧洲の諸大学が宗教的束縛から実質的に脱却したことからその形態を決定されたのであるが、すでに他方ギリシア時代の昔からアカデミズムは存在した、例えばイオニア学派・ピュタゴラス学壇・プラトンのアカデミー等々。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今の場合、アカデミズムという範疇は主として大学を云い表わすと見ても不当ではない。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがジャーナリズムとアカデミズムとはどう対立するか。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
