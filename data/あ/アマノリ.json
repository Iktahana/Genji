          ],
          "literary": [
            {
              "text": "その間をくゞつて漁女等が、甘海苔を岩から掻き落してゐる。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷に下りて、あまのりや生ひたると尋ぬれば、あやまりてや見るらん、芹のみ茂りふしたり。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古郷の事、はるかに思ひ忘れて候ひつるに、今此のあまのりを見候て、よし無き心おもひでて憂くつらし。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたうみ、いちかは、小港の磯のほとりにて、昔見しあまのりなり。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔の毛氈かと見えるあまのりの床が、一箇所異様に乱れて、真珠の様に艶やかな水泡が、無数に立昇り、ひとみを凝せば、その水泡の立昇るあたりには、青白く滑かな一物が、比目魚の恰好で海底に吸いついているのです。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
