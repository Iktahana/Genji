        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日行在所について考えている。",
              "source": "幻辞"
            },
            {
              "text": "行在所という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は行在所の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には行在所が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "行在所を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは行在所について学習した。",
              "source": "幻辞"
            },
            {
              "text": "行在所の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は行在所の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では行在所が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "行在所という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に行在所という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では行在所についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "行在所を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると行在所は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "行在所について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では行在所が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に行在所は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により行在所の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "行在所は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に行在所は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こんなやり方は如何にも勝元らしく、爾来東軍は行在所守護の任に当って、官軍と呼ばれ、西軍は止むを得ず賊軍となった。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後醍醐天皇の行在所の黒木山へも参りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり天武天皇の行在所があったところかも知れない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはワサミかワサミに近い実際の前線指揮処だった行在所で、つまりその地点で天皇が大友皇子の首実検をしたところだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西｜筑摩の郡長、郡書記も出張して来て、行在所となるべき家は馬籠では旧本陣青山方と指定された。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島の行在所において木曾の産馬を御覧になったことなぞ聞き伝えて、その話を半蔵のところへ持って来るのは伏見屋の三郎と梅屋の益穂とであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵は裏の井戸ばたで水垢離を執り、からだを浄め終わって、神前にその日のことを告げた後、家の周囲を見て回ると、高さ一丈ばかりの木札に行在所と記したのが門前に建ててあり、青竹の垣も清げにめぐらしてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧本陣奥の間の風通しのよいところに横になって連れて来た女の子に乳房をふくませることも、先年東山道御巡幸のおりには馬籠｜行在所の御便殿にまで当てられた記念の上段の間の方まで母のお民と共に見て回ることも、お粂には久しぶりで味わう生家の気安さでないものはなかったようである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原家は酒造を業とするこの地の豪家で、曾て明治天皇の行在所であった由緒ある家であり、門前には聖蹟を顕彰する石柱が立っている。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで八月二十四日の夜、主上におかせられては勿体なくも、婦人車にお召しになられ、神剣、神璽を奉じたてまつり、ひそかに南都へご行幸あそばされ、ついで和束の鷲峯山へご行幸、ここも、危険とおぼしめされ、笠置の城へ入らせられ、ここを行在所とお定めあそばされた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば後醍醐天皇が一時｜行在所にお充てになった穴生の堀氏の館など、昔のままの建物の一部が現存するばかりでなく、子孫が今にその家に住んでいると云う。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉野朝廷はその本来の都と文化とから離れてかりの行在所を山岳の地に据えられたのであるから、どうしてもその政治行動の理想はその本来の都の奪回ということに向かなくてはならぬ。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、天皇以下、「――事成り難し」「ここも、安からねば」　と、即夜、ほかへ行在所を求めて、奈良を立ち出でて行ったことか。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれからともなく、「なんと、行在所の釈迦堂におわす天皇は、まことの後醍醐の君ではないぞ。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、その彼らまでが、離反の仲間に加わり、ここの行在所へ向って、遠くから鬱憤を言い哮ッているものにちがいない。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいか、ずいぶんなお疲れでもあろうに、雲清寺の行在所では、帝のおん眉は明るかった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯耆船上山の行在所――すなわち後醍醐のみかどのもとへ――ここの大戦捷を、上奏するための早馬だった。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
