    "definitions": [
      {
        "index": 1,
        "gloss": "temporary lodging built to accommodate an Imperial visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
