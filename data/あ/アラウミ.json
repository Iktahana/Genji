        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒海について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒海という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒海の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒海が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒海を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒海について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒海の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒海の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒海が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒海という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒海という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒海についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒海を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒海は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒海について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒海が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒海は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒海の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒海は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒海は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一例として「荒海や佐渡に横とう天の川」という句をとって考えてみる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれにとっては「荒海」は単に航海学教科書におけるごとき波高く舟行に危険なる海面ではない。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの荒海は一面においてはわれわれの眼前に展開する客観の荒海でもあると同時にまたわれわれの頭脳を通してあらゆる過去の日本人の心にまで広がり連なる主観の荒海でもあるのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大海に島もあらなくに海原のたゆとう波に立てる白雲」という万葉の歌に現われた「大海」の水はまた爾来千年の歳月を通してこの芭蕉翁の「荒海」とつながっているとも言われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん西洋にも荒海とほぼ同義の言葉はある。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面は、波のような丘陵の起伏と、そのさきの太平洋に面した荒海がある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時には銭屋五兵衛の抱で、年中千五百｜石積を家として、荒海を漕廻していた曲者なのだ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花片を憐るよ、蝶の翼で撫づるかと、はら／＼と絹の手巾、輕く拂つて、其の一｜輪の薔薇を抽くと、重いやうに手が撓つて、背を捻ぢさまに、衝と上へ、――坂の上へ、通りの端へ、――花の眞紅なのが、燃ゆる不知火、めらりと飛んで、其の荒海に漾ふ風情に、日向の大地に落ちたのである。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途すがら、遠州｜灘は、荒海も、颶風も、大雨も、真の暗夜の大暴風雨。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、事もおろかや如法の荒海、剩へ北國日和と、諺にさへ言ふのだから、浪はいつも穩かでない。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月　それ、おほみそかは大薩摩の、もの凄くも又可恐しき、荒海の暗闇のあやかしより、山寺の額の魍魎に至るまで、霙を錬つて氷を鑄つゝ、年の瀬に楯を支くと雖も、巖間の水は囁きて、川端の辻占に、春衣の梅を告ぐるぞかし。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――暗さはつきぬけに全都の暗夜に、荒海の如く續く、とも言はれよう。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、かいとかじとをうしなった小船が、荒海にもてあそばれるように、おかあさんは、悲しみにもてあそばれていました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海や佐渡に、と口ずさんだ芭蕉の傷心もわかるような気が致しましたが、あのじいさん案外ずるい人だから、宿で寝ころんで気楽に歌っていたのかも知れない。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬籠の窓が開いて、軒、廂の雪がこいが除れると、北風に轟々と鳴通した荒海の浪の響も、春風の音にかわって、梅、桜、椿、山吹、桃も李も一斉に開いて、女たちの眉、唇、裾八口の色も皆花のように、はらりと咲く。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が勇しき船頭は、波打際の崖をたよりに、お浪という、その美しき恋女房と、愛らしき乳児を残して、日ごとに、件の門の前なる細路へ、衝とその後姿、相対える猛獣の間に突立つよと見れば、直ちに海原に潜るよう、砂山を下りて浜に出て、たちまち荒海を漕ぎ分けて、飛ぶ鴎よりなお高く、見果てぬ雲に隠るるので。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其の凄じさと言つたら、まるで眞白な、冷い、粉の大波を泳ぐやうで、風は荒海に齊しく、ぐわう／＼と呻つて、地――と云つても五六｜尺積つた雪を、押搖つて狂ふのです。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都　いや、荒海を切って影を顕すのは暴風雨の折から。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海の磯端で、肩を合わせて一息した時、息苦しいほど蒸暑いのに、颯と風の通る音がして、思わず脊筋も悚然とした。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海の巌礁に棲み、鱗鋭く、面顰んで、鰭が硬い。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は低く灰汁を漲らして、蒼穹の奥、黒く流るる処、げに直顕せる飛行機の、一万里の荒海、八千里の曠野の五月闇を、一閃し、掠め去って、飛ぶに似て、似ぬものよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海の力と音とに對する爭が彼等の筋肉を強大にし、其音聲を太く、語調を暴くする。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里西に遠い荒海の上からも、望めば、仰げば、佇めば、みな空に、面影に立って見えるので、名に呼んで知られている。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海ながら、日和の穏かさに、渚の浪は白菊の花を敷流す……この友禅をうちかけて、雪国の町は薄霧を透して青白い。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その凄じさといったら、まるで真白な、冷い、粉の大波を泳ぐようで、風は荒海に斉しく、ごうごうと呻って、地――と云っても五六尺積った雪を、押揺って狂うのです。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二荒海の、荒海の潮の八百道の、八潮道の、潮の八百会に、ハレヤ、とどろ坐す速開津姫に、朝開、朝のみ霧の遠白に、末鎮み鎮まらせ、み眼すがすがと笑ませとぞ、きこしめせと申さくみ船謡。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二荒海の、荒海の潮の八百道の、八潮道の、潮の八百會に、ハレヤ、とどろ坐す速開津姫に、朝開、朝のみ霧の遠白に、末鎭み鎭まらせ、み眼すがすがと笑ませとぞ、きこしめせと申さくみ船謠。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤房の垂れて小暗き産屋かな君とわれ惜春の情なしとせずふたりづつ／＼行く春の塵五月二日　金沢あらうみ海会員大挙上京。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
