[
  {
    "uuid": "ac1a65fc-e8fb-5b9c-acd7-7ee284ad3035",
    "entry": "厚い",
    "reading": {
      "primary": "あつい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
