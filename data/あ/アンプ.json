    "definitions": [
      {
        "index": 1,
        "gloss": "amp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンプについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンプという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンプの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンプが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンプを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンプについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンプの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンプの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンプが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンプという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンプという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンプについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンプを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンプは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンプについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンプが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンプは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンプの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンプは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンプは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今より二十三年の昔出来たアンプリア号という当時での巨船に比較すれば実に非常の進歩である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし事情が許されるならば、女を抱き乍らシヨパンのアンプロンプチユを聴くことも自由である。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもアンプレショニストのそれの如く極めて柔かです。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、手紙よりも、木崎さん、一寸これ見て下さい」　細君が出しなにたたき割って行った買いだめの注射薬のアンプルのかけらを、坂野は見せ、土色の顔を一層土色にして、ふぬけていたが、やがてエヘッと笑うと、「印籠みたいなもンでさあ」　と、ポケットからヒロポンの箱を出して来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここン所坂野医院大繁昌だね」　坂野はにやりと木崎の顔を見ながら、ケースの中からヒロポンのアンプルを取り出し、アンプル・カッターを当てて廻すと、まるで千切り取るように二つに割った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、不健全なものへ、悪いと知りつつ、かえって惹きつけられて行くのがマニヤの自虐性であり、当然アンプルを割る音は頽廃の響きに濁る筈だのに、ふと真空の虚ろに澄んでいるのは、頽廃の倫理のようでもあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、芳子はわざとヒロポンにかこつけて、アンプルを割るという芝居までして、銀ちゃんのふところへ転がり込んで来たのだが、しかし、一つにはお腹の子供のこともあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと看護婦が帰って来たが、のろまな看護婦がアンプルを切ったり注射液を吸い上げたり、腕を消毒したりするのに手間取っているのを見ると、寺田は一代の苦痛を一秒でも早く和げてやりたさに、早く早くと自分も手伝ってやるのだった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田はあわててロンパンのアンプルを切って、注射器に吸い上げると、いつもの癖で針の先を上向けて、空気を外に出そうとしたが、何思ったのかふと手を停めると、じっと針の先を見つめていた。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて看護婦が強心剤のアンプルを切って、消毒もせずに一代の胸に突き刺そうとしたが、肉が固くてはいらなかった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれからは注射がもう趣味同然になって、注射液を買い漁る金だけは不思議に惜しいと思わず、寺田の鞄の中には素人にはめずらしい位さまざまなアンプルがはいっていたのだ。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の日本では、よほどの金持ちの子でもない限りアンプやドラムを手に入れるのは難しく、大きな音を出せば出すほど、練習場所にも苦労する事情もかかわっていたのかもしれません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンプはオレのギターを成層圏まですっとばしてくれるし、奇妙な電子音も面白けりゃそれでいい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンプをとおさない、ソリッド・ボディのエレキだから、ペラペラした情けない音色だが、それでも充分だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで、そんなことをしなくちゃならないんだ」「もうすぐ、ヴォーカル・アンプがくるはずだから、すこしはデカい音になるよ」「ならねえよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、ファズを貸してくれないか」　シールドのジャックをアンプに差しこみながら、広岡がいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンプがハムを起こし、すぐにいつものノイズにもどる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな音になるのかな」　慶一は、広岡からファズをとりもどして、アンプにつないだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに、アンプがいやな音をたてる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一さん、ちょっと、お話があるんです、だってよ」　服部が人間アンプとなって、令子のささやきを増幅した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい寮に移って、念願の最上階で練習できるようになり、慶一はアンプなしの練習が苦にならなくなった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
