        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安否について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安否という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安否の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安否が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安否を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安否について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安否の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安否の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安否が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安否という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安否という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安否についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安否を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安否は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安否について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安否が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安否は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安否の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安否は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安否は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（明治四十年十月三日『東京朝日新聞』）　　　　　　　　　十三　　　　　　霧中の汽車信号　鉄道線路の傍に巨人のごとく直立しあるいは片手あるいは両手を拡げて線路の安否を知らせる普通の信号標は、通常の天気ならば昼夜の別なく有効であるが、ただ霧が掛かって数歩の外は見え分かぬような日には何の役にも立たぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝山の麓――朝　お絹の安否を思って上って来る両親や村人達。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の安否にも関係する重大なことをあさっているのに、何ンにもならんことで茶化すんねえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民自身も今のようなスピード時代では到底百年後の子孫の安否まで考える暇がなさそうである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかりのついた、お附合の隣の窓から、岩さんの安否を聞かうとしでもしたのであらう。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれそれと小田原をやってる処へ、また竜川とかいう千破矢の家の家老が貴方、参ったんだそうで、御主人の安否は拙者がか何かで、昔取った杵柄だ、腕に覚えがありますから、こりゃ強うがす、覚悟をして石滝へ入ろうとすると、どうでございましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士は繰返してまた、「千破矢さんはどうしたんだ、」と、これは何心なく安否を聞いたのであったが、ふと夢の中の事に思い当った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、それと同時に、第一に吾等の胸を打つたのは、櫻木大佐等の乘込める海底戰鬪艇の安否である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』松島海軍大佐の端然たる顏色は微に動いて『では、貴君は、若しや我が娚日出雄少年の安否を――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大助は敵の我を忌むを識りて、小主公の安否｜心許なく、なお推返して言わんとするを、三郎は遮りて、「宜しい彼室で待ってな。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが今日は海老責に逢うことを牢屋附の下男の内報によって、牢内でも薄々承知していたので、ひそかにその安否を気配っていると、かれは問い落されもせず、責め殺されもせず、弱りながらも無事に帰って来たので、牢内の者どもは跳りあがって喜んだ。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、主人の行方も安否も判らぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩石に骨を砕かれて即座に命を隕したか、或は案外の軽傷で無事に生きているか、先ず其安否を確めねばならぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父の行方とお杉の安否とを探る為に、市郎は直ちに此の冒険を試みようと決心した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなるからは寧そのこと、どん底まで真直に降りて行って、彼のお杉の安否を確めた方が優かも知れぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が此の如き有様であるとすれば、其子の安否も甚だ心許ないものである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は驚きのあまり幸子の安否を見届けることもしないで、逃げ帰ったではないか。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛込の下宿から私の家の安否を気使うて来てくれた若い友達は、砲兵工廠が焼けていると言った。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もまた糧食を負ひ、茣蓙をかつぎ、削ぎ竹を杖にして、近親の安否を案じ、朋友の救援に赴く者も亦一つとして死線の険難に惑はざるはなかつた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民たちも、摂政宮殿下が御安全でいらせられるということは早く一日中に拝聞して、まず御安神申し上げましたが、日光の田母沢の御用邸に御滞在中の　両陛下の御安否が分りません。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、それとなく、じぶんの家内や子どもの安否を聞きさぐらうとしました。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「檀那は御機嫌好くてお出になるかい」と末造の安否を問うことだけは忘れない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへで　では、姉樣の安否も知れませぬか。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春彦　姉はさて措いて、上樣の御安否さへもまだ判らぬ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父単于がついに降服させることのできなかったこの不屈の漢使の存在を思出した狐鹿姑単于は、蘇武の安否を確かめるとともに、もし健在ならば今一度降服を勧告するよう、李陵に頼んだ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき彼は人を遣わして蘇武の安否を問わせ、食品、牛羊、絨氈を贈った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人の安否を問返す陵のよそよそしい言葉におっかぶせるようにして立政がふたたび言った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就の真意は、厳島へ我が大軍をひきつけ、安否の合戦して雌雄を決せんとの謀なるべし。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度信州の御働きは先年に超越し、御遺恨益々深かりければこの一戦に国家の安否をつけるべきなり云々」とあるから、謙信が覚悟のほども察すべきである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
