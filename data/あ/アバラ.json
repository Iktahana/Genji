        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "肋について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この肋は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "肋の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が肋について知っています。",
              "source": "幻辞"
            },
            {
              "text": "肋は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は肋の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "肋に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では肋が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から肋を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "肋の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも肋が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では肋が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "肋について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも肋は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも肋は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で肋は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に肋について学びました。",
              "source": "幻辞"
            },
            {
              "text": "肋の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する肋の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では肋の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "前二者が注射や服薬ならば、之は神経衰弱や軽微な肋膜の療養に似て、呑気にブラブラすることを要請してゐるのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "肋骨みな瘠せ軍鷄の如くに叫べるを聽く。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沢が、濶く、峡間に延びて、峡流の分岐したのが、幾筋となく蜿ねり、枯木が、踏み砕かれた、肋骨のようになって、何本も仆れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさま、この福慈岳は火を背骨に岩を肋骨に、砂を肉に附けていて少しの間も苦悩と美しさと成長の働をば休めない大修業底の山なのでございますわ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山一つさえその通り――「まだそのときのわたくしは、きしゃな細火を背骨にし、べよべよ撓るほどの溶岩を一重の肋骨として周りに持ち、島山の中央の断れ目から島地の上へ平たく膨れ上っただけの山でした」　世の中は、ただうとうとと、あま葛の甘さに感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から噴き流れて凝った血が、岩となって二枚目の肋骨としてまわりに張っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども自分の胸から噴き流れて凝った血は、三枚目の肋骨となって、まわりに張っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇って壊れた自分を観ると、そこにはまた第四の肋骨が出来上っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは只今、最初から数えて八枚目の肋骨まで出来ております。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい苦労は確にしたのだな」　それに凝りずに、娘はなおも苦労を迎えてそれを支えた成長の肋骨を増やす積りでいる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてる筈ぢゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一三年の春は肋膜を病んだ。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なれば、君の感情は恐怖の一刹那に於て、正しく君の肋骨の一本一本をも数へ得るほどの鋭さを持つてゐるからだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　戸外に彼女がでると、萎黄病のように燻んでしめった月が建物の肋骨にかかっていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸には肋骨が一つ一つ數へられた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "會社員の奧さんで肋膜がお惡い上に盲膓炎なんですつて。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて、そんな事をすると肋膜の方がねえ……」「そりやあ大變だ……」と、私は少し誇張した聲で云つた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫は、夫は、肋膜炎に罹つてゐますの。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらわな肋骨の辺には皮が擦り剥けて赤い血が泥ににじんでいるところがある。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肋膜炎、腎臓炎、胃かいよう、心臓弁膜不全症――内科と外科は別だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何も云わず、ぶくぶくした手が剣身を握りとめないうちに、剣は、肋骨の間にささって肺臓を突き通し背にまで出てしまった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてる筈じゃないか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前京都にいた頃は毎年のようにこの季節に肋膜を悪くしたのですが、此方へ来てからはそんなことはなくなりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正賓は肋を傷けられて卒倒し、一場は無茶苦茶になった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来正賓は近年逆境におり、かつまた不如意で、惜しい雲林さえ放そうとしていた位のところへ、廷珸の侮りに遭い、物は取上げられ、肋は傷けられたので、鬱悶苦痛一時に逼り、越夕して終に死んでしまった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、いわば安全弁のような役目をして気持ちよく折れてくれるので、その身代わりのおかげで肋骨その他のもっとだいじなものが救われるという話である。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸は貧弱で、肋骨が醜く浮いて見えているので、やはり病後のものと思われたにちがいない。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてるはずじゃないか」　大学士はあわてて走って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字どほりの、あばらやに住んでゐる。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに比べたら、たとえどんなあばら家でも、大空が見え、広野が見える室のほうが少なくも自由に呼吸する事だけはできるような気がする。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
