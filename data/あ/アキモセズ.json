        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "政江は再び同じことを飽きもせずに繰り返えすのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "太一は此を近來の役目のやうにして飽きもせずにやつて居る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎にも来る度他出中なりけれど、本意無げにも見えで急ぎ帰り、飽きもせずして通ひ来るなりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、飽きもせず彼等は私の部屋に碌々とし続けた。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは本郷三好坂だよ」「本郷六丁目も来ているぜ」「ふふん、浅草七軒町もいらあ」「おっと、最上の浪人もいらあ」「全くもってご精が出るな、とっ代え引っ代え飽きもせずに、やって来るのはいいとしても、時々ひどく乱暴するので、たいして有難い客ではないよ」「有難くないばかりかい、迷惑至極というものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう飽きもせずに降るの」と独り言のように言いながら、ふと思い出した体にて、吾が膝頭を丁々と平手をたてに切って敲く。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、それでもよく飽きもせずに、三日も四日も、寝てばかりいられたものだね。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方からは、その単調さと異様な鼓膜の震動とで神経も空想も麻痺するモウタアの響がプウ……と、飽きもせず、世間の不景気に拘りもせず一日鳴った。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでも四辺に満ちているのは暗い野蛮、卑猥、飽きもせず繰返されている喧騒とであったが、計らず「母なるヴォルガ」はその洋々とした流れの上で、ゴーリキイの生涯にとって実に意義深い「最初の教師」をひき会わせることになった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十を越した老夫人の対手をし、おもんはそこで三年の間、倦みも飽きもせず、解した毛糸を巻き暮した。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "章子自身それを心得てうわてに笑殺しているのであろうが、ひろ子は皆が寄ってたかって飽きもせずそれをアハアハ笑い倒しているのを見るといい気持がしなかった。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとは大島｜伯鶴というのが好きだとかで、飽きもせずに寄席の話ばかりしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、甲板に出て、寒い海の風に吹かれながら、いま眼の前｜遙に立つてゐる島を、飽きもせずに眺めてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は総監から下は巡査刑事に至るまで一人残らず旧式の拷問応用の見込捜索ばかりを、飽きもせずに繰り返していたものである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして木村は精力絶倫といふのか年寄のくせに飽きもせず私のからだを求めるけれども、私は肉体のよろこびを感じたことがなかつた。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ア、スチャチャンのチャン……」と、昨夜からの計算を、また飽きもせず繰り返してはしゃぎ立てると、タヌはいまいましそうな顔で、「君はずいぶんおたんちんね。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し秀子から見ると――慢性の愛に浸り込み、半日でも子供を抱き続けて飽きもせず、傍から大事そうに眺めて楽しんでいる、秀子から見ると、私の愛はでたらめな危険なものだと思われたかも知れない。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は、いつも金太郎さんの絵本を、きまって手に取り上げて、飽きもせずながめていました。",
              "citation": {
                "source": "春風の吹く町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "で彼は彼らの要求する事を飽きもせずに彼らにしてやった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段高い学府に籍を置いたという厳粛な感じに支配せられて燈下に膝を折って下読みにいそしむ事も多く、同時にまた松山の狭い天地を出て初めて大きな都に出たという満足の下にその千年前の旧都を飽きもせずに彷徨き廻る日も多かった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞は謹慎な見物の前に、既定のプログラム通り、単調で上品な手足の運動を飽きもせずに進行させて行った。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "千々子さまは、飽きもせずに、毎日、根気よく電話で誘いかける。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五といふ、脂の乘り切つた男盛りを、親讓りの金があり過ぎて、呉服太物問屋の商賣にも身が入らず、取卷末社を引つれて、江戸中の盛り場を、この十年間飽きもせずに押し廻つて居る典型的なお大盡です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五という、脂の乗り切った男盛りを、親譲りの金がありすぎて、呉服太物問屋の商売にも身が入らず、取巻末社を引きつれて、江戸中の盛り場を、この十年間飽きもせずに押し廻っている典型的なお大尽です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笑い茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからまあ、選挙などというものが、飽きもせず亢奮的な訳でしょうがね。",
              "citation": {
                "source": "火のついた踵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、ほっと呼吸をついて、飽きもせずうっとりとその人形を眺めやった。",
              "citation": {
                "source": "菊",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはそこに横になって、視野いっぱいの青空をバックに、大きな波が打ちつけるたびに立つ飛沫の幕、その飛沫にかかる小さな虹の脚を、飽きもせずぼんやりとながめていた。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日、彼は飽きもせず彼女の話を聞き、彼女に見惚れつづけた。",
              "citation": {
                "source": "メリイ・クリスマス",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、さっそく、これからおはじきを始めるからね」　そういうと、ほんとうにお糸坊を相手にしながら、もうぱちぱちとおはじきをやりだしたもので、しかもなにがそんなにおもしろいものか、あきもせずに夕がた近くまで同じことを繰り返し繰り返しやっていたものでしたから、伝六がとうとうお株を始めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ八つの子供から七十近い爺さん婆さんまで、「そろそろまた本読みさ行くか」と、やって来る人々に向って、いつも一人の人間、つるの曲った眼鏡の先生が、あきもせず、いろんな詩、小説、戯曲をよんできかせてやる。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
