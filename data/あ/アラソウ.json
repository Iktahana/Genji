[
  {
    "uuid": "97704d8d-6fd5-52b9-affa-b1f97726f110",
    "entry": "争う",
    "reading": {
      "primary": "あらそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
      "ctype": null,
