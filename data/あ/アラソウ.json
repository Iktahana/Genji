    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to compete",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日争うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "争うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は争うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には争うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "争うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは争うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "争うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は争うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では争うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "争うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に争うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では争うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "争うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると争うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "争うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では争うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に争うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により争うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "争うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に争うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った朝は来た、朝がいかなる方面から、いかに忍び足に寄って来て、一秒ずつ額を白くしたかは徹夜凝視しても解らない、夜と朝の筋目が判然と目立つほどなら、地球の緯度線が草鞋の爪先に引っかかるわけである、しかも争う可らざるは朝の神秘なり、一たび臨むとき、木偶には魂を、大理石には血を与る。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年大西洋航路などでは速力の増すとともに賃金も著しく上がったが、それにもかかわらず争うて快速力の船を選ぶ有様だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦の比率を争うのも緊要であろうが、科学戦に対する国防がこの状況では心細くはないか。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶なことを云われて民子は心配やら嬉しいやら、嬉しいやら心配やら、心配と嬉しいとが胸の中で、ごったになって争うたけれど、とうとう嬉しい方が勝を占めて終った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の麩を争う池の鯉の跳躍への憧憬がラグビー戦の観客を吸い寄せる原動力となるであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の電話申込人等はそんな事とは知らず、待てども待てども順番が来ぬ、殊にパリの銀行家など一刻を争う経済上の交渉をひかえているので気は気でない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、恋を争う者なんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類相争う限り、彼らはまだ、その真の自由を得ていないという意味を示してみたいものである。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新星はかなり天頂に近く白鳥座の一番大きな二等星と光を争うほどに輝きまたたいているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、近所の人と争うことも出来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもし霊魂なるものが肉体へ突然入り込んで来るものであるとすると、一人の子供がまさに出産しようとする際には、いくつもの霊魂が産婦の枕もとに詰めかけて、おれがおれがと争うであろうと言っているのは読者をしておのずから破顔微笑させるものがある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、先を争うて押し合う心理も昇降機の場合にはたいした恐ろしい結果は生じない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようなただ一日を争う競争はまたジャーナリズムの不正確不真実を助長させるに有効であることもよく知られた事実である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪雨の一夜、郊外の泥道、這うようにして荻窪の郵便局へたどりついて一刻争う電報たのんだところ、いまはすでに時間外、規定の時を七分すぎて居ります。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い争うような声が聞えたので眼を覚まし、窓の方を見ると、佐吉さんは長い梯子を屋根に立てかけ、その梯子の下でお母さんと美しい言い争いをして居たのでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞や雑誌は争うて彼女の写真や、言葉や、文章を載せた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には内国の政治経済産業方面に関する記事でも、大多数の国民が一日を争うて知らなければならないものがどのくらいのパーセントを占めているかを考えてみなければならない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた、いま争うときでないと考えて山羊の方を見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番｜年長の娘は、直ぐに夫れを父伯爵の手から借りて見て、「まあ何んと云う綺麗な腕環でしょう、之れは屹度伯父様から、妾に贈って下さったのですよ」と云えば、二番目の娘は横合から覗込んで、「いいえ、伯父様と妾と大の仲好しですもの、妾に贈って下さったに相違はありません」と争う。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番目の娘は其名を露子と云う、三人の中でも一番美しく、日頃から極く温順な少女なので、此時も決して争う様な事はせず、黙って腕環を眺めて居る。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合にいつも先陣を争う髯将軍はいかにせしぞと後に聴けば、将軍、剛力の遅々が癪に触って堪らず、暫時叱※督励していた為に、思わず大いに遅れたという事だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円は奥に、上り口に晃、お百合、と互に楯にならんと争う。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて町はずれの狭く急なる曲がりかどを争うと見えたりしが、人力車は無二無三に突進して、ついに一歩を抽きけり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、一月や二月を争うこともありますまい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に忽ち掴み合が始まった、上になり下になり、互に転げて挑み争う中に、何方が先に足を滑らしたか知らず、二人は固く引組んだままで、傍の深い谷へ転げ墜ちた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実味と真実味とを区分したり、人生味と自然味と優劣を争うたりする境地を脱していない。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が周章ててそれを奪い取ろうとして争うはずみに引金がひけてしまう。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、もともと所有慾というものは薄く、また、たまに幽かに惜しむ気持はあっても、その所有権を敢然と主張し、人と争うほどの気力が無いのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其限りがあるうちで人の眼につく様に此趣味を出すと云えば作者の嗜好は判然として争うべき余地はない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
