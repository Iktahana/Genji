[
  {
    "uuid": "dfd85171-994d-5f1b-aa14-bee40099efac",
    "entry": "相知る",
    "reading": {
      "primary": "あいしる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to know each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相知るは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相知るが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相知るに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相知るが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相知るについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相知るについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相知るについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相知るが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相知るが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相知るは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相知るは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相知るを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相知るをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相知るが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相知るの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相知るを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相知るに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相知るについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相知るは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相知るを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分について言へば、自分は彼の多數の友人――實に彼は多數の友人と交つてゐた――の一人であり、しかも交情日尚淺く、相知ることの最もすくない仲であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前世因縁値遇だか何だかは知らぬが、此頃寂照は丁謂と相知るに至った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "』かくして彼金子鋭吉と自分とは相知るに至つたのである。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜、身に誤りのなき事は後日に相知るゝ御事なり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日に相知るゝ御事、又御枕のうち身の曇り去るとは處女膜が彼の御ン事に御寵愛の其夕べまで嚴存せしを指たのだ）。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人はレスパネエ夫人及その娘と相知ること三年に及べり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛長とは、相知る仲なれば、不足の賃金の二倍を借りて、それで汽車賃をすましぬ。",
              "citation": {
                "source": "親子遠足の感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "此町には大分前に死んだ田中千里君の邸宅があり、其の父は県立病院の最初の院長で、私も大名屋敷のやうな其の家へ遊びに行つた覚えがあるが、千里君も鏡花君とは竹馬の友だつたといふのに、私と泉君とは遂に相知る機会がなかつた。",
              "citation": {
                "source": "亡鏡花君を語る",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椿岳国の第一の名産たる画はどんな作である乎、先年の椿岳展覧会は一部の好事家間に計画されたので、平生相知る間を集めて展観したのだから、この展覧会で椿岳の画の全部を知る事は出来なかったが、ほぼその画風を窺う事は出来た。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、「エイ、エイッ」と馬丁の掛聲勇ましき黒塗馬車の公道を嫌つて、常に人生の横町許り彷徨いて居る朱雲がかゝる男と相知るの必ずしも不合理でない事もうなづかれる。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、「エイ、エイツ」と馬丁の掛声勇ましき黒塗馬車の公道を嫌つて、常に人生の横町許り彷徨いて居る朱雲がかゝる男と相知るの必ずしも不合理でない事もうなづかれる。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は正当の新婦と相知る場合にも、人は大抵皆然うだと云う。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女相知るのを怕ろしいとも恥かしいとも思わなくなるのか？",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼れに嘲罵されて憤懣してゐた硯友社其他の作家連が、彼れと相知るに及んで、ます／＼彼れを毛虫扱ひにして、其訪問を忌避したのも一理ある。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いも寄らぬ偶然な事から一人の男と相知るに到って自分の性情は不思議なほど激変した。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は令兄の文吉さんを知つてゐるが、今また令弟と相知る機会を得たのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "満鉄の図書館を訪うて松崎鶴雄先生と相知る喜びをも得た。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条御息所は皇太子の死後、十分な門地財産を持って六条に住んでいる時に、源氏と相知る事になる。",
              "citation": {
                "source": "反省の文学源氏物語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は見知らない一人の人（それは肉体をさへ具へない数字のやうなものであるのに――）それも永遠に相知ることは不可能である一人の人を対象として、詩を残したり、その存在を記念したい欲望にかられたりする。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて根津七軒町の富本の師匠｜豊志賀と相知るのである（これが宗悦の娘であることはすでに述べた）。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先生田葵山｜書肆大学館と相知る。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうこの先輩は最初水戸の学問からはいったが、暮田正香と相知るようになってから吉川流の神道と儒学を捨て、純粋な古学に突進した熱心家であるばかりでなく、篤胤の武学本論を読んで武技の必要をも感じ、一刀流の剣法を習得したという肌合の人である。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ嘉永の四年には、本木昌造も既にこれをつくり出してゐるが、長崎と江戸と距てては相知るところがなかつたであらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こうして一つ家の老媼と相知ることができ、永い間頭にあった一つ家というものを知ることができました。",
              "citation": {
                "source": "玉章",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上剣花坊、近藤京魚、伊上凡骨、川上三太郎氏らと相知る。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　兄弟相知る　もっとも、イワンが陣取っていたのは別室ではなかった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩は君と相知ること深かりしにはあらねどまた因縁浅しということを得ない。",
              "citation": {
                "source": "新島先生を憶う",
                "author": "二十回忌に際して",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて大和の柳生石舟斎とは、面識はないが、沢庵を通じて相知る仲である。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "死――というもの、相知る人間同士の別れというようなものなどが――この寂かな昼の大気につつまれた頭の中でしいんと考える対象になる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
