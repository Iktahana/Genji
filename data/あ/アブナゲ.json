        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "危なげについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この危なげは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "危なげの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が危なげについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "危なげは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は危なげの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "危なげに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では危なげが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から危なげを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "危なげの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも危なげが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では危なげが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "危なげについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも危なげは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも危なげは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で危なげは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に危なげについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "危なげの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する危なげの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では危なげの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二人は其の上の橋の、危なげに丸太を結つた欄干に背を靠せて列んだ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにかしてやらなければどんなになるか解らないように危なげに見えた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、日々時々繰り返し、繰り返して、これを重ねる時には、少しずつ、少しずつ、思うようになり始めて、六・七メートルの間、十・二十メートル程は、危なげながらも漕げるようになる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの兄弟子たちは　見あげるやうな恐ろしい高さを　どうして危なげもなく　上手に渡れるんだらうね。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその次のレースの本命が若しも根拠に乏しく、危なげなものだとしか考察出来なければ兎も角、それが確実な本命であると信ずるならば、これは買うべきレースである。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十あはれ、さはうち鄙びたるいはけなき玉乘の子が危なげに足にあはせて、かすかにも彈き鳴らす※オロン彈きの少女。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "円筒形にランプ室の周囲を取り巻いた大きなガラス窓の、暗黒の外海に面したほうには、大きな穴があき、蜘蛛の巣のようなひびが八方にひろがり、その穴から冷たい海風がサッとガスを吹き込むと、危なげな蝋燭の火がジジッと焦立つ。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの橋は、ブランコのやうにゆれるので、提灯の足どりが危なげね。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、彼の後から來る青年に向つては、ならうことならやはり危なげのない世間の道を行くことをすすめたい。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を乗せてくれた馬は、ひどく温順な馬でして、馬上初めての私も、何の危なげもなく悠然と乗っていたわけです。",
              "citation": {
                "source": "山の湯の旅",
                "author": "――発甫温泉のおもいで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は危なげな足もとで別室に連れ立って行った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはと、折竹の命にしたがった二人が危なげに浮き木をわたり、最終点の「五本の大蕨」へきた。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、そうして出来た自然草の橋のうえを、二人が危なげに渡っていたのである。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け野原のなかで詳しい情報は知る由もなく、私は危なげな腕前で自転車を走らせねばならなかった。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生さんは何か悲しいことでもあると、その悲しみそのものを樂しまれようとする――さういふ二つの相反した感情が絶えず室生さんの心のなかでは微妙な均衡をすこしも危なげなしに得てゐる。",
              "citation": {
                "source": "「文藝林泉」讀後",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元は危なげにふらついていたが、どかりと元の席に腰を下す拍子に、ビール瓶を卓子の上に立てた。",
              "citation": {
                "source": "在学理由",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　新女帝の治世の始めは、まだ存命の父母に見まもられて、危なげはなかつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "危なげのない、調和のとれた、澄みきつた、美しい姿なのであります。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは最初のところは、奥多摩の地理や生活ぶりが書いてあるので、そこに生れた作者にとっては、何の造作もない、まことに危なげのないところでゆける。",
              "citation": {
                "source": "中里介山の『大菩薩峠』",
                "author": "三田村鳶魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味に於て、小説界が田山花袋の「蒲団」を問題視したと同様に、劇文壇は、中村吉蔵の「剃刀」（大正三年、芸術座上演）に対して、「出るべきものが出た」といふ声を放つたのであるが、そこにはまだ北欧の濃霧のなかを、手さぐりで歩いてゐる東洋の作者の危なげな足どりがみられた。",
              "citation": {
                "source": "二つの戯曲時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的感覚の柔軟な操作、驚くべき技法の成熟ぶりによつて、忽ち「危なげのない」新進作家として迎へられはしたが、森本薫は単にそれだけの作家ではない。",
              "citation": {
                "source": "二つの戯曲時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼等の芸道では、彼等が現実に示したやうな多才ぶりや危なげのなさに比べると、要するにそれ以上ではありません。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げるにかけては、危なげというものがない。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は掃いてあるところもあり、掃いてないところもあるから歩きづらい中を、蛇の目の傘を傾げて、足許危なげにこっちへ歩んで来るのは女でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまるで曲乗りのような具合に、横の方から片脚を差入れ、右足だけでペダルを踏み、それでも危なげなく吹っとばして行った。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし浴衣をうまく着る、つまり本来のこの服装の美感に添うて正当に――とは実は平凡に、着る場合には、日本の夏裳束は危なげでゐながら、然も決して危なくないものである。",
              "citation": {
                "source": "浴衣",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎし世の智慧といふもの何の益かある、　授くるものは梭櫚の葉の　危なげも無い勝利のみ。",
              "citation": {
                "source": "不可能",
                "author": "L'IMPOSSIBLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中にわれ文章をつづらんにもの懶くあぢはひ悲しければけふもヒツポドロムを見にきたりつ、そのなかに空わたりするマテニと云へる露西亜のをんなのありき、肥えたるからだに肌衣を着け露き出しの手と足とをもておのれ空中を泳ぎまはりせん方もなく危なげに悲しくぞ見ゆ。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人の踊りは見ていてちっともあぶなげがない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しのあぶなげもない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
