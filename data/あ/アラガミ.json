    },
    "definitions": [
      {
        "index": 1,
        "gloss": "powerful deity (sometimes impetuous)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒神について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒神という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒神の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒神が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒神を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒神について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒神の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒神の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒神が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒神という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒神という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒神についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒神を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒神は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒神について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒神が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒神は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒神の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒神は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒神は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "外にも壊れかかった石祠がある、中には神体代りの小鉄板が、※びて腐蝕しながらも、奉納白根大日如来寛政七年乙卯六月と読まれた、白峰赤石両山脈の頂で、山の荒神たちと離れられない関係があるらしい、鉄の槍身が、赤｜錆びになって仆れていた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神橋の方に遠心乾燥器が草原に転っていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川水は荒神橋の下手で簾のようになって落ちている。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神橋には自転車が通り、パラソルや馬力が動いていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の外には人気勢して、くすくす笑い、三太夫は大粒の涙ほろほろ、刀をからりと投棄てて、「切った割に血の出ぬは、むむ、今日は血を流すと、荒神様が祟る日だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ、荒神様がついてござる、猿智慧だね、打棄っておかっせえまし。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と弥次郎｜眼を※って、「や、平家以来の謀叛、其許の発議は珍らしい、二方荒神鞍なしで、真中へ乗りやしょう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は品川荒神の秋季大祭とかいうので、品川の町から高輪へかけて往来が劇しい。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神様へ詣るもよい。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先方にも荒神様が付いてゐない訳では無くて、チャント隠し印のあることには気が付かなかつたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿夫利神社神璽の印をおした紙、南無普賢大荒神守、火不能燒、水不能漂、とかいた護符などが散らばつて居た。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "残らず、一度は神仏の目の前で燃え輝いたのでございましょう、……中には、口にするのも憚る、荒神も少くはありません。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "げっそりと痩せて青ざめた顔に、落ちつきのない表情を泛べ乍ら、「あのう、一寸おたずねしますが、荒神口はこの駅でしょうか」「はあ――？",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここは荒神口でしょうか」「いや、清荒神です、ここは」　新吉は鈍い電燈に照らされた駅名を指さした。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、荒神口に御親戚かお知り合いがあるわけですね」「ところが、全然心当りがないんです。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神口なんて一度も聴いたことがないんです」「しかし、おかしいですね。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神口に心当りがあれば、たぶんそこで待っておられるわけでしょうが、そうでないとすれば、駅で待っておられるんでしょうね。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしスグコイといったって、この頃の電報は当てにならないし、待ち合わす時間が書いてないし、電報を受け取られたあなたが、すぐ駈けつけて行かれるにしても、荒神口というところへ着かれるのが何時になるか、全然見当がつかないでしょう。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、普通の女ならさっさと帰ってしまうだろうに、いつまでも清荒神の駅に佇んでいる女の気持も、従順とか無智とかいうよりも、何か思いつめた一途さだった。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後、新吉が清荒神の駅に降り立つと、さっきの女はやはりきょとんとした眼をして、化石したように動かずさっきと同じ場所に坐っていた。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒神口の方へ道を折れて行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登では、産婦のまだ七十五日を過ぎないものを、（あの姉さんは、まだ小屋の中、）と言う習慣のあるくらい、黒島の赤神は赤神様と申して荒神で、厳く不浄を嫌わるる。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまではなくても、浦浜一体にその荒神を恐れました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いのを着た姿は、前門の虎に対して、荒神様の御前立かと頼母しく見えたので。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても斯うしちゃあいられないのか」「随分いろいろに趣向もして見たけれど、向うに荒神様が付いているんでね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる晩は宇都宮に着いたが、その翌日も午すぎまでここに逗留して、伝兵衛は澹山を案内して二荒神社などに参詣した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は荒神に最愛のものを生牲として願いをきいてもらおうとする太古の人のような必死な心になっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしはかるだに、その性の恐しときく荒神も御気色いとゞ麗はしく在すが如くおもほえて、御手にはわれが心の臓、御腕には貴やかにあえかの君の寝姿を、衣うちかけて、かい抱き、やをら動かし、交睫の醒めたるほどに心の臓、さゝげ進むれば、かの君も恐る恐るに聞しけり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
