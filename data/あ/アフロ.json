    "definitions": [
      {
        "index": 1,
        "gloss": "Afro (hairstyle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフロについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアフロは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アフロの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアフロについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アフロは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアフロの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アフロに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアフロが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアフロを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アフロの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアフロが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアフロが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アフロについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアフロは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアフロは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアフロは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアフロについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アフロの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアフロの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアフロの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私たちはその溜り水から堰をこしらえて滝にしたり発電処のまねをこしらえたり、ここはオーバアフロウだの何の永いこと遊びました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマやナポリでアフロディテの大理石像の観照に耽った時とまるで同じような気持である。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のしぶきのなかからは、あちらからもこちらからも、薄羽かげらふがアフロデイツトのやうに生れて来て、渓の空をめがけて舞ひ上つてゆくのが見えた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のしぶきのなかからは、あちらからもこちらからも、薄羽かげろうがアフロディットのように生まれて来て、溪の空をめがけて舞い上がってゆくのが見えた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはその溜り水から堰をこしらへて滝にしたり発電処のまねをこしらへたり、こゝはオーバアフロウだの何の永いこと遊びました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに天のアフロバイテを讃える恋の勝負は造化主の意思の外にあるのであろう。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處か、此の晴れ渡つた空の下で、薔薇色の泡からアフロディテが生れかかつてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か、この晴れ渡った空の下で、薔薇色の泡からアフロディテが生れかかっている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大理石もて刻めるアフロヂテの神か。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "能くアフロヂテを作りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツジヨは海を指ざしてかゝる青く波立てる大面積は羅馬の無き所なり、おほよそ地上の美なるもの海に若くはなかるべし、宜なり海はアフロヂテの母にしてと云ひさし、少し笑ひて、又ヱネチア歴代の大統領の未亡人なりといへり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「君のまだ見ない絵がもう一つある」そして一枚の被覆をさっと取り除けると、彼は侯爵夫人アフロディーテの全身像を現わした。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おお、お美しい、――お美しいアフロディーテさまが！",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故トルーフルがかく尊ばるるかというに、相も変らず古今を通じて浮世は色と酒で、この品殊に精力を増すから、旧く嬌女神アフロジテの好物と崇められ諸国王者の珍羞たり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アペルレースの諸画中もっとも讃えられたは嬌女神アフロジテーが海より現じた処で、その髪より搾り落す水滴が銀色の軽羅様にその体に掛かる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運のアフロディテ水沫から生れたアフロディテ！",
              "citation": {
                "source": "海辺小曲（一九二三年二月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら生得の痴愚にあき人生の疲れを予感した末世の女人にはお身の歓びは　分ち与えられないのだろうか真珠母の船にのりアポロンの前駆で生を双手に迎えた幸運のアフロディテ　　　　　＊ああ、劇しい嵐。",
              "citation": {
                "source": "海辺小曲（一九二三年二月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアフロヂテの泡と呼ばれている、阿剌比亜の香水のはいった石鹸を丁寧に塗りながら、……皇帝の朝の化粧は終りに近づいた。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして香料に関しての諸般の知識は美の神アフロディーテの使ひ女エオーネの無分別から人間界に過つて伝へられたと云はれて居る。",
              "citation": {
                "source": "希臘及び羅馬と香料",
                "author": "加福均三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、巌壁の外で、大衆が、神集いにつどい、大論争をし、ついに、衆議一決、天鈿女の命というアフロディテをして、ほとも露わに、ストリップの大騒ぎをすることにするのである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "※私は御身を信じます、聖なる母よ、海のアフロヂテよ！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフロディーテは其名の示すが如く、海水の泡沫より、生れ出でし女神にして、潮水の生殖力の人格化たること明なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此林檎には、「最も美しき者へ」との文字書かれしによりて、忽ち天神ヘラ、正善の神パラス、アテーネ、恋愛の神アフロディーテ三女神の間に、何れか之を得可きやに関して、一場の争論を生じたり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アテーネは戦陣の名誉を与えんと云い、アフロディーテは、世界絶無の美婦を与えんと云いしが、パリスは直ちに裁决を下して、恋愛の女神は林檎を得たり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日月流るるが如く、暫くはパリスの生涯に、何等の変化も無かりしが、かの女神アフロディーテの約言は、間もなく実行さるることとなりぬ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "メネラオスと其兄弟との不在は、遂に多くの財宝と共に、ヘレナを奪うの機会を与え、アフロディーテの助によりて、パリスは安全に帰国するを得たり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校の二年生の冬、彼女は兄が贈つて呉れた希臘神話を読んだが、そのなかでアフロデイテが海の泡から生れたといふ話が大そう彼女の気に入つてしまつた。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼女の肢体はまだ決して、彼女の大好きなボッチチェルリのアフロデイテではなかつたけれど、それは行く行くはその豊麗な完成にまで約束されてゐる、ごく稀な型に属してゐたのである。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸復興期のマドンナは豊かな肉体と優美な顔とをもって描かれているが、しかしそこには、美の権化としてのアフロディテの表現の上に、さらに永遠の処女としての侵し難い清らかさ、救世主の母としての無限の慈愛を現わそうとする努力があり、またあるものはそれを現わし得ている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
