        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日余るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "余るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は余るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には余るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "余るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは余るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "余るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は余るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では余るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "余るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に余るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では余るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "余るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると余るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "余るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では余るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に余るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により余るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "余るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に余るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "斯くの如き場合の斯くの如き誤解は、実に局外者の想像に余るものだといふことは、どれ程云つても云ひ足りはしないだらう。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の顔を斜に見た処で、無論少年の手には余る画題であるのを、自分はこの一挙に由て是非志村に打勝うという意気込だから一生懸命、学校から宅に帰ると一室に籠って書く、手本を本にして生意気にも実物の写生を試み、幸い自分の宅から一丁ばかり離れた桑園の中に借馬屋があるので、幾度となく其処の厩に通った。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "背には綿の厚い、ふっくりした、竪縞のちゃんちゃんを着た、鬱金木綿の裏が見えて襟脚が雪のよう、艶気のない、赤熊のような、ばさばさした、余るほどあるのを天神に結って、浅黄の角絞の手絡を弛う大きくかけたが、病気であろう、弱々とした後姿。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吃驚して、取つて、すつと上へ引くと、引かれた友染は、其のまゝ、仰向けに、襟の白さを蔽ひ余るやうに、がつくりと席に寝た。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖と袖と重ねたのは、二側に居余る、いづれも声なき紳士淑女であつた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊さへなくば夏の夕の月あかき時なんどは、特に川中に一杯を酌みて袂に余る涼風に快なる哉を叫ぶべき価ある処なりといふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何家の老人も同じ事で、親父はその老成の大事取りの心から、かつはあり余る親切の気味から、まだまだ位に思っていた事であろう、依然として金八の背後に立って保護していた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人薄命といふ語さへあつて、美しい為に不利を亨けた例は歴史にも伝説にも余るほどあります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの大嵐には黒い波が一町に余る浜を打上がって松原の根を洗うた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを基礎としてそれから二等三等三角網が張り渡され、それを目標として局部局部の地形測量を仕上げられるまでのいきさつは、およそ素人の想像に余るものであろう。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その時、十一歳であった私と、七ツになったばかりのアヤ子と二人のために、余るほどの豊饒な食物が、みちみちておりました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築が設計者製図者を始めとしてあらゆる種類の工人の手を借りてできあがるように、一つの映画ができあがるまでには実に門外漢の想像に余るような、たくさんの人々の分業的な労働を要するのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結極余るところが借金を残す位ゐのもので、何うにも仕様がないのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海も空も澄み過ぎて、薄靄の風情も妙に余る。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは銀色の蒼く光るものあり、また銅の錆たるものあり、両手に抱えて余るほどな品は、一個も見えないが、水晶の彫刻物、宝玉の飾、錦の切、雛、香炉の類から、印のごときもの数えても尽されず、並べてあった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼は立去りあえず頭を垂れたが、つと擬宝珠のついた、一抱に余る古びた橋の欄干に目をつけて、嫣然として、振返って、「ちょいと滝さん、見せるものがある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おい、おいらも、まさかこれほどとは思わなかったが、随分手に余る上に、ものは食わずよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旬日に余る旅、しかも多く人の難とする険所をのみ選みし行なれば、旅中の珍談奇談山のごとし。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "）黙って金箱から、ずらりと掴出して渡すのが、掌が大きく、慈愛が余るから、……痩ぎすで華奢なお桂ちゃんの片手では受切れない、両の掌に積んで、銀貨の小粒なのは指からざらざらと溢れたと言う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一｜皿の菓子、一｜盞の珈琲に、一円、二円と擲ちて、なおも冥加に余るとなし、我も我もと、入交り、立替る、随喜の輩数うるに勝うべからず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は居余るのだから、端近を求むるにたよりは可い。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪なす羅、水色の地に紅の焔を染めたる襲衣、黒漆に銀泥、鱗の帯、下締なし、裳をすらりと、黒髪長く、丈に余る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――沖からこの辺の浦を一目に眺めますと、弁天島に尾を曳いて、二里三里に余る大竜が一条、白浪の鱗、青い巌の膚を横えたように見える、鷲頭山を冠にして、多比の、就中入窪んだあたりは、腕を張って竜が、爪に珠を掴んだ形だと言います。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬波に翻える状に、背尾を刎ねた、皿に余る尺ばかりな塩焼は、まったく美味である。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに三抱に余る山桜の遠山桜とて有名なるがござ候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、美しい、柔軟な、艶の可い髪は見た事がないってね、――死骸を病院から引取る時も、こう横に抱いて、看護婦が二人で担架へ移そうとすると、背中から、ずッとかかって、裾よりか長うござんしたって……ほんとうに丈にも余るというんだわね。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方の冬木立は赤裸になった今日｜此頃でも、樅の林のみは常磐の緑を誇って、一丈に余る高い梢は灰色の空を凌いで矗々と聳えていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "余一郎までがなぜ出て行ったか判りませんが、お角さんを遠いところへ連れて行くのに、一人ではちっと手に余るので、その加勢に行ったのかも知れません。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは轡川の眼に余るほどだとぼくは思ったが、しかし轡川は平然としていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り余るほど買溜めしていてもそうなのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
