        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀号は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀号が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀号に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀号が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀号について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀号についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀号について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀号が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀号が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀号は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀号は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀号を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀号をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀号が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀号の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀号を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀号に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀号について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀号は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀号を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "四月二十九日の午前二時、士民の哀号の声の中を西大門を出たのである。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "打てば血が流れ、その哀号の声はあたりの森に木谺して、凄惨実に譬えようもなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀号、哀号、と叫び立てる声がやがて、うおーッうおーッというような声に変って行く。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らがひざまずいて祈りはじめ哀号しはじめると、皇帝ニコライは慈愛深い父たる挨拶として無警告の一斉射撃を命じた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "回天の事業、独力を奈何せん……と人知れず哀号を唱えているところへ又、天なる哉、命なる哉と来た。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、金椎が立去ったあとで、哀号の声がしきりに起りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その哀号を遠音に聞きながら、駒井甚三郎は人間の本能性の底の知れない不検束というものを、両様に感じないわけにはゆきません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御当人はああして哀号することによって、気分が改悔の誠意を見せているつもりか知らん、同時に同情の念を呼び起そうとつとめているのか知らん、見ている周囲にとっては、いよいよ滑稽と、侮蔑とがあるのみだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「与八さん、七という字は、ドッチへ曲げるだっけかなア」　横に一本書いて、縦から書き卸してみたが、途中まで来て、どっちへ曲げていいかわからない、そこで行先をたずねて哀号する子供がある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいよいよその死屍を八つ裂きにするだんになって、刑吏がこれに一太刀斬りつけると、たちまちに哀号と叫喚とがむらがり起った。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀号泣訴、「恐ろしや、恐ろしや。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船も装備もみな失い、あげくに、指揮者黄安も賊に生け捕られ、散々なていで済州へ逃げ帰った官兵は、ただ事の顛末を奉行所の門へ哀号し合うだけだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さては、責任を問われるのか」　と、旧奉行は青くなって萎れたが、新任の奉行もまた、門前の哀号を耳にして、「なんと。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこうごくな、引ッとらえて火あぶりの極刑に処してくれん」　秦明は仰天して、上へ哀号した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は哀号して命乞いの必死をみせた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちに喪を発し、泊中の者は頭巾に喪章をつけ、また宛子台の上には黒い喪旗が掲げられ――一山、哀号のうちに沈みきった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗治の犠牲によって、はからずも自分たちのその命が救われたことを狂喜した哀号でもなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん董一家の男女は一名もあまさず捕われ、府内の獄に押しこめられたので、哀号悲泣の声は憐れというもおろかであった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "袁紹も怒って、田豊を血祭りにせんと猛ったが、諸人が哀号して、助命を乞うので、「――首枷をかけて獄中にほうりこんでおけ。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "老幼男女の悲泣哀号の声が天地にみちて聞えた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし逢紀、義渠の二将が追いついてくれたので、彼は蘇生の思いをし、冀州の領へ帰って行ったが、その途々にも、人民たちが、「もし田豊の諫めをお用いになっていたら、こんな惨めは見まいものを」　と、部落を通っても、町を通っても、沿道に人のあるところ、必ず人民の哀号と恨みが聞えた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもその筈で、こんどの官渡の大戦で、袁紹の冀北軍は七十五万と称せられていたのに、いま逢紀、義渠などが附随しているとはいえ、顧みれば敗残の将士はいくばくもなく、寥々の破旗悲風に鳴り、民の怨嗟と哀号の的になった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡和は、哀号して、甘寧や※沢も自分と同腹なのに、自分だけを斬るのはひどいと喚いたが、周瑜は笑って、「それはみな、自分がさせた謀略である」　と、耳もかさず、一閃の下に屠った。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "国中、喪に服して、哀号の色もまだ拭われないうちに一船、江を下ってきて、「元勲、瑜公の死を聞き、謹んで遠くよりおくやみに来ました」と告げた者がある。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "于禁は哀号して、助命をすがった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "首にして街へ梟けるから観念するがよい」　兵は仰天して、雨中に哀号しながら、呂蒙を伏し拝んで、「命だけはお助け下さい。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやがて洛陽を出た喪の大列をここに迎えるの日、彼は哀号をあげて、それを城外の門に拝した。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ哀号し、かつ恨んで云った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明の訃が報じられて、成都宮の内外は、哀号の声と悲愁の思いに閉じられ、帝｜劉禅も皇后も日夜かなしみ嘆いていた折なので、この直後の変に対しても、いかに裁いてよいか、判断にも迷った。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
