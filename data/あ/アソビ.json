          ],
          "literary": [
            {
              "text": "」　翌年の春になつて暖かくなると、忠魂塔の下に遊びに行つたものださうだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はズツと離れた郊外にゐたし、彼の友人や知人はみんな市内やまた他の方面の郊外にゐたので、彼は電車賃がないとなれば、誰かが遊びに来るのを待つてゐて、遊びに来た者から借りるか、それとも本を売るかしなければならないのだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした外観だけを見ている人は、おそらくこうした夫婦の生活を、たわいもない子供の『ままごと』遊びのように思ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗る言いにくい話であるが、彼とふたりで遊び歩いていると勘定はすべて彼が払う。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎氏と遊びたくてせっせとこれだけこしらえたのだが」「僕におくれ」「いいとも」「菊ちゃん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五所川原太宰治　叔母が五所川原にゐるので、小さい頃よく五所川原へ遊びに行きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬には、羽織を脱いでそれを折りたゝんで「兜」にして冠る遊びがあつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、今から近所に遊びに行つて来ますよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか信さんの部屋へ遊びに行った時、見馴れぬ絵の額がかかっていた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては白湾子と共に名古屋に遊びし帰途伊勢を経て雪夜こゝに一夜を明かせし淋しさなどもさま／″＼偲ばる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ少年雑誌などというものの存在を知らなかった頃の冬夜の子供遊びにはよく「火渡し」「しりつぎ」をやったものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外に「カアチ／＼」という遊びがあった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「難破船」の遊びが前述の「神鳴り」とそっくり同じようである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は男の子と女の子が遊んでいると、他の遊び仲間から「おとことおなごとおにやんべ、やんがておややができやんしょ」と云って囃し立てられるのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿は日曜などにはよく家内連れで方々へ遊びに出た。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平一は今年の夏妹夫婦と姪とで夜の会場へ遊びに来た事があった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滞欧中のある冬にイタリアへ遊びに行った。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し快くなる頃はもう外へ遊びに出ようとする、それを引き止めるための玩具がまた増した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か遊びに行ってみたい。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおったらみんなを連れて一日くらい遊びに行こう。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、長男の道樂は、次男三男の酒亂の如くムキなものではなく、ほんの片手間の遊びである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その遊びに依つて、舊家の長男にふさはしいゆかしさを人に認めてもらひ、みづからもその生活の品位にうつとりする事が出來たら、それでもうすべて滿足なのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたちの深切は、遊びだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ、あなたと一緒に遊びたいのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍宮へ行つて遊びたいのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びに來ましたよ、と言へばいい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遊びに來ましたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお家の庭先に私が時々あそびに行つて、さうして、おいしいやはらかな豆なんかごちそうになつたのを、あなただつて知つてたぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
