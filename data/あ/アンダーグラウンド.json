    "entry": "アンダーグラウンド",
    "reading": {
      "primary": "アンダーグラウンド",
      "alternatives": [
        "アンダーグランド"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
