    },
    "definitions": [
      {
        "index": 1,
        "gloss": "underground (film, theater, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンダーグラウンドについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンダーグラウンドの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンダーグラウンドが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンダーグラウンドについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンダーグラウンドの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンダーグラウンドが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンダーグラウンドという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンダーグラウンドについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンダーグラウンドは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンダーグラウンドが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンダーグラウンドは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンダーグラウンドの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンダーグラウンドは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンダーグラウンドは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これより先き、私はステップニャツクの『アンダーグラウンド・ラシヤ』を読んで露国の民族性及び思想に興味を持ち、この富士の裾野に旅した時も行李の中へ携えて来たが、『罪｜与罰』に感激すると同時にステップニャツクを想い起し、かつ二葉亭をも憶い浮べた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　ラボラトリー・アンダーグラウンド　夢の中で気づくと、人工光に照らされた地下室にいた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
