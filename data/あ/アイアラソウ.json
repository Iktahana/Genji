[
  {
    "uuid": "426f3818-94c6-553e-a1d2-e0c0fa5efd80",
    "entry": "相争う",
    "reading": {
      "primary": "あいあらそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行"
      ],
