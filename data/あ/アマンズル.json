    "definitions": [
      {
        "index": 1,
        "gloss": "to content oneself with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘んずるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘んずるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘んずるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘んずるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘んずるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘んずるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘んずるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘んずるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘んずるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘んずるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘んずるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘んずるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘んずるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘んずるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "学者が第一次近似をもって甘んずる時、世人は却って第二次近似あるいは数学的の精確を期待する場合もあり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姉のさびしい生涯を想えば、もはや月並みな若い娘らしい幸福に甘んずることは許されず、姉の一生を吹き渡った孤独な冬の風に自分もまた吹雪と共に吹かれて行こうという道子にとっては、自分の若さや青春を捨てて異境に働き、異境に死ぬよりほかに、姉に報いる道はないと思われた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わるく云えば立ち腐れを甘んずる様になった。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "型に入った批評家のために閑却され、多忙のため不公平を甘んずる批評家のために閑却されては、作家（ことに新進作家）は気の毒である。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "物に足らざるも心に足りて、慾に充たざるも情に充ちて甘んずる、是の如きは動物に無くして人にのみ有り得るところである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "句讀訓詁の學をなして、たゞ句讀訓詁に通ずるを以て足れりとし、句讀訓詁の師たるに甘んずるやうなる學問の仕方を爲したなら、其は非で有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、其の態度が如何にも自信に充ちていて、言葉こそ叮寧ながら、どう見ても此方の頤使に甘んずるものとは到底思われない。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに甘んずる者ありとせむか、その婦人いかなるべき。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、女というのを官能の角度からでしか見られない自分のデカダンスを、もはや主張する気にもなれないくらい、木崎はデカダンスであったが、しかし、げすと言われたことに甘んずる自虐の喜びではなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今よりして当時の平民の心裡の実情を描けば、あはれ彼等は蠖蟄の苦を甘んずるにあらざれば、放縦豪蕩にして以て一生を韜晦し去るより外はなかりしなり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ吾人は自ら顧みて己れを観る時に、何の希望もなく、何の目的もなく、在来の倫理に唯諾し、在来の道徳を墨守し、何事かの事業にはまりて一生を竟るを以て、自ら甘んずること能はざるものあるに似たり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "形を鑿ちて精に入らざれば、自ら甘んずること難し。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "父義実の一言を誤らざらんとて、一身の破滅を甘んずるは、シバルリイの極めて美はしき玉なり、而して其の是を実行するに至りては、海潮の干満整然として、理法の円満を描くに似たり。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を以て犠牲たる、何が故に犠牲たるを甘んずるを得るや、美いかな人間の情、好むべきかな人間の心、友の為に身を苦しめ、親の為めに心を痛め、而して自ら甘心し、真実何の悔恨なきを得るは、豈に讃むべき事にあらずや。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の一統は武装解除に甘んずるだろうか？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々いかでかわが成績に甘んずることを得ん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は彼の文学の為にならば奈落の舞台回しになることに甘んずる――斯う云つて彼がジーベルを私に紹介したのは、あの山麓で私が哲学に飽きて、夙に中世の海賊文学の閲読に、夢を逞しくしてゐた頃であつた。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其地主に向つては殆んど絶對の服從をすら甘んずるばかりに物堅い爺さんの頭は馴致されて居るのであります。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイ長は雇い入れなしで負傷させて打っちゃってあるし、おれたちは、全く馬車馬か奴隷かで甘んずるなら、それでもいいだろうけれど、――それに、いま時分、室蘭に休む者はありゃしないと思うんだがなあ」と波田は主戦論を唱えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋が去り古川が罷める以上はイツマデ腰弁を甘んずる義理も興味もないので、古川が罷めると間もなく自分も辞職してしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし欧羅巴だったら小説家としても相応に優遇され、二葉亭もまた文人たるを甘んずる事が出来たであろう。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君一人を知って甘んずるのは、進んで自己の発達を不完全にするようなものである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くの機械で甘んずるのか？",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ自分は平凡なる生活に甘んずる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすつかり度胆を抜かれて、「僕は単に君の下僕として甘んずるだけのことだよ。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の孤独を反省する、それは孤高でなくて孤寒である、私は孤立を誇るほど思ひあがつてはゐないが迎合に甘んずるほど堕落してもゐない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助が真鍮を以て甘んずる様になつたのは、不意に大きな狂瀾に捲き込まれて、驚ろきの余り、心機一転の結果を来たしたといふ様な、小説じみた歴史を有つてゐる為ではない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら全く互に孤独を厳守して精神上の友であるのに甘んずることが出来るかというに、それも彼の情熱が許さなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば酉の市は先様がとりの市、こっちはとられまちで、どの道金に縁の薄い江戸ッ児には、宵越しをさせたくもこの始末なので及びもつかぬこと、それでも一かどの福運を得る気で、眼前とられにゆくを甘んずるなどはとうてい江戸ッ児以外の人には馬鹿気切ってて嘘にも真似の出来たものではない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百は人の廡下に倚ることを甘んずる女ではなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
