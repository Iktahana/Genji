        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日尼法師について考えている。",
              "source": "幻辞"
            },
            {
              "text": "尼法師という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は尼法師の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には尼法師が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "尼法師を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは尼法師について学習した。",
              "source": "幻辞"
            },
            {
              "text": "尼法師の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は尼法師の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では尼法師が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "尼法師という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に尼法師という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では尼法師についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "尼法師を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると尼法師は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "尼法師について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では尼法師が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に尼法師は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により尼法師の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "尼法師は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に尼法師は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――これが目くされの、皺だらけの、腰のまがった、背の低い、六十ばかりの尼法師でございました。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは京極の左大弁様で、何事かと胸を轟かせながら、慌て御文を開けて見ますと、思いもよらず御姫様は、いかに左大弁様を思いわびてもとんとつれなく御もてなしになるから、所詮かなわぬ恋とあきらめて、尼法師の境涯にはいると云う事が、いかにももの哀れに書いてあるではございませんか。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　我身の因果を歎ち、黒髪をたち切って、生涯を尼法師で暮す心を示したお若の胸中を察します伯父は、一層に不愍が増して参り、あゝ可愛そうだ、まだ裏若い身であんなにまで恥ているは……あゝこれも因縁ずくだ、前の世からの約束ごとだから仕方がない、と晋齋もお若のするが儘にさせておきました。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂光院の塔頭に新たなる庵を結んだ、一人の由緒ある尼法師、人は称して、阿波の局の後身だとも言うし、島原の太夫の身のなる果てだと言う者もあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尼法師、年はもはや五十路を越えているが、その容貌はつやつやしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が尼法師で、俗人を夫に持っている類のものも、すでに平安朝の中頃にはあったらしい。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の歌の中の常陸介は、はたしてかの女の夫の字か否か不明ではあるが、かかる種類の尼法師が必ずしも法師をのみ夫に持っておったとはかぎるまい。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの多数は男法師であったであろうが、その間また尼法師も少しとしなかったに相違ない。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "濫僧とは通例非人法師に対する称呼であるが、婦人すなわち尼法師にも、やはり古くこの徒があった。",
              "citation": {
                "source": "濫僧考補遺",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼法師が仏供の撤下物を所望し、卑猥なる歌を歌い、身振りおかしく打ち躍るは、目に見えるようではないか。",
              "citation": {
                "source": "濫僧考補遺",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は人に顔見られるさえ疎ましい気分ですから、香合せなどをする気は微塵もありませんが、相手の尼法師の調子が滑らか過ぎて、一寸咄嗟の間には断わり切れなかったのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、座が定まると、お経を読むでもなく、念仏を称えるでもなく、尼法師がおもむろに取り出したのは、緞子の袋に入った紫檀の十※香箱、一重口白磁の香爐に、流儀の炭団を入れ、銀葉を置いて、「…………」　静かに一礼して、名木を※きます。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅ましの光景に名香は燃え尽きた　それから幾日かの間、不思議な尼法師は毎日丈太郎の寮を訪ねました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "香の酔から醒めて、尼法師が帰って了うと、お園の思い出を涜す恥かしさに、丈太郎は自分の身内を掻きむしり度いような恐ろしい悔恨に責められました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それも日と共に薄れて、やがては、尼法師の訪ずれるのを、夜となく昼となく待ち焦れるようにさえなってしまいました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あの頃私は、お布施で暮して居た、頼りない尼法師だったんですもの、どんな下心があったにしても、寄進報捨を惜しまない檀家に、無愛想な顔も見せられません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違った女、それも墨染の法衣を着た若い尼法師の美しさに驚いたのです。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代之助の心を犇と捕えたのは、尼法師の紅い唇――茱萸のように丸くて、茱萸のように艶やかな唇だったのです。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代之助の足は、何時ともなく、その尼法師の後を慕って、上野の山下から、根岸の方へ歩いて居りました。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は鶯も梟も鳴いた根岸、日が暮れると滅切り淋しくなるのですが、尼法師はさまで急ぐ風もなく、木立から藪へ、藪から田圃へと、暗くなりかけた道を辿って、根岸の奥へ奥へと入って行ったのです。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」尼法師は鈍い光にすかして、黙って千代之助の顔を見詰めました。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のは世を捨てたのではなくて、世に捨てられた身の上で御座います」「ハテ、そんなに美しいお方を、捨てる世の中が憎いでは御座いませんか」　千代之助は優しく尼法師を見上げるように、ズイと膝を進めました。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おゆう」　彼はそのとき路傍の松影に、ひとりの清楚な尼法師の白い頭巾をしてたたずむのを見た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "若きも老いも、尼法師、あやしき山賤まで、（中略）おのおの目押し拭ひ、鼻すすりあへる気色ども、げに憂き世の極めは、今に尽しつる心地ぞする。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
