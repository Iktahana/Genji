        "examples": {
          "standard": [
            {
              "text": "毎日、アイスコーヒーは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスコーヒーが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスコーヒーに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスコーヒーが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスコーヒーについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスコーヒーについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスコーヒーについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスコーヒーが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスコーヒーが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスコーヒーは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスコーヒーは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスコーヒーを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスコーヒーをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスコーヒーが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスコーヒーの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスコーヒーを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスコーヒーに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスコーヒーについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスコーヒーは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスコーヒーを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "飲みかけのアイスコーヒーのグラスもある。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路樹の陰の野天のカフェーにも、客がいっぱいに溢れて、アイスコーヒーなどを飲んでいた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、タウベが飛んでいる空の下で、平気でアイスコーヒーやソーダ水を飲んでいたのである。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時に出かけ、中泉眼科へ寄り、耕一路でアイスコーヒーを飲み、座へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ってニューグランドへ行き、トマトクリームスープに、チキンとヌードルのクリーム煮、それにアイスコーヒーとプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリムピックへ入り、アイスコーヒーをのみ、小松へ理髪に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三昧堂へ入り新刊二冊買って、ローマイヤへ入り食事、豆のスープにウィンナシュニツェル、ウィンナアイスコーヒー、それから座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
