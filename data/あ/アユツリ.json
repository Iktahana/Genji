        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日鮎釣りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は鮎釣りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には鮎釣りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは鮎釣りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は鮎釣りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では鮎釣りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に鮎釣りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では鮎釣りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると鮎釣りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では鮎釣りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に鮎釣りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により鮎釣りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "鮎釣りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に鮎釣りは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私が此夏、鮎釣りに泳ぎ渡つた際、大きな蟻に臍を食ひつかれて愕いた、竜宮岩も紅葉の間に浮んで、静もりかへつてゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝なして水沫さかまく宇治川に鮎釣りがてら聞くほととぎす明治二十七年七月十二日、人人と一日百首催しけるに、いみじく暑さ日なりければ。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はまだ試みないが、鮎釣りの愉しみは、先づこの最初の匂ひから始まるといつてよい。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今では何といつても鮎釣りが人気王であるが、江戸期には今のやうに交通が便でなかつた故か、キス釣りが人気の中心だつたやうである。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "又新宿からは鮎釣りの臨時列車も出たし、各府県が同じやうに釣徒のために好意を持つて、その河川を拓いてくれるから、日本は鹿児島から北海道まで、自由にその特有の魚を釣つて歩ける。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鮎の極く上等を手に入れるのは非常の困難で、私は以前国にいた時分鮎釣が好きでしたが東京へ来てからも暑中休暇には毎度近郊の川筋へ鮎釣りに出かけました。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ夏近くなると始まる鮎釣りの季節にだけ、堂本は仕事着めいたシャツに古股引、大きい麦藁笠といつた姿で川岸に現はれるのだつたが、それさへなるべく人目にかゝりさうな場所をはなれて、上の方から釣手が下つて来るとだんだん下流の方へ、時には一里位下に遠ざかつてしまふのであつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな小さい時から、父のお供をして若鮎釣りに使う餌採りの相手をさせられた。",
              "citation": {
                "source": "父の俤",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　私の少年の頃には、鮎釣りに禁漁期というものがなかった。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、私は五、六年の頃から父のあとに従って、村の地先へ若鮎釣りに行った。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　前橋市を中心として、上流は坂東橋付近、下流は新堀地先までの利根川でやる若鮎釣りの技術は独特のものである。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　私は、今から十五、六年前、裏飛騨の吉城郡坂上村巣の内へ、鮎釣りの旅に赴いたことがある。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎釣り、山女魚釣り、はや釣りの方に面白味を持つという。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒釣りには数回の心得があるが鮎釣りはこれが入門だ。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は、気まぐれな戦争から解放されたはじめての鮎釣り季節を迎えて、またこの魚野川に伜や娘を伴い、一夏を楽しく過ごしたいと、ひたすら希う。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父は、若いときから鮎釣りにたんのうで、随分大漁したことがあったそうだ。",
              "citation": {
                "source": "那珂川の鱸釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、五月はじめのある朝、父と二人で、村の河原の雷電神社下の釣り場へ若鮎釣りを志して行った。",
              "citation": {
                "source": "母の匂い",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "相州の相模川は、与瀬から下流厚木付近まで、東京の鮎釣りの人で知らぬ人はあるまい。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "美濃へも、表飛騨へも鮎釣りの旅をした。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い頃、父に伴われて故郷の川へ鮎釣りに行くたびに、河原で聞いたいそしぎの声に似ているのである。",
              "citation": {
                "source": "みやこ鳥",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに東雲のたなびくころ、幼い私は父に連れられて、利根の流れへ鮎釣りに行った。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀は、栃木県と茨城県にまたがる那珂川の釣り人も、若鮎釣りの餌に使っているという話だ。",
              "citation": {
                "source": "石亀のこと",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天を、毎日海辺の川尻の黒鯛釣りやはや釣りに専念して、第一年の夏は終わったのであったが、第二年は六月のはじめから鮎釣りをやってみた。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう想像して若鮎釣りだけで満足し、大川の友釣りには手を出さなかった自分であった。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大東京幾十万の鮎釣り党は、多摩川の鮎釣り党は、多摩川の鮎を日本一なりと主張して、一歩も退かない確信を持っていた。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが鮎釣りの本場であって、百匁に近い大ものが渾身の力をこめて逸走の動作に移れば鈎も糸も、ブンと飛ばしてしまう。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に鮎釣りというものは、漁場の権利みたいな料金を支払うのが普通である。",
              "citation": {
                "source": "釣り師の心境",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十三年六月二十八日福井地震の発震時は午後四時三十分ごろであったが、中央気象台本多技官によると、その日の午後九頭竜川で鮎釣りをした人が八十匹も釣り上げたと言う。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよく磧へ出て行って、鮎釣りなどをしたものであった。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、父の釣はあゆつり（郷里ではあゆかけといつてゐた）だけであつたが好きな割には下手で、却つて子供のわたしの方がいつも多く釣つてゐた。",
              "citation": {
                "source": "鮎釣に過した夏休み",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
