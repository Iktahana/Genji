        "examples": {
          "standard": [
            {
              "text": "私は毎日アルミについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルミという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルミの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルミが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルミを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルミについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルミの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルミの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルミが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルミという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルミという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルミについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルミを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルミは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルミについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルミが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルミは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルミの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルミは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルミは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "途中の淋しい小驛の何處にでも、同じやうな乘合自動車のアルミニウム・ペイントが輝いて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚水中にアルミニウムの電極を入れて電流を通ずれば、過酸化アルミニウムを生じ、これが種々の汚物に結合して固まってしまう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒の外側はアルミニウムペイントで御化粧をしてあるが、金属製だかどうだか見ただけでは分らない。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽にはいったまま腕をのばし、水道のカランをひねって、備付けのアルミニウムのコップで水を幾杯も幾杯も飲んだ。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は、私にアルミニウムのコップを、だまって渡した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはでこぼこではありましたが、アルミニユームでできてゐましたから、大丈夫こはれませんでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどアルミニウムだかマグネシウムだかの閃光は光度において大きく、ストロンチウムだかリチウムだかの炎の色は美しいかもしれないが、始めからおしまいまでただぼうぼうと無作法に燃えるばかりで、タクトもなければリズムもない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸を伸ばして隣りの三畳間を覗くと、三畳間の隅に、こわれかかった七輪が置かれてあって、その上に汚く煤けたアルミニュームの薬鑵がかけられている。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝くアルミホイルに包んだチョコレートを五つ六つ抛って下さいな。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際器内の水の運動を水中に浮遊するアルミニウム粉によって観察して見ると、底面から熱せられた水は決して一様には直上しないで、まず底面に沿うて器底の中央に集中され、そこから幅の狭い板状の流線をなして直上する。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋マッチが一箱、二インチほどの獣脂蝋燭が一本、ＡＤＰ印のプライヤ製パイプ、長刻みの板煙草を半オンスばかり詰めた海豹皮の煙草入れ、金鎖の付いた銀時計、ソヴリン金貨五枚、アルミニウムの鉛筆入れ、書付け数通、ワイス社（ロンドン）の刻印がある細小で硬い刃の象牙柄ナイフが一振り。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼等は微笑みみながら、すべて茶碗や土瓶、アルミ鍋などを、テーブルの下に置いた。",
              "citation": {
                "source": "晩餐",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　われは友を顧みて、拿破里は最早こゝより見ゆるかと問ひしに、友は笑ひて、まだ見えず、されどヘスペリアは見ゆるなり、アルミダの奇しき園は見ゆるなりと答へき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルミダはタツソオが詩中の妖艷なる王女なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも或る粘土からアルミニユームを採る方法を發明したと稱へて一つの會社を起さうとしてゐる男であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間にプープーと湯気を吹いているアルミの大薬鑵や、外の雪をチラチラと透かしながら一面に水滴をしたたらしている硝子窓は、二人が長い間話し込んでいる事を証明していた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実物は木のおひつの底にアルミの電極を張り付けただけのもので、じつに何ともわかりやすいというか情けないというか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近代詩歌』の四月号に彼の詩『鍋焼うどん』といふのがあり宵暗の都市に親子の貧しい、うどん売子の熱いアルミニュームの鍋に、彼が渇いた唇をあてゝ『子がしつらへて親がはこぶなり』とせち辛い浮世の味ひを歌つてゐたので私は彼に旭川の鍋焼を喰べに来いと葉書をやつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを閉めると余計に小暗くなつてしまふ板の間に、おくみはどんよりした戸棚から煮物の砂糖の入れものを出したりして、うつたうしくこゞんで、アルミニュームの手鍋の下の瓦斯を捩ぢた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井は、四〇一号のアルミサッシュの窓枠に両手をかけて、上下に揺すりはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に坐った、こわい顔のマスターらしき人物が、高志をにらんで、吸っていたタバコを、アルミの灰皿が音をたてるほど強くもみ消した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早よう」　ワラは、もう元気な声で、カメラの入ったアルミ・トランクのふたを、きっちりと閉めている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえらなんか、はじめからいなかった、っていわれてるような気がしてくる」　高志は、手にしていたタバコを、アルミの灰皿に押しつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　据わりの悪いアルミの灰皿で、タバコをもみ消してから、高志は口を開いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、なんだよ」「ギター」　といって、照れかくしのように、高志は背後の棚からアルミの灰皿をとった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の水晶、鉛やアルミの鍍金鎖なぞは説明までもない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腰弁」という名称の起りは、腰にブラブラしたアルミの弁当からであるが、それが今では月給取りの総称になってしまった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ボーイは、酒壜をのせたアルミの盆をさげたまま、舷側にだらりともたれかかっている僕の顔を呆れたような目でみて、「これはどうもおそれいりました。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
