    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Amazon (river, rainforest, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アマゾンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアマゾンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアマゾンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアマゾンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアマゾンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアマゾンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアマゾンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアマゾンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアマゾンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアマゾンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアマゾンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアマゾンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アマゾンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアマゾンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが下駄を片手にぶらさげて跣足で田の畦を逃げ廻るのを、村のアマゾン達が巧妙な戦陣を張ってあらゆる遁げ路を遮断しながらだんだんに十六むさしの罫線のような畦を伝って攻め寄せて行った。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを相島は引きとつて、「うむ、長屋のアマゾン連も二三人出て見て居た」と云ふ。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（15）Spanish main ――往時、南アメリカの北海岸のオリノコ河またはアマゾン河の口からパナマ海峡に至る一帯の地方や、カリブ海のこれに接した部分を、漠然と指した名称。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマゾン辺の民｜一汎に信ずるはマイダゴア（水の母また精）とて長数百フィートの怪蛇あり、前後次第して河の諸部に現わると。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを以てアマゾン河辺のある土人は、水に入る時｜椰子殻に細孔を開けて男根に冒せる。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎場の正面のずっと高い石の壇上には、大熊老人の亡骸を安置しその下には、各名士から贈られた真榊や、花筒や、花環がギュウギュウ言うほど、おし並べられ、まるでアマゾン河畔の大森林を此処に移したかの感があった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちみち、網を打つて、糧食を求めるのがアマゾンの役目の由であつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、訓練ある沈黙と速度をもって、五、六人の女隊が、アマゾン流域特産のぽけっと猿みたいにするすると船腹の縄梯子を這い上って甲板へ現れる。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船にはアマゾンのにおいがする。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋隠猿はアマゾン流域に特産する小さな小さな猿だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラジル焼酎を飲りながらアマゾン奥地の、「神にして狂う」河の話をきっとやるだろう……と私は、しめしめとばかりに舌なめずりをしながら、彼の開口を待ったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、こうして佇んだ数秒間さえなければ、かの怪奇の点では奥アマゾンを凌ぐといわれる、水棲人のすむあの秘境へはゆかなかったろうに。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、人も知る奥アマゾン、さらにオリノコ川の上流もその一つだろうし、また、南端へゆけばパタゴニア地方にも、恐竜の全化石などがでる未踏地がある。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラジル焼酎を飲りながらアマゾン奥地の、「｜神にして狂う」河の話をきっとやるだろう……と私は、しめしめとばかりに舌なめずりをしながら、彼の開口を待ったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代支那には、編磬のような響石楽器や、方響のような扁板打楽器があり、古代インカの乾木鼓やアマゾン印度人の刃形響石も知られている。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六尺近い豊かな肉付きは、まさにアマゾンと云う形容であろう。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、南米アマゾン河奥地の、“Rio Folls de Dios”の一帯。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一のアマゾン河奥地というのは「神々の狂人」と訳される。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、南米アマゾン河奥地の、“｜Rio Folls de Dios”の一帯。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには、前作、「第五類人猿」のアマゾン奥地探検のとき関係のあった、「世界新報」というペルー新聞までがいる始末。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、あなたのアマゾンヌの様な、トレエニング・パンツの姿が、Ａ甲板の端から此方まで、風をきって疾走してくる。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "パミール高原やアマゾンの奥で、一度は釣つて見たいものだ。",
              "citation": {
                "source": "釣れない時",
                "author": "君は何を考へるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "『アマゾン』『オリオン』『サラトガ』と、山のような大きな航空母艦が、岬の陰から出て来た。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗艦『アマゾン』の檣に、信号旗が上っている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "――フーラー博士」　あッ、フーラー博士は、早くも、新しい『荒鷲』を持って、母艦『アマゾン』に乗っているのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
