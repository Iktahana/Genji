[
  {
    "uuid": "e2d6a8a4-32fc-5b8b-a3d4-638ba7d8c04b",
    "entry": "甘んじる",
    "reading": {
      "primary": "あまんじる",
      "alternatives": [],
      "is_heteronym": false
    },
