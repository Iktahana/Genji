    "definitions": [
      {
        "index": 1,
        "gloss": "to content oneself with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘んじるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘んじるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘んじるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘んじるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘んじるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘んじるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘んじるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘んじるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘んじるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘んじるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘んじるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘んじるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘んじるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘んじるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "全て人間的シウ態といふものは、マイがマイセルフに楯つく所、甘んじる所から出て行く。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして征服者の大軍の通り去った野に落ちちらばった弾殻を拾うような仕事に甘んじると同じような事になりがちである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物に足りなくとも心に足りて、慾に充たなくとも情に充ちて甘んじる、このようなことは動物には無くて、人にだけ有るところである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "句読訓詁の学を為してただ句読訓詁を理解することで満足とし、句読訓詁の師であることに甘んじるような学問の仕方をしたならそれは非であろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それでも清貧に甘んじるか……。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に広義国防ではなくて「社会政策」か「国民生活安定」にしても、吾々は容易に夫を信頼出来ぬし、又それだけに甘んじることは出来ぬ。",
              "citation": {
                "source": "近衛内閣の常識性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、本当に文学を愛し、新しい小説を生み出してゆきたいとねがうわたしたちとしては、この最少抵抗線に甘んじることはまちがっている。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い上がって暮らした自分が今後はどんな屈辱に甘んじる女にならねばならぬかしれぬと紫の女王は愁いながらもおおようにしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また経済事情からも年齢関係その他からも結婚は可能でありながら、男女交際の自由が許されない現代において媒妁結婚の不安を感じて結婚を躊躇している男があり、媒妁結婚に甘んじるにしてもまだその意味の良縁を得ないで模索している男がある。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は粗衣粗食に甘んじる。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の下層民が不潔に甘んじるのは決して天性では無いとの事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは勿論一つには、彼の蒲柳の体質が一切の不摂生を許さなかったからもありましょうが、また一つには彼の性情が、どちらかと云うと唯物的な当時の風潮とは正反対に、人一倍純粋な理想的傾向を帯びていたので、自然と孤独に甘んじるような境涯に置かれてしまったのでしょう。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みではあつても、読み量の少い方法に甘んじる様になり、ひき出しの摘要書きの範囲の広く及ばないのに焦れて、遂には、かあどの記録を思ひ止る様になつた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の存在を信じ、来世の幸福を信じなければ、どうしてこのやうな困苦の生活に甘んじることができませうかと言つた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しほらしさは、むろん女の強さともなるものであるが、ひとたび方向を間違ふと、たゞ消極的な男性の玩弄物たるに甘んじるひとつの風情に過ぎないのである。",
              "citation": {
                "source": "女性へ　２",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、有名になり、金を握つてみて、その馬鹿らしさにウンザリしたといふなら、それもそれで結構だけれども、自ら落伍者で甘んじる、たゞ仕事だけ残せばいゝといふ、その孤独な生活によつて仕事自体が純粋高尚であり得るといふ性質のものではない。",
              "citation": {
                "source": "大阪の反逆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "清貧に甘んじるとか、困苦欠乏にたへ、オカユをすすつて精進するとか、それが傑作を生む条件だつたり、作家と作品を神聖にするものだといふ、浅はかな迷信であり、通俗的な信仰でありすぎる。",
              "citation": {
                "source": "大阪の反逆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それはそれなりに職業として成立っているところに、誘惑もあり危険もあるのですが、あなたの場合は、まさか、そんなことで甘んじるつもりはないでしょう。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはね、なんていふんでせう……苦しみからのがれようとしないで、その苦しみに甘んじるつていふこと……宗教のことはわからないけど、さういふ人間の生き方もあるんぢやないかと思ふの。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命だといって、――甘んじることが出来たら私は父とのつながりを平気でたつことが出来るでしょうが、私の心の隅に反抗がある以上、父とのつながりはあるのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方損の運命に、甘んじるべきや、否や、これ実に、小生一生の大問題、面壁九年の一大事であったです。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "発展させる必要なんてないぢやないの」五　かういふことを、近頃の若い娘は、見得にでも言つてみるもので、いざとなれば、それぞれ平凡な主婦として、一切の運命に甘んじるのだと、彼も内心高をくくつてゐるにはゐるが、それにしても、なんのためにそんなことを云つてみなければならないのか。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く無代償で不便な生活に甘んじる風流人は滅多になかろう。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化社会学の理論が、如何に非実践的・観想的なものに甘んじるかは、この点からも明らかだろう＊＊。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、有名になり、金を握ってみて、その馬鹿らしさにウンザリしたというなら、それも結構だけれども、自ら落伍者で甘んじる、ただ仕事だけ残せばいいという、その孤独な生活によって仕事自体が純粋高尚であり得るという性質のものではない。",
              "citation": {
                "source": "大阪の反逆",
                "author": "――織田作之助の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "清貧に甘んじるとか、困苦欠乏にたえ、オカユをすすって精進するとか、それが傑作を生む条件だったり、作家と作品を神聖にするものだという、浅はかな迷信であり、通俗的な信仰でありすぎる。",
              "citation": {
                "source": "大阪の反逆",
                "author": "――織田作之助の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、彼等は貧困に甘んじることをもって生活の本領としたのではない。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "他者の完全性をしっかりとあがめる者は、自分の不完全性に甘んじることはないし、その他人そっくりに自分の魂を変えていくだろう。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回はこれで甘んじる代りに、僕の問題が起った時、犬馬の労を執ってくれ給え」　と僕はこれを機会に元来の約束を思い出させた。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或程度まで下敷に甘んじるよ」「伸びている。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
