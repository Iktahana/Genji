        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これは愛蘭の例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼の眼には真佐子のやや、ぬきえもんに着た襟の框になっている部分に愛蘭麻のレースの下重ねが清楚に覗かれ、それからテラコッタ型の完全な円筒形の頸のぼんの窪へ移る間に、むっくりと搗き立ての餅のような和みを帯びた一堆の肉の美しい小山が見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛蘭独立はその問題が英議会に伝統化された時に解決の端緒が開かれた。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三がい松の根方に籐のテーブルを据え、愛蘭土｜麻のテーブル掛けを敷いて、その上には、またテーブルの布地と揃いのナフキンを畳んで載せた化粧皿が置いてあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな泥まみれになり、ヴェランダは愛蘭土泥炭沼の如し。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛蘭土劇を飜案したものだった。",
              "citation": {
                "source": "天の配剤",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新思潮」が復活するまでの間、僕は大学の研究室で愛蘭劇をよんでゐた関係で現代劇を研究するつもりだつたから、茲で、僕は戯曲は大抵読んだ。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "故ニ中世貴族ノ所有地ヲ現今ニ至ルモ解決スル能ハズシテ終ニ獨立問題ニマデ破裂セシメタル愛蘭ノ土地問題ト、此ノ私有地限度制トハ其思想ニ於テモ進歩ノ程度ニ於テモ雲泥ノ差アルヲ知ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亞ニ民有論ノ起ルハ正當ナルト共ニ、愛蘭ノ貴族領ガ國有タルベキモ可能ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮ヲシテ日本ノ愛蘭土タラシムル如キコトアラバ、將來大羅馬帝國ヲ築カントスル日本ハ全然其ノ能力ナキコトヲ第一歩ニ於テ立證スルモノナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮ノ亡國史ヲ知リ露國ノ脅威ニ戰慄シタル危機ヲ顧ルナラバ、愛蘭土獨立問題ヲ朝鮮ニ直譯シテ論及スルノ理ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文学者７・20（夕）　サー・ロバアート・ポールといへば愛蘭生れの名高い天文学者で、剣橋大学で天文学の講座を受持つてゐる先生だが、幾ら天文学者だからといつて、木星から高い生活費を受取る訳にも往かないので昼飯は精々手軽なところで済ませる事に決めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育に愛蘭生れの音楽家ヴヰクトル・ヘルバルトといふ男が居る。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史は船には強い方ではなかつたが、それでも二等室にゐた愛蘭人の一人が、ひどく弱り込んでゐるのを見ると、もうじつとして居られなくなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史は苦しさうに嘔吐してゐるその愛蘭人の肩を抱へながら言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私のお腹が弱いと仰有るんですか……」愛蘭人は涙の眼で女史の顔を睨まへた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方自治の事か何かで、氏は例の白熱のやうな雄弁で、自治は愛蘭にも、自治は蘇格蘭にも、自治は威耳斯にも許さなければならないと言つて、勢ひ込んでとんと卓子を一つ叩しつけた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せめて犬でも一匹ゐてくれるといいんだが」……　　　　　◇　愛蘭の詩人イエエツは気分ほど大切なものはない、歴史上の大事件でも煎じつめると、ふとした人間の気分一つに原づいてゐるのを見付けることが少くないといつてゐるが、実際さうで、むかし韃靼人と波斯人とが幾年もにわたつて大戦争をしたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちだって、旅行者のもつ俗な善意と口笛の気軽さで、野花とみどりの斜面と羊のむれのケント州の心臓を走って、「ある日大きな倫敦へ愛蘭人がやってきた」ように、黒いヴィクトリア停車場へ着いたものだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い眼の愛蘭人の微笑だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の蒼い、愛蘭人の微笑とともに、そっと彼の低声が私たちの耳のそばを流れた。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曜日の夕方、愛蘭土の海岸が遙か背ろに溶け去って、靄のような暮色が波がしらに立つ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画を描いて雑誌に売り込んだりなどしていた、これも独身者のケネス・オハラという愛蘭土生れの画家が、ふと新聞の個人広告欄に眼を留めて、知らず識らず吸い込まれるように、「求縁――インデアナ州ラ・ポウト郡の風光明媚なる地域に、収穫多き農園を経営する美貌の寡婦――」　貪り読んでいる。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来愛蘭土人は気が早いので有名だ。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は彼の戯曲の中に、愛蘭土劇の与えた影響を数える。",
              "citation": {
                "source": "「菊池寛全集」の序",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大陸文学ではないが、以前文壇の一角に、愛蘭土文学が持て囃されたのも、火の元は亜米利加にあつたやうだ。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを又、乗客の中に居た、愛蘭の海軍将校上りが感付いて、船中に宣伝して廻ったから堪まらない。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その養子の話によりますと、御存じか知りませんが、このＳ岬のマリイさんと申しますのは、愛蘭人のお袋さんの血を受けているので御座いましょう。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、Sylphe の女性をそれにもまた男性化しているばかりでなく、再び古｜愛蘭のような角張ったゴソニック文字で、それには筆者の性別は愚かなこと毛のような髯線一筋にさえ、筆蹟の特徴を窺うことは許されなかったのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は、あの愛蘭土の傑僧がデシル法――（註）に似た行列を行うと、それがドルイド呪僧を駆逐して、アルマーの地が聖化されたという史実を御存じでしょうか」（註）ウエールスの悪魔教ドルイドの宗儀で、祭壇の周囲を太陽の運行と同様に、すなわち、左から右に廻る習俗。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、ラインハルトの『抒情詩の快不快の表出』という著述の中に、ハルピンの詩『愛蘭土星学』のことが記されてある。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
