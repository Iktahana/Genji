[
  {
    "uuid": "490c8162-aed3-54e4-b668-c74be06d282d",
    "entry": "或は",
    "reading": {
      "primary": "あるは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "some ... and others ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日或はについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "或はという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は或はの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には或はが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "或はを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは或はについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "或はの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は或はの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では或はが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "或はという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に或はという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では或はについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "或はを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると或はは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "或はについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では或はが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に或はは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により或はの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "或はは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に或はは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "神経的、或は潔癖精神的に幻想のげにも脆い臍の緒を掴へることによつて、心境の一断想を歌ふばかりである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで思はず、Ａのカマに掛かり、ニツコリしたり、或は、急に不慣れな問題が跳出したので、表情が激変したりする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人物の上で……或は……。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞそれが可能に見えるのは、かの記憶、或は経験によつてゞある。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "セザール・フランクが、或はスクリャビンがやつたあの旋廻は、蓋し彼等の抽象情緒の周囲を旋廻したのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠実たること――即ち愚痴つぽくないためには、敬虔なる感情を持し得るの必要、或は絶えず意識的なる自己葛藤が必要であらう。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意せよ、彼は以前には驚くべく観念明晰な男であつたが、やがてその観念を自己の裡に位置せしめる底のもの、即ち自然――手を差伸べもしないが手を退きもしないもの、――が人間の裡にあつては恩愛的な作用をつとめる、その作用を、雑念或は意識及び其の惰性によつて忘失したのである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、真底想はなかつたから、判然皺が現れなかつたのだ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点高橋新吉は或は不良少年の心理に似てゐるのだが、彼の無意識的な善良さが人々の中に生きてゐるうちにさうなるのは当り前なのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、認識能力或は意識によつて、己が受働する感興を翻訳する。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには何かしら、或る物なつかしい、昔々母の懐中でまどろむやうな、或はまた焚火の温暖を恋するやうな、人間情緒の本質に遺伝されてる、冬の物侘しい子守唄の情緒がある。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は荒寥とした枯木の中を、葱さげて家路に急ぐ人の姿は、さうした冬の季節の中で、ふしぎに物侘しく、孤独にふるへる生の果敢なさを感じさせ、何かしら或る暖かい、焚火の燃える家郷への、魂のノスタルヂアを追懐させる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍聴席には、その両親の子供たちが、ハッキリ数へることは出来なかつたが、七八人、或は十人もゐたかもしれなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も戸外と云つても唯庭をあちらから見たり此方から見たり、或は二階か近所の屋根や樹の梢を見た處など、もしこれが本當の畫家ならば始めからてんで相手にしないやうなものを、無理に拾ひ出し、切り取つては畫布に塗り込むのであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは子供の時分に何か長く欲しがつて居た新しい玩具を手に入れて始めて其れを試みようとする時、或は何かの研究に手を付けて、始めて新しい結果の曙光が朧に見え始めた時に感じるのと同じやうなものであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語もかういふ工合に活用させる人ばかりだつたら、字を見なければ分らない或は字を見ても讀めないやうな生硬な術語などをやめてしまつて、もう少し親しみのあるものに代へる事が出來さうである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全色盲の見た自然は或はこんなものだらうかといふ氣がして不愉快であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして色々人を笑はせる心算らしい粗暴な或は卑猥な言語を並べたりした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし或は家の方が先に建つて居たので切通しの方が後に出來たかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上へ、まだ活字が揮発油で濡れているパリ・ミデイの一版を抛り出して、キャフェの蕭条をまづ第一に味わいに来たのは Boulevardier（界隈の人、或は大通漫歩の人と訳すべきか）と呼ばれている巴里の遺物である。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然と人とは互に冥通する何者かを失うことなしに或は争い或は親しんだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "離れたときには山と自分と相対した二つとなり、融ずるときには自分を山となし、或は山を自分とする一致ができた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の稽古事が新時代的のものや知識的のものに移って行ったのも、或はまたその現われの一つと云えるかも知れない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、もしこれを性の欲望に関する変態のものだったろうと言うなら、或はそうかも知れないと答えよう。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか誇張的な言葉かとも聞えるが、或は本当かも知れない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々糺罪の吏ででもあるか、或は逆に苛政の下、〔喘〕いだ民の末でもあるか。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅内或は長沼輩、党の内部の敵でさへ、眉をひそめて煙を吐き、わしの修養を嗤ふだらう。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも富沢が何かしっかりしたさういふことの研究でもしてゐてじぶんの考へに引き込むためにさう云ってゐるのか全く本音で云ってゐるのか、或は早くもあの恐ろしい海外の思想に染みてゐたのかどれかもわからなかった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
