        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しばらく經つて、とんと輕く足踏みして、おもむろに呻き出すは、「是は阿波の鳴門に一夏を送る僧にて候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は踊りの事は何も知らないし、ましてやこんな西洋の足踏み踊りなどいったいなんのことだかちっともわけがわからない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと下の方の座敷には足踏み轟かして東京音頭を踊つて居るらしい一團がある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや湿って落ち付いた下層の落葉は朽ちた冷たい気配と共に彼の足踏みを適当に受け止めた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは町内の経師職の伜で、弥三郎というんです」「師匠の家へ出這入りすることはねえか」「去年までは毎晩稽古に行っていたんですが、若い師匠が死んでからちっとも足踏みをしねえようです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたんばたんという足踏みの音、怒号や潮罵が烈しく起りました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは足踏みをして歌いました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足踏み辷らして崖へ落ちて木へブラ下がる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が駈け附けた時、伊吉足踏み辷らし谷川に落ちる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに巡査は二つ三つ婦人の枕頭に足踏みして、「おいこら、起きんか、起きんか」　と沈みたる、しかも力を籠めたる声にて謂えり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし古来の科学者が、「試み」なしの臆断を続けたり、「試み」の結果を判断する合理的の標準なしに任意の結論を試みたり、あるいは「試み」に伴なう怪我のチャンスを恐れて、だれも手を下す事をあえてしなかったら、現在のわれわれの自然界に関する知識と利用収穫は依然として復興期以前の状態で足踏みをしていたであろう。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに足踏みならしてたぬきの歌う歌の文句が、「こいさ（今宵の方言）お月夜で、お山踏み（たぶん山見分の役人のことらしい）も来まいぞ」というので、そのあとに、なんとかなんとかで「ドンドコショ」というはやしがつくのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、おしっこが出たくて、足踏みしているのよ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日の月は東にかゝり空気は水より冷たかった、学士はしばらく足踏みをしそれからたばこを一本くはへマッチをすって「ふん、実にしづかだ、夜あけまでまだ三時間半あるな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日の月は東にかかり空気は水より冷たかった、学士はしばらく足踏みをしそれからたばこを一本くわえマッチをすって「ふん、実にしずかだ、夜あけまでまだ三時間半あるな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもし世界じゅうの他の国が昔のままに「足踏み」をして、日本の追いつくのを待っていてくれたらさぞいいだろう。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分が裸になるのを見てそこに脱ぎすてた着物の上にあがって前足を交互にあげて足踏みをする、のみならず、その爪で着物を引っかきまたもむような挙動をする。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が人間の喜びに相当するらしい感情の表現として、前足で足踏みをするのは、食肉獣の祖先がいい獲物を見つけてそれを引きむしる事をやったのとある関係があるのではないかという荒唐な空想が起こる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空想の翼はさらに自分を駆って人間に共通な舞踊のインスティンクトの起原という事までもこの猫の足踏みによって与えられたヒントの光で解釈されそうな妄想に導くのであった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人間の祖先の猿が手で樹枝からぶら下がる時にその足で樹幹を押えようとした習性の遺伝であろうと言った学者があるくらいであるから、猫の足踏みと文明人のダンスとの間の関係を考えてみるのも一つの空想としては許されるべきものであろう。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免よ」と云ひながら相島は軟い雪に一足踏み込んでよけながら通つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは足踏みをして歌ひました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とみんなは足踏みをして歌いました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足踏み辷らして谷底へ落ち損なったことが度々あった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白煙｜濛々と立昇る地獄穴｜溶岩を覗いて、未醒画伯と髯将軍、快哉を叫んで躍り上がったところが、忽ち麓から吹き上ぐる濃霧に包囲されて、危うく足踏み外し白煙中へ捲き込まれんとし、二人、一生懸命｜巌に獅噛み付いて、ようよう命を陥さずに済んだそうである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大佐は、今朝も定れる職務に參るが、昨夜は取紛れて語らず、今朝は猶ほ御睡眠中なれば、此水兵を以て申上げるが、此住家の十｜町以内なれば、何處へ行かるゝも御自由なれど、其以外は、猛獸毒蛇等の危害極めて多ければ、决して足踏みし玉ふな、大佐は夕刻に皈つて、再び御目にかゝる可し。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすここそ頂上に相違ないと、余りの嬉しさに周章てたものか、吾輩は巌角から足踏み滑らして十分に向脛を打った。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」正面壁に沿い左向き足踏み。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、批評家である中野好夫の足も、私小説とその方法の否定という線であしぶみをくりかえすことになっているからであった。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいろいろなことが、あしぶみをしていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
