        "名詞-の形容詞",
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "piping hot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と釜のふちを白い手で留めたと思うと、「お熱々。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮方に、また、夕河岸の鰹、生鰹、鰯こ、鰯こい――伊太利じゃ晩餐の朗々朗が聞えて、庭のコスモス、垣根の黄薔薇、温室の朝顔も一際色が冴えようという時、廊下が暗くなると、（あ、熱々々々、）と火がついたように、凡ての音楽を打消して、けたたましく言い出したじゃないか。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも二時間とは続かない、すぐにまた、（熱々々々！",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる好意とか親切とかいふもの以上の、何か別なもの、謂つて見れば一種人間的な、本然的な優しい真実な思ひ遣り、さういつたやうなものが、お信さんの胸から、ぢかに熱々と感ぜられたのであつた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たがいに堅く二世を誓い合って、放しませぬ離れませぬと熱々の間柄である。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家で馴染に成ったのか、と重ねて訊きますと、ええそうよ、今は迚も大熱々の最中よ、フリのお客なんかテンデ寄せ付けないわ、貴方、一眼惚れ？",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "「岡惚れどころじゃない、大熱々のコンコンチキよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大熱々だらうよ、念のため行つて聽いて見るもいゝが、――金費ひがどんな鹽梅だか、そいつが一番大事だぜ」「それぢや親分」　八五郎は飛んでしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大熱々だろうよ、念のため行って聴いてみるもいいが、――金費いがどんな塩梅だか、そいつが一番大事だぜ」「それじゃ親分」　八五郎は飛んでしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "大熱々なのぼせ方である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西門慶も熱々に通ってくるが、むしろ金蓮こそ今は盲目といっていい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々この安道全は、医者の女好きという方で、建康府の花街には、大熱々となっている妓がある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三日目の黄昏前、君枝がさすがに浮かぬ顔をして下足の番をしていると、「えーうどんの玉アあつあつのお玉ちゃん白い着物きて朝から晩まで湯にはいりつるつるの肌した別嬪ちゃんのお玉ちゃん十オあって五銭」　と触れ歩いている声がきこえ、よく聴くと他吉の声だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳やという小料理屋がありますからね、先生、このごろは柳やのおステさんと大あつあつで、いりびたりだ、かなわねえ」　駅へ行き、切符を買い、東京行きの省線に乗り、阿佐ヶ谷で降りて、北口、約一丁半、金物屋さんのところから右へ曲って半丁、柳やは、ひっそりしていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たったいまお帰りになりましたが、大勢さんで、これから西荻のチドリのおばさんのところへ行って夜明しで飲むんだ、とかおっしゃっていましたよ」　私よりも年が若くて、落ちついて、上品で、親切そうな、これがあの、おステさんとかいうあのひとと大あつあつの人なのかしら。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清「アアあの人に大あつあつヨ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで、はたちの青年のやうに、恋にあつあつなんです。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたがい大あつあつだった頃にや、仲よく遊び※りもしたし、秋の夜長をしんみり語り明かしたこともあるじゃねえか。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアの女はまず大抵、作家を手に入れる前に、自分のほうが首ったけの大あつあつになっちまう。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれていないばかりか　にやにやしながら　あつあつの　お茶が　入った　カップを　そのまま　きつねめさんに　なげつけてきました。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、このびんには毒の印はなかったので、アリスが味見してみると、とってもおいしくて（なんと風味はサクランボのタルトにカスタード、パイナップルからローストチキンとキャラメル、あつあつのバタートーストまでがいっしょになったみたいで）あっというまに飲みきっちゃった。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、このびんには〈毒〉の印はなかったので、アリスが思い切って味見してみると、とってもおいしくて（なんと風味はサクランボのタルトにカスタード、パイナップルからローストチキンとキャラメル、あつあつのバタートーストまでがいっしょになったみたいで）あっというまに飲みきっちゃった。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
