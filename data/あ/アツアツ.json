[
  {
    "uuid": "c3ccb6fb-b5bb-5509-9b2f-6423c8a6b8be",
    "entry": "熱々",
    "reading": {
      "primary": "あつあつ",
      "alternatives": [
        "アツアツ",
        "あっつあつ",
        "あっつあっつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
