        "examples": {
          "standard": [
            {
              "text": "私は毎日亜剌比亜について考えている。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は亜剌比亜の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には亜剌比亜が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは亜剌比亜について学習した。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は亜剌比亜の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では亜剌比亜が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に亜剌比亜という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では亜剌比亜についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると亜剌比亜は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では亜剌比亜が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に亜剌比亜は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により亜剌比亜の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "亜剌比亜は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に亜剌比亜は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "亜剌比亜式の平べったい煉瓦積み（煉瓦は板壁にペンキで描いたもの）に、カーキー色と赤のダンダラの日除けを張りまわしているのがある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亜剌比亜の医師カアシッシュの不思議なる医術上の経験」といふ尺牘体には、基督教の原始に遡りて、意外の側面に信仰の光明を窺ひ、「砂漠の臨終」には神の権化を目撃せし聖｜約翰の遺言を耳にし得べし。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亜剌比亜の医師カアシッシュの不思議なる医術上の経験」といふ尺牘体には、基督教の原始に遡りて、意外の側面に信仰の光明を窺ひ、「砂漠の臨終」には神の権化を目撃せし聖約翰の遺言を耳にし得べし。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖｜亜剌比亜馬とは何んな馬をいふのか、一向｜区別がつかず、骨牌の切札とはどんなものか、それも知りもしなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心は神戸から自分を乗せて駛って来た仏蘭西船へ行き、あの甲板の上から望んで来た地中海へ行き、紅海へ行き、亜剌比亜海へ行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仮屋の前の厩には二百四十頭の牝馬が繋いでありましたが、わけても殿下の亜剌比亜産に配せた三十四頭の牝馬と駒とは人目を引きました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亜剌比亜の沙漠に悪疫あり、奔馬して一瞬に人体を壊る。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及、亜剌比亜、羅馬などにも、喫煙の俗ありしと云ふは、青盲者流のひが言のみ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第十巻の終りに Terminal Essay が附いてゐて、此の物語の起源、亜剌比亜の風俗、欧羅巴に於ける訳本等が精しく討究されてゐる。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に亜剌比亜並びに東方諸国の風俗に関する論文は、学術上の貴い研究資料であると共に、専門家ならぬ者にも頗る興趣あるものである。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、亜剌比亜人の形容を其儘翻訳して居るのに非常に面白いものがある。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば Shahriyar 王の妃が黒人の男を情夫にする条の註を見ると、亜剌比亜の女が好んで黒人の男子を迎へるのは他ではない。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜剌比亜人の penis は欧羅巴人のよりも短い。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の為めに亜剌比亜女が黒人を情夫に持つのであるといふ類である。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の破れ目から怪我をしないように、手を突込んで、注意して調べてみると、全部で五冊に別れていて、その第一頁ごとに赤インキの一頁大の亜剌比亜数字で、、、※と番号が打ってある。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来ウイチグスという人は、亜剌比亜・希臘の科学を呼称したシルヴェスター二世十三使徒の一人なんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の外側には、アカンサスの拳葉で亜剌比亜模様が作られている、古風な鉄柵縁が張り出されてあった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん、俺が何んで知る」「亜剌比亜草よ、亜剌比亜草だ、絶対に日本には無い花だ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名付けて亜剌比亜麻尼と云う。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもあれは昔に返して、亜剌比亜の沙漠の神殿の奥へ、封じ込まなければならないのだよ」　こう云ったのは若い方の武士で、その云い方には特色があった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マホメットという人物を宗祖として、近東｜亜剌比亜の沙漠の国へ興った、非常に武断的の宗教の、教主であるということであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜剌比亜をご存知なので」「いかにも某存じております」「ふうむ」と老武士は呻き声を上げたが、すぐに、そいつを引っ込ませると、別のことを云い出した。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのはカアバというこの文字の意味は、亜剌比亜のメッカ市に存在する、回教の殿堂の名なのであるから。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に壁の合間などに、波斯織りだの亜剌比亜織りだのの、高価らしい華麗な壁掛けなどが、現代の眼から見る時には、ペンキ画ぐらいしかの値打しかない――しかし享保の昔にあっては、谷めて高雅に思われるところの、油絵の金縁の額などと一緒に、物々しくかけられてあるのであるから、見る人の眼を奪うには足りた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……亜剌比亜から渡って来た何かであろう。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、焙り出されかけた家の子供等は、「水」と云ふものに、原始アラビア人が覚えた程も、驚異と礼讚の念を抱くやうになつたのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアの詩にも十五種ほどもミーターの種類があるらしいが、その中でも十五、十五の連続あるいは八、八、八、八の連続などは乱暴に読めば短歌風に読まれなくはない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ｇｒの代わりにｇｄを取ってみると、アラビアの動詞 ghadiba（怒り）の中に見いだされる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアでは「ひどく怒らせる」が 〔gha_za〕 である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
