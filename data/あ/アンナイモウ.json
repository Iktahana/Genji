        "examples": {
          "standard": [
            {
              "text": "私は毎日案内申について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内申という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内申の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内申が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内申を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内申について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内申の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内申の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内申が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内申という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内申という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内申についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内申を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内申は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内申について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内申が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内申は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内申の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内申は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内申は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "客が足を洗ッてしまッて、まだふききらぬうち、主人は、『七番へご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六番さんのお浴湯がすんだら七番のお客さんをご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の所へご案内申しあげましょう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さあ、それではご案内申しましょう、どれ、ちょうど私も米を磨ぎに参ります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺までいらっしゃいます前には、あの、まあ、伊勢へおいで遊ばすお方に、山田が玄関なら、それをお通り遊ばして、どうぞこちらへと、お待受けの別嬪が、お袖を取るばかりにして、御案内申します、お客座敷と申しますような、お褥を敷いて、花を活けました、古市があるではござりませぬか。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一所においでなさい、御案内申しませうから。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて、洲崎だの、仲町だの、諸入費の懸かる場所へは、強ひて御案内申さないから、讀者は安心をなすつてよい。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……右は、といふうちに、――豫め御案内申しましたつけ、仲の町正面の波除へ突き當つたと思召せ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「――三密の月を澄ます所に、案内申さんとは、誰そ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "路をいそぐと一旦はお斷りなされましたを、無理にねがうて御案内申しました。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちもまゐつて御案内申せ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御婦人を、旦那――帳場で、このお座敷へ御案内申したのでございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに御案内申します。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御案内申し上げます。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方もね、実は、お景物にお目に掛ける、ちょうど可いからッて、わざと昨夜も、貴方を隣桟敷へ御案内申したんです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さあ、其では御案内申しませう、どれ、丁度私も米を磨ぎに参ります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまここまで出てまいりましたのは、大空の神のお子さまがまもなくおくだりになると承りましたので、及ばずながら私がお道｜筋をご案内申しあげたいと存じまして、お迎えにまいりましたのでございます」とお答え申しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お風呂へ御案内申しませう」　その声に彼は婢を見返りて、「ああ、姐さん、この花を那裏へ持つて行つておくれでないか」「はあ、その花で御座いますか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ當る所あり、御案内申さむといふに、導かれて、再び白雲山に上る。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にや、案内申さむか』と云へば、『腹減りたり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『明日金精峠を越ゆ』と云へば、『御案内申さむ』といふ。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしが御案内申しまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからわたくしが肩にかけ又ある時には路ゆく百姓の馬の背を借りて、ようようこれまで御案内申しました。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物知りの夜光命も、これには驚くかと思ひの外、『報知新聞の受賣か』と素破拔かれて、裸男大いに器量を下げたるが、『好し／＼、さらば、世間に知れざる櫻の名所案内申さむ。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "参られたならばねんごろに御案内申せとの御伝言でござりますゆえ、手前これより御案内申しまするでござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼じゃが、こちらからご案内申せ」　待ちきっていたとみえて、あわただしい声といっしょに、その三庵がうろうろしながら取り乱した顔をみせると、おろした駕籠を内玄関のほうへ回させて、そのまま人の目にかかるのを恐れるようにあたふたと招じあげました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
