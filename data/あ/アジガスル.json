        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この汁は丁度｜椰子の汁のような味がするそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時宅から持って行った葡萄酒やベルモットを試みに女中の親父に飲ませたら、こんな珍しい酒は生れて始めてだと云ってたいそう喜んだが、しかしよほど変な味がするらしく小首を傾けながら怪訝な顔をして飲んでいた。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、玉が溶けたと思う酒を飲んだら、どんな味がするだろうねえ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ただ一口試みられよ、爽な涼しい芳しい酒の味がする、）と云うに因って、客僧、御身はなおさら猶予う、手が出ぬわ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか変な味がするもんですよ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろそっくり、あぶらののった、こひつじというところだが、さあたべたら、どんな味がするかな。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩っぱい味がする……重曹の味だけだ。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、玉が溶けたと思ふ酒を飲んだら、どんな味がするだらうねえ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮には少し酸味を含んで丁度香竄葡萄酒を飲んだやうな味がする。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつきりと描いて放つて置いたやうに、何とも言ふに言はれない好い味がするのである。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか馬鹿みたような味がする。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども三四郎にはただ西洋料理の味がするだけであった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「変に白くてすっぱいものよ」「へえ、だって初恋の味がするっていうじゃあないの、初恋はそんな？",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠がまだ故郷にゐた時、姉や友達につれられて、山へ椎の實を拾ひに行つたことが度々あるが、その椎の實の味を思ひ出す樣な味がする。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは箱根風で寒いとは思はないが、生薑の味がする。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、芸州仁方から来て居た書生、三刀元寛と云う男に、鯛の味噌漬を貰て来たが喰わぬかと云うと、「有難い、成程｜宜い味がすると、悦んで喰て仕舞て二時間ばかり経てから、「イヤ可愛そうに、今喰たのは鯛でも何でもない、中津屋敷で貰た河豚の味噌漬だ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の方は、鼠の肉に猫の味がするから、そんな鼠を食うよりも餓え死をした方がいいと言います。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか馬鹿見た様な味がする。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども三四郎にはたゞ西洋料理の味がする丈であつた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎がどんな味がすると聞くと、森本はよく思い出せないが、何でも魚肉と獣肉の間ぐらいだろうと答えた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の歌では、「待てど来まさぬ」の句に中心感情があり、同じ句は万葉に幾つかあるけれども、この句はやはりこの歌に専属のものだという気味がするのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の家のは別製だから一つ試み給え」客は早速｜賞翫し「なるほど格別の味がする。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうです、これは一種異様の味がするでしょう。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな味がするか、僕にもちょっと吸わせてください」「いや、いけない！",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの脳みそは、まるで、おしつぶされた林檎みたいだ」　といったが、林檎の味がするのも道理である。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウモウとケムがでてサンマの味がするんだろう」「いえ、あれはね、去年はヤナがはじめての仕掛けですからちょっとの出水でしょっちゅうこわれてアユがとれなかったんです。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なる程これはうまい、甘薯のうまいのは、ほくほくして栗の味がする、この間のおいらんとは全く別な味だ、これは何という種類です」　力さんが答えていう。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヘンゼルはうんと高く手をのばして、屋根をすこしかいて、どんな味がするか、ためしてみました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっと、きみのそのうすっぺらな舌を、窓からだしたときのような味がするだろうぜ。",
              "citation": {
                "source": "ネコとネズミのいっしょのくらし",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
