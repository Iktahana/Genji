    },
    "definitions": [
      {
        "index": 1,
        "gloss": "red face",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "五十近いでっぷり肥った赤ら顔でいつも脂ぎって光っていたが、今考えてみるとなかなか頭の善さそうな眼付きをしていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山は二十五か六という年輩で、丸く肥えて赤ら顔で、目元に愛嬌があって、いつもにこにこしているらしい。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀杏返は赤ら顔で、白粉を濃くして居た。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ふと、汗ばんだ赤ら顔の、元気らしい、若いのが、唇をしめて……真顔に成つて、「然うだ、然うだ、思ひつけた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥った赤ら顔の快活そうな老西洋人が一人おり立って、曲がった泥よけをどうにか引き曲げて直した後に、片手を高くさしあげてわれわれをさしまねきながら大声で「ドモスミマシェン」と言って嫣然一笑した。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奴の間夫だか、田楽だか、頤髯の凄まじい赤ら顔の五十男が、時々長火鉢の前に大胡坐で、右の叔母さんと対向になると、茶棚｜傍の柱の下に、櫛巻の姉さんが、棒縞のおさすり着もの、黒繻子の腹合せで、襟へ突込んだ懐手、婀娜にしょんぼりと坐っているのが毎度と聞く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とも云わるる、青ぺらの鍔を※り上げて、引傾げて剥いで見せたは、酒気も有るか、赤ら顔のずんぐりした、目の細い、しかし眉の迫った、その癖、小児のような緊の無い口をした血気｜壮の漢である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔の大入道の、首抜きの浴衣の尻を、七のずまで引めくったのが、苦り切ったる顔して、つかつかと、階を踏んで上った、金方か何ぞであろう、芝居もので。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人、袷の引解きらしい、汚れた縞の単衣ものに、綟綟れの三尺で、頬被りした、ずんぐり肥った赤ら顔の兄哥が一人、のっそり腕組をして交る……　二人ばかり、十二三、四五ぐらいな、子守の娘が、横ちょ、と猪首に小児を背負って、唄も唄わず、肩、背を揺る。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨組の逞ましい、この女の足袋は、だふついて汚れていた……赤ら顔の片目｜眇で、その眇の方をト上へ向けて渋のついた薄毛の円髷を斜向に、頤を引曲げるようにして、嫁御が俯向けの島田からはじめて、室内を白目沢山で、虻の飛ぶように、じろじろと飛廻しに※していたのが、肥った膝で立ちざまにそうして声を掛けた。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト挨拶をしそうにして、赤ら顔に引添って、前へ出ると、ぐい、と袖を取って引戻されて、ハッと胸で気を揉んだ褄の崩れに、捌いた紅。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔は見免さない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人｜発奮をくって、のめりかかったので、雪頽を打ったが、それも、赤ら顔の手も交って、三四人大革鞄に取かかった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と赤ら顔はいよいよ赤くなって、例の白目で、じろり、と一ツずつ、女と、男とを見た。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まだ二人ともなにも言わなかった時、連と目配せをしながら、赤ら顔の継母は更めて、男の前にわざとらしく小腰、――と云っても大きい――を屈めた。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔は悪く切口上で、「旦那、どちらの麁※か存じましないけれども、で、ございますね。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔も足も動かさなかった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の小さい、赤ら顔のデップリとした小男で、額の上に禿げ残った毛を真中からテイネイに二つに分けて、詰襟の白い洋服を着ていたが、トテモ人のいい親切らしい風付きで、悪魔らしいところはミジンも見えなかったのでガッカリしてしまった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によって飲こしめした、朝から赤ら顔の、とろんとした目で、お蔦がそこに居るのを見て、「おいでなさい、奥様、へへへへへ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人、骨組の厳丈した、赤ら顔で、疎髯のあるのは、張肱に竹の如意を提げ、一人、目の窪んだ、鼻の低い頤の尖ったのが、紐に通して、牙彫の白髑髏を胸から斜に取って、腰に附けた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『御緩り様で、』と左側の、畳五十畳計りの、だゞつ広い帳場、……真中に大な炉を切つた、其の自在留の、ト尾鰭を刎ねた鯉の蔭から、でつぷり肥つた赤ら顔を出して亭主が言ふ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔して旅語る商人ふたり。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と赤ら顔の車輛会社のＳ爺さんがひょろりとやって来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄逸な反り型の赤ら顔だが、どこかに俗っぽい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしには商用があるのなんのと云って置いて、囲物なんぞを拵えて」鼻の低い赤ら顔が、涙でって、末造の顔を見ていたが、ずっと傍へいざり寄って、金天狗の燃えさしを撮んでいた末造の手に、力一ぱいしがみ附いた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥満した、赤ら顔の、八字｜髭の濃い主人を始として、客の傍にも一々毒々しい緑色の切れを張った脇息が置いてある。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔の医者が薬籠を持つてあがつて来た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の上の男は赤ら顔の肩幅の広い若者でのんきらしく煙管をくわえているのも絵になっていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小錦という大関だか横綱だかの白※の肉体の立派で美しかったことと、朝潮という力士の赤ら顔が妙に気になったことなどが夢のように思い出されるだけである。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズは戸を押して個室の方へ入り、ビールを二杯、赤ら顔で白いエプロンの亭主に注文した。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
