[
  {
    "uuid": "192b2738-133b-5c02-a0ff-071204be19a9",
    "entry": "赤ら顔",
    "reading": {
      "primary": "あからがお",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
