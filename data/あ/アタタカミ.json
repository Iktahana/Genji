          ],
          "literary": [
            {
              "text": "どこまでも澄みきっていながら、しかも震いつきたいほどの暖かみを持ったそのしなやかな声は、悲しい物語を、見るように渡瀬の耳の奥に運んできた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒステリーは治つたが、左の口尻がつり上つたきりになつて、底意地悪い顔付に見える母も、頬だけは美しい血の色を見せながら、痩せて蝋のやうな皮膚の色の兄も、跛足でしなびた小さい哲も、家の中に暖かみと繁盛とを齎らす相ではなかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根のさきの感じでは、たしかに、地べたの中にさえ、命と暖かみが、あるようです。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは家具も揃った暖かみのある部屋で、蝋燭が卓上に二本、炉棚に二本、灯されていた。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後ろから、今助けるぞ、という暖かみのある声が聞こえ、同時に褐色のたくましい手が怯えた馬の轡をつかんで、群の外へと引っ張っていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尖がストーブの暖かみで、溶けた雪粉によって湿らされていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はふと右の肩に暖かみを覚えるように思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬の傷々しくこけたために、葉子の顔にいうべからざる暖かみを与える笑くぼを失おうとしてはいたが、その代わりにそこには悩ましく物思わしい張りを加えていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日天気は上々で東向きの壁はさわってみたら内部からでもほんのりと暖かみを感ずるだろうと思われるほど暑くなっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、淡彩に夏草を散らした薄葡萄色の、金紗縮緬の着物の下に、軽く波打っている彼女の肉体の暖かみをさえ、感じ得るように思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白いうちに、なつかしい暖かみができた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯の感じには暖かみがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、淡彩に夏草を散らした薄葡萄色の、金紗縮緬の着物の下に、軽く波打つてゐる彼女の肉体の暖かみをさへ、感じ得るやうに思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒パンである上に、さらに真っくろに焦げつかして、まだ少し暖かみがある。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に人間と人間とが相対しているのだというような、心からの暖かみや深切は見えない。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "背筋のひきしまるような気もちで、人気のない長廊下を来て柵のところの机に、電燈の光を肩から浴びた受付の人の姿を見るとき、人里に近づいた暖かみと安心とを覚え、階段にかかっている円形時計の面を見上げるのであった。",
              "citation": {
                "source": "図書館",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤みを帯びた卵色の地の色と、常緑樹と、軽い水色の空は、風景にふしぎな愛しみと暖かみを与える。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、わたしたちが菜の花を愛するのもさうした祖先の感謝をもつて、心の底に暖かみを感じてゐるのかも知れない。",
              "citation": {
                "source": "菜の花",
                "author": "――春の新七草の賦のその一ツ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ淡水と潮水とが交錯する平原の大河の水は、冷やかな青に、濁った黄の暖かみを交えて、どことなく人間化された親しさと、人間らしい意味において、ライフライクな、なつかしさがあるように思われる。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱手は、自分の暖かみと、益満の暖かみとが一つに融け合うのを感じると、すぐ、次の瞬間、二人の肌も融け合い、二人の血が一つになって、流れているような気がした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は莨を不味そうに吹かして、窓から射す光線の暖かみを身に快く感じていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "西に傾いた弱々しい日脚の、僅かな暖かみを肩先に惜んで、ゆっくり坂を上ってゆくと、左手に、粛條たる平地が一面に日の光りを受けていた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち二人のよろこびが、あたしの冷めきつた心に、いくらかでも暖かみをつたへてくれるだらうと、それを楽しみにしてるの。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "心づくしの湯たんぽが、脚の下からほのかな暖かみを送ってくれるが、上半身の方はだんだん冷えて来る。",
              "citation": {
                "source": "雪後記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手袋を手から出る暖かみを遮断するために用いるのはちょっと面白いが、考えて見るまでもなくすべての防寒具の目的とするところは結局同じことなのである。",
              "citation": {
                "source": "雪雑記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の夜の灯火がところどころに点々と少量の暖かみを滴らした。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは紅色としては感じられないが、しかし白色に適度の柔らかみ、暖かみを加えているのであろう。",
              "citation": {
                "source": "巨椋池の蓮",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作の世界全体に叙情詩的な気分が行きわたり、不幸や苦しみのなかにもほのぼのとした暖かみが感ぜられる。",
              "citation": {
                "source": "藤村の個性",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、何が幸ひになるか分らないもので、此の医者がたいへん親切な暖かみのある老人であつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原氏の感じでいちばん好い所は、どこかぼんやりとした所があつて、それが非常に魅惑的なあたたかみをもつてゐることです。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
