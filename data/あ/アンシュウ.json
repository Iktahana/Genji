        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗愁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗愁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗愁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗愁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗愁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗愁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗愁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗愁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗愁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗愁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗愁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗愁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗愁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗愁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗愁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗愁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗愁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗愁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗愁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗愁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああ　この暗愁も久しいかな！",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という罪のない絵だろうとしばらく眺めていたが、名状の出来ぬ暗愁が胸にこみあげて来て、外套のかくしに入れたままの拳を握りしめて強く下唇をかんだ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ難き暗愁は暫時も自分を安めない。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いがたき暗愁は暫時も自分を安めない。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　それが現実であるかのような暗愁が彼の心を翳っていった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからずつとおれらは逃走してやつて來たのだあの遠い極光地方で　寒ざらしの空の下をみんなは栗鼠のやうに這ひ※つたいつもおれたちの行くところでは暗愁の、曇天の、吠えつきたい天氣があつた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは魚のやうにつめたくなつて目からさうめんの涙をたらし情慾のみたされない　いつでも陰氣な悶えをかんずるああこの噛みついてくる蠍のやうにどこをまたどこへと暗愁はのたくり行くか。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情慾の強い惱みを抑へ、果敢ない運命への叛逆や、何といふこともない生活の暗愁や、いらいらした心の焦燥やを忘れさせ、安らかな安らかな寢臺の上で、靈魂の深みある眠りをさそふやうな、一つの力ある靜かな感情。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふこともない暗愁の浪、浪、浪、浪、浪。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乘客の暗愁とは他なし、此の不祥を氣遣ふにぞありける。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常のように平気の顔で五六人の教師の上に立ち数百の児童を導びいていたが、暗愁の影は何処となく彼に伴うている。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗愁なにごとぞ、夕まぐれ、人はさわさわ、新開のはづれなる坂のあき地にうづくまる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い解きがたい暗愁――それは若い人が恋人を思う時に、その恋が幸福であるにもかかわらず、胸の奥に感ぜられるような――が不思議に君を涙ぐましくした。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経が急にざわざわと騒ぎ立って、ぼーっと煙った霧雨のかなたさえ見とおせそうに目がはっきりして、先ほどのおっかぶさるような暗愁は、いつのまにかはかない出来心のしわざとしか考えられなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために自分に女のないのが餘計に暗愁を増すやうな事もあつたけれど、それでも外に何もないのだから、やつぱりその女を考へずにはゐられなかつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心沈静、暗愁を感じる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十五日発｜奉天赴長春汽車中作万里平原南満洲　　風光潤遠一天秋当年戦跡留余憤　　更使行人牽暗愁「日露の親和がこの汽車中にはじまり、汽車の前進するがごとくますます進展せんことを望む。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は凱旋の将の如く得々として伯父より譲られたる銀側の時計をかけ革提を持ち、「皆様御健勝で」と言うまでは勇気ありしが、この暇乞の語を出し終りたる後は胸一杯、言うべからざる暗愁を醸し生じたり。",
              "citation": {
                "source": "良夜",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は赤彦君のまへに偽を言ひ、心に暗愁の蟠りを持つて※蔭山房を辞した。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心をきない微笑、打ちとけた物腰、一片の危懼もない瞳――その瞳にはただ一人の人のみに話しかけた或る種の暗愁と悪戯を読むことさへできたが――それは恰も彼女自身すら彼と長年の交遊を思ひ信じてゐるのではないかと疑はれるばかりであつた。",
              "citation": {
                "source": "姦淫に寄す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉慾とは違つた場所に、裏日本の潮風につながるやうな暗愁が、暗く、うねりの高い海のやうにひろがり、狂ほしく疼く肉慾を悲しいものに思はせたりした。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや左門は徒らに暗愁にふける余裕はなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年の負担とするにも堪えがたい暗愁を放し得ないのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "払へども尽きぬ暗愁の数々を外にして。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樹下を過る度にわたしは何とも知れぬ暗愁を禁じ得ないのである。",
              "citation": {
                "source": "十年振",
                "author": "一名京都紀行",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの時一種の暗愁の湧くを感じた。",
              "citation": {
                "source": "暗い空",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は、おあいさんかと口に言おうとしたが、心に他の暗愁が萌して言葉を出さずにしまった。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "病的な、暗愁の多い春は去て、淡々として白い夏が来たのだ！",
              "citation": {
                "source": "抜髪",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
