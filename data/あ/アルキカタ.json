    "definitions": [
      {
        "index": 1,
        "gloss": "way one walks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩き方について考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩き方という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩き方の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩き方が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩き方を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩き方について学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩き方の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩き方の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩き方が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き方という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩き方という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩き方についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩き方を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩き方は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き方について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩き方が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩き方は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩き方の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩き方は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩き方は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうしてあの一種特有なアメリカ人の歩き方までを真似ようとするのである。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、彼の歩き方の不器用さは、緩和し、そして今度はさつさと歩いて行きました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の歩き方はまるで子供のやうに怯づ怯づしてゐて、そんな輕快な歩調にはいかにも慣れてゐないやうであつたけれど、それは昔の歩き方の思ひ出で一杯になつてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョク／＼して、外見は、えげつない歩き方をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れはそれを物ともせずに、しつかりした歩き方で堤の上を大跨に歩いた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの歩き方は然し大跨でしつかりしてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、私たちの動き方、歩き方は、ちょうどあの羽ばたきはするが飛ぶことの出来ない牝鶏のようなものだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と獣類との間に身体の構造についてさほどの大差がないのに、人間の体の動かし方や歩き方は獣類に比して、まるで竹馬に乗っかって歩くように（木に竹をついだように）全く不自然にゴツゴツとぎこちなく歩く、そして直ぐ疲れてしまい、かつ歩きぶりが不意気なものだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "望月はうしろからつけていたが、しかし君勇はそれには気づかぬような歩き方であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は小沢が着せてやったレインコートにくるまっていたが、やはりその下の裸を気にしたような歩き方でついて来た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服ではないが、玄関の石段を登って行く歩き方で、「私服だな」　と、すぐ判るものもいた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、信吉が怒って、いなくなっていても構わないという歩き方だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは、人は普通の歩き方をすることはむつかしいのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、書記官長のようにソワソワと歩き、あるものは女官のように歩く、あるものはポーターがいることだけで、もう城門をはいる人間のような優越感を感じてスクリーンの人間の歩き方のように、足が速くなる。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは温泉場の湯治客のように、わざと倦怠な歩き方をする。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一ホテルのような、二流のホテルでも、人は自分の家の畳の上を歩くような歩き方は出来ないのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくこせこせした歩き方だった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、カイは、近所じゅうの人たちの話し方も、歩き方も、まねすることができるようになりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪を怠らず、学問ありげな、れいの虚無的なるぶらりぶらりの歩き方をも体得して居た筈でありますし、それに何よりも泥酔する程に酒を飲まぬのが、決定的にこの男を上品な紳士の部類に編入させているのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩き方が乱調子になって来た青年の姿を見失うまいとして、かの女は嫌でも青年に近く随いて歩かねばならなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微白く見える顔も、肩の恰好も、背たけも、歩き方も、皆懐しい女房であった。",
              "citation": {
                "source": "月光の下",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度比處まで彼の語り來つた時に、やや離れた卓子にゐた一人の記者――その編輯してゐる地方版の一つの大組が遲れた爲めに殘つてゐた――が、何を思つたか、突然椅子を離れて、だらしなく腰に卷いた縮緬の兵子帶の前に兩手を突込み、肩を怒らした歩き方で我々の方に近づいて來た。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "後れがちなのを親分に叱られながら、亭主の男乞食がとき／″＼ぴょんと弾上る腰付や威張ったように細腰を踏み出す例の歩き方を、しくりかえし、とくりかえしてついて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の本堂の屋根棟をむこう側から、ひょっくり烏が跨いで出て、また屋根棟の上へ跳ね上り、屋根棟の歩幅を測りでもするようにこの鳥独特の歩き方をはじめます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古土タダアゲマス」屋根に書いて破目に打付けてあるその露地へ入って行った女は白足袋の鼠色になった裏がすっかり見えるように吾妻下駄の上でひっくらかえす歩き方を繰り返して行く。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐助の自尊心は、ここに到って、アバタのひけ目を補って余りあるくらい満足され、「天下ひろしといえども、この俺より強い者に一人も出会わなかったとは、はてさて弱い奴ばかしが、佃煮にするほどおったものだわい」　と、歩き方も変って来たが、しかし、帰りの道を歩いて帰るのは、いささかおっくうであつた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山ははっとして顔をそむけると、固い歩き方で通路を抜け、省線のプラットの方へ階段を降りて行った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、坂野の細君の芳子も何か狂気じみていた――その証拠には、折角京吉について行った陽子のアパートから、急に飛び出して、呼びとめる京吉の声を雨の背中に聴き残しながら、町角を走って折れたが、やがて気の抜けた歩き方に重くうらぶれていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただにわかに足をうかすようなあるきかたをして縁先へきてしまった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花曇りの下を、丁稚を伴につれて、その眉のあとの青い女房が、「ぬきあし中びねりのあるきかた」で、耳の垢とりの後から、桟橋を渡るのを見た時には、何とも云へずさびしかつた。",
              "citation": {
                "source": "世之助の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
