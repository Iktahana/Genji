        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、頭が痛いについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭が痛い戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭が痛いの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭が痛いという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭が痛いについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭が痛いの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭が痛いに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭が痛いを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭が痛いは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭が痛いは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭が痛いは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭が痛いを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「頭が痛い」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何しろ火鉢に掴まって、しばらく気を静めていると、襖や障子が朦朧と顕れるけれども、坐った当座は、人顔も見えないという始末だからね、余り力を入れて物を見るので、頭が痛いと云うんだよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が痛い……と思いながら私は眼を閉じて夜具を頭から引き冠った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はなあ、あんまり主人に我儘を云ったり、番頭や丁稚を叱りつけたりするから頭が痛いんだぞ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから頭が痛い時はすぐに、主人にこうしてもらえ」　と云ううちに、右の手で岩のような拳固を作って、お神さんの右の横面をグワーンとなぐりつけました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうじゃありませんけど……あたし今夜何だか……頭が痛いようですの……」　父親は平手で顔を撫でまわした。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のどの痛みは、なおったが、こんどは頭が痛い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）（舞台中央まで来て、疲れ果てたる者の如く、かたわらの漁師に倒れるように寄りかかり）ああ、頭が痛い。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（崩れるように、砂の上にあぐらを掻き）ああ、頭が痛い。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が痛い痛いと言っていましたけど。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉に燻る香の匂いと床の間の花の籠った匂いでおまえは頭が痛いといった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が痛いんですから」　母親は別に気にも止めない振りで答えた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が痛くないですか」「そう云われてみると成る程頭が痛いし、胸がすこしムカムカするようだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭が痛いんです」　房枝は真っ青な顔を上げて言った。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭が痛いんですって！",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「父親が帰ってきたら、あなたは頭が痛いと言って、ご自分の部屋へ下がってください。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」頭が痛いといふより他に病気と自称する自分の容体を発表する術はなかつたので、彼は如何にも感傷的な表情をして、道子の荒々しい態度が病人である彼に対しての順当な動作でないぞ、といふやうに、又自分が終日引籠つて居た事に勿体を付けるために、顳※を一本の指先で突いて見せた。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――若しならなかつたら幸ひだが……どうも俺は……あゝ頭が痛い――」「そんなに痛むの？",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘はれると彼は、今日は頭が痛いとか、用事があるからとかとあらぬ口実を造つて断つた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が痛いツて、どう？",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから頭が痛いんだよ。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、風邪がいつまでも尾をひいてゐるやうな氣持で、午後になると惡寒を覺え、やがては顏をまつ赤にして、頭が痛いと言ひ出すのでした。",
              "citation": {
                "source": "道",
                "author": "――ある妻の手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はがつくりして、頭が痛いと云つてゐた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "みさをは眼をさますと、しばらく頭が痛いと言って不機嫌でした。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし神経がつかれたのか、頭が痛い。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云うと、「頭が痛い。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてはめづらしく頭が痛い、散歩、暮羊居で、ラツキヨウを下物にコツプ酒。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は二日も頭が痛いと云つて苦り切つてゐた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私も今朝頭が痛いのよ。",
              "citation": {
                "source": "二人の病人",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お初、お前に頼んでおくがね、みんな学校から帰って来て聞いたら、そう言っておくれ――きょうは父さんが袖ちゃんを休ませたからッて――もしかしたら、すこし頭が痛いからッて。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭が痛いぐらいで学校を休むなんて、そんな奴があるかい。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
