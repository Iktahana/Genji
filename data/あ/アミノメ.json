        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日網の目について考えている。",
              "source": "幻辞"
            },
            {
              "text": "網の目という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は網の目の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には網の目が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "網の目を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは網の目について学習した。",
              "source": "幻辞"
            },
            {
              "text": "網の目の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は網の目の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では網の目が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "網の目という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に網の目という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では網の目についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "網の目を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると網の目は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "網の目について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では網の目が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に網の目は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により網の目の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "網の目は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に網の目は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "風のエネルギーは第一に蚊帳を煽るに費やされ網の目を抜ける時に摩擦で消される。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかけ離れたアフリカへんやアイスランドまでも網の目を広げられる事になってしまうのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち箇々の存在は、その網の一つ一つの網の目である。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは因果の道理は正直に行われているのですが、その因果関係は、前に述べました複雑な網の目のようになっているので、気急な単純な「智」では充分、その原因、結果を突き止めかねるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の茶屋あとの空地を見ると、人の丈よりも高く八重葎して、末の白露、清水の流れに、螢は、網の目に眞蒼な浪を浴びせて、はら／＼と崖の樹の下の、漆の如き蔭を飛ぶのであつた。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　遊軍に控えたのまで手を添えて、搦め倒そうとする糸が乱れて、網の目のように、裾、袂、帯へ来て、懸っては脱れ、また纏うのを、身動きもしないで、彳んで、目も放さず、面白そうに見ていたが、やや有って、狙を着けたのか、ここぞと呼吸を合わせた気勢、ぐいと引く、糸が張った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、虫は大きな黄いろな繭を、網の目ごとにかけはじめました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、網の目の細い戸を、一、二寸開けたと思うと、がっちりと支えたのは、亀井六郎が所持と札を打った笈であった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の天井を八重に渡した調革は、網の目を透してのた打つ大蛇の腹のやうに見えた。",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "其網の目をもるあかりで細かい仮名を読んだ。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにわが国は、こういうふうに外側地震帯及び日本海を走っている内側地震帯の幹線に地方的な小地震帯がたくさんの支線を結びつけているうえに、火山脈が網の目のようになっているから、その爆発に因る地震も非常に多く、従って土地の隆起陥没もまた多い。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小鼻に皺を寄せて、黒子に網の目の筋を刻み、「御都合じゃからお蝋は上げぬようにと言うのじゃ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜道の落人、ありがたい、網の目を抜けたと思いましたが、さあ、それでも追手が掛りそうで、恐い事――つかまったって、それだけだものを、大した御法でも背いたようでね。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の他愛なさに、効無い殺生は留にしやう、と発心をした晩、これが思切りの網を引くと、一面城ヶ｜沼の水を飜して、大四手が張裂けるばかり縦に成つて、ざつと両隅から高く星の空へ影が映して、沼の上を離れる時、網の目を灌いで落ちる水の光り、霞の懸つた大な姿見の中へ、薄りと女の姿が映つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議や、其の天守の壁を透いて、中に灯を点けたやうに、魚の形した黄色い明のひら／＼するのが、矢間の間から、深い処に横開けで、網の目が映るのか凡そ五十畳ばかりの広間が、水底から水面へ、斜に立懸けたやうに成つて、ふわ／＼と動いて見える。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の横の金網の目から、春のシーズンの名残りらしく野球の球が白く往き来しているのが透けて見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には何時の間にか鰯雲が出て、それが網の目のように行当岬の方へ流れていた。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い雲が流れてそれが網の目のようになっていた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網の目のやうな黒い影が体一面にもつれかかつて何処を見ても明るい凉しいものは見えなかつた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い雲が流れてそれが網の目のやうになつてゐた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよ風が小波立てて、沼の上を千条百条網の目を絞って掛寄せ掛寄せ、沈んだ跡へ揺かけると、水鳥が衝と蹴たごとく、芭蕉の広葉は向うの汀へ、するすると小さく片寄る。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "核攻撃を受けて通信線の一部が途絶えても、全面的なコミュニケーションの途絶に陥らないよう備えた、網の目状の〈打たれ強い〉通信網が原点だったと言うのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際、網の目状のシステムには打たれ強い性格があると強調されたことは事実です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと至るところにはりめぐらされた坂村健の美意識の網の目に唾を吐きかけ、これを破ろうとするはずだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖は一帶に唯拭つた如く平らで踏ん込んだ山の脚近くには丁度建て干した網の目のやうな菱形がほのかに水面に現はれて居る。",
              "citation": {
                "source": "彌彦山",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ手網が一杯に水を離れた時には佐渡は網の目から透きとほつ見える。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかに網の目を張った様な落葉樹の枝の煙り渡っているなかに、それこそ眼覚むる様なその段々田が山の襞に沿うて長々と下から上へ作りあげられているのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりおり振り返って見ると、落葉の枝の網の目を透して遥かに遠く富士山の姿が望まれるばかり、他に何もなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十｜浬ほど南下して、最初に上げた渋網には、蟹がモリモリと網の目に足をひっかけて、かかっていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドシ／＼眼の前で網の目から落ちて行く同志を見るのは、可なり淋しいことだつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
