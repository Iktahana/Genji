        "examples": {
          "standard": [
            {
              "text": "私は毎日安南語について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安南語という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安南語の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安南語が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安南語を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安南語について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安南語の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安南語の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安南語が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安南語という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安南語という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安南語についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安南語を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安南語は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安南語について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安南語が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安南語は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安南語の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安南語は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安南語は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "虎は安南語を解し林中にあって人が己れの噂するを聞くという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はマダムＮの質問に答えて、生徒には絶対に漢字を教えないで、一種のローマ字で書き現した安南語を教えているということを、非常な得意で話した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女は勉強家だから、すぐ、仏蘭西語も、安南語も覚えちやふでせう。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に、安南語と仏蘭西語で小さく墨の文字で書いた板も打ちつけてあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーは英語も仏蘭西語も、安南語も達者で、仕事もてきぱきしてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「燈火を、消し忘れたンで、降りて来たンだ」　富岡が、安南語でさゝやくやうに云つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに、軽々と心が解放された気持ちで、床柱に凭れたまゝ、安南語で唄をくちずさんでゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、安南語で歌つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝は受話器を耳にあてて、おおハッチソン君か、と機嫌よく応対していたが、追々すさまじい恐竦の色を浮かべ、安南語で早口に何事かを語り出した。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南語ではキセルをレウといふと、明和二年の奧州漂民の聞いた安南語彙中にみえる。",
              "citation": {
                "source": "キセルの語源",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "サトウ氏の舊考にはこのレウから日本語のラウが出たやうに書いてあるが、實は安南語のレウも日本語のラウも共に安南やカンボチヤに接壤してゐるラオ國の國名から來たものとすべきである。",
              "citation": {
                "source": "キセルの語源",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもペルシャ語だの安南語などいうものは、先生の方が月謝を払っても習ってくれる者がない。",
              "citation": {
                "source": "勉強記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
