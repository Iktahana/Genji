    "definitions": [
      {
        "index": 1,
        "gloss": "to rampage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暴れまわるについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この暴れまわるは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が暴れまわるについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は暴れまわるの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では暴れまわるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から暴れまわるを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも暴れまわるが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では暴れまわるが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも暴れまわるは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも暴れまわるは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で暴れまわるは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に暴れまわるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "暴れまわるの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する暴れまわるの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では暴れまわるの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すると小さい雄は、まるでその玉の番人か何かのように、暴れまわる雌の脚を叱るようにつつくのであった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れまわる妾を何遍も何遍も抱え上げかけては、床の上に取り落し取り落ししたので、そのたんびに妾は気が遠くなりかけたようよ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが博士の気に入らないと、博士はまた八つ当りの体たらくとなり、大暴れに暴れまわるに相違ないからであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、善かれ悪しかれ、かならず老紳士に加担し、騒がしく暴れまわる生活が何よりも好きだから、ちょっと目くばせするか、うなずくかすれば、たちまちにしてサーベルをひきぬくのだ。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに、暴れまわるかしれないからです。",
              "citation": {
                "source": "幽霊船",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラバラッときたら、抜刀して暴れまわる所存だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の愛情は、神さまから離れるときでさえ、あれほど恐ろしい精力で暴れまわる……それは愛の力が神さまの力だつたからですわい。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "バックがますます怒つて暴れまわると、綱が無慈悲にしまつてきて、舌が口からだらりと垂れ、大きな胸はむなしく喘いだ。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア、それから撲る、突く、蹴る、踏む、猛り狂ったように暴れまわるのです。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘利にいれば、川にもぐり、山を駆け、鳥や野獣を追い追われて、自由に、無拘束に、暴れまわることができる。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも狼狽したであろうし、四郎の暴れまわる殺気にも胆を消したとみえ、侍たちは、足も地につかないでいずこへか逃げてしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸をふき甦してからというものは、苦痛にたえかねて暴れまわるので、やむなく、門下たちは帯を解いて、彼の体を戸板にしばりつけ、四隅を持って、葬式のように暗然とあるき出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣鐘も釣鐘堂も引きずッて、そこへと歩いて行きたいように気が逸る、体じゅうの血が暴れまわる。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒浪の中を乗りまわし乗りまわし、鯨のように日本丸は暴れまわる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は女を相手に、あばれまわる事でしょう。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタバタとあばれまわる。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の大艦隊をもって、東京をふみつぶし、関東平野をあばれまわるんです。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一体いつのことでしょうか、あばれまわる怪塔王の秘密は、一つの事件ごとに、だんだんと身のまわりをせばめていくではありませんか。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れる人造人間「うおーっ」　と、ものすごい唸りごえをあげて、人造人間エフ氏は、部屋の中をあばれまわる。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "取っては投げ、取っては投げ、さながら男は無人の境を往くようにあばれまわる。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "にげてしまった」大捜査陣　透明人間があばれまわるのを見ただけでなく、したたかになぐられ、階段からけり落とされて動けなくなるほどの目にあいながら、アダイ署長は、なおも信じられないという顔をしていた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍若無人にあばれまわる鼠の行動を見ると、鼠の家に人間が住まわせて貰っているような心地さえする。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、空家になった校舎の中で、存分にあばれまわることは、彼らの予期しなかった新しい楽しみだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うことをきかずにあばれまわる子供たちの名を、あきずに呼び立てたり、菓子売りのおどけた老人と、わずかなイタリア語で長いあいだじょうだんを言い合ったりして、自分たちの人間的な共同生活をだれが見物していようと、ちっとも気にかけていなかった。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、五十三次をあばれまわる巨盗だ」　私のハラは、きまった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "むらがる剣を雑草ともおもわず、押しかかる槍ぶすまを枯れ木のごとくうちはらって、縦横無尽とあばれまわる怪力は、さながら金剛力士か、天魔神か。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その忍剣が、堪忍をやぶって、鉄杖と鉄腕のつづくかぎり、あばれまわるのであるから、ほッたて小屋どうような狩屋建は片っぱしからぶちこわされ、召捕ろうとする、新手も新手も、猛猪に蹴ちらされる木の葉のように四｜離し、散滅して、手負いの数をふやすばかり。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは淋しさのあまりに親族故旧を誘うこともあり、または人知れぬ腹立ちのために、あばれまわることもしばしばあった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
