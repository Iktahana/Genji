        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "明かり取りのあるところを降りて来ると、見張り番交代に昇って来るミルン氏に逢った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ腰を掛けて茶を飲んでいると、天井の明かり取りのガラス板の上をおおぜいの人が靴を踏み鳴らしながら通る。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子段に近い明かり取り窓の下に、黒天鵞絨の洋服を着た盲目の少女が夕陽の中の鉄棒の影のように立っている。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに明かり取りがあって雪明りが仄かな光を落としている長い長い廊下をいく曲がりかしていちばん奥までやってきたとき、「どうぞこちらへ」　座って女中が襖を開けた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにもあの醜い正面の明かり取りは中門の陰になって見えなかった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背が延び、より冒険を好む歳になると、若いウォードは時折、傾いだ家々や破れた明かり取り窓やぐらつく階段や捻れた手すりや浅黒い顔や言葉もないような悪臭がごった返したこの地区を巡りつつ、サウス・メインからサウス・ウォーターに向かって、湾を行く汽船が今なお立ち寄る船だまりを探した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側で境界を接している二階建ての隣家のこちら側の壁には、階段のスペースの上方に設けた小さな明かり取りの窓があるだけだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわずかな抵当品でもないものかと眼を皿にして梯子段を登つたり降つたりしたが、もとより目星しいものと云つては何一つ在りよう筈もなく、僕の部屋から捕虫網を持ち出すと、何に使ふものかと考へる風で宙に振つてゐたが（その様子は僕が時々あかりとりに飛び込んで来る蛾を追ふ態と同じやうであつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "北向きの、その小さな窓が一つと、ピラミツド型に歪んだ天井裏に二尺四方のあかりとりが開いたが、そんな小さな窓から空を仰ぐと、わけても憐れに満ちた放浪の煙りがもやもやとして、細々と空へ立ち昇つてゆく思ひが切なく、私は細引を曳いて窓板を閉ぢると戸立蜘蛛の有様で穴の底に瞑目するだけだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころはまだ電灯照明を使うことがむずかしかったので、建物の天井にあかりとりの窓をあけなければなりません。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあかりとりのガラス窓を隠すために、見物席のすぐ上に、笠のような小屋根を作ったものです。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス張りのあかりとりなどは、少しも必要がないのです。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のほうには、小さなあかりとりのほか、窓は一つもありません。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかりとりの小窓ばかりで、外をながめるような窓はありません。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根をささえている材木が、そのまま、むきだしになっていて、いっぽうには、あかりとりの小さな窓がついています。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
