        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私と緒方氏とは、ほんの二三度話合っただけの間柄ではあるが、よい小説家を、懸命に努力した人間を、よほどの不幸の場所に置いたまま、そのまま死なせてしまったという事実に就いて、かなりの苦痛を感じている。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、混り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の時間よりも少し早かったので、遠慮のない間柄であるから主人は「ちょっとお待ち下さい」といわせて急ぎの手紙を書き終えてから下へ降りた。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう間柄でありつつも、飽くまで臆病に飽くまで気の小さな両人は、嘗て一度も有意味に手などを採ったことはなかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ位隔てなくした間柄だに、恋ということ覚えてからは、市川の町を通るすら恥かしくなったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく恩地孝氏の紹介によつて私と恭吉氏とは、互にその郷里から書簡を往復するやうな間柄になつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校時代に、鮨屋の娘ということが、いくらか恥じられて、家の出入の際には、できるだけ友達を近づけないことにしていた苦労のようなものがあって、孤独な感じはあったが、ある程度までの孤独感は、家の中の父母の間柄からも染みつけられていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私達はその夜から親しい間柄になったのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど親しい間柄の人にでもなければ、見せるものではない。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喋舌らせようとする方が無理じゃ」「そこで今度は方角を変えて、近所｜隣家や出入りの者の噂から探りを入れてみると、あの斬られた娘のお熊と言うのは、実を言うと先妻の子で、今の母親とは継しい間柄じゃげな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇親の間柄とて案内もなく客間に通って見ると綾子と春子とがいるばかりであった。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野とおぬいさんとの間柄は園が考えていたようではないらしい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父子で身にしみじみと話しこんで顔にとまった蚊が血に飽きすぎて、ぽたりと膝の上に落ちるまで払いもせずにいたという、そういう父子の間柄であったのを思い浮べた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前、千歳が七八つの頃、慶四郎が父の内弟子に来てから、最初のうちは慶四郎は千歳の子守役、千歳が成長するにつれ縁日ゆきの護衛、口喧嘩の好敵手、時には兄妹のような気持にさえ、極めて無邪気な間柄であった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな気心を知り合った人間同志の間柄でも、互いの性質が違い、年齢が違い、教養が違い、その時々の気分や頭の調子に変化のある以上、そう一つことを二人の人が全く同じように了解し合うということは不可能であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれぐれも好き嫌いは自分および自分と同好同志の間柄だけに止めて置き、それによって天下の調和を乱さぬことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三と自分との間柄は、たとえ多少の心の触れ合いがあったにせよ、恐らくそのくらいなことは世間の娘の誰もがもつ結婚まえの記憶であり、結婚後にも何の支障もなく残る感情だけのものではあるまいか。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋にたんのうし生活にたんのうしもうこの上何の動きも必要としない境地に落ちついた間柄に見える。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしいものでも喰べて春の宵をしずかに過そうという水なら淵へ流れ入った間柄と見える。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、湿り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私は櫻木海軍大佐とは面識の間柄で、數年前の事、私がまだ今回の漫遊に上らぬ以前、ある夏、北海道旅行を企てた時、横濱から凾館へ赴く船で面會した時も、談話爰に及んだ時、彼はふと衣袋の底を探つて、昨夜旅亭の徒然に作つたのだと言つて、一｜篇の不思議な新體詩を示された。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな間柄になつて居るとまでは見破ることの出来ないお茶屋の女中や朋輩芸者は「あやちやんは利口ものだ」と云つて感心すると同時に「松村の旦那はちつとも御存じないのかしら」と云ふ様な目付で、男の顔を気の毒さうに見て居ることなどもあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方とかう云ふ間柄になつた初めのことを考へますと、やつぱり訳もなにもなかつたんですわねえ。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方とかう云ふ間柄になつた初めのことを考へますと、やつぱり譯もなにもなかつたんですわねえ。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは高田駄平とて、横浜に住める高利貸にて、得三とは同気相集る別懇の間柄なれば、非義非道をもって有名く、人の活血を火吸器と渾名のある男なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方には能くある習、角川の市郎と冬子とは所謂許嫁の間柄で、市郎が医師を開業すると同時に、めでたく祝言という内相談になっている。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あんまり有名な方じゃありませんから多分御存知ないでしょうけれど――イヤ、でも僕は坊城君とは非常に親密な間柄なんだから、清水って名前位は坊城君からお聞き及びになっていらっしゃるかも知れませんねえ。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも区長と犯人との間柄は、赤の他人以上に無関係です」「しかし君は、そうした犯人に関する意見を、何故に司法主任の馬酔君に話さなかったのですか。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父はそうした旧悪に対する一種の自白心理を利用して私たちを誤魔化そうと試みているので、友丸伊奈子と私とはその実、タネ違いの兄妹とも、従兄妹同志ともつかぬ異様な間柄になっているのではないか……と疑えば疑い得る筋がないでもない位の事であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツネ子と自分とは、一夜だけの間柄です。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
