        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日紫羅欄花について考えている。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は紫羅欄花の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には紫羅欄花が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは紫羅欄花について学習した。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は紫羅欄花の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では紫羅欄花が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に紫羅欄花という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では紫羅欄花についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると紫羅欄花は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では紫羅欄花が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に紫羅欄花は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により紫羅欄花の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "紫羅欄花は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に紫羅欄花は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "岩石のはざまよりは、青き迷迭香（ロスマリヌス）、赤き紫羅欄花など生ひ上りたるが、その巓にはチウダレイクスが廢城の殘壁ありて、猶｜巍々として雲を凌げり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫羅欄花、帽子の帶の縁にさした人柄な前立。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃草、紫羅欄花、罌粟の花、どんなに嫖緻の好い子よりも、おまへたちの方が、わたしは好だ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い迷送香、赤い紫羅欄花、アネモネ、薔薇、そして枝も撓わなミモザ。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、一方には黄楊や、林檎や、梨や、櫻桃等の樹が立ち並び、他方の花壇には古めかしい樣々の花、紫羅欄花や、亞米利加撫子、櫻草、三｜色菫などが青萵や、薔薇やその他樣々な香氣のある草に混つて繁り合つてゐる散歩道を逍遙つて行つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでも時には、さすがに飾電灯ばかりは煌々として雪白の食卓布の上一杯に、紫羅欄花やチューリップ、ダアリアなぞの飾られた広い森閑とした食堂で、たった一人でナイフを動かしている侘しさを身にしみじみと感ぜぬわけにはいかなかった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの婆さんを頼んで使にやると、お極りでにおいあらせいとうを買って来やがる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四年十二月　　あらせいとう人知れず袖に涙のかかるとき、かかるとき、ついぞ見馴れぬよその子があらせいとうのたねを取る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木犀草（レセダ）又はにほひあらせいとう（ヘイランツス）の花など道の傍に野生したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらせいとうの間には、露けき橄欖の葉を織り込めつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こあらせいとう（マチオラ）の花、青き「アネモオネ」の花などにて、風に翻りたる衣を織り成せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子の上には披げた手紙があつて、女の頭へ蔽被さる様に鉢植の匂ひあらせいとうが咲いてゐた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子の上には擴げた手紙があつて、女の頭へ蔽被さる樣に鉢植の匂ひあらせいとうが咲いてゐた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに「あらせいとう」といふ章があつた。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの一種に Sweet Stock（にほひあらせいとう）といふのがあるさうである。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとポオル・モオランの短篇集の題は「にほひあらせいとう」と譯されなくつちやならん。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからね、『タンドル・ストック』は『にほひあらせいとう』さ。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なるほど、さう言はれて見るとそれに違ひないので、私は私の「にほひあらせいとう」説を棄てることにしたが、まだいくらかこの説に未練がないこともない。",
              "citation": {
                "source": "（ポオル・モオランの「タンドル・ストック」）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろはちょうどにおいあらせいとうがパリの市場に出始める季節であった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまえに、お父さんがにおいあらせいとうの栽培をやっていたと言ったが、この花を作るのはわりあいに容易で、パリ近在の植木屋はこれで商売をする者が多かった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "においあらせいとうの季節がすむと、今度はほかの花を作らなければならない。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッケンのお父さんは、においあらせいとうの季節がすむと、七月、八月の祝い日の用意にせっせとかかっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『こんどはにほひあらせいとう（丁子の一種）の花を調べてみやう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "にほひあらせいとうにはそれが六本あつて、長い方の四本は対になつてゐて二本は短い。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "年とつた彼女の頭の上をば、季節の變遷は幾度となく通り過ぎて、それが今では日々の過ぐる如く短かいものであつた‥‥　黒ずんだ、倒れかゝつた壁をした小部落の周圍に、薔薇の藪や、石竹や、あらせいとうなどがあつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
