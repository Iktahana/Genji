        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日漢人について考えている。",
              "source": "幻辞"
            },
            {
              "text": "漢人という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は漢人の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には漢人が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "漢人を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは漢人について学習した。",
              "source": "幻辞"
            },
            {
              "text": "漢人の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は漢人の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では漢人が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "漢人という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に漢人という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では漢人についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "漢人を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると漢人は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "漢人について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では漢人が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に漢人は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により漢人の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "漢人は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に漢人は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "李陵はこの衛律を始め、漢人の降って匈奴の中にあるものと、ほとんど口をきかなかった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、他の漢人同士の間でもまた、互いに妙に気まずいものを感じるらしく、相互に親しく交わることがないようであった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢人のふうをあくまで保とうとするなら、胡地の自然の中での生活は一日といえども続けられないのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢人のいう礼儀とは何ぞ？",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "利を好み人を嫉むこと、漢人と胡人といずれかはなはだしき？",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ漢人はこれをごまかし飾ることを知り、我々はそれを知らぬだけだ、と。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、胡俗の粗野な正直さのほうが、美名の影に隠れた漢人の陰険さより遙かに好ましい場合がしばしばあると思った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸夏の俗を正しきもの、胡俗を卑しきものと頭から決めてかかるのは、あまりにも漢人的な偏見ではないかと、しだいに李陵にはそんな気がしてくる。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代支那の文明は今日の研究では、南種に属する漢人種のものではなく、北種によって創められたものらしいと言われているが、その王道思想は正しく日本国体の説明と言うべきである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この王道思想が漢人種によって唱導されたものでないにせよ、漢民族はよくこの思想を容れ、それを堅持して今日に及んだ。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの漢人に対し共産主義の害毒を日本人に対するように宣伝をしてもどうも余り響かないらしい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは漢人の一員たる気持であらねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族は互に関係しあい、入りまじりあって発展して来るのであって、日本のような狭い土地の上でさえも、海という自由な広い道を通って、人類的にはアイヌ、ツングウス、インド支那、漢人、ネグリート、インドネシアなどがまじりあった民族が今日日本人として栄えている現状である。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "末賢は大和に住し東漢に属した帰化漢人であり、奴加己利も亦、そして加西溢は帰化高勾麗人であった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年の秋、支那人（漢人）が革命を起して、滿人（清朝）より獨立した時の檄文に、漢人實耕。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年秋に、支那人（漢人）が革命を起して滿人（清朝）より獨立した時の檄文に、「漢人實耕、滿奴食之。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢人實織、滿奴衣之」と憤慨の辭を連ねてあるが、かかる事實は決して清朝時代に限つた譯でない。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢狗とは狗同樣の漢人といふ意味で、一錢漢とは一文奴の漢人といふ意味である。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢とは漢族（支那人）のことで、漢狗とは狗同樣の漢人といふ意味、一錢漢とは一文奴の漢人といふ意味である。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "金以前にも辮髮種族が支那内地を占領して、國を建てたことがあるけれども、當時果してその領内の漢人が辮髮したか否かは判然せぬ。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地在住の漢人が、明に辮髮したのは、金以來のことである。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて金の太宗の天會七年（西暦一一二九）に、始めてその領内の漢人に對して、胡服・※髮の令を下した。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "青州の觀察使李の『北轅録』（８）や、宋の樓鑰の『北行日録』（９）等、南宋時代に金へ使した人々の紀行を見ると、金の領内の漢人が、女眞服を着けて居つたことを明記してある。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の章宗の承安五年（西暦一二〇〇）に、女眞人・漢人等の拜儀に就いて議論があつた時、司空の完顏襄が、今諸人袵髮皆從本朝（金）之制。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "是によつても當時金廷の官吏は、女眞人と漢人との別なく、一律に胡服・辮髮したことがわかる。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を天會七年の※髮の令と對比すると、金一代を通じて漢人――少くとも漢人で官吏たる者――の辮髮した事實に就いて、殆ど疑を挾むべき餘地がない樣である。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
