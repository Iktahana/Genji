        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨音について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨音という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨音の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨音が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨音を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨音について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨音の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨音の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨音が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨音という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨音という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨音についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨音を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨音は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨音について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨音が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨音は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨音の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨音は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨音は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "苫に当る雨音を聞きながら一夜を寝苦しく船中に明した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外の雨音はまだ盛に聞えてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外に雨音が聞え出した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘ぎ登る機關車の車輪の響が篠つく雨音の間に絶え絶えに傳はつてくる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は雨音のみ繁い大津の停車場に止まつて、また間もなく動き出した。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時過ぎると、二階へ上って、床の上に身を横たえて竪樋を落ちる雨音を、さみしく聞いていると、美和子が明るい顔で帰って来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりにひとけは一切なく、物音もなくひっそり、あると言えば雨音だけ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々に雨戸をなでる庭の八つ手の大きい葉に、雨音がぴしゃぴしゃときこえるのも、外の暗さを想わせるような夜であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、雨音はきこえない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乗れよ」　トタンを叩く雨音にさからって、高志が躰をななめにし、大声を出した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえも入れ」　ためらっている慶一の尻を叩くように、周囲の草むらや木立を打つ雨音が高くなり、しかたなく、令子がさしかけた布の端に飛びこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨音をぬって、こっちこっち、と叫ぶ男の声がきこえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空訓練で電燈は消されてしまつたので、一杯ひつかけてそのまゝ寝た、夜中に、トタン屋根をたゝく雨音に旅愁を感じた。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は寂しい庭の雨音を耳にしながら、風呂場にしばらくいたが、葉子が来ないのに少し不安を感じはじめた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければザッ、ザッ、気味悪くひどい雨音がする。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、家に臥て静に夜の雨音を聴くようなすがすがしいいい心持がした。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ざあつと云ふ雨音以外に何も変化のない事を知ると、猫はやはり身動きもせずもう一度眼を糸のやうにした。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つ、八つ半、――時はこの雨音の中にだんだん日の暮へ移つて行つた。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は雨音の鳴り渡る中に殆気味の悪い反響を起した。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "光も雨音の高まるのと一しよに、見る見る薄暗さを加へて行つた。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "義父も母も雨音をきいてつくねんとしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨音のなかに眇めるやうな幸福な思ひがりよの胸に走つてくる。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きも帰りもならない、雨音の騒々しさに、ゆき子は、あゝと溜息をついた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の中にまで、雨音は溢れていつぱいに詰りさうだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨樋から溢れるやうな雨音を聞いてゐると、富岡は、一晩ぢゆうでも酒を飲みたくなるのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨音を立てている前の家のトタン葺の屋根のはずれと、そのとなりの家の、燃火のけむりが低く雨の中に流れ出している土壁との間にある空地ごしに扇形にひらいた引込線に、石炭をつんだ無蓋貨車が何輌もつながったまま雨に打たれている。",
              "citation": {
                "source": "無題（十二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも押し潰すような雨音と、何もかも貫き通すような閃光とは、人の心を躍らせます。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　正夫は、雨音も消えるようなしいんとした気持でした。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘にあたるささやかな雨音。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨音だけがしていた。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
