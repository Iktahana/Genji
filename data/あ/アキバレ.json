    "definitions": [
      {
        "index": 1,
        "gloss": "clear autumnal weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "翌朝港内をこめていた霧が上がると秋晴れの日がじりじりと照りつけた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛はしんみりと、　「石松、俺が昔やくざだったから……俺がやくざだったから、お前だけはやくざにしたくなかったんだ」（Ｆ・Ｏ）　三年の月日が流れました――Ｓ＝茶店の表　秋晴れの或る日の事。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明方の發作今日も少し重くエフエドリンを服用したが、この四五日にない秋晴れの穩かな日で割に氣分がいい。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方に於いて、それがもう最後の秋晴れであった。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　書店の二階の食堂で昼飯を食いながら、窓ガラス越しに秋晴れの空をながめていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、カメラをさげて秋晴れの郊外を歩いている人たちはおそらく幾平方センチメートルの紙片の中に全｜武蔵野の秋を圧縮して持って来るつもりで歩いているのであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの青空の中に隣の西洋館の屋根の煙出しが並んで三本あった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは秋晴れである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの日で、病院の庭には、未だコスモスが咲き残っていた。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が本年発表した創作に就いて八篇の力作牧野信一「秋・二日の話」――「或る日の運動」――「悪の同意語」――「貧しき日録」――「環魚洞風景」――「鏡地獄」――「秋晴れの日」――「極夜の記」等であります。",
              "citation": {
                "source": "私が本年発表した創作に就いて",
                "author": "八篇の力作",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子のガラス越しに見える秋晴れの空を蜻蛉の群れが引っ切りなしにだいたい南から北の方向に飛んで行く。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい秋晴れの日に縁側へ出て庭をながめながら物を考えたりするのにぐあいのいいような腰の高い椅子があるといいと思う。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　秋晴れの午後二階の病床で読書していたら、突然北側の中敷窓から何かが飛び込んで来て、何かにぶつかってぱたりと落ちる音がした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス障子越しに庭の楓や檜のこずえが見え、隣の大きな栗の樹の散り残った葉が朝風にゆれていて、その向こういっぱいに秋晴れの空が広がっている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その曲がった脊柱のごとくヘテロドックスなこの老学者がねずみの巣のような研究室の片すみに、安物の籐椅子にもたれてうとうととこんな夢を見ているであろう間に、容赦なく押し寄せる野球時代の波の音は、どこともない秋晴れの空の果てから聞こえてくるであろう。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて十月になったが、からりとした秋晴れの空にはならず、梅雨時のような、じめじめして蒸し暑い日が続いた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一箇月そこで暮して、秋晴れの日の午後、やっと退院を許された。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけると、今朝も拭ったような秋晴れで、となり屋敷の大銀杏の葉が朝日の前に金色にかがやいていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れのうららかな日和にそそのかされて、遁世の法師もどこかへ浮かれ出したのであろう。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れといって、このごろは東京の空もいなかのように深く見える。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度彼が視てゐる海の色は秋晴れの空と和して散漫な眺めではあったが、それは肩に暖かい日光が降り注ぐためでもあった。",
              "citation": {
                "source": "アトモス",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ秋晴れの朝、巷に立って見渡すと、この町も昔とはずいぶん変ったものである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の赤蜻蛉、これがまた実におびただしいもので、秋晴れの日には小さい竹｜竿を持って往来に出ると、北の方から無数の赤とんぼがいわゆる雲霞の如くに飛んで来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために房川の船渡しは十日あまりも止っていたが、九月になって秋晴れの日がつづいたので、ようやく船を出すことになると、両岸の栗橋と古河とにつかえていた上り下りの旅人は川のあくのを待ちかねて、さきを争って一度に乗り出した。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは爽やかな秋晴れの日のことだった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れのうららかな日の朝、四ツ（午前十時）をすこし過ぎたころに、ひとりの男が京橋東仲通りの伊藤という道具屋の店さきに立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "仮面",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　――――――――――　或る秋晴れの日に不図訪れて来た樽野に、床の間に剥製の鶴が飾つてある座敷で青野が話したことの断片――。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月と秋晴れの一ヵ月の午前だけとられたそうだ。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・咲きつづく彼岸花みんな首を斬られてゐる　うつくしい着物を干しならべ秋晴れ・百舌鳥が鋭くなつてアンテナのてつぺん・風のつめたくうらがへる草の葉・秋晴れて草の葉のかげ　九月廿七日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
