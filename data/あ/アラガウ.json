        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日抗うについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "抗うという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は抗うの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には抗うが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "抗うを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは抗うについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "抗うの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は抗うの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では抗うが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "抗うという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に抗うという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では抗うについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "抗うを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると抗うは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "抗うについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では抗うが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に抗うは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により抗うの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "抗うは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に抗うは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何と抗うてみても体験で固めたこの厚い扉のように堅く寂しい男の笑顔に対しては、爪も立たないように思われました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで旦那が、御覧じやした通りの体裁、や、抜けつ潜りつ、こやの軽いのにゃ飽倦ッちゃって、二人とも大汗になって、トド打掴え、掛けたのを外しにかかると、俯向けに倒れながら、まだ抵抗う気だ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼神に横道なし、と云う、情に抵抗う刃はない筈、」　枢をかたかた、ぐっと、さるを上げて、ずずん、かたりと開ける、袖を絞って蔽い果さず、燈は颯と夜風に消えた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "重さに抗ったが、何故か抗う動作が体をしびらしてしまった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの時何者かが矢庭に背後から彼を引っつかむと、彼が抗う暇もなく兇暴なる腕は、彼の首をしめつけたまま忽ち壁に向って押し戻した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "抗うべき術もなくて、言わるるままに持ち合せの衣類取り出し、あるほどの者を巻きつくれば、身はごろごろと芋虫の如くになりて、頓て巡査に伴われ行く途上の歩みの息苦しかりしよ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう勢いになったのは、大夫の詞に人を押しつける強みがあって、母親はそれに抗うことが出来ぬからである。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その抗うことの出来ぬのは、どこか恐ろしいところがあるからである。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂部はもうそれに抗う気力はなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下衆のくせに寄ってたかって、先生方に反抗うなんて、恥知らず奴が……。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前どもがこの旦那衆に反抗うなんて、そんな……。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何うしても貴方に抗う事が出来ませんでした。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二世紀（十五・六世紀、ルネッサンス）というものは権力に抗う人々が『自由意志』の怪しげな主義を築くために費された。",
              "citation": {
                "source": "バルザックについてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆寒さに抗うように赤い顔をしていた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、おまはんどないしても、親に抗うて、森田と一緒にならう言ふんやな？",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒にかけては抗うものがいない。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はそれを強いられる儘に、京を離れるのはいかにもつらかったけれど、しかし自分の余りにもつたなかった来しかたに抗うような、そうして何か自分の運を試めしてみるような心もちにもなりながら、その郡司の息子について近江に下っていった。",
              "citation": {
                "source": "曠野",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、キリーリンが言い寄った頃には、彼女はもう抗う力も気持もなくて、そのまま身を任せてしまったのであった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう訴えにはジョンの正直な心は抗うことができない。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "抗うことの愚かしさ、許しを乞うことの無益さを、その瞬間から彼女は悟った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに若いお前は、田舎のあばら屋でも我慢もできるだろうが、私はどうしても都を離れたくないのだよ」　涙ながらにかきくどく母の言葉には、抗うすべもなく、妓王はいやいや、妹と他の二人の白拍子と連れ立って西八条に出かけていった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポセイドンの波の恵、エウロスの風の力で、8490フリギアの平な野から、抗う高い背に載せて、故郷の入江へ送り込まれた、その間の波の止所のないゆらめきにまだ酔っています。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党がっているお六も、抗う力もなく首を延し上げられて、左の小脇にかい込まれると思う間もなく、薄月に閃く銀簪、あわやお六の右の眼へ――。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "呪いの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言ったものかな」　ガラッ八はまだ腑に落ちない様子ですが、平次にそう言われると、強いて抗うほどの智恵もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "招く骸骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黙っておいで、権助、お前なんかの出る幕じゃない」「まア、そう言ったものさ、ね番頭さん」　それでも権助は、強いて抗う様子もなく、一度に溜飲を下げるとニヤリと人の好い薄笑いを残して、元の庭前へ立ち去りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "匕首は私の品だが、お勢を殺したのは私じゃありませんよ」　抗う猪之松は、馴れた万七の手にたぐり寄せられました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "その種のもの、貴兄に抗う何かを自ら招喚し、よって貴兄の最強力な手段も無効とならん。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お俊はそう言ってきよ子を土手の上へ拉れてくるのだが、きよ子はべつだん母親に抗うこともなく従順に尾いてきて、土手の上であそぶのだった。",
              "citation": {
                "source": "童話",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は鉱滓(*5)に抗い、御神の智慧は人智に抗うのだ！",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "上見ぬ鷲の翔らん天ぎわから地上へかけて雲の帳は相変らずかけ垂れていたが、深まり来るたそがれの色にあらがうように帳の色は明るく薄れ行きつつある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
