        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アタックについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社のアタック戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "アタックの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "アタックという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアタックについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "アタックの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "アタックに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちはアタックを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界でのアタックは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、アタックは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "アタックは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々なアタックを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「アタック」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
