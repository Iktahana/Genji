    "definitions": [
      {
        "index": 1,
        "gloss": "exposure by washing away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い出しについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い出しの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い出しが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い出しについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い出しの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い出しが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い出しという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い出しについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い出しは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い出しが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い出しは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い出しの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い出しは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い出しは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「まだ十分というわけには行きませんが、少しは種を洗い出して来ました」と、多吉は得意らしく云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところに寺の裏門があったのかと、次郎がおどろいていると、君枝は、「ちょっと……」　待っていてくれと言って、境内の隅の地蔵の前にしゃがんで、頭を下げ、そして、備え付けの杓子で水を掛けて、地蔵の足をたわしでしきりに洗い出した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "御免下さい」と、向うは笑いくずれたが、すぐ白いつばを吐いて、顔を洗い出した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人の洗い出したような鮮さが、信一郎の心を、深く深く動かした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い出したような紺青色の空に、眩しい夏の太陽が輝かしい光を、一杯に漲らしていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を洗い出しても、今みてえにあわ食うなよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして風や雨は、私の心の中にある悪辣な部分丈を洗い去り、従って善良な部分を明瞭に表面へ洗い出して呉れたように思えるのであった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の早い新兵衛はもうその一件のあらましを何処からか聞き込んでいたらしかったが、軍右衛門は更にくわしい説明をあたえた上で、なんとかしてかの娘の身許を洗い出してくれないかと膝づめで頼んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、いきなり自暴にそこここ洗い出した。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月に入って仕様検討と並行してシステム設計に着手していた松本たち、マイクロハードの開発チームは、新規に開発すべきＡＳＩＣを洗い出していった★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新規に起こすべきＡＳＩＣをつごう六つ洗い出しながら八月いっぱいをかけて進めていったシステム設計上のポイントは、快適な操作環境を実現するために、グラフィックスの処理能力を徹底的に強化し、磨きをかける点に置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馬琴は黙ってまた、足を洗い出した。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、もう一度手拭を洗い出しながら、柘榴口の方へ歩いて行く馬琴の後ろ姿を見送って、これから家へ帰った時に、曲亭先生に遇ったということを、どんな調子で女房に話して聞かせようかと考えた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかあなた他さまをお借りなすって」　人の好さそうな婆さんは、気の毒そうに頭を下げて、またゴシゴシお皿を洗い出した。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "南町奉行直々の指図で、与力堀江又五郎が采配をふるい、三輪の万七が子分と下っ引を総動員して、転び切支丹と、その一家一族を根こそぎ洗い出し、たった三日の間に、江戸御府内だけで七十八人の切支丹関係者を探し出したのは、大したことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は三村屋へ筋を引く奴を、根こそぎ洗い出してみる」　平次はそう言いながら、ヒョイと板囲いの外を見ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "酒屋火事",
                "note": "青空文庫"
              }
            },
            {
              "text": "友次郎はひどく気を揉んで、綱吉に怨みを持ちそうな人間――と言ったところで、少しでも水茶屋のお常に気がありそうな男を、片っ端から挙げて来て洗い出しましたが、これは少なくない数で、およそ、芝愛宕下界隈の男の切れっ端は、顫え上がったと言ってもいいくらいです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "済みませんが旦那、私が行っては、友次郎兄哥の手柄にケチを付けるようで悪うございますから、誰か人をやって、その女を風呂で洗い出してみて下さいませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いやに「ね」に力をいれ、ここはお前さんたちの出はいりするところではありませんよ、と言わぬばかりの冷たい調子でこたえ、そのまま雑巾をバケツの中でざぶざぶ洗い出した。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "中へ這入って行くと右側の二三軒目の、見事な洗い出しの板塀に囲まれた二階の欄干から、松の葉越しに女は死人のような顔をして、じっと此方を見おろして居た。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのくそ野郎のことを聞かしてくれ、あの野郎はしゃばになにか余罪がありそうだ」と松田は云った、「おめえが知ってることを話してくれれば、あの野郎の正躰を洗い出してやる、どうだぶしゅう、話を聞かせねえか」　栄二はなおも黙っていて、やがて立ちあがり、そのまま長屋のほうへあるきだした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その画にも倦んだらしく、武蔵が筆を洗い出したので、もういっぺん頼んでみようかと、城太郎が唇を舐めてなにかいいかけると、飛石を拾って来る木履の音がして、「お客さま。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、水を汲み上げて、顔を洗い出した。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はむッくり起って水瓶のそばで顔を洗い出した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
