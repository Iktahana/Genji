[
  {
    "uuid": "da9a0656-457c-5fdc-bba7-f1e4b13b034a",
    "entry": "餡餅",
    "reading": {
      "primary": "あんもち",
      "alternatives": [
        "あんも"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mochi rice cake with red bean jam filling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日餡餅について考えている。",
              "source": "幻辞"
            },
            {
              "text": "餡餅という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は餡餅の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には餡餅が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "餡餅を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは餡餅について学習した。",
              "source": "幻辞"
            },
            {
              "text": "餡餅の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は餡餅の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では餡餅が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "餡餅という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に餡餅という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では餡餅についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "餡餅を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると餡餅は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "餡餅について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では餡餅が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に餡餅は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により餡餅の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "餡餅は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に餡餅は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "其れよりも、徹夜の温習に、何よりか書入れな夜半の茶漬で忘れられぬ、大福めいた餡餅を※つたなごりの、餅網が、侘しく破蓮の形で疊に飛んだ。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、徹夜の温習に、何よりか書入れな夜半の茶漬で忘れられぬ、大福めいた餡餅を※ったなごりの、餅網が、佗しく破蓮の形で畳に飛んだ。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろこしと糯米の粉で製したという餡餅などをも持って来てくれる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て居るとも知らず源八は餅を取上げ二ツに割て中の餡を繰出し、餡は餡餅は餅と両方へ積上げまして、突然懐中へ手を突込み暫くムグ／＼やつて居たが、ズル／＼ツと扱出したは御納戸だか紫だか色気も分らぬ様になつた古い胴巻やうな物を取出しクツ／＼と扱くと中から反古紙に包んだ塊が出ました。",
              "citation": {
                "source": "黄金餅",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い提灯をぶら下げた、その屋台で、おじいさんが、鉄板の上に、焼きざましの、しわの寄つた餡餅を並べて売つていた。",
              "citation": {
                "source": "秋の暮",
                "author": "西東三鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもただ空腹をしのぐというだけでなしに、しだいに口をよろこばすという目的がつけ加えられたことは、餡餅なども同じである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
