[
  {
    "uuid": "17538643-8f08-5835-ac8d-9c072bf0039e",
    "entry": "慌ただしい",
    "reading": {
      "primary": "あわただしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "busy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日慌ただしいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は慌ただしいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には慌ただしいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは慌ただしいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は慌ただしいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では慌ただしいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に慌ただしいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では慌ただしいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると慌ただしいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では慌ただしいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に慌ただしいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により慌ただしいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "慌ただしいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に慌ただしいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "汽車の時間が迫ったので、みんな店先で草鞋をはいたところへやっと出来て来たので、上り口に腰かけたまま慌ただしい新春を迎えたのであったが、これも考えてみるとやはり官能的の出来事であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌ただしい復旧工事の際｜足手纏いで邪魔になるお婆さん達が時を殺すためにここに寄っているのかという想像をしてみたが事実は分らない。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそう決心すると同時に、園は心臓がきゅうに激しく打ちだして、顔が火照るまでに慌ただしい心持になっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その良夜の前の二、三時間を慌ただしい旅の心が騒めきやまぬ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもあまりに慌ただしい舟の速力である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の人の世話を焼いたり、人に親切らしい事を言ったりする言語挙動の間に、どこか慌ただしいような、稍不自然な処のあるのを認めるだろう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分慌ただしい旅立になりそうだが」「なに。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあこの世界には、こうした慌ただしい側面がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その慌ただしい中に、地方長官の威勢の大きいことを味つて、意氣揚々としてゐるのである。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起きたのはいつ頃じゃ」「かれこれ四ツ頃でござりました、宵のうち急ぎの用がござりまして、出先からお帰りなされましたところへ、どこからか京弥どのに慌ただしいお使いのお文が参ったらしゅうござりました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "事なし、と思われたお廊下先に、突然｜慌ただしい足音が伝わると、油を取替えにいった茶坊主大無がうろたえ乍らそこに膝を折って言った。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後の、万事に慌ただしい、猫の眼のようにうつりかわる気分に慣れた父兄は、わけもなく胡麻化された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、廊下をばたばた走ってくる慌ただしい跫音がきこえて、外側から扉にどさりともたれかかるような音がした。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事が出ていってからものの五分とたたぬうちに、またもや慌ただしい足音が階段に聞こえて野田をひやりとさせた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした慌ただしい軍備にもかかわらず、一般の人たちは普段と変わらず平静のままであった。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その諾否を、この二つで回答してくれと仰言って……」と彼女は語尾を萎めて、あまりにも慌ただしい、人生の変転を悲しむごとくであった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、あの人は追ひつめられた者の慌ただしい悲しさで私の部屋へ這入つてきて、生きる理由が分らなくなつたと言ひ、こんな滑稽なことを考へねばならない余儀ない気持は苦しいものだと言つたりしたが、呼吸でも苦しくなつたのかネクタイをちぎるやうに引きはづして椅子へ落込んだりした。",
              "citation": {
                "source": "訣れも愉し",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "御達者に暮して下さい」　つづいて私の背中に太郎さんの慌ただしい靴音が起り、私の横へまで走つてきて私と並んで歩き出したのが分つた。",
              "citation": {
                "source": "訣れも愉し",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ慌ただしい情景を描くに当つても作者が慌ててはいけない。",
              "citation": {
                "source": "意慾的創作文章の形式と方法",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都といふところは、二三日の慌ただしい見物でなかつたら、乗物に乗らず、目当のない散歩のつもりで、足の向くままぶらぶら歩くに限るのである。",
              "citation": {
                "source": "醍醐の里",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬、捲き起つた砂煙が徐々にはれると、隅々に張りめぐらされた天幕の内外に、慌ただしい地上勤務兵の活動が見え、着陸点を示す紅白の吹き流しが静かに朝風に翻つて、○○大集団の基地らしい威容を感じさせる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復をいれて三週間といふ慌ただしい旅行ではあつたが、私としては、得難い経験であり、また、深く考ふべき多くの問題を拾つた。",
              "citation": {
                "source": "北支の旅",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か慌ただしい気持が腹の中で燃えた。",
              "citation": {
                "source": "自殺を買う話",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌ただしいノックの音だ。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あす、お土産を買うといっておりましても、何やかやと慌ただしいでしょうから、今夜のうちに、何か買っておかれましたらいいでございましょう。",
              "citation": {
                "source": "両面競牡丹",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、妹に相談すれば、妹は必ず一緒に死ぬと答えるですから、私は慌ただしいことになるでしょう。",
              "citation": {
                "source": "露の答",
                "author": "ぬばたまのなにかと人の問ひしとき露とこたへて消なましものを",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さういふ果敢無さが慌ただしい色情の裏側に、むしろうら悲しくやるせない刻印を押してゐるやうに思はれて、物の哀れとも言ふべきものが、侘しく胸に泌みて来るばかりであつた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も空車を止めて早速にも帰りたいと考へたが、生憎通つた数台の自動車は客を載せて疾走する慌ただしい車で、アッケなくブウンと唸りを引いたまま行つてしまふと、暫時のうちは運悪く右も左も車が途切れて、空虚な侘しい道のみが線路を無気味に光らせ乍ら其処に残つてゐただけであつた。",
              "citation": {
                "source": "群集の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見る間に箒ではきかけるやうなあわただしい雨、私があわてゝ逃げ込んだのは、山の手のとある崖際の家の歌舞伎門であつた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレットのキャラバン、酒場から酒場へ近道の建札、夜の美粧院に吊された青蛙の料理写真にしたらんたん、足の化粧法、日本人を日本人らしく見せない整型学、醜いものをグロテスクにするための進歩主義、あわただしい木馬競走に見惚れる観衆の喝采。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
