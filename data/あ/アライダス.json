    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to reveal by washing the surface",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い出すについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い出すの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い出すが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い出すについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い出すの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い出すが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い出すという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い出すについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い出すは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い出すが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い出すは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い出すの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い出すは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い出すは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "芝居気のねえ野郎だな」と独言ちて、若衆は次の盤台を洗い出す。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、いいのですよ」「なに、男の垢をつけておくことはない」　日本一太郎がそういって、構わず洗い出すとお駒ちゃんは、いやな顔をして、泣き出しそうな声になった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々無雑作に、あれは観念論だ、これは観念論的だと云い勝ちだが、そしてその言葉には或る一定の隠れた体系的な含蓄があるのであって、この含蓄の一部を洗い出すのが今のこの仕事の一部分になるのだが、併しそう批評された当の人間達には、この言葉は必ずしも痛くピンと来るとは限らない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
