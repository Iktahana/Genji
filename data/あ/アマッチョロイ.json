        "examples": {
          "standard": [
            {
              "text": "私は毎日甘っちょろいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘っちょろいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘っちょろいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘っちょろいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘っちょろいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘っちょろいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘っちょろいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘っちょろいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘っちょろいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘っちょろいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘っちょろいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘っちょろいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘っちょろいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘っちょろいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おれはそれほど甘っちょろい男ではないし、それほど彼等と親しくもなかった。",
              "citation": {
                "source": "失われた半身",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "存外にも、甘そうな見かけの物に、甚だ甘からざる何かゞあるもので、恋をする女の心、その眼の深さ冷めたさ鋭さは、表面の甘っちょろい反射本能的な言動などとは比較にならぬものがあるようだ。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が甘っちょろい男だから、こんな大げさな事を考えなきゃならん所に、おっこちるんだ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そいつを甘っちょろい文化主義者共が言っているのが現状だ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘヘ、愛だのなんだの甘っちょろいことよりゃ、憎みの方が、タシカだよ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といういい気な、甘っちょろい兄だろう、と軽蔑してやりたい気にさえなる。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさ、甘っちょろい人道主義と言うのは。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私はこう云ったの、「とにかくさわぐにしろ、家でさわぐというのは、やっぱり家に対して、妻に対して自分の義務を感じているとも云えるので、今時の男が本当に何かやりたいと思って、一々女房の許可を得てやるなんて甘っちょろいものではないのだから、こっちからそんなことにさばける必要はない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらしく先生と書かずに、教師と書いたところに早苗の精いっぱいさがあり、甘っちょろいあこがれなどではないものを感じさせた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと甘っちょろい素人くさい調停者だろう！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の身でそこまで考えなければならないんだ、そういう境遇が現にこの世にあるんだ」と栄二は自分を叱りつけるように呟いた、「――きさまなんかまだあまっちょろいもんだぞ」　東仲町へゆき着くまで、彼は同じことを繰返し考え続け、幾たびも眉をしかめては舌打ちをした。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
