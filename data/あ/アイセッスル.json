[
  {
    "uuid": "b26b522d-ecdc-523c-a7f1-de79e2b44a0f",
    "entry": "相接する",
    "reading": {
      "primary": "あいせっする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
