        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒縄について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒縄という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒縄の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒縄が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒縄を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒縄について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒縄の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒縄の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒縄が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒縄という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒縄という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒縄についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒縄を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒縄は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒縄について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒縄が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒縄は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒縄の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒縄は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒縄は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鋭利な解剖刀のような普遍的法則が、それさえあればこの拷問的の荒縄を涙が出る程切りとばしてばらばらにしてやるのに。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は二十三四で、どこかの武家屋敷の中間らしく、帯のうしろには木刀をさしていたが、両腕を荒縄で固く縛られて、両足を投げ出して、銀杏の木の根につながれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と荒縄の綱を引く。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」往来を、大きなカボチャを三つ荒縄でくくって背負い、汗だくで歩いているおかみさんがある。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ夏にもならぬのに裾縫の切れた浴衣一枚を荒縄の帯で纏うた、真黒い素跣足。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲殺して占め損い、遁げんとして馬丁に見露され、書生のために捕えられて、玄関に引摺込まれし、年老いたる屠犬児は、破褞袍を衣て荒縄の帯を〆め、踵の辺は摺切れたる冷飯草履を片足脱ぎて、花崗石の上に平蜘蛛。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）宅膳　黒牛の背に、鞍置かず、荒縄に縛める。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、」　民弥は、思出したように、室の内を※しながら、「烏金……と言えば、その爺婆は、荒縄で引括って、烏の死んだのをぶら下げていたのよ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に荒縄の太いので、笈摺めかいて、灯した角行燈を荷ったのは天狗である。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う傾けに草へ倒して、ぐるぐる巻というよりは、がんじ搦みに、ひしと荒縄の汚いのを、無残にも。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、踞んで、毛虫を踏潰したような爪さきへ近く、切れて落ちた、むすびめの節立った荒縄を手繰棄てに背後へ刎出しながら、きょろきょろと樹の空を見廻した。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "、）と荒縄の綱を引く。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒縄持ちて来らずやと手をたゝくに、最前の逞ましき寺男、勝手口より落付払ひて、のそ／＼と入り来り、改めてわれに一礼し、柄杓の水を茶碗に取りてわれにすゝめ、和尚の死骸を情容赦もなくクル／＼と菰に包み、荒縄に引つくゝりて土間へ卸しつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この松浦愚と自分は大の仲好しで、二人で醤油買いに行くのに、わざと二本の太い荒縄で樽を釣下げて、その二本の縄の端を左右に長々と二人で引っぱって樽をブランブランさせながら往来一パイになって行くと往来の町人でも肥料車でも皆、恐ろしがって片わきに小さくなって行く。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中の三角になった木馬に跨らせられて腰に荒縄を結び、その荒縄に一つ宛、漬物石を結び付けてダンダン数を殖やすのであったが、頭山も進藤も実に強かった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の先の天井裏からは荒縄で縛った生鰤の半身が、森閑とブラ下っているが、無い袖は振られぬ理窟で、五合桝を中に置いて涙ぐましく顔を見交しているところへ天なる哉、小雨の降る居酒屋の表口に合羽包みの荷を卸した一人の棕梠箒売が在る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、裃紋附の上に荒縄をかけられ、刑場へ引かれたが、この時、松陰は同囚等への告別のつもりで、自筆の「留魂録」の冒頭の歌、身はたとひ武蔵の野辺に朽ちぬとも　　　留め置かまし大和魂　と、次の辞世の詩、「吾今為国死。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の左右と真中へ、草の中に、三本の竹、荒縄を結渡したのが、目の前を遮った、――麓のものの、何かの禁厭かとも思ったが、紅紙をさした箸も無ければ、強飯を備えた盆も見えぬ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "履物が無かったばかり、髪も壊れず七兵衛が船に助けられて、夜があけると、その扱帯もその帯留も、お納戸の袷も、萌黄と緋の板締の帯も、荒縄に色を乱して、一つも残らず、七兵衛が台所にずらりと懸って未だ雫も留まらないで、引窓から朝霧の立ち籠む中に、しとしとと落ちて、一面に朽ちた板敷を濡しているのは潮の名残。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七兵衛はのような足つきで不行儀に突立つと屏風の前を一跨、直に台所へ出ると、荒縄には秋の草のみだれ咲、小雨が降るかと霧かかって、帯の端｜衣服の裾をしたしたと落つる雫も、萌黄の露、紫の露かと見えて、慄然とする朝寒。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな荒縄で幾重にも厳重に引っくくるのだから、地蔵さまも遣り切れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵さまの尊像は高さ三尺ばかりで、三間四方ぐらいのお堂のなかに納まっていましたから、雨かぜに晒されるようなことは無かったのですが、荒縄で年中ぐいぐいと引っくくられるせいでしょう、石像も自然に摺れ損じて、江戸末期の頃には地蔵さまのお顔もはっきりとは拝めないくらいに磨滅していました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は荒縄で厳重に縛られているのです」「縛られ地蔵に女が縛られている……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死体は石地蔵をうしろにして、両足を前に投げ出し、あたかも地蔵を背負ったような形で、荒縄を幾重にも捲き付けてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それを制作台の上に据ゑると彼は、主柱を心棒にして、其処に形造られるべき私の姿を、指先を持つて想像した後に、今度は荒縄を水に浸して、壁に向つて、サツと切つた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此一本の支柱は私の脊髄に該当し、螺旋状に巻かれた荒縄は私の内臓器官と神経系統に相当する――と私は想像したのである。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
