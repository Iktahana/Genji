        "examples": {
          "standard": [
            {
              "text": "私は毎日アンチテーゼについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンチテーゼの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンチテーゼが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンチテーゼについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンチテーゼの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンチテーゼが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンチテーゼという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンチテーゼについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンチテーゼは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンチテーゼが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンチテーゼは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンチテーゼの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンチテーゼは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンチテーゼは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "またかつて藤原博士が私に話されたように、古来の大家によって夢想されて来た熱力学第二法則のアンチテーゼのようなものも渦の観察から予想されなくはないのである。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エキスパンドブックが私達の前に提示してみせてくれている可能性は、不幸にして『個人でも手軽に本が作れる』という部分を抜きにして、発達していっている日本のＤＴＰに対するアンチテーゼだと思っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはマルクス派文学に対するアンチテーゼである。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学派はこれで見ると明確にマルキシズム文学のアンチテーゼとしての自己をまだつくり上げないで、それを摸索しているのだ。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この遊離のアンチテーゼとしてあらわれる類型がここに最後に残ってくるのである。",
              "citation": {
                "source": "知識と政治との遊離",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は必ずしも社会を国家の上に置こうとはしなかった、処がそうしない限り、実はヘーゲルのアンチテーゼにもジュンテーゼにも立つことが出来ない。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの火の哲学者を調べると、彼の熱および蒸気の学説およびそれらにたいするアンチテーゼは、何世紀にもわたって医術に影響した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
