        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝寒の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "秋の野分しば／＼して、睡られぬ長き夜の、且つ朝寒く――インキの香の、じつと身に沁む新聞に――名門のお嬢さん、洋画家の夫人なれば――衣絵さんの（もう其の時は帰京して居た）重態が、玉の簾を吹ちぎり、金屏風を倒すばかり、嵐の如く世に響いた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども札幌では十分朝寒といっていい時節になった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒がその頬に紅をさして、白い歯なみが恥ずかしさを忘れたように「ほほえみの戸口」から美しく現われていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒が私に咳を強ひた。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも晴れたれど朝寒し。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "・最後の飯の一粒まで今日が終つた・朝寒の針が折れた　　　入庵一週年ちかし・蓼の花もう一年たつたぞな　　　追加備忘・道がなくなり落葉しようとしてゐる・水に水草がびつしりと旅・たゞあるく落葉ちりしいてゐるみち　九月十一日―十月一日　『行乞記』",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、つまみ菜、ちがへ菜、そろへ菜、たばね菜と、大根のうろ拔きの葉、露も次第に繁きにつけて、朝寒、夕寒、やゝ寒、肌寒、夜寒となる。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七兵衛はのような足つきで不行儀に突立つと屏風の前を一跨、直に台所へ出ると、荒縄には秋の草のみだれ咲、小雨が降るかと霧かかって、帯の端｜衣服の裾をしたしたと落つる雫も、萌黄の露、紫の露かと見えて、慄然とする朝寒。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶柳条のフラネルの単衣に朝寒の羽織着たるが、御召｜縮緬の染直しなるべく見ゆ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶屋の座敷に上って見ると、もう玄適と良沢とが、朝寒の部屋に火鉢を囲いながら向い合っていた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然がその内ぶところに秘めてゐる孤独感が、をりからの朝寒夜寒に凝り固まつて咲いたらしい、この花の持味は、自然の使者として、その閑寂と侘心とを草庵にもたらすのに充分なものがあらう。",
              "citation": {
                "source": "侘助椿",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨川の水にも痩せが見えて、河原の柳は朝寒に身ぶるいしながら白く衰えた葉を毎日振るい落した。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然がその内ぶところに秘めてゐる孤独感が、をりからの朝寒夜寒に凝り固まつて咲いたらしい、この花の持味は、自然の使者として、その閑寂と柁心とを草庵にもたらすのに充分なものがあらう。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水量がぐつと落ちた川尻の塩と淡水との入り交るあたり、朝寒夜寒のきびしさに、ともすれば季節が後退りしようとするこの四五日、芦の切株に張りつめた薄氷のなかから、逸早くも春をめざして躍り出さうとする小さな生命の動きは、これなのか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、長閑、暖、麗、日永、朧は春季と定め、短夜、涼、熱は夏季と定め、冷、凄、朝寒、夜寒、坐寒、漸寒、肌寒、身に入、夜長は秋季と定め、寒、つめたしは冬季と定む。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "・秋風の腹たててゐるかまきりで（再録）・かまきりよいつ秋のいろがはりした・糸瓜ゆつたりと朝のしづくしてゐる・重荷を負うて盲目である・家いつぱいの朝日がうらの藪までも・風に眼ざめてよりそふ犬の表情で・這うてきたのはこうろぎでぢつとしてゐる　九月廿三日朝寒夜寒。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、米磨ぐ水がやゝつめたく、汲みあげる水がほのかにあたゝかい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・考へてゐる身にかく百舌鳥のするどく・太陽のぬくもりの熟柿のあまさをすゝる・てふてふたかくはとべなくなつた草の穂・昼も虫なく誰を待つともなく待つ　十月六日　晴、朝寒。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、遠く蜩のうた、身辺整理、読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、火鉢がこひしくなつた、朝月もつめたさうだ、まともに朝日があたたかく、百舌鳥の声が澄んできた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、朝寒、火が恋しくなつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬らしい冷たさ、朝寒夜寒であるが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、袖なしを出して着た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・漂泊詩人の三つの型　　芭蕉、良寛　　一茶　　井月九月廿五日　晴、朝寒、時々曇る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒夕寒、日中は暑い。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、朝寒、平静、執筆。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、火がなつかしい。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　朝寒のころに、Ｋ―がよく糸織りの褞袍などを着込んで、火鉢の傍へ来て飯を食っていると、お銀が台所の方で甲斐甲斐しく弁当を詰めている、それが、どうかして朝起きをすることのある笹村の目にも触れた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰にしても彼はこの春朝寒の頃の感冒から、体の倦怠を感じてゐた。",
              "citation": {
                "source": "浪の音",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒むの烈しい時、田の間の清水からは、白靄が立つて榛の樹には霜の華が咲く。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
