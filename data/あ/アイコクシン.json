    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patriotic feelings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛国心は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛国心が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛国心に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛国心が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛国心について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛国心についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛国心について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛国心が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛国心が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛国心は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛国心は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛国心を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛国心をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛国心が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛国心の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛国心を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛国心に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛国心について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛国心は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛国心を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "子供の時からつめこまれた愛国心とかいうものがまだどっかに残っているのかな。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、愛国心に満ちた士官の持つ、それと同じ心臓で、運送船で敵地に送られた陸兵の上陸や、大連湾の攻撃や、威海衛の偵察、旅順攻撃、戦争中の軍艦に於ける生活、威海衛の大攻撃等を見、聞き、感じて、それを報告している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり愛国心がないではないか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども愛国心がどうであるの、敵愾心がどうであるのと、さようなことには関係しません。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類が進歩するに従って愛国心も大和魂もやはり進化すべきではないかと思う。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天災の起こった時に始めて大急ぎでそうした愛国心を発揮するのも結構であるが、昆虫や鳥獣でない二十世紀の科学的文明国民の愛国心の発露にはもう少しちがった、もう少し合理的な様式があってしかるべきではないかと思う次第である。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の愛国心は、どうも極端すぎる。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い信仰もなく、烈しい愛国心もない自分には、とても及びもつかないことながら、生来の自分にも何かそれと一味共通の清らかさ雄々しさがあったようにも思われ、ジャンヌを見た途端に、それが喚び覚まされるような気持で、咀わしい現実の自身と環境にすっかり厭気が差してしまうのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、東京の人の愛国心は無邪気すぎます。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の愛国心は不穏でも何でも、本質が無邪気で明るいけれども、僕のほうの愛国心は複雑で暗くて、いや、そうでもないのかな？",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、愛国心について永々と説いて聞かせているのだけれど、そんなこと、わかりきっているじゃないか。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄雲の如き土塵をものともせず、我も亦躍然として人々と共に一群の先鋒に銅羅声をあげたりき、これこの古帽先生が其満腔の愛国心を発表しえたる唯一の機会なりし也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り愛国心がないではないか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども愛国心がどうであるの、敵愾心がどうであるのと、左様なことには関係しません。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが此処の季節ももう直き閉じますし、それにこの上あの可愛ゆい娘に居られたらわたし達は愛国心に反くまで娘に国情を探らしてやることになりそうです。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を軍籍に措かざれば祖国のために尽すの路なきが如き、利子付きにて戻る国債応募額の多寡によつて愛国心の程度が計らるゝ世の中に候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これじつに今日比較的教養あるほとんどすべての青年が国家と他人たる境遇においてもちうる愛国心の全体ではないか。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かの早くから我々の間に竄入している哲学的虚無主義のごときも、またこの愛国心の一歩だけ進歩したものであることはいうまでもない。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうに、国史地誌の編纂が行はれた事は、わが国民の国家意識を高め、愛国心を培つたことであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のごとき不埒な神職に愛国心や民の元気を鼓吹せしめんと謀るは、何ぞ梁の武帝が敵寇至るに沙門を集めて『摩訶般若心経』を講じて虜となり餓死せしに異ならん。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五に、神社合祀は愛国心を損ずることおびただし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛郷心は愛国心の基なり、とドイツの詩聖は言えり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職が無慙不義にして、私慾のために諸神社を検挙し撲滅するより、愛国心など説くも誰も傾聴せぬは、上にすでに述べたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる不埒の神職が少々の俸給を増し得んとて、祖先来四百年以上奉崇し来たれる古社を滅却せんとする心もて愛国心など説きたればとて、誰かこれを信ぜん。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに人民の愛国心を滅却するのはなはだしきは、我利一偏の神職、官公吏の合祀の遣り方なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく神社合祀は、第一に敬神思想を薄うし、第二、民の和融を妨げ、第三、地方の凋落を来たし、第四、人情風俗を害し、第五、愛郷心と愛国心を減じ、第六、治安、民利を損じ、第七、史蹟、古伝を亡ぼし、第八、学術上貴重の天然紀念物を滅却す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局はかくまで百方に大害ある合祀を奨励して、一方には愛国心、敬神思想を鼓吹し、鋭意国家の日進を謀ると称す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
