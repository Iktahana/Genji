[
  {
    "uuid": "564d0a8a-f514-52e7-87d4-2f34fd4c2896",
    "entry": "愛国心",
    "reading": {
      "primary": "あいこくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
