    "definitions": [
      {
        "index": 1,
        "gloss": "to be utterly amazed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お前は兄さんと引きかえて、まことに我が子ながら呆れ返る程の馬鹿で困る。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの時点においてもなお、両者を繋ぐもう一つの道筋を見逃していたことに気づかされ、私は後に、自分自身に呆れ返ることになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅牢な皮の装丁に慣れた彼らに現在の印刷本を見せれば、あまりの粗末さに呆れ返るはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今考えますと、よくあんなお転婆が出来たものだと、自分ながら呆れ返るくらいでございます。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に避難バラックの住民の多数を占めている「江戸ッ子」が最近に見せている気分は、この気味合いを最も明らかに見せているので、一言で云えば、唯呆れ返るほかはないのである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこそあの怪しげな呻き声も、のたうつような戦慄陣痛の苦悶であり、奇妙な風船笛のような鳴き声も、すこやかな産声であり、怪しげな濁り水も、胎児の保護を終えた軽やかな羊水であったのか、とわれながらいまさらのように呆れ返るのだった。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人に担がれても知らないほど、眠っていたとは呆れ返るな……とにかく屋敷の様子を見よう」　葉之助は立ち上がった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッケないほど一つだけ鳴つて、それきり鳴り止んでシンとしてゐたので、ハッとして思はず欹てた先生の心へは呆れ返るほど寒々とした闇の冷たさが押し込んできた。",
              "citation": {
                "source": "群集の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は呆れ返るだろう。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れ返るもの――罵る者――地団駄を踏む者――直ぐに追いかけて、あん畜生、とっ掴まえて今度こそはと、マドロスを憎むこと骨髄に徹する者もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきぶらりと、気が抜けたような顔をして帰ってまいりましてね、呆れ返るの雨蛙じゃアありませんか。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人だの、次の間だの、茶だの、煙草盆だの、と云うとすこぶる尋常に聞えるが、その実名ばかりで、一々説明すると、大変な誤解をしていたんだねと呆れ返るものばかりである。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "風通しがよくなって、晩のお菜まで往来から見通しだ」「ヘッ、呆れ返るぜ親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尤も、お前には其處までは聽かせなかつたよ、土壇場になつて、聟の身代りになるのが嫌なんて言ひ出されると困るからな」「呆れ返るぜ」　何んな仔細があるか解りませんが、杯事の始まる前、聟の支度部屋を占領して、平次はガラツ八相手にこんな無駄を言つて居るのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっとも、お前にはそこまでは聴かせなかったよ、土壇場になって、聟の身代りになるのが嫌だなんて言い出されると困るからな」「呆れ返るぜ」　どんな仔細があるか解りませんが、杯事の始まる前、聟の支度部屋を占領して、平次はガラッ八相手にこんな無駄を言っているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、形こそムク犬を髣髴するものがあれ、その心術に至っては、雪と墨と言おうか、月と泥と言おうか、ほとほと呆れ返るばかりであるのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御苦労のねえ先生だなあ」と、その寝顔を見た時に、米友が改めて呆れ返るような表情をしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友は、お喋りが即ち弁信であり、弁信が即ちお喋りであることを、まだよく知らないから、一気にまくし立てられて呆れ返るばかりでありましたが、弁信の減らず口はまだ続きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やっぱり原は呆れ返るほど広い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州へ来て、広い原さえ見れば安達ヶ原だと思い、一つ家がありさえすれば鬼の棲家だと想像する自分の頭脳の御粗末さ加減に呆れ返る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋口のズボラには全く呆れ返る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればアバタの旗印、顔一面にひるがえる、あきれかえるの醜男と、六十余州かくれもなき、鷲塚佐助のこの面を、とっくり拝んで置け！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が考えたってへんなことだと思うわ」　あきれかえるわねえ。",
              "citation": {
                "source": "しようがない、だろうか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともただただあきれかえるのだろうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ対手はヤンキーだからやり切れない、I guess, と云うような、耳ざわりな言葉を前置きにして、鼻にぬけた胴間声で、しゃべるわしゃべるわ、而も山岳に対しては、〔Mo:nch〕 の発音さえ覚束ないしろ者なんだからあきれかえる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにあなた、あきれかえるじゃございませんか。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大鳥氏は、意外につぐ意外に、ただもうあきれかえるばかりです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈎のような手の爪で、しっかり襟もとへつかまっているので、十兵衛は槍をつきだしようがなく、あッと見ると、長安自身も、つかんだ曲者の手の毛むくじゃらにあきれかえる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
