        "index": 1,
        "gloss": "ukiyo-e print produced with various shades of indigo (and sometimes small amounts of vermilion or yellow)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
