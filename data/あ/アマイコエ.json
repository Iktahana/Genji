        "examples": {
          "standard": [
            {
              "text": "私は毎日甘い声について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘い声という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘い声の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘い声が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘い声を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘い声について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘い声の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘い声の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘い声が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘い声という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘い声という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘い声についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘い声を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘い声は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘い声について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘い声が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘い声は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘い声の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘い声は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘い声は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「御本はみんな伏せてしまって、ようござんすか、リヤ王はもう八十の坂を越えた……」　甘い声であった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が走つて出て、甘い声で、ボンソアと庭口へ呼んだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔い炬燵蒲団をはぐつて、電気のスイッチを入れると、ゆき子は、富岡の顔を見ないやうにして、「寒いから、炬燵へおはいりになつて」と、甘い声で云つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルナはオラウスを見ていた、やがて静かな甘い声で言いはじめた、オラウスの耳にその甘い声はふるさとの村の蜜蜂のうなりのように甘やさしく聞えた。",
              "citation": {
                "source": "剣のうた",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと正面の御拝のある階段からは行かないで、側面の扉をほとほとと叩いて、「御免下さいまし」　なんとなく、うるおいのある甘い声。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをきっかけに、扶佐子はだんだん露骨になり、わざとらしく甘い声でＮを呼んだりした。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き声も立てず、やがて扶佐子は、いつもの甘い声で、「奥さん。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかももしこの甘い声をもう一度聞いたならば、その人恋しと思っている私の理性は、たちまち箍を外して、年甲斐もなく鍵を掛けた妻の寝室の扉に体当りでもしかねまじいのを、自分ながらハッと恐れたからであった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "………やさしい、かすかな、いかにも綺羅子らしい甘い声でした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半之助などは見向きもせず、しかし充分以上に意識して、「だめですわ、遠藤さま、貴方の番じゃございませんの、ねえ、早くいらしって」　ねばねばするような甘い声で、しかも千之助の腕を取って、しなしなと躯をくねらせた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "賞賛が、さっさと我が身のまわりにふり積り、長く降るよりも厚くふり、久しく降るよりも豊かにふり、そして、わたしの知覚ともろともにさっさと消えてうせることこそ、それから後はその甘い声音がわたしの耳に触れないでくれることこそ、望ましゅうございます。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "細く甘い声でといふ狙いはヒットして、一寸徳山・藤山をまぜたやうな声である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙子の掴めば消えてしまい相な、しなやかな身躯、ほほえむとニッと白い八重歯の見える、夢の様に美しい顔、胸の擽られる様な甘い声音、それらの一つ一つが、時がたてばたつ程、まざまざと記憶に浮んで、明智は二十歳の青年の様に、悩ましい日を送らねばならなかった。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の罌粟の花の様な笑顔や、歌の様に甘い声を、汽車の動揺につれて目と耳に繰返した。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
