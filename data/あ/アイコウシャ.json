[
  {
    "uuid": "7e817091-c5f6-5b91-93b0-1358affcbaf9",
    "entry": "愛好者",
    "reading": {
      "primary": "あいこうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
