    },
    "definitions": [
      {
        "index": 1,
        "gloss": "enthusiast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛好者は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛好者が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛好者に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛好者が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛好者について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛好者についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛好者について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛好者が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛好者が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛好者は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛好者は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛好者を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛好者をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛好者が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛好者の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛好者を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛好者に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛好者について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛好者は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛好者を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "古來歴史上の大科學者、例へばガリレオや、ワツトや、ニユートンや、エヂソンやが、その少年時代に於て、いかに夢想的な子供であり、いかにフアンタスチツクな童話の愛好者であつたかを、彼等の教育者等は知らないのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕事はどうも私には荷が勝った仕事ですが、いずれ勤先とも話がつきましたら専心この計画にかかって私の生涯の事業にしたいと思いますので」　その節は、亡父の誼みもあり、東海道愛好者としても呉々も一臂の力を添えるよう主人に今から頼んで置くというのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の詩の愛好者は、私が当初に予期したよりも遙かに多数であり且つ熱心でさへあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また世の蔭にひそんで人知れず自己の作品を書き努める無名の作家、雜誌への投書を樂しむつつましき文藝愛好者、そこにもそれぞれに懷しく、忘れ難い處女作の思ひ出は隱れてゐることであらう。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の文士とか批評家とか、又は学者、その他の芸術研究家、もしくは芸術愛好者の類で、時々「能」にチョッカイを出す人があるが、筆者の思うほどに「能」に突込んでくれる人が一人もいない。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "純素人として、全霊を裸体にして能と四ツに取り組んで、能の真実の力に打ちひしがれて満足し得る芸術愛好者、もしくは芸術研究家は、この尖端芸術とか、大衆芸術とか言って差別待遇を受けている吾々の仲間以外にいないのであろうか。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそういう音楽家の潔癖を尊重するものではあるが、それと同時に一般の音楽愛好者が蓄音機を享楽する事をとがめてはならないと思うものである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれがまた、この映画が日本あるいは東京の一般活動愛好者の感激を促し得ない理由であろうと想像される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも有名なドーヴィル愛好者だ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　更に作品に就き詳述して置く事も、私の芸術愛好者若くは後世の白秋研究家に取り全く無意義な事では無いやうに思はれる。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いたほん物の天竜が大きに欣んで一日葉公の家に降り己の愛好者を覗き見た。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、有能な実際的科学者で、忠実な大英国の技術官で、敬虔なスコットランド教会の信徒で、かの基督教のキケロといわれるラクタンティウスの愛読者で、又、骨董と向日葵との愛好者だった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "於此乎斯道愛好者は宜しく冷静に熟慮反省して、決して人間界に於てこの声を発せず、換言すれば深山幽谷に去って哀猿悲鳥を共として吟ずるか、もしくは環海の孤島に退いて狂瀾怒濤に向って号叫すべしである。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来外国の芸術家、もしくは芸術愛好者たちが日本の「能」に着眼して、色々な研究をしていると聞いた。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽愛好者の九十何パーセントがこの流儀に属しているのは無理もない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内弟子は日本国中の同流の愛好者から紹介されたり、又は自ら望んで来たり、又は内弟子の有力者や、家元自身が見込んで連れて来た者なぞ色々である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "または、あんな簡単、率直な定型が、どうしてあんなに色々に美しく感ぜられるのであろう……という事は、能楽愛好者の皆不思議がるところであると同時に、説明に苦しむところである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後に、無意味な、無気分な、只美しい、品のいい、音と形ばかりの、笛の舞の世界をあらわして最高の芸術愛好者を酔わせて了うのである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川さんは、演劇の愛好者だわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方、演劇愛好者でも何でもありゃしないわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お金が、そんなに必要でしたら、私の知らない演劇愛好者から、いくらでもお貰いになるといいわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、心では自然の愛好者でありながら、勤務のためにやむなくこの大首府の埃と暑さとのなかにいなければならない、という人がだね、――誰でもそういう人が、日曜以外の日でも、この町のすぐ近郊の自然の美しい風景のなかに、閑静に対する自分の渇望を医そうとしたとするね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今、満天下の正確なる時と上等のキャベツとの愛好者に訴えて助力を求めるのである。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかな朝の単調にわづかな胡椒を振りかけたばかりの食膳私の味覚はそんなぐらゐの甘つたるい料理は喰ひあきた舌なのですもつと　もつと腕利きのコックを雇つて下さいこの現代の味覚はもるひね愛好者のたゞれた舌ですねばりこく脂こい情感にふるへるやうなわたしは料理をのぞむのです。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その独言で、勝手にテレて――さうしてまた彼はそのテレた気持を回復しようと努める為に、稍暫く絵葉書屋の前に立つて、ヨソメには如何にも熱心な絵葉書の愛好者であるが如く見ゆる程、凝と絵葉書を眺めた。",
              "citation": {
                "source": "失題",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その声で彼は、一足飛びに活動俳優の愛好者になつてしまつた。",
              "citation": {
                "source": "失題",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩愛誦家の中にはママ諳んずるものもあるが、小説愛好者、殊に馬琴随喜者中に知るものが少ないゆえ抄録して以てこの余談を結ぶ。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風変った画を描くのは誰にも知られていたが、極彩色の土佐画や花やかな四条派やあるいは溌墨淋漓たる南宗画でなければ気に入らなかった当時の大多数の美術愛好者には大津絵風の椿岳の泥画は余り喜ばれなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそんなわけですから、わたしは単に人形の愛好者というだけのことで、人形の研究者や蒐集家でないことを最初にくれぐれもお断わり申して置きます。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
