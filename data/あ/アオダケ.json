        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お爺さんは、青竹の狹い縁を滑らぬやうに、用心しながらそつと渡る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思はずお世辭で無く言ひ、青竹の縁側に出る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面の底のくらやみに、うらうら草の茎が萌えそめ、鼠の巣が萌えそめ、巣にこんがらかつてゐる、かずしれぬ髪の毛がふるえ出し、冬至のころの、さびしい病気の地面から、ほそい青竹の根が生えそめ、生えそめ、それがじつにあはれふかくみえ、けぶれるごとくに視え、じつに、じつに、あはれふかげに視え。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹光る地面に竹が生え、青竹が生え、地下には竹の根が生え、根がしだいにほそらみ、根の先より繊毛が生え、かすかにけぶる繊毛が生え、かすかにふるえ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "代赭色の小鉢に盛り上がった水苔から、青竹箆のような厚い幅のある葉が数葉、対称的に左右に広がって、そのまん中に一輪の花がややうなだれて立っている。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹羊羹というのは青竹のひと節に黒砂糖入り水羊羹をつめて凝固させたものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝腎要の御嫁御さんがあのように非業の最後をなさる間もなく、その御両親の蔵元屋の御一家が賭博宿の御疑いで、昨夜のうちに一人残らずお召捕になって、表口と勝手口に青竹の十文字が打付けられようなぞ言う事を、御結納前に見透し得なかったのは一生の大シクジリで御座いました」「どう仕りまして。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方で木戸を丈夫に造り、開閉を厳重にするという条件であったが、植木屋は其処らの籔から青竹を切って来て、これに杉の葉など交ぜ加えて無細工の木戸を造くって了った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際にたとえば青竹送り筒にささげと女郎花と桔梗を生けるとして、これらの材料の空間的モンタージュによって、これらの材料の一つ一つが単独に表現する心像とは別に、これらのものを対合させることによってそこに全く別なものが生じて来る。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこそある人のある日に生けたささげと女郎花と桔梗と青竹筒は一つの芸術的創造のモンタージュ的視像となりうるのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お湯は、近頃、お爺さんが裏の納屋の側へ掘り当てた透明な、質の好い水を、青竹の管で呼んで、潤沢に湛えたものを沸かしたのである。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺飛んで星移り、当時は何某の家の土蔵になったが、切っても払っても妄執は消失せず、金網戸からまざまざと青竹が見透かさるる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方を将軍家だ思うて、橋から青竹を差出します。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに、おみき所と言ふのに、三寶を供へ、樽を据ゑ、緋の毛氈に青竹の埒、高張提灯、弓張をおし重ねて、積上げたほど赤々と、暑くたつて構はない。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれを青竹一本で渡したんですが、丈といい、その見事さ、かこみの太さといっちゃあない。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが――困りましたな――これもお話の中にありましたが、大な青竹の三尺余のずんどです。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青竹の中には、何ともたとえがたない、美しい女像がありました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴中には青竹を破りて曲げて環にしたるを幾処にか入れて、竹の両はしには屈竟の壮佼ゐて、支へて、膨らかに幌をあげをり候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に青竹の埒を結廻して、その筵の上に、大形の古革鞄ただ一個……※しても視めても、雨上りの湿気た地へ、藁の散ばった他に何にも無い。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は七夕、当地の河原はたいへん賑ふといふ、郵便局へ出かけたが、街は青竹のうつくしさで埋められてゐる、晩には煙火見物に出かけるかな。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは、青竹の狭い縁を滑らぬやうに、用心しながらそつと渡る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思はずお世辞で無く言ひ、青竹の縁側に出る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしいつたところで、青竹をかついだ百姓男と道づれになりました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ・Ｓ氏はそこで出た料理の中で、焼蛤の皿に紅梅の蕾が添えてあったことや、青竹の串に差した田楽の豆腐に塗ってある味噌に木の芽が匂ったことを想い出して話した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "筏乗りが青竹の棹をしごくと水しぶきが粉雪のやうに散つて、ぶん流し、ぶん流し行く筏の水路は一条の泡を吐いて走る白馬だ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三聲を續けて鳴いたと思ふと……雪をかついだ、太く逞しい、しかし痩せた、一頭の和犬、むく犬の、耳の青竹をそいだやうに立つたのが、吹雪の瀧を、上の峰から、一直線に飛下りた如く思はれます。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の杢若どのは、古筵の両端へ、笹の葉ぐるみ青竹を立てて、縄を渡したのに、幾つも蜘蛛の巣を引搦ませて、商売をはじめた。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と蠢かいて言った処は、青竹二本に渡したにつけても、魔道における七夕の貸小袖という趣である。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの………扉の、お仕置場らしい青竹の矢来の向うに……貴女等の光景をば。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんで、へい、苧殻か、青竹の杖でもつくか、と聞くと、それは、ついてもつかいでも、のう、もう一度、明神様の森へ走って、旦那が傍に居ようと、居まいと、その若い婦女の死骸を、蓑の下へ、膚づけに負いまして、また早や急いで帰れ、と少し早めに糸車を廻わしている。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
