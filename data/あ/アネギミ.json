    "definitions": [
      {
        "index": 1,
        "gloss": "(elder) sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日姉君について考えている。",
              "source": "幻辞"
            },
            {
              "text": "姉君という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は姉君の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には姉君が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "姉君を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは姉君について学習した。",
              "source": "幻辞"
            },
            {
              "text": "姉君の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は姉君の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では姉君が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "姉君という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に姉君という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では姉君についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "姉君を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると姉君は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "姉君について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では姉君が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に姉君は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により姉君の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "姉君は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に姉君は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その表彰式に彼の母も参列したが、人々は「我 Senior Wrangler の姉君」のために万歳を三唱」した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本箱をさがして、紫のおん姉君の、第七帖を出すのも仰々しからう。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええええ、その董、露草は、若様、この度の御旅行につき、白雪の竜馬にめされ、渚を掛けて浦づたい、朝夕の、茜、紫、雲の上を山の峰へお潜びにてお出ましの節、珍しくお手に入りましたを、御姉君、乙姫様へ御進物の分でござりました。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史六十巻、小説百巻、と申しまするデュオデシモ形と申す有名な版本の事を……お聞及びなさいまして、御姉君、乙姫様が御工夫を遊ばしました。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鸚鵡のみは、いかにしてかあの姉君を憎めるがこぼれ幸にて、今も飼はれ侍り。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鸚鵡のかたへ首さしいだしていふに、姉君憎むてふ鳥は、まがりたる嘴を開きて、「さならずや、さならずや」と繰返しぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "車停むるところへ、はや馴れたる末の姫走り来て、「姉君たち『クロケット』の遊したまへば、おん身も夥になりたまはずや、」とわれに勧めぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の夫人はこの君の伯母御にあたりて、姉君さへかの家にゆきておはすといふに、始めて逢へること国人の助を借らでものことなるべく、またこの城の人に知らせじとならば、ひそかに郵便に附しても善からむに、かく気をかねて希有なる振舞したまふを見れば、この姫こころ狂ひたるにはあらずやとおもはれぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鸚鵡のみは、いかにしてかあの姉君を憎めるがこぼれ幸いにて、いまも飼われ侍り。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さならずや」と鸚鵡のかたへ首さしいだしていうに、姉君憎むちょう鳥は、まがりたる嘴を開きて、「さならずや、さならずや」と繰り返しぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "車とどむるところへ、はや馴れたる末の姫走り来て、「姉君たち『クロケット』の遊びしたまえば、おん身もなかまになりたまわずや」とわれにすすめぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の夫人はこの君の伯母御にあたりて、姉君さえかの家にゆきておわすというに、はじめてあえること国人の助けを借らでものことなるべく、またこの城の人に知らせじとならば、ひそかに郵便に附してもよからんに、かく気をかねて希有なる振舞いしたまうを見れば、この姫こころ狂いたるにはあらずやとおもわれぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　浄飯王が狩の道にて――天竺、天臂城なる豪貴の長者、善覚の妹姫が、姉君｜矯曇弥とともに、はじめて見ゆる処より、優陀夷が結納の使者に立つ処、のちに、矯曇弥が嫉妬の処。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐を呼び出して、源氏は姉君へ手紙をことづてたいと言った。",
              "citation": {
                "source": "源氏物語",
                "author": "関屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉君ではあるが太政大臣の未亡人の宮はもっと若く、美しいところを今もお持ちになるが、これはまったく老人らしくて、女性に遠い気のするほどこちこちしたものごしでおありになるのも不思議である。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、血を分けたきょうだいだが、弟の出世の妨げになっちゃと、世間のてまえもあるんでね、なるべく人に隠れて行き来しているうちに――」「船で加持祈祷を受けにやって来るにも、まくらがなくちゃ来られねえほど、その姉君が重い病気になったといったろう」「そうなんです、そうなんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからというて別に彼らを慰めてやる方法もないので困って居た所が、この正月に碧梧桐が近所へ転居して来たので、その妻君や姉君が時々見舞われるのは、内の女どもにとりてはこの上もない慰みになるようになった。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "して彼方の窓に、彼れの手に虜はれとなりおる（whom he holds in bondage）我姉君リオノルス姫が居りまする。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震の起つた時「丸山の姉君」が傍にゐたと俊は云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には森氏の祖母君、丸山の姉君います。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "せうとの君、これなくてはと飲みて、丸山の姉君にまゐらす。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉君、こよなう怜し、さきよりこれ欲しうおもひたるにとて、心地よげに飲み給ひ、常はえまゐらぬまだしき大根まゐるもをかし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月八日岡山奥小野崎姉君御病死之旨今日｜御達差出、一日之遠慮引いたし候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）岡山より姉君遺物到来。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は紫の女王の姉君であった。",
              "citation": {
                "source": "源氏物語",
                "author": "藤袴",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失のあったあとでは後宮に侍してはいても、表だった后の位には上れない運命を負った自分のために、姉君の皇太后はどんなに御苦労をなすったことか、あの事件を起こして永久にぬぐえない悪名までも取るにいたった因縁の深い源氏の君であるなどとも尚侍は思っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当代の天子の御信任を受けてはなやかな勢力のついてくるにつけても、失恋の苦を忘れかねて、女三の宮の姉君の二の宮と結婚をした。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女御が実家に帰っている時でもあったから、姉君にも逢って、悩ましい気持ちの少し紛らすこともできた雲井の雁夫人は、平生のようにすぐ翌日に邸へ帰るようなこともせず父の家の客になっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二女も近い年で、上品な澄みきったような美は姉君にもまさった人であったから、普通の人と結婚させることは惜しく、兵部卿の宮が求婚されたならばと、大納言はそんな望みを持っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "背が高くて、艶に澄み切った清楚な感じのする聡明らしい顔ではあるが、はなやかな美は全然姉君一人のもののように女房たちも認めていた。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
