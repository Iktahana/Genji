    "definitions": [
      {
        "index": 1,
        "gloss": "good relationship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合縁は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合縁が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合縁に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合縁が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合縁について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合縁についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合縁について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合縁が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合縁が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合縁は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合縁は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合縁を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合縁をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合縁が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合縁の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合縁を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合縁に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合縁について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合縁は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合縁を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「物は取りようじゃ、この二つの刀の鞘が誂えたようにしっくりと合い、目釘の穴までがピタリと合うのは、あいえんの証拠に違いない」　竜之助はお雪の一生懸命な忠告を取合わず、やすやすと中身を入れ替えて、再びぬぐいをかけました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
