    "definitions": [
      {
        "index": 1,
        "gloss": "to be amazed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大正時代の熱中期に買ひ集めた二百餘枚のレコオドのかびさへはえてゐたのを拭き磨いて今更の如く掛けてみるのだが、こんなのを嬉しがつて聽いてゐたのかと呆れるばかりだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、小幡は自分の前に泣き伏してゐる妻を呆れるやうに叱つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うと、鼻持ちならぬキザな虚栄の詠歎に似るおそれもあり、または、呆れるばかりに図々しい面の皮千枚張りの詭弁、または、淫祠邪教のお筆先、または、ほら吹き山師の救国政治談にさえ堕する危険無しとしない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、呆れるばかりである。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の腑甲斐なさに呆れるほどだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が教へた生徒の中に、一人千葉県人が居りましたが、その人の話に依ると、その村の青年達の理想は、東京へ出て来て自動車の運転手になることだといふから呆れるぢやありませんか。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、病気だなんて……電報うったくせに」「嘘じゃなかったけど、もう直った」「まあ……」　千歳が呆れるのも構わずに、慶四郎は無造作に千歳の肩を掴えて向を変えさせ、腕を抱えてぐんぐん外へ連れ出した。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心の切り方が悪いからよ」と婆やはたしなめる様に云うと、おすめは其には答え無いで突立ったまま、何処を睨むか見当の付かない様な斜視の眼を据えて、「婆やさんの長湯にも呆れるなあ、やあ垢擦りだ、やあ糠だのって」と云って口を尖らした。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といえば、東京の人人は呆れるだろうか、眉をひそめるだろうか、羨ましがるだろうか。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅燃ゆるが君勇女史の頬を紅燃ゆるにしたんだよ」　呆れるくらい、下手な洒落を言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳の単純な頭が思いついたにしても、呆れるくらい乱暴である。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆れるほど自信のないおど／″＼した表情と、若い年齢で女を知りつくしている凄みとをたゝえた睫毛の長い眼で、じっと見据えていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし春次に言わせると、お神の勘定高いにはほとほと呆れることばかりで、銀子を見に行った時も、春次はお神に誘われ、松島見物でもするつもりで出かけたのだったが、帰って来ると、往復の汽車賃や弁当代までを割勘にし、毛抜きで抜くように取り立てられたのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の男のことなぞ」　と嘲って呆れるのであるが、なおその想いは果実の切口から滲み出す漿液のように、激しくなくとも、直ぐには止まらないものであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挙に三十年も四十年も若返り、異様にはしゃぎ出して、朗読劇をやろうなんて言い出すのだから呆れる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり客観の句だとすると、あまりにもあたりまえ過ぎて呆れるばかりだし、村人の呟きとすると、少し生彩も出て来るけれど、するとまた前句に附き過ぎる。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚だなんて、子供のお伽噺ではあるまいし、いいとしをしたお歴々が、額にはくれないの鶏冠も呆れるじゃないか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呆れるくらいに強く、きめつけるような口調で言い、手帖をひらいて私の鼻先に突き出した。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周さんはその夜、自分の生立ちやら、希望やら、清国の現状やらを、呆れるくらいの熱情を以て語った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と云う体で呆れると、お蔦は寂しそうな笑を見せて、「お嬢さん、その貴嬢、面白いことが無いんですもの、」と勢のない呼吸をする。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ながら呆れるほど、歯の浮くような、いやらしいお世辞なども書くのである。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を好きなんだ、とか何とか自分でも呆れるくらい下手な事を言って、そっと女中の手を握ろうとしたら、ひどい事になりました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評家は之を読んで嘲笑し、読者は呆れる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては、襖の蔭で縫いものをしている家の者に迄あなどられる結果になるやも知れぬという、けち臭い打算から、私は友人を屋外に誘い出し、とにもかくにも散策を試み、それでもやはり私の旗色は呆れる程に悪く、やりきれず、遂には、その井の頭公園の池のほとりの茶店に案内するという段取りになるのであった。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呆れるばかりである。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "屡々、自分で何をかいたのか呆れる有様。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "払うな、と俺が吩咐けたからその通り申します、と申しますが、呆れるわい、これ、払うべき金子を払わいで、主人の一分が立つと思うか。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つけられた方は、呆れるより、いきなり撲るべき蹴倒し方だったが、傍に、ほんのりしている丸髷ゆえか、主人の錆びた鋲のような眼色に恐怖をなしたか、気の毒な学生は、端銭を衣兜に捻込んだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "、失戀が聞いてあきれる。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くそれを聞かされた時は、何という頼りない人かとあきれるほど情けなかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
