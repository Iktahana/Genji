    },
    "definitions": [
      {
        "index": 1,
        "gloss": "patriotic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛国的は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛国的が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛国的に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛国的が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛国的について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛国的についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛国的について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛国的が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛国的が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛国的は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛国的は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛国的を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛国的をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛国的が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛国的の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛国的を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛国的に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛国的について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛国的は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛国的を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼の好みにはあまり合わないこの仕事を、彼は愛国的感情から引受けたと云われている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、諸々の作品に見られる愛国的乃至は軍国的意識性は、日清戦争の××××××××して解放戦争、防禦戦争としようとした従来の俗説（高橋亀吉等の）に対して、一つの反証を、ブルジョアジー自身によって動員された文学そのものが皮肉にも提供している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、旅順攻囲戦の戦慄すべき困難と愛国的感情の熱烈な無数の将校の犠牲の山が書かれている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、旅順攻囲戦という歴史的な客観的現実を愛国的探照燈で照し出したるが如きものである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、広く行き渡ったにもかゝわらず、いまだ文学的批判の対象として取り上げられなかったらしいのは、従来の文学批評家の文人気質によるというよりは、愛国的熱情があまって真実を追求しようとする意力の欠如が、文学としての価値を低めているがためだろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論人各々主義あり、斯かる主義を自己一人にて実行するは勝手なり、余輩敢て干渉の限りにあらずと雖も、苟も這般の陋劣なる、無気力なる、非愛国的なる主義を全国に唱導伝播するに至つては、断じて黙視すべきにあらず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこと、愛国的といえるでしょうか？",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなわけで、ウ※ルターは、今もつて、つひにどこからも一片の表彰をされたこともなく、この先も永久に、一人のかくれた偉人としてをはるわけですが、彼のこの絶大な勇気と、このりんぜんたる愛国的奉仕とは、いつ／＼までも神と人間との前に、無限の霊光をはなつものでなければなりません。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又攘夷論者も、鎖国主義的攘夷論でなくて、国家の面目を傷け、国体の尊厳を毀り、国民の意気を挫く脅迫的開国、城下の盟約開国に悲憤慷慨する尊皇愛国的な攘夷論者であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の新聞雑誌を見ても、国民の一致団結は、涙ぐましいくらゐであり、純粋素朴な愛国的感情が随処に、ほとばしつてゐるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、君の云はれるやうな「ヱビス」のやうな強さはもたないが、不幸にして痩躯こそ恵まれてゐるが、愛国的情熱をもつ青年である。",
              "citation": {
                "source": "Ｓ・Ｉ生へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことは愛国的だといえようか、市場がよいのバスケット君にはんだんしておもらい申しましょう。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じデカダンでも何処かサッパリした思い切りのいゝ精進潔斎的、忠君愛国的デカダンである。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、愛国的の興奮から従軍を志願しただけあって、最初は独軍の砲声を聞きながら、くだらない歌劇などに現を抜かしている士官や兵卒に、かなり大きい反感を持たずにはいられなかった。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は善良な学生であり、愛国的の熱情を湧かしていた自分の近い過去が思い出された。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いなるかな、自分の罪を償うためにも、最後の愛国的な興奮に副うためにも、ただ戦いがあるばかりだと思った。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "金鎖を下げた乞食……三年も湯に入らぬ富豪……家の無い自動車持ち……妾の四五人も居る無妻主義者……愛国的の名目を持つ亡国運動者……社会主義的団体名を振りまわす成り金崇拝者なぞ、数え立てれば限りもない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て余は独逸人に一問を足した、若し伯林でカイゼルの命名日に、何人かかゝる処で愛国的示威運動を企てたら、独逸の警察や社会は果して之を何といふであらうかと。",
              "citation": {
                "source": "露都雑記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり母親といふ母親は、始終子供の歯に気をつける事だけで、男の及ばない愛国的の事業を仕遂げる事が出来るといふのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに僕は香港の港を眺めながらの、支那の学生等の愛国的憤慨の言葉も聞いた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松克麿氏はやはり本誌（九月号）で社大党の変節を指摘し、而もそれが擬装された愛国的態度だと断じ、真の日本主義に転向するか、それとも非愛国的な社会民主主義に戻るか、どっちかに決めろと要求している。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは決して単なる安価な愛国的感傷でもなければ、珍しくしこたま日本料理をつめこんだために急に気が強くなっての言でもない。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "この売春婦の非公式ふらんす帰化の心理には、いくぶんそこに、じぶんの行為によって自国の名誉を傷つけたくないという少しの愛国的作用も働いてることだろうし、それに、外国の女となると、べつの現象に対するように男の好奇心が沸き立つところをも、彼女らは経験によって捉えているのであろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当時個人主義的に傾きつつあったので、この合理的な自然科学者が愛国的であることが不思議に感じられた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又彼の愛国的精神さへ抛つて顧みない文化人だつた。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合は不快な気持だけだが、もしこれを大にすれば、愛国的義憤に違いないじゃないか？",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これは止むに止まれぬ「愛国的行為」である。",
              "citation": {
                "source": "日本に生れた以上は",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、愛国者たる以上、その名に値する「愛国的行動」を為さねばならぬといふ考へ方はどんなものであらうか？",
              "citation": {
                "source": "日本に生れた以上は",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
