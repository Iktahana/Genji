[
  {
    "uuid": "c38edfac-1454-53e4-910a-7eaba70ebd17",
    "entry": "愛国的",
    "reading": {
      "primary": "あいこくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
