              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その散薬の包み袋が人間のと全く同じであるが、名前の所には吉村氏愛猫としてその下に活字で「号」の字があった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそれからしばらくは愛猫号という三毛のあだ名が子供らの間に流行していた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家のリセリウもまた愛猫家として聞えてゐるが、死ぬる時には遺言で、莫大の遺産金まで猫に呉れてやつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の愛猫フク子もまたこの足に迷って死んだ。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、Ｄ夫人には一匹の愛猫があった。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事のために、Ｄ夫人はＢ夫人と諍いを生じ、Ｄ夫人は弁護士に依頼して、Ｂ夫人を相手取り、愛猫喪失の慰藉料を請求した。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ロ）、旅宿で受取った留守宅からの消息の端に愛猫の初産を報じてきた事は、子のない作者にとってささやかな喜と感興をそそらずにはおかない。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母を一番先にここに疎開させたかったけれど、東京に六十年も住んで来た母は、なんというても東京をはなれたく思わないで、汽車の切符を三度も無駄にしてやっと六月の末になって、二人の男につれられ、リリー（愛猫）を籠に入れてこの家に疎開して来た。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年冬になれば風邪で入院する母の身の上に、この土地の寒さがこたえやしまいかと、私はとても心配していたが、十二月十二日までとても元気で、食物も沢山食し、愛猫リリーに何かと世話をやく母を、私は嬉しく思っていた。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉がゑぐられる深傷だといふ無慙な話であるけれども、彼の方が女房の横ッ面をヒッパたいたことすらもないといふ沈着なる性格、深遠なる心境、まさしく愛猫家や愛妻家の心境といふものは凡俗には理解のできないものだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉がえぐられる深傷だという無慙な話であるけれども、彼の方が女房の横ッ面をヒッパたいたことすらもないという沈着なる性格、深遠なる心境、まさしく愛猫家や愛妻家の心境というものは凡俗には理解のできないものだ。",
              "citation": {
                "source": "悪妻論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊島与志雄先生は名題の猫好きで、多くの猫と長年の共同生活であるが、何が一番食いたいかというと猫が食いたい、それも自分のウチで飼ってる愛猫が食いたいとさ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その四　人形の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　疲れて壁にもたれかかつた妻の膝には、彼と彼の女との愛猫が、しなやかにしのび寄つてのつそりと上つて居るところであつた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、甘える愛猫が彼の指を優しく噛む時ほどの痒さを感じさせた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を哀れむ女房や子供たちは、最後に視力も衰へはてた黒猫をつれに行つたが、「…………」　と愛猫の名前を呼んで見ても、ふしぎさうに女房や子供たちを眺めるだけで、すぐ傍に寄りつかうともしなかつた。",
              "citation": {
                "source": "鉄の死",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣のうちの最も人に愛せらるる獣にして、且つ最も小なるもの、この獣を玉と言い、この美人の愛猫でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間もＭ子の愛猫ミミーが、めったに家から出たこともないのに、どうしたかげんであったか、三日も家をあけたまま姿を見せないので、みんなが大騒ぎをし、Ｍ子もＥ子にその心配を打ち明けたが、その後二日経ってミミーは帰って来たので、そのことを話すと、「そう、よかったわね、そうしてどこへ行っていたと言った？",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "志摩子さんの愛猫です」　警部はそれを聞いて変な顔をした。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの「久松」は志摩子さんの愛猫だ。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本一の愛猫家物語子猫の嫁入り先が四十六軒？",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫でも好い気になって、天井の鼠公以上に荒れまわり、襖を破るやら掛物を引き裂くやら大変な騒ぎ、それでも主人公平気で玉よ駒よと、本当の猫撫で声、さすがは日本一の愛猫家と友人どももあきれ返った。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
