    "definitions": [
      {
        "index": 1,
        "gloss": "blue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "若葉の青色と、城の白堊とが色彩の明るい配合をしているところに、この句の絵画的のイメージがあり、併せてまた主観のヴィジョンがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶壁の縦断面には、灰青色の熔岩を見ないでもないが、上を被覆するゴロタ石のために、底の岩石を知ることが出来ない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰青色した緻密の熔岩と砂礫と互層をしているところを、筋違いに岩脈がほとばしって、白衣の道者たちが大沢で祈ったのと同じように、この岩脈を十二薬師の体現と信じて、崇拝するという話である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを巡ると、大宮口から吉田口に到るまでの間に殊に多く灰青色の堅緻なる熔岩流があり、漆喰で固めたように山を縦に走っている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」な色彩とは、まず灰色、褐色、青色の三系統のいずれにか属するものと考えて差支ないであろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、灰色と茶色と青色の一切のニュアンスが「いき」な建築を支配している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に朱赤色や濃黄色といったような熱色の花には単調な色彩が多くて紫青色がかったものや紅でも紫がかったものにはこうした色のかがよいとでもいったものがあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代に手をつけた「空の青色」に関する問題が、二十六年後の一八九九年に現われた論文で取扱われている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気分子自身による光の分散によって青色が説明され、それから分子数が算定される事を示した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば眼の辺には紺青色と真珠色の光を放ち、腹部にはルビー色、雪白色および空色の光斑を具えている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの丘の塊りからは一筋の細い流れが、なんの動搖も示さずに流れてゐて、その夜色を帶びた暗青色で、灌木どもの緑いろをした炎を怯やかしてゐます。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は部屋の眞ん中の床の上に、暗青色の制服から大きな體をはみ出させたまま、横はり、そしてもう身動きもしなくなつてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした瞬間を限って変る人間の気持ちと、構成され破壊される歴史の記録を掲示する銀座の青色の夜、プロレタリア駆逐したプチ・ブルジョワ達によって、かくも盛大に開演された未来派のオペラ、金属的なめろでい、青磁色の空には女優募集の広告と、ダダイズムの集会の予告板とが蛾と戯れていた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　アラビア丸――怪奇な青色の女、デッキ・ゴルフ、七色の弾丸のような意志が接触する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顔の色を見て、それから金山から出る緑砂紺砂の色、銅板の表面の色などの事を綜合して「誠に青色は日輪の空気なる（？",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は海の青色で――御覧そのなかをいくつも魚が泳いでいる。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復の船は舷灯の青色と赤色との位置で、往来が互に判るようにして漕いで居る。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ数センチメートルの長い火花を写真レンズで郭大した像をすりガラスのスクリーンに映じ、その像を濃青色の濾光板を通して、暗黒にならされた目で注視すると、ある場合には光が火花の道に沿うて一方から他方へ流れるように見える。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海を隔ててはるかの向こうに群青色の山々が異常に高くそびえ連なっている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く槍のやうな形の、するどい鱗粉が、青色リトマスで一帯に青く染まって、その中に中軸だけが暗赤色に見えたのです。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時緑青色のその切立ての巌の、渚で見たとは趣がまた違って、亀の背にでも乗りそうな、中ごろへ、早｜薄靄が掛った上から、白衣のが桃色の、水色のが白の手巾を、二人で、小さく振ったのを、自分は胴の間に、半ば袖をついて、倒れたようになりながら、帽子の裡から仰いで見た。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどやっぱり陳氏だ、お経にある青色青光、黄色黄光、赤色赤光、白色白光をやったんだなと、私はつくづく感心してそれを見上げました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とペンネンネンネンネン・ネネムはけだかい紺青色にかがやいてしずかに云いました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は新しい青色の着物と新しいバラ色の帽子をもらって、いまそのすばらしい晴れ着を着たところでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがパノラマ館に入つた人が、何人も決して忘られないのは、油繪具で描いた空の青色である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが現實の世界に穹窿してゐる、現實の青空であることを、初めに人人が錯覺することから、その油繪具のワニスの匂ひと、非現實的に美しい青色とが、この世の外の海市のやうに、阿片の夢に見る空のやうに、妖しい夢魔の幻覺を呼び起すのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
