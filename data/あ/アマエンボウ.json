        "examples": {
          "standard": [
            {
              "text": "私は毎日甘えん坊について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘えん坊の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘えん坊が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘えん坊について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘えん坊の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘えん坊が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘えん坊という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘えん坊についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘えん坊は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘えん坊が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘えん坊は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘えん坊の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘えん坊は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘えん坊は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "学校から帰ると甘えん坊の久助君は、何か喰べる習慣だつたのである。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ文六ちゃんは、一人きりの子供で、甘えん坊でした。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、文六ちゃんは樽屋の清六さんの一人きりの大事な坊ちゃんで、甘えん坊だからです。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えん坊の文六ちゃんは、それでも、いつも親切な義則君だけは、こちらへ来てくれるだろうと思って、うしろをむきむき、水車のかげになってゆきました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり自分は甘えん坊なところがある。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番人生の甘えん坊が、自殺するのさ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかといえばぼくはすぐ夢中になりやすい人なつっこい甘えん坊で、ちょっとタガを弛めるとすぐに流れ出し、全身で相手にもたれかかってしまう。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又、自分は本来相当甘えん坊でもある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょうのない甘えん坊だ」　千之助は眉をひそめながら、極めて親密な態度で、佐枝の引くままに、庭の向うへ去っていった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
