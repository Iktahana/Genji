    "definitions": [
      {
        "index": 1,
        "gloss": "Algol (algorithmic language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルゴルについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルゴルの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルゴルが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルゴルについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルゴルの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルゴルが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルゴルという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルゴルについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルゴルは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルゴルが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルゴルは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルゴルの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルゴルは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルゴルは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "当時のコンピューターの常識的な規模と機能からすれば、ちっぽけなディスプレイ付きの計算機といった印象を与える仲間の作っていたマシンのために、ケイはアルゴル★に似た言語を小さなメモリーに収まるようにコンパクトに作ろうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターにおけるＩＢＭの大成功によって、フォートランの普及には拍車がかかったが、この言語は論理的な厳密性や洗練を欠いており、プログラムの記述が汚くなるとして、潔癖症の頭のよい人たちがアルゴルを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学技術計算用に開発され、厳密な論理構造を備えるアルゴルの機械語への変換を、ハードウエアで処理してみようと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを参考に、古山は半年ほどかけて、フォートランとアルゴルをごちゃ混ぜにしたような言語のコンパイラーをＮＥＡＣ―２２０３用に作ってみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その星の地位からして見ると、アルゴルの星の光が最も低く沈む時分、長浜の無礙智山大通寺の寺の中へ、「お花さん狐」が一つ化けて現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
