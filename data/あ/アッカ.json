        "examples": {
          "standard": [
            {
              "text": "毎日、悪化について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の悪化戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "悪化の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "悪化という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは悪化について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "悪化の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "悪化に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは悪化を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での悪化は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、悪化は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "悪化は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な悪化を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪化」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "事件は、すべて彼の留守中に悪化した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦だからというのでつい医者を呼ばなかったばかりに病気が悪化するといったような場合もありうるであろう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、昔の津軽の人たちは、安寿厨子王が津軽の子供である事を堅く信じ、につくき山椒大夫を呪ふあまりに、丹後の人が入込めば津軽の天候が悪化するとまで思ひつめてゐたとは、私たち安寿厨子王の同情者にとつては、痛快でない事もないのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のほうに転出しようかとも考えているのですが、永い汽車旅行のあいだに悪化してしまうといけませんし、とにかくこの子の眼がよくならなければ私たちはどこへも行けない状態で、ほんとに困ってしまって。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱腸の悪化で、手術ということになった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などまだ六年の文壇経歴しかないが、その六年間、作品を発表するたびに悪評の的となり、現在もその状況は悪化する一方である。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が教えた通りに喋ったら議会の空気が悪化して解散になりそうになった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先に広がるのは混迷なのか、想像を超えた調和なのか」（『免疫の意味論』）　発病以来、繰り返しの長期入院や周期的に訪れる体調の悪化で、仕事はあまりできなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで状態は、投錨の際に一度に悪化した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知らせずに、こっそりぐんぐん病気を悪化させてしまうつもりであった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼女の病気は、美しくなるどころか、日増しに悪化し、次第に顔が狐のやうに尖り、皮膚の色沢もなくなり額のところの毛が脱けてきた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、健康状態は急速に悪化し、一一月二〇日朝五時、東京都豊島区千早町一の三〇番地のアパート東荘の自室で死去。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "日支事変で日英関係が悪化した事も原因であるが、大体日本人の国民性には、現象に左右されるといふ心理的動揺の幅がありすぎる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼むしろ日英関係が悪化した場合には、大いに英語を学ぶべきで、相手国を理解し尽しそれを圧倒するには、相手国の言葉を知ることが何より先決問題だからである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "善いものゝ中から悪いものを棄て、悪いものゝ中から善いものを拾ふのが人間の見識であつて、此見識を養つて悪いものゝ悪化を受けないやうな堅固な頭脳を作るのが父兄なり先輩なり教育家なり道徳家なりの若いものや後輩に対する任務である。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日の間に、すっかり踵の弾傷は悪化していたのだ。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂の声には義妹の容態の悪化を案じるよりも、病院の申出に至らしめたとよ子の現在を詰問する口ぶりの方が、あらわであった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………　××社交クラブ成立案内書大正の大震火災後社会の風潮は著しく悪化して参りました。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の多くの眼からの隔離、それは実に驚く可き恐る可き悪化を齎らし易いものだ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "――農村青年の思想悪化だなんて、彼奴等青くなってるんだから夢中よ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに様々な生活上の事態は水車の勢ひをもつて悪化に向つて回転し、就中 KOMOIDOS 論の二人の学生は激情に激情を加へた上句、遂に斯んな騒ぎを巻き起して、平和な村の、黄昏時の夢を破るに至つたのである。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい水を馬に飲ませている間に、私は、天候がひどく悪化した事に気付いた。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の容態が一歩悪化すると、喜助の食慾も一椀がところ減退した。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレゴのそういう態度が、折角今夜この招待に応じたホーテンスの気持をここで悪化させないかを虞れたのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日遅れれば一日だけ、悪化するに相違ない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの国に、団子二串に薪百把払うやづがあっか。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御神前も糞もあっかい。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我家さチャセゴに来る奴、あっか。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰も糞もあっかい！",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同意をもとめるかのように一座の人々の顔をずーっと見まわし、それから又源吉の方へ向きなおって、「まア、行って見べし、大丸の事務所はな、この前の道をつきあたったら左さ二町ばかし行ぐんだ、浜さ出る途中さ白い土蔵があっから、その隣りが事務所よ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
