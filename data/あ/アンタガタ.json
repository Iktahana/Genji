        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あんたがたについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんたがたの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんたがたが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんたがたについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんたがたの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんたがたが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんたがたという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんたがたについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんたがたは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんたがたが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんたがたは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんたがたの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんたがたは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんたがたは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――あんたがたでも、仮令｜他人と他人との喧嘩でも、喧嘩である時は何でも好いから其処から遠去かることですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――で、あそこを畠にして了っても、あんたがたは、やって行げるかね？",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お気の毒ですが、まあ、此処の地所はそう云うわけですから、あんたがたも一つ、百姓なんかやめて了って、商売でも始めたらどんなものでしょうね？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は地代がどっさり這入るし、あんたがたは商売が繁栄するってことになるじゃありませんか？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬあんたがたが別段うかつというわけじゃねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあんたがたの来訪を受けたから、マレー語独修第四十一課の途中じゃが、ここでいったんお休みとするか」　そういって、田方氏は首をちょいと曲げた。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんたがた、レーニンの室見せて貰いましたかね。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがたは――」「そうです」とわたしは答えた。",
              "citation": {
                "source": "ソヴェトのピオニェールはなにして遊ぶか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあもう、あんたがたつた今、酒場のおかみさんとこにゐたつてことよりも確かに妾や知つとるだよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに前と比べると丸で生れかわったように饒舌娘になってしまってね……そうしてそのうちに、あんたがたまらない程可愛いくなって来るにつれて、あのヤングが云っていた色んな言葉の本当の意味が、一つ一つに新しく、シミジミとわかって来たように思うの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サエは、順坊によく似合うとほめながら、「何て、あんたがた夫婦らしいやりとりなんだろう！",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたがたそんなものとったって喰べられやしないのよ。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、あんたがたは、奇術師だったのか。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だが、あんたがたに親切にしてもらっていながら、わるいことをしたのなら、わしはこの手でたたきのめしてやる。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　神父さんが、こう聞きます、――「愛児たちよ、あんたがたは一体どういうお人かな？",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの度はたと当惑したのは、あんたがたが例の伯爵の持物だということですわい。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがたは、明日から勉強ができさへすればいいんだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してあんたがたを見棄てるわけぢやない。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがたは、わたしがゐなくなつても、新しい塾長の下で、楽しく勉強ができることを信じてゐるからだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "速水女塾は、塾長が変つても、校舎が大半焼けてしまつても、やつぱり、あんたがたの速水女塾です。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいあんたがたの心が集まつて、正しい教へに導かれる尊い場所として、いつまでも、この通り、ここにある。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがたには、いつでも、前の方に、遠い遠い前の方に、光がみえるはずだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがたのやさしい笑顔だけが、わたしの、このかすんだ眼にもはつきりみえるからだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（憤然として）こうなったらもう言っちまうが、僕の才能は、あんたがたの誰よりも上なんだ！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "（頭の包帯をむしりとる）あんたがた古い殻をかぶった連中が、芸術の王座にのしあがって、自分たちのすることだけが正しい、本物だと極めこんで、あとのものを迫害し窒息させるんだ！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルカージナ　あんたがたは今日、言い合せたように、寄ってたかってわたしをいじめるのね！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどはあんたがたの番ですわ。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいことに僕にはもう、あんたがた年頃の青年の気持がわからなくなつて来てゐるが、お見受けするところ君はかなり神経質なくせに、どこかふてぶてしい野心家の風貌がある。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽くまでもあんたがたと闘ふ決心だで……」　小峯は、これも起ち上ると一緒に、低く独言のやうに呟いた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいじゃあんたがた、大事にしてな。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
