          ],
          "literary": [
            {
              "text": "これまで紙や印刷用のフィルムに吐き出してきたポストスクリプトのデータを、コンピューターの画面に表示させようとする試みは、アクロバットと名付けられています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、エキスパンドブックのように完全に画面で読むことに目標を絞った電子本も、アクロバットで作れます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "写植詰め打ちは書体デザインの枠を正方形に固定したまま、とりあえず字間距離だけを微調整してみせるアクロバットの産物にすぎないからだ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの論文の書きかたは技術的に理論のアクロバットであったし、第三者に対しても論点を明瞭に示して、問題を正しく会得させてゆくために必要な客観的叙述にかけていたのは残念でした。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義文学の伝統にたいして正当性をかいている平野謙、荒正人氏たちの論説を反駁し、書きぶりは、アクロバットめいているが、衝く点はたしかについています。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの文学のゆがみそのものを、その一文の中でアクロバット風に表現しているにすぎないことを痛ましいと思う。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識の裏をかいたアクロバット的な手口をひねり出してチップの数を減らすことこそが、ウォズニアックにとっての作る喜びだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の情報をどうメモリーに記憶させるかに関してアクロバット的な仕掛けを採用することで、ウォズニアックは通常なら実現できない色数のカラーを、少ないメモリーで表現する手法を編み出した★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドビ社のアクロバットという技術を使うと、しっかりレイアウトした文書がインターネットでやりとりできる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクロバットなどより真面目な美しさです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はサッと踊りでゝ、中央の先頭に立ち、フラダンス、ヴギウギ、アクロバット、ウンチクを傾けての合成品、ヘッピリ腰で踊りまくり、一同が引っこんでからも、一人残って熱演。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまたいへんなところなんだ」　最初に奥壁をやったＫの記録にも残っているように、右手のテラスは危険な濡岩だから、そこでアクロバットをやってはいけないのだ。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "真名古の推理によると、「カアマス・ショオ」の別の一人がハッチソンの窓から入って来て、岩井の部屋の窓から出て行ったことになっていて、その七人目の人物はアクロバット・ダンスのヘンリイという男だとされていたのだが……　早速ヘンリイが呼び込まれる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと、サーカスのアクロバットの藝人、その後、柔道家になり、拳鬪選手もやつたことがあると言つていたが、私と附き合つていた頃は、バクチを打つて歩いているようだつた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクロバット同然です。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう輩の、嘗ての勉強が、こういう箇処（自然科学が十八世紀は蒐集の学、十九世紀がその整理の学としての分析綜合の学として発展した云々）というようなところをアクロバットの跳ね台にしているのですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はどんなことがあっても作家であって、アクロバットの芸人ではないのであるから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロアにはアクロバット・ショーが演じられていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身に金粉を塗った三人の美女が、キラキラ光りながら、ヘビのアクロバット踊りを踊っていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が相手ではとても考えつかないような破天荒な姿勢、奇抜な位置に体を持って行って、アクロバットのような真似もした。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクロバットでも見ているようです。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂場のぶたいでは、大中小三人の道化師が、クルクル、クルクルと、車のように、とんぼがえりをうって、アクロバット（かるわざ）を、やっていたのです。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すもうとりのような大男も、みかけによらぬアクロバットの名人で、みごとに、ひっくりかえっています。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクロバットがおわると、三人の道化師は、見物せきにむかって、もう一度、ていねいなおじぎをして、サアッと、とぶように、がくや口へひっこんでいきました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
