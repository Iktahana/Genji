[
  {
    "uuid": "5e023169-c744-56dc-bf4d-88dfd0f8b162",
    "entry": "溢れる",
    "reading": {
      "primary": "あぶれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fail (in getting a job)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日溢れるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "溢れるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は溢れるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には溢れるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "溢れるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは溢れるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "溢れるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は溢れるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では溢れるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "溢れるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に溢れるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では溢れるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "溢れるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると溢れるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "溢れるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では溢れるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に溢れるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により溢れるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "溢れるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に溢れるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が草木が洗われて、富士山と釜無川の大断層と、南アルプスや、関東山脈の高屏風に囲まれた日本最大の裾野が、大空を持ちあげるばかりの力をみなぎらして、若い力から溢れる鮮新味で輝きわたるのを見たことを悦ぶ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎの小説が、中途までくると、私は、仰向けに寝転がつて、溢れる涙をそうつと、たもとでふいた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も勿論愉快が溢れる……、宇宙間にただ二人きり居るような心持にお互になったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の推察通り、棉は末にはなっているが、風が吹いたら溢れるかと思うほど棉はえんでいる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花へ、顔を押つけるやうにして、ほろ／＼溢れる目をごまかしましてね、「西洋のでございますか、いゝ匂ですこと。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに唇から口紅が溶けたやうに、真赤な血が溢れるんですものね。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜人では第一｜乗溢れる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂然して溢れる計り坐ったり立ったりして居るのが皆んなかんかん虫の手合いである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏と陰部とを小さなガーゼで被うてある外は、死體にのみ特有な支那の桐油紙のやうに鈍い冷たい青黄色い皮膚が溢れるやうな朝の光線の下に曝されてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、いくら因の電気が溢れるほどスタンドの口元まで来ていましても、私が知らん顔をして縁のスイッチを捻らなければ、永久に灯は点りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そういう人が一人でも世間に多くなれば、智慧に溢れ、慈悲に溢れ正義に溢れる世の中になりますから、万人の幸福でもありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋を向うへはづすと、水も溢れるまで、手桶の中に輪をぬめらせた、鰻が一條、唯一條であつた、のろ／＼と畝つて、尖つた頭を恁うあげて、女房の蒼白い顏を、凝と視た。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋を向うへはづすと、水も溢れるまで、手桶の中に輪をぬめらせた、鰻が一條、唯一條であつた。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の手は溢れる許りに詰め込まれた函の手紙を一一とり出してゐる。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」桑野は溢れるやうな熱心を以て畳を叩くやうな手付をして云ふのである。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から見る松原の葭簀茶屋と酸漿提灯と、その影がちらちら砂に溢れるような緋色の松葉牡丹ばかりが、却って目に涼しい。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水柱は高く六尺に昇つて、潺々と落ちて小波を立てて溢れる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこに屋根囲した、大なる石の御手洗があって、青き竜頭から湛えた水は、且つすらすらと玉を乱して、颯と簾に噴溢れる。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　と、御手洗は高く、稚児は小さいので、下を伝うてまわりを廻るのが、さながら、石に刻んだ形が、噴溢れる水の影に誘われて、すらすらと動くような。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その掛稲は、一杯の陽の光と、溢れるばかり雀を吸って、むくむくとして、音のするほど膨れ上って、なお堪えず、おほほほほ、笑声を吸込んで、遣切れなくなって、はち切れた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時入浴して座敷に帰ると、桂川も溢れるかと思うような大雨となった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流れるように句心は湧いて溢れるのだ。",
              "citation": {
                "source": "述懐",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ、飲みすぎ食べすぎのたたりてきめん、身心がだるい、熱い溢れる湯にはいりたくなり湯田へ行かうかとも思つたが止めにして戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちはこんなにも大人に育って女性の漿液の溢れるような女になって、ともすれば身体の縒り方一つにも復一は性の独立感を翻弄されそうな怖れを感じて皮膚の感覚をかたく胄って用心してかからねばならなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子の無性格――彼女はただ美しい胡蝶のように咲いて行く取り止めもない女、充ち溢れる魅力はある、しかし、それは単に生理的のものでしかあり得ない。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝の水は増したが、溢れるほどでもなく、ふだんのせせらぎはなみなみと充ちた水勢に大まかな流れとなって、かえって間が抜けていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑も樺も橙も黄も、その葉の茂みはおのおのその膨らみの中に強い胸を一つずつ蔵していて、溢れる生命に喘いでいるように見える。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、そんな、あまったるい通俗小説じみた、――腹立たしくさえなって、嘉七は、てのひらから溢れるほどの錠剤を泉の水で、ぐっ、ぐっとのんだ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花や莟をチョイチョイ摘取って、ふところの紙の上に盛溢れるほど持って来た。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……湯気に山茶花の悄れたかと思う、濡れたように、しっとりと身についた藍鼠の縞小紋に、朱鷺色と白のいち松のくっきりした伊達巻で乳の下の縊れるばかり、消えそうな弱腰に、裾模様が軽く靡いて、片膝をやや浮かした、褄を友染がほんのり溢れる。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
