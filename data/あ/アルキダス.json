      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to start walking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩き出すについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩き出すの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩き出すが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩き出すについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩き出すの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩き出すが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩き出すという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩き出すについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩き出すは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩き出すが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩き出すは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩き出すの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩き出すは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩き出すは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども、　歩き出すと案外に平気だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びヨボヨボと歩き出すと、ひとしきりの風が驀地に道の砂を捲いて老翁を包んだ時｜余は深き深き空想を呼起こした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は無言で、くるりとうしろを向き、そろそろと歩き出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人がじろじろ見て通るからしかたなしに歩き出す。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と力強く言って歩き出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朋輩に後を頼んで、仲蔵に「お待ち遠う」　と二人並んで歩き出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い付いて、　二人並んで歩き出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてフラフラ歩き出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人でブラブラ歩き出すと、　物凄い美人とすれ違った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人仲よく歩き出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で、源五左と団九郎、肩を並べて歩き出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまじき晴れて来ますわよ」　小初が赤い小旗を振って先に歩き出すと、雨で集りの悪い生徒達の団体がいつもの大勢の時より、もっと陽気に噪ぎ出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもぬれた着物をまた引っかけて歩き出すのはずいぶんいやだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟はしばらくは、立って自分たちの方の馬の歩き出すのを待ってゐましたがあまり待ち遠しかったのでたうとう少しづつあるき出しました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は全く異議もなく、はあはあ頬をふくらせて、ぐたっぐたっと歩き出す。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえ聞けばとそろそろ歩き出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくするとまた歩き出す。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はまた歩き出す。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一足歩き出すと又ひよろ／＼。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は黙って歩き出すと、女はやはり附いて来た。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の火消し屋敷に知っている者があるので、そこへ行って訊き出したら又なにかの掘り出し物があるかも知れないと、彼は酒屋の御用聞きに別れて七、八間ばかり歩き出すと、その隣りの大きい屋敷から提重を持った若い女が少し紅い顔をして出て来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア、二人とも道具かたづけて、おれの尻について来い」　やがて豹吉が南海通の方へ大股で歩き出すと、次郎と三郎は転げるようにしてチョコチョコついて来た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（現在その女の本当の名を忘れているのだが、想い出す都度簡単に花子だとしている）あの時、一緒に連れてくれいうたのに、のし、どない思て連れてくれなかっちゃんならと、彼女は並んで歩き出すと、言った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ一つ飛ばないかナ……などと他愛ない事を考えながら、何の気もなく星空を見い見い歩き出すトタンに深良屋敷に通ずる道路の中央に埋めて在る平たい花崗岩の第一枚目に引っかかって、物の見事にモンドリを打った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって急いで歩き出すと、いまにも眼の前に泥田圃か肥料溜が、ぱかと口を開き、それにのめり落ちたが最後、奈落の底までも沈み溺れそうな気がいたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくするとまた歩き出す。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで歩き出すと折井は、「どうだ、これから浅草へ行かないか」　一年前と違い、何か押しの利く物の云い方だった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "己はそのまま別れて歩き出す真似をして、そっと跡へ戻って、角に立って見ていた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙祷よろしくあってまたあるきだすと、「なあに、ここをかわせばもうじき広野の村へ下りでございます」　なんかと与吉、この道は始めてのくせに例のとおり知ったかぶりをして、出張った山鼻の小径を曲がる――が早いか、血相をかえたつづみの与の公、ギオッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ　アリスは　やよいウサギのほうへ　あるきだすんだけど、　すすんでいくと　また　そこに　ネコが　いてさ！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
