[
  {
    "uuid": "91629cc9-2311-5566-bcb6-ee04071dcb79",
    "entry": "歩き出す",
    "reading": {
      "primary": "あるきだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
