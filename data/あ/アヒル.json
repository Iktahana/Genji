        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家鴨について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この家鴨は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "家鴨の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が家鴨について知っています。",
              "source": "幻辞"
            },
            {
              "text": "家鴨は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は家鴨の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "家鴨に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では家鴨が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から家鴨を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "家鴨の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも家鴨が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では家鴨が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "家鴨について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも家鴨は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも家鴨は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で家鴨は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に家鴨について学びました。",
              "source": "幻辞"
            },
            {
              "text": "家鴨の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する家鴨の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では家鴨の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "画はやはり田舎の風景で、ゆるやかな流れの岸に水車小屋があって柳のような木の下に白い頭巾をかぶった女が家鴨に餌でもやっている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その少し前にこの夏泊った沓掛の温泉宿の池に居る家鴨が大きな芋虫を丸呑みにしたことを想い出していた。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い芋虫と真紅の肉片、家鴨と眇目の老人では心像の変形が少しひど過ぎるが、しかしこの偶然な一と朝の経験から推して考えてみるとフロイドの「夢判断」の学説も、そのことごとくが全くの故事付けではないかもしれないという気がして来るのである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕が怒つたのは、家鴨の卵から鷄が生れたと言つて腹を立てたやうなもので、今思へば我ながら認識不足の滑稽である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば郷里の家の前の流れに家鴨が沢山並んでいて、夕方になると上流の方の飼主が小船で連れに来るというような何でもない話でさえ、何かしら一種の夢のようなものを幼い頭の中に描かせると見える。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池に家鴨がただ一羽いる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨は群れている方が家鴨らしく、白鳥は一、二羽の方が白鳥らしい。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年この家にいた家鴨十数羽が今年はたった雄一羽と雌三羽とだけに減っている。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った家鴨どもはわれわれには実によく馴ついて、ベランダの階段の一番上まで上がって来てパン屑をねだる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔萌黄いろなるその頸を〕萌黄いろなるその頸を、　　　直くのばして吊るされつ、吹雪きたればさながらに、　　家鴨は船のごとくなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論この川で家鴨や鵞鳥がその紫の羽や真白な背を浮べてるんですよ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上この家の名物｜家鴨のオレンジ料理に添えて飲むものに彼等はチョコレートを誂えた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理ツール・ダルジャン　家鴨の番号数二万――八。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店創始以来の客数とそれに奉仕した家鴨とを同一数に附号付けたカードを客に渡すことをこの店の特色としている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二万――八番目の家鴨が裸で料理場から躍り出た。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨は薄刃の庖丁で皮を剥がれ薄く同じ厚さに肉を切られた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皿鍋にこの血の汁を移し家鴨の薄身をいれて掻き廻しながら煮詰めると汁は肉の周囲にチョコレート色に淡く固まる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一皿と家鴨の股の肉にサラダをあしらった一皿を組ましたものが、この店の名物「家鴨のブレッセ」である。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂で家鴨の血の汁を掻き立てる匙の音が霰のようだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を出るとき家鴨の番号を記入したカードをマネージャーが恭しく客に差し出す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちこちに鶏が勇ましく啼いて、庭の流れに家鴨も啼いている。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は変らぬ河岸であるが、岩に堰かれ、旭日にかがやいて、咽び落つる水のやや浅いところに家鴨数十羽が群れ遊んでいて、川に近い家々から湯の烟がほの白くあがっているなど、おのずからなる秋の朝の風情を見せていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "突きおとされた豆腐屋の末っ子は落下しながら細長い両脚で家鴨のように三度ゆるく空気を掻くようにうごかして、ぼしゃっと水面へ落ちた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとつた婦人のすがたは家鴨や鷄によく似てゐて網膜の映るところに眞紅の布がひらひらする。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あたし、足に赤いきれをつけてた、かわいそうなアヒルを笑ったことがあったわ。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに、アヒルの巣がありました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣の中には、一羽のおかあさんのアヒルがすわって、今ちょうど、卵をかえそうとしていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのアヒルたちにしてみれば、わざわざ、このおかあさんのところへ上っていって、スカンポの下におとなしくすわって、おしゃべりなんかするよりも、掘割りの中を、かってに泳ぎまわっているほうが、おもしろかったのです。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいそぎ、おいそぎ」と、おかあさんアヒルは、言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おかあさんアヒルは言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
