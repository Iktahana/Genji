    "definitions": [
      {
        "index": 1,
        "gloss": "to look up (at)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "甲板に立って帆柱の尖に仰ぐ星、船室で誰やらが欠びをする。",
              "citation": {
                "source": "星",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの点についてはむしろ本誌の読者の側から示教を仰ぐべきであろう。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方を仰ぐと、赤沢岳が無器用な円頂閣のように、幅びろく突ッ立って、その花崗岩の赤く禿げた截断面が、銅の薬鑵のような色をして、冷めたく荒い空気に煤ぶっている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧はフツ、フツと渦巻く、偃松に白く絡んで、火事場の烟でも立つように、虚空を迷っている、天幕の屋根の筋目から仰ぐと、暗灰色の虚空が壁のように狭くなって、鼻の先に突っ立っている、雨と知りながらも、手を天幕の外へ出すと、壁から浸染み出る小雨に、五本の指が冷やりとする、眼がやっと醒める。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少数のある人々はこの生涯の峠に立って蒼空を仰ぐ、そして無限の天頂に輝く太陽を握もうとして懸崖から逆さまに死の谷に墜落する。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を仰ぐと下谷の方面からひどい土ほこりが飛んで来るのが見える。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "期せずしてみんなが空を振り仰ぐ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に籠れる歇気を吐くのであろうか、夜中に凝る乳を粒立たすのであろうか、とにかく、この湧玉をみて、そして峯を仰ぐとき、確に山の眼覚めを思わせる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の一篇は、一般に予報の可能なるための条件や、その可能の範囲程度並びにその実用的価値の標準等につきて卑見を述べ、先覚者の示教を仰ぐと同時に、また一面には学者と世俗との間に存する誤解の溝渠を埋むる端緒ともなさんとするものなり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が不敏を顧みずここに二、三の問題を提起して批判を仰ぐ所因もまたこれに外ならず。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り向いて西の空を仰ぐと阿蘇の分派の一峰の右に新月がこの窪地一帯の村落を我物顔に澄んで蒼味がかった水のような光を放っている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は気がついてすぐ頭の上を仰ぐと、昼間は真っ白に立ちのぼる噴煙が月の光を受けて灰色に染まって碧瑠璃の大空を衝いているさまが、いかにもすさまじくまた美しかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもあらばあれ、われこの翁を懐う時は遠き笛の音ききて故郷恋うる旅人の情、動きつ、または想高き詩の一節読み了わりて限りなき大空を仰ぐがごとき心地す」と。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いておふみ上を仰ぐ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開けて仰ぐと、溪の空は虻や蜂の光点が忙しく飛び交っている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を潜ったが、仰ぐと梢に出て白い、月の形はここでも別にかわりは無かった、浮世はどこにあるか十三夜で。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫となって、辻に立って、前夜の雨を怨めしく、空を仰ぐ、と皎々として澄渡って、銀河一帯、近い山の端から玉の橋を町家の屋根へ投げ懸ける。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "端厳微妙のおんかおばせ、雲の袖、霞の袴ちらちらと瓔珞をかけたまいたる、玉なす胸に繊手を添えて、ひたと、おさなごを抱きたまえるが、仰ぐ仰ぐ瞳うごきて、ほほえみたまうと、見たる時、やさしき手のさき肩にかかりて、姉上は念じたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして魚ばかりではない、柳の葉も食切ると痛むのだ、）と思い思い、又この偉大なる樟の殆ど神聖に感じらるるばかりな巨材を仰ぐ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは魔法というべきではなく、神教を精誠によって仰ぐのであるから、魔法としては論ぜざるべきことである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて読者の示教を仰ぐことができれば幸いである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして右をふり仰ぐと突兀たる小浅間の熔岩塊が今にも頭上にくずれ落ちそうな絶壁をなしてそびえ立っている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまわれは、この講堂の塔の電氣時計を振り仰ぐ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまわれは、この講堂の塔の電気時計を振り仰ぐ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の師と仰ぐものはイエス・クリストじゃない、悪魔に魂を売った独逸の魔法使いファウストだってんで、ありとあらゆる科学的な悪事のやり方が、自分の体験と一緒に、それ相当の悪魔式のお説教を添えて書いてあります。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は生れてこの天地の間に来る、無我無心の小児の時から種々な事に出遇う、毎日太陽を見る、毎夜星を仰ぐ、ここに於てかこの不可思議なる天地も一向不可思議でなくなる。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは理論上からも予期される事であり、またたとえば実験室において油をしみ込ませた石綿板の一点に放火して、電扇の風であおぐという実験をやってみてもわかることである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は神様の心を知る予言者、一人は神様の忠義なしもべ、さすがにトゥロンは聖マルティンを守り本尊とあおぐ町だけあると、他の町々までうわさされるようになりました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子とおなじ空気をすうのも、深い海をながめるのも、星のきらめく夜空をあおぐのも、今夜かぎりとなりました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたばたと威勢よく七輪をあおぐ。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to look up to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to ask for (e.g. guidance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            },
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
