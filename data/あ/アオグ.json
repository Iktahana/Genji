[
  {
    "uuid": "c60ad587-ce2c-517e-80ae-fa1a20a88f95",
    "entry": "仰ぐ",
    "reading": {
      "primary": "あおぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
