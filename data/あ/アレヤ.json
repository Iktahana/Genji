        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒れ屋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒れ屋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒れ屋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒れ屋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒れ屋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒れ屋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒れ屋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒れ屋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒れ屋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒れ屋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒れ屋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒れ屋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒れ屋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒れ屋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "茶屋といったところで、壁も何もない荒れ屋である。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしもひどい荒れ屋敷だと思っていましたが、まさかに空屋敷とは……」と、喜右衛門も今更のように溜息をついていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "街は至って静かな所で殊に二十九番館は人が住むか狐が住むか、外から見ては判じ兼ねる様な荒れ屋敷で、門の戸も殆ど人の出入りする跡が見えぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等は荒れ屋敷、荒れ寺を目あてにして、今夜の陣を張っているのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより形の如き荒れ屋敷ですから、門と垣根の締りも厳重というわけにはゆきません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地をグルリと表の方へ廻ると、荒れ屋敷の一方はかなりの構へでその入口に看板が掛けてあつて、『尺八指南、竹齋』と讀めます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地をグルリと表の方へ廻ると、荒れ屋敷の一方はかなりの構えでその入口に看板が掛けてあって、「尺八指南、竹斎」と読めます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて駕籠の灯がとまった荒れ屋敷の門を見届け、そこの崩れた土塀の横に身をひそめていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこの荒れ屋敷の主人だろう。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女のからだは、外濠並木の括り駕籠から、この荒れ屋敷へつれ込まれて以来――その夜からもうここの主の自由なものにされていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして裏門か表門かわからないが、とにかくこの荒れ屋敷から正気もなく突き出された。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この荒れ屋敷に住む関久米之丞は、いつかここへ駒をよせた月江と共に八王子の町に向い、あれから小仏越えにかかって自分の野望を遂げようとしたため、かえって、月江を谷底へ失い、おのれは通りすがった日本左衛門と先生金右衛門のために殺害されてしまっている。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へば平凡なこととなるけれど、あれやこれやの作品が、その読む人の人格といふ点で関連し合ひ、ひいては文学一般の了得が、その人なりに満足され、つまり、競技に勝つだけでなく、そのフォルムも自分にとつて決定的である筈のものが最後的に探索されねばならないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやああんな男だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あゝまだあなたは知らないんでせう、あれやあね、僕等と田舎廻りにゐた時は僕の下役をしてた位なもんでさあ、あゝン………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "云換れば、其の西欧二千年の文献の、そのあれやこれやが、誰かの口によつて少し唱へられさへすれば、人々はその方へドヤドヤと寄り、それを一通り見た頃にはもう飽き飽きしてゐたのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にそのあれやこれやの一部分を書き並べます。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しもあれや松の雪、　　をちこちどどと落ちたれば、室ぬちとみに明るくて、　　品は四請を了へにけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しもあれやさんとして、　　身を顫はする学の長、雪刷く山の目もあやに、　　　たゞさんとして身を顫ふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところがあれやみんな渋柿だ。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の日向に床をひかせて起上り、食べ度いと思うものをあれやこれや食べながら、くめ子に向って生涯に珍らしく親身な調子で言った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奧州、仙臺、岩沼の、得平が膏藥は、　あれや、これやに、利かなんだ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が帰つてから、ひとりでくらやみで、あれやこれやといつまでも考へてゐた、……寝苦しかつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松」の裸木追悼号を読んで、あれやこれや考へさせられた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやこれやと東上準備、なか／＼忙しい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のさぎ師はあれやこれやと新しい服を着つけるふりをしました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はこの頃から早熟の青年らしく人生問題について、あれやこれや猟奇的の思索に頭の片端を入れかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでかの女は気が萎んで、自分が老紳士にいった言葉などあれや、これやと、神経質に思いかえして見た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉露の壺は単に看板で、中には何も入つてなく、上茶も飛切りは壺へ移す手数を省いて一々、静岡の仕入れ元から到着した錫張りの小箱の積んであるのをあれやこれやと探し廻つて漸く見付け出し、それから量つて売つて呉れる。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれや、狸や狐じゃない、天狗じゃ、天狗じゃ」と、彼は声を慄わして云った。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
