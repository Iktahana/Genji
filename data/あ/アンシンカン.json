    "definitions": [
      {
        "index": 1,
        "gloss": "sense of security",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安心感について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安心感という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安心感の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安心感が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安心感を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安心感について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安心感の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安心感の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安心感が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安心感という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安心感という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安心感についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安心感を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安心感は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安心感について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安心感が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安心感は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安心感の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安心感は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安心感は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やっぱり日本は哀れな国になってしまったのか……」　外で米の飯が食べられる余裕があったのかという咄嗟の安心感は、簡単に消えて、恥も外聞も見栄ももうこの国の人間は失ってしまったのかと情けない――というよりむしろ腹が立った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、狭義の道徳――例えば修身の教科書の精神に裏づけられた言葉を、自己保存の本能から、ある安心感をもって聴くことを好み、それ以外の奇矯に走った異色ある言葉には、一応眉をひそめるのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう誰が、どんなところから突いて来たって、この作家は大丈夫なのだという安心感を得て、実に私は満足であった。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま考えると、当時の私の無警戒は、不思議なような気もするが、しかし、正しい人というものは、何か安心感を与えてくれるもののようである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イーチャンが終ると、柱時計を見上げて、五時を指している針を見た時、だから銀ちゃんは軽い後悔と共に、何か諦めた安心感を感じたが、実は時計は故障で停っていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々には安心感があった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことは私たちが生きる日々の安心感の根拠にかかわる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モノとしての電子本ができあがり、私たちが新しい安心感の根拠を手に入れる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向側へ滑り落ちるようにして匐い込んだとき、彼はようやく安心感を得た。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にとつて二年間もつづいた飢餓感覚は今もまだ僕を脅かしてゐるのだが、僕はその黄色なものの存在に対して子供らしい安心感を抱くやうになつた。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "平板な敗者の安心感だけで、どの東京人の顔も、懐疑的な表情で歩いてゐるものはない。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊103「予定」はまた、一つの安心感を必ず含む。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう安心感のようなものを感じた。",
              "citation": {
                "source": "女優の親",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、ほっとした安心感もあった。",
              "citation": {
                "source": "ヘヤーピン一本",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックの出来上つたころはもう進駐軍は日本の一般飲食店へは這入れぬ定めになつたけれども、元来がさういふ魂胆の設計だから、ちよつとあちらの一品料理屋といふ感じで、コック場などもあちらのお客の潔癖に応じて安心感を与へるやうに工夫がこらしてあるといふ心掛けである。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから作家も、舞台といふものを考へた場合に、さういふものは、俳優が適当に自分でやる、それで間違ひはないのだ、といふ、安心感があれば、つまらない些末なことや、余計なセリフなどはぶいて、ぐんぐん人物と人間関係を突つ込んで書ける。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時は、早く――巣鴨の――家に歸りたくなります、不思議なもので、自分の居處と定まつた『巣鴨の幽居』が慕しくなるのです、そして巣鴨の鐵門をくぐり、衣服を全部改めて古巣に入れられると『やれやれ無事に歸れてよかつた』といふ安心感に滿たされます。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、それこそが人間生活の常態であると思はれるやうな、よくもわるくも、「人間」に対する一種の安心感は、いつ、いかなる場合とまではいかなくても、しばしば、生きるよろこびと希望とを私に与へてくれた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、東京から転校して来たアイノコが組にいたが、私は彼女がとても好きになり――というのは、私の悪事を知らないという安心感があったのであろうか――たった一人彼女を家へ招いた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の中に、もう仏教的な安心感もなく、恋を恋したあの戦死者への想いも失せていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぶつかって砕ける浪がまわりにあり、曇った空が上にあるばかりで、例の魔ものはここにいなかったので、とにかくひとつの安心感、すなわち、現在のこのときと、のっぴきならぬ惨澹たる将来とのあいだに休戦が成り立った、という気もちが、一種の穏かな忘却を与えてくれた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、京都へ来たという実感の中には、そういう理窟を超越した安心感があった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その安心感で、瑣末な心配は忘れられるし、これ以上はどうなっても仕方がないのさと覚悟もつく。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "安心感から逆にそうなるのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれまで見てきたように人体は牛痘に感染する準備がなされているので、多くの慢性病においてよく知られている生理学的法則に従って安心感を与えるために牛痘が身体に導入されるのではないだろうか？",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
