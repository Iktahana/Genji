    "definitions": [
      {
        "index": 1,
        "gloss": "elder brother's wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日兄嫁について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄嫁の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄嫁が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄嫁について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄嫁の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄嫁が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄嫁という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄嫁についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄嫁は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄嫁が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄嫁は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄嫁の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄嫁は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄嫁は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一月ばかり経って、すっかり兄嫁に馴染んだ頃、道子は、「お姉様は、なぜ御婚礼の晩あんなに悲しそうにしていらっしたの？",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはね、――」兄嫁はちょっと口ごもって、「あたしの一番の仲良しをあの晩お呼び出来なかったからよ。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、兄嫁はふと赧くなっただけで、答えなかった。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから間もなく、兄嫁のところへ結婚式の招待状が来た。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、口惜しい」兄嫁は叫んだ。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄も兄嫁も訳を聞いて驚いたが、正面からそれに反対しなかった。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は兄嫁より十しか若くはない。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ横浜かな」　半七は自分の意見をのべて、奉行所の許可をうけて、その月の二十一日に江戸を出発することになったので、お粂は兄嫁を花見に誘い出すどころではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢の小姑や兄嫁に軽蔑されて、実家といふ背景のないものゝ惨めさは、矜も箇性もないものなら卒知らず、芸術にでも生きようとするものには、迚も堪へ切れないことなのよ。",
              "citation": {
                "source": "彷徨へる",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄嫁は賢しい女であるので、夫の出たあとで徐四に言った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄嫁のわたしが意見じゃ。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座になって面白う遊ばんせ」「ええ、つべこべとさえずる女め、おのれら売女の分際で、武士に向って仮りにも兄嫁呼ばわり、戯れとて容赦せぬぞ」　彼は扇をとり直して、女の白い頬をひと打ちという権幕に、そばにいる女どもも、おどろいてさえぎった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも兄嫁が家にのこっているとき、次弟の妻が自由に行動するというようなことは普通にはあり得ない。",
              "citation": {
                "source": "離婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さえの家庭は母親のしもと、兄嫁のすぎと、その子の三郎といふ九つになる息子と七つになるいまといふ娘との四人暮しである。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さえの母親と、兄嫁のすぎが桑つみにひよつこり蝶子の後へ上つて來た。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係から云っても、同級であった桃子の兄嫁のところへ、ただ洋裁の仕事先として多喜子は来ているのであった。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき兄嫁などはぶるぶるふるへて口が利けなかつたさうであつた。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の兄嫁はとうに死んだ先妻の子供で、現在の蒲原夫人は子供達と姉妹のやうな、漸く二十七歳といふ若さであつた。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄嫁と不和な為に北海道へ渡ってひとりぽっち、語るに友なき淋しい生活をしてゐる故、末ながく姉妹の契りを結ばうといふお手紙。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいうちに強みを持った、優しいなかにきりっとしたところのある彼の女が兄嫁との不和で北海道へ来たといふ……ありさうな事だ。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の兄嫁というのはきさくな性分で、食事のおり、「これが東京でお世話になっていたときには大分面白いことがあったそうですね」といった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征した兄の遺骨が遺族のもとに送り届けられた後、両親始め親類の者達が相談して、そのまま兄嫁を弟にめあわせたのである。",
              "citation": {
                "source": "噂ばなし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "母や兄嫁は立つたり坐つたり、何となしに家事に忙しかつたが、勝代はざつと二階の掃除をして、時間外れの朝餐を一人で食べると、下女に吩咐けて、二階の炬燵に火を入れさせて、閉ぢ籠つた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下へ下りて母親や兄嫁を驚かすのは氣の毒であるし、それよりも自分の腸胃のまだ癒つてゐないことを家の者に知られて、東京行を引き止められるかも知れないのが恐しくて、腹を壓へて唸きながら我慢してゐた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "母や兄嫁は立ったり坐ったり、何となしに家事に忙しかったが、勝代はざっと二階の掃除をして、時間はずれの朝餐を一人で食べると、下女に吩咐けて、二階の炬燵に火を入れさせて閉籠った。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下へ下りて母親や兄嫁を驚かすのは気の毒であるし、それよりも自分の腸胃のまだ癒っていないことを家の者に知られて、東京行を引止められるかもしれないのが恐ろしくて、腹を圧えて呻きながら我慢していた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは藝術などに些しも趣味のない兄嫁に當てつけたのだとは、馬越も直ぐに感じた。",
              "citation": {
                "source": "假面",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、不斷の如く兄や兄嫁の側にゐる方がまだしも氣樂なやうに思はれだした。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉は、衰へてゐる神經に感ぜられる家庭の不平を妹に向つてゞも並べたくなつたが、そんなことを喋舌つて、心をいら立たせるのは、折角保養に來た目的に背く譯ではあるし、そんな話のために昂奮して、今夜また熟睡されないやうではたまらないと、口に出かゝつた兄嫁の惡口を、ねばつこい唾液とゝもに呑み込んだ。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がかたづくと間もなく、一人の兄は病死し、兄嫁が実家へ帰つてしまうと、独り者の父は、えたいの知れぬ女をどこからか連れ込んで身のまわりの世話をさせていたが、近所の話では、その女にはほかに男があり、父の死後も、がんとしてこの家に居据わるつもりでいるらしい。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
