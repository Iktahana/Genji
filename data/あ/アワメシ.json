        "examples": {
          "standard": [
            {
              "text": "私は毎日粟飯について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粟飯という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粟飯の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粟飯が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粟飯を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粟飯について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粟飯の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粟飯の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粟飯が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粟飯という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粟飯という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粟飯についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粟飯を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粟飯は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粟飯について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粟飯が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粟飯は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粟飯の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粟飯は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粟飯は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昨夜の残りの粟飯なりとまゐらせむと云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉の如く庫裡に入りて笈を卸し、草鞋を脱ぎて板の間に座を占め、寺男の給仕する粟飯を湯漬にして、したたかに喰ひ終り、さて本堂に入りて持参の蝋燭を奉り、香を焚きて般若心経、観音経を誦する事各一遍。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（兄弟三人、台所に腰をかけ、粟飯を茶碗に盛りながら、大根を鍋よりはさみ出しながら食う）甚三　一揆も、やっているときは、景気がええがのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその日の朝飯に初めて粟飯というものを食わされた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の夕方、家へ歸つて、黒々と墨の附いた手で先づ袂の四角い紙包みを取り出し、いそ／＼として披いて見ると、現はれたのは、紅を刷いたやうな駿河屋の羊羮ではなくて、羊羮を切つた形に捏ね上げた寺の粟飯であつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い粟飯が続いた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は粟飯一炊の間……とあるのは事実、何の不思議もない事である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日吉山王の舟祭りに、膳所に渡御なると、粟の飯を献ることは名高い話であるが、其由来を此民譚では、若に粟飯を与へた田畑之助が、粟津の人であつた為、其が為来りになつたのだとも言ふ。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、種子油の沢山入った粟飯であった。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は、笊を片付けながら、塊りの粟飯を頬張って云った。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘、人にものいふごとく月やくのうれひをかたりつゝ粟飯をにぎりてあたへければ、れいのごとくすぐに立さらず、しばしものおもふさましてやがてたちさりけり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "――同僚は、たいてい磨かれたように白く光っている白米のぎっちりつまった豪華な弁当をひろげていたが、ぼくのはたいていフスマのパンか、粟飯のパラパラなのを防ぐためにそれを小さなお握りにしたやつであった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃまるで粟飯じゃねえか」　雪は天界の黄塵を含んで、地上に落ち、それが飯を黄色に染めてしまうのである。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "李と粟飯を神饌として献る古例である。",
              "citation": {
                "source": "府中のけやき",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮守府将軍源頼義、義家奥州征伐等の言葉のものものしさにひきかへ　すもも祭　といふ名の素朴さがほほゑましく、李と粟飯にも当時の東国の辺陬らしさがあつて宜しい。",
              "citation": {
                "source": "府中のけやき",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏菜の汁と粟飯との朝食が済むと、娘は支度を改めて荒地へ出ていった。",
              "citation": {
                "source": "内蔵允留守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粟飯も少しあるよ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩からい泥鰌、黒い味噌、粟飯。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今飛び出して来た姿を見ると、足にはいつもの馬子草鞋を穿き、背中には、粟飯の弁当風呂敷を背負って、尻きり着物一枚、どう眺めても、侍の子ではない、蛙の子の旅立ちである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "粟飯をたべ終ると、伊織は、武蔵の前へ一冊の書物を持って来て、「先生、水が退かないうちは、どうせ仕事にも出られないから、書を教えてください」　と、畏まっていった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、一人の老媼が、「貴人にあげて下さい」と、粟飯を炊いて来た。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "怜悧な少年は奇遇を喜び、薪をくべ、粟飯ながら夕餉をもてなす。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
