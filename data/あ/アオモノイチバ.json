        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "次第に空の色が薄れて、岸和田の青物市場についた時は、もう朝であった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀やんは毎朝北田辺から手ぶらで出てきて河堀口の米屋に預けてある空の荷車を受けとると、それを引っぱって近くの青物市場へ行き、仕入れた青物つまり野菜類をその車に載せて、石ヶ辻や生国魂方面へかけて行商します。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新銀町は大工、屋根職、左官、畳職など職人が多く、掘割の荷揚場のほかにすぐ鼻の先に青物市場があり、同じ下町でも日本橋や浅草と一風違い、いかにも神田らしい土地であった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の説明によると、その西瓜は青物市場から仕入れて来たのではない。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭に集まる者は湊屋の生前の親友であった魚市場と青物市場の連中ばかりで、一人残らず無学文盲の親方連中であったが、それでも真情だけは並外れている博多ッ子の生粋が顔を揃えていた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾助爺はこの洪水のような雑踏の中を押し切って、毎朝｜神田の青物市場へ野菜物を満載した荷車を曳いていくのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物市場の出場時刻が切れるので、爺はうっかりしていることができなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、もし時刻に遅れて青物市場に入場することができないとすれば、ただそれだけで彼のわずかばかりの資本はすべて消滅してしまうような結果になるのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、もしその野菜物を神田の青物市場へ曳いていくことができないとすれば、吾平爺の資本は全部消滅してしまうのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾平爺は一台の古い荷車を買い、近所の農家から野菜を買い集めて、毎朝それを神田の青物市場へ曳いていくことにした。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、青物市場には入場の時間が規定されてあった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、吾平爺はその赤茶けた野菜物を曳いて青物市場へ出かけていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この夏以来の不景気のために、青物市場には新鮮な野菜物が氾濫していた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝聞きつけている青物市場に往く青物を積んだ自動車なら五時｜比であった。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その往来の左右はどこかの青物市場と見えまして、大勢の人々が、新らしい野菜や果物を、忙しそうに売ったり、買ったり、運んだりしています。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂埃と蹄の音を高く揚げながら、千里一飛びという勢いで都の南の端にある青物市場へ一目散に飛び込みました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の青物市場付近なぞは随分神経をとんがらして見たが、成る程、江戸ッ子らしい兄いや親方が大分居るには居るけれども、よく見ると、彼等のプライドたる鉢巻きのしぶりや売り買いの言葉なぞに、昔のような剃刀で切ったような気が見えぬ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市に間に合うのだそうである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこは青物市場で、白い大根や、蕪や、赤い芋が、山のように積みあげてありました。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市の間に合うのだそうである。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はきょろきょろしながら新鮮な空気を吸いに泥溝の岸に拡っている露店の青物市場へ行くのである。",
              "citation": {
                "source": "街の底",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば出荷組合を作らうといふのでその組織の事とか、村に青物市場を開設するとかいふやうなことだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、出荷組合や、青物市場や、さういふものがただそれだけでは一體なんだらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、土地の新聞に載っていた求縁広告を見て出した照会に、今返事が来て、小金のある独身の伊太利人トマソ・ラノ――この男は長らくルイヴィル市の青物市場の世話役をして其の頃は半ば隠退していた――が、南欧人だけに情熱的に轟く胸を抑さえながら、手にした、インデアナからの優しい水茎の跡に飽かず見入っていた。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのそばでは青物市場があってそこへ日本人の女の人が沢山青物を買い出しに行っているのをみたのであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天満組とは北組の北界になつてゐる大川より更に北方に当る地域で、東は材木蔵から西は堂島の米市場までの間、天満の青物市場、天満宮、総会所等を含んでゐる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば須田町の通りが非常に賑かだけれど、一寸梶町青物市場の方へ曲るとあすこは暗くて静かだ。",
              "citation": {
                "source": "一番気乗のする時",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
