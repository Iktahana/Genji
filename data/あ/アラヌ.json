          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有らぬについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有らぬという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有らぬの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有らぬが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有らぬを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有らぬについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有らぬの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有らぬの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有らぬが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有らぬという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有らぬという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有らぬについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有らぬを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有らぬは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有らぬについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有らぬが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有らぬは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有らぬの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有らぬは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有らぬは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "引摺るほどにその奴が着た、半纏の印に、稲穂の円の着いたのも、それか有らぬか、お孝が以前の、派手を語って果敢なく見えた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って根も葉もない噂も立ち、吉岡の母にも有らぬ疑惑を受ける様になった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお杉に有らぬ疑惑を掛けたのを、今更｜大に後悔した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては男も是非無げに声｜出すべき力も有らぬ口を開きて、「はい御深切に……難有う存じます……」「さあ、お話し下さい」「はい」「今更お裹みなさる必要は無からう、と私は思ふ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、お父様は平生から冗談口一つ仰有らぬ真面目なお方でしたから、このような歌のウラに隠してある本当の意味はおわかりにならなかったでしょう。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手甲脚半の他は裸の竜次郎、下帯に小刀をさした風は、醜態此上も有らぬ。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それか有らぬかこれらの者は、ちょうど慈父でも慕うように、私を慕うのでございました。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予嘗て東京を引きし時、弟へ向ひ、是迄少しも作略をやりたる事有らぬゆゑ、跡は聊か濁るまじ、夫れ丈けは見れと申せしとぞ。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の書物と、青い傘を掛けたランプとの外には、世に又何物も有らぬかと思はるる靜けさ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事についても、滅多に間違ったことを仰有らぬお兄様だったけれど、今度の正確さだけは恨みに思います。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から、間違ったことを仰有らぬお兄様。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか彼はただ徒らに気を弱くされてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、猫の瞳孔が紋むやうに、海は急劇に曇つて来て、今にも時化でもやつて来さうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へば云ふ程てんであらぬ効果を生むばかりなのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか文士と呼ばれる人種の中にも、文学でも何でもない、といつて文学に全然関係がなくもないから、つまり文学の爪だの垢くらゐには関係のあることを何かと云々して、それで以て自身は文学のつもりでゐる人が少しはゐる。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "身も世も、あらぬ思いで、私は、すぐには返事も、できませんでした。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで、私の性格、體質などに就いて、ずゐぶん誇張されて言ひ傳へられ、たしかに私にも不用意な點があつて、明かにそれは私のいたらぬところであつたけれど、あらぬ傳説が一部の人たちに信じ込まれてゐた樣子で、たいへん評判がわるかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来、その点、身も世もあらぬ思ひもあらば、また何かの形で、歌となつて出ることもあるであらうといふ、はかない念願を抱懐することに終つてゐる。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ出だにもあらぬがにまして夢などあるべきか。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、翁は天宙から頭上へ目庇のように覆い冠って来る塩尻の形の巨きな影を認めたかに感じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏はざらざら雲の波、早くも黄びかりうすあかり、その丘のいかりはわれも知りたれどさあらぬさまに草むしり行く、もう夕方だ、はて、この沼はまさか地図にもある筈だ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの抱かれて居るは誰何、知れるかえと母親の問へば、言下に兄樣で御座りましやうと言ふ、左樣わかればもう仔細は無し、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同顏を見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれてゐるは誰君、知れるかへと母親の問へば、言下に兄様で御座りませうと言ふ、さうわかればもう子細はなし、今話して下された事覚えてかと言へば、知つてゐまする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もあらぬ実験室の夜の更けにしづかにひびく装置を聞きぬ　この歌は題目が殊に新しく、着想も面白いが、その題目や着想が淡い情調に融合されて、少しも目立たないで能く単純化が行われて居る。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "如斯ことはきょう始めてと云うではないが見る度に胸がふさがるべくおぼえ何と云うて慰さめんようもなく身も世もあらぬ思である。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は身も世もあらぬさまでいきなりにお増の膝へすがりついて泣き泣き、「お増や、お母さんに申訣をしておくれ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれて居るは誰君、知れるかへと母親の問へば、言下に兄樣で御座りませうと言ふ、左樣わかれば最う子細はなし、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕には職あり、身は健かなるに、いつまでかくてはあらぬ物を』と口癖に仰せらるゝは、何所やら我が心の顔に出でゝ、卑しむ色の見えけるにや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと嬉しうて、今やこの事かたり出ん、しばししてや驚かすべき、さこそは人の羨やましがるべきをと、嬉しきにも猶はゞかられつゝ、あらぬ事ども言ひかはすほどに、折しもかの子規軒端に近う鳴く声のする。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宿はこゞゐの森にもあらぬを、この夜頃たえせず声の聞ゆるが上に、ひるさへかく」と打出したれば、友は得ときがたきおもゝちして、「何をかのたまふ」とたゞに言ふ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
