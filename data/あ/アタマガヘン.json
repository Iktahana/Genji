        "examples": {
          "standard": [
            {
              "text": "毎日、頭が変について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の頭が変戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "頭が変の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "頭が変という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは頭が変について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "頭が変の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "頭が変に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは頭が変を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での頭が変は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、頭が変は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "頭が変は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な頭が変を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「頭が変」という概念について深く考察する必要があります。",
              "source": "幻辞"
