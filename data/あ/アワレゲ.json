        "examples": {
          "standard": [
            {
              "text": "私は毎日哀れ気について考えている。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は哀れ気の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には哀れ気が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは哀れ気について学習した。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は哀れ気の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では哀れ気が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に哀れ気という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では哀れ気についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると哀れ気は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では哀れ気が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀れ気は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により哀れ気の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "哀れ気は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に哀れ気は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああ哀れ気の毒千万なる男よ！",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れ気が狂れたのである。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "立往生の客ばかり、哀れ気の毒に見えたりしが、恰も好し、某学校の制服着けたりし賀客両人、入り来りしかば、五つ紋の先客は、九死の場合に、身代りを得たる思を為し、匆々辞して起ちたりしが、主人は尚分れに臨み、『それなら、四日の朝四時までに、僕の家に来給へ。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コブラを知らないのか」　チャンは楽しげに、いや哀れ気に笑って振り返った。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも痛みを忘れさせてくれる」　ベナが最後の言葉をゆっくり哀れ気に話す様子は、自分自身に言い聞かせるようで、連れを忘れたかのようだった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンシア嬢は哀れ気に頼りなさげに泣いている。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話はしたくないぜ」「何カ月もだろう」　とファーガソン部長が哀れ気に言った。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "六カ月も、七カ月も、一元の給料さえ、兵卒に支払わない、その督弁の張宗昌は、城門附近で、自動車から、あわれげな乞食の親子を見て、扈従に、三百元を放ってやらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすると、弱々しげな手付をして、しきりと　手真似をするのでしたが、その意味が、つひぞ通じたためしはなく、あわれげな　思ひをさせるばつかりでした。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉が小山の家の方から通っている同じ学校の先生で、夏休みを機会に鼻の療治を受けに来ている人があると、三吉は直ぐそれを知らせにおげんのところへ飛んで来るし、あわれげな唖の小娘を連れて遠い山家の方から医院に着いた夫婦があると、それも知らせに飛んで来た。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、あわれげな人が通ると、懐に入れて出た小金を、みんな、その人の掌にあけてやってしまうのだった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験に不正を行ったのは一つの理想より出たことである、どうか早く学士になり、親に安心を与えたいと思うが、近ごろ親が病気でこうこうだとあわれげな話をする。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が下りるまで私はお妙ちゃんのあのあわれげな視線をうけて居る事が出来るかしらこう思いながら、見られればキッとこっちからもそれに答える心持をもって居た。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし歩いては休み、すこしあるいては休みして、　カアーン、カアーン……と行乞の鉦をあわれげにたたく。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
