    "definitions": [
      {
        "index": 1,
        "gloss": "any brown or reddish-brown frog of the family Ranidae",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "はてさて迷惑な、こりゃ目の前で黄色蛇の旨煮か、腹籠の猿の蒸焼か、災難が軽うても、赤蛙の干物を大口にしゃぶるであろうと、そっと見ていると、片手に椀を持ちながら掴出したのは老沢庵。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が、藥だと勸めるものも、やれ赤蛙が可い事の、蚯蚓が利く事の、生姜入れずの煎法で。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにひきかえて赤蛙はあくまで孤独だ。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹とんで赤蛙　蟻が行儀正しく最後の御奉公にいそしんでいる姿は、ときどき机の上を歩きまわったり寝床を襲うたりして困るけれど、それは私に反省と勤労を教えてくれる。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛い赤蛙がぴよんと飛ぶ、そして考へてゐる、まだ子供、いや青年だ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙が化けたわ、化けたわと、親仁が呵々と笑ったですが、もう耳も聞えず真暗三宝。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞし蝦蟆は赤蛙なり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてさて迷惑な、こりや目の前で黄色蛇の旨煮か、腹籠の猿の蒸焼か、災難が軽うても、赤蛙の干物を大口にしやぶるであらうと、潜と見て居ると、片手に椀を持ちながら掴出したのは老沢庵。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、それと入れ違いに今度は赤い兵隊の服を着た赤蛙が先に立って、あとから最前の疣蛙が這入って来ると、立派な金モールの服を着た殿様蛙と、その奥さんらしいやさしい顔をした青蛙が這入って来ました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この殿様蛙夫婦が這入って来ると、室中にいた疣蛙も赤蛙も青蛙もみんな一時に床の上にひれ伏してしまいました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の顔と蛙の顔とは大変に違うから珍らしがっているのだろう」　こう思っているうちに、殿様蛙は赤蛙の兵隊を連れてサッサと帰って行きました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をとめて見るとそれは赤蛙だつた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙としてもずゐぶん大きい方にちがひない、ヒキガヘルの小ぶりなのぐらゐはあつた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙は洲の岸まで来た。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙は一生懸命に泳いで行く。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流れに逆らふやうにして頭を突つ込んで泳いで行く赤蛙はまん中頃の水勢の一番強いらしい所まで行くと、見る見る押し流されてしまつた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて赤蛙はのたりのたり歩きだした。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは長く思はれたが、五分は経たなかつただらう、赤蛙は再び動きだした。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今不思議な見ものを見るやうな思ひで凝視してゐる私の目の前で赤蛙は又もや流れへ向つて歩きだしたのである。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は赤蛙をはじめて見つけた時、その背なかの赤褐色が、濡れたやうに光つてゐたことを思ひだした。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が見る前に、赤蛙はもう何度この繰り返しをやつてゐたものかわからない。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙は向う岸に渡りたがつてゐる。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし赤蛙はそのために何もわざわざ今渡らうとしてゐるその流れをえらぶ必要はないのだ。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さな淵の上には、柳のかなりな大木が枝さへ垂らしてゐるといふ、赤蛙にとつては誂へ向きの風景なのだ。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がそんなことを考へてゐる間にも、赤蛙は又も失敗して戻つて来た。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙を打たうといふ気はなかつた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "石は赤蛙の周囲に幾つも落ちた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙はびくつとしたやうに頭を上げたり、ちよつと立ち止つたりしたが、しかし結局予定通り動くことをやめなかつた。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙は何もかにも知つてやつてゐるのだとしか思へない。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙はある目的をもつて、意志をもつて、敢て困難に突入してゐるのだとしか思へない。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
