        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨空について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨空という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨空の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨空が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨空を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨空について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨空の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨空の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨空が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨空という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨空という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨空についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨空を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨空は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨空について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨空が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨空は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨空の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨空は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨空は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして睡眠は時雨空の薄日のように、その上を時どきやって来ては消えてゆくほとんど自分とは没交渉なものだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、こよひの月は、雨空に道行きをするやうなのではない。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日も、この梅雨空で、雨の小留んだ間も、蒸しながら陰が籠つて、家居は沈み、辻は黄昏れた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッパの勇しい響きと同時に、到るところで、××君万歳の声が渦をまいて、雨空に割込むように高く挙った。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自動車に轢かれたほど、身体に怪我はあるでしゅが、梅雨空を泳ぐなら、鳶烏に負けんでしゅ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口は思い切り大きい両開きの木の扉が左右に裏板を見せて、ほの暗い内部を透かした向うにかっきりした長方形の雨空と緑との画面がうち明っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲足早き雨空の、おもいがけない、ご馳走ですな。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は明くる日も降りつづいて、本式の梅雨空となった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、編んでいるうちに、私は、この淡い牡丹色の毛糸と、灰色の雨空と、一つに溶け合って、なんとも言えないくらい柔かくてマイルドな色調を作り出している事に気がついた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の雨空と、淡い牡丹色の毛糸と、その二つを組合せると両方が同時にいきいきして来るから不思議である。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に持っている毛糸が急にほっかり暖かく、つめたい雨空もビロウドみたいに柔かく感ぜられる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物すごく底光りのするまっさおな遠洋の色は、いつのまにか乱れた波の物狂わしく立ち騒ぐ沿海の青灰色に変わって、その先に見える暗緑の樹林はどんよりとした雨空の下に荒涼として横たわっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、このおいらの目玉は、雨空、雪もよう、晴れ曇り、慈悲にもきくがにらみも江戸一ききがいいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜の暮れ方から雨空になった。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊長雨空の喪過ぎて、さすや忽ち薄日影、冠の花葉ふりおとす栗の林の枝の上に、水のおもてに、遅花の花壇の上に、わが眼にも、照り添ふ匂なつかしき秋の日脚の白みたる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊長雨空の喪過ぎて、さすや忽ち薄日影、冠の花葉ふりおとす栗の林の枝の上に、水のおもてに、遲花の花壇の上に、わが眼にも、照り添ふ匂なつかしき秋の日脚の白みたる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨空に重い雲が渦をなして老人の病室近くに舞い下り、枕許につめている人々は、煌々たる電灯の明るさに、昼と夜との錯覚をひきおこすようなことになった或る不気味な日の午後、大熊老人は全く意識不明に陥り、やがてその夕刻、脈膊も薄れて、眠るが如く大往生を遂げてしまった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとそのとき、彼は梅雨空に溶け込む夜の濃密な街角から、閃めく耳環の色を感じた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八戸はここで降りるのだといふ驛で、ここには家内の實家があるのだと微笑する川端君と共に、驛の周圍の陰鬱な雨空を見廻したが、私にはそのキリストの荒唐無稽な説も鶯の聲のやうに節面白く頭に生きて、思はずにそのやうな説を説く人達の頭も、とりすがつた夢の美しさのやうに感じられた。",
              "citation": {
                "source": "梅雨",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・梅雨空おもく蜘蛛と蜂とがたたかふ・焼かれる虫のなんと大きい音だ・頬白がよう啼いて親鳥子鳥・何もないけどふるさとのちしやなます（砂君に）・話しても話しても昔話がなんぼうでもとんぼ通りぬけさせる　　　こんな句も・けさも二人でトマト畑でトマトをたべる（新夫婦に）　　　（一人ならば私だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら梅雨空も霽れるらしく、私も何となく開けてきた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ平静、降りきらない梅雨空を仰ぎつゝ溜息を洩らしつゝ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手に、高くすっきり櫓形に石をたたみ上げた慈海燈を前景とし、雨空の下にぼんやり遠く教会堂の尖塔が望まれる。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の廊下を通る者はなく、こうやって座っていても、細い鉄の手摺り越しに遙か目の下に那須野が原まで垂れた一面の雨空と、前景の濃い楢の若葉、一本の小さい煙突、よその宿屋の手摺りにかかった手拭などが眺められる。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細雨を傘によけて大観門外に立って見ると、海路平安と銘あるそのすっきりした慈航燈を前景とし、右によって市中の教会の尖塔がひとり雨空に聳えて居る。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴、といつても梅雨空、暗雲が去来する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・からつゆから／＼尾のないとかげで　いつしよにびつしより汗かいて牛が人が・ゆふぐれは子供だらけの青葉　仔猫みんな貰はれていつた梅雨空また文なしになつた、宿料はマイナスですむが、酒代が困る、やうやくシヨウチユウ一杯ひつかけてごまかす。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のうちは梅雨空らしかつたが、やがてからりと晴れた、そして風も相変らず吹いた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "口に云えない程の柔かさと弱い輝を持った気味悪い程丸味のある一体の輪廓は、煙った様に、雨空と、周囲の黒ずんだ線から区切られて居る。",
              "citation": {
                "source": "雨が降って居る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
