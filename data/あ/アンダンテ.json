        "examples": {
          "standard": [
            {
              "text": "私は毎日アンダンテについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンダンテの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンダンテが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンダンテについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンダンテの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンダンテが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンダンテという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンダンテについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンダンテは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンダンテが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンダンテは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンダンテの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンダンテは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンダンテは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おれの事だからいつだかわからんと云ったような事を云うてザブ／＼とすまし、机の上をザット片付けて革鞄へ入れるものは入れ、これでよしとヴァイオリンを出して second position の処を開けてヘ調の「アンダンテ」をやる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポにもアダジオやアンダンテはあってもアレグロがなく、表情にもフォルチシモがなく、そうかと云ってピアニシモもなかった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツシーマーア、カデンーノーオー、センキーンーンタン」というふうに全く同じ四拍子アンダンテの旋律を繰り返しながら、だんだんに薬の効能書きを歌って行くのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘重なラルゴで始まったのが、アンダンテ、アレグロを経て、プレスティシモになったと思うと、急激なデクレスセンドで、哀れにさびしいフィナーレに移って行く。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポで言えばまずアンダンテのような心持ちである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻が無くてしかもかの象の鼻のアンダンテ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してただそこはかとなくアンダンテの夢の調子に堕ちてゆく。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面は全速力で自動車が走つているのに音楽は我不関焉とアンダンテか何かを歌われたんではきのどくに見物の頭は分裂してしまうほかはない。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭を横截って二人で上がって行くと、書棚や椅子や額や、雑書雑誌などの雑然と積み重ねられたなかで、子供の庸太郎が、喫茶台の上と下に積んであるレコオドのなかから、彼女に向きそうなチャイコフスキイのアンダンテカンタビレイをかけてくれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は最終までアンダンテで押し通すべきだつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポの緩やかな長いイントロダクション、続いて湖水の表のような冷静な第一楽章、アンダンテ、しかして作者はこの章と第二楽章との間に少くとも十二日間という休符を挿入するつもりだつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋川一家というテーマの上に組み立てられたこの殺人シンフォニーはかくして第一、第二の楽章がアンダンテとプレストに作られ偶然にもシンフォニーの形式で弾奏されはじめたのだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にアンダンテからアレグロに移るお休みの瞬間の美しさは、何と形容していいのか説明の出来ない、不思議な音の無い音楽の美しさを味わいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてお手紙よむと、そこにはいつも変らぬあなたのテンポがあり、それは弾力にとみつつアンダンテで快調です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくプレスト時代ですからこうしてアンダンテのリズムをきき、ところどころカンタビーレの交っている諧調は耳ばかりか心を休め、養います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのアンダンテ・コン・モトの静かな揺ぎのうちには、夕日の平和の中にある大木の厳かな仮睡や小鳥の歌などの、朗らかな印象が見出せるのであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると、二時間もの音楽会で、唇に微笑を浮かべ、眼を輝かして、最もひどい困難に――モーツァルトの幼稚なアンダンテをひくという困難に、首尾よく打ち勝った高名なピアノの名手を、彼は蔑視することもあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフは少しも遠慮のない態度で、彼の音楽上の作品をけなしたり、彼がハーモニュームでハイドンのアンダンテを台なしにすると、大声をたてたりして、すっかり彼を征服してしまった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『このプレストの後で、二人は見事ではあるが、極めて平凡な新味のないアンダンテに、俗悪なヴァリエーションをつけて弾き進みました。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨晩のアンダンテを弾いてよろしいか」　とワルマ卿。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、アンダンテを弾いてくれ」　伯爵が気を静めて聞き入った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダンテが進むにつれワルマ卿がだんだんぐったりしてきた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルマ卿が謝罪にほほ笑んで、「私のアンダンテを聴かないとはバチあたりだ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイドンは、この交響曲の第二楽章の眠りを誘うアンダンテの途中で、いきなりドカンと全管弦のフォルテで聴衆の眠りを驚かして喜んだのであると伝えられる。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま窓の外に歌う左官の歌に霊感を呼覚されて、「弦楽四重奏曲第一番ニ長調」の有名な「アンダンテ・カンタービレ」を作ったりした。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な「アンダンテ・カンタービレ」を含む「弦楽四重奏曲第一番＝ニ長調」の全曲レコードのないのが惜しい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚物はなく、ことごとく組物だが、バッハの『ヴァイオリン・ソナタ』六曲のうち、四番、五番、六番の三曲と二番のアンダンテを入れているのは嬉しい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンデルの『サラバンド』、ジンディングの『アンダンテ・レリジオソ』は大したことはない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曲はベートーヴェンが病気の癒えた感謝と祈りをこめて書いた曲で、その第二楽章の「アンダンテ・モルト・アダジオ」の美しさは、この世のものとも覚えないほどだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルマン弦楽四重奏団の『アンダンテ・カンタビーレ』は通俗味満点だろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
