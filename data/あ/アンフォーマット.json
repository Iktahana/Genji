        "examples": {
          "standard": [
            {
              "text": "私は毎日アンフォーマットについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンフォーマットの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンフォーマットが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンフォーマットについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンフォーマットの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンフォーマットが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンフォーマットという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンフォーマットについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンフォーマットは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンフォーマットが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンフォーマットは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンフォーマットの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンフォーマットは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンフォーマットは興味深い例である。",
              "source": "幻辞"
            }
          ],
