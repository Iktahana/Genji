          ],
          "literary": [
            {
              "text": "たくさんのアマチュアたちが、マイクロコンピューターに何をやらせるのか、勝手に考えはじめていたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ＴＫ―80に群がったアマチュアたち一人ひとりは、自分なりの使いこなしに頭を悩ませはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬、日本のコンピュータ・アマチュアたちが、大挙してやってきたのかと、錯覚したほどである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂浜から一段高くなった草地は、セミ・プロやアマチュアたちのムーヴィ・カメラの砲列だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
