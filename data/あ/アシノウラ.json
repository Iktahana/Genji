[
  {
    "uuid": "25f28438-bab6-5a23-9003-4f2c10e216e0",
    "entry": "足の裏",
    "reading": {
      "primary": "あしのうら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
