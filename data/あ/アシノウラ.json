    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sole of the foot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "廊下を歩くのに足の裏が冷たからうといふ思ひやりの樣であつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだしで歩くと、足の裏がいやにぬらぬらする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だうりで、さつきから足の裏がぬらぬらすると思つてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏と珠との間がほんのわづか隙いてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの足の裏は、いまだいちども、ものを踏んだ事が無いのかも知れぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ眞の氣品を有してゐるものの如く、奧ゆかしく思はれて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では海水浴場の岩角にこの烏貝が群っていて、うっかり踏付けて足の裏を切らないよう用心しなければならない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というが疾いか、横ざまに駆けて入る、柳腰、下駄が脱げて、足の裏が美しい。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏が馬鹿に冷い。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこういう際はかかとを浮かして足の裏の前半に体重を託してあるけば安全だということを発明したわけである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも熱伝導がきわめて悪いから下で半日焼けても屋上でははき物をはいた足の裏を焼けどする心配もない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにつまらない思いで、湯槽から這い上って、足の裏の垢など、落して銭湯の他の客たちの配給の話などに耳を傾けていました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心細く感じながらも、ひとりでそっと床から脱け出しまして、てらてら黒光りのする欅普請の長い廊下をこわごわお厠のほうへ、足の裏だけは、いやに冷や冷やして居りましたけれど、なにさま眠くって、まるで深い霧のなかをゆらりゆらり泳いでいるような気持ち、そのときです。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェルト草履は、見た眼にも優雅で、それに劇場や図書館、その他のビルディングにはいる時でも、下駄の時のように下足係の厄介にならずにすむから、私も実は一度はいてみた事があるのであるが、どうも、足の裏が草履の表の茣蓙の上で、つるつる滑っていけない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だしぬけに私の視覚が地べたの無限の前方へのひろがりを感じ捕り、私の両足の裏の触覚が地べたの無限の深さを感じ捕り、さっと全身が凍りついて、尻餅ついた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、揺れる電車やバスの中で立っているときの心得は、ひざの関節も足首の関節も柔らかく自由にして、そうして心もちかかとを浮かせて足の裏の前半に体重をもたせるという姿勢をとるのだそうである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏をくすむるように砂が掘れて足がどんどん深く埋まってゆくのがこの上なく面白かったのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏が丈夫なら草履ははかなくともいいが袴ははかなければいかんといやがる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏はもとより丈夫だが、脛っぷし――というものがあるかないか、腕っぷしがある以上はありそうなものだ――だって丈夫だからな。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい板敷が彼の熱し切つた足の裏にひやりと触れるのだけを彼は感じて快く思つた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永く湯をつかはなかつた爲めに足の裏から踵にかけて、痂のやうに垢がたまつてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳ざわりが素足の裏にさらさらと気持よく触れます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやもほっと安心すると、急に湯上りの温った足の裏に、木肌が冷たく沁み渡って、せいせいした気持になった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふが疾いか、横ざまに驅けて入る、柳腰、下駄が脱げて、足の裏が美しい。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌角の突出で巌石の砕けて一面に転ばっている坂道は、草鞋の底を破って足の裏の痛きこと夥しく、折から雲霧は山腹を包んで、雨はザアザア降って来れば、水はこの巌石の細道を滝のごとく上から流れ落ち、さながら急流を踏んで山を登るに異らず。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、何か足の裏にさゝつたやうな気がして少しく痛かつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいか、熱湯を引いてあります土間を踏むと、足の裏が焦げますようなり、魚見岬へ水柱が立ったといえば、誰が乗るともなく、船がずんずん漕ぎ出して行く、影法師が見えるといいます。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなった日には、足の裏を膠で附着けておかねばなりません。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後で雨戸を閉めかけて、おじい、腰が抜けたか、弱い男だ、とどうやら風向が可さそうなので、宰八が嘲けると、うんにゃ足の裏が血だらけじゃ、歩行と痕がつく、と這いながら云ったので――イヤその音の夥しさ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突出した得物の尖が、右の袖下を潜るや否や、踏占めた足の裏で、ぐ、ぐ、ぐ、と声を出したものがある。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
