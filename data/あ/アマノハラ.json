        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天の原について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天の原という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天の原の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天の原が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天の原を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天の原について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天の原の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天の原の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天の原が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天の原という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天の原という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天の原についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天の原を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天の原は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天の原について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天の原が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天の原は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天の原の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天の原は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天の原は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "七楽しからずや天の原　　そら照る星のさやけさに月の光の貴さに　　心をさらすその時のアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の分れし時ゆ、神さびて高く貴き駿河なる富士の高嶺を、天の原振りさけ見れば渡る日の、影も隠ろひ、照る月の、光も見えず、白雲もい行憚り時じくぞ雪は降りける、語り継ぎ云ひ継ぎ行かん富士の高嶺は。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、天の岩戸扇石、一名辨慶七戻り、高天の原、紫雲石、天の岩戸胎内潜り、國割石、神樂石、大黒石、北斗石、寶珠石、大神石など是れなり。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の原ふりさけ見れば春日なる三笠の山に出でし月かも」　いい歌だ、いい歌が出来たものだと思つて、今一度よみかへしてみると、それは自分の歌ではなく、百人一首に出てゐる名高い安倍仲麿の作だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の原ふりさけ見れば春日なる三笠の山に出でし月かも」　いい歌だ、いい歌が出来たものだと思つて、今一度よみかへしてみると、それは自分の歌ではなく、百人一首に出てゐる名高い安部仲麿の作だつた。",
              "citation": {
                "source": "無学なお月様",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の間にと聞きつつをれば天の原雲にも秋の声立ててけり山風は夜来て山にかへりけむ木の葉屑をば庭に残して　尚先生の倭歌については茲では長くなるから、後日にゆづり略することとする。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の夜の　ほがら／＼と、天の原照る月かげに、雁鳴き渡るほがら／＼といふと、夜明けの空のあかるさを示す言葉です。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の原　ふり放け見れば、大君の御命は長く、天たらしたり（倭媛皇后――万葉巻二）此表現の不足も寿詞に馴れた当時の人には、よく訣つたのであらう。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして又、海の彼方か、山の奥か、但しは天の原から来る村の守り主のお目にかけねばならなかつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○天の原ふりさけ見れば大王の御寿は長く天足らしたり　〔巻二・一四七〕　倭姫皇后　天智天皇御｜不予にあらせられた時、皇后（倭姫王）の奉れる御歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、歌に「天の原ふりさけ見れば」とあるから、素直に天空を仰ぎ見たことと解する旧説の方が却って原歌の真を伝えているのでなかろうかと思うのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は「天の原ふりさけ見れば」といって直ぐ「大王の御寿は」と続けている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○天の原富士の柴山木の暗の時移りなば逢はずかもあらむ　〔巻十四・三三五五〕　東歌　これは駿河国歌で相聞として分類している。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和田の原、天の原、二重の帷徒らにこの彩もなき世をつつみ、風の光の白銀に、潮の藍に、永劫は經緯にこそ織られたれ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、神代の説話において、二大系統である高天の原系統と出雲系統との神話が、或るものは融合して一つになり、或るものは融合しないままの形で接續している。",
              "citation": {
                "source": "古事記",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲系であるスサノヲの命が、高天の原系統の神話に現れることなども、天武天皇が新に整理された結果であるとは考えられない。",
              "citation": {
                "source": "古事記",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二に二を加ふれば四なるは千古に渉りて争ふべからざるが如く先天の原理より演繹し来れる修史の原則は何人も拒む能はじ。",
              "citation": {
                "source": "史論の流行",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日をまほに　家ひとつ見ゆ湖尻の　遠山昏く日はおちて、夕空いよゝ　冴えのこるなりくろ／″＼と　山並みよろふ月あかりに、富士たゞ一つ　かすみたるかも天の原　月高くすみて、更けにけり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "定かならぬ浮雲のごとく天の原に浮游しているんだ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……回天の原動力は水戸にある。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔一、伊耶那岐の命と伊耶那美の命〕〔天地のはじめ〕　天地の初發の時、高天の原に成りませる神の名は、天の御中主の神一。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時伊耶那岐の命｜大く歡ばして詔りたまひしく、「吾は子を生み生みて、生みの終に、三柱の貴子を得たり」と詔りたまひて、すなはちその御頸珠の玉の緒ももゆらに取りゆらかして一八、天照らす大御神に賜ひて詔りたまはく、「汝が命は高天の原を知らせ」と、言依さして賜ひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　高天の原にありとする川。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに高天の原皆暗く、葦原の中つ國悉に闇し。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに高天の原｜動みて八百萬の神共に咲ひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに天照らす大御神｜怪しとおもほして、天の石屋戸を細に開きて内より告りたまはく、「吾が隱りますに因りて、天の原おのづから闇く、葦原の中つ國も皆闇けむと思ふを、何とかも天の宇受賣は樂し、また八百萬の神｜諸咲ふ」とのりたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ天照らす大御神の出でます時に、高天の原と葦原の中つ國とおのづから照り明りき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに日子番の邇邇藝の命、天降りまさむとする時に、天の八衢一に居て、上は高天の原を光らし下は葦原の中つ國を光らす神ここにあり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ此地ぞいと吉き地」と詔りたまひて、底つ石根に宮柱太しり、高天の原に氷椽高しりてましましき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、天照らす大神とスサノヲの命誓約――暴風の神であり出雲系の英雄でもあるスサノヲの命が、高天の原に進出し、その主神である天照らす大神との間に、誓約の行われることを語る。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
