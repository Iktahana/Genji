        "examples": {
          "standard": [
            {
              "text": "私は毎日アンシクロペディストについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンシクロペディストの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンシクロペディストが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンシクロペディストについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンシクロペディストの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンシクロペディストが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンシクロペディストという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンシクロペディストについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンシクロペディストは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンシクロペディストが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンシクロペディストは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンシクロペディストの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンシクロペディストは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンシクロペディストは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は十八世紀末葉から十九世紀初頭にかけての、最高のドイツ的なアンシクロペディストであった。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ロマン派的な世界や宇宙的なものに親しい筈のフィヒテやシェリングに較べて、彼が何故特にアンシクロペディストであったのか、その意味を考えねばならぬ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の場合と同じく彼に於ても、諸文化諸世界の組織的連関に関する興味が一個のアンシクロペディストを産み出しているのであるが、処がそのために欠くことの出来なかったのが文人批判的な社会的関心である。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンシクロペディストなるものは（古典ギリシアに於ける哲学者、ルネサンスに於ける普遍人、十八世紀フランスに於けるアンシクロペディスト、それから現代に於て要求される者――どれも文化的大変動期の産物であるが）他ならぬクリティシズムのこうした機構によって成り立っているのだ＊。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアンシクロペディストのクリティシズム的悟性能力からは割合離れた観念だ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンシクロペディストとクリティシズムとにとっては、守護神は一寸見つからないかも知れない。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスのアンシクロペディストのやうな著作家の団体が生まれてくることも意義がなくはなからうと思ふ。",
              "citation": {
                "source": "辞書の客観性",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程、フランスのアンシクロペディスト達は大部分政治的活動分子ではなかった。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃大アンシクロペディスト達に就いての多少の研究が発表されているし、又一二の人物やテーマに就いての研究ならば絶無ではないが、まだ唯物論史の体裁をなさぬ。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスのアンシクロペディスト達も亦之を、その『百科辞典』（1751）そのものの基本として採用した。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に現代の事情に就いて云えば、この点想像に難くないことだろうし、又前例としてはフランス唯物論者、アンシクロペディストがある。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは一切の植物性食物に含まれている含有味の素が、システムかも知れない、して見るとフランスのアンシクロペディストなどは、こうした文化的味の素の発見者であったわけだ。",
              "citation": {
                "source": "ひと吾を公式主義者と呼ぶ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
