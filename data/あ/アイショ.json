[
  {
    "uuid": "5f6bb6ee-008b-5283-8cb4-3f8da14fa319",
    "entry": "愛書",
    "reading": {
      "primary": "あいしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great love of books",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛書は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛書が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛書に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛書が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛書について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛書についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛書について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛書が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛書が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛書は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛書は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛書を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛書をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛書が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛書の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛書を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛書に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛書について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛書は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛書を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この異彩ある珍書は著者、解説者、装幀意匠者、製紙工、染織工、印刷工、製本工の共同制作によってできあがった一つの総合芸術品としても愛書家の秘蔵に値するものであろう。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを拾い上げてやる時にちらりっと見ると、その中には、「樹木崇拝の起原」と云ったような名前の本もあったが、たぶんこの老人は、あるいは商売にしろ物好きにしろ、とにかく貧しい愛書家で、しかも珍本の蒐集家に相違ないと思った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本と蔵書印　本屋の息子に生れただけあって、文豪アナトオル・フランスは無類の愛書家だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家として聞えている割合には、その蔵書がひどく貧しく、とりわけ新刊物がまるで見えないのに驚いた客は、すなおにその驚きを主人に打ちあけたものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は聞えた外国文学通で、また愛書家でもあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬晴」二絶の一は例の愛書の癖を忘れない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしメリメエの書簡集（誰かわからない女に宛てた恋愛書簡集）はいろいろの話を含んでゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書癖を、その好適例として持ちだした。",
              "citation": {
                "source": "田巻安里のコーヒー",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業も同じようなものであったが、愛書家同志のことで、矢島の来意をきくと、一冊の書物にからまる心労にきわめて好意ある同感をいだいたようであった。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年には、「愛書百人会」といふのが特にドルュエルモに頼んで石版画の挿絵を十六枚描かせ、百三十部限定の豪華版を作つた。",
              "citation": {
                "source": "「博物誌」の序に代へて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家も徒に華装ばかりを尊重したがらずに、こうした所に平明直截な美を打ち立てることに留意してほしい。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家の習書　軍隊の教練のように、兵卒が百人が百人、お一二というわけで、足を揃えて歩むが如き習い方をする書家の書道は、個々について見ますとき、誠に不見識で、是非とも百人が百人違った結果の字を書かなければならぬと思います。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家の心得　書も習うということになりますと、とかく他所行きの姿になりやすい、いわゆる気張って書く。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに、私が、愛書家であり、蔵書家であっても、それで満足がされます。",
              "citation": {
                "source": "書を愛して書を持たず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ私には若干の愛書と、家族を容れて余りある古き二張の麻蚊帳と、昼夜清水を吐いて呉れる小泉と、ジヤマン製の強力なる拡大鏡一つとがある。",
              "citation": {
                "source": "普羅句集",
                "author": "前田普羅",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩集の絶版本を尋ね当てた人の嬉しそうな顔色を度たび見て、そういう鮮度の高い愛書の心を失っている私自身を、あんたんとして私は回顧する時があった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に愛書家なるものがある。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら一家じゅうの愛書となり大変よかったのですが、父さんは、手紙をよこされ、小さい男の子は自分が親代りになって育てるつもりだとのことです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書癖と言へば、アナトオル・フランスが有名な珍・稀・豪書好きで、而も門外不出主義の大家であつた。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、両君の書斎が又愛書家にふさはしい洵に立派なものである。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は非常に稀覯書で、而も扉の見返には近代の愛書家四名の書蔵票が連貼してある。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝になると、彼等は再たのこのこと、馬の糞のように集まって来て、箱の前に呑気な顔を列べて、愛書家の群を待っている。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "その署名がボナパルトとあったか、それとも又ブオナパルテとイタリア流に書いてあったか、其処迄は聞もらしたが兎に角、五年に一度でも、十年に一度でも、斯んな掘出物があるから、愛書家が血眼になったり、蚤取眼になったり、鵜の目鷹の目になったりするのも無理ではない。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家のことを一般にビブリオフィルと呼んでいるが、此の愛書家の癖が高じると、ビブリオマーヌ即愛書狂となる。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の愛書狂の中にも色々種類があって、書籍であれば何でも有難がる奴がある。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書狂の中でも、合掌派や墓守流は未だ未だ無難であるが、之が更に一歩進むとビブリオクレプト即書盗となる。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ物騒な話で、此んな奴が飛び出すと、愛書家はお互に用心し度くなる。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
