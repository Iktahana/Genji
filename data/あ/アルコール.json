[
  {
    "uuid": "f9dfbb8a-9b70-5a9d-a7d9-8eea81c4a70a",
    "entry": "アルコール",
    "reading": {
      "primary": "アルコール",
      "alternatives": [
        "アルコホル"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "alcohol",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルコールについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルコールという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルコールの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルコールが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルコールを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルコールについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルコールの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルコールの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルコールが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルコールという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルコールという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルコールについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルコールを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルコールは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルコールについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルコールが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルコールは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルコールの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルコールは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルコールは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "実際蘭人達は日本酒、殊にアルコール分の強い泡盛は飲めなかつたのである。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、資本主義のアルコールで元気をつけて歩き出した。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の腹の中では、百パーセントのアルコールよりも、「ききめ」のある、コレラ菌が暴れ廻っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラのうちにはアルコールラムプで走る汽車があったんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかアルコールがなくなったとき石油をつかったら、缶がすっかり煤けたよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アルコールか電気だらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕博物館でアルコールにつけてあるの見た。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールで消毒はされるかもしれないがあまり気持の好いものではない。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て児童はどうして出来るかと質問したときに、教師がそれをいいかげんに答えるのはいうまでもなく悪いが、これを知っている場合に、何でもないことだ、アルコールの燃える際に生ずる水蒸気がビーカーにあたって露になって着くのだといって、あまり無造作に片づけてしまうのは面白くないと思う。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近にあったアルコールの数滴を机の上に垂らしてその上に玉虫の口をおっつけると、虫は活溌にその嘴を動かしてアルコールを飲み込んだ。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の表情というものがあり得るかどうか知らないが、ただ机の上のアルコールの減じて行く速度がそういう感じを起させたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールを飲んだ玉虫はとうとう生き返らなかった。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間だとしたらたぶん一ポンドくらいの純アルコールを飲んだわけである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールを入れたのです。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アルコールを入れたのか。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当のアルコールです。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん、随分入れたな、アルコールを。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかアルコールがなくなったとき石油をつかったら、罐がすっかり煤けたよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アルコールか電気だろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　説明も形容も何もない――燐寸を摺ると否や、アルコールに火をつけるのであるから、言句もない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの場合になぜ金属棒は松やにを着けた皮でしごき、ガラス棒だとアルコールを着けた綿布でこするか、この幼稚な疑問に対してふに落ちる説明をしてくれる教師はまれであろう。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく理科の書物なぞにある、ビーカーの底をアルコール・ランプで熱したときの水の流れと同じようなものになるわけです。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清酒と同様に綺麗に澄んでいて、清酒よりも更に濃い琥珀色で、アルコール度もかなり強いように思われた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラのうちにはアルコールランプで走る汽車があったんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかアルコールがなくなったとき石油をつかったら、缶がすっかりすすけたよ」「そうかねえ」「いまも毎朝新聞をまわしに行くよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
