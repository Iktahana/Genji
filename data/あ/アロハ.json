    "definitions": [
      {
        "index": 1,
        "gloss": "aloha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アロハについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アロハという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアロハの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアロハが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アロハを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアロハについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アロハの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアロハの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアロハが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アロハという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアロハという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアロハについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アロハを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアロハは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アロハについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアロハが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアロハは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアロハの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アロハは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアロハは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "-------------------------------------------------------「グッドバイ」「オォルボァル」「アヂュウ」「アウフビタゼエヘン」「ツァイチェン」「アロハ」等々――。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、夏になれば、アロハ襯衣がまた全盛だらうから、ネクタイの商売は駄目ださうだ」「でも、前田さんは、世渡りが上手だから、何をしたつてやつてゆけますわ」　軈て、丼飯、二三品のおかずの皿がついた膳とビールを、さつきの娘が運んで来た。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハのアンちやんでもなかにはいいのがゐるんですね。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画、レコード、ラジオ、新聞とのタイアップが、時には、その「わなの道」に人間を追い込み「利潤対象としての大衆」すなわち「ミーちゃんハーちゃん族、アロハアンちゃん族」を創造することすら、あえて辞さないのである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四八年はアロハシャツと色メガネの大流行時代であったが、アロハユニホームはよろしくないが、色メガネは用いた方がよろしいだろう。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "売ったり買ったりぐらいなら、マーケットのアロハでもできるんだ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私が傍観してきた裏側の人生を通観して、敗戦後、道義タイハイせり、などとパンパン、男娼、アロハアンチャン不良少年の類いをさして慨嘆される向きは、世間知らずの寝言にすぎないということを強調しておきたい。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "よってヘベレケに酔っ払う人種があつまり、パンパンとアロハのアンチャンがたむろする。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のアロハのアンチャン、もっともアロハをきているわけではない、リュウとしたニュウルックのダブル、赤ネクタイの二人づれ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アロハのアンチャン、交番の中でサッと上衣をぬごうとする。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチャン方も、何が何やら無意識に、ただもうアロハ的本能で行動していらッしゃるのかも知れない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "サッと上衣をぬぎかけたり、サッと逃げたり、アロハ本能というもので、相手が一文にもならなかったり、その場に限って自分に弱味がなかったりすると、相手を交番にひッたてたくなるというアロハ本能があるのかも知れない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚悟はしていたことだから、パンパンやオカマや集団強盗など月並であったが、アロハにはおどろいた。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにぶん、アロハというものは、妖怪として登場したものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後、美意識の初の出動がアロハであったから、この次には何がでるかと思うと、怖れおののいたのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップなどゝいうものは、着物をぬげば誰でもなれるのだから、創造せられたもの、衣裳とよぶことのできない原始風俗であるけれども、アロハは衣裳であるぞ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハは風をきり、銀座の風も、新宿の風も、奥州蛇谷村の風も、みんなアロハにきりまくられた。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "概して都心の流行というものは、モガモボにせよ、いくらか当代の最高芸術に心得もあり、寄らば逃げるぞという人種のものであったが、戦後の都心はクリカラモンモンの熱血児に占領されて、日本中、アロハとパンパンに完全にいかれてしまった。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォーブなどというのはアトリエの小細工だが、アロハは熱血躍動する美の化身そのものであるぞ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷談師安吾の想像力がタカの知れたものであるのは当然らしいが、ダ・ヴィンチにしたところで、けっしてアロハほど唐突なイマジネーションをめぐらしてはいないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハの出現に至っては筋はない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハは突如として消え去せてしまったが、世を忍び、地下へくぐったにすぎない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハは生きている。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、生きているどころか、指令を発し、現に美のもろもろはアロハの大きな手におさえられているのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "惑星アロハをめぐる小遊星のタップダンス程度なのが今の世の流行であり芸術だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
