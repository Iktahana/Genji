[
  {
    "uuid": "3bacb5c4-9d7a-51e9-8b8e-cea346a2c5ce",
    "entry": "歩き",
    "reading": {
      "primary": "あるき",
      "alternatives": [
        "ありき"
      ],
      "is_heteronym": false
    },
    "grammar": {
