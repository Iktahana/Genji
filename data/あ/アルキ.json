    "definitions": [
      {
        "index": 1,
        "gloss": "walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩きについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩きという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩きの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩きが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩きを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩きについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩きの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩きの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩きが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩きという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩きという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩きについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩きを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩きは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩きについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩きが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩きは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩きの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩きは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩きは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三人はゾロゾロ私の家の方へ歩きだした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、　歩き出すと案外に平気だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も山も新緑で、はだかになってしまいたいほど温く、私には、新緑がまぶしく、眼にちかちか痛くって、ひとり、いろいろ考えごとをしながら帯の間に片手をそっと差しいれ、うなだれて野道を歩き、考えること、考えること、みんな苦しいことばかりで息ができなくなるくらい、私は、身悶えしながら歩きました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場にはこのまちが始めてのようであったが、べつだん驚きもせずゆったりした歩調で私と少しはなれて歩きながら、両側の小窓小窓の女の顔をひとつひとつ熟察していた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較根性の愚劣」と自分へ説き聞かせるようにゆっくり呟きながら、ぶらぶら歩きだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし歩きましょうよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら、ひとりごとのようにして呟くのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのスリツパをはいて、二階の廊下を懷手して、ぶらぶら歩き、ときどき富士を不機嫌さうに眺めて、やがて部屋へはひつて、こたつにもぐつて、何もしない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年より昭和八年十月迄、毎日々々歩き通す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頻りに早く出世したい気持がして来て、その気持に引き摺られるやうに父のゐない部屋を歩き、歩いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜の町を仰向勝ちにスタスタと歩きながら、「……あなただけに言ふんだから、誰にもスベらせちやあ嫌ですよ……」つてことばがヒツキリなしに頭を往来した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は孤独で居れば居るほど、夜毎に宴会の夢を見るようになり、日毎に群集の中を歩きたくなる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい新聞紙の包を大事そうにかかえて電車を下りると立止って何かまごまごしていたが、薄汚い襟巻で丁寧に頸から顋を包んでしまうと歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の隠しへねじ込むと蜜柑がつかえるから、また片手でしっかりさげて歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰ってどうすると云うあてもないので、銀座通りをぶらぶら歩き、大店のガラス窓の中を覗いてみたり雑誌屋の店先をあさってみたり、しばらくはほとんど何事も忘れていた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば雨のふる日に傘をささないで往来を歩きたいと思ったとしても、なかなかそうはさせてくれない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びヨボヨボと歩き出すと、ひとしきりの風が驀地に道の砂を捲いて老翁を包んだ時｜余は深き深き空想を呼起こした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しずまったころ、三十歳くらいのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまわるのであるが、私は、いまに、また、どこか思わざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉じるのではなかろうかと、ひやひやしながら、読んでいった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻、菊池寛氏へもわが生きかたの粗雜貧弱を告白して、いまは大事の時だ、めそめそ泣いて歩きまはつてゐたつて仕樣がない。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん終りには、Ｙ・Ｔといふ人が、「Ｋ君は歩きながら語り合ふ樣な人であつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら、だんだん嬉しくなつて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は無言で、くるりとうしろを向き、そろそろと歩き出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただああして幽かに笑つて琴をかき鳴らしたり、またこの廣間をふらふら歩きまはつて、櫻桃の花びらを口に含んだりして遊んでゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは、この子は、父に連れられて近所の井の頭動物園に行つた時、檻の中を絶えずチヨコチヨコ歩きまはつてゐる狸の一群を眺め、愛すべき動物であると思ひ込み、それゆゑ、このカチカチ山の物語に於いても、理由の如何を問はず、狸に贔屓してゐたのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は爺さんに捕へられ、もう少しのところで狸汁にされるところであつたが、あの兎の少女にひとめまた逢ひたくて、大いにあがいて、やつと逃れて山へ歸り、ぶつぶつ何か言ひながら、うろうろ兎を搜し歩き、やつと見つけて、「よろこんでくれ！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も、野道をひとりで歩きながら、ふと考へた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の住居は東京の、井の頭公園の裏にあるのだが、日曜毎に、澤山のハイキングの客が、興奮して、あの邊を歩き※つてゐる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
