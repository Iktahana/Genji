        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安臥について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安臥という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安臥の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安臥が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安臥を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安臥について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安臥の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安臥の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安臥が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安臥という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安臥という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安臥についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安臥を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安臥は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安臥について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安臥が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安臥は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安臥の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安臥は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安臥は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "乃ち茲に暫らく閑天地を求めて、心頭に雲を放ち、胸底に清風を蔵し、高眠安臥、興を暮天の鐘にさぐり、思を緑蔭の流光に托し、風鈴に和して吟じ、雨声を友として語り、この夏中百日を暢心静居の界に遊ばんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二十頭の牛は水上五寸の架床上に争うて安臥するのであった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見れば乳牛の近くに若者たちもいず、わが乳牛は多くは安臥して食み返しをやっておった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二十頭の牛は水上五寸の架床上に爭うて安臥するのであつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "來て見れば乳牛の近くに若者達も居ず、我が乳牛は多くは安臥して食み返しをやつて居つた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居から一段低くなって病室の前は広いテレスになって居り、藤の安臥椅子が、いくつとなく、棟のテレスを蓋うた深い廂の下の、はずれからはずれまでとびとびに置いてあった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とよ子が安臥してからは、私への挨拶もそこそこに俄かに忙しそうにして中庭の出入口の方へ、その兄は駈けるような後姿を見せて帰って行った。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずまず座敷へお這入りなされて暫くご安臥なさりませ」　純八は老僕に手伝わせ、急いで褥を設けると、老僧を中へ舁き入れたが、是ぞ本条純八をして、数奇の運命へ陥らしむる、最初の恐ろしい緒なのであった。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドの上に安臥させられた婦人は、一時間ばかりしてぱっちりと目をさました。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はそれにしたがってもとの路へ帰り、ドノバンのたんかをになって洞へ帰ると、残りの少年たちはホーベスを洞へ入れて、ドノバンと同じく床の上に安臥せしめた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜週間の安臥は、御米に取つて實に比類のない忍耐の三｜週間であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ために征服者をして一日も鉄火のもとにその国を鎮圧するにあらざれば高枕安臥するあたわざるものあり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は絶対に安臥を命じた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は医者から安臥を命ぜられて以来、両便とも寝たまま他の手で始末してもらっていた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには彼の予期通り、白いシーツに裹まれた蒲団が、彼の安臥を待つべく長々と延べてあった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識に見捨てられた例の少ない彼としては珍らしいこの気分は、今床の中に安臥する彼から見れば、恥ずべき状態に違なかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三週間の安臥は、御米に取って実に比類のない忍耐の三週間であった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もっとも苦痛が全く取れて、安臥の地位を平静に保っていた余には、充分それだけの余裕があったのであろう。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇化のうるおすところ遠く草莽に及び、余のごとき微臣、なお茅屋の下に安臥して閑歳月に伴うを得。",
              "citation": {
                "source": "妖怪学講義",
                "author": "緒言",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出づれば起きて働き、日没すれば安臥すると云ふ、いとも自然なる生活である。",
              "citation": {
                "source": "青年よ師を無数に択べ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い秋の日を、一日一杯｜寝椅子で安臥している病院生活の間中、寝ても醒めてもただうつらうつらと、日となく夜となく頭の中で私にほほえみかけてくるものは、ただジーナとスパセニアの二人だけだったと申上げたら、その時の私の焦慮と焦心が察していただけるかも知れません。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物慣れた看護婦が注射をして、病人を安臥させる。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドに運び入れて安臥させる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は此の安臥の上に前に述べた主義に從ひ、或る精神的體驗を加へたのである。",
              "citation": {
                "source": "神經質に對する余の特殊療法",
                "author": "森田正馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥の如き大軍をかき分けて、孫堅とやらを始め、曹操、袁紹など逆徒に加担の諸侯の首を、一々大地に梟けならべてご覧に入れん」「いや、たのもしい」と、董卓も大いによろこんで、「そちがおればこそ儂も枕を高くして、安臥しておられるのだ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、堂上を見れば、几席のうえにのびのびと安臥している一箇の人がある。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "周瑜は営中の一房に安臥しても、昏々とうめき苦しんでいる。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "父っつあんがお貸元を追い返したんだろう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父っつあんがいくら……いくら、いくら何んと云ったって……」　「もういい石松、分った分った分ってるよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ァ父っつあんが許して呉れなくとも行くよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
