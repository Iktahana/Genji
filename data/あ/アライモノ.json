        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日洗い物について考えている。",
              "source": "幻辞"
            },
            {
              "text": "洗い物という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は洗い物の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には洗い物が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "洗い物を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは洗い物について学習した。",
              "source": "幻辞"
            },
            {
              "text": "洗い物の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は洗い物の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では洗い物が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い物という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に洗い物という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では洗い物についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "洗い物を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると洗い物は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "洗い物について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では洗い物が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に洗い物は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により洗い物の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "洗い物は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に洗い物は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "静かな台所でことことと音のするのを便りに其処の戸を開けてみると、ファニーが後ろ向きになって洗い物をしていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　このお家へは、お台所で、洗い物のお手伝をいたします。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、階段を降りようとして、ふと見ると、洗面所で何か洗い物をしているらしい、痩せて背の高い、長髪の男のうしろ姿が眼にはいった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悲しくなってしまって、店の隅で黙々と洗い物をしているマダムの妹の、十五歳らしい固い表情をふと眼に入れながら、もう帰るよと起ち上ったが、よろめいて醜態であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはまは例の苦のない声で小唄をうたいながら台所の洗い物をしている。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな夜ふけになぜ洗濯をするかというに、風呂の流し水は何かのわけで、洗い物がよく落ちる、それに新たに湯を沸かす手数と、薪の倹約とができるので、田舎のたまかな家ではよくやる事だ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっすら明るい梅の下に真白い顔の女が二つの白い手を動かしつつ、ぽちゃぽちゃ水の音をさせて洗い物をしているのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよはもう洗い物には手が着かない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代わり年とった女を二人｜傭って交代に病院に来さして、洗い物から食事の事までを賄わした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大通りを曲って自分の家のある路地へ這入ると直ぐ、其処にある水道｜栓で、彼の妻が洗い物をして居た。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、妻は洗い物を早々に片づけ始めた。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と……そのときはしなくも耳を打ったものは、そこの勝手わきの井戸ばたで、じゃぶじゃぶと洗い物をでもしているらしい水の音でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週に一度は、派出婦がやって来て、食料品を補ったり、洗い物を受けとったりして行くのが例だった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉のない猫柳の下に井戸があって、女房らしい二十四五の女が何か洗い物をしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "雇い婆は二階へ上るし、小僧は食台を持って洗槽元へ洗い物に行くし、後には為さん一人残ったが、お光が帯を解く音がサヤサヤと襖越しに聞える。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自炊はさして面倒なものではなくむしろ楽しかったが、後の洗い物が苦手だったから、これは附近の老婆に御飯と一緒に頼むことにした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗い物をして来たお熊は、室の内に入りながら、「おや、もうお起きなすッたんですか。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさやは本気な相好で、まるでバンと一つくらわせさえすれば、洗い物の方でよごれはさっと吐き出すという約束でも出来ているように、確信をもって、簡単にくらわして安心している。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江が洗い物をしているのであろう。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の方へ行って、構うことはない、一升壜から冷酒をコップについで、それをあおりながら、がしゃがしゃ洗い物をした。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素は、菜っ葉とか芋とかその他の洗い物などが、水を切るために並べられるぐらいなものであろう。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が洗い物をしていられる時、花を拾ったり、流しから落ちる水に蛙がいるので、烟草の粉を貰って来て釣ったりします。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、コトコトと音がした、下女が台所で洗い物をしていて、器と器とをぶっつけたのでもあろう。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ早いのか晩いのか、どこかで寺の鐘でも鳴らないか――と、大迫玄蕃が耳をすますと、台所で洗い物をする音がかすかに聞えて、折助どもの笑い声もするようだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーミ　洗い物はしねえのかい。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしらんとこじゃ、勘定の最後にフランス語と音楽と洗い物は「せんたく」てえあったな。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「洗い物はしねえのかい？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
