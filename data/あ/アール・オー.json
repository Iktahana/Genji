        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日ＲＯについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はＲＯの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはＲＯが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはＲＯについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はＲＯの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではＲＯが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にＲＯという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではＲＯについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとＲＯは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではＲＯが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にＲＯは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりＲＯの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "ＲＯは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にＲＯは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターで広く使われている器に、もともと音楽用に開発されたＣＤの技術を応用した、ＣＤ―ＲＯＭがある。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章や音、さまざまな映像をあらかじめ焼き込んでおけば、一枚のＣＤ―ＲＯＭからそれぞれを引き出せる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはさらに、ＣＤ―ＲＯＭから情報を引き出したり、レーザーディスクをコントロールする機能を付け加えることができました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く使われるようになってきたＣＤ―ＲＯＭならさらに、フロッピーディスクの五百倍近い六百五十メガバイトまで入ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダグラス・アダムスはおおぼらを吹いたつもりで、本の百万ページ分が入ると書いていますが、ＣＤ―ＲＯＭはもう、彼の冗談をすっかり台無しにしています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＣＤ―ＲＯＭは、パワーブックのような小型のマシンでも、すぐに使えるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに誰かが作ってくれたＣＤ―ＲＯＭを読むだけではなく、自分で作ることも簡単にできるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの専門誌を開くと、一枚からＣＤ―ＲＯＭ作りを引き受けるお店の広告が載っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤ―ＲＯＭを作る装置の値段も、実売価格で十万円を切るところまで落ちてきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿のデジタル化がすんでいるのなら、今日にでも数千冊の本をおさめたＣＤ―ＲＯＭを自分で作れるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "枚数のまとまらないうちは、ＣＤ―ＲＯＭの単価は一枚あたり数千円についてしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみれば、数千冊分の本が、数千円のＣＤ―ＲＯＭに入るのだから、この時点でもう「安い」というべきなのかもしれません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "原盤からプレスする方式で数百枚まとめれば、一枚三百円前後でケースに収めたＣＤ―ＲＯＭが出来上がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "島流しにあうとしても、ＣＤ―ＲＯＭ一枚持っていけば、まず、十年やそこらは読む物に不自由しないでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤ―ＲＯＭに代わる今後の標準として期待されるＤＶＤでは、容量はもう一桁上がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社はすでに、この『大百科事典』をＣＤ―ＲＯＭ化しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "値上がりして十八万六千円になっている紙の版の価格を、当初ＣＤ―ＲＯＭ版は大きく上回っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、彼らはＣＤ―ＲＯＭ版を用意し、私は別に自分でコンピューターに投資して、電子本の読める環境を整えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の版を返すから、ＣＤ―ＲＯＭ版で戻して欲しいと平凡社にお願いしてみたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚百円程度といっても、ＣＤ―ＲＯＭをプレスする費用もかかります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤ―ＲＯＭの製作原価は紙よりよほど安く付くはずなのに、むしろ電子辞書の定価は、おうおうにして従来のものよりも高くなっているありさまです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、たくさんの本をフロッピーディスクやＣＤ―ＲＯＭのような小さなメディアにおさめられる点。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年、アップルは初めてマック用のＣＤ―ＲＯＭドライブを売り出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大容量のメディアとしてかねてから期待されていたＣＤ―ＲＯＭが、ようやくマックで使えるようになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライバルのＣＤ―ＲＯＭははるかに小さく、専用の再生装置もコンパクトに仕上げることができます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当たり前になってきたＣＤ―ＲＯＭ　当初エキスパンドブックとして出し直そうと考えてから、一年あまりをかけて原稿を準備する過程で、電子出版物をめぐる状況はかなり大きく変わってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい機種のほとんどが、ＣＤ―ＲＯＭの再生装置付きで売られるようになり、アプリケーションも、ゲームも、電子化した本や写真集の類も、一気に虹色に光る銀色の円盤で供給されるようになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌の付録にＣＤ―ＲＯＭが付くようになったのも、この頃です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロッピーディスクの五百倍近い容量を持つＣＤ―ＲＯＭが使えるとなると、電子出版物でも動画や音にころうという意識が強まりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
