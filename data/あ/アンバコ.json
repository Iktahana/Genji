    },
    "definitions": [
      {
        "index": 1,
        "gloss": "camera obscura",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗箱について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗箱という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗箱の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗箱が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗箱を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗箱について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗箱の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗箱の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗箱が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗箱という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗箱という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗箱についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗箱を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗箱は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗箱について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗箱が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗箱は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗箱の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗箱は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗箱は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは、子｜供向きに寫眞の沿革から撮影、現像、燒｜付の法、それに簡單な暗箱の作り方までを説明してある。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄板を組合せて名｜刺形の暗箱をこしらへる。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手｜製の暗箱をこしらへた頃、毎日目｜録を眺めては樂しんでゐた頃、汽車の疾走などを大｜騷ぎで寫して喜んでゐた頃、それらを思ひ返すと、私の胸には何かしら變な寂しさが湧いてくる。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイルハルト・ウィーデマン Eilhard Wiedemann の研究によると、この人は日食の観測に針孔暗箱を用いた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も映画固有な現物的なリアリズムから云って、色彩の或る程度以上の誇張はインチキ性を孕んで来るが、併し写真機の暗箱の底に写る倒影に見られる程度の光彩の集中は、慥かに良いものだ。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "同博士が自分の頭蓋骨と名付くる「天然色、浮出し、発声映画撮影機の暗箱」に取付けている二つの眼球のレンズと、左右の耳朶のマイクロフォンに、如何なる順序で、そうした事件の推移が印画されて来たかという事を、その順序通りに廻転して行くフィルムに就て説明して参ります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その動きは、二枚の種板が一つの暗箱の中でずって動くように、上層官吏と下級官吏との間で、いくらかずつ異った利害をもっているのだろうとも、推察される。",
              "citation": {
                "source": "石を投ぐるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ上ニ大型ノ写真ノ暗箱ノヨウナ機械ガ天井カラ降リテ来テ予ノ姿勢ノ上ニ巧ク出会ウヨウニ加減スル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノタビゴトニ暗箱ノ調節ガアリ、可ナリ面倒デアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の書斎は、四方の書棚も窓も壁も黒布で覆い隠して、一つの大きな暗箱の様にしつらえられていた。",
              "citation": {
                "source": "悪霊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を申しますと、これは私が学校をすませて帰って来て、第一にやったいたずらなのですが、私は、自分の居間と私の家の女中部屋とを、例のレンズと鏡で出来た、様々の形の暗箱を装置して、熟れた果物の様な肥太った、二十娘の秘密を、隙見してやろうと考えました。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋の目につかない様な、例えば天井の隅っこなどに、私の発明した鏡とレンズの装置を施し、そこから暗箱によって、天井裏などを通路にして、光線を導き、女中部屋で鏡に映った影が、自分の居間の机の上の鏡にも、そのまま映る様な仕かけを拵えた訳なのです。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の隅にとりつけた、鼠色の暗箱の中には、方二寸ほどの小さな鏡が、斜めに装置せられ、上のレンズから来る脱衣場の景色を、まざまざと映し出しています。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
