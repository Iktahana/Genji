  {
    "uuid": "c7174d96-e87a-57ad-a2aa-bf28c2a30441",
    "entry": "暗箱",
    "reading": {
      "primary": "あんばこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
