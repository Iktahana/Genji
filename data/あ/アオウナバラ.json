    "definitions": [
      {
        "index": 1,
        "gloss": "the blue sea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "朝晴の蒼き大空は、軽いが頭に近いよう、彼方にごろごろと音がして、黒きかたまりの緩やかに畝り畝り、遠ざかり行く、車、雲助、その行くあたりちらちらと、白い雲の動いて見ゆるは、狭間に漏るる青海原、沖に静な鴎の波。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三いヤァハレ海原や青海原。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五章　速吸と菟狭その一男声独唱海原や青海原、海道の導や、早や槁根津日子、速吸の水門になも、その珍彦。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五章　速吸と菟狹その一男聲獨唱海原や青海原、海道の導や、早や槁根津日子、速吸の水門になも、その珍彦。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青海原の星天井で山のような浪また浪の中ですけに宜うがすなあ……四海浪、静かにてエー……という歌はここの事ばいと思いましたなあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眸を轉じて望めば、火山の輪廓は一抹の輕雲の如く、美しき青海原の上に現れたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは星斗のきらめける空を仰ぎ、又熔巖の影處々に紅を印したる青海原を見遣りたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの青海原を悠々と泳げ廻れたらどんなに愉快なことだらう！",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――眼を瞑ると、渺茫たる青海原が陽春の日の下に凪ぎ渡る……間もなく彼の肉体はその喜びだけで充満する――「一時も早く彼の海辺へ走らう、それだけが今の俺は唯一の心からの希望だ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇のおそひ初めた街路を一人で帰つて行く途中、私の心の中には異常に凄壮な大きい青海原が見え初めた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の上にあがつた円い月が、畳々たる田畑の青海原に隈なき光りの翼を伸べひろげて濛々と涯しなく霞んでゐました。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隈なき月の光りで青海原のやうに畳々とした畑の中を奴等はスイスイと、恰で氷滑りでもしてゐる見たいに速やかに走つてゐた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あたりは再び動くものゝ影だに見へぬ渺々とした青海原であつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "走つてゐるのか、滞つてゐるのか、何うしても見境のつかない小舟が点々として落葉のやうに青海原に散つてゐた。",
              "citation": {
                "source": "陽に酔つた風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向て瞻る蒼空には、余残の色も何時しか消え失せて、今は一面の青海原、星さえ所斑に燦き出でて殆んと交睫をするような真似をしている。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の家の裏あたりから、川幅は次第に広くなって、浪に漾っている海猫の群れに近づくころには、そこは漂渺たる青海原が、澄みきった碧空と融け合っていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "青海原沖さけ見ればあらしほを空にいぶきて鯨浮べり「雨とふらせて」「雲かかる」の二句を除きたるは至極賛成なるが、これも結末に今一歩と思ふ所なきにもあらず候。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで眼ざす鯖の群れが青海原に見えて来ると、一人は艫にまわって潮銹の付いた一挺櫓を押す。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程外観は東洋哲学的で、瞑想する如く、一竿をのべて山水に対し、青海原の青冥とともに、悠々として水天一如の境地にあるやうに見えるが、あの気持を大きくいふと、真剣音無しの構へだ。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（笑う）笑は罌粟の畑をすぎて、青海原へ沈み行くのに、何も知らぬ領主の君。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃至は明けても暮れてもただ鬱然たる山をだけしか見る事の出来なかつた人の前に、図らずも開けた青海原のそれであつたかもわからなかつた。",
              "citation": {
                "source": "「明の古染付」観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤヌッセンは、ここで、助手のガンスと同伴者と、三人で、筏を造りはじめ、一週間後に、地底の青海原に乗り出す。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかはなにひとつ目に止まるものもなく、どこを見ても、ただ茫々とした青海原でありました。",
              "citation": {
                "source": "不死の薬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "任日上人の句に「蓼酢とも青海原をみるめかな」とあるのは、自分の考えでは、青海原を蓼醋とみなしてそれに云いかけた洒落であろうと思うが、多分海松は蓼醋などで喰べたものであろう。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して根国と青海原と、或点に於て、互に其性質を融通する以て見れば、太古の世界観に於て、海洋が如何ばかり重要の位置を有せしや、之を想像するに難からず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "7205青海原のほとりへ、われ等の住む野へ来まさば、そを皆おん身に語るべきに。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常によい天気であったので、僕は甲板へ出て、いい心持ちで清らかな朝の日光にひたりながら、僕の部屋の腐ったような臭いとはまるで違った、薫りの高い青海原のそよ風を胸いっぱいに吸った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る承安元年には、深く考えることもせず一時の出費と思い、ひとえに将来の利益になると考えて、却って不覚にもお勧めいたしましたが、その翌年、八月二日の台風により、潮水の氾濫にて築島は、残念この上なく元の青海原に没してしまいました。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
