          "literary": [
            {
              "text": "頭を掻くような恰好をした。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "』一同はたゞ頭を掻くのみ『はい、はい、どんな事でも／＼。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに沢山要るものは、自分たちでお金を出して、しまに買って来て貰ってお使いなさいよ」　すると、連中は「へい／＼」と頭を掻く真似なぞして母の言うなり通りにします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッハッハ」と豪傑笑いをして一寸頭を掻くと、首をすくめて、「なに、いや、そのう、銀座でこれをやっていたんでね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と山伏は頭を掻く。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち去らむとするに臨み、裸男幹事の槇園君に向ひ、『會費を』と云へば、槇園君嗔りて、『花の下に金錢を計算する沒風流あらむや』といふに、裸男閉口して頭を掻く。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今晩、三河屋會食の約あるを忘れたるか』と、天隨君に注意せられて、更に又頭を掻く。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『乃木大將の別莊は何處ぞ』と、夜光命に問はれて、『それは知らず』と頭を掻く。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男一言もなくして、頭を掻く。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が何と云はうが、彼と云はうが、如何ばかりの黄金をふりまかうが、舟を出すべからざる時には、出し申さずと、子供扱ひにせられて、覺えず頭を掻く。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ものを云ふ毎に左右にゆらゆらと肩を揺り動かせながら、わけもなく恐縮の態で頭を掻くのが癖だつた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を掻くと、白板があるという信号だったり、鼻の頭をこすると連風牌があるということだったりする簡単な信号から、もっと秩序だったものでは、持牌十三枚の間、適当なところをすこしすかしてみたり、又一枚ぐらい列から前へ出したり、後へ下げたりして、入用な牌を相手に求める方法もある。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外事を素破拔かれた藝妓が、對手が新聞記者だけに、弱つて了つて、援助を朋輩に求めてるのもあれば、反對に藝妓から素破拔かれて頭を掻く人もある。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外事を素破抜かれた芸妓が、対手が新聞記者だけに、弱つて了つて、援助を朋輩に求めてるのもあれば、反対に芸妓から素破抜かれて頭を掻く人もある。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　甲谷は頭を掻くように笑いながら、一寸後を振り返ったがまた急いだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を赤らめて、頭を掻く私をたしなめるように先生は言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや一般にこういう手合いが頭を掻くのはどういう時だろう？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア人が頭を掻くのには、その場合々々によって、実にさまざまな意味があるのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がわざと頭を掻く振りをして手をあげても、悪魔は自分に向つて十字を切られるのではないかと思つて、一層はやく翔つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これでは遲く來て、それで少しも掘らない者が、一｜番勝利を得た譯ですね』　水谷氏と余とは頭を掻くの他はなかつた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕末に困ったが、頭を掻くだけにした。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、さすがの三角定木も、こうなると頭を掻くより他わありません。",
              "citation": {
                "source": "三角と四角",
                "author": "巖谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘、真紀と顔を見合せて頭を掻く。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（頭を掻く）可児君　　それで早く云ふと、土地を買へつて云ふんでせう。",
              "citation": {
                "source": "可児君の面会日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（また頭を掻く）木暮妙　　（袖で顔をかくして笑ふ）織部　　その広告文ぢや、君、荻窪や吉祥寺と変つたところはないぢやありませんか。",
              "citation": {
                "source": "可児君の面会日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、変な手つきをして頭を掻くの。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手ということは一体どういうことだかはっきり分らずに、ただ下手だから恥ずかしい、書けないから恐い、従って無意味に頭を掻くというようなことになるのでありますが、この点をよく呑み込んで分っていないと、それこそ恥ずかしいことになって、常に不愉快だと思うのであります。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "再認識しなくちゃ悪いね」と、頭を掻くばかり。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（木谷君と指名された男優Ｅは頭を掻く）女優Ａ′　　先生、筋は……？",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "海仙氏もあたまをかく。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
