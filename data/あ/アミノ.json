        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アミノについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アミノという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアミノの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアミノが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アミノを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアミノについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アミノの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアミノの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアミノが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アミノという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアミノという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアミノについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アミノを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアミノは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アミノについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアミノが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアミノは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアミノの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アミノは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアミノは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああやっと見つけたという工合だわ　　アミノ　と。",
              "citation": {
                "source": "情景（秋）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初句、原文「嗚呼見浦爾」だから、アミノウラニと訓むべきである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し史実上で、阿胡行宮云々とあるし、志摩に英虞郡があり、巻十五（三六一〇）の古歌というのが、「安胡乃宇良」だから、恐らく人麿の原作はアゴノウラで、万葉巻一のアミノウラは異伝の一つであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさ子　アミノピリンを抜くのよ。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋演舞場へ行って中井さん、アミノさんに会い、三人で又歩き、中井さんを有楽町まで送って尾張町からタクシーでかえる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノ、モヤーの古い西部という友達。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "直観したところはちがいませんが水分をふくみますから出があります云々」九月二日（木曜）　アミノさん一日居。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい、澄んだ、磨いたような空気、さぞ今日など竹藪が美しいだろうと思って散歩を欲したが、アミノさん動かず。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨なり、又ツーリングをよんで、日本橋により、アミノさんのところまでかえって、一服。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさん、十月までに奈良に行く故、東京のなごりがおしそうに見えた。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　昨夜アミノさんから借りて来た中川一政の『見なれぬ人』をよみ、感動した。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十九日（火曜）　八木さん、かえりにアミノさんのところへ廻る。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさん今日奈良に立つなり。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさん部屋がなくて家をかりた由。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさんにハガキを書く。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさんに永い手紙を書く。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノさん、黙って居たの、本当なり。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三日（日曜）　アミノさん、和田さんつれ立って来た。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田、アミノ、丹野、苅田、関、林町へ絵ハガキを書いた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前アミノさんとしたときは一向要領を得なかったが、今度は判ったし、又飽きぬ理由判明して愉快。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大瀧の叔母、アミノさんのところ、英男、苅田さんのところ、そして近くに小柳さんの死を見、小山内さんの死、沢田正二郎、高畠、何とうつり変ったことか。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Sole七月二十五日（土曜）　夕方、アミノさんと御飯たべていたら、信吉来。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯、アミノさんと。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔの細君曰ク「うちは消費組合運動に不賛成ですよ、小売商人がこまるからって――」〔欄外に〕　○相原さんをつれてアミノさん来。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりにアミノさんと三人銀座をずっと歩く。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺で秋の茸のいちばん早いのはアミノメという茸である。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノ酸とマグネシウムとはうんぬんというようなこともあるのかもしれないが、海の魚には海の塩があうといっておいたほうが、余韻があるかもしれない。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同位元素アンモニアから合成したアミノ酸の少量を窒素平衡状態にある成熟ラットの餌に加えると、組織タンパク質に急速に大量に取り込まれることが示された。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂肪酸と同じようにこれらのアミノ酸は化学変化を受ける事実が示された。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
