[
  {
    "uuid": "d68ee284-ceef-5c3a-90e3-156f4ede048f",
    "entry": "現る",
    "reading": {
      "primary": "あらわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Nidan verb (lower class) with 'ru' ending (archaic)",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to appear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日現るについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "現るという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は現るの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には現るが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "現るを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは現るについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "現るの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は現るの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では現るが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "現るという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に現るという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では現るについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "現るを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると現るは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "現るについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では現るが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に現るは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により現るの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "現るは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に現るは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "古より文人墨客の輩綾瀬以上に遡らずして、たまたまかゝる地あるを知らざりしかば、詩文に載せられて世に現るゝことなく、以て今日に至りしならん。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その根本の性を無性と説き、その上に現るる因果の法は歴然であると説くのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ刹那、千年に一度現るるかの星こそは、われとわが醸みにし酒の火の飛沫、――濃き幻のしたたりに天さへ燬けむ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "会半ばにして裁判所長ツェダルクランツ現る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻無比の傑作現るとか何とか。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのとき、警察が現る。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるを忽ちにして我はその目前に現るゝを覺えき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏は卑しげなるものから、美しき髮長く肩に掛かり、その目なざしには、常にいと憂はしげなる色見えて、をり／＼は又手負ひたる獸などの如きおそろしき氣色現るゝことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして黒き物の其前に現るゝあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おん身の心のマリアに惹かるゝは、戀の神の所爲なれば、人の噂は遠からず事實となりて現るゝならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時青年エリフ仲裁者として現る。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはいよいよ武光という人もありけり、縁起などいうものは多く真とし難きものなれど、偽り飾れる疑ありて信とし難しものの端々にかえって信とすべきものの現るる習いなることは、譬えば鍍金せるものの角々に真の質の見るるが如しなどおもう折しも、按摩取りの老いたるが入り来りたり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座もし東京に裏街といふものがなかつたら銀座は日本一の表街だが、表は表だが銀座は医者にひつくりかへされたトラホームの眼瞼のやうだブツブツと華美で賑やかな消費の粒がまつかにただれて列んでゐる突如　　ウヰンドーに煉瓦を投げつけて金塊を盗む悪漢現る。",
              "citation": {
                "source": "小熊秀雄全集-11",
                "author": "詩集（10 ）風物詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人現るると見ると、色めき立ちつつ、一斉に気負い出したので、早くもそれと推定がついたもののごとく、微笑をみせたのは退屈男です。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此時ヂュリエット二｜階の窓に現るゝ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロミオとヂュリエットと樓上の窓口に現るゝ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "哨戒艦現る　半かけの月は水平線の彼方に落ち、南シナ海は今やまっ黒な闇につつまれている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、誰か早くいって、団長閣下へ報告をしてこい」　突如、怪人物現る。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リット少将は、日本潜水艦現るとの報に、愕然と顔色をかえた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本潜水艦現るとさわいでいる最中に、検閲点呼のことについてもないじゃないか」「はっ、しかし重大事件でございますので。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から海豚の群舷側に現る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく煙の立つたいまつをもった男二人、二十人ほどの武士のあとから飾りたてた白馬に乗った法王が現る。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を敲けば盃酒｜忽焉として前に出で財布を敲けば美人｜嫣然として後に現る。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前方近距離に氷山現る。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　こうしてこのキャリフォルニアン号の発した無電警報、「前方近距離に氷山現る。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、マー坊出沒常無し、こゝに隱れ彼處に現る。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰ひ／＼て鍋の底現るゝ時、第二の鍋は來りぬ。",
              "citation": {
                "source": "闇汁圖解",
                "author": "子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をさますとすぐ昨夜の事件が気にかかり出したので床の中で新聞紙を手あたり次第にひろげて見ると、ある、ある、「秋川家の殺人」とか「秋川家の惨劇」「殺人鬼現る」とかいう標題でゆうべの事件が盛んに報道してある。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹地に三羽の烏あらわる。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場の観覧料は多年の習慣に従って、今まで銀何匁と唱え来たりしが、この座が初めて何円何十銭に改め、爾来その例に倣うもの続々あらわる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
