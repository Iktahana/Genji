      {
        "index": 1,
        "gloss": "dancing that expresses the meaning of the song lyrics",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
