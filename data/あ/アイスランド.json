    "definitions": [
      {
        "index": 1,
        "gloss": "Iceland",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の冬は、オーロラ観賞のために愛斯蘭へ旅行する予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "愛斯蘭南部の活火山が噴火し、周辺地域に影響が出ています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "愛斯蘭の作家が書いた古代の英雄譚は、世界中で読まれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "愛斯蘭では、地熱エネルギーを積極的に活用した再生可能エネルギー開発が進んでいます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやー、愛斯蘭の氷河はすごいね！」と、友人は感嘆の声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "愛斯蘭の氷河洞窟ツアーは、一年を通じて限られた時期にしか体験できない貴重な機会です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "愛斯蘭のラム肉は、その清らかな環境で育つため、独特の風味があると言われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "anger はアイスランドの 〔a&ngr〕 やＬの angor などのような「憂苦」を意味する言葉と関係があるそうで、一方ではまたスウェーデンの「悔恨」を意味する 〔a&nger〕 に通ずる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかけ離れたアフリカへんやアイスランドまでも網の目を広げられる事になってしまうのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドの火山 Askja は同国古語の Aska（灰）であるとすれば、これは英語の ashes（灰）と親類だそうである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりいけなけあ仕方ないから館長様へ申し上げてアイスランドへ送っちまうよ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（７）アイスランドの東南、スコットランドの北方の洋上にある諸島。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはまたその面積においてはデンマーク本土に二倍するアイスランドをもちます。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドの伝説に、何でも出す磨を試すとて塩を出せと望み挽くと、出すは出すは、磨動きやまず、塩乗船に充ち溢れて、ついにその人を沈めたとあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドも蛇なきを以て聞えた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわくファン・トロールの書に「アイスランドの蛇―なし」これだけを一章として居ると。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前代未聞のこの怪事件を最初に発見し、そしてその現場に一番乗りをした上に、全世界の報道網に対し輝かしき第一報を打つことに成功したデンマーク新報のアイスランド支局員ハリ・ドレゴの命名によるものであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼の父の代になって――というよりも数年前、このアイスランドがデンマーク領たることを御免蒙り独立してしまってからは、イギリス軍やアメリカ軍の進駐となり、古い淋しいアイスランドは急に夜が明けたように賑やかになった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何月何日の深夜、この汽船は発狂の極、アイスランド島ヘルナー山頂に坐礁した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼムリヤ号は、或る予期せざる椿事のため、或る巨大なる力を受けて北極海から天空に吹きあげられ、そして遂にこのアイスランドのヘルナー山頂へ墜落したのだろう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゼムリヤ号が北極海からこのアイスランドへ飛来したという説は、全く事実に反するものだ」「なに、事実に反するって。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "警告の手紙　サンキス号は、アイスランドを後にして、一路南下していった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレゴは都合により、今日の海底探検に同行することを辞退したいこと、それから彼は出来るだけ早くこの調査団から離れて、アイスランドへ戻りたいことを申述べた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして護衛艦の一隻が今日、アイスランドへ引返すことになっているから、それに便乗して行ったがいいだろうといって呉れた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はドレゴが急にこんな翻意をするようになったわけは、その前夜、アイスランドから一通の無線電信を受領したことに拠る。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "花束の待人　この事件が起こって以来ずっと一緒に手をとって来た親友水戸記者を大西洋に置去り、自分ひとりアイスランドへ帰っていくドレゴの気持ちは、さすがに晴れなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "早合点「おお、エミリー……」　ドレゴの前へ飛び出してきた女は、チョコレート色の長いオーバに大きなお尻を包み、深緑のスカーフに血色のいい太い頸を巻いた丸々と肥えた年増のアイスランド女だった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアイスランド海域の監視人なのよ」「なに、やっぱり原子爆弾か。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはヤクーツク造船所の一代理人だが、原子爆弾防衛委員でもなければ、アイスランド海域の監視人だなんて、それは嘘ですよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドは勿論のこと、大西洋全域から、各国の重要都市が一つ残らず探索されたけれど、どこにもワーナー博士一行の新しい消息も見当らず、聞き当らなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の手紙　話はアイスランド島のオルタの町へ飛ぶ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランド火酒の味が忘れられないで、またやって来たよ」「船長、二年間も忘れているなんて、そんな法はないですよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船はアメリカからこのアイスランドへ直航したんでしょう」「そのとおりだ」「そうでしょう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は、実にワーナー博士が水戸のために海底より救い出され、気息奄々たる身体をサンキス号の船上に移したその翌朝のことで、当時サンキス号はアイスランド島のオルタ港へ急航の途中にあり、突然大統領からの暗号電報に接した次第であった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときワーナー博士は、思う仔細があって、水戸を手放し、アイスランドへ赴かせたのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
