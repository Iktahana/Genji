[
  {
    "uuid": "63ca7ed7-3044-55c2-b7d7-1df2e0ff0e26",
    "entry": "愛斯蘭",
    "reading": {
      "primary": "アイスランド",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
