    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩むについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩むという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩むの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩むが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩むを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩むについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩むの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩むの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩むが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩むという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩むという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩むについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩むを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩むは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩むについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩むが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩むは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩むの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩むは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩むは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いかなれば蹌爾として時計の如くに憂ひ歩むぞ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二足三足歩むほどに、をみな、あわただしげに呼ばふ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが喫煙おまへのその、白い二本の脛が、　　夕暮、港の町の寒い夕暮、によきによきと、ペエヴの上を歩むのだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "西に向いて、また一峰を超え、やや下ってまた北に向って上る、霧の中で目標にする山もないから、手に磁石を放さない、何でも北へ向けばいいのだ、北へ、北へと歩む。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵も決然、波打ち際を歩む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はまた、浮気な貴女を愛することは禁断道路を歩むよりも一層困難に思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を塞ぎ、呼吸をころしてひそみたるに、四足のものの歩むけはいして、社の前を横ぎりたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村の組は勝手にふざけ散らして先へ行く、大友とお正は相並んで静かに歩む、夜は冷々として既に膚寒く覚ゆる程の季節ゆえ、渓流に沿う町はひっそりとして客らしき者の影さえ見えず、月は冴えに冴えて岩に激する流れは雪のようである。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原の径を歩みてはかかるいみじき想いも起こるならんが、武蔵野の路はこれとは異り、相逢わんとて往くとても逢いそこね、相避けんとて歩むも林の回り角で突然出逢うことがあろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この路を独り静かに歩むことのどんなに楽しかろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を目がけて小走りに歩むその足音重し。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど空気は重く湿り、茂り合う葉桜の陰を忍びにかよう風の音は秋に異ならず、木立ちの夕闇は頭うなだれて影のごとく歩む人の類を心まつさまなり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢路を歩む心地で古い記憶の端々をたどりはじめた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "常住｜湿り気の乾ききらないような黒土と混って、大小の丸石が歩む人の足を妨げるようにおびただしく転がっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど神は歩むべくわれに他の道を賜へり」と結論した事や「人は其の終局に於て遂に孤立せざる可らず」と書いた事やを思ひ出した。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前檣と後檣との間を四五｜回も往復する内に其惡感も次第／＼に薄らいで來たので、最早船室に歸つて睡眠せんと、歩む足は今や昇降口を一｜段降つた時、私は不意に一｜種異樣の響を聽いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の名前は警部の耳にも響いて居たと見え、何も云はないで俺の歩むが儘に任せてくれた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪｜颯と夜風に乱して白き衣服を着けたるが、月明りにて画けるごとく、南をさして歩むがごとし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇を歩むに馴れたれば、爪先探りに跫音を立てず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "閻王の使者に追立てられ、歩むに長き廻廊も死に行く身はいと近く、人形室に引入れられて亡き母の存生りし日を思い出し、下枝は涙さしぐみぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "静に蹈みて下り行くに足はやがて地に附きつ、暗さはいよいよ増りぬれど、土平らにて歩むに易し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽葉色に垢附きて、見るも忌わしき白木綿の婦人の布を、篠竹の頭に結べる旗に、（厄病神）と書きたるを、北風に煽らせ、意気揚々として真先に歩むは、三十五六の大年増、当歳の児を斜に負うて、衣紋背の半に抜け、帯は毒々しき乳の上に捩上りて膏切ったる煤色の肩露出せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と豆府屋おずおず、群集を分けて入らんとすれば、比々として排べる車に支えて、台を担うて歩むべからず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩むにつれて、足下の叢より池に跋ね込む蛙は、礫を打つがごとく水を鳴らせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　白糸は思案に余って、歩むべき力も失せつ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ありて遠くより渠を望む時は、鼻が杖を突きて歩むが如し。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉は宙を歩むように、傍の小高い岩角へするすると登った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Everyman sings his own song and follows lonely path――お前はお前の歌をうとうてお前の道を歩め、私は私の歌をうとうて私の道を歩むばかりだ。",
              "citation": {
                "source": "砕けた瓦",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんみが菊をさげて歩むの路を清淨にせよ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
