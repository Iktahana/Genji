[
  {
    "uuid": "da32a54a-eb23-5973-a45b-838c7832f410",
    "entry": "歩む",
    "reading": {
      "primary": "あゆむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
