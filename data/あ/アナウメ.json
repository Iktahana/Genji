[
  {
    "uuid": "24a2a2ff-e511-5b03-99ea-652d79e9611e",
    "entry": "穴埋め",
    "reading": {
      "primary": "あなうめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "filling (up) a hole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日穴埋めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は穴埋めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には穴埋めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは穴埋めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は穴埋めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では穴埋めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に穴埋めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では穴埋めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると穴埋めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では穴埋めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に穴埋めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により穴埋めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "穴埋めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に穴埋めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "前立てや吹き返しの金銀を取りのけて、小銭でその穴埋めをするというのがむずかしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人に覚られては大事であると、了哲らがその穴埋めに取りかかっている処へ、半七と亀吉が再び乗り込んで来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "校正の穴埋めの厭なこと、雑誌の編集の無意味なることがありありと頭に浮かんでくる。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、赤字穴埋め策として立てた政府の官吏減俸案に反対し全国的官吏の未曾有の示威が行われている最中である。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその手数料も、所長の指図で半額だけ出せばよいことになり、あとの半額は有耶無耶になって、いずれ他の請願人が穴埋めをさせられることになるのだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一八七六年にカイザーが臨席して、華々しくバイロイト祝典楽劇をやったのですが、何しろ全ドイツから一流のオペラシンガーを集めてやったので経済的には大変な欠損で、ワグナーはその借金の穴埋めに長いこと苦労したということです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故そんなことをやったかというと、始めはあの新説で世間を呀ッと云わせて虚名を博しよう位のところだったらしいが、いよいよというときには事務室の金庫から彼が消費こんだ大金の穴埋めに、『赤外線男』を利用したわけだった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、辛酸を嘗め合った同志を穴埋めにした裏切り行為！",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、「オイちょっと顔を貸せ、今松」　……なんたるこッたろう、ここへも三軒目にくるはずの師匠の助六が休んだ芸人の穴埋めにもうきて聴いていたのだった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は一文もないし、あの手風琴はとっくの昔に借金の穴埋めに売り払われていた。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、泰軒先生をうながして、一路穴埋めの現場へいそぐチョビ安。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列の殿をおさえて行く峰丹波ガッシリしたからだをそこで立ちどまらせて、穴埋めの役割の連中へ、そう最後の命令をくだした。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "残る穴埋め係の中から、宰領格の結城左京が進み出て、「御師範代、御心配無用」　と丹波へ笑いかけ、「これからすぐに埋めにかかれば、ナニ、さほどの仕事ではござりません。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには、穴埋め役の一同。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　異口同音にさけんで、穴埋め組は、一度に鋤、鍬などをふりかぶって身がまえた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の連中は、商人や百姓に扮したまま、穴埋めに出て来たのだから、納屋にころがっていた鍬や鋤をひっかついでいる……これでは、いまここへ現われた異様な人物に、対抗のしようがない。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "士気を鼓舞すべく……また、南無妙法蓮華経の法力を借りて、この穴埋めの御難を乗りきるべく――。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、丹下の殿様も、酷えことをしたもので、あの伊賀の暴れん坊といっしょに、渋江の寮の焼け跡で穴埋めにされてしまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "席がきまると、「エヘン……」　出もしない咳ばらいをして上座にたちあがったのは、結城左京――あの、穴埋めの宰領をつとめた男。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの穴埋め水責めの危機の際に、悪い水を飲んだらしいのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと橋下の乞食小屋で、かりにも、父てエ名のつくお侍を一人拾い上げて、まあ、父のつもりで孝行をつくす気でいたところが、そのお父上は穴埋めにされて、おまけに水浸しときたもんだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が千久馬君に代つて二千円の穴埋めをすることにしませう」「あら、そんなこと……」　と、千種は意外なものにぶつかつた時の、あの驚きを顔いつぱいの表情にみせて、うつかり声をはづませた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も田もかっさらって　濁流飢えせまるごとく　でかくなる　白銅貨の穴姉　妹　　つぎつぎに　　年貢の穴埋め――中川めかく子へ――金箔にまみれ　　豊かでない　　きみの生業工賃　へらされた金箔で　　仏像のおめかし註・中川めかく子は箔打職人。",
              "citation": {
                "source": "鶴彬全川柳",
                "author": "鶴彬",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の穴埋めに、あたしが三味線ひきに雇われちゃったよ。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はここにニヒリスティックな或いは又アナーキスティックな卓抜さがあるのであって、同じ思想の退潮期の穴埋め材料としての宗教復興などに較べて、卑俗さが遙かに少ない所以なのである。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェストーフの哲学が即ちそのまま文学である所に、シェストーフ的なものの穴埋め材料としての特色があったのだ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "娯楽はこうした社会生活に於ける健康と幸福との現実的な第一段階であって、ただの社会の隙間の穴埋めにあるのではない。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはよくお考えにならなけりゃなりませんが、この手続きではしょっちゅういろいろな事柄が口の端に上りますが、そんなことはもう常識で間に合うものではなく、誰もがただ疲れ果て、いろんなことに気をそらされていて、その穴埋めに迷信に没頭することになるんですよ。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふしだらな生活で莫大な借金に責められ、伯父から金を引出して穴埋めをしようと、「火山岩を金にする発明」などという嘘をついたが、――平野氏がおいそれと金を出さぬと知って、遺産をめあてに平野氏殺害を思い立ったのである。",
              "citation": {
                "source": "天狗岩の殺人魔",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
