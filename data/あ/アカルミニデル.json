        "examples": {
          "standard": [
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかして当時の学界へのパッスを所有していた他のルクレチウスの子孫ヘルムホルツによって始めて明るみに出るようになった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新聞紙上で明るみに出る事実なんて、大抵が実にそっけなく実に卑しい。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るみに出るにはなかなかだと解った。",
              "citation": {
                "source": "文字のある紙片",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "程なく帰って来た蟹口は、この体を見て大いに狼狽し、警察に訴えようとしたが、ツル子は私の恥が明るみに出るから厭だと主張して、とうとう訴えさせなかった。",
              "citation": {
                "source": "衝突心理",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく私どもの幼い頃には、眩影景（暗い中を歩かせられて、不意に明るみに出ると、前述したような理論で、何でもないものが恐ろしいものに見える、一種の心理見世物）などいう心理見世物が、きまって、お化博覧会などの催し物には含まれていたものです。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩崩れがして凄じくのり出した崕の下をソッと通り抜けて明るみに出る、這いつくばった蟾蜍のような岩が二つ三つ重り合って、狭い谷の口を遮っている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで、だいじな話がこわれてしまったわ」「神月が恐れているのは、あなたのことが新聞に書きたてられて、じぶんらの暗い仕事が明るみに出ることなんだ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苅田壮平もこんな気持だったろうか」と彼は呟いた、「御用金を不正に動かしたことがいつ明るみに出るか、今日か、明日かと、絶えずびくびくしていたことだろう」　大丈夫、これは無事に始末をつけると思いながら、同時に、自分の犯した罪に怯え続けていたに相違ない。",
              "citation": {
                "source": "醜聞",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恥はもっぱら嫉妬のために増大して、いよいよ明るみに出るばかりである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし我々の世界の終末説が正しく、あの詩人〔ルクレティウス〕がその世紀を若いと結論することが正しいとすれば、この新世界は我々の世界が全く闇に没したときに始めて明るみに出ることにならなければなるまい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日で明るみに出る。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
