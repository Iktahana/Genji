          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "阿漕の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしいつの代にも横着者は絶えないもので、その禁断を承知しながら時々に阿漕の平次をきめる奴がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家数四五軒も転がして、はい、さようならは阿漕だろう。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが朝は仏縁深重の地とあって、伊勢ノ国阿漕ヶ浦に流れ寄り、夜な夜な発する霊光。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら父でも師でも、わたしに対し面と向っては阿漕なことはもう口に出せない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡曲｜阿漕の一節に、「丑満過ぐる夜の夢。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの頃から夫に忍び、その名岩島友吉こそは、年も二十六、やさがた生れ、きりょう好いのについ誘かされて、人目忍びて逢う瀬の数も、……　――阿漕が浦の度かさなれば、おさだまりで、たちまち近所となりのうわさ、これも定まる処です。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が口を利くのだ、奴もさう阿漕なことは言ひもすまい。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は植物の方に潜心して返事せぬ事多きに屈せず、阿漕が浦の度重なりてそんな眼に逢う。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、悪運が尽きたとでもいうのですか、それとも、阿漕が浦で引く網も度重なれば何とやらの譬か、警察ではやっとのことで、彼等の二つの住居の中の一つを嗅ぎ出したのです。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿漕でも小松でもかまいません。",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にアッと云わせてやらあ」「まあそう云わずと聞かせてくんな、一人占めは阿漕でやす」「へ、またお決まりの芝居もどきか。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は叔母の仕打に、是と云ふ目立つた阿漕な所も見えないので、心の中では少なからず困つたが、小六の將來に就いて一口の掛合もせずに歸るのは如何にも馬鹿々々しい氣がした。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来己を捨てるということは、道徳から云えばやむをえず不徳も犯そうし、知識から云えば己の程度を下げて無知な事も云おうし、人情から云えば己の義理を低くして阿漕な仕打もしようし、趣味から云えば己の芸術眼を下げて下劣な好尚に投じようし、十中八九の場合悪い方に傾きやすいから困るのである。",
              "citation": {
                "source": "道楽と職業",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お吉、それじゃアもう逢わねえぜ」「阿漕だ！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の海｜阿漕ヶ浦に引く網もたび重なればあらわれにけりで、何時しか伯父様が気附いた。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お八重さんばっかりに眼をとられて、あっしを見ねえとは阿漕ですねえ」　胡座から立て膝に直ったかと思うと、こう勘兵衛が冷嘲すように云った。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「天狗様にしろお狐様にしろ、船大工ばかりに祟るなんて、どうでも阿漕というものだ」「見ていや、今に、江戸中から、船大工の影がなくなるから」「亭主、いくらだ？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても阿漕だなあ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「二つを取ろうとなされても、それは阿漕でございますよ」冷っこい冷っこい声である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぼなんでも、そりゃ阿漕だよ！",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「阿漕たあ、一体どっちのこった！",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに阿漕、松川磯の小木津。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア、頼まれるからいてやる……そうまで阿漕ぎな気もちでもないでしょうが、どうせ行くところがないのだから、幼いチョビ安を夜露にさらすのもかわいそう、当分ここにとぐろをまいていよう――ぐらいの浅いこころ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "口じゃ親類付合だとか何とかいってるくせに、金にかけちゃあかの他人より阿漕なんだから」「来た時にそういって遣れば好いのに」　比田と兄との談話はなかなか元へ戻って来なかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は叔母の仕打に、これと云う目立った阿漕なところも見えないので、心の中では少なからず困ったが、小六の将来について一口の掛合もせずに帰るのはいかにも馬鹿馬鹿しい気がした。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜村屋のやり方は端倪すべからずですからなア」　路考の方へ、ジロリと睨みをくれて、「路考さん、あっしはいつか一度言おうと思っていたんだが、いくら立女形の名代のでも、あんたのやり方は少し阿漕すぎると思うんだ。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖がっちゃァいないが、そうしなかったら、チョコのこったもの、どんなまた阿漕なことをいって来るか知れない。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい材料を惜しげもなく使うのと阿漕に高い勘定をとるのとでわずかなうちに仕出し、間もなく今度は、いまの「区役所横町」の徳の家という待合のあとを買って入った。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "種のいゝものを使ふのと、阿漕に高い銭をとるのとで、わづかなうちに仕出し、間もなく、今度は、伝法院横町の、待合のあとに入つて店を出した。",
              "citation": {
                "source": "浅草の喰べもの",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二では謠の「善知鳥」など、三では「阿漕」、「鵜飼」など其適例である。",
              "citation": {
                "source": "妖怪研究",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
