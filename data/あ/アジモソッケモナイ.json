          "literary": [
            {
              "text": "それ一つ取ってみれば、テキストは味も素っ気もない基本ファイルだ。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ即ち、今晩の呼び物であったかと推察し、箸につまんで口中へ放り込み、つぶさに奥歯と舌端で耽味したのであったが、これはまたほんとうに何の味も素っ気もないものであった。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美しさに較ぶれば、ただ白いばかりで肌膚の粗い生毛の生えた西洋の女の皮膚なぞというものは、味も素っ気もない瀬戸物の破片みたいな気持がした。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹立てゝやってゐるので味も素っ気もない芝居になってしまふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
