    "definitions": [
      {
        "index": 1,
        "gloss": "American film",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ映画について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ映画の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ映画が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ映画について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ映画の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ映画が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ映画という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ映画についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ映画は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ映画が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ映画は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ映画の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ映画は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ映画は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ロシア映画で教養も何もない農夫が最も光ったスターとして現われ、アメリカ映画でも土人のほうが白人の映画俳優の下っぱなどより比較にならぬほどいい芝居をして見せるのも同様な現象である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おかしいことには、これと同日同所で見せられたアメリカ映画「流行の王様」に、やはり同様に破産した事務所の家具が運び出される滑稽な光景がある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　ある夜の出来事　ゲーブルとコルベールの「ある夜の出来事」は、いかにもアメリカ映画らしい一種特別なおもしろみをもっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうアメリカ映画が日本の婦人の思想に及ぼす蓄積的な影響は存外ばかにならないであろうという気がした。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画でも、言葉のよくわからぬわれわれにはどうもあまりしゃべり過ぎてうるさく感ぜられることが多いが、これはやむを得ないかもしれない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでたとえばアメリカ映画における前述のレヴューの線条的あるいは花模様的な取り扱い方なども、そうした懸賞問題への一つの答案として見ることもできる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたアメリカ映画では何かしら新しい趣向をして観客のどぎもを抜こうという意図が見られる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも事件の展開が簡単でなくて、一つの山から次の山へと移って行く道筋が容易には観客の予測を許さない、というだけのはたらきのあるのは、近ごろのこうしたアメリカ映画に普通である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このフランス映画がなんとなく陰気でどこかじじむさい感じがするのに引きかえて一方のアメリカ映画「模倣の人生」はいかにも明るく新鮮である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアメリカ映画の話の筋は決してそう明るいものではなくむしろその奥底にはかなりに悲惨な現実の問題を提供しているはずのものであるのに、映画として観客に与える感覚は主として明るくさわやかに新鮮な視像の系列としてのそれである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもこういうのが近ごろのアメリカ映画の一つの定型であるらしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　男の世界　生粋のアメリカ映画である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそうおもしろい事実はそもそも俳諧の本場であるわが日本の映画が、もっとも俳諧の欠乏したアメリカ映画にそっくりな手法ばかりを墨守していることである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画はヤンキー教の経典でありチューインガムやアイスクリームソーダの余味がある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ世界中に流行したアメリカ映画、あれには、こんな所謂「純真」な雄や雌がたくさん出て来て、皮膚感触をもてあまして擽つたげにちよこまか、バネ仕掛けの如く動きまはつてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばロシア映画のあるものは前者の類型であり、アメリカ映画のあるものは後者の仲間であると言ってもそうはなはだしい牽強付会ではあるまいと思われる。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋物はアメリカ映画で、「西部開発史」を取扱ったものだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思えばアメリカ映画が最もその国際性を発揮したのはやはり無声映画の末期であり、ちよびひげをつけ、山高帽をかぶり、だぶだぶのズボンをはいた道化男が悲しい微笑を浮べて世界中を駆けまわつたときにとどめを刺すのである。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画の黄金時代を象徴するものはこの悲しい道化であるが、同時にそれは芸術以前の映画の姿をも象徴しているのである。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大地」は、バックの原作がこれまでヨーロッパ人によってかかれた「支那物語」と性質を異にした本ものである故もあり、おそらくアメリカ映画界としては初めてつくられた真面目な中国についての映画ではあるまいかと感じた。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ残念なことにこの「大地」もアメリカ映画特有の癖で、ハッピイ・エンドになっている。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大地」　ポール・ムニとルイズ・レイナアとが主演している映画の「大地」は中国を背景として製作されたアメリカ映画中の傑作であった。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画はどんどん入ってきます。",
              "citation": {
                "source": "自覚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画の貧弱な真似をすることを止めない限り日本映画の芸術的な独自性は育てられないという事実をこれらの社も自覚しはじめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画　輸入公開されている外国映画のトップはアメリカ映画である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に「スバル座」を始めとして幾つかのアメリカ映画館がつくられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ映画のシスター・ケリーをみても、アメリカではじめての婦人開業医ブラックウェルの話をよんでも、科学における婦人の能力のために闘わなければならなかった様子がはっきり分ります。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇蹟といえばアメリカ映画の活劇や猛闘を見ると奇蹟だらけである、もうあれだけの谷底へ自動車もろとも墜ちたのだから多分助かるまいと思っていると、案外平気な顔で何度でも起き上がって来る主役がある。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代人が最も要求している恋愛関係で、殊にアメリカ映画なぞには幾らでも現れる。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、例えばアメリカ映画に現れるような女の生活は、その儘決してアメリカの女の実際上の生活ではない。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
