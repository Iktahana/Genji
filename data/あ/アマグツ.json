        "examples": {
          "standard": [
            {
              "text": "私は毎日雨靴について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨靴という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨靴の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨靴が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨靴を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨靴について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨靴の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨靴の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨靴が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨靴という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨靴という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨靴についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨靴を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨靴は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨靴について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨靴が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨靴は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨靴の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨靴は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨靴は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "学生のくせに毛糸のジャケツを買ったり、ゴムの雨靴を買ったりさ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨靴」石井ふじ子、「乳房」小林ひさえ、「蕗のとう」「あらし」山代巴、「遺族」「別離の賦」「娘の恋」竹本員子、「流れ」宮原栄、「死なない蛸」「朝鮮ヤキ」譲原昌子。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ゴートも、雨靴もないゆき子は、水色のブラウスに紺のスカートをはいて、毛深い脚をむき出したまゝ、部屋へ黙つて這入つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうとおりにしないと木底の雨靴で撲りつけて意に従わせようとしたが、太子は毅然として最後まで屈しなかった。",
              "citation": {
                "source": "カストリ侯実録",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジェレミーさんは　あまがっぱを　はおって　ぴかぴかの　あまぐつを　はきました。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき　でっかい　げんごろうが　スイレンの　はのしたに　あらわれて　あまぐつの　つまさきを　ぐっと　つまみました。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ　ますは　あまがっぱの　あまりの　まずさに　３０びょうと　たたず　はきだして、　のみこまれたのは　ジェレミーさんの　あまぐつだけでした。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも　おさとうや　かぎタバコ　あまぐつなども　あつかっていて。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
