        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "青物もやはり奧へゆけばゆくほど堆高く積まれてゐる。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物もやはり奥へゆけばゆくほど堆高く積まれている。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の話によるとそれは青物を売りに来る女があって、その女といろいろ話をしているうちにその肺病の特効薬の話をその女がはじめたというのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背戸に近い百姓屋などは、漬物桶を置いたり、青物を活けて重宝がる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の奧に住める人の使へる婢、やつちや場に青物買ひに出づるに、いつも高足駄穿きて、なほ爪先を汚すぬかるみの、特に水溜には、蛭も泳ぐらんと氣味惡きに、唯一重森を出づれば、吹通しの風砂を捲きて、雪駄ちやら／＼と人の通る、此方は裾端折の然も穿物の泥、二の字ならぬ奧山住の足痕を、白晝に印するが極惡しなど歎つ。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば青物を市へ積出した荷車が絶えては続き、街道を在所の方へ曳いて帰る。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に空の色が薄れて、岸和田の青物市場についた時は、もう朝であった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その主人の親戚で亀やんという老人が、青物の行商に毎日北田辺から出てくるが、もうだいぶ身体が弱っているので、車の先引きをしてくれる若い者を探してくれと頼まれていたらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀やんは毎朝北田辺から手ぶらで出てきて河堀口の米屋に預けてある空の荷車を受けとると、それを引っぱって近くの青物市場へ行き、仕入れた青物つまり野菜類をその車に載せて、石ヶ辻や生国魂方面へかけて行商します。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新銀町は大工、屋根職、左官、畳職など職人が多く、掘割の荷揚場のほかにすぐ鼻の先に青物市場があり、同じ下町でも日本橋や浅草と一風違い、いかにも神田らしい土地であった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の説明によると、その西瓜は青物市場から仕入れて来たのではない。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁三郎の友人に水野某という青物問屋の主人があった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又二人の友人で又木某という他県人の青物仲買人があった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに今少と、肴ば提げて来るけに……」　青柳喜平というのは当時から福岡の青物問屋でも一番の老舗で双水執流という昔風の柔道の家元で、武徳会の範士という、仁三郎には不似合いな八釜しい肩書附の親友であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭に集まる者は湊屋の生前の親友であった魚市場と青物市場の連中ばかりで、一人残らず無学文盲の親方連中であったが、それでも真情だけは並外れている博多ッ子の生粋が顔を揃えていた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしろ博多ッ子の中の博多ッ子、湊屋仁三郎の葬式じゃけに、一ツ思い切って立派にしてやれというので、生魚、青物両市場の大問屋全部が懸命の力瘤を入れた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾助爺はこの洪水のような雑踏の中を押し切って、毎朝｜神田の青物市場へ野菜物を満載した荷車を曳いていくのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青物市場の出場時刻が切れるので、爺はうっかりしていることができなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、もし時刻に遅れて青物市場に入場することができないとすれば、ただそれだけで彼のわずかばかりの資本はすべて消滅してしまうような結果になるのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、もしその野菜物を神田の青物市場へ曳いていくことができないとすれば、吾平爺の資本は全部消滅してしまうのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾平爺は一台の古い荷車を買い、近所の農家から野菜を買い集めて、毎朝それを神田の青物市場へ曳いていくことにした。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、青物市場には入場の時間が規定されてあった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、吾平爺はその赤茶けた野菜物を曳いて青物市場へ出かけていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この夏以来の不景気のために、青物市場には新鮮な野菜物が氾濫していた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝聞きつけている青物市場に往く青物を積んだ自動車なら五時｜比であった。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
