          "literary": [
            {
              "text": "行灯も蕪村の画も、畳も、違棚も有って無いような、無くって有るように見えた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大さは普通三｜尺もあろうか……しかし伸縮は自由自在であるから、言わば大さが有って無いようなものじゃ……。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何のために今まであってないような妄執に苦しみ抜いてそれを生命そのもののように大事に考え抜いていた事か。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家があってないような……いるところに苦労しているんですって。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪状があってないようなもの、それに身分が武士であり、人格も勝れているところから、手錠なども外されて、普通の士人としてあつかわれていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってる者があって、五十日も厄介になっていたが、つい近くに、えー、何ちゅう名だったか――なかに髪結の店まである温泉があってない――省三、お前覚えないごんだか？",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、わたしも、旦那がああして商売に精出して下さるから有難いことは有難いが、どうも商売にばかり凝って、家のことを心配して下さいません、わたしというものも、子供というものも、あってないようなものなのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的があってないような道行には、それも苦にならないで、二人は、これからまた落ち行く目標の相談をはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
