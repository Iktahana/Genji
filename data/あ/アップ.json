        "examples": {
          "standard": [
            {
              "text": "毎日、アップについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社のアップ戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "アップの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "アップという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアップについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "アップの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "アップに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちはアップを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界でのアップは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、アップは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "アップは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々なアップを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「アップ」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
