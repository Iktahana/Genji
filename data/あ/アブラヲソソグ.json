[
  {
    "uuid": "a15f2afd-e133-5e84-8ca4-243f1d66243b",
    "entry": "油を注ぐ",
    "reading": {
      "primary": "あぶらをそそぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ガ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to pour oil on (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "油を注ぐについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この油を注ぐは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が油を注ぐについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は油を注ぐの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では油を注ぐが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から油を注ぐを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも油を注ぐが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では油を注ぐが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも油を注ぐは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも油を注ぐは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で油を注ぐは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に油を注ぐについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "油を注ぐの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する油を注ぐの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では油を注ぐの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紺屋の白袴どころでなく、これでは柳吉の遊びに油を注ぐために商売をしているようなものだと、蝶子はだんだんに関東煮屋をはじめたことを後悔しだした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴どころでなく、これでは柳吉の遊びに油を注ぐために商売をしているようなものだと、蝶子はだんだん後悔した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分ランプへ石油を注ぐ時使う金の道具があった。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油を注ぐものも、注がるゝものも、はじめから豫定されて居るのだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がそれ等の書物から知り得た多くのことは、私の最初の感じに、さらに油を注ぐようなものであった。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「し、失礼な事をなさると、声を揚げますよ」　然しそんな努力は反って薪に油を注ぐようなものだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああそれなのに、あの火星獣の毛のことをうちの新聞に素っぱぬくなんて、彼奴の憤慨の火に油を注ぐようなものですよ。",
              "citation": {
                "source": "見えざる敵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目の老人が平鉢を前にすすめて、生作りの鯉の眼に醤油を注ぐ。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに福子の父親迄が、さうすれば娘の身が固まるし、甥の一家を救つてもやれるし、双方のためだと考へたのが、おりんの工作に油を注ぐ結果となつた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに福子の父親迄が、そうすれば娘の身が固まるし、甥の一家を救ってもやれるし、双方のためだと考えたのが、おりんの工作に油を注ぐ結果となった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば林の一言が火に油を注ぐような結果になったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "女記者矢留瀬苗子は、その嫉視へ油を注ぐようなことを平気でやらかしたのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油を注ぐことの代りに、愛情を注ぐだけの相違であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にここのお代官殿を中に、今の屋敷の近頃の空気そのものが、またお蘭さんの行動に油を注ぐように出来ている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　がんりきは辰巳あがりの体で、眼が据わって来るのを、お勢は、「ずいぶん、きむずかしやのような先生ですから、おあいにならない方がようござんしょう」　留めて、かえって油を注ぐようなことになってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "百五　金助改めびた助は、こういう場合に、主膳の意に逆らうような文句を以て応酬することの、かえって火に油を注ぐようなものであることだけはよく知っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樣子が、ヴェリチャーニノフの雄辯にいよいよ油を注ぐことになった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら彼のために不幸なことには、一旦癒えていた彼の忌わしい性癖に油を注ぐ一人の女性が茲に登場して来るのである。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが正造の心火に油を注ぐ結果になったのである。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは火に油を注ぐようなもので、また彼の目をいっそう盲目ならしむるものだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは、賤ヶ嶽の攻略を、独り明朝に期していた玄蕃允には、さらに、火へ油を注ぐものとなった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
