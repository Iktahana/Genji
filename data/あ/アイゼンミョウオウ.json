        "examples": {
          "standard": [
            {
              "text": "毎日、愛染明王は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛染明王が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛染明王に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛染明王が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛染明王について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛染明王についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛染明王について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛染明王が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛染明王が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛染明王は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛染明王は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛染明王を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛染明王をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛染明王が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛染明王の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛染明王を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛染明王に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛染明王について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛染明王は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛染明王を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その効果を仏教では「愛染行」（愛染明王の行　愛欲に入ってしかも愛欲を度す）と言います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈尊は、釈尊は、大悲の弓の智慧の矢をつまよつて、三毒の眠を驚かし、愛染明王は弓矢を持つて、陰陽の姿を現せり、されば五大明王の文殊は、養由と現じて、れいを取つて弓を作り、安全を現して矢となせり。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の眼で見ると愛染明王の相だ」「ふふん」と今度は主膳が冷笑しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、敏外住職は存外まじめで、「その竪の一眼は、愛染明王の淫眼といって、ことに意味深い表徴になっている」「ナニ、いんがん」「左様」「どういう字を書くのだ」「淫は富貴に淫するの淫の字――これは愛染明王が大貪著時代の拭うても拭いきれない遺品だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡を見送ると、ちょうど今のお社のあるところまで来て、愛染明王の姿を現じて行方知れずになったといってあります。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛染明王はもとは愛欲の神であったそうですが、愛という名からわが国では、特に小児の無事息災を祈っていました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
