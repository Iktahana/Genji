    "definitions": [
      {
        "index": 1,
        "gloss": "Ragaraja (esoteric school deity of love)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
