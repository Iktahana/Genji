        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹は陶器のような青白い歯を出して、にやっと笑った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」祖母は剃られて青白い、眉毛の跡を吊り上げて、その老眼鏡の上から覗くやうに言つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間その大きな気味の悪い星が不吉を予言するかのやうにスーツと音もなく青白い長い尾を引きながら暗の中に消えてしまつたのは誰も知らなかつたことである。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして謝源にはその青白い色をして居る畑が自分を冷笑して居るやうにも見えた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は身にまとつてゐる薄布をなびかせ裸足で歩いてゐるが、よく見ると、その青白い小さい足は、下の小粒の珠を踏んではゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のやうに、アルテミスは月の女神で、額には青白い三日月が輝き、さうして敏捷できかぬ氣で、一口で言へばアポロンをそのまま女にしたやうな神である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心はスパークのやうに、一瞬間青白い光を放ち、熱を持つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪はまだ下さないで、金襴、染絹の衣、腺病質のたちと見え、透き通るばかり青白い肌に、切り込み過ぎたかのようなはっきりした眼鼻立ち、男性的な鋭い美しさを持つ青年でした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの辺を散歩すると云って寮を出るし、男はまた鯉釣りに化けて、この土手下の合歓の並木の陰に船を繋って、そこでいまいうランデブウをしたものさね」　夕方になって合歓の花がつぼみかかり、船大工の槌の音がいつの間にか消えると、青白い河｜靄がうっすり漂う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、水色の汽車の窓の所で、瘠せた旅人が、青白い苹果にパクと噛みついた。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原の礫は、みんなすきとほって、たしかに水晶や黄玉や、またくしゃくしゃの皺曲をあらはしたのや、また稜から霧のやうな青白い光を出す鋼玉やらでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若いお父さんは、その青白い時計をチョッキのポケットにはさんで靴をかたっと鳴らしました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が車室のちゃうど天井にかかってゐるらしく、窓の氷はただぼんやり青白いばかり、電燈は一そう暗くなりました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の爪草の花、青白いともしびを點じ微かな悦びをくゆらしそれから月光を吸ふつめくさの原。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス海岸には、青白い凝灰質の泥岩が、川に沿ってずいぶん広く露出し、その南のはじに立ちますと、北のはずれに居る人は、小指の先よりもっと小さく見えました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬川の鉄橋を渡り牛蒡や甘藍が青白い葉の裏をひるがえす畑の間の細い道を通りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君の詩風から聯想して、高貴な青白い容貌をした、世慣れない温和の青年を考へてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今、僕の前に對座してゐる、この如何にも田舍文士然たる粗野の人物が、果してあの青白い貝のやうな詩を作つた、高貴な優しい室生犀星であるだらうか？",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴族的の風貌と、青白い魚のやうな皮膚を心貌に畫いて居た。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾患する犬の心に、月は青白い幽霊のやうな不吉の謎である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、なぜおれはこれなんだ、犬よ、青白いふしあはせの犬よ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、もちろん、わたくしの腰から下ならば、そのへんがはつきりしないといふのならば、いくらか馬鹿げた疑問であるが、もちろん、つまり、この青白い窓の壁にそうて、家の内部に立つてゐるわけです。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには青白い顔をした病身のかれの子供が立つて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柱の一本に掴って青白い生ものが水を掻いている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡を借りて自分の顏を見る時、青白い皮膚の色や、凹んだ眼や、殺げた頬や、變に尖がつた鼻や、毛の日に日に拔け落ちて行く頭などが、とても自分だとは思へないやうに情無く見えた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何の病人だらう……」と、その刹那にふと眼に殘つた女のほつそりと痩せた、青白い、如何にも物寂しい感じの輪廓を持つた顏を思ひ浮べながら、私は考へた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手術の結果はどうなつたらう……」と、三四日窓に見られなくなつた青白い顏の女を思い出して、或る時私は呟いた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は午後の蒸暑さを語るやうにどんより曇つてゐたが、朝の食事を濟して窓際へ凭つてみると、私の向うの、青白い顏の女の病室の窓から暗い顏で庭を見降ろしてゐるその夫の姿を珍らしく見附けた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は寢臺に横はつてゐるあの女の青白い顏、それをぢつと見詰めてゐるに違ひないその夫の憂ひげな顏を思ひ浮べてみた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
