[
  {
    "uuid": "f65f75c6-f006-5f78-a4b6-a09ab2375cd3",
    "entry": "甘ったれる",
    "reading": {
      "primary": "あまったれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to behave like a spoiled child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘ったれるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘ったれるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘ったれるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘ったれるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘ったれるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘ったれるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘ったれるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘ったれるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘ったれるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘ったれるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘ったれるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘ったれるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘ったれるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妹も、そのころは、痩せ衰えて、ちから無く、自分でも、うすうす、もうそんなに永くないことを知って来ている様子で、以前のように、あまり何かと私に無理難題いいつけて甘ったれるようなことが、なくなってしまって、私には、それがまた一そうつらいのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ったれるのもこのへんでよし給え。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、そんなに甘ったれるんだろう、　大きななりをしてながら、　私より貴方は随分かさばって居るもの。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥さえも居ない木から木へと見すかしては友達をさがす様な様子をして、甘ったれる様に鼻をならしたり小雨のしずくをはらう様に身ぶるいをしたりする。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬ私たちに、喉を鳴らしながら甘ったれる。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ったれる様な意味のある様な様子をして居るのが源さんに気に入らなかった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めて、眼をつぶって、甘ったれるより外はない。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五歳のこのおれが、彼女に対しては、ただ甘ったれるだけの能しかないのだ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を以て、心を以て、情愛を以て、甘ったれるということがどんなことだか、彼女に思い知らしてやらなければならない。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今やこの家の主人公が、さも甘ったれるように娘を自分の方へ凭れ掛けさせながら、その娘やその母親と一緒に自分の炉辺に腰を卸した時、スクルージは前よりも一層注意して見守っていた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の腕の中で、私は極めて快活に甘ったれることも覚える。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "サト子は、あわれな微笑をうかべながら、「おっしゃること、よく、わからないんですけど……だれかと、間違えているんじゃないかしら」　ダスター・コートが、甘ったれるような含み声で、からみついてきた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして甘ったれるような口調や、呼び立てるような口調や、また命令するような口調のもあります。",
              "citation": {
                "source": "オカアサン",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロオラが同じ「オカアサン」を言う時にも、甘ったれるようなのや、少し不きげんなのや、またあごでこき使う調子を帯びたのや、さまざまな発音があると彼女はいうのです。",
              "citation": {
                "source": "オカアサン",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをおじさまが色々考えて息を吹きこんで下すっているの、だから、水さえあれば何処にでもお供が出来るんです、そしてあたい、甘ったれるだけ甘ったれていて、何時も、おじさまをとろとろにしているの、おじさまもそれが堪らなくお好きらしいんです。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬の首に抱きついて、自分の面をそこへ持って行って、充分に甘ったれるようにシナをしながら、トロリとした酔眼をみはって、そうして兵馬の面を見定めようとする努力を試みている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼女は突然、甘ったれるような、そのくせ変に冷やかすような、猫撫で声でそう云いました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸首をかしげてあまったれる様な様子をして笑って見た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャラメルがありましょうか」　Ｈさんはあまったれる様に云って桃色のと茶色のとをとってもらって、「今夜は私も奥さんの子供にして下さるでしょうネエ」と云った。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
