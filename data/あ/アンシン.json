    "definitions": [
      {
        "index": 1,
        "gloss": "peace of mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安心について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安心という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安心の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安心が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安心を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安心について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安心の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安心の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安心が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安心という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安心という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安心についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安心を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安心は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安心について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安心が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安心は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安心の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安心は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安心は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "之に反して、月末の支払ひだけ片付くとなれば安心の出来る人達は元気でゐる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感覚を通して這入つて来るものの中に安心立命してゐるのである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……」と突然三田村はその重さうな頭をハネ上げて続きを始めるのだつた、「俺がついててやるから安心しいろい」「うん、うん」と私は相変らず吊り込まれて承知するのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それであたしも安心したわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人が出て来ると、なんだか安心ですの。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そう信じて安心しておりたいのでございますけれども、どうも、年とって来ると、物慾が起り、信仰も薄らいでまいって、いけないと存じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に安心させるまちである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬川先生もこれで全く御安心なさるだろう、と私は思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、芸術といふものが、生れるものであつて、拵へようといふがものではないといふことは、如何にも芸術の説明にはなつてゐないやうであるけれど芸術家である人には、かう聞けば安心のつくことである点に留意されたい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども兎に角、教師達が彼に威勢の好い声を掛始めたといふことが彼を安心させた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正九年、露細亜詩人ベールィの作を雑誌で見かけて破格語法なぞといふことは、随分先から行はれてゐることなんだなと安心す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には自分を詩人だと思ふだけでは安心出来ないものがある。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急に大きな安心を得たやうに胸が踊つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの故郷の方には、小生の家の方から別に何とも言ふわけで無し、誰にも知れる氣づかひは無いのだから、安心して一度たづねてやつて下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、「二箇のズルフオンアミド基」を有する高級化學療法劑に就いては、かねて新聞廣告に依つても承知してゐたのでありますし、いま自ら購ひ求めて、藥品に添附されて在る一枚の效能書をつくづく眺め、熟讀して、腰の腫物を忘却してしまふほど安心したのであります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上林さんと御一緒で、あたし、とても安心だわ。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、乙姫はご自分の家へやつて來た珍客を階段まで出迎へて、さうして安心して、あとはあなたのお氣の向くままに勝手に幾日でもここで遊んでいらつしやるやうにと、素知らぬ振りしてああしてご自分のお部屋に引上げて行くといふわけのものぢやないんですかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を信頼しきつて、安心しきつてかの女の心は蜜柑の色にそのやさしさは氾濫するなく、かといつて鹿のやうに縮かむこともありませんでした私はすべての用件を忘れこの時ばかりはゆるやかに時間を熟読｜翫味しました。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす日で安心していた間もなく、雨がザッとふり注いで来た、谷の中で雨に降り出されるほど、滅入った気になることはない、ゆうべ槍ヶ岳の峰頭から見た、北の空の燃え抜けるように美しい夕日も、今になって見ると、神棚の火のように影がうすいものであった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、当分は枕を高くして寝られる」と地主たちが安心しかけた処であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「分らねえか、警察の旦那かって聞いてるんだよ」　彼は喫驚すると同時に安心した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の人間が四十歳くらいで得た人生観や信条をどこまでも十年一日のごとく固守して安心しているのが宜いか悪いか、それとも死ぬまでも惑い悶えて衰頽した躯を荒野に曝すのが偉大であるか愚であるか、それは別問題として、私は「四十にして不惑」という言葉の裏に四十は惑い易い年齢であるという隠れた意味を認めたい。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時にはもう三代吉の父親の辰五郎が白米、薩摩芋、大根、茄子、醤油、砂糖など車に積んで持って来たので少し安心する事が出来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば野獣も盗賊もない国で、安心して野天や明け放しの家で寝ると、風邪を引いて腹をこわすかもしれない。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の道を通る人もないので、私は安心してその柱によりかゝつた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに眼を覚まして、そこにお蘭のいるのを確めると、また安心して瞼をゆるめた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同席の人もあるので、どうかと思ったがお蘭老婦人のあまりに快濶な様子に安心して訊いてみた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松技師は帰りしなに、少し改って「実はお願いがあって参りましたのですが」　と言って、暫く黙っていたが、主人が気さくな顔をして応けているのを見て安心して言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――店の跡を譲った人も素性はよし（もちろん売り渡したのだが）安心して引込めますよ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫だ、安心しろ。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
