        "examples": {
          "standard": [
            {
              "text": "私は毎日アートマンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アートマンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアートマンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアートマンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アートマンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアートマンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アートマンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアートマンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアートマンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アートマンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアートマンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアートマンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アートマンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアートマンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アートマンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアートマンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアートマンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアートマンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アートマンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアートマンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "宇宙の本体はブラハマン Brahman でブラハマンは吾人の心即アートマン Atman である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラハマン即アートマンなることを知るのが、哲学および宗教の奥義であった。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度宗教の根本義であるようにアートマンとブラハマンとは同一である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙の本体はブラマン Brahman でブラマンは吾人の心即アートマン Atman である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このブラマン即アートマンなることを知るのが、哲学および宗教の奥義であった。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度宗教の根本義であるようにアートマンとブラマンとは同一である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　今じゃあアートマンと云う語さえ忘れかけているぜ。",
              "citation": {
                "source": "青年と死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はこの古い文化の伝統に対する革新者としてバラモンの権威に挑戦し、アートマンの形而上学を斥け、四姓制度の内面的な打破を試みたのである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の無我の主張はアートマン哲学への反駁なのである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　道元がかく仏性をアートマンとする解釈を排し、「仏性の言をきゝて学者おほく先尼外道の我のごとく邪計せり。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも仏教はアートマン思想の否定に始まり、大乗仏教の根柢もまたその立場において築かれた。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに外道の哲学におけるアートマン思想の優勢はついに仏教の内に（特にこの涅槃経において）我の思想の浸入を引き起こした。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
