          "literary": [
            {
              "text": "まるで蕈とあすなろとの合の子みたいな変な木が崖にもじゃもじゃ生えてゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで蕈とあすなろとの合の子みたいな変な木が崖にもじゃもじゃ生えていた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の南の背の高い、よく雀が来てとまるひば、一杯の引かぶった松、あすなろう。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよいとして、はじめは燈籠の下あたりにだけあったに相違ない低い笹が、根から根へひろがって、左手の円いあすなろうのところまで茂っている。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――空地のほぼ中央に、さしわたし二尺あまりのあすなろうの樹があり、その脇に、小舟をあげたのが伏せてあった。",
              "citation": {
                "source": "あすなろう",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
