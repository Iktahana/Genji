          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見はるかす段丘の雪、　　　　　なめらかに川はうねりて、天青石まぎらふ水は、　　　　　百千の流氷を載せたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ひて形容すれば、銅青石の溶けてなせるが如き冷き冬の夜の空氣の内に――その空氣は漁村の點々たる燈火をもにじませ、將た船の鐘の徒らに風に驚く響にさへ朗かなる金屬の音を含ませる程にも濃いのであるが――そのうちに、かの「やれこらさよな、やこらさのおさあ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い中に、向うに、もう一つぼうと白いのは涎掛で、その中から目の釣った、尖った真蒼な顔の見えるのは、青石の御前立、この狐が昼も凄い。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際なら奇蹟であるから、念のためと、こゝで、其の翌日旅店の主人に聞いたのが、……件の青石に薄紫の筋の入つた、恰も二人が敷いた座蒲団に肖て居ると言ふ其であつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつがどうしても金を返さず、書換もせずに逃げ廻っていたのに、或日｜青石横町の角で出くわした。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆重罪の者と見えて、手には手械がかかり、足には足械をし、首には青石の大きなのを首械として置いてあった。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三人は青石横町の伊予紋で夕飯を食う。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび郷平橋を渡りつつ、赤平川を郷平川ともいうは、赤平の文字もと吾平と書きたるを音もて読みしより、訛りて郷平となりたるなりという昔の人の考えを宜ない、国神野上も走りに走り越し、先には心づかざりし道の辺に青石の大なる板碑立てるを見出しなどしつ、矢那瀬寄居もまた走り過ぎ、暗くなりて小前田に泊りたり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷青石横町の露路裏のドンヅマリの、塵埃すて場の前にいたが、隣家の女髪結さんから夜中火事を出して、髪結さんは荷物を運び出してしまってから騒ぎだした。",
              "citation": {
                "source": "朝散太夫の末裔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ上野山下の青石横町にいる時分に、あたしは雨上りに三枚橋下へ小魚を掬いにいったり、山内へ椎の実を拾いにいって、夜になるとおばあさんの不思議な話をききながら煎ってもらって、椎の実の味を知った。",
              "citation": {
                "source": "チンコッきり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘つき堂の鐘が鳴った――　ふと、青石横町の、母方の祖母の家で、寝ざめや、寝ぎわにきいた、三ツは捨て鐘で、四つめから数えるのだときいたことから外祖母の家を思いだした。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "青石横町にいると、五月雨の雨上りの日など抄い網をもって、三枚橋の下へ小蝦や金魚をすくいに来たから、石段をおりれば道は知っていた。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野下の青石横町に住んでいたころも、根岸のお行の松のすぐきわに、音無川の前にいたころもそうだった。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子は後ろのドアの方を向いてから顔を矢代の肩へ靠らせたが、また身を起すと足を組み替え一層重くもたれ直したので、首飾の青石がかすかに鳴った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "海底から出たと思われる普通の青石だが、風雨に曝されて黒ずみ、小さな凹みには苔が生えていた。",
              "citation": {
                "source": "狸石",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お地蔵さまを青石でこしらえている途中のようなものに見えた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀閣寺義政時代の宝徳のが唯一つあるが、此は今一つはりがねで結わえた二つに破れた秩父青石の板碑と共に、他所から持って来たのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下手には、青石｜峨々たる岬角が、橋の袂から斜に川の方へ十五六間｜突出て居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門はひとしほ綺麗で木は質の緻密な光の柔和な材を用ゐ、敷石は青石の一枚。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "土台の青石に金色の四角な一分か二分かの長方形の結晶体が付いて居るのを辰や、初ちやん、市ちやんと一緒に取りに来た事があつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女はこういって、琥珀と群青石の指輪を一つずつはめた両手を餉台の上に並べて見せた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下手には、青石峨々たる岬角が、橋の袂から斜に川の方へ十五六間突出て居る。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を受けた一本の樹木の中には、眼の丸い青石盤色の鳩が鳴いていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく大きな平たい青石の上へ、背の老母を下ろして言った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもとの絶壁を、蔦に攀じ、岩にすがり、一歩一歩登りつめて、以前の青石のところへ戻って来てみると、はて、どうしたのか？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ独龍岡の城門の大手には、巨大な青石に、一篇の頌が刻んである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中ほどに大なる青石あり。",
              "citation": {
                "source": "遠野物語",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああおいしい」　如何にも好物を嬉しそうに抱え込んでいると、ガラリと格子が開いた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああおいしい、ああおいしい。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
