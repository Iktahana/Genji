        "examples": {
          "standard": [
            {
              "text": "私は毎日安山岩について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安山岩という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安山岩の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安山岩が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安山岩を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安山岩について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安山岩の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安山岩の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安山岩が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安山岩という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安山岩という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安山岩についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安山岩を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安山岩は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安山岩について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安山岩が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安山岩は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安山岩の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安山岩は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安山岩は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "安山岩かと思はれる火山岩塊の表面が赤※色に風化したのが多い。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安山岩かと思われる火山岩塊の表面が赤※色に風化したのが多い。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ石英安山岩、いやに響くなこいつめは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うは安山岩の集塊岩、こっちは流紋凝灰岩です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔これは安山岩です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この石は安山岩であります。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすぐろくて安山岩だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安山岩の柱状節理、安山岩の板状節理。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふは安山岩の集塊岩、こっちは流紋凝灰岩です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（石英安山岩か流紋岩から来た。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田県からも斯の如きものを産する由、複輝石安山岩だそうな）僅々二三町に過ぎぬのだから、大したものではない。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石楠花の咲いていたその背後の絶壁は、高さ九十尺幅百二十尺の屏風を立てたような角閃安山岩から成立つ。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲仙一帯を構成する火山岩はすべてこの安山岩で、長石、角閃石、黒雲母等それに雑る斑晶の多少の差を認めるに過ぎない。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "この熔岩流の中へ来て見ると熔岩の集団はいよいよ生々しいどころではなく、同じ安山岩であっても、角閃石に多くの黒雲母を雑えた、また構成の比較的｜脆弱なもので、殊に凝灰岩をもまじえているので、風化浸蝕作用は案外早く行われ、岩石という岩石は悉く蘚苔をつけていないものはないのである。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほども故郷の村へ帰って、崖の上から昔の河原を望んだが、流れを遮る鬼岩は、その頃と変わらぬ安山岩の荒い肌を、激流の面へ現わして、白い飛沫を空に撒いていた。",
              "citation": {
                "source": "父の俤",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "燧石や黒曜石や、安山岩の類で造つたものが多いのでありますが、時には水晶や瑪瑙のような綺麗な石で造つたものもあります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、われわれは、何の希望もなく、変朽安山岩をほじくり返すことに飽きあきしてしまったんです」「われわれ、と、おっしゃるのは？",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "安山岩の黒い山が、天に聳えるようにそそり立っている。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、地底に山などのあろうはずがないのだから、近づいて行って見ると、変朽安山岩が正規浸蝕谷の中へ落下して来たもので、リヒトホーヘンが、西班牙語をそのまま採用して、リア（Rias）と呼んでいる現象だということがわかった。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、さらに一キロばかりのところで、二叉にわかれ、一つは、脈状に青い粘土をはさんだ堅固な安山岩盤で行きどまりになってしまい、一方は、分岐点から二百六十メートルばかりのところで、変朽安山岩で塞がれている。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロピライトというのは、安山岩が風化して、輝石類が緑泥化したもので、掘ればほるほど天井から崩れてきて、どうしてもその先へ進むことができない。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の推定では、プロピライト道のほうは断念するのほかはなく、安山岩の岩盤をダイナマイトで破壊して、隧道の口を探すことだけが、最後の希望なのだが、その上の天井は、集塊岩が石泉の作用を受けて、軟化しているので、ダイナマイトなどを使用すると、どのような危険が起るか予想できない。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩基性輝石安山岩の岩側は、数千万年の風湿のために研磨されて艶々とした滑肌になり、黒曜石のようなどっしりとした深みのある光沢を持っていた。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに備えて、大安山岩壁の口に構築しておいたバリケードを破壊する時間だけが、追跡者の側のわずかなハンディになっている。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
