        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日雨雲について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨雲という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨雲の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨雲が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨雲を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨雲について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨雲の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨雲の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨雲が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨雲という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨雲という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨雲についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨雲を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨雲は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨雲について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨雲が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨雲は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨雲の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨雲は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨雲は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "沼津を過ぐれども雨雲ふさがりて富士も見えず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧れば峡間から東方の霞沢岳連峰の木山には、どす玄い雨雲が、甘藍の大葉を巻いたように冠ぶさって、その尖端が常念一帯の脈まで、包んで来ている、雪の峡流は碧い石や黄な石をひたして、水嵩も多くなって、樺青く雪白い間を走って行くのが、遙かに瞰下されて、先は森林の底に没している。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は藍鼠色に濁って、雨雲が真ッ黒な岩壁に、のしかかっている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峯は雨雲の底面で悉くその頂を切り取られて、山々はたゞ一面に藍灰色の帷帳を垂れたやうに見えてゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な河童橋は河風が寒く、穂高の山塊はすつかり雨雲に隠されて姿を見せない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峰は雨雲の底面でことごとくその頂を切り取られて、山々はただ一面に藍灰色の帷帳を垂れたように見えている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な河童橋は河風が寒く、穂高の山塊はすっかり雨雲に隠されて姿を見せない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁ずきの紙にもあるか君が身は瀧見に行かず雨づゝみするかえし雨雲のおほひかくさば二荒山行きて見るとも多岐見えめやも此夕長塚来りて、雨ふるとも明日は行かん、という。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この溪間が雨雲に閉されて見る物悉く光を失ふた時の光景を想像し給へ。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の雨が晴て空は薄雲の隙間から日影が洩ては居るものゝ梅雨季は爭はれず、天際は重い雨雲が被り重なつて居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水まさ雲は如何なる雲をさすにやと久しく思ひ疑ひ居けるに、全流の兵書に、雨雲の一種にて、はなればなれに魚の鱗のならべるやうに空に布くものなり、とありたるにて、さては水増雲の義なるべしなど思ひぬ。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぎれかかった雨雲の尾は鴻島の上に垂れかかって、磯から登る潮霧と一つになる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "林はまだ夏の緑のそのままでありながら空模様が夏とまったく変わってきて雨雲の南風につれて武蔵野の空低くしきりに雨を送るその晴間には日の光｜水気を帯びてかなたの林に落ちこなたの杜にかがやく。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方は雨雲に閉されて能くも見え分かず、最近に立つて居る柏の高さ三丈ばかりなるが、其太い葉を雨に打たれ風に揺られて、けうとき音を立てゝ居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は雨雲ひくく漂い、木の葉半ば落ち失せし林は狭霧をこめたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな硝子窓越しには遠くに雨雲のよどんだ夏の無月の空が、潤みを持つた紺碧の色に果てもなく擴がつてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨雲が時々、その奇怪な姿をまざ／＼と見せて、遠くの方で稻妻が光つてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月六日　一昨日からだんだん曇って来たそらはとうとうその朝は低い雨雲を下してまるで冬にでも降るようなまっすぐなしずかな雨がやっと穂を出した草や青い木の葉にそそぎました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛唐の乗ったボートは橋に引掛かり、対山の翠は雨雲に包まれて、更に一鳥の飛ぶを見ず。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……森のめぐりの雨雲は、陰惨な鼠色の隈を取った可恐い面のようで、家々の棟は、瓦の牙を噛み、歯を重ねた、その上に二処、三処、赤煉瓦の軒と、亜鉛屋根の引剥が、高い空に、赫と赤い歯茎を剥いた、人を啖う鬼の口に髣髴する。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、鉛のような雨雲を無限に送り出して来るいわゆる「上毛の三名山」なるものを呪わしく思うようになった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をつけるとその一人一人に特色があって、そしてまた、特にこれが華やかとも思えない男女が、むらな雨雲のように押し合って塊ったり、意味なく途切れたりしつつ、大体の上では、町並の側と車道の側との二流れに分れて、さらさらと擦れ違って行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、雨雲の陰が湖の上をみるみる暗く染めて行くように、蒼い大きな翳が自分の上にかぶさって来る。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新村博士の頼となれば何を措いても諾はなければなるまいと思ひ、五月の雨雲に暗い日曜日の朝の事であつた、紙を捜して図案を考へた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一間半の古格子附いたる窓は、雨雲色に燻ぶりたる紙障四枚を立てゝ、中の二枚に硝子｜嵌まり、日夕庭の青葉の影を宿して曇らず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あれ、どこともなく瀬の音して、雨雲の一際黒く、大なる蜘蛛の浸んだような、峰の天狗松の常燈明の一つ灯が、地獄の一つ星のごとく見ゆるにつけても、どうやら三体の通魔めく。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "港には浪の音も鈍にひびらぎ、灰だめる氷雨雲空にみだれてすそあかる黄いろの遠に、海鳥煙濃き檣の闇に一列朱の色の大き旗鳴きもめぐりぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の里｜外目の空は雨雲の間青く潤ひ母の眼かとも山方は野町原町北の関その関越えて官軍は来し註、野町、原町もともに村の名。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "北を眺めると、その海岸線は南と同じようなさして高からぬ丘陵が続いて、立枯れのとど松の疎林が、しきりなく流るる雨雲の下にほうほうとうち煙って見えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ある人のいへる、「あまぐものはるかなりつる桂川そでをひでゝもわたりぬるかな」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
