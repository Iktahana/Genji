        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安南について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安南という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安南の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安南が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安南を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安南について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安南の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安南の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安南が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安南という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安南という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安南についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安南を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安南は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安南について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安南が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安南は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安南の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安南は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安南は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妾は、皮膚の色｜褪せた波斯族、半黒黒焼の馬来人、衰微した安南の舞姫の裡にあって、日露戦争役の小さい誇を、桜の花の咲いた日本の衣服に輝かせていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳底に女の好物でものこるように、交響楽によって嗜色人の踊がはじまると、軍隊的な組織も粋な衣服にかくれて、部屋にいる人間の甘い唾液のなかを、安南の××がとおりぬけるのだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "場合によってはと考えて、初から娘の旅券には暹羅、安南、ボルネオ、スマトラ、爪哇への旅行許可証をも得させてあったのが、幸だった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年春三月、工部尚書厳震安南に使するの途にして、忽ち建文帝に雲南に遇う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高麗、唐土、暹羅国、カンボジャ、スマトラ、安南、天竺、世界ははて無く広がって居りまする。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高麗大明、安南天竺、南蛮諸国まで相手に致しての商人でござる。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永元年五月｜安南船長崎に到着候時、三斎公は御薙髪遊ばされ候てより三年目なりしが、御茶事に御用いなされ候珍らしき品買い求め候様｜仰含められ、相役横田清兵衛と両人にて、長崎へ出向き候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永元年五月｜安南船長崎に到着候節、当時松向寺殿は御薙髪遊ばされ候てより三年目なりしが、御｜茶事に御用いなされ候珍らしき品買求め候様｜仰含められ、相役と両人にて、長崎へ出向き候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで丁度二条行幸の前寛永元年五月安南国から香木が渡った事があるので、それを使って、隈本を杵築に改めた。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が、海洋を行くや、疾風の如く、遠く安南、シャム、ルソン、マラッカ、フィリッピンにまで押し渡り、貿易が許されない場合は、忽ち両肌を脱ぎ、長刀を振つて命知らずの奮闘をした。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川幕府の世になつても、ルソン、安南、シャムなどには、日本の植民地があつて、日本町と呼んでゐた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の交通が大規模となつて、ヨーロッパ人の東洋経営が猛烈化し、フランスの安南占領、イギリスの印度攻略、阿片戦争、ロシアの黒龍江地方の経営等が行はれてゐた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "エイモニエーの『安南記』にはオラングライー族の村に虎入りて人なり犬なり豕なり一頭でも捉わるると直ぐ村を他処へ移すと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南人また信ず、虎鬚有毒ゆえ虎殺せば鬚を焼き失う習いだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南人また信ず虎王白くて人を啖わず、神山に隠れ棲む処へ子分ども諸獣肉を献上す、また王でなく白くもない尋常の虎で人を啖わずいわば虎中の仙人比丘で神力あり人を食うほど餓うればむしろ土を食うのがある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎は安南語を解し林中にあって人が己れの噂するを聞くという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランドの『安南民俗迷信記』にコンチャニエンとて人に似て美しく年｜歴ると虎に化ける猴ありと。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランドの『安南風俗迷信記』にこの蛇土名コン・トラン、その脂を塗れば鬚生ずとあれば漢医がこれを大寒性とせるは理あり、『蛇の脂人骨に著くればすなわち軟らかなり〉。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の年は鼠、丑の年は牛と、十二支に十二禽を割り当る事、古く支那に起って、日本・朝鮮・安南等の隣国に及ぼし、インドやメキシコにも多少似寄った十二物を暦日に配当した事あれど、支那のように方位に配当したと聞かぬ（拙文「四神と十二獣について」）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如く戰國時代からして既に支那の疆域は全體に於いて外に向つて膨脹しつゝあつたのに、秦の天下を統一して、其の力を一にせるが爲に、益々其の膨脹力を増して、遂に東は朝鮮の半位から北は沙漠の南、西南は安南地方に至るまでも併合して絶大の國を形成した。",
              "citation": {
                "source": "日本上古の状態",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗に似たひしゃげた安南兵が劒銃を連らねて並んでいた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南部の南洋群島、フィリッピン、西部の印度、大陸に接する安南、緬甸、香港、澳門も亦すでに彼白人の勢力にして、猶、未だ白人の雄心死せざるなり。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南の土人がやっているフランス文の日刊新聞の中に、大きな見だしで、ある殺人事件を論じてあった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　たぶん香港からだったろう、一人の安南人らしい、白い口髯や細いあご髯を長く垂らして品のいいお爺さんが乗った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海防から乗った若い安南の学生に聞くと、もとの王族の一人で、今も陸軍大臣とか何とかの空職に坐っているのだそうだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一般の安南人となると、見るのもいやなくらいに、みな卑劣と屈辱とでかたまっているように見えた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれは、安南人が他の東洋諸民族にくらべて顔も風俗も一番われわれ日本人によく似ているようなのでなおさらいやだった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海防や西貢の町を歩いて見ても、安南人はみな乞食のような生活をして小さくなっている。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はマダムＮの質問に答えて、生徒には絶対に漢字を教えないで、一種のローマ字で書き現した安南語を教えているということを、非常な得意で話した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "安南人の子供等は、こうして教育されて行って、だんだんにフランス語を覚えて、その中の見こみのありそうなものはフランスへ留学させられる。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
