    "definitions": [
      {
        "index": 1,
        "gloss": "common and low grade type of katsuobushi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒節について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒節という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒節の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒節が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒節を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒節について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒節の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒節の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒節が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒節という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒節という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒節についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒節を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒節は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒節について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒節が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒節は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒節の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒節は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒節は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
