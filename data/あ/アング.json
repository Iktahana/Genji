          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗愚について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗愚という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗愚の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗愚が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗愚を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗愚について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗愚の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗愚の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗愚が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗愚という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗愚という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗愚についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗愚を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗愚は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗愚について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗愚が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗愚は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗愚の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗愚は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗愚は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "悪性の料簡だ、劣等の心得だ、そして暗愚の意図というものだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス革命の際、暴徒たちが王の居室にまで乱入したが、その時、フランス国王ルイ十六世、暗愚なりと雖も、からから笑つて矢庭に暴徒のひとりから革命帽を奪ひとり、自分でそれをひよいとかぶつて、フランス万歳、と叫んだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪性の料簡だ、劣等の心得だ、そして暗愚の意図といふものだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、そうした暗愚の義景を頼りにしたのは、長政の不覚でもあるが……。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元は、信長の為に一敗地にまみれたとは云え三大国を領するに至った丈にどこか統領の才ある武将であったが、子の氏真に至っては全く暗愚であると云ってよい。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は決して暗愚の将では無かったのだが、その機略威名が父信玄に遠く及ばない上に、良将を率い用いる力と眼識が無く、かく老将を抑えて自分を出そうとする我執がある。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府が、かうした難関に直面してゐた時、弘安七年北條時宗が三十四歳の壮年で世を去つたことは、北條氏の運命を決したやうなもので、その子貞時は凡庸、その孫高時は暗愚にして、一族の中の内訌相次ぎ、北條氏の衰運は、著るしいものがあつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世では、その人となり性悪で無く、暗愚無知でも無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗愚と言われたよりも明君と言われたら、八百万石のお心持も、さぞやいいお心持だったに違いない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用の世の中にこの古風は暗愚もまた甚だしい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "星を観測して地動説をとなえたガリレイが、そういう固定観念にぶつかって、生命の危険におびやかされたことを、今日の若い娘たちは、あらまアと彼のために同情し当時の権力の暗愚を憐みまた笑うだろう。",
              "citation": {
                "source": "幸福の感覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのルネッサンス女性の暗愚さは、ソヴェトの若い観客の目からけっして見落されてはいないに違いない。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど私たちの日本で、天皇制権力の犯した狂気のような国際的暴行と国内における抑圧を、ひしとその運命にうけてきながら、そこからの完全な解放をかち得ようともしない民衆と作家とがあるとすれば、そのあまりの暗愚と卑屈さがくちおしいことであるのと同様である。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケプラーのような真摯な天文学者でも、彼の生きた時代の権力と宗教とが暗愚であったこと、彼の母親が魔法つかいとして宗教裁判に附されようとしたりして、そのために時間を費し、精力を費してたたかわなければならなかった。",
              "citation": {
                "source": "なぜ、それはそうであったか",
                "author": "――歴史・伝記について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活のためパン焼工場へ行った十七、八のゴーリキイが、既に彼等に会わなかった前のゴーリキイではなくなっているという重大な事実、及び暗愚と無恥との中におしこめられて精神的に孤独な境遇に暮すことがゴーリキイにとって、従前とは異った苦痛となっていることなどを不幸にも彼の教師達はちょっとも洞察しなかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私のさうした暗愚を見せつけられながら、どうして嫌やにおなりにならなかつたのでせう。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに當時の人主は多く暗愚にして一定の識見なく、徒らに彼等の博辯宏辭に欺かれて、政策を變更し、遂に大事を誤るに至る。",
              "citation": {
                "source": "韓非子解題",
                "author": "小柳司気太",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川佐兵衛は暗愚でも、時流が廻米、廻船問屋というものを恵んだ。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、深い理解と友情の必要な場合程、俗衆と同じ見地にまで成り下る暗愚な仲間に対する侮蔑を禁ずる事が出来なかつた。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　私は女性の位地を高めようとするには、女性が互に現在の自己の暗愚劣弱を徹底して自覚することがその第一歩であると確信するに到った。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西晉の武帝はその太子の惠帝（司馬衷）の暗愚で不評判なるを憂ひ、その才能の程度を實驗する爲に、特に密封にて或る問題を與へて、太子にその答案を提出せしむることにした。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗愚では困るが、普通の人間なら、その論文には必ず經書や古人を引用せねばならぬ慣習は、この事件を見ても明かである。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の天子は如何に暗愚でも、天下を治むる間は、決して孝道を忘れぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ支倉君、これ以上論ずる問題はないと思うが、ただただ憐憫を覚えるのは、伸子に操られて鞠沓を履かせられ、具足まで着せられた暗愚な易介なんだよ」そう云ってから法水は、最初から順序を追い、伸子の行動を語りはじめた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶、暗愚の蛮僧に遇つた為に、好んで、この天与の福を失ふやうな事になつたのである。",
              "citation": {
                "source": "酒虫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば余が弱冠の時より今日にいたるまでの生活は、悉皆偶然に出でたる僥倖にして、その然るゆえんは必ずしも余が暗愚、先見の明なきがために非ず。",
              "citation": {
                "source": "成学即身実業の説、学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸気、電気の働は開闢の初より明に示す所なれども、人間の暗愚なる、久しく之を知らずして、漸く近年に至り始めてその端緒を探り得たるのみ。",
              "citation": {
                "source": "人生の楽事",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後とても人智の次第に進歩するに従い、いよいよ之を探りていよ／＼之を知り、その知り得たる上にて未だ知らざる時のことを思えば、唯人間の暗愚なりしを悟るのみにして、今日は学界尚お暗黒の時代と云うも可なり。",
              "citation": {
                "source": "人生の楽事",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸氣電氣の働は開闢の初より明に示す所なれども、人間の暗愚なる、久しく之を知らずして、漸く近年に至り始めて其端緒を探り得たるのみ。",
              "citation": {
                "source": "人生の樂事",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い木のてっぺんで百舌鳥が鳴いているのを見ると、六蔵は口をあんぐりあけて、じっとながめています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
