        "examples": {
          "standard": [
            {
              "text": "私は毎日アムールについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アムールという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアムールの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアムールが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アムールを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアムールについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アムールの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアムールの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアムールが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アムールという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアムールという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアムールについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アムールを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアムールは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アムールについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアムールが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアムールは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアムールの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アムールは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアムールは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "散文も少々あるやうだが、詩集アムール・ジョーヌは彼の主著である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の苦い経験の全て、やさしい告白の全ては、アムール・ジョーヌの中にある。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムール、サクソン、スプリング、浦塩、アプルツク。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど終日、アムール河の上流シグハ川に沿うて走る。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのセパードはアムールといってステキに大きい、人懐こい犬で、その中でも玲子と、玲子の先生の中林哲五郎には特別によく懐いているのであった。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時に玲子は別段にアムールの名を呼ぼうとはしなかった。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい……あの……あの……泥棒が……」「……泥棒……何が泥棒です……」「あの……あの……このごろ……アムールが御飯を食べなくなりましたので……」　マダムの薄い唇に冷笑が浮かんだ。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのアムールは、そんなに手軽く他所の人に馴染むような馬鹿犬ではありません。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムール河の水にうつる軍帽の赤い星、爆撃機の大きい影、ひしひしと白人の魔の手は、東洋へのびて来る。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど終日アムール河の上流シグハ川について走る。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私が『戀はしました』（ジェイ・フェイ・アムール）といつた、その一語であつた。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三、カムチャッカ作戦基地よりするスピーディな水上・潜水巡洋艦と、アムール河上ニコライエフスク作戦基地の航空巡洋艦の活動は、日本海軍の作戦に並行して、自国沿岸防備以外の、日本沿岸封鎖の重要作戦をとり得ること。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はオニグルミ一名チョウセングルミをもって、満州、朝鮮ならびに黒龍江（アムール）地方にある Juglans mandshurica Maxim. すなわちすなわちマンシュウグルミの一変種だと考定したい。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くアムールの岸を噛む波の響きは、興安嶺を越え、松花江を渡り、哈爾賓の寺院を揺すり、間島の村々に伝はり、あまねく遼寧の公司を揺るがし、日本駐屯軍の陣営に迫るおう、国境を越えて腕を結び×（24）の防塞を築くその日はいつ。",
              "citation": {
                "source": "生ける銃架",
                "author": "――満洲駐屯軍兵卒に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "安里は口癖のやうに、女はもつと「アムールーズ」でなければ駄目だと云ふ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アムールーズ」とは、女の恋心について、フランス語でまあ「濃厚な」とか、「旺盛な」とかいふぐらゐの意味だらうが、梨枝子には、そのことが既にもうよくは呑み込めなかつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時侵略を免れたという国が、その康熙帝の子孫に至ってどういう事になったというと、百年の後には「アムール」河を取られ、五十年の後には沿海洲も取られ、続いて露西亜は支那の困難に乗じて更にまたかの浦塩斯徳に近い処を取ってしまった。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗世の音楽書にあるアムール（愛）という音は、修道院の中にはいって行くとタンブール（太鼓）もしくはパンドゥール（略奪者）と代えられていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
