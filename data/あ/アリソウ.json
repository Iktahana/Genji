        "examples": {
          "standard": [
            {
              "text": "私は毎日有りそうについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りそうという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りそうの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りそうが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りそうを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りそうについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りそうの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りそうの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りそうが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りそうという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りそうという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りそうについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りそうを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りそうは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りそうについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りそうが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りそうは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りそうの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りそうは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りそうは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそういう処でも「絶対の自由」などという夢のようなものはおよそ有りそうもないようである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつの云うことを聞く者がだいぶ有りそうかな？",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見慣れぬビルディング街の夜の催眠術にかかって、いつのまにか方角がわからなくなってしまう、ということは、きわめて有りそうなことである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも人のうわさで事実はたしかでないが、しかし至極もっともな有りそうな話である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表だけ見えて、欄干が左右へ……真中に榎の大樹があって仕切る、その二階がね、一段低くなって流に臨んで、も一つ高い座敷が裏に有りそうなんだ、夢だからね、お聞き。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ仰有りそうな処、御自分の越度をお明かしなさりまして、路々念仏申してやろう、と前途をお急ぎなさります飾りの無いお前様。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかオンバコやスギ菜を取って食わせる訳にもゆかず、せめてスカンポか茅花でも無いかと思っても見当らず、茗荷ぐらいは有りそうなものと思ってもそれも無し、山椒でも有ったら木の芽だけでもよいがと、苦みながら四方を見廻しても何も無かった。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の暖簾の鯛の色は、燐火となって燃えもせぬが、昔を知ればひづめの音して、馬の形も有りそうな、安東村へぞ着きにける。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、有りそうなことだと思います。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に用の有りそうな連中は、大概この座に居合わす。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「東京が贔屓かい、それは難有いね、そしてここいらに、贔屓は珍しいが、何か仔細が有りそうだな。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな事がまったくあるかしらん」　どう考えても、そんなことが有りそうにも思われなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的には元から幽霊は幽霊であったのだが、昔それに無い内容を嘘き入れて、有りそうにした主観までが、今は消え失せてしまっている。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質は分らないが、どうもねじくれた処なぞが有りそうにはない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは上野の寺内に立籠っていた為で、なるほど有りそうなことですが、芝居の番附を抱いていたのは藤崎さん一人でしょう。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことも有りそうに思われるので、高松さんも娘の詮議は先ずそのくらいにして置きました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士が大小をさゝずに来たなどというのは、常識から考えても有りそうもないことですから、こゝの家で隠したと云う疑いはすぐにかゝる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあ有りそうなことですが、ねえ、親分、凄いじゃあありませんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「真珠の首飾」にしても、有りそうな事件を取り扱い乍ら、拵え物としか思われないのは、その把握力が弱いからで、キメの荒い散文的の描写は、そうでなくてさえ非審美的の、探偵小説というものを、一層ぞんざいに墜し入れている。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも有りそうな事件と云うより有った事件を有りのままに纏めた――こう云い度いような作品です。",
              "citation": {
                "source": "二つの作品",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のびのびとした、ねぼけたような春の日光は縫目にしらみの行列の有りそうな袷の背中をてらして居る。",
              "citation": {
                "source": "ピッチの様に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夕方の香りの有りそうなもやがかなり下りて川で洗われてしっとりとつやのある背の馬が思うままにのびた草を喰べながら小馬を後につれながら同じ池のふちを歩いて居た。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは有りそうなことである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "活眼を開いて人生の活相を観得なかった私が、例の古手の旧式の思想に捕われて、斯う思ったのは仕方がないが、夫にしても、同じ思想に捕われるにしても、も少し捕えられ方が有りそうなものだった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本名だとすればだね、君は気がついているかどうか知らないが、秋川という姓は、有りそうでいて殆どない姓だぜ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ顔を見覚えておくために、眼の前に坐っている運転手の顔を、反射鏡で気取られないように覗き込んだが、見れば見る程ガッシリした体格で、肩幅なぞは普通人の一倍半ぐらい有りそうに見える。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時に家老の隠居があって、大層政治論の好きな人で、私が家老の家に行たらば、その隠居が、ドウも公武の間が甚だ穏かでない、全体どうも近衛様が爾うも有りそうもない事だとか、或は江戸の御老中が詰らないとか云うような慷慨談を頻りに云て居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共雑誌に出て居るのを見ただけではそう私のすくものでは有りそうもない。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに味方の伝習隊が役に立たぬ」「味方の鉄砲が役に立たぬに、敵の鉄砲が」「シャスポーを、フランス式は使用しているが、何んでも幕府に金の無い為、安物を買ったとかで、銃身の何っかが曲った廃銃まであるという噂もあった」「有りそうな事だ。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折の油画にありそうな女だなど考えながら博物館の横手｜大猷院尊前と刻した石燈籠の並んだ処を通って行くと下り坂になった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
