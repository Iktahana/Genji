        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有りけるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有りけるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有りけるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有りけるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有りけるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有りけるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有りけるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有りけるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有りけるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有りけるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有りけるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有りけるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有りけるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有りけるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有りけるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有りけるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有りけるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有りけるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有りけるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有りけるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御堂は狭からぬに灯は蛍ほどなり、灯の高さは高し、互の程は隔たりたり、此方を彼方は有りとも知らず、彼方を此方は能くも見得ねば、西行は只我と同じき心の人も亦有りけるよと思ふのみにて打過ぎたり。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "足かけ四年で師の春満は死んだが、平田｜篤胤は玉襷の中で、荷田の門の人も多かりしと聞ゆる中に、一人ぬけ出て、その正意をば得られてぞ有りける。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其比は牧那渡の橋は無くて、上下往来の大道は金宮の麓よりぞ有りける。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして放免の或る者が雑色と呼ばれる身分のものになっていた事は、前引「今昔物語」の「詣鳥部寺女値盗人語」に、鳥部寺で参詣の婦人を強奸し、その衣服を剥ぎ取った雑色男が、「もとに侍にて有りけるが、盗して獄に居る後、放免になりにける者なり」とあるによって知られる。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七）やけどを治する呪術「さる沢の池のほとりに有りけるがあじかの入道をふてこそ入れ」この歌を三遍よみ、やけどの所を口にて吹くまね三度して、また、そこを足にてふむまね三度すべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "深き山にはかゝる者も有りけるよとて、細井知慎語れり（『視聴草』第四集巻六所録「荻生徂徠手記」）。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯る深山に入りてみやびたるわざに心をこらす少女の心のうちを思うにいとなつかしく今｜迄は只いとわしき者にのみ思いし外国人の中にかかるやさしきもありけるよと心にくき事限りなし。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾きし月の光にすかし見ればかねて見知りし大入島の百合という小娘にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは心たしかに侠気ある若者なりしがゆえのみならず、べつに深きゆえあり、げに君にも聞かしたきはそのころの源が声にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "此君にして此臣あり、十萬石の政治を掌に握りて富國強兵の基を開きし、恩田杢は、幸豐公の活眼にて、擢出られし人にぞありける。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検死の医師の診察せるに、こは全く病気のために死したるにあらで、何にかあるらん劇しき毒に中りたるなりとありけるにぞ、棄置き難しと警官がとりあえず招寄せたる探偵はこの泰助なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここぞかの人形の室の裏なる密室になんありける。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とありける時、「御前いらっしゃいまし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠きその昔は知らず、いまの男は、牛込南榎町を東状に走つて、矢來中の丸より、通寺町、肴町、毘沙門前を走つて、南に神樂坂上を走りおりて、その下にありける露地の家へ飛込んで……打倒れけるかはりに、二階へ駈上つたものである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――八大竜王鳴渡りて、稲妻ひらめきしに、諸人目を驚かし、三日の洪水を流し、国土安穏なりければ、さてこそ静の舞に示現ありけるとて、日本一と宣旨を給りけると、承り候。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて翌日まさに福井に向かいて発足すべき三日目の夜の興行を※として煙の布くがごとく、淡墨を流せる森のかなたに、たちまち跫音の響きて、がやがやと罵る声せるは、見世物師らが打ち連れ立ちて公園を引き払うにぞありける。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づきてとくと視れば、浅葱地に白く七宝｜繋ぎの洗い晒したる浴衣の片袖にぞありける。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて裁判長は被告に向かいて二、三の訊問ありけるのち、弁護士は渠の冤を雪がんために、滔々数千言を陳ねて、ほとんど余すところあらざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔見し花ちる里の古き井にありける影や幼な君われ。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起居注の魏観字は杞山というもの、太子に侍して書を説きけるが、一日太祖太子に問いて、近ごろ儒臣経史の何事を講ぜるかとありけるに、太子、昨日は漢書の七図漢に叛ける事を講じ聞せたりと答え白す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本より此の異僧道衍は、死生禍福の岐に惑うが如き未達の者にはあらず、膽に毛も生いたるべき不敵の逸物なれば、さきに燕王を勧めて事を起さしめんとしける時、燕王、彼は天子なり、民心の彼に向うを奈何、とありけるに、昂然として答えて、臣は天道を知る、何ぞ民心を論ぜん、と云いけるほどの豪傑なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話は別になりますが、昔の人が今の小説を読んで、主人公の結局る所がないと云ふ、「武士の浪人ありける。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れたり、斯道に曙山君ありけるを、花一ツ採りて懐にせんも惜く、よく色を見、葉を覚え、あくる日、四丁目の編輯局にて、しか／″＼の草はと問へば、同氏頷きて、紙に図して是ならん、それよ、草菖蒲。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乘客の暗愁とは他なし、此の不祥を氣遣ふにぞありける。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の原由を尋ぬるに、旗野の先住に、何某とかや謂ひし武士のありけるが、過まてることありて改易となり、邸を追はれて国境よりぞ放たれし。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人皆いずれの道にも煙はのがれず、殊に不便はこれにぞありける。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうがうしこのピアノ、立ち添ひて、蹲み見て、蓋をひらき、鍵たたき見て、見も飽かず終日ありける。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "古にありけることを。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "年のごとありけるものを。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは人に知らせじと思ひし、わが人斬りの噂、次第に高まり来りて、いつしか長崎奉行、水尾甲斐守の耳に入りしと覚しく、与力、手先のわれを見送る眼付き尋常ならざるに心付き、人知れず身を晦まさむ時の用意に備へたるものにぞありける。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
