[
  {
    "uuid": "198f54c7-41ec-5cc0-932b-8c3503b457a9",
    "entry": "歩き初め",
    "reading": {
      "primary": "あるきぞめ",
      "alternatives": [
        "ありきぞめ"
      ],
      "is_heteronym": false
    },
    "grammar": {
