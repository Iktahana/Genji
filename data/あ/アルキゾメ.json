      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "baby's first steps",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日歩き初めについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は歩き初めの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には歩き初めが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは歩き初めについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は歩き初めの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では歩き初めが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に歩き初めという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では歩き初めについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると歩き初めは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では歩き初めが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に歩き初めは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により歩き初めの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "歩き初めは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に歩き初めは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（４）leading-strings ――歩き初めの子供につかまらせて歩き慣らせる紐。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、またスタスタと歩き初めた。",
              "citation": {
                "source": "失題",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで漸く気がついた照子は、好いあんばいにひよろ／＼と歩き初めた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つたかとおもふと頬のあたりから鼻頭をこゝろもちあからめて、再び頓興な笑ひ方をすると、突然快活な口笛を吹き鳴らしながらグルグルと部屋のなかを歩き初めた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言いながら、青年は歩き初めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は軈て男の周囲をめぐって歩き初めた。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう言ひながら、青年は歩き初めた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　午後、建物の内廊下を歩き初め。",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森君は階段を上って、お堂の中を覗き込んで、廻郎を歩き廻って下へ降りて、今度はお堂の廻りをグルグル歩き初めた。",
              "citation": {
                "source": "贋紙幣事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場上の丘を、のそりのそり、下りて来るとすれちがいに、挨拶する男がある、誰かと思ったら昨日の絵はがき屋さんで、いやに、にこにこしている様子が、話でもはじめそうだから、また、ブオン・ジオルノで御免を蒙って、急に、いそがしそうに歩き初めた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリンムルの一つ手前の、ローゼンタール・グロース・ウェネディガー Rosenthal-Gross-Venediger で下りて、ぶらぶら歩き初める。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうするうちに、午前正十一時、降りしきる雨の中を停車場をはなれて、だらだら路を、村の方へ一行五人歩き初めた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が自分等の預つて居る生徒の父兄であるかと考へると、浅猿しくもあり、腹立たしくもあり、遽に不愉快になつてすたすた歩き初めた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬之進は何か思出したやうに、熟と其少年の群を見送つて居たが、軈て心付いて歩き初めた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮太郎は何か思出したやうに、後から来る細君の方を振返つて見て、やがて復た歩き初める。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、丑松は半分夢中で聞いて居たので、つと立上つて部屋の内を歩き初めた時は、もう其声が聞えなかつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女同志は直に一緒に成つて、言葉を交し乍ら歩き初めた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "季子は声まで出して思うさま大きな欠伸をしつづけたが、こんな処にはもう我慢してもいられないとでも云うように、腰掛を立ち、来た時のようにぶらりぶらりと夜店の灯の見える方へと歩き初めた。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　季子は知らない振もしていられず、ちょっと笑顔を見せて、そのまま歩き過ると、男も少し離れて同じ方向へと歩き初める。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の方を鋭い眼で見つめながら、頭をこっくりこっくり動かして、私の寝てるまわりをぐるぐる歩き初めた。",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "季子は聲まで出して思ふさま大きな欠伸をしつゞけたが、こんな處にはもう我慢してもゐられないとでも云ふやうに、腰掛を立ち、來た時のやうにぶらり／＼夜店の灯の見える方へと歩き初めた。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　季子は知らない振もしてゐられず、ちよつと笑顏を見せて、そのまゝ歩き過ると、男も少し離れて同じ方向へと歩き初める。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　不味さうに取揃へられた晝食を爲し終へると、彼は兩手を胸に組んで考へながら室内を歩き初める。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　彼は室内を歩き初めたが、施て小聲で又言出す。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　不味そうに取揃えられた昼食を為し終えると、彼は両手を胸に組んで考えながら室内を歩き初める。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　彼は室内を歩き初めたが、やがて小声でまた言出す。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "警手の西山は知らぬ顔をして、リノリュームの通路を静かに歩き初めた。",
              "citation": {
                "source": "静かな歩み",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "（既に先に立って歩き初めている井上の後に従って、花道へ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうから少々歩き初めです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は椅子から身を起こした、そして室のうちを歩き初めた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
