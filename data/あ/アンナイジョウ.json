        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内嬢について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内嬢の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内嬢が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内嬢について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内嬢の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内嬢が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内嬢という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内嬢についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内嬢は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内嬢が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内嬢は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内嬢の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内嬢は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内嬢は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "２　間もなく、君枝はタクシーの案内嬢に雇われた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ客はまごつき、運転手も余り歓迎せぬ制度ゆえ、案内嬢は余程の苦労が要る。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝は致し方なく、新聞の三行広告を見て、タクシーの案内嬢に雇われた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで大きな百貨店の玄関で案内嬢から店内の案内を聞くような気がする。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫との間を清算しようとして失踪したのだそうで、しかしこれも成功せず、数年後、東京銀座の大阪系酒場で再会した時も、やはり勢蝶との同棲は余儀なく続けられており、あきらめて私が遠ざかって多年ののち、勢蝶が新橋演舞場の美人の案内嬢と結婚したとの報せを耳にした。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内嬢は今日でもゐるけれど、大晦日にはやつぱり島田に結ふだらうか。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内嬢以前の留場の男は、キチンとしたたつつけ袴を履き、細く仕切られた桝の上をわたつて来ては、ほんとに腰を海老に曲げ、たべものの注文を聞いて歩いた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふいに、ぼくら旅客の眠りをさまして、案内嬢がいじらしい嬌声を張りあげる。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなにあんないじょうを出して、こんや見せるといってあるんだから、よすことはできないんだって。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
