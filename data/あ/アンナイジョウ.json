              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昨日の夕刊が二枚と、『探偵小説全集』が一冊と、『南京鼠の合理的長命法』と云うパンフレットと、古い帝国ホテル舞踏会の案内状が一枚出て来たばかりでした。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はパンの会の為めにしばしば案内状の板下を作つた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内状は、主に準之助氏の知人関係に配られた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "披きて讀めば、博士マレツチイと夫人サンタとの案内状にして、フエデリゴ君をも伴ひて來ませとあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日を経て果して案内状を送り来りければ、両親および学生友人を誘いて見物せしに、なるほど一座の進歩驚くばかりなり、前年半ばは有志半ばは俳優なりし彼は終に爾く純然たる新俳優となりすませるなりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の漁が見たかつたので知人の案内状を持つて九十九里の濱の網主のもとへ行つた。",
              "citation": {
                "source": "濱の冬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "活版の案内状に、何某も呼んであるから来いといふ書添がしてあつた。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "健作――明日の案内状の返事はもうたいてい来たかね？",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、案内状が来てたじゃございません」「知らないよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの案内状どこへ行ったんでしょう」「ふうん。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内状にも書いてある通り、きょうは朝から細かい雪が降っている。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物の場所はかならず土間の四と決まっていて、団十郎の方から日をきめて案内状を送って来た。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内状には必ず堀越秀という本名を記し、最初の二、三回は本人の直筆であったが、その後は狂言作者の竹柴瓢三の代筆になったということである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――××中学卒業生のうち、東京在住の者だけの同級会の案内状だつた。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスへ留学するＥの送別会の案内状が彼の許にも届いていた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスへ留学するＥの送別会の案内状が彼の許にも届いてゐた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仕事はおトクイ様に案内状を出す事と、カンタンな玉づけをならって行く事だった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "●女中の手登場……珈琲と、帝劇マチネーの案内状を机の上に置いて退場……。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇悪人の手…………立ちながら珈琲を取り上げつつ案内状を見る。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………指環をはめ直し、指先に残っている化粧のあとをハンカチで拭い消しなぞしながら、何気なく机の案内状と葉書とを取り上げてみる。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………まず、案内状の回答用葉書に新しく「同　シズ子」と書いたのを照し「欠席」の文字の上のカスレタペンの痕を検め、次いでインキに濡れたピンセットを照し出す。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って封を開いて見ると、それは明後日の午後六時から、男爵の私邸で小宴を開くから来てくれという意味の、儀礼をつくした案内状で、最後に出席する人々の名前が書いてある。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角御来邸の案内状を頂いたのに、留守をしていては申訳ないからね」「途中から引返したのか」「とんでもない。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、君のところへは会の案内状が来た？",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか私を、会の案内状から削除するという意味ではあるまい……？",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はむずかしい顔して、行儀よく坐ったが、「君のところへは案内状が行ったかね？",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは直造が案内状を出す間際になつて心づき、入念に考へたあげくに呼ぶことにした高間房一だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう、昨日の同窓会――案内状が来たでしょう――はおもしろかってよ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなにあんないじょうを出して、こんや見せるといってあるんだから、よすことはできないんだって。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
