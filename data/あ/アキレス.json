    "definitions": [
      {
        "index": 1,
        "gloss": "Achilles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "実にホーマーについて知られることは、彼がイリアッドを書いている時に、あの見すぼらしい放浪詩人が、実にトロイ戦争の勇士であり、アキレスであったと言う事である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ彼は始めから、トロイ戦争の勇者になり、アキレスのように戦場で功名していた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘラクレスの如くアキレスの如き巨漢が、甘ったれた口調で、私のことを「パパ、パパ」と呼ぶのだから、やり切れない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで我が妻アキコを知るお調子者某が、「ホントお宅に行っても僕らにはお茶一杯出しませんよね」などとぬかそうものなら、オレとしてはやむを得ずアキレス腱固めに及ぶしかない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばラシイヌの描いたイフジエニイとウリピイドの描いたイフゲニイ、ラシイヌの描いたアシイルとホーマーの描いたアキレスを比較して見れば、這般の事情ははつきりとわかるであらう。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そろ／＼、務めに出かけようぜ、アキレス！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、出て行つた二人の鎖襦袢はテイヴオリの凱旋門近くの森にある「パトロクラスの傷を介抱するアキレス」の記念像を務める、騎士級の家柄に育つた若者である。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前五世紀の人でアレキサンドリア出のギリシアの著者アキレス・タティオス（Achilles Tatios）の記したところによると、カルデア人はこういうことを主張していた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗暴な狼たちは、このアキレス腱めがけて、菅氏にとびかかり、かんでかんで、遂に彼の勇気を、かみちぎってしまいました。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキレス氏｜腱は張り切って、果物ナイフの刃のように外へむかってほそく震えていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は、貴方特有の強健な趾と、アキレス腱の跳躍力を利用して、この事件を遂行されたに違い無いのです。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキレス　希臘の英雄アキレスは踵だけ不死身ではなかったそうである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――即ちアキレスを知る為にはアキレスの踵を知らなければならぬ。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシヤ神話のアキレスの致命の踵がここでは、武器の方に移つてゐるのは面白いではありませんか。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキレス　希臘の英雄アキレスは踵だけ不死身ではなかつたさうである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづくは戦艦『アキレス』『クリシナ』（戦の神）である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後の國の王であるよりは貧しき人の地を耕す賤の男でありたい（三）、と叫んだアキレスの如く、死後の存在に、たとひ消極的意義においてにせよ、思ひを向けることは常に行はれる事であらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも「アキレスと亀」の詭弁が詭弁ならざる真理として永遠に「シツツアル力」の亀を先登に立てゝ進みつゝある。",
              "citation": {
                "source": "意識と時間との関係",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽巡アキレスとエジャクとの二隻が加わろうとしている」　二人の少壮士官は、一しょに駈けだしていった。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ敵は恋路を邪魔されて引きさがるような男でないことは、あの嵐のように女を愛したアキレス同然である。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「できるんだよ」アキレスは言いました。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そしたら俺はここにいないだろうね」アキレスは謙遜して答えました。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「全くその通りだ」アキレスは同意しました。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フットボールをやる亀なんて……」アキレスは言いかけました。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アキレスは考えながら言いました。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
