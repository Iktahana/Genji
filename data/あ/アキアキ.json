        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "自然保護の活動が広がっている。",
              "source": "幻辞"
            },
            {
              "text": "環境問題への対策は急務である。",
              "source": "幻辞"
            },
            {
              "text": "野生動物の生態系が脅かされている。",
              "source": "幻辞"
            },
            {
              "text": "森林資源の管理が重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "自然災害への対応力が試されている。",
              "source": "幻辞"
            },
            {
              "text": "気候変動の影響が顕著になっている。",
              "source": "幻辞"
            },
            {
              "text": "自然現象の美しさに心が洗われる。",
              "source": "幻辞"
            },
            {
              "text": "生物多様性の保全が急がれている。",
              "source": "幻辞"
            },
            {
              "text": "自然エネルギーの活用が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "環境汚染の改善に向けた取り組みが進む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "云換れば、其の西欧二千年の文献の、そのあれやこれやが、誰かの口によつて少し唱へられさへすれば、人々はその方へドヤドヤと寄り、それを一通り見た頃にはもう飽き飽きしてゐたのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は實に、日本文壇の技巧的文學に飽き飽きしてゐる。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い飽き飽きした時間の後に、やつと明石行の列車が這入つてきた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって僕は歌劇の舞台以外おしろいをべったり塗って西洋人のなかをしゃなしゃな歩く沢山のマダム・バッタフライの複製には飽き飽きしているんだ。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢のようでもあり、いつまで経っても同じ繰返しばかりで飽き飽きしても感じられた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この系統の電車は均平にもすでに久しくお馴染になっており、飽き飽きしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、金とか、女とかいうものも実際に手に取ってみると存外下らない、飽き飽きしたものである上に、そんなものに対する慾望を持続して行くためには実に馬鹿馬鹿しい、たまらないほど夥しい苦労を続けなければならぬであろうことを考えるだけでもウンザリした。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど女性の陰に悩まされた自分でありながら、さて女性に離れて仕舞うことになると、まるでぽかんとして仕舞うのですね」　それは恰度菓子造りの家の者が菓子に飽き飽きしながら、絶えず糖分を摂取せずにはいられないようなものではなかろうか。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は婆さんのおしゃべりに飽き飽きして片方の手をコツンと箱にさわらせた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十日も通うと少し飽き飽きして来るのねえ」　加奈江がつくづく感じたことを溜息と一緒に打ち明けたので、明子も自分からは差控えていたことを話した。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽き飽きするのも無理もない。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心とか、義理とか、人情とか、生活の苦しみとか、いうものには毎日毎日飽き飽きするくらい触れているんだから、そんなものにモウ一度シミジミと触れさせる普通の小説なんか、御免蒙りたいのだ。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻につく」という言葉は、始めのうちは珍らしさに紛れていた臭味がだんだんとわかって来てうんざりした、嫌になった、飽き飽きしたという、多少前の「鼻｜白む」というのと似通ったような表現であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が飽きなくっても、南條先生は飽き飽きしていらっしゃるだろう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ困るのは『その日、その日の話』というやつで、わざわざ本でよまないでも、毎日のことで飽き飽きしますよ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ一体いつまで待たせるんだろうねえ、飽き飽きしちまった。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽き飽きするほど日のながいこの頃、物考えなどしてどうかすると午前か午後かを忘れる事がある。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者は最早露西亜や満洲の記事には飽き飽きした。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飽き飽きするでえ！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が当にしていた雲の切れ目も無くなって、飽き飽きする程同じ調子で、三日も四日も続いた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたあちやんは、もう飽き飽きして『帰りませう、帰りませう』と云ひましたが、おきいちやんは『もう鳥渡、もう鳥渡』と云つて矢張り摘んでゐました。",
              "citation": {
                "source": "虹の橋",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一爺イと子供とが、あんなに真面目に話していたのでは、どうも聞く方で飽き飽きする。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無味単調な仇討の旅に、彼はもう飽き飽きしていた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに来てから、四日の間、ぼんやり床の間や天井や、庭や墓地などを見ていた格之介は、そうしたものに、かなり飽き飽きしていた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はもう下宿生活には飽き飽きしちゃった。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月廿一日　見ているとどの男も女に飽き飽きし、女は男に飽き飽きしている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬか雨が音もなく降り出して、さっきからわたしがさんざんそばをぶらついて、今ではもう飽き飽きしてしまった馬鹿げた灰色の丸太の山に、べた一面ちっぽけな黒ずんだ点々をつけた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手の強い姑の伴ばかりして、毎日行かせられるのを、お庄も飽き飽きしていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れゃ、人をうち殺すのにゃ、もうあきあきしちゃったぞ！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ジム、もうあきあきしたわ、そんな事。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
