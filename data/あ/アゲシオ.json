        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上げ潮の例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "道は上げ潮の運河の上の橋にかかっていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "図は上げ潮の時の有様ですから、潮流はＤの方からＡＢを通ってＣの方へ流れて行きます。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "図は前にも云った通り上げ潮の時の有様ですが、下げ潮の時には反対に図の下側の方へ同じような流れと渦巻が出来ます。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざわざわ鳴り続け出した蘆洲の、ところどころ幾筋も風筋に当る部分は吹き倒れて泡をたくさん浮かした上げ潮が凪ぎあとの蘆洲の根方にだぶつくのが覗ける。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは盛運の上げ潮に乗った緊張の過ぎた結果であったと思われる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ある夜遅くあの部屋へ入って、結婚｜衣裳を調べていて、ふと、上げ潮に鴎の鳴く声を聴いたら、娘は芝居の幕が閉じたように、若い学者との結婚が馬鹿らしくなった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮の頃と見え、家の裏手の堀川に荷船が頻りに通っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのあとでも藻の中の泥土にまみれて漁師の眼から逃れた魚が上げ潮に誘われて半死半生のからだを浮き上らせないことはありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはもう対岸に近く、葭のまばらな岸の根に食込んで、土手の投影の中に河の本流が上げ潮の早い流勢を見せています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮の芥に横転縦転する白い鴎がビール会社の赤煉瓦を夕暮にした。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳緑のびろうどの河豚責めふくらし昨日も男涙ながしき　こうした歌を校正しているうちにさみどりのちひさ河豚の子上げ潮のしほさゐ安く群るるこの頃という風の歌が出来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂のこまかな波打際に坐つて、永い間、京都のこと、其處の古い寺々のこと、歌のこと、地震のこと、それとはなしにまた彼の一身のことなどを話してゐるうちに、いつか上げ潮に變つたと見えて小波の飛沫が我等の爪先を濡らす樣になつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の落ちるのは、干潮の間僅かの時間であるから、雨の強い時には、降った水の半分も落ちきらぬ内に、上げ潮の刻限になってしまう。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮で河水が多少水口から突上るところへ更に雨が強ければ、立ちしか間にこの一区劃内に湛えてしまう。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮で河水が多少水口から突上る處へ更に雨が強ければ、立ちしか間に此一區劃内に湛へて終ふ。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりゃ上げ潮を待った方がいいや」三上はまだ獲物のそばにでもいるように薄気味わるく、ぞんざいな言葉を使った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでたまたま張る気を以って物事を行っていても、少時で直ちにまた反対の弛む気が引き出されて来て、次第に張る気が衰え弛む気が長じて来ることは、例えば進潮（上げ潮）が永く進潮であり得なくてやがて退潮（引き潮）を生じるようなものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば南海の上げ潮の時に、強い南風がこれに加わると潮狂いになっていわゆる潮信（潮時）と云うものを失ってしまうのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば潮は毎日夜に二回ずつ進潮（上げ潮）になり退潮（引き潮）になる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも言えない勇ましい新しい力――上げ潮のように、腹のどん底からむらむらとわき出して来る新しい力を感じて、君は「さあ来い」と言わんばかりに、艪をひしげるほど押しつかんだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂のこまかな波打際に坐って、永い間、京都のこと、其処の古い寺々のこと、歌のこと、地震のこと、それとはなしにまた彼の一身のことなどを話しているうちに、いつか上げ潮に変ったと見えて小波の飛沫が我等の爪先を濡らす様になった。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――抱き合ったままのいたましい骸を守りながら、折からの上げ潮を乗り切って漕ぎに漕ぎつ、急ぎに急ぎつ、さしかかったのは大川名打ての中州口です。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは上げ潮のひた押しに押して來る姿に似てゐた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮につれて灰色の帆を半ば張った伝馬船が一｜艘、二艘とまれに川を上って来るが、どの船もひっそりと静まって、舵を執る人の有無さえもわからない。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮の隅田川の水に灯の映って見える玄関の軒灯をくぐり、二階へ昇って行くと真紀子はもう先に来ていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の干潟の渚には、水の方にみな頭を向けて、死者と生者とが相並び、それを上げ潮の川水が徐々に浸していった。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど日の暮の上げ潮だったが、仕合せとあすこにもやっていた、石船の船頭が見つけてね。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいのが洲走りといつて、此奴は釣れないが、オボコとなるともう四五寸あるから、夕方の上げ潮なら何処の川口でも釣れる。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから水は上げ潮で河幅一杯に満々と、妊婦の腹のように膨れていた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
