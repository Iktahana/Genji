        "examples": {
          "standard": [
            {
              "text": "私は毎日雨間について考えている。",
              "source": "幻辞"
            },
            {
              "text": "雨間という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は雨間の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には雨間が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "雨間を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは雨間について学習した。",
              "source": "幻辞"
            },
            {
              "text": "雨間の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は雨間の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では雨間が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "雨間という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に雨間という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では雨間についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "雨間を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると雨間は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "雨間について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では雨間が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に雨間は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により雨間の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "雨間は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に雨間は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "翌日一日滯在、降りみ降らずみの雨間に出でて辨天橋といふあたりを散歩した。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が山に登つてから三日間は少しの雨間もなく降り續いた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "遲い夕飯を終つた頃、幸ひ雨間となつてゐたので出て七間町あたりを彷徨ひ、カフエーパウリスタといふ名を見附けて其處へ寄つた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日たつてから私は少しの雨間を見て散歩に出た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨間を見ては、苅り残りの麦も苅らねばならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはひさしぶりの雨間に、さっきから頭の君が道綱のところに来ていられたようだったが、そのうち知らない間に一人でこちらへ入らしってしまわれた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨間を見ては、お勤の暇々に、私も少しずつ手入れをさせ出していたが、そんな或日の事だった。",
              "citation": {
                "source": "かげろうの日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨間というものがすこしもなく、雲行きは悪く、荒れ気味で安心がならなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "光明后宮の維摩講に唱われた仏前唱歌「しぐれの雨間無くな降りそ紅ににほへる山の散らまく惜しも」のごときは、仏に対する感情が全然表現せられていない点でわれわれを驚かすのである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上を歌い流れる小川のほとり、白いチューリップや水仙の中を、鵠の鳥が堂々と歩を運んでる新鮮な牧場、大きな翼の燕や鳩の群れが飛んでる澄みわたった空気、雨間を貫く日光の楽しさ、雲間に笑う輝いた空、夕の厳かな清朗さ、森や家畜や町や野の休らい、などを彼は愛していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "実例はいくらもあるが一つ挙げて見ると、『万葉集』巻八に、時雨の雨間なくな降りそ紅に匂へる山の散らまく惜しもという歌がある。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああまあいいあんばいだった。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああまあいいあんばいだつた。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道側に倒れていたんを、お坊さんが見つけて、京の屋敷へ引渡そうというたのを、義観さんが、まあまあいうて、御自分の庵室へ、連れ戻りなされたんやがな。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあまあいいから帰りたまえ」　たくましい手をグイと延ばし、私の腕をひっ掴んだ。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見かけするところ、あなたあ変な御様子だがこりゃあまあいったいどうなすったというので――あの出羽、いや、祖父江出羽さまのお眼に留まって、田万里から伴れ出されてから、今までどこにどうしてお暮らしなされた――。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあまあいい方だよ」「ところが毎日喧嘩ばかりしているさ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「来週からですって……」「――じゃあまあいいけれど――人に訊かれても、何処へも出ていません、じゃ困るからね、あの年で……お前からよくお礼を云うようにお云いよ――お父様、あのお忙しい中を、この間だってわざわざ津村さんの家までいらしったんだよ、そのために……」　佃は、大学へ通うようになった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあまあいいじゃないの。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の親父は、まあまあいい奴だったな。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅家の書の落款を入れ替えたもの、或は狩野風の無落款な時代物へ印章を後から加えた物などは、まあまあいい方というくらいである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
