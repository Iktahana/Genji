  {
    "uuid": "d4771f37-fdbd-5102-8b6c-6fb4874ffa24",
    "entry": "浅蜊",
    "reading": {
      "primary": "あさり",
      "alternatives": [
        "アサリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Manila clam (Ruditapes philippinarum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "春夜浅蜊のやうなもの、蛤のやうなもの、みぢんこのやうなもの、それら生物の身体は砂にうもれ、どこからともなく、絹いとのやうな手が無数に生え、手のほそい毛が浪のまにまにうごいてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊の殻を店の前の泥に敷いていた自身番の老爺は、かかえていた笊をほうり出して、半七らを内へ入れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊貝の腐ったゴト口開けとる奴ばドウするケエ』『まあまあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊ッ貝を小一升と、木葉のような鰈を三枚、それでずぶ濡れになっちゃあ魚屋も商売になりませんや。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊はとなりの家へやって、鰈は老婢とふたりで煮て食ってしまったというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "安房上総の山々を背景にして、見果てもない一大遊園地と化した海の上には、大勢の男や女や子供たちが晴れた日光にかがやく砂を踏んで、はまぐりや浅蜊の獲物をあさるのに忙がしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "はまぐりや浅蜊の獲物も大抵捨てて帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "お土産は小雑魚よりも浅蜊、蛤の類、手に手に破れ網の古糸をすき直して拵えたらしい提げものに一ぱいを重そうにして、これ留守居や懇意へのすそ頒け、自分は喰べずとも綺麗さっぱり与ってしまった方が結句気安いようで、疲れて寝る臥床の中に、その夜の夢は一入平和である。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲焼と蜆汁　土用に入っての夏の食いものに、鰻と蜆とは江戸ッ児の真先に計えあげる一つで、つづいては泥鰌、浅蜊のたぐいである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊は澄まし汁最もよく、豆腐にあしらったも悪くはない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹輪に浅蜊貝といったような物を種にして、大阪風の切鮨を売っている。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お縫は、やがて下駄を突かけて、ゆうべの浅蜊の殼をもって裏へまわった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この砂の中に隠れているのは浅蜊と云う貝に違いない。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから家族の衣食もそれに准じて粗末なもので辛棒させて、魚や肉などは余りに買わないで多くは浅蜊や蛤または鰯売り位を呼込んで副菜にし、あるいは門前の空地に生い茂っている藜の葉を茹でて浸し物にする事もあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泳ぎがうまく、蛤や浅蜊を拾う名手であった。",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "海辺の人から浅蜊の乾したのを送つて貰つた時、さつま汁の豚肉代りにしたり、豆腐と煮たこともあつて、浅蜊はこんなにおいしい物かと思つてその一袋をたのしみながら食べた。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊に生姜、豆腐に葱、台所に貼り付けとけ。",
              "citation": {
                "source": "麺麭屋文六の思案（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先で癇癪持らしい、侠な主が豆絞りの手拭で向こう鉢巻をして、セッセと浅蜊の殻を剥いていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父さんがよく宿酔のとき、深川茶漬といって浅蜊のおじやみたいなものをこしらえ、その上へパラリと浅草海苔をふりかけたのをよくお相伴させて貰った。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁令のおかげで却って人気が出て、文久のはじめごろは猫も杓子も万年青つくり、仕事もなにも放りぱなしで、壌士は京都の七条土に限るのそうろうの、浅蜊の煮汁をやればいいのとさんざんに凝りぬく。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "潟からは浅蜊や蜆や蛤がよく獲れて、綺麗な模様をした貝殻も多かった。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は浅蜊の貝殻を踏みつけた高橋際の路地にあった。",
              "citation": {
                "source": "醤油仏",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだとなると、こいつア検死が面倒だ、とにかく、抛っちゃおけねえ」　今さら驚いて顔役と亀親方だけが、例の浅蜊をザクザク踏みしめる路地の奥を訪れた。",
              "citation": {
                "source": "醤油仏",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丼飯の上へ、いろいろな物の煮汁を、まさにぶっかけたもので、浅蜊汁とか鰯の団子汁とか、鳥の叩き汁とか、野菜と油揚のけんちん汁など、種類が多いので、下等ながら評判であった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正造はそういってしきりに憂慮していたが、関宿附近の村落の被害がようやく肉眼に見えるまでになったと知り、江戸川及び中川の河口附近の浅蜊、蜆、蛤などが近来激減してきたと聴いて、にわかに加藤兼吉、野口春蔵の両名に実地踏査を嘱すことにした。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食、スパゲティーと、豚カツ、浅蜊のみそ汁、飯一杯半食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "残雪がまだ消えやらず化粧柳の若芽が真紅に萌え立つ頃には宿の庭先に兎が子供を連れて遊びに来たり、山鳥が餌をあさり歩くことも珍らしくないさうである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残雪がまだ消えやらず化粧柳の若芽が真紅に萌え立つ頃には宿の庭先に兎が子供を連れて遊びに来たり、山鳥が餌をあさり歩くことも珍しくないそうである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同出兵と云っている癖に、アメリカ兵は、たゞ町の兵営でペーチカに温まり、午後には若い女をあさりにロシア人の家へ出かけて行く。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "在留邦人達の北伐に対する関心は、幾年かを費して、拵え上げた財産や、飾りつけた家や、あさり集めた珍らしい支那器具や、生命を、五・三十事件当時の南京、漢口の在留者達のように、無惨に、血まみれに、乱暴な南兵のため踏みにじられやしないか、という一事にかかっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
