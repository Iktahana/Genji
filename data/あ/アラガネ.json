        "examples": {
          "standard": [
            {
              "text": "私は毎日粗金について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粗金という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粗金の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粗金が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粗金を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粗金について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粗金の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粗金の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粗金が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粗金という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粗金という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粗金についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粗金を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粗金は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粗金について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粗金が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粗金は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粗金の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粗金は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粗金は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "蟻等皆群なしていそしみ7635粗金持て来よ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雜りけのない粗金が汚い鐵屎よりも遙かにいゝよ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏きや神のみ埼にうつせ貝むなしき家を見ればさぶしも蚯蚓鳴くあらがねの土の下にて。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は、新しく登場した作家として「沃土」を書いた和田伝、「鶯」を発表した伊藤永之介等の作家があり、「あらがね」で鉱山の生活を描こうとした間宮茂輔等があった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらがねの土あたたかし冬籠、七十五歳｜陶後」と書した懐紙が徳さんの蔵儲中にある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄とあらがねが、絡んで、軋んで、押しあうひびき。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の博刃は今し高潮に達したとみえ、ふみきる跫音、鉄とあらがねの相撃ちきしみあうひびき、人の心胆を寒からしめる殺気、刀気……ののしるこえ、物を投げる音！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これは現在こゝろざすところに、余りにも遠く離れすぎてゐるものなので、別に心へとゞめることとして、あらがねの土秋暑き通り雨を得てこの方を切短冊へ認める。",
              "citation": {
                "source": "薄暮の貌",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの雰囲気はあらがねのように、いいもわるいもごたごただ。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日は茂輔氏の『あらがね』（小山出版）の会でいろんな人の顔といろんなテーブルスピーチをききました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "茂輔さんの『あらがね』も送って見ましょうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「あらがね」の作者、「探求」の作者などによって）。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今や直さんの「はたらく一家」「あらがね」。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その努力や摸索が見当をすこし違えると、「あらがね」以後のその作者になったりいろいろに変化する。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮越の根あがり松といふを見て、　わが身にあたる風もかくやと、みち潮のこしてや洗ふあらがねの土もあらはに根上りの松「なるほど」　園阿はうなずいたが、是とも非ともいわない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
