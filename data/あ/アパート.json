    "definitions": [
      {
        "index": 1,
        "gloss": "apartment building",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アパートについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアパートは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アパートの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアパートについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アパートは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアパートの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アパートに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアパートが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアパートを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アパートの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアパートが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアパートが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アパートについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアパートは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアパートは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアパートは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアパートについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アパートの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアパートの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアパートの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "毎晩アパート三階の便所に行くと、新宿の百貨店や何かの電燈広告が五六町ばかりの向ふに灯つてゐて、まるでほんとかと云ひたくなる。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はアパートの五階に住み荒漠たる洋室の中壁に寢臺を寄せてさびしく眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ非情の妻と別れてより、二兒を家郷の母に托し、暫くこのアパートメントに寓す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにしなくても市中の地の底へ何層樓のアパートメントでも建てた方がよささうに思はれる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴磨きにアパートにおける殺人の嫌疑をかけるためには殺されるダンサーのアパートにその靴磨きをなんとかしておびき入れ、そうしてアパートにおける彼等の姿を確実に目撃した証人をこしらえておく必要がある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその手順の第一として先ず街上でダンサーに若い方の靴磨き田代公吉へモーションをかけさせ、アパートへ遊びに来ないかと招待させる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしておいてから、田代公吉を縄張問題から同業の暴漢になぐらせ負傷させ卒倒させておいてそこへ前のダンサーを通りかからせ、そうして目的のアパートへ連れて行かせる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のアパートにおける目撃者としてアパートの掃除婦を役立たさせるためにわざわざ浅岡に水を汲みにやって廊下でこのおばさんに出逢わせておく必要のあることは勿論である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五円をもった田代がこのアパートに来ているものと見当をつけて尋ねて来るところに多少の複雑な心理的な味を見せようというのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊売りが問題の夜更けに問題のアパート階上の洗面場で怪しい男の手を洗っているのを見たという証言のあたりから、記者席の真犯人に観客の注意が当然集注されるから、従ってその時に真犯人は真に真犯人であるらしい挙動をして観客に見せなければならないこと勿論である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生のおうち、この近所」「いまは、この先のアパートにいる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は、茲のアパート、あちらの貸家と、彼の一所不定の生活が始まった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは湊と別れるとき、湊がどこのアパートにいるか聞きもらしたのが残念だった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傲がんなこころがすこしの反省もなく、イズモ町の彼女経営の流行品店を素通りして、築地河畔のコルビジェ風のアパートメントの一室を訪れた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、夙川のアパートメントの独身部屋をノックする音で私は眼ざめました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になって再びチタ子は私のアパートを訪れてきて、当分、私から離れたくないと言ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "安アパートの夜の雨の場面にももう少しの俳諧がほしいような気がした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしのアパートにいらっしゃいません？",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパートには、面白いお友達がたくさんいますわ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アパートに行けば、すばらしいプレイがあるのですか？",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　アパートの、前田さんの部屋には、三十歳をとうに越えて、やはりどうにも、まともでない感じの女が二人、あそびに来ていた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦になり、細君と女児を、細君のその実家にあずけ、かれは単身、東京に乗り込み、郊外のアパートの一部屋を借り、そこはもうただ、寝るだけのところ、抜け目なく四方八方を飛び歩いて、しこたま、もうけた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進　（四）　キヌ子のアパートは、世田谷方面にあって、朝はれいの、かつぎの商売に出るので、午後二時以後なら、たいていひまだという。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、電話の番号帳により、キヌ子のアパートの所番地を調べ、ウイスキイ一本とピイナツを二袋だけ買い求め、腹がへったらキヌ子に何かおごらせてやろうという下心、そうしてウイスキイをがぶがぶ飲んで、酔いつぶれた振りをして寝てしまえば、あとは、こっちのものだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、田島は、世田谷のキヌ子のアパートを捜し当てた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い木造の陰気くさい二階建のアパートである。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大失敗の夜から、四、五日経ち、眼鏡も新調し、頬のはれも引いてから、彼は、とにかくキヌ子のアパートに電話をかけた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
