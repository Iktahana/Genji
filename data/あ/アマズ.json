        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘酢について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘酢という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘酢の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘酢が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘酢を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘酢について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘酢の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘酢の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘酢が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酢という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘酢という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘酢についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘酢を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘酢は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘酢について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘酢が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘酢は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘酢の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘酢は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘酢は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鱠は鯉の甘酢、この酢の加減伝授なりと。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く味噌汁、曰く甘酢、曰く椀盛、曰く焼物と。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時には、甲府行きの汽車にひかれて死ぬ事も賑やかな甘酢っぱい空想。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は冷たいその根を噛んでは甘酢つぱい汁を、チユウ／＼音をさして吸ふた。",
              "citation": {
                "source": "日記より",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの、腰掛に落着き、卓子に片肱でもたれかかり、甘酢の鶏肉をさかなに、温い真白な濁酒をあおっていると、俺はもう口を利くのも懶くなった。",
              "citation": {
                "source": "どぶろく幻想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰺の酢の物は三枚に卸して塩を振って塩の利いた時分に酢へ十分間ほど漬けて丁寧にすればそれを取出して皮を剥ぎ小骨を抜いて甘酢をかけて山葵を載せて出します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酢は煮きり味淋へ酢と塩とを加えて醤油を少し落したものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○鰺の姿鮓は小鰺を丸のまま中骨を抜き一塩になし半日ほど置きて一旦酢にて洗いたる後甘酢へ漬おき別に炊たての飯へ酢と塩と砂糖とを適宜に混ぜ堅く握りて前の鰺の腹へ入れ二、三時間押しをして食すなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生または塩漬けの数の子は、庖丁で斜めに薄く切ったものを、甘酢にしばらく漬けておいてもよいが、いや、そのほうがよいようでもあるが、干し数の子は、庖丁で切ると、どうも面白くないし、美味くもない。",
              "citation": {
                "source": "数の子は音を食うもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また薄塩を振り、甘酢を用い、甘酢作りとして食うのも、替り刺身として乙なものである。",
              "citation": {
                "source": "西園寺公の食道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生姜の味付けに甘酢に浸す家もあるが、江戸前としての苦労が足りない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ大根おろしでも甘酢にして、すり柚の入れ加減まで、和尚の注意も行き届いたものであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪に※きしめた、不思議な異香が、この女の甘酢っぱい体臭とカクテールになって、八五郎の官能をグイグイと揺ぶるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれだえ」「あたし」　女の声は甘酢ッぱく金太の好奇心をこそぐります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の物語本には、美人の異常な体臭や、分泌物のことも書いて居りますが、日本の文献にはあまり見当りません、併し存在することは疑いもない事実で、現に若い発育し切った少女や少年達が、一種言うに言われぬ煽情的な、甘酢っぱい体臭を持って居ることは、誰でも気の付いて居ることです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第二夜　匂う踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保十一年の晩春、十一代将軍家斉の治下で、江戸の風物は熟れた果物のように、甘酢ぱく頽廃し切った時のこと、私の為には流祖、人形師としては、古今の名人と言われた松本鯛六――一名大六｜雲鼎は、鑿一挺で大変なものを拵えてしまったのです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第六夜　人形の獄門",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男なら、笛はまずいが腕はたしかだ、化物なんか引っ捕えて甘酢で食べますよ、ヘッ、ヘッ、ところが、運が良いか悪いか、兵二郎は休んで太之助が行った」「市ガ谷の兵二郎なら俺も聴いたことのある名だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笛吹兵二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から、旅姿の娘に肩を貸して、同じ茶店の奧へ入つて來る、八五郎の甘酢ぱい顏といふものは――。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点菓物には限らぬがすべて旧式の代物ばかり、三十年代にはたいてい影を潜めたが、当時は別に苦情もいわず結構都人士のお口にかなって舌鼓を鳴らしたもので、甘酢っぱい言い草だがその頃の味を思うと、フルーツ全盛の現代は、真に恵まれたるかな。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのため紅い唇や、蜂蜜のように粘る手や、甘酢い髪の毛のにおいやらが、すぐ頭から去って、彼は、常の彼の身に回っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから……あの二人を殺して頂戴な」　ぽッとなった源六の耳朶へ、甘酢い息が薫りました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しんから憎々しそうにそう言って、また一つ頬張り、「ああまずい。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用があるなら唯今呼んでまいりましょうか」「いや、呼んじゃあまずい」と、半七は首を振った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "朴鳳錫　上げちゃあまずい。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣の浪人ものは、その体を見て、あまずっぱいような微笑を湛えたかと思うと、ほどなくこれも匆々として釣道具をおさめて、つないでおいた小舟へ飛び乗ると、自ら艪を押してさっさと南浜の方へ向けて漕ぎ出し、忽ち葦の間に隠れて影も形も見えません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは聞き物だ」「まず身分を考えるがいい」「うん、身分か、能役者よ」「観世宗家の一族ではないか」「ああまずそういったところだな」「観世宗家と来た日には、五流を通じて第一の家柄、楽頭職として大したものだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあまずあるがな、ほれ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのくらい色電気のながれた異国の暗黒街に、どういう過去をもつかしらぬが、ひとりの日本の淫売婦がたっている、むろん正常じゃないが、婬惨な、ダダ的な情欲がながれて、おれの脳神経をあまずっぱく刺戟した。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまずらとか蜂蜜とかも記録にあるのみで、まったくこれを知らぬ土地は少なくなかったのである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、その私が、ひょっとして往來で知合いの人に出逢った時、たといそれが心からの友達だったにしたところで、やっぱりそうした瞬間――つまり茫然自失の状態でいる瞬間に、その相手に近づきたくないばかりに、わざと避けるようにするのは、こりゃあまず自然の成行きじゃありませんか。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
