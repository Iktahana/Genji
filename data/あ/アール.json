            }
          ],
          "literary": [
            {
              "text": "自分よりは一つ年上の甥のＲと二人で高知から室戸岬まで往復四、五日の遠足をした。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥のＲが死んでからもう二十余年になるので当時の想い出を話し合う相手もなくなってしまった訳である。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でもキャフェ――Ｒが彼女の持場だった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時Ｒ研究所での仕事に聯関して金米糖の製法について色々知りたいと思っていたところへ、矢島理学士から、西鶴の『永代蔵』にその記事があるという注意を受けたので、早速岩波文庫でその条項を読んでみた。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私どもの狂はしいＢＡＲの生活が初まつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときには根津權現の境内やＢＡＲの卓の上で詩作をしたりした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのＲ・Ｍ・リルケ",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは少数の帝政派も日本に駆逐されてしまって新にバイカル湖畔から輸送された泥人形と、コーカサス遺族達によって世間は私に怠惰と、大陸的な新浪漫主義を沁みこましてしまった（将軍ＢＡＲでさえ農民と職工によって占領されてしまったのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――チタ子とは数日前、私が夙川の舞踊場の踊りの帰路を立寄ったＲ酒場で会ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金融界の乾の手輩としてＮ・Ｒ漁業権を背景として、政党と政党の対立に山師の貫祿を見せた彼も、内閣が更迭すると疑獄事件のうずのなかに、不治の病を発してしまった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓデパートに依頼された新衣裳と、Ｒ新聞に原稿を明朝までに書いて置かなくちゃならないの。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝当時自分の勤めていたＲ大学の事務室にちょっとした用があってはいって見ると、そこに見慣れぬ年取った禿頭のわりに背の低い西洋人が立っていて、書記のＳ氏と話をしていた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分よりは一つ年上の甥のＲが煙草を吸って白い煙を威勢よく両方の鼻の孔から出すのが珍しく羨ましくなったものらしい。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒのつけた雑誌の名前を繰り返し繰り返し喜び、それと定まるまでの苦心を滑稽化して笑いました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日前ＲやＡや二三人でその美しい花を見、マロニエという花じゃないかなど云い合っていたのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもしこの場合の数 N(CCC) を現在の表中の火山の総数に等しいと取れば、これは結果のＲを少なくするほうの取り方であるからこれで得られたＲが大きければ、ほんとうはもっと大きい事になる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥海山はトリノウミと言ったらしい形跡があるので、これも入れるとするとＲはさらに四分の五倍だけに増すわけである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の場合に得たＲの価はいずれも１に対して相当多いものである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれにつづいて考えることは Rausu, Rausi, Rasyowa のアイヌ系のものから始めのＲを除き Lesson, Lassen からＬを取るとアソ型に接近する。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで本のほうは断念して、園芸好きのＲ研究所の門衛Ｕ君に教わって理研製殺虫剤ネオトンのやや濃度の大きい溶液で目的を達せられることを知った。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、歌舞伎俳優で有名なＩＲ氏である。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが悪魔の聖書とでもいったものでしょうか……これこそ世界中にタッタ一冊しかないと噂に聞いたシュレーカーのＢＯＯＫ　ＯＦ　ＤＥＶＩＬ　ＰＲＡＹＥＲ（外道祈祷書）かと思うと私は気が遠くなって、真夏の日中にガタガタ震え出したものでげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年は友人のＫと甥のＲと三人で同じ種崎のＴという未亡人の家の離れの二階を借りて一と夏を過ごした。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大網の尖端は、紐のように太く揺れて、アール・ヌーボー式の図案に見るような、印象の強い輪廓を作って、幾筋となく繋がっては、環を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "君にとつてみれば、すべて抽象的のものは興味がなく、ただ具象的のもの、レアールのものばかりが眞實なのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁にはルノアールの偽もの蜿蜒の画がかかっていた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "父　滋賀県神崎郡八日市町二四四山崎晴弘姉　神奈川県鎌倉市長谷通り二五六　　　マ・ソアール美容院山崎つた友達本郷区森川町九〇加藤郁子淀橋区戸塚町一ノ四〇四宮崎晴子",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "シー・ティー・アール・ウィルソンの膨張箱の実験が画期的であったゆえんはまず何よりも粒子の実在を質的に実証した点であった。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老翁はラルュウの前店主エドアール・ニニヨンである。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
