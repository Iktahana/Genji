      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "overreliance on others",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘ったれについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘ったれの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘ったれが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘ったれについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘ったれの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘ったれが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘ったれという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘ったれについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘ったれは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘ったれが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘ったれは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘ったれの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘ったれは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘ったれは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妹も、そのころは、痩せ衰えて、ちから無く、自分でも、うすうす、もうそんなに永くないことを知って来ている様子で、以前のように、あまり何かと私に無理難題いいつけて甘ったれるようなことが、なくなってしまって、私には、それがまた一そうつらいのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふられても恰好がつくなんてのは、てんからひとに甘ったれている証拠らしいが、――ま、落ちつく」　馬場がそう言ったのを私は忘れない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという甘ったれた精神であろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は、意識しないで僕に甘ったれ、僕のたいこもちを勤めていたのではないだろうか。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ったれるのもこのへんでよし給え。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いつもに似ずきびしくそう答えてから、急に持ちまえの甘ったれた口調にかえるのであった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎は狆の甘ったれた精神にむかむか憎悪を覚えたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿が甘ったれてだらだら書いた日記など、豚も食わない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ったれた芝居はやめろ。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一生ゆるされる筈はないのだし、また、許してもらおうなんて、虫のいい甘ったれた考えかたは捨てる事だ。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気にもかかわらず、親雀がスーッと来て叱るような顔をすると、喧嘩の嘴も、生意気な羽も、忽ちぐにゃぐにゃになって、チイチイ、赤坊声で甘ったれて、餌を頂戴と、口を張開いて胸毛をふわふわとして待構える。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は可羨しい、あんな大きななりをして、私に甘ったれますもの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな甘ったれた考えを持っていたんじゃあ、僕はここで予言してもいい。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘ったれていやがる。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あの、甘ったれた、女の描写。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この甘ったれ根性め。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふと甘ったれた声を、京吉は、「おれ知るもんか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜遅くなって新三郎が何かの拍子に眼を覚してみると、お滝の室でお滝が甘ったれたような声をして笑っているのが聞えた。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘラクレスの如くアキレスの如き巨漢が、甘ったれた口調で、私のことを「パパ、パパ」と呼ぶのだから、やり切れない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその態度のうちに相手をすっかり馬鹿にし切って鼻毛までも数え得るという冷静さと同時に、上っ面だけは甘ったれたのんびりした気分から鼻毛でも勘定して見ようかという閑日月が出て来る。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真そこから泣き、笑い、怒り、怨み、拗ね、甘ったれ、しなだれかかり、威し、すかし、あやなす事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と故とらしい京弁で甘ったれて、それから饒舌る。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい志賀直哉というひとの作品は、厳しいとか、何とか言われているようだが、それは嘘で、アマイ家庭生活、主人公の柄でもなく甘ったれた我儘、要するに、その容易で、楽しそうな生活が魅力になっているらしい。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　けれども君、僕がこんな甘ったれた古くさい薄のろの悩みを続けているうちにも、世界の風車はクルクルと眼にとまらぬ早さでまわっていたのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえきっと正井さんよ」「なあに岡だ」「じゃ賭けよ」　葉子はまるで少女のように甘ったれた口調でいって玄関に出て見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、そんなに甘ったれるんだろう、　大きななりをしてながら、　私より貴方は随分かさばって居るもの。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、雪だ」「ほんとだわ」と云ういせいの良い壮い男の声と、あまったれたような女の声が絡みあうなり、入口のガラス戸が敷居の上に重い軋りをさした。",
              "citation": {
                "source": "雪の夜の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪だわよ」　今のあまったれたような声がまた聞えて、それが私のいる食卓の前へ来た。",
              "citation": {
                "source": "雪の夜の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は軒先に立って面白い問答をききながら向いの雑貨店の店さきで小さい子供の母親の膝にもたれて何か云ってあまったれて居るのを自分もあまったれて居るような気になって望めて居る。",
              "citation": {
                "source": "大きい足袋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸首をかしげてあまったれる様な様子をして笑って見た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
