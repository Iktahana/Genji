[
  {
    "uuid": "28481cf3-e212-5952-9725-ff9997a4b7c7",
    "entry": "甘ったれ",
    "reading": {
      "primary": "あまったれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
