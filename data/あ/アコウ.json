[
  {
    "uuid": "a8c888e6-5380-51cf-8970-486f8f03302b",
    "entry": "亜綱",
    "reading": {
      "primary": "あこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
