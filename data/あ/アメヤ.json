        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日飴屋について考えている。",
              "source": "幻辞"
            },
            {
              "text": "飴屋という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は飴屋の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には飴屋が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "飴屋を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは飴屋について学習した。",
              "source": "幻辞"
            },
            {
              "text": "飴屋の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は飴屋の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では飴屋が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飴屋という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に飴屋という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では飴屋についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "飴屋を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると飴屋は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "飴屋について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では飴屋が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に飴屋は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により飴屋の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "飴屋は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に飴屋は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "土方ばかりじゃありません、飴屋もやったて云いますよ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日永に生欠伸で鼻の下を伸している、四辻の飴屋の前に、押競饅頭で集った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世渡やここに一｜人、飴屋の親仁は変な顔。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの飴屋が、喇叭も吹かず、太鼓をトンとも鳴らさぬかわりに、いつでも広告の比羅がわり、赤い涎掛をしている名代の菩薩でなお可笑い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思わず唐突に陽炎を吸って咽せた……飴屋の地蔵は堪らなそうに鼻を撫でる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　潮を踏んだ飴屋は老功。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と飴屋は頷くように頤杖を支いて言う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目にそれしゃとは見えながら、衣紋つき端正として、薄い胸に品のある、二十七八の婀娜なのが、玉のような頸を伸して、瞳を優しく横顔で、熟と飴屋の方を凝視めたのがある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六　お千世は、ぱっちりとした目を瞬いて、「飴屋の小父さんは、鶯が壊れたから、代りを拵えて、そして持って行けッて云ったんですよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飴屋が名代の涎掛を新しく見ながら、清葉は若い妓と一所に、お染久松がちょっと戸迷いをしたという姿で、火の番の羽目を出て、も一度仲通へ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁日はもう引汐の、黒い渚は掃いたように静まった河岸の側で、さかり場からはずッと下って、西河岸の袂あたりに、そこへ……その夜は、紅い涎掛の飴屋が出ていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、宮奴の装した白丁の下男が一人、露店の飴屋が張りそうな、渋の大傘を畳んで肩にかついだのが、法壇の根に顕れた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地口行燈があちこちに昼の影を浮かせて、飴屋、おでん屋の出たのが、再び、気のせいか、談話中の市場を髣髴した。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴屋か、豆屋か、団子を売るか、いずれにも荷が勝った……おでんを売るには乾いている、その看板がおもしろい。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の魂は飴屋の亭主を誘ひ出して、わが子がこゝに埋められてゐることを教へたのであらう。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二丁ばかり行くと、そこはもう場末の裏町で、おでん屋や、鼈甲飴屋の屋台が出ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側から畳のうえに薄い秋の西日が差し、裏町に飴屋の太鼓の音がしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の提灯、真赤な猿の面、飴屋一軒、犬も居らぬに、杢若が明かに店を張って、暗がりに、のほんとしている。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に、神主様も飴屋もあると同一でな。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘さした飴屋の前で、奥深い白木の階に、二人まず、帽子を手に取った時であった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……頭に樹の枝をかぶったり、かずらや枯葉を腰へ巻いたり……何の気もなしに、孫八ッて……その飴屋の爺さんが夜話するのを、一言……」　　　　（！",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも（ちょいとこさ）と言えばこないだ、小橋の上で、あの（ちょいとこさ）の飴屋に逢ったの。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷町で五十銭の半ズボン、松屋町の飴屋で飴五十銭。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、丹造は苦笑もせず、そして、だんだん訊くと、二、三、四、六、七の日が灸の日で、この日は無量寺の紋日だっせ、なんし、ここの灸と来たら……途端に想いだしたのは、当時丹造が住んでいた高津四番丁の飴屋の路地のはいり口に、ひっそりひとり二階借りしていたおかね婆さんのことだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千日堂」は煙草も売っているが、飴屋であった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても笑止や、垣根のそとで障子張るひと、椿の花が上に真赤に輝けば張られた障子もくわつと照る、烏勘左衛門、烏啼かせてくわつと吹くよかよか飴屋のちやるめらもみんなよしよし、粉嚢やつこらさと担いで、禿げた粉屋も飛んでゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんころ兵隊、赤胴衣、飴屋のお鉦で泣き出した。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造は松永町から、仲徒町へ掛けて、色々な買物をして廻る間に、又探るともなしに、飴屋の爺いさんの内へ壻入のあった事を慥めた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "南、島原半島の筑紫富士（温泉岳）と遥にあひたいし、小城と東松浦との郡界の上に聳え、有明海沿岸の平野を圧するものを天山――また、あめやまともいふ――となす。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あめやさん村山籌子きみ　には　ボンボン、きみ　には　チヨコレート、きみ　には　キヤンデイ、きみ　には　キヤラメルをあげよう、さあいくらでももつてゆきたまへ。",
              "citation": {
                "source": "あめやさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
