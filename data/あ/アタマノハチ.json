          ],
          "literary": [
            {
              "text": "小林は、秋山を放り出して、頭の鉢を抱えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "御好志はありがたかつたが、私は頭の鉢以来、とみに意気が沮喪して、早くＮ君の家へ引上げて、一寝入りしたかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓさんのお家へ行つて、こんどは頭の鉢どころか、頭の内容まで見破られ、ののしられるやうな結果になるのではあるまいかと思へばなほさら気が重かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の鉢にこだはる事は、やめた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……くさりかたびらも大切だ、千切れた所はつづるがいい……たすきの白布頭の鉢金、さあさあ人数だけこしらえろ……」　銅兵衛八方へ指図をする。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワッという悲鳴、ころがり落ちると、両手を上げて頭の鉢、かかえたまんまで動かない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒眼鏡が酔いつぶれる時に、きまってあげる『オダ』に依れば、彼はどうにもしようのないやくざ者で、人の女房と姦通して、おまけに亭主の頭の鉢を金テコで打破って、無期徒刑を喰ったのだが、御大典のおかげで、二度と出られる筈のなかったこの社会に舞い戻って来たという札つきの『金スジ』だった。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその拍子に頭の鉢がぽっくり落ちて、それといっしょに、ばらばらと金銀や宝石がこぼれ落ちました。",
              "citation": {
                "source": "鉢かつぎ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の鉢が大きく開き強い近眼の上に鼻がまた素晴らしく大きくて赤かったが、その奇怪な容貌のようにこのときの沖氏の踊りもひどく下手いというよりも初めから巧みに踊ろうとは考えてもいない踊りである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の鉢の開いた支配人は矢代の傍へいつもよく来て、どうですこの料理の味は？",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　塩野のそういうのに、口重な佐佐は少し云い渋ってもどもどしたが、人より頭の鉢の大きく開いた強い眉の下で、眼だけ鋭く反抗している微笑を泛べて云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　禿げた頭の鉢は大きく開き、耳の後ろから眼尻にかけて貫通した流弾の疵痕が残っている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、頭の鉢が低く斜めに殺げ、さらに眉のある上眼窩弓がたかい。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは頭の鉢巻きをかなぐりすてたとき、その斑々たる火傷のあとが現われたので見物人はまたまた喝采した。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「博士さまの、その頭の鉢巻きは、どうしたのけえ」「作十よ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガッ」という悲鳴、倒れたのは、真っ先に進んで来た段鼻の武士で、頭の鉢を右から斜、左の眼頭まで割り付けられた。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして余りに調子に乗って強く頭を打った為め遂々頭の鉢を割ったのであろう――それにしてもこのような狢などに迂濶に魅入られるのは不覚の至、俺の修行はまだ未熟だ」　阿信は口の中で呟いたが心の中は寂しかった。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二は静岡の魚問屋の坊ちゃんで、倉の陰で子守相手に「塵かくし」ばかり仕て居たほど気の弱い頭の鉢の開いた様な子だったが十九の年、中学を出ると一緒に、良吉の家へ養子になった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ったところが、何ぞと云っては痛み、そこが痛めば頭の鉢まで弾けそうになった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、頭の鉢が割れて、血がどくどく流れ出してるじゃありませんか。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげくに発狂して助役を放火犯人とよび頭の鉢をわられるに至ったと云われている。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ温和にして猫のごとく従順な君コン吉が、こんなふうにむやみに乱暴を働くというのは、多分、かねて神経衰弱の徴候をはらんでいた君の頭の鉢が、「変り咲き」の国花の花鉢に接触したとたん、交流した精神錯乱の過剰電気が、君の大脳の電極でスパークしたのに違いないよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠った菅笠を切り割って頭の鉢へ刃が止まる。",
              "citation": {
                "source": "村井長庵記名の傘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまた悲鳴、全く同じだ、宗三郎が二人を切り、体の固めの崩れたのを、狙い澄ました敵の一人、右手から掬って切ろうとし、寄ったところをスッポリと、頭の鉢を割られたのである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の二匹の家来は柱に頭をぶつけて頭の鉢をぶち割ってしまった。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の鉢はうんとおっぴらき、眼はびっくりしたようにキョロリとし、鼻は孫の手みたいにしゃくれている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よく気がそろうな」　頭の鉢のひらいた十歳ばかりのひねこびた子供で、舌で唇をペロリとやると、うわ眼で顎十郎の顔を見あげながら、「……金座の烏組といや、江戸の名物のひとつなんだが、お前、知らなかったのか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔し鎌倉へ遊びに行って、いわゆる五山なるものを、ぐるぐる尋ねて廻った時、たしか円覚寺の塔頭であったろう、やはりこんな風に石段をのそりのそりと登って行くと、門内から、黄な法衣を着た、頭の鉢の開いた坊主が出て来た。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
