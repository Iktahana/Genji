    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become stormy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒れるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒れるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒れるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒れるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒れるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒れるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒れるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒れるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒れるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒れるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒れるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒れるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒れるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒れるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒れるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒れるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒れるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒れるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒れるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自力だけを恃み、方法を尽したところで舌鼓を打つて「あゝうまい」と思ふ境地は、絶対の力を俟つてこそ得られるのであつて自力をばかり恃んで、舌鼓を無理に打つてみても舌が荒れるくらゐのものである。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯かる場合に稀薄にされた直観に気付くことなく、何とか直観濃厚の時節に於けるが如く活々としたいものだと思つて、新しい方法を講じようとして何かと議論すればする程、直観層は荒れるばかりである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間から丘にかけて一帯に耕地が固くなって荒れるがまゝにされている中に、その一隅の麦畑は青々と自分の出来ばえを誇っているようだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋からは、その沿線附近一帯をも、あまり儲けにならない麦を蒔かずに、荒れるがまゝに放って置く者もあった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ……此から海が荒れるぞ、と云ふ前觸れに、廂よりか背の高い、大な海坊主が、海から出て來て、町の中を歩行いて居てね……人が覘くと、蛇のやうに腰を曲げて、其の窓から睨返して、よくも見たな、よくも見たな、と云ふさうだから。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時か聞いた事がある、狂人と真人間は、唯時間の長短だけのもので、風が立つと時々波が荒れるように、誰でもちょいちょいは狂気だけれど、直ぐ、凪ぎになって、のたりのたりかなで済む。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈は消えるし、どしや降りだし、風はさわぐ、ねずみは荒れる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に――お互は失禮だけれど、破屋の天井を出てくる鼠は、忍ぶにしろ、荒れるにしろ、音を引ずつて囘るのであるが、こゝのは――立つて後脚で歩行くらしい。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊れ、踊れ、と踊り囘つて、水戸の大洗節で荒れるのが、殘らず、銀座のバーから來た、大女の一人藝で。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の住むのが気に入らないので荒れるのだろうと思いますが。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて段々船の進むほど、風は荒くなる、波は荒れる、船は搖れる。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、とんでもない……波は荒れるし。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも梅の手が次第に荒れるのを、お玉は気の毒がっている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「荒れるはずだよ。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に維新以後はその武家屋敷の取毀されたのもあり、あるいは住む人もない空屋敷となって荒れるがままに捨てて置かれるのもあるという始末で、さらに一層の寂寥を増していた。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この摩訶不思議な物語が荒れる天候から現れ出たかのよう――大時化の際の藻草が一面に押し寄せるがごとくで――そして今再び同じく退いていったかのよう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな船は、荒れる海の上をゆられゆられ、とぶように走りました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざあざあ、地の底を吹き荒れる風のような水の音。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ……これから海が荒れるぞ、と云う前触れに、廂よりか背の高い、大な海坊主が、海から出て来て、町の中を歩行いていてね……人が覘くと、蛇のように腰を曲げて、その窓から睨返して、よくも見たな、よくも見たな、と云うそうだから。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の位置までくると、シャツにチョッキ姿の屠手は、きわめて熟練したもので、どすと音がしたかと思うと、牝牛は荒れるようすもなく、わずかに頭を振るかとみるまに両膝を折って体をかがめるとひとしく横にころがってしまう。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭の端を捲くつて沿びせる埃の爲に髮の毛の荒れるのを酷く嫌つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は余り喰べると口中が荒れるからと注意されたけれど悉くたべて畢つた。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れに荒れる海上に、燈台の光をながむるほど、人の心を感傷的にするものはない。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いた時の作、山がつの庵に焚けるしばしばも言問ひ来なむ恋ふる里人　冬になって雪の降り荒れる日に灰色の空をながめながら源氏は琴を弾いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も碌々に掃除する者もないので、座敷も庭も荒れるがままに捨てて置かれて、化物屋敷というには全くふさわしいような廃宅の姿になった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き荒れる風すらがそのためにさえぎりとめられて、船の周囲には気味の悪い静かさが満ち広がった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはすさまじく蒙古風の吹荒れる砂漠の中で。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の荒れる響がそれと左側にきこえて、昼ならば磯に砕ける波の白いのも見えるであらうと思はれたが、暫くすると灯の影が沢山に遠くにあらはれて、それが見る／＼うちに近く近くなつて行つた。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞くと、その荒れるうちでも今日のなど最も強いものであったそうだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「こんなに荒れると、本当に自動車はお危のうございますわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
