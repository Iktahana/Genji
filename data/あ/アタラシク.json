        "examples": {
          "standard": [
            {
              "text": "毎日、新しくについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の新しく戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "新しくの原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "新しくという言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは新しくについて学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "新しくの治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "新しくに関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは新しくを目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での新しくは見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、新しくは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "新しくは日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な新しくを見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「新しく」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
