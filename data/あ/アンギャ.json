[
  {
    "uuid": "d2cc3c6f-5173-5e94-a876-45ef43b6eaa6",
    "entry": "行脚",
    "reading": {
      "primary": "あんぎゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
