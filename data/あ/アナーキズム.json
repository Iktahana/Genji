        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナーキズムについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナーキズムの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナーキズムが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナーキズムについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナーキズムの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナーキズムが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナーキズムという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナーキズムについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナーキズムは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナーキズムが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナーキズムは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナーキズムの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキズムは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナーキズムは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こういう道義的アナーキズム時代における人の品行は時代の背景を斟酌して考慮しなければならない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は江戸末季の廃頽的空気に十分浸って来た上に、更にこういう道義的アナーキズム時代に遭逢したのだから、さらぬだに世間の毀誉褒貶を何の糸瓜とも思わぬ放縦な性分に江戸の通人を一串した風流情事の慾望と、淫蕩な田舎侍に荒らされた東京の廃頽気分とが結び付いて勢い女道楽とならざるを得なかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、文学の領域でアナーキズムとマルクシズムとの論争が旺んであった時代は、プロレタリア文学史のことで最も紛糾した頁をなしているのであろうと思うが、それは性質において今日プロレタリア文学内に交流し渦まきその頭や尻尾が見えつかくれつしている諸要素とは大いに違っていたと思う。",
              "citation": {
                "source": "プロ文学の中間報告",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中はアナーキズムとイタリア語との研究をやる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキズムは、クロポトキンの『相互扶助』と、ルクリュの『進化と革命とアナーキズムの理想』というのを読み終った。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はクラーウの『アナーキズムの目的とその実行方法』というのを読んでいる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文学には無産派文学運動が擡頭していて、アナーキズムとボルシェビズムの対立のはっきりしはじめた時代であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第三巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はアナーキズムとボルシェビズムとの理論闘争の時を通じてアナーキズムの陣営にのこり、その後、プロレタリア文学運動に沿って歩みながら、常に、『ナップ』とは対比的な立場に自身をおいて、「独特」さを示そうとしている婦人作家として経て来た。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女よりもひと昔まえの一九二〇年代の後半にアナーキズムの渾沌の裡から生れ出た平林たい子が、「施療室にて」から今日までに移って来た足どり。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『青鞜』のグループと『白樺』とが若い世代の動きとして共通した脈絡をもち得なかったことには、末期の『青鞜』に『平民新聞』廃刊後のアナーキズムの色が流入したからというばかりでない内奥の理由もある。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキズムの指導者として、クロポトキンの「革命家の思い出」ロマン・ローランの「民衆芸術論」の翻訳などのあった大杉栄がその妻伊藤野枝と幼い甥の宗一と一緒に、憲兵隊につれてゆかれ甘粕憲兵大尉とその部下によって縊殺された。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前後のいきさつは河上肇の自伝の中にも興味ふかく物語られているが、この頃から、従来ひとくちに「無産階級運動」と云われていた解放運動のなかで、アナーキズムとマルクシズムとの対立がはっきりとして来た。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想的雑居の状態で共同戦線をもっていた初期のプロレタリア芸術運動は、発展につれて基本的な階級の観念とその闘争の具体性を把握しはじめ、アナーキズムと訣別することとなった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「交換手見習」として上京してから二三年のうちに、いつしかアナーキズムの流れにまきこまれ朝鮮や満州を放浪した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "解放運動の全線にわたって、アナーキズムとコンムニズムとの区別が明確にされていない時代であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第六巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二三年と云えば日本では、無産階級解放運動の初期で、アナーキズムとボルシェビズムとの対立の時代であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第二巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキスト出身で著名な婦人作家で、その才能の素質と妻としておかれている偽瞞的な環境のためにアナーキズムから社会観を本質的に高められることができず、労働者弾圧にも動員される右翼の暴力団の生活に近接する機会をもつようになって、その描きてとしてあらわれているひともある。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "性慾アナーキズム貞操共産主義も鼻について来ましたからねやつぱり私の心臓の中にも善魔がゐるんですね。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキズムの主導者となったクロポトキンにふさわしい話だ。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはボルシェヴィズム的ではなく、どこまでもアナーキズム的だ。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルシェヴィズムは陰鬱だが、アナーキズムは朗かである。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治嫌いを公言してる私が、特殊な自治とか特殊なアナーキズムとかを夢想してることは、彼から見れば可笑しかったであろう。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく平凡な好人物で、怠惰が唯一の美徳であって、そのアナーキズム的な思想も、常識的空想の一つの現われに過ぎなかったのではなかろうか。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この重税に反抗して芸術界の ANARCHISMUS（アナーキズム）が起らないとも限るまい。",
              "citation": {
                "source": "緑色の太陽",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当はアナーキズムが好きなんだよ。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のアナーキズムは辻潤のダダに通じていて、統一がない。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私個人としては、先ず、大体に、アナーキズムが、やや理想に近い社会形態であると考えている。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキズムの理想社会というものは、空想や理想の上には有り得ても、実際としては先ず実現の見込みはない。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
