[
  {
    "uuid": "5d23773c-e4ed-5ba2-ae55-9b687bc4eb3b",
    "entry": "荒っぽい",
    "reading": {
      "primary": "あらっぽい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wild",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒っぽいについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒っぽいの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒っぽいが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒っぽいについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒っぽいの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒っぽいが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒っぽいという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒っぽいについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒っぽいは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒っぽいが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒っぽいは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒っぽいの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒っぽいは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒っぽいは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "藤吉はあべこべに云いまくられて、そのくやしまぎれに、お前が禁断のむらさき鯉を売り込んで、荒っぽい銭儲けをしているということを俺が一と言しゃべったら、ここの家にぺんぺん草が生えるだろうとか何とか嚇し文句をならべて立ち去っても、宇三郎はおどろかない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、豪放な、荒っぽい兵士がとび出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒っぽい、無茶な仕事が飯より好きな連中だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒っぽい、活気のある男が、いつか、蒼白に坑夫病た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが妻木君の喰い方の荒っぽいのには又｜流石の私も舌を捲かれた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分の仕事を勉強しろ……」　そういう私の荒っぽい声の反響を聞いているうちに私は、自分の眼がしらがズウーと熱くなって来るように思った……何故だかわからないまま……しかし外の私はイヨイヨ冷静になったらしく、その薄い唇の隅に微な冷笑を浮かべたのであった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち荒っぽい大きな歓楽を避けてさえいれば、自然また大きな悲哀もやって来ないのだ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに大きな悲哀があとでやって来てもいい、荒っぽい大きな歓楽が欲しいと内心あせってはいても、自分の現在のよろこびたるや、お客とむだ事を言い合い、お客の酒を飲む事だけでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた東京へ出て来て、荒っぽいすさんだ生活に、身を投じなければならなかった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく気がるに、またも二、三円を乱費して、ふと姉を思い、荒っぽい嗚咽が、ぐしゃっと鼻にからんで来て、三十前後の新内流しをつかまえ、かれにお酒をすすめたが、かれ、客の若さに油断して、ウイスキイがいいとぜいたく言った。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵の眼をもってそれらを探し出すのではなく、詩人の心をもって（恐ろしく荒っぽい詩人だが）彼に触れるすべてを温め、（ときに焦がす惧れもないではない。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "持参したインド土産らしい布地などをガルスワーシー夫人に手渡しながら不平の交った荒っぽい賑やかさを残して客間を引き上げて行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在年寄夫婦が商売しているのだが、士地柄客種が柄悪く荒っぽいので、おとなしい女中はつづかず、といって気性の強い女はこちらがなめられるといった按配で、ほとほと人手に困って売りに出したのだというから、掛け合うと、存外安く造作から道具一切附き三百五十円で譲ってくれた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取の無い率直さが荒っぽい土地の人気に投じたらしい。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経を逆撫する荒っぽい残酷さが、何時も私の心を押しつける。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中と健児社の箱田｜六輔氏等が落合って大事を密議している席上に、奈良原到以下十四五を頭くらいの少年連が十六名ズラリと列席していたというのだから、その当時の密議なるものが如何に荒っぽいものであったかがわかる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には白い雲が飛んで荒っぽい秋風が路の下の方の林に音を立てて吹いていた。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在年寄夫婦が商売しているのだが、土地柄、客種が柄悪く荒っぽいので、大人しい女子衆は続かず、といって気性の強い女はこちらがなめられるといった按配で、ほとほと人手に困って売りに出したのだというから、掛け合うと、案外安く造作から道具｜一切附き三百五十円で譲ってくれた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「荒っぽいやつだ。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、荒っぽい男の一団につかまえられて、しばらく無遠慮にゆすられた。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに詰らない、」「いえ、ところが私にゃあ不可ません、お嬢さんなんざ何でも分っていなさるんだから、はじめから幾らも皆伝になられます、荒っぽい気をお出しなすっちゃあ不可ませんぜ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のところで使っているロイドという若い番頭が、去年の夏頃から港崎町の岩亀へむやみに遊びに行って、ずいぶん荒っぽい金を使うらしいが、商館の方で渡す給金だけじゃあとても足りる筈がない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとに限らず、ここの助手さんたちは、少し荒っぽいところがあるけれども、本当は気持のやさしい、いいひとばかりのようだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝口坑では、いつでも死傷者に対して炭坑独特の荒っぽい検屍を、救護室で行うことになっていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体馬琴は史筆｜椽大を以て称されているが、やはり大まかな荒っぽい軍記物よりは情緒細やかな人情物に長じておる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご高家仕えのご用人さんだから荒っぽい痛み吟味もできねえし、どうしたもんだろうとひと汗絞るところだったが、万事がおあつらえ向きだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、出がけからいやいいのに、草香流が湯気をたてているのなんのと荒っぽいことをおっしゃったんで、あっしゃてっきりおどし文句の本尊の根城にでも乗り込むんだろうと肝を冷やしていたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにそれは、どうにもならぬ荒っぽい洪水のような腕力だった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去何百年の太平に依って洗練された、極めてデリケートな彼等の趣味と生活とは、もう見る見る中に、新しい荒っぽい新東京人の生活と趣味に圧倒されてしまいつつある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "………連載一回分（二千字前後）欠………東京の犯罪地帯　東京市中でほかの犯罪はみんな殖えているのに、殺人傷害だの、強盗だのいう荒っぽいところが枕を並べて減少しているのも面白い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
