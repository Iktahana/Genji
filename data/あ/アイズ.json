[
  {
    "uuid": "500e20d5-f3b0-5959-ae03-8f34797b72b1",
    "entry": "合図",
    "reading": {
      "primary": "あいず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
