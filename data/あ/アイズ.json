          "literary": [
            {
              "text": "「フアゾムレス　アイズ！",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカマのロクを通して矢萩から大金をせしめていた俺は、ここで、アイズキ（挨拶）をしなくちゃならぬところだが、沙発に泣き伏している照子を見たことが俺の口をつぐませた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
