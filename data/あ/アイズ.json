    "definitions": [
      {
        "index": 1,
        "gloss": "sign",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、合図は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは合図が重要です。",
              "source": "幻辞"
            },
            {
              "text": "合図に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では合図が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で合図について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から合図についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では合図について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では合図が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では合図が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に合図は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において合図は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に合図を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に合図をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で合図が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、合図の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は合図を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は合図に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で合図について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から合図は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは合図を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "間もなく駆け来る列車の一隅に座を構えて煙草取り出せばベルの音｜忙しく合図の呼子。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手を挙げて合図をして「居た居た、あそこに」と云われても、どこにどんな鳥がいるのか明き盲の自分にはちっとも見えない。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気紛れに、そこへ根を卸したような五葉松は、仰向けに川の方へ身を反らして、水と頷ずき合って、何か合図をしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の坑夫、――秋山も小林も混って――は、各々口にバットを喞えて、見張からの合図を待っていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年も、殆んど毎日のように、導火線に火を移す彼等であっても、その合図を待つ時には緊張しない訳には行かなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ東国の方へ遺った、まだ見ぬ山に棲める筈の姉と弟の方からは、翁のこれほどの血の愛の合図をもってしても何の感応道交も無かった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手を振って、尾いて来ちゃいけないと合図すると、彼は笑って素直に再び酒を呑み出した。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らない草穂が静かにゆらぎ、少し強い風が来る時は、どこかで何かが合図をしてでもいるように、一面の草が、それ来たっとみなからだを伏せて避けました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙の方ではその合図の火影を認めた瞬間にぴたりと水の流出を止めて、そうして器の口に当る区分の文句を読むという寸法である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が又「アカン」と眼で合図する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、Ｔ「伝八つあんと仰しゃるんでしょう」　棚倉さてはと思って門弟に合図する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵がソレッと合図した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張りの者が、ソレ来たと合図した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅大広間の次の室には　ふんぞり七兵衛の率いる捕方が合図如何と待ちかまえる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "合図をすると、児分が二人現れる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、彼は、診断室を出て行くように、合図に手を動かした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はゆさ／＼崩れそうにゆれる薪の上を歩いている宗保に手で合図をした。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が賛美歌の番号を知らすと、堂のすみから、ものものしい重い、低い調子でオルガンの一くさり、それを合図に一同が立つ。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」先生、この時、チョイと目を転じて、メートルグラスの番人を見た、これはおかわりの合図。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに合図するのかまねをするのか、それとも外界の物理的化学的条件に応じて機械的に反応しているのか、どちらだか自分にはわからない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうおしまいという合図らしい。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は四ツを合図に店を閉めて寝てしまったから、よくは知らないと寅次は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今までに幾人も通ったが、北の方からきこえて来るその足音がどうも待っているものであるらしく直覚されたので、半七は咳きの合図をすると、塀の横手からもその返事があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　イワンは、うしろの馭者に何か合図をした。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長が三四歩あとすざって、合図に手をあげた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで、何かの合図が聞えたものゝようだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　井村は、タエに、眼で合図をして、何気ない風に九番坑に這入った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "５４＝玄関　右門下りて来て門前に待たせてある伝六に合図する。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "54＝玄関　右門下りて来て門前に待たせてある伝六に合図する。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の始まる前の合図にガタンガタンと板の間をたたくような音をさせるのはドイツのと違っていて滑稽な感じがしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
