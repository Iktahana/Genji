    "definitions": [
      {
        "index": 1,
        "gloss": "rowdy fellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒くれ男について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒くれ男の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒くれ男が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒くれ男について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒くれ男の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒くれ男が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒くれ男という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒くれ男についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒くれ男は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒くれ男が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒くれ男は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒くれ男の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒くれ男は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒くれ男は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そんなこと自由ぢやないの……」「えゝ、さういへばさうだけど、自由なんて引つぱり出すと却つて不自由だ、怒鳴りたい時は怒鳴るが好いつてのが自由でせう……」「ぢや若し、隣の人達が女だから好いけれど、荒くれ男共だつたら如何するの」　低声で言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つのランプの光は赤くかすかに、陰は暗くあまねくこのすすけた土間をこめて、荒くれ男のあから顔だけが右に左に動いている。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌脱の荒くれ男の影鬼の如く映れるあり、乱髪の酌婦の頭の夜叉の如く映るかと思へば、床も落つると思はるゝ音が為て、ドツとばかり笑声の起る家もあり。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟夫や樵夫の荒くれ男ですら之を魔所と唱えて、昼も行悩む三方崩れの悪所絶所を、女の弱い足で夜中に越そうと云うのは、余りに無謀で大胆であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月代の伸びた荒くれ男どもは本職の渡世人らしく、頬冠りや向う鉢巻で群がっている穢苦しい老若は、近郷近在の百姓や地主らしい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒たちは荒くれ男、だが中隊長の体に手をかけるやうな、勇敢な男は一人もゐない、ズラリと兵士たちをならべてをいて中隊長は兵士の額にむかつて訓示をしそれが終ると、くるりと廻れ右させて、今度は兵士の後頭部に命令した、すると彼等は、しやにむに走つた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの屋敷の内に女というのは、台所のお仙一人で、そのほかはみな犬の肉でも喰いそうな荒くれ男ばかりである。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒暑と波濤と力わざと荒くれ男らとの交わりは君の筋骨と度胸とを鉄のように鍛え上げた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小波は小皺の寄った今日でも秀麗閑雅を偲ばせる美男だから、少年時代はさこそと推量られるので、「五月鯉」の第一回に梅若丸然とした美少年が荒くれ男に組敷かれる処があるのも大方小波の好か稚児時代の自叙伝の一節だろうと想像する。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閤秀吉が自分の好みから、また政略上の方便から煽り立てた茶の湯の流行は、激情と反抗心との持主である奥州の荒くれ男をも捉えて、利休の門に弟子入をさせ、時おりは為う事なさの退屈しのぎから、茶器弄りをさえさせるようになったのだった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中から、三人の荒くれ男が七八ツ位から十二三位の美しい子供を都合十三人、猿轡を噛まして後手に縛ったまま引きずり出して、砂原の上に坐らせた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒くれ男は三人共、不意に奇妙な子供が出て来た上に、こんな大胆な事を云ったので、驚いて顔を見合わせた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう荒くれ男が青くなるのは、見ている者には実に愉快なものだ。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺青師は無数の細い針を束ねた一種の簓のようなものを用いて、しずかに叮嚀に人の肉を突き刺して、これに墨や朱をだん／＼に注して行くのですが、朱を注すのは非常の痛みで、大抵の強情我慢の荒くれ男でも、朱入りの刺青を仕上げるまでには、鬼の眼から涙を幾たびか零すと云います。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "警務班長のマットン中佐が先頭にたち、あとにはヨコハマ・ジャックなどの荒くれ男が四、五人つきしたがい、その一行の真中には、半裸体のまま両手に手錠をかけられたわが勇士、杉田二等水兵がひったてられているのだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んで見ると、筆者が日曜日にハドソン河畔を散歩していると、ニューヨーク側から一艘のボートがこちらの河岸へ漕れて来たが、それには六人の荒くれ男と一人の若い女が乗っていた。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二三の荒くれ男がだまって鷲づかみにしてしまやあ、それっきりだろうじゃないか。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカラマゾフなどを読んでも、裁判官の前に立つ荒くれ男のミチャが、かえって説教者としての威力を持ってるところなどに動かされます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々とした「のっぺい」（土の名）の畠の側を進んでまいりますと、一人の荒くれ男が、汗雫になって、傍目もふらずに畠を打っておりました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾名チューブッフことガルール、渾名フィヌイユことマロン、渾名クールドースことシャブルトンという名うての悪漢と、その手下の破戸漢七人、都合十人の荒くれ男が、密閉された、真暗な船艙の中で、穏かならぬ語気で何かぶつぶつ論争をやりだした。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、天井からぶら垂ったカンテラに照されて、十人ほどの荒くれ男が正体もなく転がっていた。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の下では三人の荒くれ男が、三頭の牛に、瓦斯タンクのやうに偉大な眞つ黒な蒸汽氣罐を牽かして來て、そこでこの急坂を奔け上る爲に、眞劒になつて牛を勵ましてゐる處だつた。",
              "citation": {
                "source": "烈日",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女護の島へ十人も荒くれ男を泊めるんで、今朝から二人がテンテコ舞をしてるやおまへんか。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は思わず喝采をしたものの、流石の荒くれ男共もこうしたお作のズバリとした思付きに、スッカリ荒胆を奪られてしまって、その次の瞬間には、水を打ったようにシンとして終ったのであった。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、それをどうかしに来たらしい荒くれ男が三四人、平気で冗談を云い合いながら葉巻を吹かしているじゃないの……あんまり恐ろしい、不思議な事なので、妾は、あと先を考える事も何も出来やしなかったわ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうしたら又……釜山の南浜から船に乗って、絶影島を廻ると間もなく、荒くれ男を大勢載せた、正体のわからない発動機船が一艘、どこからか出て来て、父さんを捉まえて踏んだり蹴ったりしたから、ウチもその中の一人の向う脛に噛み付いてやったら、一気に海へ蹴込まれてしもうた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを二三度も石炭籠を担いで往復してから急に上甲板の冷めたい空気に触れると、眼がクラクラして、足がよろめいて、鬼のような荒くれ男が他愛なくブッ倒おれるんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺の頑丈な戸口の外には出入する所のない、十畳敷ばかりのガランとした刑事部屋は、二方の窓から受入れる光線で割合に明るいが、誰でもこの部屋に入れられて、物凄い眼つきの荒くれ男に取巻かれて、鋭い質問を浴せかけられたら、怯じ恐れないものはないであろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
