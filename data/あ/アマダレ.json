          ],
          "literary": [
            {
              "text": "軒から落ちるあまだれがすさまじくあたりにきこえて、サツと風が物凄く樹を鳴らした。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が溶けないから、あまだれが決して落ちない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日かなり強い雨の音とあまだれの雨に包まれ、さわがしい水すだれの中に入って居るような心持。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からの雨が雪になるかと思ったが、寒さがきびしいばかりで雪になるようすもなく、雨落の石を打つあまだれの音が、気のめいるような陰気な調子で、低く、ゆっくりと呟いているのが聞えた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
