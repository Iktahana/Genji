[
  {
    "uuid": "8b2a42c1-85e0-5d4d-8648-86d6469f2448",
    "entry": "アンテナ",
    "reading": {
      "primary": "アンテナ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "antenna",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンテナについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンテナという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンテナの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンテナが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンテナを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンテナについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンテナの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンテナの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンテナが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンテナという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンテナという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンテナについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンテナを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンテナは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンテナについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンテナが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンテナは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンテナの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンテナは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンテナは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第二に前述の発生器で生じた波動を空中に伝える物は、アンテナと称えて高い柱に張った針金である。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来はこのアンテナより発する電波はいずれの方向にも拡がって行くので一定の目的地の方角のみに送る事は出来難かった。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "反射鏡など使っても駄目であったが、近頃マルコニが作ったアンテナは従来の物のごとく垂直に立てず却って大部分を水平に張ったもので、これを用うればほとんど一定の方向にのみ波を送る事が出来るそうである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもう一つの方法はブラウン氏の発明で、これは三本の垂直なアンテナから同時に波を送り、三つの波を互いに干渉させ、その結果ある方向に最も強い波の起るようにしたものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に受信地で電波を受取るにはやはり前述と同様なアンテナを用うるのであるが、これも前のマルコニ式の水平なのを用うればいずれの方角から波が来るかという判断が出来るそうである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると遠くから来た電波がアンテナからこのデテクターに伝わると同時に白金の間の抵抗が減じ、従って電流が強くなって電話器で音を発する。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち発信器の方では不断に規則正しい波を送りそのアンテナに電話の送話器を接続し、受信器には前述のエレクトロリチック・デテクターを用うればよいのである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信器のアンテナに電波が来れば急速な交番電流が起る、これを白熱灯デテクターおよび電流計あるいは電話の受話器に接続すれば、ごく微弱な電波でも感じるから遠距離の通信には都合のよいものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は十八トンでアンテナを張った帆柱が低かったにもかかわらず四マイルの距離で通話自在であったという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしラジオ商や百貨店ラジオ係が自分の店でそれを試験する場合には、高い長いアンテナを使い、完全なアースを使って試験するのであるから、感度の低い機械でもちゃんと立派に聞こえ、何不足もない機械としか見えないであろう。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくアンテナを拡張し、完全なアースをすれば聞こえるであろうと思われたが、それがおっくうであるのと、もう一つは、前述のような理由から元来熱心でないためとでついついそのままに放棄してあった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが近頃になって、どうかした機会に、近所のラジオ屋に来て見てもらったら、このラジオ屋さんはちゃんと心得ていてさっそく水道栓へアースを引っぱって、アンテナを天井の廻りに引延ばして、ともかくも音だけは旧通りに聞こえるようにした。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアースやアンテナを引っぱり廻わす事なしに役に立つ感度の好い機械としての価値はもう永久に失われたようである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆破された無電局の、天に突きさゝるようなアンテナ柱は、半分どころからへし折れ、傾き、倒れかゝっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "観測器械を入れたテントのそばには無線電信受信用のアンテナが張ってある。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな行きがかりで自然ラディオというものに対する一種の恐れをいだくようになってみると、あの家々の屋上に引き散らしたアンテナに対しても同情しにくい心持ちになる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンテナをつけたＭ・Ｐのジープが通ったあと、三条河原町のゴーストップの信号が青に変った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ろ、屋根を、雲も、星座も、　　アンテナで包囲されてる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、その触覚のアンテナは聴く、　ＪＯＡＫ、こちらは東京放送局であります。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなアンテナを架けて、「ＪＯＡＫ、こちらは東京放送局であります。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてラジオのアンテナの竿がその屋根屋根から林立していた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲に於いてはナチスの全滅、東洋に於いては比島決戦についで沖縄決戦、米機の日本内地爆撃、僕には兵隊の作戦の事などほとんど何もわからぬが、しかし、僕には若い敏感なアンテナがある。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアンテナは信頼できる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国の憂鬱、危機、すぐにこのアンテナは、ぴりりと感ずる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの初夏の頃から、僕のこの若いアンテナは、嘗つてなかったほどの大きな海嘯の音を感知し、震えた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま屋根の斜面を馳け降りて、闇の庭の舗道に飛び降りて、死んでしまいたいような衝動に馳られましたが、下の方から非常梯子を登って来るオドロオドロしい足音を耳にしますとまた、気を取り直しまして、直ぐ足の下から引っぱって在るラジオのアンテナ伝いに、隣りの棟の二階の屋根に降り立ちました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の上には二本のアンテナと、短い煙突が一本と、換気筒が五本数えられたが、一見するとアパート風の建物のやうで船とも見えなかつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると風間老人が、「むこうの鉄柱からこの玻璃窓の前の手すりへはったアンテナが、大石のために切れてしまったからです……で、それから、わたしは小使を起そうと思って下へ、三田村君は現場へと、すぐに別れました。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから三田村さんは、アンテナを修繕して、少しも早く通信を始めて下さい。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたし達を見ると、これからアンテナの取付工事をするのだが、失礼ながらちょっと手伝っていただきたい、と申し出た。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
