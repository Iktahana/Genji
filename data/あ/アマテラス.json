        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日天照について考えている。",
              "source": "幻辞"
            },
            {
              "text": "天照という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は天照の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には天照が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "天照を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは天照について学習した。",
              "source": "幻辞"
            },
            {
              "text": "天照の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は天照の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では天照が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "天照という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に天照という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では天照についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "天照を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると天照は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "天照について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では天照が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に天照は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により天照の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "天照は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に天照は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煤けた天照大神と書いた掛物の床の間の前には小さなランプがついて二｜枚の木綿の座布団がさびしく敷いてあった。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝ちさびに天照大御神の営田の畔離ち溝埋め、また大嘗きこしめす殿に屎まり散らしき」というのも噴火による降砂降灰の災害を暗示するようにも見られる。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この主婦の亡夫は南洋通いの帆船の船員であったそうで、アイボリー・ナッツと称する珍しい南洋産の木の実が天照皇大神の掛物のかかった床の間の置物に飾ってあった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　二階は上がり口が三畳で、押入れに置床のある次ぎの六畳に古い箪笥があり、父は敬神家とみえて天照皇大神の幅がかかっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇統や、天照らす神の御裔、代々坐しき、日向すでに。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天照らす大御神、皇祖、皇祖かくぞ、　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は天照皇太神宮と、阿弥陀仏と、我が皇室と、この三体を一つに祭って、いやその祭壇を私の家庭にこさえたのです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから、どうしても天照大御神を中心に、お祭りするのがほんとうでないかと思う。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊弉諾神は、この女神さまに天照大神というお名前をおつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊弉諾神はこのお三方をご覧になって、「わしもこれまでいくたりも子供を生んだが、とうとうしまいに、一等よい子供を生んだ」と、それはそれは大喜びををなさいまして、さっそく玉の首飾りをおはずしになって、それをさらさらとゆり鳴らしながら、天照大神におあげになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩屋一　天照大神と、二番目の弟さまの月読命とは、おとうさまのご命令に従って、それぞれ大空と夜の国とをお治めになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、その響きにびっくりなすって、「弟があんな勢いでのぼって来るのは、必ずただごとではない。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、「はじめに生まれた三人の女神は、おまえの剣からできたのだから、おまえの子だ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、大空の神々たちは、たいそうお困りになりまして、みんなで安河原という、空の上の河原に集まって、どうかして、天照大神に岩屋からお出ましになっていただく方法はあるまいかといっしょうけんめいに、相談をなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、そのたいそうなさわぎの声をお聞きになると、何ごとが起こったのかとおぼしめして、岩屋の戸を細めにあけて、そっとのぞいてご覧になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命は、「じつはおれは天照大神の同じ腹の弟で、たった今、大空からおりて来たばかりだ」と、うちあけてお名まえをおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剣はのちに天照大神へご献上になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きじのお使い一　そのうちに大空の天照大神は、お子さまの天忍穂耳命に向かって、「下界に見える、あの豊葦原水穂国は、おまえが治めるべき国である」とおっしゃって、すぐにくだって行くように、お言いつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その当たった矢が名鳴女の胸を突き通して、さかさまに大空の上まではねあがって、天安河の河原においでになる、天照大神と高皇産霊神とのおそばへ落ちました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　天照大神は、そんなわけで、また神々に向かって、こんどというこんどはだれを遣わしたらよいかとご相談をなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしたちは天照大神と高皇産霊神とのご命令で、わざわざお使いにまいったのである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天照大神と高皇産霊神に、すっかりこのことを、くわしく奏上いたしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠沙のお宮一　天照大神と高皇産霊神とは、あれほど乱れさわいでいた下界を、建御雷神たちが、ちゃんとこちらのものにして帰りましたので、さっそく天忍穂耳命をお召しになって、「葦原の中つ国はもはやすっかり平らいだ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神と高皇産霊神とはそれをご覧になりますと、急いで天宇受女命をお呼びになって、「そちは女でこそあれ、どんな荒くれた神に向かいあっても、びくともしない神だから、だれをもおいておまえを遣すのである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夢の中で、天照大神と高皇産霊神のお二方が、建御雷神をおめしになりまして、葦原中国は、今しきりに乱れ騒いでいる。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で皇女、豊※入媛が、はじめて伊勢の天照大神のお社に仕えて、そのお祭りをお司りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまは、やはり皇后のお口を通して、「これはすべて天照大神のおぼしめしである。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまてらすおおみかみの頃には、こんなに人もあまってはいなかったのだろう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまてらすおおみかみさまは裸で岩戸からのぞいておいでになる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
