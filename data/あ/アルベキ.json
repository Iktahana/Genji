        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有るべきについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有るべきという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有るべきの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有るべきが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有るべきを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有るべきについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有るべきの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有るべきの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有るべきが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有るべきという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有るべきという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有るべきについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有るべきを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有るべきは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有るべきについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有るべきが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有るべきは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有るべきの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有るべきは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有るべきは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども僕にはそんな真似は出来ないから、里子と共に色々と怨霊などいうものの有るべきでないことを説いたけれど無益でした。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符の表に、有るべき理由の無い一字が、もし有ったら、いつも控え控え断念めて引退る、その心がきっと届くぞ！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に有るべきところの人生は、決してこんな態であってはならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかそこには、一言にして万事を言い尽し得るような、詩的表現の全般に行き届いた、真の判然明白なる答案があるように、有るべき筈だと感じられる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も愚劣千万なのは、人々がこの種の似而非自由詩（印象的散文）に見慣れた結果、それを以て新しき詩の正道であると考え、実に有るべき真の詩を、理念から閑却していることである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の湯に主と家来とは一緒に招く場合も有るべき訳で、主従といえば離れぬ中である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都だの僧正だのというのは、俗界から教界を整理する便宜上から出来たもので、本来から云えば、名誉でもなく、有るべき筈もないものだが、寂照が僧都にされたことは、赤染集に見えている。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳に首があり尾が有るべき理は無いなどと、愚にも付かぬ理窟などを考へて居るものは一人だつて有りは仕ない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に人情自然、然樣有るべき理なので有る、當然なので有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上は廣闊、風はおのづからにして有るべき理である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に望氣の法のみによつて鑛山の有望無望を考定するは迂陋なること勿論であるが、既に何等かの物あれば又おのづからにして何等かの氣有るべき道理であるから、氣を望んで山を相するのも一理無きにあらずである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其婦人等――日本人の理想に從へば、穩しく、しとやかに、萬に控へ目で有るべき筈の婦人等は、嚴かなる法廷に立つに及んで、何の臆する所なく面を揚げて、「我は無政府主義者なり。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にも歌人の大家先生は澤山あれど我等のやうに先生の薫陶を受け大島小學校の門に學び候ものならで、能く我等の精神感情を日の出の唱歌に歌ひ出し得るもの有るべきや、甚だ覺束なく存候。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "名譽は有るべきやうなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の死に臨みての願は、御二人の永く幸福を享け給はんことのみに候、あはれ、此數行の文字を托すべき人は、その人ならで又誰か有るべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此寺はカルララの大理石もて、人の力の削り成しし山ともいふべく、月あかき夜に仰ぎ見れば、皎潔雪を欺く上半の屋蓋は、高く碧空に聳えて、幾多の簷角、幾多の塔尖より石人の形の現れたるさま、この世に有るべきものともおもはれず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "美津田氏は質直不文の人なれど、假名付の小説を能く讀みたり、其談話は一に記臆より出し故に、誤謬も多少有るべきと同時に、虚構潤色を加る事無しと知らる。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に人情自然そう有るべき理屈なのである、当然なのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に少なくとも不良で無く凶悪で無く狂妄で無い限りは、人の思想や言説や行為に対しては、少なくとも剋殺的で無く助長的で有るべきである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来ないまでも少なくとも租税を免じて社会的負担を軽くし、国家的社会的重圧を虚弱の身の上に加えないようにするのが有るべき道理である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々時々、事々物々、ただ我が当然「こう有るべきこと」、「こう行うべきこと」を考えて行い、行って過ちが無ければ、これ即ち誠があるというものである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ誠を守る工夫を、朝から夕まで、夕より朝まで、休むことなく途絶えることなく、何事においても「こう有るべき」というところを間違えずに、柔らかみ（仁和）あり、正しさ（義）ある心を常に保てば、自然と少しの不平不満も起らない、正にこれ君子なのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒じやと言ひたいが、やはり貴方が自ら作せる罪の報で、固よりかく有るべき事ぢやらうと思ふ」　宮は俯きてよよと泣くのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日になつて彼が悔悟した、それでも好く悔悟したと謂ひたいけれど、これは固よりさう有るべき事なのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが女の道と謂ふもので、さう有るべきです、さう有るべき事です。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場に近づくに従って、怪人城塞が、有るべき場所から姿を消しているのが確かとなった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は有るべきことが、有るやうに在るのだと思つた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で自分の手にあまる廻りからは、どんどん新たな、決して、私の有るべきという範疇では認めていなかった関係的いきさつが不快に、或る時には明かに不正に襲って来る。",
              "citation": {
                "source": "われを省みる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
