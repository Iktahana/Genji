  {
    "uuid": "473eb437-5958-5574-bd03-87ee5be35d2d",
    "entry": "愛車",
    "reading": {
      "primary": "あいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) beloved car (or motorcycle, bicycle, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛車は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛車が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛車に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛車が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛車について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛車についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛車について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛車が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛車が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛車は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛車は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛車を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛車をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛車が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛車の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛車を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛車に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛車について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛車は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛車を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
