        "examples": {
          "standard": [
            {
              "text": "私は毎日兄上について考えている。",
              "source": "幻辞"
            },
            {
              "text": "兄上という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は兄上の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には兄上が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "兄上を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは兄上について学習した。",
              "source": "幻辞"
            },
            {
              "text": "兄上の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は兄上の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では兄上が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "兄上という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に兄上という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では兄上についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "兄上を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると兄上は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "兄上について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では兄上が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に兄上は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により兄上の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "兄上は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に兄上は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "毎朝いただいて居る東奧日報に據れば、私の兄は、いま、縣會に於いてたいへん割のわるい役をして居るやうである、私、いま、兄上に叱咤されるのを覺悟のうへで申してゐるのであるが、勘平役者が黒衣にまはつたやうで氣持がよくない。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やくざな私を、無言のうちに叩きあげて下さるのも、すべて兄上のちからである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上の峻嚴と竹内俊吉氏のなごやかさは、縣會に於いて、よいコントラストをなしたであらうに。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍の御齢は三十を一つも越えたもうか、二郎に比ぶれば四つばかりの兄上と見奉りぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）兄上が左樣申し殘されたか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上に逢うたらばそのおもむきを確と申傳へてくりやれ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上書に、兄上様――旻。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上の言ふことは本當だと思ふ、立派な兄を持つことは幸福である、しかし、私は文學のために勉強を怠ることがない、その故にこそいつそう勉強してゐるほどである、と誇張した感情をさへところどころにまぜて長兄へ告げてやつたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばし、お名あがり家ととのうたるのちは、御兄上様御姉上様、何条もってあしざまに申しましょうや。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日昼過ぐる頃、弟は学校より帰り来りて、おのれが釣竿、装置など検めゐしが、見おぼえぬ竿のあるを見出して、此は兄上の新に購ひ給ひしにやと問ふ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度はさきに帰りし時とは違ひて、家に入るや否や大きなる声を揚げて、兄上、はや明日の釣りに兄上には必ず負けまじ、兄上三十尾を獲たまはば我四十尾を獲ん、兄上五十尾を獲玉はば我六十尾を獲ん、兄上に中田の竿あれば我に藤作の竿あり、我が拙きか兄上が拙きか、釣りの道の技くらべは明日こそとて、鼻息荒く誇る。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其声を聞きつけて、兄上も寤め居たまへるや、此雨はまた如何に降りに降る事ぞ、さても口惜からずやと力無く睡気に云ふ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くは雨の止むこともあらんとの思ひに心休まらで、睡るとも無く睡らぬとも無く時を過ごしける中、いつしか我を忘れて全く睡りに入りけるが、兄上と揺り覚まされて、はつと我に返れば、灯火の光きら／＼として室の内明るく、父上も弟も既衣をあらためて携ふべきものなど取揃へ、直にも立出でんありさまなり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて舟子は既「きゃたつ」を海の中にたてゝ、餌匣ととを連ねたるものをも其に結ひつけ終りければ、弟先づ釣竿を携へて「きゃたつ」に上り、兄上羨みたまふな、必ず数多く釣りて見せまうすべしと誇る。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）貴兄のお兄上は、県会の花。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
