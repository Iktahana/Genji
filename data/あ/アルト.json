        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アルトについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アルトという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアルトの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアルトが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アルトを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアルトについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アルトの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアルトの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアルトが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アルトという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアルトという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアルトについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アルトを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアルトは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アルトについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアルトが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアルトは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアルトの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アルトは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアルトは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――ソロモン僕はもうバッハにもモツアルトにも倦果てた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れも矢張り宿屋へ蓄音機を持ち込み、宿屋で東京音頭を踊るタイプの、無邪氣で善良で、人に迷惑をかけるのを人情の厚い證據とするアルトルイスト日本國民のすることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにジェームス・スチュアルト教授の器械工場の援助を得て、簡単で安いガルヴァなどを沢山作らせることが出来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常は無爲な私も事務に追はれて、アスフアルトが弛んでゐるやうな街を歩いた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは門司市、東川端の卑猥な街、カアルトン・バアの青い給仕人の花風病の体温、ロシア女の新らしい技術の中で無頼漢の唄う流行歌。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンディトライには家庭的な婦人の客が大多数でほがらかににぎやかなソプラノやアルトのさえずりが聞かれた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「音楽は、モオツアルトだけですね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お世辞の失敗を取りかえそうとして、山名先生のモオツアルト礼讃の或る小論文を思い出し、おそるおそるひとりごとみたいに呟いて先生におもねる。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今夜、久し振りにモオツアルトを聞き、音楽とは、こんなものだとつくづく、……」「僕は、ここから乗るがね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオツアルトを聞けば、モオツアルトさ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオツアルトを聞けば、モオツアルト。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて頭に冠さるようにリアルト橋が来た。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・炎天のましたをアスフアルトしく・胡瓜の手と手と握りあつた炎天　七月九日晴、晴れるにきまつてゐる、晴れなければならないのだ！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・朝風の青草食みつつ馬は尾をふる・日影ゆるゝは藪ふかく人のゐて・炎天の機械がうごく人がうごく（アスフアルトプラント）　　　　□　ひらいてゆれてゐる鬼百合のほこり・朝からはだかで雑草の花　糸瓜さいて垣からのぞく　殺された蚊でぞんぶんに血を吸うた蚊で・風が吹きとほすまへもうしろも青葉　七月廿日　土用入。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時、星城子さんは役所へ、私はアスフアルトの街道へ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・雪ふりかゝる二人のなかのよいことは・雪がふる人を見送る雪がふる・この道しかない春の雪ふる・ふる雪の、すぐ解ける雪のアスフアルトで・かげもいつしよにあるく・けふはこゝまでの草鞋をぬぐ・椿咲きつづいて落ちつく　三月十五日雪が降りしきる、敬君を駅まで見送る、一杯やる、雪見酒といつてもよい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショパン、リスト、モオツアルト、メンデルスゾオン、ラベル、滅茶滅茶に思いつき次第、弾いてみた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私は、あの海老茶色のリボンを考へ、その書生帽子を思ふだけでも、ふしぎになつかしい独逸の戯曲、アルト・ハイデルベルヒを聯想して、夏の青葉にそよいでくる海の郷愁を感じたりした。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この男はアルトゥールと云って、独逸が混ってるフランス人ですがね」とむす子は日本語がみんなに判らぬのを幸い、かの女に露骨に説明した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアルトゥールもその一人ですが、そんな理ですから、また、この男くらい恋愛を簡単に女に投げかけてみて、そして深刻に失敗した奴も少いでしょう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアルトゥールがどこで女に失敗するかというと、その熱心さがあんまり気狂い染みているというんです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうでしょうか、そうかも知れませんね」「パパとアルトゥールとまるっきり違うけど……私思い出したわ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな天才生活時代の前生涯と、今のプライヴェート生活のような親密な性情と両面持っている……」　かの女とむす子がプライヴェートな会話に落ちこんでいると見たらしく、アルトゥールは非常に軽快なアクセントで、他の連中に講演口調で喋っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはない」とアルトゥールは写真師を噛むように云ったが、すぐ興醒め声になっていった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬だとか、憎みだとかいうものは、感情に前後の関係を考える歴史趣味だ」　アルトゥールの云うこととは別の中味は、もう二重になっていて、云ってる意味と違ったものを隠しているようだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる「川向う」の流行の繁華区域は、皮膚にさえもうるさく感じるようになって、僅かばかりの家財を自動車で自分で運び、グルネルの橋を渡り、妾町と言われているパッシイ区のモツアルト街に引移った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モツアルトの横町からパッシイの大通りへ突当ると、もうそこのキャフェのある角に音楽隊の屋台が出来ていて、道には七組か八組の踊りの連中が車馬の往来を止めていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ結果、俺ハ双生児ノ片割レデアルトイフコトガ判明シタ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
