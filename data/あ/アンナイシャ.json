        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案内者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案内者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案内者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案内者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案内者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案内者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案内者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案内者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案内者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案内者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案内者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案内者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案内者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案内者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案内者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案内者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案内者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案内者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案内者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案内者は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "次の日はポツオリに行って腹立たしくうるさい案内者に悩まされながらセラピスの寺の柱に残る地盤昇降の跡を見、ソルファタラ旧火口の噴煙を調べ、汚い家でスパゲッティの昼食を食って、帰りの電車で、贋銀貨をつかまされた外にはあまり人間味のある記憶が保存されていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう、道案内者の言ふ事に從つてゐなければいけない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名もない一遊子ではあるけれど、私も幼い時から、富士の影を浴びて、武蔵相模で育った一児童として、永い間の外国生活から、故国へ放還された一旅人として、親友と、子供と、忠実なる案内者とに囲まれて、今富士の膝下へ来て亡き母の顔に見えまつるが如く、しみじみと見ているのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは逆廻りといって、道者は忌むのだそうで、案内者をもって自任する荷担ぎの男は、私から右の水引と朱印を取りあげて、遂に返してもらえなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮方面の案内者は、深沢弥作といって、親切な男であったことを附記する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御馳走さまで」と、案内者は水の礼を述べて、いよいよ裾野の中へ入る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってる顔と見えて、案内者は薄明りに、二言三言挨拶をして行き過ぎる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊へ着いて見ると、戸は厳重に釘づけにされ、その上に材木を筋交えに抑えにして、鋼線で結びつけてあるが、寂ッそりとして、人の気はなく、案内者の咳払いが、沈んだ空気を乱しただけだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者のも同じだ、私のもそうだという。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも学術上の権威者の一つの役目は丁度旅行者に対する案内者の役目である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都見物を一定時日の間に最も有効にしようというには適当な案内者あるいはこれに代るべき案内書があると便利である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科書やノートは丁度案内者に過ぎない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんやせっかく案内者が引っぱり廻しても肝心の見物人が盲目では何の甲斐もない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者のいう所がすべて正しく少しの誤謬がないと仮定しても、そればかりに頼る時は自身の観察力や考察力を麻痺させる弊は免れ難い。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに如何なる案内者といえども絶対的に誤謬のないという事は保証し難い。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどこまでも信用の出来る案内者はあり得べからざるものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山にまします女神だち歌のわく子にさちあらせたまへ翌日朝早く案内者一人｜召し具し二人きおいにきおいて滝壺に下る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と口に云えば映画は観客の眼の代理者でありまたその案内者なのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育機関としての映画の役目は、このように観客の眼の「案内者」としての役目である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月二十六日『東京朝日新聞』）　　　　　　　　　七　　　　　　アフリカの杜鵑　アフリカに、杜鵑の一種で俗名を「蜂蜜の案内者」と称する鳥が居る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊る影絵はそれ自身が目的ではなくて、それによって暗示される幻想の世界への案内者をつとめるのであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おれが案内者になるぜ」　半七は先に立って、茗荷屋へ再びはいった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "つるはしのような杖をさげて繩を肩にかついだ案内者が、英語でガイドはいらぬかと言うから、お前は英語を話すかときくと、いいえと言いました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっしょに行ったチロル帽の老人がいろいろ質問を出すけれども、娘の案内者は詳しい事は何も知らないので要領を得ませんでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっしょに見て歩いた学生ふうの男がこの案内者に「お前さんのように毎日朝から晩まで身の毛のよだつような話を繰り返していてそれでなんともありませんか」と意地の悪いことをきくと女はただ苦笑していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者が萌黄色の背広を着た英国人らしいのに説明していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば友だちの名をかたってパリへ出かけるいたずら者が、自分の引き立て役に純ドイツ型の椋鳥を連れて行く、その椋鳥のタイプとか、パリ遊覧自動車の運転手とか案内者とか、ベデカと首っ引きで、シャンゼリゼーをシャンセライズと発音する英国老人とかいうのがそれである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある赤煉瓦の恐ろしく殺風景な建物の前に来たとき、案内者が「世界第一の煉瓦｜建築であります」と説明した。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに空知太より空知川の岸をつたふことは案内者なくては出来ぬとのこと、而も其道らしき道の開け居るには在らずとの事を、三浦屋の主人より初めて聞いたのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
