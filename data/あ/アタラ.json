        "examples": {
          "standard": [
            {
              "text": "毎日、可惜について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の可惜戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "可惜の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "可惜という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは可惜について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "可惜の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "可惜に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは可惜を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での可惜は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、可惜は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "可惜は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な可惜を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「可惜」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「可惜」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「可惜」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「可惜」という概念について深く考察する必要があります。",
              "source": "幻辞"
