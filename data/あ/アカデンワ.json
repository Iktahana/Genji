        "examples": {
          "standard": [
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "高志は、通りの赤電話を指さし、おれはレコードを見てる、といった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親というのはそういうものなのだろうが、風邪をひいていないか、ケガをしていないか、ちゃんと宿題をやっているか、あしたの夕食はなにを食べたいか……などといっているうちに、売店で両替した十枚の十円玉は、すべて赤電話にのみこまれてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、切るからね」　赤電話を増やすべきだ、という母親をなんとかなだめ、受話器をおき、十円玉が一枚も落ちてこないのをたしかめ、大きくため息をつく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤電話でソバ屋のダイヤルを廻し終えて、彼はふと私設球場の金網に片手をかけ、背を向けて、その若い女が立っているのを見たのだった。",
              "citation": {
                "source": "待っている女",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄介は赤電話で神田の画廊を呼び出した。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとちゅうで、小林君は、赤電話で、明智探偵事務所をよびだし、明智先生に、これから、あやしいおばけやしきを探検することをつたえ、その場所を、くわしく、しらせておいたのです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、赤電話で、先生に、このおばけやしきをしらべると、報告しておいたからです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット小僧は、たばこ屋の店の赤電話にとびついて、明智探偵事務所を呼びだすのでした。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線電話機ができれば、少年たちは、それを持って、探偵をすることになり、あやしいやつを見つけたら、いままでのように、赤電話のあるところまでかけださなくても、すぐに明智探偵事務所と話ができますし、また、悪者につかまって、どこかへおしこめられても、いくらでも助けがもとめられるのです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に、赤電話があったら、それで、おうちの人とはなしてみるのです。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、小林団長に知らせよう」　山村君は、商店のならんでいる町のほうへ、かけ出していって、赤電話で、明智探偵事務所の小林少年に、このことを知らせました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の入口のかたわらに赤電話があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの仲間たちはどうしているのだろうかという話になり、夏休みのいまでも東京にいることが確実な連中のところへ、赤電話が見つかるたびに、電話した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んでおいて、赤電話の受話器をとると、まず、一一九をまわして、火事の場所を知らせたあとで、警視庁の捜査課を呼びだし、知りあいの中村警部に、いそいで、ことのしだいをつげました。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに気がつけば、トランクなんかにかくれないで、赤電話で、明智先生なり、中村警部なりに知らせて、おとなの手で二十面相をとらえてもらうことにしたでしょう。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "有田君は、商店のならんでいる大通りへかけつけて、赤電話で一一〇番を呼びだし、ロボットがあらわれたことを知らせました。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林少年は明智探偵のさしずで、門の外へかけ出していって、赤電話で、警視庁にこのことを知らせました。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　町の赤電話の前にきたとき、章太郎君がポケットから十円玉を出して、電話をかけようとしますと竹内君は、「探偵事務所へ行くなんて言っちゃいけないよ。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
