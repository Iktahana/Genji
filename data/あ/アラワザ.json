    "definitions": [
      {
        "index": 1,
        "gloss": "physical labor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒業について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒業という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒業の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒業が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒業を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒業について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒業の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒業の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒業が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒業という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒業という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒業についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒業を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒業は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒業について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒業が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒業は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒業の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒業は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒業は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "問題設定の切れ味の良さ、訴えたいポイントはどんな荒業を駆使してもアピールしようとする誠実な臆面のなさはほとんど桂枝雀の落語を思わせるものがあり、オレは氏を内心でトッテン師匠と呼ばさせていただいている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それはさうとして彼も再び都に戻り、いよ／＼創作の筆を執らうと奮起したのであるが、いざペンを持つて見ると、これまでの余りな荒業に練られた腕にとつては、ペンの軽さが手答へがなくて厭にペン先が震へるばかりで、決して落々と文字などを書き誌すといふことが不可能事であるのを発見した。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世はそんなものではない」「ですが、住田や玉子をかどわかす荒業ができるぐらいなら、ボクを海へ帰らせるのにペコペコすることはなさそうですよ」「ザコを殺して大罪を犯すのは愚の骨頂だぜ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ京へ上る足ついで、是非その道場を訪れて見ましょうわい」「しかし、随分ともご用意あって参らぬと、尋常の武芸者と違って、怖ろしい荒業を致すという噂でござりますぞ」　と十太夫は特に注意した。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上とくとお断り申しておくのは当流はお武家方の板の間泳ぎのなまくら剣術と事違い、すこぶる荒業でござるゆえ、たとえ如何なる怪我を致すも、試合の上なら用捨はござらぬ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
