[
  {
    "uuid": "7f124baf-5a89-59a1-8131-01f9dfe3d65a",
    "entry": "あるか無いか",
    "reading": {
      "primary": "あるかないか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whether or not",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あるか無いかについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあるか無いかの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあるか無いかが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあるか無いかについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあるか無いかの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあるか無いかが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあるか無いかという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあるか無いかについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあるか無いかは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあるか無いかが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあるか無いかは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあるか無いかの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あるか無いかは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあるか無いかは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｔ「縁があるか無いか」　と言って立ち上った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此温泉が果して物質的に僕の健康に效能があるか無いか、そんな事は解らないが何しろ温泉は惡くない。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "題材の取り扱いの上に作者の独創があるか無いかが問題になるのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に彼は客が食通であるか無いかおおよそ見分ける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――あるか無いかより、どうしてもあってもらわなくてはならなくなったわたくしの心持ちを少しお話いたしましょう。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の踏んでいる足下の土地さえ、あるか無いか覚えない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎では人間の価値を、現金があるか無いかできめてしまうのね。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の見ている前で、重箱の蓋に、一両の小判をきちんと載せ、玄関に置いて来て、「式台の右の端、最も暗いところへ置いて来ましたから、小判の主でないお方には、あるか無いか見定める事も出来ません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分も鏡のなかへ映る自分の眸に星があるか無いか検べるから、傍からもよく鏡の中の自分の眸と本当の自分の眸を見較べて欲しいと言うのである。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく額か何処かに怪我があるか無いかを見れば判ると思いながら歩いた。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがほんとうの妹であるか無いかは、家へ帰ってみれば判ることである。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠があるか無いか知りませんが、職人伸間ではみんなそう言っていたそうですから、何か訳があるんだろうと思います。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、棹の上に取り付けてある矢の羽型の風車が、これも彩色を無くしたまま、時折り、あるか無いかの風を受けて廻転しかけては、ク――ック――ッと陰気な音を立てているばかり……空は一面の灰色に曇って、今にも降り出しそうである。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊像のあるか無いかは百日を過ぎれば自然に判ることである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しその碁盤が名妓の遺物であるか無いか、又それが深川の柘榴伊勢屋から出たものであるか無いか、その当時の半七はまだなんにも知らなかったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しお俊という女と関係があるか無いか、そんなことは一切知らないと用人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以来、老女は毎日かかさずに東門へ行って、石の亀の眼に異状があるか無いかを検めることにしていたので、ある少年が怪しんでその子細を訊くと、老女は正直にそれを打ち明けた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、小坂部――小刑部とも刑部ともいう――明神の本体が女神であるか無いかという議論以外に、その正体は年ふる狐であるという説が一般に信じられているらしい。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "要りもしない、一年に二度か三度著る事があるか無いか解らなくても、著物は五十円六十円出して拵へるのを一向何とも思はんくせに、書物となると十銭か二十銭の雑誌一冊でも借りて読まうとしてゐる。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、私は五分間の猶予をあたえますから、癲癇の血統があるか無いか考えてみてください」　そこで、この五分間――今でも私はこの世ながらの地獄のどん底をさぐり廻っていたような気がする。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、年の方は一つや二つ違ったところで、差したる問題でもないのですが、一体このお金に亭主があるか無いか、勿論、表向きの亭主は無いにきまっているが、いわゆる内縁の亭主とか、色男とか旦那とかいうようなものがあるか無いか、それを念入りに探索する人もあったのですが、どうも確かなことは判らない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一年ほど経ってから、神奈川の貸座敷に手取りの女がいて、その右の頬にかすり疵のあとがあると云う噂でしたが、それが彼の矢がすりであるか無いか、確かなことは知った者もありませんでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京通信社などはいい方で、そんな新聞があるか無いか判らないような、遠い地方の新聞社員と称して、従軍願いを出す者が続々あらわれる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半七捕物帳」の半七老人は実在の人物であるか無いかという質問に、わたしはしばしば出逢うのであるが、有るとも無いとも判然と答え得ないのは右の事情に因るのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の問題は、玉藻が果たして魔性の者であるか無いかということで、それを確かに見きわめた上でなければ、あとへもさきへも踏み出すことが出来ないのであるが、今の千枝太郎は不幸にして、それを見定めるだけの大きい強い眼をもっていなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそんな空想に耳を傾けてくれる学者が手近にあるかないか見当が付かなかった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の坂だらけの町を、あるかないか當てにならない宿を求めて歩き※はるのでは第一折角保養に來た本來の目的に合はない、それよりか寧ろ東京の宅の縁側で咲殘りのカンナでも眺めて欠伸をする方が遙かに有效であらうと思つたのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう現象は普通の気象学の書物などには書いてないことで、果して颱風と直接関係があるかないかも不明であるが、しかし土佐の漁夫の間には昔からそういう現象が知られていて「とうじ」という名前までついているそうである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この流行言葉を口にする人の中で、本当に学位濫造の事実があるかないかを判断するだけの資料と能力をもっている人がどれだけあるかは極めて疑わしいと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし他の諸動物についても同様の事があるかないか調べてみたら面白いだろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
