    "definitions": [
      {
        "index": 1,
        "gloss": "secret manoeuvres (maneuvers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗躍について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗躍という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗躍の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗躍が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗躍を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗躍について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗躍の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗躍の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗躍が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗躍という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗躍という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗躍についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗躍を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗躍は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗躍について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗躍が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗躍は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗躍の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗躍は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗躍は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかも巨万の富を貯えて印度貿易に関する限り非常な潜勢力を有し、非常時の内治、外交の裡面に重大な暗躍を試みているらしい事も、私が嘗て東京で、暴力団の用心棒をやっていた関係からチャンと睨んでいる。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の中には釈放された有力な戦争協力者たちが暗躍していて、この一年間に人民に対する抑圧とアジアの解放を妨げる仕事がある時はこっそりと、ある時は公然と法律をふりかざして行われてきています。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の妻からハインリッヒ伯爵家の主婦の地位と、巨額の財産を奪い取るべく暗躍している者が随分多いのですから……」　私は思わず襟を正した。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは、幽鬼の不敵な暗躍につれて、おどろと跳ね狂う、無数の波頭を見るのみであって、事件の表面には人影一つ差してこなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこの事件の本体が、あの陰険きわまりない暗躍の中に尽されているのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなって、ファウスト博士の暗躍が明らかにされると同時に、そのいっこう単純な局面にもかかわらず、さしも法水でさえ、傍観する以外に術はなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は胎龍と年雅塾の同門だったのですが、官展の出品で当選を争った際に、胎龍は卑怯な暗躍をして、父を落選させ自分が当選しました。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、吾々が立ち騒いでいる間に、叫声も物音も立てなかった、犯人の陰微な暗躍があった訳ですな」　といってから、杏丸は狡猾な笑いを作って、声を低めた。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗ては惑星的存在として政界に暗躍したことが、その肥満した体躯に、短く刈った半白の髪に、厚がましい顔の皮膚に、隠退してる今でも仄見えていた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は芳町の芸妓で、戦争になって花柳界閉鎖後も、政界に暗躍してる八杉の世話になり、東京近くのこの町にのんびり暮している彼女のこととて、眼に宿るその陰に、特殊の意味があるのではない。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これら宣教師は神衣の蔭にかくれて自国権益のため暗躍する不良分子もあり、従来兎角の問題を惹起してきたものだ。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　天智天皇は当然継承すべき帝位に即かず、皇極、孝徳、斉明、三帝のもとに皇太子として暗躍した。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、百川は暗躍した。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暗躍することのみが生き甲斐だつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒食はゞ皿まで、彼はもう弥縫のための暗躍に厭気がさして、卑屈な自分を呪つたが、所詮弥縫暗躍がまぬがれがたい立場なら、いつそ全てを自分一存のカラクリで仕上げてやれといふ自暴自棄の結論に達してゐた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "行長は根が正直者、国を裏切り暗躍に狂奔してゐるが、陰謀はその本性ではない。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "如水黒幕の暗躍により関ヶ原の大事はほゞ決したのだが、これは後日の話。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今朝方の女のことや、キミの話をきいてみると、住田以外の誰かが、住田ぬきでこの出版を挫折させようと暗躍しているようなフシがあるね。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事件をきつかけに、かねて彼と不和だつた某先輩が校内を暗躍して、彼に不利な策謀をしたと伝えられた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大資本にモノを云わせて、必死に投手引きぬきに暗躍しているのだ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゼルをせつ子の敵にまわさぬように、彼はひそかに暗躍する覚悟をかためていた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ、山師や事業家の暗躍をシリメに、当主大伴宗久どのは書斎の中で居眠り同然の読書にふけって、血まなこの山師事業家どもを全然そばへ寄せつけない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西に散らばって待機中だった同志が、前後して下ってきたのを、江戸に暗躍していた人々が途中まで迎いに出て、この二、三日、あとになり前になり、警戒にこころを砕きながら三々五々、やっと、江戸へ一｜伸しのここまで来たところだった――。",
              "citation": {
                "source": "口笛を吹く武士",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "林コンツェルンを押退けてその現勢力に取って代ろうとする日興コンツェルンが、皇帝の反対党、すなわち親仏閥の李光明擁立派を抱込んで、さまざまに暗躍しているという風評がチラチラ聞こえる折だったから、皇帝に対して何か乱暴な企てでもありはせぬかと心の休まる暇もなかった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを資本・構成をほぼ等しくする好敵手、小口の日興コンツェルンがなんとかして林の手から取上げようと、皇帝反対派、すなわち、皇甥擁立派を突ついて盛んに暗躍している最中だから、それは何かためにするところある日興の仕業ではないかという疑念は、誰の胸にもすぐ浮かぶのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次がそんな計畫を樹てゝゐるうち、人斬の暗躍は休んだわけではなく、十二日の間に三ヶ所ばかりで、脅かされたり斬られたり、外神田一帶、益々物情騷然たる有樣です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手になつてゐるのは、江戸開府以來の捕物の名人と言はれた錢形の平次、まだ三十そこ／＼の苦み走つた良い男ですが、十手捕繩を持たせては、江戸八百八町の隅々に、魑魅魍魎のやうに暗躍する惡者共を番毎｜顫へ上がらせてゐる名題の名御用聞です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の役目",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
