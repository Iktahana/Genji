        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日有難さについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "有難さという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は有難さの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には有難さが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "有難さを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは有難さについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "有難さの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は有難さの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では有難さが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "有難さという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に有難さという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では有難さについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "有難さを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると有難さは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "有難さについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では有難さが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有難さは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により有難さの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "有難さは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に有難さは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そういう気兼ねのいらないのは誠に二十世紀の有難さであろうと思われる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国の有難さが身にしみた。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙音観世音　　梵音海潮音　観音の有難さ、それは潮の音のごとく大きくひたひたと押し寄せる。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なぞという挨拶にはじまる女人の実体を活写し得ても、なんの感激も有難さも覚えないのだから、仕方がないのである。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だって、お金の有難さは存じていますが、でも、その事ばかり考えて生きているのでは、ございません。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スグ馴レルモノデス　このお言葉の有難さ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、おもむろに、かの同行の書生に向い、この山椒魚の有難さを説いて聞かせようと思ったとたんに、かの書生は突如狂人の如く笑い出しましたので、私は実に不愉快になり、説明を中止して匆々に帰宅いたしたのでございます。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の山椒魚が、とにかく古代の化石と同じくらいに大きいというところに有難さがある訳でありまして、文句無しに世界一ばん、ここに私の情熱もおのずから湧いて来て、力こぶもはいってまいります次第でございます。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で無うてさへ、御時節の有難さに、切支丹と間違へられぬが見つけものゝ処ぢや。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し此の世でいっち慕わしいお人に逢わんで往んでも大事ないか』おくみ『あれ、御慈悲の有難さに源兵衛さんのことは、いつの間にやら忘れていた。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又頼む時にも都合がいいから」　位の有難さしか感じていないその熱誠の度合いがそっくりそのまま鼻の頭に顕われていて、その眼や口が表現している熱度よりも著しく低い度合を示しているからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる「何事のおはしますかを知らねども有難さにぞ涙こぼるる」ものなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち言語で言い顕わし得ぬ冥々の裡に、わが国万古不変の国体を一時に頭の頂上より足趾の尖まで感激して忘るる能わざらしめ、皇室より下｜凡民に至るまで、いずれも日本国の天神地祇の御裔なりという有難さを言わず説かずに悟らしむるの道なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "手古奈とて忍男其人に毛程の厭がないは、勿論で、寧ろ領主の若殿に思はれるといふ有難さは、云ひやうなく嬉しい。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美奈子は、母の言葉を聴くと、地の中へでも消えてしまいたいような恥かしさと、母の自分に対する真剣な心づくしに対する有難さとで、心の中が一杯になってしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛法と王法とがひとつになつて、この深い山の御堂にこの上もない有難さをひろげてゐるやうに見えた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べたらこの御堂の有難さは！",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美奈子は、母の言葉を聴くと、地の中へでも消えてしまひたいやうな恥かしさと、母の自分に対する真剣な心づくしに対する有難さとで、心の中が一杯になつてしまつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康そのものの有難ささへ知らぬかのやうに。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自白すると自分の如きも昔二十幾人の教師に教を享けたるに不拘、今猶しみ／″＼と思出して有難さに涙をこぼすのは、唯此鹿川先生一人であるのだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉まで出懸けた聲は辛うじて噛殺したが、先生の有難さ、友達に冷笑れる羞かしさ、家へ歸つて何と言つたものだらうといふ樣な事を、子供心に考へると、小さい胸は一圖に迫つて、涙が留度もなく溢れる。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉まで出懸けた声は辛うじて噛殺したが、先生の有難さ、友達に冷笑れる羞かしさ、家へ帰つて何と言つたものだらうといふ様な事を、子供心に考へると、小さい胸は一図に迫つて、涙が留度もなく溢れる。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の最大の有難さは、何より人命を尊重することだと私は思う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは警察の役人でない有難さ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙のやうに泥濘に住む事の好きな市長も、目上の人から招待される有難さは知つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで神前へいってお辞儀をしたって何の役にも立つかというと、そんなことをしてはあなたの有難さがなくなってしまうという。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのような方は、この銀安を遁さず上海にでも行って金貨のありがたさを味わってくるんだわ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生、内地米のありがたさには気づかずに食っていたのだが『食』は、『衣』『住』と共に、人間が生きて行く上に最も重大なことなので、まずいとなると、それに対する対策は、なか／＼真剣でいくらも智恵が働きそうに思われる。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "治まる聖代のありがたさに、これぞというしくじりもせず、長わずらいにもかからず、長官にも下僚にも憎まれもいやがられもせず勤め上げて来たのだ。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に痛切に感じたことは日本の陸地測量部で地形図製作に従事している人たちのまじめで忠実で物をごまかさない頼もしい精神のありがたさであった。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
