          ],
          "literary": [
            {
              "text": "第二二課　敵、味方一　敵が相手側にばかりあるかと思えば自分の中にもあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、更に公判が進み、ストライヴァーが同僚弁護士であるカートンの注意によってカートンとダーネーとの容貌の酷似を利用して相手側の一証人の証言を粉砕する。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手側の言い分も聞かねば。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
