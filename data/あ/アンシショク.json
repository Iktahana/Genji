        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗紫色について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗紫色の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗紫色が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗紫色について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗紫色の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗紫色が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗紫色という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗紫色についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗紫色は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗紫色が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗紫色は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗紫色の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗紫色は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗紫色は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "截られて居る雑木の大部分を占めて居る大人の拳位な太さのくぬぎの木肌は、誠実な労役を経た、老いた農夫の掌の様な、ひびだらけな上皮の、暗紫色へ、ほろほろ、と白い浮粉が吹き交ざった様な枯淡ななつかしみをかやに与えるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この拷問をうけるものは、はじめは惣身が赤くなり、更に暗紫色に変じて冷汗をしきりに流し、それがまた蒼白に変じるときは即ち絶命する時であるといい伝えられているので、皮膚に蒼白の色を呈するのを合図にその拷問を中止することになっていた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎骨の左の方に暗紫色の痕が見える。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔一めんが暗紫色、口の両すみから真白い泡を吹いている。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子の頭上の電燈は、先刻加奈子が部屋を出る時かぶせて行った暗紫色の覆いを透して、ほの暗い光をにじみ出している。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は黄褐色、冬は灰鼠の色に、春先は暗紫色になり、そして春の終わりから夏の終わりまでは一色の緑を刷く雑木林の丘だった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又暗紫色なる斑あり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "腮の直下に数箇の爪痕及暗紫色の斑点ありき。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "下から成層圏へのぼっていくと、白昼でもまず十キロのあたりでは、空が暗青色となり、それからだんだん暗さを増して、暗紫色となり、二十キロを超えるころには黒紫色となり、それ以上は黒灰色になって、われわれが普段見ている晴れた夜空と同じようになる。",
              "citation": {
                "source": "成層圏飛行と私のメモ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、総監の唇は暗紫色を帯び、顔に苦悶の表情があらわれたので、松島氏は隣室に退いた人々を呼びに行った。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗紫色に腫れあがつた顏は無氣味な光澤を持ち、片方の眼は腫れふさがつて細く小さくなつてゐた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗紫色に腫れあがった顔は無気味な光沢を持ち、片方の眼は腫れふさがって細く小さくなっていた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の第三番目の像では、もう顔面の中で、額と、耳の背後と、腹部の皮膚の処々が赤く、又は白く爛れはじめて、眼はウッスリと輝き開き、白い歯がすこし見え出し、全体がものものしい暗紫色にかわって、腹が太鼓のように膨らんで光っている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦は黒鯛に似た形の、暗紫色に黄味を帯びた二尺｜許の無名｜魚や「小判｜冠り」を釣つて大得意である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴色や暗紫色をした肋骨と手足の骨とが左右に一｜間程の高さでぎつしりと積まれ、其横へ幾列にか目鼻の空ろに成つた髑髏が掛けられて、中には一つの髑髏を中心として周囲に手足の骨で種種の形に模様づけられたのもある。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこだけ暗紫色に黒ずんでゐて、墨か何かを塗つたやうだつた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "透きとほるやうな空色にも、水々しいブダウ色にも、無気味な暗紫色にも、その他一切の色彩に変化して眼に映つた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と老人は、癩の疵でないことを示し得たことに幾分の喜びを感じたのであらう、満足さうに貌を晴れ晴れさせて、「この病気の発病後に出来た疵は、どんなに治つても暗紫色をしてゐるものなのです。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに薄明がたれこめ、山々は暗紫色に溶けはじめて夜のさなかへ消え落ちようとする頃であつた。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに薄明がせまり、山々は暗紫色にかすみはじめてゐたのだが、山の姿は手にとるやうに見えるので、明るさの残るうちには頭上をきはめることができさうな気がした。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、その沸騰が止んで、その化合物は暗紫色にかわり、それがまた前よりは少しずつ薄い緑色に色があせていった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの右手の高きには前穂高の巓がなおさっきの夕焼の余燼で灼やいて、その濃い暗紫色の陰影は千人岩の頭のうえまでものびていた。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも旅館の息子は川の水をヂャブリとくんで平気でお茶をわかすが、利根川もこのへんは下流であり、あるとき舟のすぐ横へ暗紫色のふくれあがつた土左衛門が流れてきたことがあつた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "産卵のために外洋から、この湾内へ乗っ込んできたものらしく、くびと背の鱗に暗紫色の艶がういていた。",
              "citation": {
                "source": "鯛と赤蛸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、ふにゃふにゃした血みどろのような、暗紫色の塊が二つ鼻持ちならぬ悪臭を放っているだけだ。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間も次第に暮れ、紫色に夕映した山々は何時しか暗い鉛色と成って、唯白い煙のみが暗紫色の空に望まれた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は熱のため、頭痛がするのを床の上に起き直って、暗紫色にうまそうな水をたゝえた果物を頬につけたり接吻したりしました。",
              "citation": {
                "source": "果物の幻想",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその根皮が、生時は暗紫色を呈している。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪の色も同じ暗紫色に変っている。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "脹れぼつたい唇が暗紫色に染まりその間から小さな舌の尖があらはれてゐた。",
              "citation": {
                "source": "水に沈むロメオとユリヤ",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
