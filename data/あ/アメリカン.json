[
  {
    "uuid": "f329cd6f-7733-5b63-b78b-9483cde9dd08",
    "entry": "アメリカン",
    "reading": {
      "primary": "アメリカン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
