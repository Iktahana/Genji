    },
    "definitions": [
      {
        "index": 1,
        "gloss": "American",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アメリカン・レビューにはそういう古典的な意味での音楽などはない代りに、オリンピックのグラウンドや拳闘のリンクに見らるる活力の鼓動と本能の羽搏きのようなものをいくらかでも感ずることが出来るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では連句的レビューの可能性が示唆され、他方ではまたアメリカン・レビュー的連句の開拓も展望される。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのＮ万ビルのマネキン事務所には、アメリカン・スタイルの女たちが地面にカードをひろげたように、緋の絨氈の上でお化粧を始めていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲のアメリカン・シチズンスの不用意な表情姿態の上に反映したフーヴァーのほうがはるかに多くフーヴァーその人を物語るのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子は、霊南坂まで来て、そこのアメリカンベーカリーへ入るまで、復一を勇気付けるように語り続けた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は、二時の復習が了ると、子供達は父と散歩かたがたアメリカン・ベイカリへ行く嬉しさで、無遠慮になっていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカン・ベイカリで、もっと休んでいればよかったのですわね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か持って参ろうと思ったんですが、まだお目にかかったことがないので、どんな物が、お気に召すか分りませんので、お花ならと思いまして……」と、パラフィン紙の中から、強烈な匂いをこぼしている、アメリカン・ビュウティと呼ばれる赤みを含んだ黄バラの花束を、準之助の前に差し出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舎への坂をいく子どもたちを、寮から望遠で撮ったアメリカン・ニューシネマ風の絵。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカン・インディアンが白人コロンブス一行を迎えたときの驚愕、エスキモー人がロシア人を見たときの驚愕などは、今回の事件に比べると桁ちがいの小さい驚愕だ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、私の妻は、アメリカン・ビユウテイのスキー・ジヤケツに身を固め、頭には雪のやうに真白なターバン帽子をいたゞき、ほのぼのとして「春風」に打ち乗つた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "では僕も、それを真似て――」　と私は云ひかけたが、カミシモはおろか祖先の物品は羽織一枚すら見当らなかつたので、書斎の壁に壁飾りとして掛けてあるアメリカン・インヂアンの容装をとり降して、手ツとりばやく身につけた。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はもう人数も減り、圧迫されて仕舞ったアメリカン・インディアンが到る処に生活していました。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七万ドルの資本は、ベンチャー投資会社の先駆けとなったアメリカン・リサーチ＆ディベロップメント社から引き出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その西君はといえば、単身、パンアメリカン航空のサンフランシスコ直行便で会場に乗り込んできて、ちょこまかと走りまわり、あっちでぺちゃくちゃ、こちらでぺちゃくちゃと、しゃべりまくっていたと思うのもつかの間、いつの間にかふいと姿を消してしまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年三月号の『コンピューター』に発表した「パーソナル・ダイナミック・メディア」に続いて、アラン・ケイは同年九月号の『サイエンティフィックアメリカン』誌に、姉妹編に相当する「マイクロエレクトロニクスとパーソナルコンピューター」を発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八四年とかなり早い時点で、マッキントッシュ以前までのアップルの歩みを、丹念に、生き生きと書きとめた『アメリカン・ドリーム』が刊行されたことは、その後の著作の積み上げに大きく貢献している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我髪梳きて口そそぎ枕に就き候とき、君は未だカンパン・プルミエにある人人の画室に語り興じ居給ふらん、あるはパンテオンのキヤツフエに寒ければとてアメリカンなど飲みて居給ふらん、ピガルの広場の前の例の家の伊太利亜少女の楽人にや聞きほれて居給ふらん。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａのアメリカンの女友達の写真を見「これも O my Kid か」とはしゃぐ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○アメリカで関税50％引上げ議案が十七ヵ月研究の後アメリカンハウス・オヴ・リプリゼンテーティブを通った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘンリイ・ビドウ氏がいみじくも言つたやうに、『アメリカン・バア、タンゴ、マオリ族の刺青が我々の時代に於けるのは、月光、廢塔、トゥルバドゥル詩人の胡弓がロマンチスムに於けるごときものだ。",
              "citation": {
                "source": "レエモン　ラジィゲ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の教科書をのぞくと、アメリカンヒストリーである。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでパンアメリカンをはじめ、多くの航空会社では、このジェット気流の調査をよくやっている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからユテリティ・フォイスト（実理第一）のアメリカン・ウェイ・オブ・ライフ（米国生活式）にしたがって、せっせとアメリカン・コモンウェルスの勉強でもはじめよう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "母音調和の現象はウラル、アルタイ語族の特徴の一つとして有名な音韻現象でありますが、これはいわゆる古アジア族のチュクチやカムチャルダールの言語にもあり、またアメリカンインデアンの中にもあるのであります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで簡単に水をひくことができるので、オール・アメリカン運河をつくり、イムペリアル平原を灌漑した。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ風の見掛けさえしていれば、どんな家にも、かならずリテリティ・ファースト（実利第一）の、快適なアメリカン・ライフがあると考えるのは浅見である。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "百々子は、甘い夫婦を見捨てて、急な坂をおりだしたが、みょうに気持がこじれてきて、その二人に、「失礼ですが、あの家には、アメリカン・コモンウェルスといったようなものは、ひとつもありません。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
