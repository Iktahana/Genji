        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早いの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "茶店の娘のお絹が朝早いので、お客がない鬱晴らしに三次と世間話をしている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛車が駐在所の前を通るとき、のっていた男が、　「おい、おまえら、朝早いのう。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛車が駐在所の前を通るとき、のっていた男が、「おい、おまえら、朝早いのう。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もう往のう往のう、明日はまた朝早いぜ』信徒二『御影像を返さんとはけしからん三井寺のやつじゃ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早い時間に棺を集団で囲んでいたときだった、その恐れ驚きは言い表しようもないが、扉がばんと開け放たれ、獣と見紛うばかりの日焼けた男がぼろをまとって部屋へ上がり込んだのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズは朝早い頃、ベイカー街の下宿でウィスキソーダを飲みながら説明するのだった。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いので人もない廊下に、低いオルガンの音が、閉された扉のなかゝら流れて来てた。",
              "citation": {
                "source": "嫂",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏だ、まだ朝早いのに湯島に参って、これから鰐口を鳴らそうと思うので、御手洗で清めようとすると、番の小児が水銭をくれろと云った。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子は、その時の母の様子がひどく不機嫌なのを知ったが、よくある事で大して気にもとめず、雑誌なぞ読みながら店番をしていたが、十一時になると、学校へ行くので朝早いためすっかり睡くなってしまい、そのままいつものように店をしまって裏二階の自分の部屋へ引きとり、睡ってしまった。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「婆や、お前は明日の朝早い人だ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いのは鶏と子供だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（草木塔）・朝早い手を足を伸ばしきる・伸ばしきつた手で足で朝風・いちりん咲いてゐててふてふ・あつさ、かみそりがようきれるかな物を粗末にすれば物に不自由する（因果応報だ）、これは事実だ、少くとも私の事実だ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ朝早いので、通る人が少い処へ、純一が通り掛かったのだから、道の両側から純一一人を的にして勧めるのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いのに、せわしく、疲れて床につく。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いときには早いのであるから、別に『お早う』と云ふ必要が無い、默つて居れば宜からうに、さうではない。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いときには早いのであるから、別に「お早う」という必要がない、黙っておれば宜かろうに、そうではない。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の都合で朝早いものですから、或はこれでまたお目にかかれないかも知れません。",
              "citation": {
                "source": "湖水と彼等",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "店座敷の枕の上できくと、その音は毎朝早い勤めを怠らない松雲和尚の方へ半蔵の心を連れて行く。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間に掃除をしたものか朝露に湿つた小砂利の上には、投捨てた汚い紙片もなく、朝早い境内はいつもの雑沓に引かへて妙に広く神々しく寂としてゐる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間に掃除をしたものか朝露に湿った小砂利の上には、投捨てた汚い紙片もなく、朝早い境内はいつもの雑沓に引かえて妙に広く神々しく寂としている。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも来るのは朝早いのよ。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いので、客車内で持参の弁当か何か食っていたが、撫順に着いたら我々といっしょに汽車を降りた。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「店へ置いちや危ないし、土藏へ入れると朝早いから出すのが面倒だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早いうちははだしではたらき、彫刻家のように、露の多い、ぼろぼろこぼれる砂を跳ねかした。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこで十分に腹をつくったうえ一同朝早いうちに引あげたのであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合へでも泊って朝暗い中に帰って来ると思っていなさるんでしょう」「朝早いから間違ったのだろうが、顔の批評は余計なことじゃないか？",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かれこれ、四五十本というところかな」　カーネーションは朝早いうちにぞっくらきられて、渋谷の市場へ運ばれるのであった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日になると、朝早いうちからいつものようにデーツコエ・セローの停車場へはき出された青年男女の見学団が、ぞろぞろとパンシオン・ソモロフのヴェランダの前の通りを通って行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の朝早いメトロの中で、「リュマニテ」の白い波が伸子をそのインクの匂う波の下にかくしたように。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
