        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あわび結びについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあわび結びの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあわび結びが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあわび結びについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあわび結びの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあわび結びが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあわび結びという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあわび結びについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあわび結びは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあわび結びが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあわび結びは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあわび結びの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あわび結びは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあわび結びは興味深い例である。",
              "source": "幻辞"
            }
          ],
