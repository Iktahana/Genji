[
  {
    "uuid": "85af6a6a-5505-5644-bef1-4f26301c5d1d",
    "entry": "愛する",
    "reading": {
      "primary": "あいする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
