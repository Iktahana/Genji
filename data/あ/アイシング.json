    "definitions": [
      {
        "index": 1,
        "gloss": "icing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイシングは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイシングが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイシングに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイシングが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイシングについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイシングについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイシングについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイシングが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイシングが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイシングは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイシングは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイシングを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイシングをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイシングが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイシングの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイシングを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイシングに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイシングについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイシングは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイシングを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一例として彼はアロールートおよびアイシングラスを注文する。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
