        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アーキテクチャについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアーキテクチャの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアーキテクチャが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアーキテクチャについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアーキテクチャの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアーキテクチャが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアーキテクチャという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアーキテクチャについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアーキテクチャは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアーキテクチャが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアーキテクチャは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアーキテクチャの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アーキテクチャは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアーキテクチャは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その東芝が、ＩＢＭ互換路線をとって富士通、日立が業績を伸ばすのを横目で睨みながらあくまで独自アーキテクチャ路線を貫き、ついに大型からの撤退発表に追い込まれるのが一九七八年二月。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭ　ＰＣが業界の標準の座をほぼ固めつつある以上、アーキテクチャはこの互換で行く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして誕生することになったサンは、設立当時からオープン・アーキテクチャ（言ってみれば技術の公開主義、標準主義か）の旗を掲げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ハードウエアでは、独自に開発したＲＩＳＣタイプのマイクロコンピューター、ＳＰＡＲＣのデザインを半導体メーカーにライセンスし、ハード・メーカーにＳＰＡＲＣマシンの開発を促して、標準アーキテクチャを確立する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "上はクレイがシェアを握るスーパーコンピューターから下はマッキントッシュの領域まで、ＳＰＡＲＣアーキテクチャに貫かれたＳＰＡＲＣｉｎｃｌａｙ（クレイに引っ掛けたダジャレ）からＳＰＡＲＣｉｎｔｏｓｈ（マッキントッシュに引っ掛けたくだらないシャレ）に至るマシンによってカバーするというのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発にあたったボカ・レイトンのギャングどもがオープン・アーキテクチャを選択したことの偉大なツケは、日本にも及ぼうとしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで嫌でもマイクロコンピューターがあふれ返る世の中に一本筋を通すために、機器組み込み型のマシンからパーソナルコンピューター、大型、ネットワークの核となるマシンまで含めて、新たに一つの体系に基づいたアーキテクチャを作り直そうではないか、と坂村さんが言いだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通の専務となっていた池田は通産省からの働き掛けに対し、ＩＢＭ互換のアーキテクチャを共有するという条件で、同社についで業界二位のポジションを占めている日立となら提携するとした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準に向けて強い風の吹くこの世界では、柱となるアーキテクチャの存在は不可欠だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルのマイクロコンピューターとマイクロソフトのＯＳ、そして技術をさらすことによって陣営を固めようとしたＩＢＭのアーキテクチャと、いくつもの公開された柱によって構成されるパーソナルコンピューターの世界は、何から何までＩＢＭという大型よりはましである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準に向かって風の吹くコンピューターの世界では、柱となるアーキテクチャがいる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルのマイクロコンピューターにマイクロソフトのＯＳ、アーキテクチャはＰＣ　ＡＴのいわゆる業界標準上には、ご存じのとおり厳しい競争が存在する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによってさらに加速したあげく、ＡＴ互換アーキテクチャはパーソナルコンピューターの枠を越えて家電にはみ出してしまうと、オレは今考えている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＴアーキテクチャがＰＣの世界を越えて我々の生活のさまざまな局面に浸透する過程で、Ｗｉｎｄｏｗｓには多様な機器の標準インターフェイスに成り上がるチャンスがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした製品のアウトラインを示してさあ作れと技術屋に要求すれば、健全な常識をもつものはＰＣアーキテクチャの利用を考慮するだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳ／Ｖなんて代物が出てきて構造変化の兆しはあるものの、これまでここでは日本電気の専有アーキテクチャーの独走を背景にＤＯＳマシンは高値維持に成功しており、メーカーはどこもそれなりにいい思いをしてきたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術情報を可能な限り公開し、サードパーティーによる関連製品の開発を促していくオープンアーキテクチャーこそ、渡辺はパーソナルコンピューターの魂であると信じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オープンアーキテクチャーをとったことには、その意味では怪我の功名としての一面もあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがまがりなりにもここまで独力で市場を切り開き、パーソナルコンピューター文化の旗手としてマスコミに遇されもしはじめている渡辺和也は、「八ビットの延長、そしてオープンアーキテクチャーこそが新一六ビット機の必須の条件である」と口をきわめて主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともにオープンアーキテクチャーへの転換を迫られた立場の端末グループは、すでに「既定方針どおり進む」との結論を出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホワールウインドは二五〇〇平方フィートを占有してしまうような巨大なマシンだったが、これと同じアーキテクチャーを持つものを、オールセンはごく小さく作ることで腕をアピールしたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場で特に大きなシェアを獲得しているアップル※は、ハードウエアの仕様を全面的に公開するオープンアーキテクチャーをとって、サードパーティーによる増設ボードや周辺機器の開発に門戸を開いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その常識をはずれて、郷に入れば郷に従い、オープンアーキテクチャーで臨むのか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターにはインテルの一六ビット版を採用し★、マイクロソフトのベーシックを載せ、オープンアーキテクチャーで臨み、外部の販売ルートに乗せて小売店で売り出すという計画に、委員会はゴーサインを出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣで唯一衝撃的な要素は、ＩＢＭがこのマシンに関して徹底したオープンアーキテクチャーで臨むとした点だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターのアーキテクチャーを可能な限りすっきりと構成することは、ウォズニアックにとって重要なテーマだったが、彼は見かけにはこだわらなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロッピーディスクを標準で持たせる以上、カセットインターフェイスは不必要としても、オープンアーキテクチャーの遵守に関しては、渡辺は一歩も譲る気はなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六ビットのアーキテクチャーの中に八ビットの構造を紛れ込ませたことのつけは、マシンの高速化が進めば進むほど大きくなっていく恐れがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８８０１までの従来機種で一貫してエッジトリガーによる割り込みを採用してきた日本電気側は、このアーキテクチャーが現状でなんら問題を起こしていない以上、わざわざ新しい方式に切り替える必要はないと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて情報処理事業グループのマシンにＰＣ―８００１の継承を求めた渡辺和也も、Ｎ―10プロジェクトに参考意見を述べるために加わって、オープンアーキテクチャーの重要性を訴えた後藤富雄と加藤明も、浜田たちが一六ビット機を開発していることは当然承知していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
