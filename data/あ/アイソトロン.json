        "examples": {
          "standard": [
            {
              "text": "この研究室では、アイソトロンを用いて高エネルギー粒子の挙動を解析しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい同位体生成の試みにおいて、アイソトロンのビーム安定性が鍵となりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アイソトロンから放出される重イオンビームは、物質科学分野での応用が期待されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初期のアイソトロン技術は、粒子加速器の発展において重要な一歩でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「アイソトロンの調整には、高度な専門知識が必要だね」と、ベテラン研究者が語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アイソトロンの設計思想は、その後の多くの加速器開発に影響を与えたとされています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究チームは、アイソトロンの改良により、より高精度の実験が可能になったと発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
