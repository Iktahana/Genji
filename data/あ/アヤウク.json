[
  {
    "uuid": "6656e91f-acc1-587f-8fc2-86c2262e12f8",
    "entry": "危うく",
    "reading": {
      "primary": "あやうく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日危うくについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "危うくという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は危うくの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には危うくが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "危うくを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは危うくについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "危うくの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は危うくの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では危うくが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "危うくという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に危うくという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では危うくについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "危うくを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると危うくは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "危うくについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では危うくが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に危うくは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により危うくの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "危うくは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に危うくは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大鳥居の柱は立っているが上の横桁が外れかかり、しかも落ちないで危うく止まっているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "福慈の神に出会い一目それをわが娘と知るや無我夢中になってしまって、矢庭に掻き抱こうとした旅塵の掌で、危うく白妙の斎の衣を穢そうとして、娘に止められて気が付いたほどである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また射的をしている人の鉄砲の筒口の正面へ突然顔を出して危うく助かった事もあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査委員はつまらぬ人の寄稿だと思って危うくこの論文を落第させようとした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷信でたちの悪いのは国を亡し民族を危うくするのもあり、あるいは親子兄弟を泣かせ終には我身を滅ぼすのがいくらでもある。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家国民の将来を危うくするような迷信が眼前の日本に流行してはいないか。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際もしも、その研究員が、更に進んでその欠点を除去し、その商品を完成するように研究の歩を進めるならば結構であるが、そうでなくて、その欠点を委細構わず天下に発表して、その結果その会社に多大な損失をかけ、事によるとその会社の存在を危うくするような心配が生じたとする。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスが発車してまもなく横合いからはげしく何物かが衝突したと思うと同時に車体が傾いて危うく倒れそうになって止まった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の知り得た限りの範囲では、この原理の存在を危うくするほどに有力なものはないように思われる。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を求めて滝壺に落ちて危うく助かった人もある。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあっぱれ自然の暴威を封じ込めたつもりになっていると、どうかした拍子に檻を破った猛獣の大群のように、自然があばれ出して高楼を倒壊せしめ堤防を崩壊させて人命を危うくし財産を滅ぼす。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪いよいよ深く、路ますます危うく、寒気｜堪え難くなりてついに倒れぬ。",
              "citation": {
                "source": "詩想",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はいよいよ危うく雪はますます深し。",
              "citation": {
                "source": "詩想",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでもこのような不平を超越しないでいては自分のような弱い神経をもったものは生存そのものが危うくなるであろう。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に飛び込んだる髯将軍、オットセイと称して浴槽の中へ仰のけのまま跳り込み、頭から、足からザブンザブン飛び込むこと十数回、危うく浴構内の土左衛門さんとならんとせしところを三人して引挙げ、ようやく事なきを得た。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時こそ三十六計の奥の手を出して一散に駆け出し、危うく吾妻川の河底へ生埋めになる急場を辛くも通り過ぎ、四人相顧みて工夫の猛悪なるに驚ろく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白煙｜濛々と立昇る地獄穴｜溶岩を覗いて、未醒画伯と髯将軍、快哉を叫んで躍り上がったところが、忽ち麓から吹き上ぐる濃霧に包囲されて、危うく足踏み外し白煙中へ捲き込まれんとし、二人、一生懸命｜巌に獅噛み付いて、ようよう命を陥さずに済んだそうである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとも危うく身を遁れて、泰助は振返り、屹と高楼を見上ぐれば、得三、高田相並んで、窓より半身を乗出し、逆落しに狙う短銃の弾丸は続いて飛来らん。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみると、その人はかつて虎に出逢って危うくも逃れた経験を有していたのである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗こそ却って今歳天正の十八年四月の六日に米沢城に於て危うく毒を飼わりょうとしたのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗と家康と馬の合ったように氏郷と仲の好かった前田利家は、温厚にして長者の風のあった人で、敵の少い人ではあったが、それでも最上の伊白という鍼医の為に健康を危うくされて、老臣の村井｜豊後の警告により心づいて之を遠ざけた、という談がある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "危うく取られそうになると、素早く前方へ投げ出す。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い身空が性根をスポイルされて、青い倦怠の気が精神肉体に充ちたとき、男女はなか／＼に危うくあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青い倦怠の中からわれ知らず罪咎の魔神の力を藉りても生き上ろうとするわが身の内の必死の青春こそ、あなや、危うくあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がその匂いを送って危うく榕樹の林へ入りかけようとする姫の嗅覚に届いた、姫は袖で顔を覆った。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "危うく転びそうになって、私たちはやっと私たちの身体を階段の欄干に支えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "本集は危うく絶版の悲運に際会しようとしたが四十四年の十一月に書肆を換えて再版し、なほ大正五年の六月に更に増補訂正して三版した、その後引続いて版を重ねてゐる。",
              "citation": {
                "source": "「白秋詩集」第二巻解題",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "河峡はいよいよ狭く、流れはいよいよ急に、舟は危うく触れんとして畳岩絶壁のすれすれを走り下る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだを踏みわけて、勘次郎はともかくも箕輪の方角へ落ちて行こうとすると、急ぐがままに何物にかつまずいて、危うく倒れかかった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間の隅にはかの土竈があって、そのそばには幾束の高粱が積み重ねてあることを知っているので、堀部君は探り足でその方角へ進んで行くと、切株の腰掛けにつまずいて危うく転びそうになったので、あわててマッチをすると、その火は物に掴まれたようにふっと消えてしまった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
