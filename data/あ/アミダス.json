[
  {
    "uuid": "fb059291-91a9-5907-bf1c-979c87ee6478",
    "entry": "編み出す",
    "reading": {
      "primary": "あみだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to think up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日編み出すについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "編み出すという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は編み出すの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には編み出すが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "編み出すを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは編み出すについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "編み出すの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は編み出すの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では編み出すが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "編み出すという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に編み出すという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では編み出すについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "編み出すを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると編み出すは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "編み出すについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では編み出すが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に編み出すは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により編み出すの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "編み出すは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に編み出すは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新しい形式を編み出す必要があるかどうかわからない――といつてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼女のこうした不可思議な創作能力は、それからさらに百尺竿頭百歩を進めて、真に意表に出ずる怪奇劇を編み出す事になった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に震災後の強烈な生存競争に疲れ切った親達は、もうそんな理窟を編み出す力さえ無くなったらしい、大昔から何の効能もないときまった、「恩の押し売り」を試みる位が関の山らしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親から見捨てられた子供のこと、その子供を育て上げてやる喜び、その小さな魂のまわりに自分の夢想や愛情を編み出す喜び、などを彼女は考えていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「矢っ張り取引所のことを卒業論文に書くんだそうだ」「流行るんだね」「最近十年のカーヴを調査して、相場高低の原則を編み出すというんだから鼻息が荒い。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が編み出す複雑な資金の流れを追いきれる人が果たしているかしら？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "力量次第どんな新手をあみだしても良く、むしろ人の気附かぬ新手をあみだすところに身上があり、それが芸術の生命で、芸術家の一生は常に発展創造の歴史でなければならないものだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを逆用してノーコメントの手をあみだすつもりだったかも知れませんよ。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして神様の陰にかくれて、天草次郎はユックリと起死回生の策をあみだすツモリであったが、碁や相撲のように個人の天分だけで復活できる世界とちがって、実業界はセチ辛く、天分通りにいかないものだ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この数ページの条約の言葉を、戦いの前に、おたがいにあみだすことができたら、どんなにたくさんの戦争がおこらずにすんだかもしれない。",
              "citation": {
                "source": "生まれ変った赤坂離宮",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが他人の処女でなしに自分自身の処女を刺殺し、自分自身の武士道、自分自身の天皇をあみだすためには、人は正しく堕ちる道を堕ちきることが必要なのだ。",
              "citation": {
                "source": "堕落論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
