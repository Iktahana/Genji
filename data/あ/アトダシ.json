    "definitions": [
      {
        "index": 1,
        "gloss": "waiting to see one's opponent's move before doing anything (e.g. as a disallowed act in rock, paper, scissors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裁判所からの照会は支倉の第三回訊問後彼の自殺を企てようとした事件の為参考人銀之助を取調べた直後出したものらしい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に京都に後出した語と考へられるさけいにがある。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "困ったね僕も――何しろ切符は買ったあとだし――。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "大病のあとだし、一年位は学校を休ませた方がいいだらうとみんなは云つてゐたが、年末頃になると、禿げてゐた頭に少しづつ髪の毛が顕れだした。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、嵐山も大堰川もとうに花は散ったあとだし、めくらに新緑を愛ずる風流気はなかろうし、だいいち、故征夷大将軍尊氏が薨じてから今日はまだ八日目なのである。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
