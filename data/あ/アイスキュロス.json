        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、アイスキュロスは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではアイスキュロスが重要です。",
              "source": "幻辞"
            },
            {
              "text": "アイスキュロスに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではアイスキュロスが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でアイスキュロスについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からアイスキュロスについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではアイスキュロスについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではアイスキュロスが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではアイスキュロスが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアイスキュロスは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてアイスキュロスは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にアイスキュロスを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にアイスキュロスをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でアイスキュロスが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、アイスキュロスの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はアイスキュロスを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はアイスキュロスに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でアイスキュロスについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からアイスキュロスは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはアイスキュロスを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "アイスキュロスは、舞台上で同時に用い得る声の数が限られている事に依て、そこで止むなく、コオカサスに鎖ぐプロメトイスの沈黙を発明し得たのであります。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学徒は道楽や贅沢という危険をともなわずにホメロスやアイスキュロスをギリシャ原文で読むことができる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホメロスはかつて英語で印刷されたことはなく、アイスキュロスも、ヴェルギリウスさえもない――それらはほとんど朝そのもののように、洗練され、がっしりと作られ、うつくしい諸作品である。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、彼は偉大な文学たとえばアイスキュロス、ソポクレース、エウリピデスの「科学的想像」すなわち運命の女神が「悲劇的な出来事を不可避のこととする」に「科学が持つ洞察力」である「秩序」と同じ法則を認めている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンの交響曲、アイスキュロスの悲劇、いとものどけきクラヴサン、ヴァチカン宮殿の古代像、オルフェウス、トリスタン、キリスト受難、体操、その他すべてのものが踊られています。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスキュロスは家の下敷になって死ぬぞと脅かされてから、始終野天に暮したが駄目だった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詩人のアイスキュロスが、アキレウスとパトロクレスとの愛を描くにあたって、なお青春の花の咲き出でようとする年頃にあり・ギリシア第一の美男と言われた・あのアキレウスの方に愛する者の役目を与えたことを、大いに責めている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
