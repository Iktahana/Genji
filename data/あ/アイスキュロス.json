    "definitions": [
      {
        "index": 1,
        "gloss": "Aeschylus (525-456 BCE; ancient Greek tragedian)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
