          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "応募者の試験委員たちの採点表中に容貌の条項はあっても腕の条項がないかもしれないが、少なくも食堂の場合には、これも一つのかなりの程度まで考慮さるべきアイテムとなるべきものかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大創出版は、三〇冊の「ダイソー文学シリーズ」を一〇〇円ショップのアイテムとした。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの作ったアロハ・シャツは、コレクターズ・アイテムになっているのです。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスチニャックは食事の支払いや住居費用、あるいは優美な生活を更に洗練されたものにするための必須アイテムの購入といったやむを得ない金の必要に迫られた時、別に大胆さや工夫を凝らした手順というものはないのだが、気がつくと彼はそこへ行っているのだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
