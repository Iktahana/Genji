        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アパルトマンについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアパルトマンは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアパルトマンについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアパルトマンの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアパルトマンが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアパルトマンを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアパルトマンが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアパルトマンが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアパルトマンは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアパルトマンは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアパルトマンは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアパルトマンについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アパルトマンの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアパルトマンの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアパルトマンの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また高いアパルトマンの間の谷底のような狭い露路について忍び込んで来て、其処をわずかにのぞく空の雲行を眺めながらも唄う。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つものアパルトマンの窓から、女や男や子供がのぞく、覗かないで窓の中でしんと仕事をしながら聴いていて手だけ窓から出し、小銭を投げてやる者もある。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは英介氏のむかし馴染みの女友だちがたずねてやってきて、英介氏を郊外の酒場へさそったり、彼女たちのアパルトマンでポーカーを一晩中やったり、英介氏にタキシードを着せてテッフィン（レストラン）に連れだしたりしたからだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭旅宿の留学生臭い生活を離れて格安ホテルに暫らく自由を味ってみたり、エッフェル塔の影が屋根に落ちる静かなアパルトマンに、女中を一人使った手堅い世帯持ちの真似をしてみたり、新吉は巴里を横からも縦からも噛みはじめた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき一七八八年以来の記録にない氷の風が北極から露西亜と波蘭土の野原を吹き抜けて欧羅巴の主要部分の都会の記念塔とアパルトマンの窓枠とを痛そうに揺すぶっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の食費――油代――とそれから運転手の食糧、車の手入れや運転手の宿泊料、チップ、グラアジ費その他は一切こっち持ちで、ほかに巴里十六区のアパルトマン代ほどに高い借賃を払わなければならないのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里のアパルトマンの屋根の下に籠っていることも、靴を穿いて石造りの歩道を歩いていることも、ほんとうに休息というものを知らない彼に取っては殆ど同じことであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "着くと早々フランが高くなった為に、私は毎日々々アパルトマンの七階の部屋で雑文を書き、巴里へ送って来た金を逆に日本の両親のもとへ送らなければならなかったのです。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに噪狂なダンス・レストランの「隅の卓子」ででも、または街路樹のさきが窓の下に揺れてるＣＯＺＹなアパルトマンの一室ででも、彼はただ「空っぽの恋愛」に埋没するだけで、どうにも動きがとれなくなるにきまってる。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "デュトオ街のアパルトマンから、近所のパストゥウル研究所に通ふ、あの朝夕の、すがすがしい、そして、また一方では、いひしれぬものうい気分にとらはれた、あのパリの生活である。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは、ホテルのアパルトマンに属する贅沢なサロン。",
              "citation": {
                "source": "音の世界",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "手形ぬきの正貨取引で、アパルトマンの裏庭にひきだされ、頭蓋骨に四五径の拳銃弾のブローカー・レージがつくんだ……クロイドン行の一便の座席を予約したが、それをやると、えらいことになる」「手紙ではだめなのか」「三池のことだから、電話にも寄りつけないような状態にしてあるのだろう。",
              "citation": {
                "source": "川波",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一箇所、これも泰造が教えられたアパルトマンがあって、そこへは多計代も一緒に見に行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家具も直接的でパイプ椅子がおいてあるアパルトマンの室の天井は、思いきり低くて、風通しもよくなさそうだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアパルトマンの「最新式」は、要するに四階のところを五階にして、室数をふやしたための云いわけにすぎなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルヴァール・ペレール四七番の四階にアパルトマンが見つかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに、このアパルトマンが多計代の気にいったのは、何とよかったろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々の親たちとつや子とが、ホテル・アンテルナシオナールから、ブルヴァール・ペレールのアパルトマンに引越すのが十六日で、伸子は、引越しに必要なシーツだのテーブル・クローズなどを買うために、いそがしく百貨店を歩いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここならアパルトマンの表口にさえ立っていれば、ブルヴァールを通るタクシーをいつでも、誰にでも、つや子にだってとめることができるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパルトマンにうつってから、つや子は気がむくと手伝う場所ができ、自分としての部屋もできて、いくらかたのしそうだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伸子はいまパリにいてペレールのアパルトマンへ日に一度は顔を出し、親たちや弟妹とブーローニュの森の散歩だの、ルナ・パークでの他愛ない遊びにつれだったりしているから、もう東支鉄道問題がどうであろうと、泰造にとってそれは外国でよむ一つの新聞記事にしかすぎないのだろうか。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　街々のマロニエの緑の色をこころよく甦らせて夕立があがった日の午後五時すぎ、伸子はペレールの両親のアパルトマンを訪ねた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来て……」　つや子のその様子は普通でないのに、アパルトマンは、しんとしていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパルトマンに引越して来てから、白地｜錦襴の包みものは、夫婦の寝台の枕元の台の上におかれているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子のてぢかななやましさと混乱は、ブルヴァール・ペレール四七番地のアパルトマンにあった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家でパリへ来て、アパルトマンをかりて、通いの手つだいをつかって暮している。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度そのとき、アパルトマンの廊下で電話のベルが鳴った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けの沈黙が、やや古風な家具調度の明るく照らし出されたアパルトマンの客室にみちた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多計代が、保の分骨を錦につつんで、まるでそこに一人の人が存在しているようにつれて歩き、ホテルの室でもアパルトマンでも特別な置場所を与えていることも、親たち夫婦のこんどの旅行についてのある心持の表現かもしれなかった――保にもパリやロンドンを見せてやっているのだという。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子と素子とが、ペレール四七番地のアパルトマンを出て、同じブルヴァールの並木はずれに洒落た軒ランプを出している小さなホテルに部屋をとったのは、かれこれ午前一時だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
