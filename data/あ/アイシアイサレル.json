        "examples": {
          "standard": [
            {
              "text": "毎日、愛し愛されるは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛し愛されるが重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛し愛されるに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛し愛されるが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛し愛されるについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛し愛されるについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛し愛されるについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛し愛されるが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛し愛されるが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛し愛されるは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛し愛されるは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛し愛されるを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛し愛されるをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛し愛されるが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛し愛されるの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛し愛されるを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛し愛されるに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛し愛されるについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛し愛されるは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛し愛されるを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一生に一度、真剣に愛し愛される恋人を得たいと秘かな烈しい望みを抱くようになった。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し愛される女性を一人、どこかに持っているということは、強い生活力ともなり闘争力ともなった。",
              "citation": {
                "source": "白藤",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し愛される者は、やたらに酒を飲んで酔っ払うことなんかない筈ではありませんか。",
              "citation": {
                "source": "道標",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしもほかの子どもと同様に、自分のものと呼んで愛し愛されるうちを持つことを考えて、その喜びに気がくるいそうになったことがあった……それがいま自分の一家をふしぎそうにながめるばかりで、心のうちにはなにも言うことがない。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が愛し愛される者を得たという確信は、初め、伸子に、たっぷりした精神の落着きと希望とを与えた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今、その観念が心のうちにはいってくると、愛し愛される喜びがすべて害されてしまった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛し愛される者は、いつかは早晩、愛から引離される……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、自然ななだらかな発展をとげて愛し愛される幸福な身になれる条件のもとにおける、彼女の姿を、いろいろ話してきかした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分に愛し愛される男は、それこそ素晴らしい幸福を受けるのだと、自分でも思い込んでいたに相違ない。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
