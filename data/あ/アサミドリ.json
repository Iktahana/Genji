        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "白つぽい砂礫を洗ふ浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白っぽい砂礫を洗う水の浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い花を載せた浅緑の葉や、赤い花を包んだ深緑の葉の影がかたまり、盛り上り、重なり合った少しまばらなところに、女客のトオクの先がわずかにちらついて写った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "老衰して黒っぽくなりその上に煤煙によごれた古葉のかたまり合った樹冠の中から、浅緑色の新生の灯が点々としてともっているのである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、同じ場所でも、一本一本見て行くと木によって多少ずつの相違があって、ある木は一面に浅緑でおおわれているのに、すぐ近くの他の木ではほんの少ししか新芽が見えないといったようなふうである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杯状のものの横腹から横向きに、すなわち茎と直角の方向に飛び出している浅緑色の袋のようなものがおしべの子房であるらしく、その一端に柱頭らしいものが見える。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　乱れがみを※りつつ、手で、砕けよ、とハタと舷を打つと……時の間に痩せた指は細くなって、右の手の四つの指環は明星に擬えた金剛石のをはじめ、紅玉も、緑宝玉も、スルリと抜けて、きらきらと、薄紅に、浅緑に皆水に落ちた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　　　　　三十八二人寝には楽だけれども、座敷が広いから、蚊帳は式台向きの二隅と、障子と、襖と、両方の鴨居の中途に釣手を掛けて、十畳敷のその三分の一ぐらいを――大庄屋の夜の調度――浅緑を垂れ、紅麻の裾長く曳いて、縁側の方に枕を並べた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅緑のリノリュームが、室の二方を張った硝子窓から射し入る初夏近い日光を吸っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今花は散って、浅緑の柔らかい若葉になっていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "立寄りて草を分けて見れば、形｜菫よりは大ならず、六｜瓣にして、其薄紫の花片に濃き紫の筋あり、蕋の色黄に、茎は糸より細く、葉は水仙に似て浅緑柔かう、手にせば消えなむばかりなり。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏打をした宣紙に臙脂・代赭・藍・浅緑・黒など、太い縞細い縞を定規で引きまた染めると、其堺目が程好くにじんで好看を呈したが、之を板木に彫ると境界が鋭く硬くなり、且つエオジン、インヂコの絵具では日本絵具の生臙脂・藍で画いたやうな色調にはならなかつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芽麦の浅緑色も美しい。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに犬の男根のような若芽の護謨苗や、浅緑の三尺バナナや、青くて柔かな豆の葉や、深い緑のトマトの葉、褐色の鳳梨やが、朱紅色の土の上に、まるで印度更紗のように、いやそれよりも生々しい極彩色の絵模様として綴られてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、舟はすぐ楊柳の浅緑の葉の煙って見える水際の沙にじゃりじゃりと音をさした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の色は暗緑で陸近いほうは美しい浅緑色を示していた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右舷の山には樹木は少ないが、灰白色の山骨は美しい浅緑の草だか灌木だかでおおわれている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若葉の出はじめには実にあざやかに明るい浅緑色をしていて、それが合掌したような形で中天に向かって延びて行く。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若葉の出はじめには実に鮮かに明るい浅緑色をしてゐて、それが合掌したやうな形で中天に向つて延びて行く。",
              "citation": {
                "source": "木蓮",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "微赤い月の光が浅緑をつけたばかりの公孫樹の木立の間から漏れていた。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに進んで礼をする時、牡丹に八ツ橋を架けたやうに、花の中を廻り繞つて、奥へ続いた高楼の廊下づたひに、黒女の※が前後に三人｜属いて、浅緑の衣に同じ裳をした……面は、雪の香が沈む……銀の櫛照々と、両方の鬢に十二枚の黄金の簪、玉の瓔珞はら／＼と、お嬢さん。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団の外へは顔ばかり出していた、裾を少し動かしたが、白い指をちらりと夜具の襟へかけると、顔をかくして、「私、………」　　　　　浅緑　　　　　　　十二「大事ねえ大事ねえ、水浸しになっていた衣服はお前あの通だ、聞かっせえ。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が嵩じて理に落ちて、身に沁みて涙になると、お縫はさすがに心着いて、鮨を驕りましょうといって戸外へ出たのが、葦の湯の騒ぎをつい見棄てかねて取合って、時をうつしていた間に、過世の深い縁であろう、浅緑の薫のなお失せやらぬ橘之助の浴衣を身につけて、跣足で、亡き人のあとを追った。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　乱れがみを※りつゝ、手で、砕けよ、とハタと舷を打つと……時の間に痩せた指は細く成つて、右の手の四つの指環は明星に擬へた金剛石のをはじめ、紅玉も、緑宝玉も、スルリと抜けて、きらきらと、薄紅に、浅緑に皆水に落ちた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "となれなれしく書いた浅緑色の手紙を、榊に木綿をかけ神々しくした枝につけて送ったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれなゐの涙に深き袖の色を浅緑とやいひしをるべき　恥ずかしくてならない」　と言うと、いろいろに身のうきほどの知らるるはいかに染めける中の衣ぞ　と雲井の雁が言ったか言わぬに、もう大臣が家の中にはいって来たので、そのまま雲井の雁は立ち上がった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝という枝は、それぞれ浅緑の若葉と、爪紅をさした花のつぼみとを持って、また蘇って来た春の情熱に身悶えしている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、自然の色を持った若葦の浅緑の生々した葉裏などにその夏虫のとまっている所は、いかにもおもしろい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蘆の葉のおもちゃのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘴は浅緑色、羽は暗褐色に淡褐色の斑点、長い足は美しい浅緑色をしていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彈き葉のあさみどりなる、内｜紅く紫くろき、層厚く七重八重なる、葉牡丹は大いにうれし。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
