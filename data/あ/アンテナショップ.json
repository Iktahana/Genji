    "definitions": [
      {
        "index": 1,
        "gloss": "shop selling local specialties from other regions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンテナショップについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンテナショップの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンテナショップが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンテナショップについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンテナショップの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンテナショップが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンテナショップという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンテナショップについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンテナショップは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンテナショップが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンテナショップは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンテナショップの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンテナショップは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンテナショップは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
