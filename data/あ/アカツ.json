          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場分析によると需要が増加している。",
              "source": "幻辞"
            },
            {
              "text": "企業の成長戦略は多方面に及ぶ。",
              "source": "幻辞"
            },
            {
              "text": "経済指標は好調な傾向を示している。",
              "source": "幻辞"
            },
            {
              "text": "取引先との関係構築が重要である。",
              "source": "幻辞"
            },
            {
              "text": "財務部門は予算の効率化に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "営業成績が前年比で上昇した。",
              "source": "幻辞"
            },
            {
              "text": "商品開発チームは新規プロジェクトを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "経営層は戦略的な決定を下した。",
              "source": "幻辞"
            },
            {
              "text": "市場競争が激化している状況だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスモデルの革新が求められている。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どうせ目下が精神の貧寒時代であることは分つてゐますし、詩人が存外の苦吟をするのであることも分つてゐるのですから、もつとあけすけにして、もつと具体的なことを論ずることが、詩壇の急務ではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに不思議な運命のそれ自体単純にして、それを織成す無限に複雑な因子の離合の間に、今や我々に既に分つたことは、宮沢賢治は死後間もなく認めらるるに至つたといふことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のことは、自身気付いたばかりのことであるから、云ふのがくすぐつたいが、自分の今迄を顧みても、最初詩の概念が分つたと思つたが、しかし書く時には、気分が失はれる。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、今度偶然にも、自分の無力をすつかり感じ、その時から、次第に、詩といふものゝ真義も分つて来るやうに思へ出した。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、右のことが分つたので歓喜にむせぶ気持でゐるが、又一方、長年求めあぐんで、暗中模索してゐたものが、一時に分つたので、慄へてもゐるといつた状態である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、気持は、そこで一先づ安らかとなつたが、作品が熟してゆくといふことは、時日を要することであるし又、漸次のことであるから今分つたからといつて、すぐに今迄よりも好いものを書いてみせろと期待されても、六ヶ敷い。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（茲で一寸断つて置くが、ホンの少しの事が分ると、分つたことが当人にとつて余りに珍しいので却つて書けるといつたあの生々しい文学青年をも「書いてゐる奴」の中に入れて話してゐるのではない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤坊の真ん前に腰掛けてゐるのは女の先生で、尤も先生だといふことは翌朝になつて分つたので、一寸見た所では薬専か歯科医専の生徒だらうと思はれた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから握手するか、ヒツパタクか、分つたものか。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由を弁解したら、それもさうかと一応は分つたらしかつたが、それでも猶そのお説教を続けるのは、僕にやつぱり一体全体「誠意がないのか」それとも、大概の老人がさうであるやうに、たゞもう剛情なのか。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　………分つてるよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も私は自己を失つたとはその時分つてはゐなかつたのである！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし新しき男は、その後非常な勉強によつて、自分のその幼稚さを分つたらしいから、私はそれを具体的に話すことを此処でしなかつたのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分つてゐてなほ分つてゐないと同様な態度で生きてゐなければならないかゞ分らなければならない――それは人が卑屈になるからだ、必要以上に陰気になるからだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを短歌や俳句の場合でみると、大衆は今後歌人なり俳人が書いて呉れようと呉れまいと、書いて呉れるとすればどういふ「型」のものを書いて呉れるかゞ分つてゐるし、従つて大衆の期待があると云へるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく「ああいふもの」と、貴方にも私にも互ひによく分つてゐるから「ああいふもの」なのですが「ああいふもの」だといふ以外に、此の場合他の如何なる言葉も帽子の属性なり用途なりの指示に止るほかはないでせう。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし分つたとしても、それが生活人自身にとつて何にもならぬことから、分らないよりもつと悪い結果を起すだけのものである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私にも、これだけのことは分つてゐる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは分つてるけれど、併し他所の親は皆々お母さん程極端ぢやあない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕にも分つてゐますがね。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偉い事の出来る人間だつたら中学のこと位分つてゐる筈だのに、中学はまづくてその上のことが分つてゐるなんて、一寸考へたつて馬鹿げたこととは思へないのだらうかねえ、あんたは。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の詩のモチーフはヒュマニティではなく、　言はゞ、「俺は全てが分つて生きてゐるのに、人々は分らないで俺と同一平面上にゐる」といふことのやうだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して人気商売の、殊には此のプロパガンダの時代に於て、彼等が悪口の種にならぬ限りに於て自己独特の奇態を流行させようなどゝいふ野望を常に抱いてゐるといふこともよく分つてゐよう。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな芸術ゲの字も分つてゐない奴等なんですよ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度目はまだ好い所へゆくつて気もあつたから元気だつたが、今度はもう目的地が一通りや二通り分つてゐるためでもあつて、やたらに家のことが後から後から頭に出て来た。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それが何かは分らない、つひぞ分つたためしはない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつきや破れし鐘樓に。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかつき覺めにけり菊の露",
              "citation": {
                "source": "秋の日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "県会議員が、当選したあかつきには、百姓の利益を計ってやる、というような口上には、彼等はさんざんだまされて来た。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あかつき眠るみどりごを〕あかつき眠るみどりごを、　　　ひそかに去りて小店さき、しとみ上ぐれば川音や、　　　　霧はさやかに流れたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
