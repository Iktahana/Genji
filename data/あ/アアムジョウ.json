        "examples": {
          "standard": [
            {
              "text": "毎日、ああ無情は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンではああ無情が重要です。",
              "source": "幻辞"
            },
            {
              "text": "ああ無情に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではああ無情が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室でああ無情について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師からああ無情についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律ではああ無情について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合ではああ無情が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではああ無情が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にああ無情は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理においてああ無情は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にああ無情を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時にああ無情をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議でああ無情が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、ああ無情の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者はああ無情を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章はああ無情に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断でああ無情について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点からああ無情は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートはああ無情を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『一八六一年、ユーゴウはこの家に滞在して、あの「｜ああ無情」のなかのウォタアルウのところを書いたんです。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "無宿者の歩みつく道一面の広野と化した巷の風ああ無情の風と歎く我身なり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　その時のセリフは、メモに曰く、「ああ無情、ああ……」　三高泣く。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ無情、ああ……」　三高手足をバタつかせて、もがき、また泣く。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ああ無情の著者ビクトルユーゴーは、自殺者ではなかった。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながら「ああ無情」と喚いたのは、酔ッ払いの単なるウワゴトとは思われない。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだん通俗な雑誌しか読まない男が、俄かに「ああ無情」や芥川や太宰を読むのはタダゴトではない。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺文士の本に何らかの読む理由があったように、ああ無情も読む理由があったのは云うまでもないね。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ無情と云ってるだけじゃないか」「放さないでくれ、ああ無情と云ってますよ」　と巨勢博士はニヤニヤ笑った。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とヤケの演説をしながらも、酔えば、ああ無情、話してくれるな、と泣くのです。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
