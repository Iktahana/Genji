          ],
          "literary": [
            {
              "text": "が、近頃は格別あせつて書かうとも思はず、無理に書いたところでいいものが書けようとも思つてゐない。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ中で、人知れずあせつたりぐれたりしながら、東へ走り西へ飛ぶ。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泥にうつぶして、いまこそおいおい聲をたてて泣かう泣かうとあせつたけれど、あはれ、一滴の涙も出なかつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と坂上の呼吸はあせつた……「親が大病だか、友だちが急病だか、知れたもんですか。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松村は追々時間が経過して行くことをあせつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ぽつちの幕の中で、俺はこの女を引きいれて、限りない欝憂から逃れたいとあせつて居たときでも俺はある大切なもの、唯一なものを、まだ彼に慝して居たのではないか。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度も斬りつけようとあせつたが、武士は刀をどうしても抜けなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門は、一時は自分から進んで難かしい経典などに親しみ、早く何事かを探り当て、どうにかして救はれようとあせつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はなほ委細に彼の身辺に何か業因らしいものを認めようとあせつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政枝の唇が青紫に色あせつつぴたぴた唾の玉を挟んで開け閉している。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥はそんなことは知らう筈なく、ただ小羊のやうにおとなしく、義雄が目を鋭くして海の方へとあせつて行くのに附いて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思へば、いくらあせつてもたツた三四枚しか出來ないこともある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸りたいとばかりあせつてゐるお鳥は、最初の短篇に對する金が電報がはせで來ると直ぐ、獨りで歸京することになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥があせつて歸つたのには、既に打ち合せが出來てゐたのではないか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "将棋を指すときは、怒つてはならない、ひるんではいけない、あせつてはいけない。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の黒髪の中の大理石のやうな顔を見ると、小さな者はハヤ震へ上つて、振※らうとして身をあせつて、仔雀の羽うつ風情。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は狼狽して嵌めやうとしたが船の動搖が激しいので幾らあせつても嵌らぬ。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "また殆んど衆人監視の中のこの針金切断の仕事は、瞬間的である必要があつたし、遂あせつて二本、三本を切つて立像の前で時間をかけて失敗をすることを極度に怖れたのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "物体のもつ色と、油絵具のもつてゐる色との両者の制約を解決することができずに、二つの色の制約をそのまゝ絵に出してゐるといふ感ありで、この作家は少しあせつてゐる安宅式の鈍重感は捨てがたいものなのに己れの良さを彼は軽蔑してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、文壇に出ることをあせつては居なかつたから、先輩を訪問したり、原稿を持ち廻つたりしなかつた。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等に取り入る一つの手段として、何か一つ自分も相当の知識を披瀝したいものだ――私は、無暗とあせつたが、凡てが夢になるより他になかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い頃にはいくらあせつても、実人生のことには容易に本当に触れ得るものではないのである。",
              "citation": {
                "source": "私の考へてゐる事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "うめの花はつはつ咲けるきさらぎはものぞおちゐぬわれのこころに梅の花さかり久しみ下｜褪せつ雪降りつまばかなしかるらむ梅の花褪するいたみて白雪の降れよと待つに雨降りにけりうめの花あせつつさきて如月はゆめのごとくになか過ぎにけり　これらはその次の集『朝の歌』に出てゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "握りこぶしを固めた組合員が輪の外から、それを乘り越さうと、あせつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その代り少しでもあせつたらお終ひだ。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こつちも、あせつてはならないぞ。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上妻君との間にはさまれたら、私は慌てたりあせつたりするばかりで、折角出来かゝつた塑像が台なしになつてしまふやうに、私の夢も姿も紙屑となつてしまふであらうと怕れはぢめた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀口や継母や篠谷達もこれに目をつけて、鍵の在所を家探しゝてゐるさうだつたが、そして彼等も亦百合子に依つてそれを尋ね出さうとあせつてゐたが、百合子は飽くまでも空呆けて、「それはお父さんでなければ解らないわ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも併しまた陽炎のやうに消えて、日々の營みに追ひつかれまいとあせつてゐるやうな、餘裕のない家内の空氣に息づまるやうな思ひをした。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
