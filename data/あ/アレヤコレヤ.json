          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日彼や是やについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は彼や是やの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には彼や是やが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは彼や是やについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は彼や是やの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では彼や是やが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に彼や是やという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では彼や是やについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると彼や是やは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では彼や是やが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に彼や是やは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により彼や是やの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "彼や是やは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に彼や是やは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――就いては、先日より何か送りたくと存じながら、彼や是やにひかされて今日まで延引いたし、誠に不本意に御座候。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へば平凡なこととなるけれど、あれやこれやの作品が、その読む人の人格といふ点で関連し合ひ、ひいては文学一般の了得が、その人なりに満足され、つまり、競技に勝つだけでなく、そのフォルムも自分にとつて決定的である筈のものが最後的に探索されねばならないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "云換れば、其の西欧二千年の文献の、そのあれやこれやが、誰かの口によつて少し唱へられさへすれば、人々はその方へドヤドヤと寄り、それを一通り見た頃にはもう飽き飽きしてゐたのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にそのあれやこれやの一部分を書き並べます。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の日向に床をひかせて起上り、食べ度いと思うものをあれやこれや食べながら、くめ子に向って生涯に珍らしく親身な調子で言った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が帰つてから、ひとりでくらやみで、あれやこれやといつまでも考へてゐた、……寝苦しかつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松」の裸木追悼号を読んで、あれやこれや考へさせられた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやこれやと東上準備、なか／＼忙しい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のさぎ師はあれやこれやと新しい服を着つけるふりをしました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はこの頃から早熟の青年らしく人生問題について、あれやこれや猟奇的の思索に頭の片端を入れかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉露の壺は単に看板で、中には何も入つてなく、上茶も飛切りは壺へ移す手数を省いて一々、静岡の仕入れ元から到着した錫張りの小箱の積んであるのをあれやこれやと探し廻つて漸く見付け出し、それから量つて売つて呉れる。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその下から例の癖が出て、わたくしはあれやこれや心の中に思い耽って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも肺病薬にしろ、もっと良い新薬が出て来たし、それに世間も悧巧になるし、あれやこれやで、これまで手をひろげた無理がたたったのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川とても、同じ気持であろうか、他愛ない話を、あれやこれやとしながらも、容易に腰を上げかねていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやこれやで、十六年間あらゆる新聞社が彼を引きださうとして失敗したのも、無理はなかつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は廿分間ばかり、あれやこれやと考えてみて、何か心に思い当ることを見つけようと思って、じっと坐っておりました。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで夜のあれやこれやで疲れていたのだ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "座ったまま二十分間ほど、あれやこれやと考えてみて、それらしいわけを探してみました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなふうに、あれやこれやとかんがえるのも、もっともなことでした。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『他人はあてにできない』理論を応用すれば、日本語のあれやこれやに取り組んでいくのは、どこまで行っても日本人となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがオレは、マッキントッシュ絡みのあれやこれやが世界中から集まってきたマックワールド・エキスポ／東京の会場で、あらためて世界と共通のプラットフォームにのっていることの意味をしみじみ思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを瑣末なあれやこれやにこだわれば、大局を見失うに決まってるじゃないかと考えて、ＤＯＳ／Ｖ音頭歌い上げとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生のあれやこれやにもあてはまりそうな、もっともらしいことが書いてあるではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来世の中のあれやこれやが不安の種となって、コンピューター界の動きも一つ一つがどうにも恐ろしくてたまらない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすが決戦だ、未来だ、新潮流だとあれやこれや思い付くかぎりのネタで大騒ぎしてきた高血圧マガジン！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところ、コンピューター村のあれやこれやへの不平不満、皆々様への文句ばかりを書き連ねてきた格好のコラムの何回目かにペン・コンピューティングを取り上げたところで、オレは「これで一まとまりついたのかな」と唐突に思い始めていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "槇園君も、あれやこれやと手にとりて見たるが、掘出しものは無かりけむ、共に失望して出づ。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやこれやといろ／＼押問答がやや久しく續けられてゐたが、終には喧嘩かとも思はるるばかりの烈しい大聲を張り上げるやうになつて來た。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か物をいいつけるような形になってこれまた私の性として好まぬところ、あれやこれやにてどうも面白からず思いましたので、これはこの辺にて、もはや見切りを附けるところか。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "別して医の道は大の好物ゆえ、御領内みなの衆にあれやこれやと医療を授けているうちに、何かと相談を持ち込むようになったのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
