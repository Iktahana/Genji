[
  {
    "uuid": "c6b046af-089b-573b-be1a-93ac930575dd",
    "entry": "粟粒",
    "reading": {
      "primary": "あわつぶ",
      "alternatives": [
        "ぞくりゅう"
      ],
      "is_heteronym": false
    },
    "grammar": {
