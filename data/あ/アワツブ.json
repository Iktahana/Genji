    },
    "definitions": [
      {
        "index": 1,
        "gloss": "millet grain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日粟粒について考えている。",
              "source": "幻辞"
            },
            {
              "text": "粟粒という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は粟粒の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には粟粒が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "粟粒を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは粟粒について学習した。",
              "source": "幻辞"
            },
            {
              "text": "粟粒の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は粟粒の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では粟粒が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "粟粒という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に粟粒という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では粟粒についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "粟粒を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると粟粒は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "粟粒について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では粟粒が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に粟粒は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により粟粒の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "粟粒は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に粟粒は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向うの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらいの活字を次から次と拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向こうの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと、小さなピンセットでまるで粟粒ぐらいの活字を次から次へと拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはその人の椅子の足もとから一つの小さな平たい箱をとりだして、向うの電燈のたくさんついたたてかけてある壁の隅の所へしやがみ込むと、小さなピンセツトでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左肺が肺癆に罹つて大部分腐蝕してゐるのは誰れも認めてゐたが、一週間程前から右肺の中葉以上に突然起つた聽診的變調と、發熱と、腹膜肋膜の炎症とを綜合して考へて見ると粟粒結核の勃發に相違ないと堅く信じたのだ。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "咯血が直接の死因をなしてゐると云ふ事も、病竈が血管中に破裂する粟粒結核の特性を證據立てゝゐるやうに思はれた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し死因が粟粒結核なら他の諸機關も犯されるのだから肺部だけですますわけには行かないと彼れは云つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば膿化した粟粒が肺の切斷面や腹膜やに顯著に見られたら愉快だらうと彼れは思つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾酪性肺炎か粟粒結核か、事の眞相を否應なしに定むべき時が來た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "著しく擴大した脾臟を割いて見ると粟粒状の結節を到る所に發見した。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中部到る處に粟粒状結節あり」　彼れは冷靜に報告した。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は肝腎の右肺部を檢査しようかと思つたが、粟粒がどの位廣く結成されたかを確めるために頭蓋骨を開いて腦膜を調べて見たくてたまらなくなつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが診斷した通り中葉以上の患部の稍粗雜な海老茶色の表面には、咯啖樣の色をした粟粒がうざ／＼する程現はれ出た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粟粒結核の結果と見るを至當なりとす」　昂然として彼れは記録者の方に向いてかう云つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の死因が粟粒結核であるのを確めて、たつた先刻心ゆくまで味つた近頃にない喜び――一つは自分より熟練だと考へられてゐる多數の先輩に對して見事に占め得た勝利の喜び、一つは自分の妻の病症の眞相をしかと確めて何にともなく復讐をしおほせた喜び――その喜びは跡方もなく消えてしまつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しく切ない稲妻がもぬけの私の身体の中を駆け廻り、ところどころ皮膚を徹して無理な放電をするから痛い粟粒が立ちます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけの頬は、やつぱり赤くて、さうして、右の眼蓋の上には、小さい罌粟粒ほどの赤いほくろが、ちやんとある。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（微笑む）粟粒を一つ二つと算えて拾う雀でも、俄雨には容子が可い。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しく切ない稲妻がもぬけの私の身体の中を駆け廻り、ところ／″＼皮膚を徹して無理な放電をするから痛い粟粒が立ちます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小供の背丈けほどもある昼間見ると藜※のような草と粟粒のような微紅い実をつけた草がぎっしり生えた住宅地の入口に、人の足によって通じた一条の路がうっすらと微月の光に見えていた。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "儂はこれを思うごとに苦悶｜懊悩の余り、暫し数行の血涙滾々たるを覚え、寒からざるに、肌に粟粒を覚ゆる事｜数政府の改良に熱心したる所以なり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、かの怪しい奴らの来たらしい跡をさがしてみると、東の古い階段の下に、粟粒ほどの小さい穴があって、その穴から守宮が出這入りしているのを発見した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が天地の間に介在して粟粒一つ攫へるのに生涯の努力を要するのだといふやうなことをも思はしめた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして此の峽谷を出る時其粟粒の千百萬分の一でいゝから攫へて行かうと思つて改めて奮發の念を起した。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術と云ったようなものに、粟粒ほどの理解も持っていない父が悲しかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さすがの退屈男もぎょッとなって、総身が粟粒立ちました。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "花と云つてもほんの粟粒ほどの大きさで、同じくこまかなしなやかな冬枯の枝のさきにつぶつぶとして黄いろく咲きいづる。",
              "citation": {
                "source": "花二三",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術と云つたやうなものに、粟粒ほどの理解も持つてゐない父が悲しかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれをあれを、あそこの、あ、あ、あれをよくごらんなさいまし……」　歯の根も合わぬように震えながら、ひたかくしに顔をかくして指さした方角をちらりと見ると、さすがの名人右門もおもわずぎょっとあわつぶだちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
