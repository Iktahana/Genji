[
  {
    "uuid": "019f7a18-1100-5852-9965-3cf910b208b5",
    "entry": "改まる",
    "reading": {
      "primary": "あらたまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be renewed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日改まるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "改まるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は改まるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には改まるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "改まるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは改まるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "改まるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は改まるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では改まるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "改まるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に改まるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では改まるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "改まるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると改まるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "改まるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では改まるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に改まるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により改まるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "改まるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に改まるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "街道の並木の松さすがに昔の名残を止むれども道脇の茶店いたずらにあれて鳥毛挟箱の行列見るに由なく、僅かに馬士歌の哀れを止むるのみなるも改まる御代に余命つなぎ得し白髪の媼が囲炉裏のそばに水洟すゝりながら孫｜玄孫への語り草なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺の火は燃え出した、その明るくなることは、花が発くのと同じで、万象の色が真の瞬間に改まる、槍と穂高と、兀々した巉岩が、先ず浄い天火に洗われて容を改めた、自分の踏んでいる脚の下の石楠花や偃松や、白樺の稚いのが、今眠から醒めたというように朝風に身振いしてソヨソヨと顫った、天地皆新しい。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は新春の屠蘇機嫌からいささか脱線したような気味ではあるが、昨年中頻発した天災を想うにつけても、改まる年の初めの今日の日に向後百年の将来のため災害防禦に関する一学究の痴人の夢のような無理な望みを腹一杯に述べてみるのも無用ではないであろうと思った次第である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三稿　明治の年号が大正に改まる二三年前。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が「たとえば哥仙は三十六歩なり、一歩もあとに帰る心なく、行くにしたがい、心の改まるはただ先へ行く心なればなり。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴誨を蒙らずして、星霜多く改まる、渇望の至り、造次に何でか言さん。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と莞爾して、「貴方、」と少し改まる。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々の季節につれて四辺の風物も改まる。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀家は肥前守斉広卿の代が斉泰卿の代に改まる直前である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源十氏は屡々これらの野卑極まりもない風習に関して、悲憤慷慨の演説を開きますが、一朝一夕に永年の習慣が改まる筈のものでもなく、稍ともすれば氏の前でその仇名を呼ぶ者に出会つては叱咤の声を枯らしつゞけてゐる始末です。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしある期間を過ぎても、両人の醜行改まる模様なき時は、本紙は容赦なく詳細の記事を掲げて畜生道に陥りたる二人を懲戒し、併せて汽船会社の責任を問う事とすべし。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔見世狂言にひどい不評を招いた中村七三郎は、年が改まると初春の狂言に、『傾城浅間ヶ｜嶽』を出して、巴之丞の役に扮した。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　折々の季節につれて四邊の風物も改まる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が改まったと云って、すぐに世のなかが改まるわけでないのは判り切っているが、それでも年があらたまったらば、心持だけでも何とか新しくなり得るかと思うが故に、こんな不祥な年は早く送ってしまいたいと云うのも普通の人情かも知れない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門学校が第四高等中学校と改まると共に、四高の学生となったのである。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説ならば、編が改まるところである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年があらたまったといって、すぐに世のなかが改まるわけでないのは判り切っているが、それでも年があらたまったらば、心持だけでも何とか新しくなり得るかと思うが故に、こんな不祥な年は早く送ってしまいたいというのも普通の人情かも知れない。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にも彼女と等しくその必要はあつたのだが私は、一寸と改まるとなると普段の会話でも、行儀正しく向ひ合つては酷く駄目な質で話の出来ないことには慣れてゐたから、そんな練習はいらないと思つた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年も押迫つて、あと半ヶ月となつた、庵には節季もなく、随つて正月もないのであるが、年の改まるを機として、生活のくぎりをつけなければならないものが、私にもないことはない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が西洋へ行ったからといって、それ等のものが遽に改まるわけのものではあるまい。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服も改まるわけでなく、食べものもずっとゆく先々で京都にいる時とあまり変らぬ日本料理がいただけたし、身体にも気持にも大した変化もなく旅を続けることが出来た。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の子の綿入を袷に脱ぎかえて、更衣の新たなるを欣ぶこころは、家に青簾掲げて棲心地の改まると同じく、別けても山の手は近郊に接するほど、簾かかげて時鳥待つの楽しみもあり、江戸ッ児には何ぼう嬉しいか知れぬものだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶節物の改まるに逢つて、二人は排除の力に一策励を加へてゐたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれを見ても、年の改まる用意に、幾らかの潤飾を加えて、店に立ち働いている人さえ、常に無い活気を帯びている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來で煙草を吸つたもの、込み合ふ中で人を押し退けて進まうとしたもの、そんなのまでを直ぐ引つ捕へて、打首にするならば、火事は半分に減ずるし、世の中の風儀は忽ち改まるであらうと思つた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "心細い悲しい生活が改まるような春の来ることが待たれますよ」　などと言っているのが聞こえる。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "異なるゆゑなくて、たやすく改まるべくもあらねば、これを世の人、たやすからずうれへあへるさま、ことわりにも過ぎたり。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、どのくらいじだらくな上下の風俗が、改まるかわかりません。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、わたくし、急にあらたまるあなたの口調おかしくて、ふとんかぶってこらえてばかりいました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの三寶ヶ辻まで引返すと、丁どいつかの時と殆ど同じ處、その温泉の町から折曲一つ折れて奧の院參道へあらたまる釣橋の袂へ提灯がふうわりと灯も仄白んで顯はれた。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
