        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "危なっかしいについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "この危なっかしいは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人が危なっかしいについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家は危なっかしいの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界では危なっかしいが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景から危なっかしいを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でも危なっかしいが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野では危なっかしいが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でも危なっかしいは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でも危なっかしいは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中で危なっかしいは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時に危なっかしいについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "危なっかしいの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連する危なっかしいの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会では危なっかしいの理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紅の花が白く咲いているうちは俺の怨みが残っていると思えってそう云ったんだそうで……でげすから只今でもその焼跡に咲いておりますくれないの花だけは御覧の通り真白なんだそうで御座います」「プッ……夏向きの怪談じゃないか丸で……どうもお前の話は危なっかしいね。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその危なっかしい血統が、龍太郎の誕生によってヤット繋ぎ止められたと思う間もなく、龍代自身の肉体に、早くもその忌まわしい遺伝病の前兆が、あらわれ初めたことがわかりましたので、まことに申訳無いが貴方に……つまり私にですね……情ない姿をお見せしないうちにお別れする決心をしました。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝平の、馬に就いての危なっかしい知識や技術は、最早、彼の生活を幾分かは助けているのであった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その田の中の畦道を、眼の前の道路から一町ばかり向うの鉄道線路まで、パラソルを片手に捧げて、危なっかしい足取りで渡って行く一人の盛装の女がいる。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな危なっかしい妃を迎えて生命を堕すような事があっても、根がお話しだからちっとも差し支えはない。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして作者の表現力と、豊かな常識と、努力とが三拍子そろっていて、危なっかしい、たどたどしいところが微塵もない点である。",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、危なっかしい足元がやはり地上に縛られている癖に星の世界ばかり覗きたがるこれらの人を笑うであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから危なっかしいトタンの端であちこちしていた二羽の鳩が、前後して線路に下りたかと思うと、すっぽかすようにすぐに一羽がトタンへ戻った。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "危なっかしい折には、そっと片手で押えていてもいいのです。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方を注意深く見廻すと、自分一人で危なっかしい岩角を辿って水際まで降りて行った。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（探偵小説……小説としても……事実としても……何だか間違ダラケのような危なっかしい気がしますなあ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この世の中には芝居以上に真剣な、危なっかしい事がイクラでもあります。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処まで登るには、細いザラザラした砂岩を削ってつけられた危なっかしい小径を、うねうねと登って行くのであるがしかし、さて登り切って見ると、其処からは相模湾が一望の下にくり展げられて、これが昼間であったならば、どんなにか素晴らしい眺めであろうと思われた。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "危なっかしい早瀬を渡るような足取りで、ベットからはなれたのだ。",
              "citation": {
                "source": "蝕眠譜",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中は、真暗なのだが、慣れたわが庵のこと、爪先さぐりで、危なっかしい縄梯子を下りてゆくと、平らな板じきになる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元が薄暗くて危なっかしい。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分で登りたいんだけど、危なっかしいから、代りに登ってみてよ。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行が湖水を潰すか、湖水が銀行を潰すか――つまり、この文句の意味と用途は、危なっかしいことだが、どっちが勝つか、傍観していて、面白い見物だというのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "危なっかしい手つきで、それを掻き集めては例の土蔵の戸前へ持って来て、無暗に積むものだから、忽ち小山のように盛り上げてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて廻るならまだいいが、時としては、それに引きずられるような危なっかしいことさえしばしばあるのには困る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸太を組んだ危なっかしい橋がそこの流れに渡してあり、ちょうどその向い岸に、四本の低い杙を脚にした納屋がある。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "補祭は用心しながら、濁流の鬣がもう届きそうになっている危なっかしい橋を渡り、小さな梯子を攀じ上って乾小屋の中へはいった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるから危なっかしいその手つきに、いまにも段取りを間違えドジを踏みはしないかと圓朝、今尚自分の弟子であるかのよう。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯氏はステッキで道をさぐりながら、危なっかしい足つきで歩いてゆく。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「先生」はわたしの危なっかしいのを見て、かれの胸にわたしの頭をつけて、わたしのからだをうででおさえてくれた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが更に甚だしい者になると、器体をさかさまにしても、木米の作である限り蓋が口べりに引っ掛かって、容易に落ちて来ないなどと、我も我もと危なっかしい手つきで、その実験を試みる。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "海面から高く上がった所、まさに海と空の間に一筋の小径があって、剥き出しのまま大いなる崖の肌に張り付きうねうねと不規則に上り下りしているのだと――見るだに危なっかしい細く急な小径で、空中に伸びる縄か糸のように、餓えにわななく水面と空との間に垂れていた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな危なっかしい所に俺はいったい何をしに来たんだろう？",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い覚悟で行った札幌は暖かすぎて、下手なあぶなっかしい講演をやっていると額に汗ばんだ。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく「嘆きの天使」を見ているときのようにあぶなっかしい感じはちっともなくて楽に見られる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
