        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案の定について考えている。",
              "source": "幻辞"
            },
            {
              "text": "案の定という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案の定の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案の定が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案の定を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案の定について学習した。",
              "source": "幻辞"
            },
            {
              "text": "案の定の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案の定の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案の定が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案の定という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案の定という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案の定についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案の定を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案の定は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案の定について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案の定が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案の定は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案の定の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案の定は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案の定は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし案の定なんにもいない。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして案の定落ちてしまう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、案の定、雄はその烈しい鳴き方をひたと鳴きやめたと思う間に、するすると石を下りて水を渡りはじめた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その事を話し出すと、それ、案の定、天井睨みの上睡りで、ト先ず空惚けて、漸と気が付いた顔色で、「はあ、あの江戸絵かね、十六、七年、やがて二昔、久しいもんでさ、あったっけかな。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早縄をかけたまま横の山道へ担ぎ込んで、懐中物を取上げてみると案の定、蔵元屋の身上調べと、黒田藩のお納戸の乱脈を細かに調べ書きにしたものが、貸付証文と一緒に在ったわい」「あっ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして深いドブの処まで誘って来ますと、案の定鳥さしは夢中になってドブの中に落ちました。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　案の定その翌日は雪に夜があけた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、可厭な、可忌しい聲を聞かずには濟むまい、と思ふと案の定……　來て、其の行逢つたものは、一ならびに並んだ三｜人づれで、どれも悄乎とした按摩である。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、あの人が帰って来るなり、はしたないことだが、いきなり胸倉を掴まえてそのことをきくと、案の定、言いそびれててん、とぼそんとした。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、上着もチョッキもなかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、一度だけこの店へ、「まだ、店をひらいているだろうか」　と、心配しながら来てみると、案の定灯がついていて、ほっとした――というよろこびのせいだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定脱衣場で見た顔だった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、「あいつ、女みたいな声でうたつてたよ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　案の定、忘れてしまつてゐる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると案の定、老紳士は、「どうも弱いので、これは中学だけで、よさせましてな」と云ったが、格別息子の未成熟に心を傷めたり、ひけ目を感じている様子も見せず、普通な大きい声だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人の調子は案の定、今口に出した思い付きの一言に煽られてそれ者らしい飛躍を帯びて来た。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは政宗も万々合点していることだから、其年の暮には上方の富田左近｜将監や施薬院玄以に書を与えて、何様なものだろうと探ると、案の定一白や玄以からは、会津の蘆名は予ねてより通聘して居るのに、貴下が勝手に之を逐い落して会津を取られたことは、殿下に於て甚しく機嫌を損じていらるるところだ、と云って遣した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか來てやしまいとは思つたが、其處は欲目で行つて見ると、案の定ゐなかつた。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、その場から、思いが叶うた、お二人さん。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父殿が工夫の絵図面、暇にあかして遣つて見て、私が先づ乗つて出たが、案の定燃出したで、やれ、人殺し、と……はツはツはツ、水へ入つて泳いで遁げた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝわね、十歳も年上の女のあとを追って、山又山の奥へ、手鍋を提げる助手に行くなんて、とんだ色気のある園芸手だわ」　案の定、葛岡は「なに、安宅先生へいろ気」と振返り、わたくしのわざとする勘違いを真正面に取って受け、その無理解の口惜しさに殆ど力も脱かれたらしく、逡巡して、はー、と息を吐きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉は案の定、小学校の運動場で体操をしていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、佐助はさすがに白雲師匠の教訓を忘れなかったのか、鳥人の術なぞ知った顔は一つも見せず、専らアバタの穴だらけの醜い顔を振りまわして行くと、案の定人に好かれた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定、妹が婿養子を迎える婚礼に出席を撥ねつけられたといって、柳吉は気を腐らせ、貯金の中から二百円ほど持ち出して出掛けたまま、三日帰って来なかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、貴子がただ女友達と二人きりで乗ったとすれば、章三のその計画も無意味なものになってしまうところだったが、案の定貴子は上品な顔立ちの青年と二人空いた座席へ並んで腰を掛けた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶるぶる震えて行くと、案の定朝の客が河豚料理に中毒して、四人の内三人までは命だけくい止めたが、一人は死んだという。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定東京へ帰って間もなく、武田麟太郎失明せりという噂が大阪まで伝わって来た。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「‥‥」「そこの駄菓子屋の娘が丁度あいつが這入るところへ出くわしたさうです――藥り瓶を提げて、いやな顏をしてイたさうだから、きツとあなたのが、案の定、移つたんでしよう――？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとおあにいさまは、あんのじょう、命のことをねたんで、いくどとなく殺しにおいでになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんのじょう、もうさっそく、むこう見ずの若い、ばか兎が一ぴき、その袋の中へとびこみました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
