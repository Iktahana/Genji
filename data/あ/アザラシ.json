    "definitions": [
      {
        "index": 1,
        "gloss": "earless seal (Phocidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
