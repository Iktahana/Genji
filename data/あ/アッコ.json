        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、悪狐について考えています。",
              "source": "幻辞"
            },
            {
              "text": "我が社の悪狐戦略は重要です。",
              "source": "幻辞"
            },
            {
              "text": "悪狐の原理は複雑である。",
              "source": "幻辞"
            },
            {
              "text": "悪狐という言葉が頭から離れない。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは悪狐について学んでいる。",
              "source": "幻辞"
            },
            {
              "text": "悪狐の治療方法は多様である。",
              "source": "幻辞"
            },
            {
              "text": "悪狐に関する法律が改正された。",
              "source": "幻辞"
            },
            {
              "text": "選手たちは悪狐を目指している。",
              "source": "幻辞"
            },
            {
              "text": "自然界での悪狐は見事である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上、悪狐は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "悪狐は日本文化の一部である。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に様々な悪狐を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            },
            {
              "text": "「悪狐」という概念について深く考察する必要があります。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして振られ抜いたあげく、これではならぬとやむをえず今度は一つ悪狐を退治して名を揚げようと野原へ出た。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "染屋の悪狐にでも憑かれているようです。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっちゃんあっこ、おっちゃんあっこ、はんぶんはんぶん」　といいつついきなり父に取りつく。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子が菓子ほしい時に、父は必ずだっこしろ、だっこすれば菓子やるというために、菓子のほしい時彼はあっこあっこと叫んで父の膝に乗るのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四歳のお児はがっこといい、三歳の奈々子はあっこという。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんもといい、あっこといい、おっちゃんといったその悲しい声は永遠に父の耳を離れてしまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃんにあっこ、おっちゃんにおんも、おっちゃんがえい、お児ちゃんのかんこ、お児ちゃんのかんこがえいと声がするかと思うほどに耳にある彼の子の言葉を、口にいいさえすればすぐ涙は流れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっこの木のてっぺんに、とんびがとまったもんだん、大砲を一発うっただげや。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘイ、お富士山はあれ、あっこに秦皮の森があります。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどあっこらにめいます。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっこはもう勝山でござります、ヘイ」「じいさん、どうだろう雨にはなるまいか」「ヘイ晴れるとえいけしきでござります、残念じゃなあ、お富士山がちょっとでもめいるとえいが」「じいさん、雨はだいじょぶだろうか」「ヘイヘイ、耳がすこし遠いのでござります。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は高い声で、「あそこはなんという所かい」「ヘイ、あっこはお石でござります。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あっこはとても駄目って。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前、あっこへのたり込むのが当り前じゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何アに此の餓鬼、贋病使うてくさるのや、あっこまで歩けんことあるものか。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、あっこに大い池があんだろ？",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああやっぱりお父ちゃまに話しをして貰ったのはわるかったわ、そういう意味じゃなく、一時あっこおばちゃんが国府津かどこかへ籍をうつしてくれられたら、と云うことだったのよ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひぐまさんとじゃ、きっとあっこおばちゃん疲れて病気すると思うわ」「だって其とこれとは別じゃないの」「そりゃそうよ、病気したって仕方がないわ」上気せて云うこととは思う。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともあっこおばちゃんが上げて下すったの？",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしくて、ウームああちゃんとうなった、あっこおばちゃん、どぉうした？",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっこから、お日さん、出やすのや」　次兄がその山の方向を指した。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっこれだこれだ」　花房一郎は雀躍りして、もう一度自動車の中へ飛込みました。",
              "citation": {
                "source": "青い眼鏡",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "アボちゃん、「あっこおばちゃんの小父ちゃん（あなたは、こういうむずかしい呼名の方なの、そういう云い方で、何か一組として分るのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の廊下で揺椅子をひっくりかえして、「あっこおばチャーン、見て御覧」とやっています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、太郎があっこおばちゃんの御勉強机のためにさっきくれたもの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "又いまにあっこおばちゃんのおじちゃんに御対面ねがいます、私が抱いて行くわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな有様だのに、林町のああちゃんは、小さい息子が風邪ひきで国府津へ行かれないからその代りと云って、湿布している息子を銀座へつれて行って、フジアイスでアイスクリームのましたときいて、あっこおばちゃん大憤激です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっこおばちゃんもなかなかでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を祝ってやりましょう、あっこおばちゃんのおじちゃんというお方は何がいいとお思いになること？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はぼんやり覚えて居るのよ、あっこおばちゃんのおじちゃんを。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
