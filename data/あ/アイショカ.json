[
  {
    "uuid": "553e631b-1ec5-5996-980b-8b27bf145128",
    "entry": "愛書家",
    "reading": {
      "primary": "あいしょか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
