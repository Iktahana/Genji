    "definitions": [
      {
        "index": 1,
        "gloss": "bibliophile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神保町の古書店街は、日本中から愛書家が集まる聖地として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「真の愛書家であれば、内容はもちろんのこと、装丁や紙の質感にまで愛着を覚えるものです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は高名な愛書家として、自宅の地下に温度管理の行き届いた巨大な書庫を設けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "亡き祖父が熱心な愛書家だったおかげで、我が家には今では入手困難な初版本が数多く遺されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電子書籍が普及する現代において、紙の本の手触りを愛でる愛書家の存在は、より文化的な重みを増している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの方は筋金入りの愛書家ですから、本のページに折り目をつけることなど、決して許さないでしょうね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外のオークションに出品された稀覯本を巡り、世界各地の愛書家たちが熱烈な競り合いを演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この異彩ある珍書は著者、解説者、装幀意匠者、製紙工、染織工、印刷工、製本工の共同制作によってできあがった一つの総合芸術品としても愛書家の秘蔵に値するものであろう。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを拾い上げてやる時にちらりっと見ると、その中には、「樹木崇拝の起原」と云ったような名前の本もあったが、たぶんこの老人は、あるいは商売にしろ物好きにしろ、とにかく貧しい愛書家で、しかも珍本の蒐集家に相違ないと思った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本と蔵書印　本屋の息子に生れただけあって、文豪アナトオル・フランスは無類の愛書家だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家として聞えている割合には、その蔵書がひどく貧しく、とりわけ新刊物がまるで見えないのに驚いた客は、すなおにその驚きを主人に打ちあけたものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は聞えた外国文学通で、また愛書家でもあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業も同じようなものであったが、愛書家同志のことで、矢島の来意をきくと、一冊の書物にからまる心労にきわめて好意ある同感をいだいたようであった。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家も徒に華装ばかりを尊重したがらずに、こうした所に平明直截な美を打ち立てることに留意してほしい。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家の習書　軍隊の教練のように、兵卒が百人が百人、お一二というわけで、足を揃えて歩むが如き習い方をする書家の書道は、個々について見ますとき、誠に不見識で、是非とも百人が百人違った結果の字を書かなければならぬと思います。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家の心得　書も習うということになりますと、とかく他所行きの姿になりやすい、いわゆる気張って書く。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに、私が、愛書家であり、蔵書家であっても、それで満足がされます。",
              "citation": {
                "source": "書を愛して書を持たず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に愛書家なるものがある。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、両君の書斎が又愛書家にふさはしい洵に立派なものである。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は非常に稀覯書で、而も扉の見返には近代の愛書家四名の書蔵票が連貼してある。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝になると、彼等は再たのこのこと、馬の糞のように集まって来て、箱の前に呑気な顔を列べて、愛書家の群を待っている。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "その署名がボナパルトとあったか、それとも又ブオナパルテとイタリア流に書いてあったか、其処迄は聞もらしたが兎に角、五年に一度でも、十年に一度でも、斯んな掘出物があるから、愛書家が血眼になったり、蚤取眼になったり、鵜の目鷹の目になったりするのも無理ではない。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家のことを一般にビブリオフィルと呼んでいるが、此の愛書家の癖が高じると、ビブリオマーヌ即愛書狂となる。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ物騒な話で、此んな奴が飛び出すと、愛書家はお互に用心し度くなる。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、古代には愛書家という語はなかったのかと聞かれると一寸困るが、語はなくとも愛書家が存在した事は確かである。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世紀は、フィルビブリオンと云う言葉まで出来た時代であるから、愛書家が名実共に存した事は蓋し疑いを容れない。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し斯る篤志家に無闇に書物を買占められると、読む方の愛書家は往々迷惑する。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……場所をとらぬ簡便な図書室を造る最良の方法は、例えば、十二巻の全集中、六頁だけ有用と信じたら、六頁だけ切取って、余は火中す可し」　然しながら、以上三人のフランスの粗探しが、二世紀に渉って、皮肉混じりの警告を発したって、愛書家の病がそれで癒おる筈もない。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々製本を仕直す中には、縁が段々に狭くなるものであるから、始めから縁にゆとりの無い書物を愛書家は特に忌むのである。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家が書籍を大切にする事は改めて断わる必要もないだろう。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛書家が珍重するのは、何と云っても稀覯書であるが、稀覯書にも種類がある。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は久しい間、彼の友である二人の愛書家に蔵書を見せる約束があった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も初めは尋常な愛書家で、主として中世紀の写本を蒐めて楽しんでいたが、フランス革命の時、国土が荒らされ、各地の僧院の蔵書が二束三文で売り飛ばされるようになったので、彼は国宝の散佚を慨し、翻然として悟って、而して逆上して書狂となったのである。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人で小説家で愛書家であったシャルル・ノディエが或日ブーラールの書庫にはいった時の感想に斯うある。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
