    "definitions": [
      {
        "index": 1,
        "gloss": "dark hole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗穴について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗穴という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗穴の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗穴が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗穴を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗穴について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗穴の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗穴の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗穴が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗穴という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗穴という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗穴についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗穴を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗穴は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗穴について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗穴が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗穴は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗穴の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗穴は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗穴は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
