        "examples": {
          "standard": [
            {
              "text": "私は毎日蟻の門渡りについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は蟻の門渡りの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には蟻の門渡りが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは蟻の門渡りについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は蟻の門渡りの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では蟻の門渡りが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に蟻の門渡りという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では蟻の門渡りについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると蟻の門渡りは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では蟻の門渡りが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に蟻の門渡りは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により蟻の門渡りの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "蟻の門渡りは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に蟻の門渡りは興味深い例である。",
              "source": "幻辞"
            }
