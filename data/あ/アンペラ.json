[
  {
    "uuid": "5ef8e4e2-29ae-58d1-9783-5c99dc69010f",
    "entry": "アンペラ",
    "reading": {
      "primary": "アンペラ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Machaerina rubiginosa (species of tropical sedge)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンペラについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンペラという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンペラの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンペラが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンペラを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンペラについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンペラの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンペラの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンペラが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンペラという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンペラという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンペラについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンペラを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンペラは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンペラについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンペラが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンペラは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンペラの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンペラは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンペラは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "呉は、その上へアンペラを置いた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マッチ工場の寄宿舎から、工人を他の一棟へ追いやって、そこの高粱稈のアンペラに毛布を拡げ、背嚢か、携帯天幕の巻いたやつを枕にして、横たわった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高粱稈のアンペラが破れかけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無意識に破れかけのアンペラのはしを、ひきむしる彼の手は、マメだらけで、板のようにかたくなっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンペラから、毛布から、背嚢から、私物まで、すっかりひっくりかえされてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裂けたワイシャツに、ズボンだけの男は、アンペラに腰をおろすことも出来ず、弾丸よけに毛布を垂らした窓の傍に突ッ立って、唇をかみしめ、ポケットに、片手を突ッこみ、光った眼で前方を見つめていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回の掠奪の後、放りさがされて散らばっている、壊れ椅子や、アンペラや、柄が折れた娘の洋傘を盗み出していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日間も風呂に這入らない兵士達が、高粱稈のアンペラの上に毛布を拡げ、そこで雑魚寝をした。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その間から、折り畳んだ紙片が、パラ／＼とアンペラの上に落ちた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、比較的新しいアンペラの切れと、焚き火のあとがあった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋に残っていた六人は、窓に吊した破れたアンペラのかげから外をのぞいた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども中には、まだ現代になり切らない店つきの問屋も混っていて、裸電灯を軒先に掲げ出し、店員たちが夜なべ仕事に着到の荷品を頻りに向う側の物置庫に運び入れているのもあれば、何やら粉末をアンペラの上へ撒き拡げて、霧吹きで湿気を与えている店もあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして原住民は十人も二十人も土間にアンペラを敷いて、一緒にかたまって転寝をしているんですから、かりに猛獣が来ても、野蛮人が来ても、ほかの者に覚られないようにそっと一人をさらって行くということは、よほど困難の仕事で、誰か気のつく者がある筈です。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりの部屋とのあいだには四尺ばかりの入口があって、簾代りのアンペラが一枚垂れていた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアンペラをかかげて隣りの部屋を覗いてみると、果たしてそこには勇造の姿がみえなかった。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原の花魁道中の前の日の事とて、洛中洛外が何とのう、大空に浮き上って行きそうな気はいが、二人の泊っている木賃宿のアンペラ敷の上までも漂うていた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家の屋根が見え砂利を敷いた村の路が見えたかと思ふと、淡竹の垣根をした藁葺の小家の裏口が其所にあつた土間へ履物を脱いてそつとあがりながら見ると、男は何時も寝てゐるアンペラを敷いた室に、汚い浅黄の蒲団をかけて俯向きになつてゐた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女中と爺やより他に、何も遠慮する者はをりませんから、」「さうですね、すぐ帰れるなら参りませう、」「すぐお送りします、」「では、参りませう、」「それでは、どうか此方へ、」　女が先になつてアンペラの俵を積んである傍を通つて土手へ出た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "発見された屍体は、その建物の前へアンペラを敷いて寝かしてあった。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左片盤の小頭が、アンペラを持って来て、係長の指図を受けながら、技師の屍体の上へかぶせて行った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、救護室へ連れて行ったんですが……、さっき私がその救護室へアンペラをとりに行った時に、やっと起きあがりはじめた程で……看護夫も手を焼いとりましたよ」「成る程」と巡査が口を挟んだ。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし……」と小頭の方へ向って、「君がアンペラを取りに行く頃までは起てなかったんだね。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、君はそのアンペラを丸山技師の屍体へかぶせるつもりで取りに行ったんだろう？",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後で技師が殺され、小頭が屍体へかぶせるアンペラを取りに行った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "工手の屍体は、アンペラで覆われた丸山技師の屍体の側に、くの字形に曲って投げ出されていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "医員の仕度が出来て救護室へ下って来た知らせを受けると、係長は、とりあえず二つの屍体を救護室に移すことにして、来合せた炭車へアンペラを敷いて屍体を積み込んだ。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「婢と爺やよりほかに、何人も遠慮する者はおりませんから」「そうですね、すぐ帰れるならまいりましょう」「すぐお送りします」「ではまいりましょう」「それでは、どうかこちらへ」　女が前になってアンペラの俵を積んである傍を通って土手へ出た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから紹介するのは、今から二十幾年前の秋、その唐もろこしの御馳走になりながら、縁さきにアンペラの座蒲団をしいて、三浦老人とむかい合っていたときに聴かされた昔話の一つである。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナ家屋のアンペラの上に俯伏して書くか、或いは地面に腹｜這いながら書くのですから、ペンや鉛筆では却って不便で、むしろ柔かい毛筆を用いた方が便利だと云う場合もありました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアンペラの敷物の上にころがって苦しんだ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
