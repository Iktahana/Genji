    "entry": "相済む",
    "reading": {
      "primary": "あいすむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to finish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相済むは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相済むが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相済むに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相済むが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相済むについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相済むについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相済むについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相済むが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相済むが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相済むは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相済むは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相済むを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相済むをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相済むが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相済むの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相済むを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相済むに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相済むについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相済むは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相済むを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "五郎　この上はただ延引とのみで相済むまい。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『なにを小癪な――勢揃いにおくれたとあっては主侯に相済むまい。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような書面を持つ使いが、馬に悪戯したり、牛車の尻に乗ったり、道草をしていては主人に相済むまいが」「お武家さん、中を見たね」「拾い物は、一応中を検めて渡すのが正しいのだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……存じてもおろうが、紀州侯は、諸事ご厳格な方であらせられるから、このようなことがお耳に入ったら、お忿怒もさぞかし、とても、二人や三人の腹切りではあいすむまい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
