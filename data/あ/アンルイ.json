        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日暗涙について考えている。",
              "source": "幻辞"
            },
            {
              "text": "暗涙という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は暗涙の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には暗涙が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "暗涙を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは暗涙について学習した。",
              "source": "幻辞"
            },
            {
              "text": "暗涙の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は暗涙の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では暗涙が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "暗涙という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に暗涙という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では暗涙についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "暗涙を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると暗涙は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "暗涙について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では暗涙が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に暗涙は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により暗涙の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "暗涙は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に暗涙は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は昔風な父のあまりに律儀な意地強さにちょっと暗涙を催したのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は憐れな気がして、そっと暗涙を袖で押えた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、さすがの少年が目に暗涙を湛えて、膝下に、うつぎの花に埋もれて蹲る清い膚と、美しい黒髪とが、わななくのを見た。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は黒百合の花を捧げて、身に影も添わず、淋しく心細げに彳んでいたが、およそ十歩を隔てて少年が一度振返って見た時、糸をもて操らるるかと二足三足後を追うたが、そのまま素気なく向うを向いてしまったので、力無げに歩を停めた、目には暗涙を湛えたり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年は暗涙を浮べて『私は本當にお前と別れるのが、悲しいよ、けれど運命だから仕方が無いのだよ、それでねえ、お前が幸に、大佐の叔父さんの家に安着して、萬一にも私共の生命が助かつた事なら、再び、あの景色のよい海岸の砂の上で、面白く遊ぶ事が出來ませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う考へると、無限に悲哀くなつて、たゞ茫然と故國の空を望んで、そゞろに暗涙を浮べて居る時、今迄默然と深き考慮に沈んで居つた櫻木大佐は、突然顏を上げた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と清しき御眼に暗涙あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず暗涙を催したり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、これが大ぜいの若者たちを自由自在に操縦もし叱※もしたあの気嵩で美しく張のあった母かと、呆れもし暗涙に噎びながら、身震いが出るほど嫌味なものを感じますが、粗末にはできません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして若しその気持が捨て去ったまゝ再び後になって戻って来るものなら戻っても来よ、戻らざれば、それも是非なしと、暗涙を催しながら思い切って徳の外に抛ってしまうのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子はまたも暗涙せぐるかなしさに大ぞらながめ、欷歔しつつ九年母むきぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては無罪の宣告ありて、今日こそ放免せらるるならめ、何にもせよ嬉しきことよと、喜ぶにつけて別れの悲しく、互いに暗涙に咽びけるに、さはなくて彼女は妾らの室を隔つる、二間ばかりの室に移されしなりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "選手仲間は勿論、野球好きの生徒達は皆暗涙にむせむだ。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今、墓、塔婆、村の寺は寂然として声もないといふことを考へると、暗涙に咽ばずには居られないやうな心地が致します。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗涙を浮かめた瞳で背後の栗野博士を振返ると、すこしばかり頭を下げた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五つ六つの子供のように、「もうしません、もうしません、もうしません」　と泣き叫んで身もだえするので二人ながら弱ったそうであるが、それほどに取り調べが峻烈だったかと思うと、姉も妻も暗涙を催したと言う。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればその永久に和睦せられざる村人の寺に穏かに葬られて眠らんよりは、寧ろそのやさしき自然の儘なる少女の手に――」　暗涙が胸も狭しと集つて来た。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の知らない暗涙は夜の御床に流れても、それを御話しなさるという女の御友達は有ませんので。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時の汽車で帰省、味噌と浴衣と小遣とを貰つて、どの駅にも帰宅する遺骨を迎へる人々、また暗涙をそゝられる。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉紹鈞の「稲草人」「古代英雄の石像」を童話として紹介すれば、人々は、中国の誠実な一つの心情がその中に流している暗涙の重みにおどろくだろう。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日もお父さまは、鳶が舞はにや影もない――と唄には歌はれる片田の上田を買はれた時の先代の一方ならぬ艱難辛苦の話をなすつて「先代さまのお墓に申譯ないぞよ」と言つて、其時は文字通り暗涙に咽ばれました。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "病める夫を介抱せる夫人の心中を思ひて、われ更に暗涙を呑む。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "……驚いて、弱って、暗涙を拭い拭い立ち竦んでいる私の手を引いて、サッサと扉の外に出ると、重い扉を未練気もなくピッタリと閉めた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし他の大学に同君を取られるようなことがありますと、この大学の恥辱になると思いますから……」　と暗涙を浮めて懇願されました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故っていうわけはありませんでしたけども……そうしてやっと文科の二年になったばかしのところです（赤面、暗涙）。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結局、友吉おやじは諦めるとしても、あの忰の友太郎だけは惜しかったですね」　と来島が暗涙を浮かめて云った。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文が通過したら何とかして洋行させたいと思っていたところなんだが……と暗涙を浮かべている。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晩巡北邑先王遺制省秋収　行到辺荒意更愁　村似癈人痿不起　民如墜葉散難留　寒流病渉纔横木　衰草救飢猶牧牛　非有問窮連日苦　那看紅樹百峰秋　章句のうち、此郷の土俗風物の真体を伝へながら、しかも暗涙を以て民病の状を喝破して余す所がない。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
