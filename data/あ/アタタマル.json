          ],
          "literary": [
            {
              "text": "鋭角的な輪廓、よく通った鼻筋、広い額、が、その冷たさに触れてかえって心が温まると思われる様な感じを起させるのだったが、唯一つ、少し上にむくれている上唇が、可憐に見えた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみおつけの温まるまで、台所口に腰掛けて、前の雑木林を、ぼんやり見ていた。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その朝は船室に籠りきりで、番茶に梅干で温まると、ないしょで味噌汁に飯をあつらえた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お前さんの懐が温まる取引さ。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "温まるにつれて、昨夜少し過した酒の醉がまたほのかに身體に出て來るのを覺えた。",
              "citation": {
                "source": "湯槽の朝",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "温まる湯もあれば冷える湯もあつた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光命も十口坊も、此頃は懷ろが少し温まると共に、身體も膨脹しだしたり。",
              "citation": {
                "source": "川越夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "温まるにつれて、君の周囲から蒸れ立つ生臭い魚の香は強く部屋じゅうにこもったけれども、それは荒い大海を生々しく連想させるだけで、なんの不愉快な感じも起こさせなかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年と一しよにゐる心持は、加減の好い湯に這入つて温まるやうである。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏色の薔薇の花、おまへの愛はのろい火で温まる杏色の薔薇の花よ、菓子をとろとろ煮てゐる火皿がおまへの心だ、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい靈媒はたいへん忙しくなり、席の温まる遑もない位であつた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれだけで身体が底から温まるように感じた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "清酒が温まる程度に出て、刺身、いくら、鳥雑煮、しるこ、等、禅堂の曇らぬ美しい椀と箸の食事となって、切り口を揃えた菜の青いひたし物が雪の夜の歯を清めた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後五時頃になると、空気は温まる丈あたたまって重くよどみ、風は落ち、草の香がかんばしく四辺に満ちて、静かな夜と昼との境が来る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この連中の云ひ分によると、虱がゐたからと云つて、人間の体は決して温まるものではない。",
              "citation": {
                "source": "虱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "温まるかもしれねえよ」「田舎じゃあ、判らねえか知れねえが――小屋へは、初めてだからのう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の身体はその心労とともに、まことに、席の温まる暇もあたえられなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当にあすこの湯は温まるのね」お幸は時子に言った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪は或る場所へ集めて火をたいて温まるのであるが、周囲は先輩が占領して、我々は火に遠い所で震えていたものである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな訣で、冬には何となく、心の温まるやうな神事が行はれるのであつた。",
              "citation": {
                "source": "神賑ひ一般",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一杯のまない、温まるわよ。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本酒とウイスキーとのちゃんぽんには、体が温まるのか冷えるのか分りませんでした。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしばらく真空管の温まるのを待った。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいゝ加減に温まると、そのまゝすぐに出た。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その代り何か温まるものを持ってきてあげるわ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、裏日本へ注ぐ川の方が、早く水が温まるわけになる。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "分流江戸川へこの水が流れ込んで来るのはもちろんであるが当時上流地方に於ける水温は低い時で八度から九度、暖い日で十一度から十二度であるから、下流へ来るに従い次第に温まるにしろ、まだ人間が膝まで入れば、身ぶるいをする位であろう。",
              "citation": {
                "source": "河鱸遡上一考",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨つきは、中おちに沢山肉をつけたのを言うのであるが、随分からだが温まる。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕は煖炉で体が温まると、突然その不思議な女のことを思いながら言った。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は手のあたたまる間、それを熟視して、また原稿紙に向った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
