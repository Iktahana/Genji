    "definitions": [
      {
        "index": 1,
        "gloss": "with stealthy steps",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句が必要です。",
              "source": "幻辞"
            },
            {
              "text": "この言葉を使った例文です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二人はさながら猫の鼠を覗うように、息を凝らし、足音を忍ばせてその音のする方に這い寄った。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は暫くためらった後に、リノリウムの上に足音を忍ばせて、マントをかぶってそっと姉の隠れた部屋へ近寄って見た。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "春夫さんは胸を躍らせながら、足音を忍ばせて真暗な梯子段を声のする方へ近寄りました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の客は途方に暮れ、無言で眼まぜして帰り仕度をはじめ、挨拶もそこそこに草履をつっかけて門口に出て、それから小声で囁き合い、三人の所持の金子全部、一歩金三十八、こまがね七十目ばかり取り集め、門口に捨てられてある小皿の上に積みかさね、足音を忍ばせて立ち去った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、盗人の如く足音を忍ばせて持ち運んで来た。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又そっと足音を忍ばせて家から遠ざかった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "満員の客席の間を、足音を忍ばせて、座席に着いた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音を忍ばせてその樹へ近づいて行つたが、それを知つたかどうか、またその先の杉の樹に啼き移つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、我慢が出来なくなって、そっと起きて、足音を忍ばせて廊下に出た。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いので顔は見えないが、その声が男と女であることは直ぐに判ったので、年のわかい庄吉は一種の好奇心から足音を忍ばせて近寄った。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは正面の神壇の秘密を見とどけようとして、足音を忍ばせて窺いよると、忽ち或る者につまずいてはっと息を嚥み込んだ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音を忍ばせて彼女は私の背後に近寄つたのだらう、声で、私は初めてＦに気づいて振り反つた。",
              "citation": {
                "source": "鸚鵡の思ひ出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そつと忍び寄らうぜ、虫の音を消さないやうに……」　彼等は口々に、科白でも云ふやうに、つまらぬ文句を吐きながら、だが動作は飽くまでも熱心に、悪漢のやうに息を殺し、体を曲げ、足音を忍ばせて、窓に近寄つた。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、足音を忍ばせて「口まがり」の傍へ近づいた。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく慎んでいてくれたのにと思うと、いったい父を誘った相手は、どこのどいつだろうと、そっと足音を忍ばせて近づいてみたそうです。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音を忍ばせてだんだんに近寄ると、池の岸にひとつの黒い影の動いているのが、水明かりと雪明かりと星明かりとでおぼろげに窺われた。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は足音を忍ばせて近寄った。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は足音を忍ばせて、この杉木立の前を通り抜けようとする時、お袖が最も恐怖を感じていたのかも知れない、すくみ勝の足をひき摺って行くうちに、木の根か石につまずいて、踏み留める間もなしにばったりと倒れたので、お琴もお由もはっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、足音を忍ばせて、其窓に近づいた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そつと寝台から降りて着物を着換へると、泥棒のやうに足音を忍ばせて窓を乗り超えた。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師様が夜のお祈りをあげているのだな、で、お松は、み心を掻き乱さないようにと、足音を忍ばせて廊下を歩いた。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いけない、隠れて」と、旦那が云ふので、食ひさしの茶碗を棚へ置き、足音を忍ばせて、階段を昇つた、上は彼女たちの寝室になつてゐた。",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は這入ってゆくにも足音を忍ばせて、こんちはも言わないで壁にゆく。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに足音を忍ばせて歩いても、杉の葉の吊してある其の軒下に文吾の影がさすと、主婦の蒼白い顏は、きツと此方を見た。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈は真紀子を起さぬように足音を忍ばせて靴を履き、それから服を着てそっと部屋を脱け出した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忍ぶ、恋路の、か――さて、果敢なさよ、とくらあ」　小藤次は、口の中で、唄いながら、植込みの中から、広縁の方へ、足音を忍ばせて、入り込んで来た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕まへてお濱さんへの土産にする気で、縁側づたひに書院へ足音を忍ばせて行つたが、戸袋に手を掛けて柿の樹を見上げた途端に蝉は逃げた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちらりと紋吉の背後を覗いて見ると、足音を忍ばせてみづ江が霧の中に隠れるところであつた。",
              "citation": {
                "source": "青春の天刑病者達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも足音を忍ばせてそっと表戸へ近寄ると潜戸の閂へ両手を掛けた。",
              "citation": {
                "source": "日置流系図",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
