    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Angola",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンゴラについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンゴラの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンゴラが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンゴラについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンゴラの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンゴラが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンゴラという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンゴラについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンゴラは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンゴラが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンゴラは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンゴラの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンゴラは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンゴラは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それについて思い当るのは、一と頃ときどき宅へ忍び込んで来る猫の中に一匹のアンゴラ種らしい立派な白猫があった、それが、もしかすると「白」の父親か祖父ではないかと思われるのであった。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの一匹がどうも前述のいわゆるアンゴラに似ているように思われた。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃草、アンゴラの生れか、手ざはりの快い、柔かい女猫。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "△蛙の話△羊の話アンゴラ兎の話人間は追剥。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路沿いの三角の空地のところに、段々の巣箱をつくってそのなかにアンゴラや何かがいます。",
              "citation": {
                "source": "二人の弟たちへのたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックの小さい小舎同然の並んでゐる、長屋のはづれに、アンゴラ兎を家のなかで飼つてゐる二階家に、加野は間借りをしてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てアンゴラ種の猫を飼ったことがあるが、アンゴラだのペルシャだの長毛のものは、空気の湿度の高い日本では聊か無理だ。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、どこの娘が着るのかもわからないアンゴラの水色に染めた半袖のスエーターを、また編みはじめました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、緬羊とアンゴラの原毛を集めてゐます。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※を立つ間ぎわになってから大急ぎで、そのカラーとカフスのところへ柔かな灰色のアンゴラ毛皮を自分で縫いつけて来た紺の合外套を着て。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は柔かい灰色アンゴラのファーつき外套を着、もう一人はラクダ色の外套を着て自分たちをむき出しに広場をかこんで止っているトラックの上からの環視にさらしたまま、佇んでいる伸子と素子。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君も御承知のとおり、葡領西｜阿弗利加アンゴラと白耳義領コンゴーとは、年中国境紛争の絶え間もない植民地であった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現地測量隊として、アンゴラ政府の派遣せるものは、技師二十六人、技手以下測量人夫三百八十人、充分なる食糧と準備を整え、約十八班に分れて、中央国境唯一の土人町ビイサウを基点として約一カ年半の予定をもって、東西｜蜿蜒千五百｜哩の国境画定測量に従事することとなったのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムラとは隊長といった風のアンゴラ土人語であり、ポンゴーというのは、同じくゴリラのことを土語ではかく言って恐れ戦いているのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴリラの醜悪なあの面貌を恐れるのか、あるいはゴリラを忌み嫌う父祖以来の伝統が、その血の中に沁み込んでいるのか、アンゴラ土人の類人猿を恐れることは獅子、虎、バンタ毒蛇、豹にもまさっているのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡領アンゴラは最も白人の少ないところであって、ロアンダ、ベンゲラの海岸都会地方においてすらも、白人の住するものは近々数千人にすぎなかった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の事情から察して、この凝血して判読の利かぬ部分が、英国から出発してアンゴラあたりへ来、いかにしてかゴリラを手に入れて、キャンプ生活にでも移っているところが記録されていたのであろうと想像せられた。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも恐ろしい兀鷹族なのだそうだが、アンゴラ土人とは違って、見るからに屈強そうな丈も高ければ体格も大きく瀝青黒のような皮膚をしていかにも北西森の住人にふさわしい人々ばかりであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその頃に、倫敦タイムス紙やマンチェスター・ガーデアン紙、デリー・テレグラフ紙、クロニクル紙各紙の社会面を賑わしていたアンゴラ、ロアンダ特電の出来事が眼に触れたのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィルダー・ゲイレック博士（五十八歳）前ケムブリッジ大学教授、動物組織学の泰斗にして、一九一九年より同二五年にわたる間、葡、蘭領アンゴラ、サマザンカ地方において、夫人とともに類人猿解剖および言語の研究に従事。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、シュトルツ氏の家にはジャアマンポインタア種の犬と、欧羅巴種の全身真っ黒な猫とがいたが、その外に、裏庭の方に箱を作ってアンゴラ兎を飼っていた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もアンゴラ兎でないただの兎であったが、真っ白な、きれいな兎ではあった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
