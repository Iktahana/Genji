        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アメリカ合衆国について考えている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアメリカ合衆国の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアメリカ合衆国が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアメリカ合衆国について学習した。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアメリカ合衆国の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアメリカ合衆国が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアメリカ合衆国という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアメリカ合衆国についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアメリカ合衆国は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアメリカ合衆国が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアメリカ合衆国は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアメリカ合衆国の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アメリカ合衆国は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアメリカ合衆国は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "身なりはよく、懐の名刺には『イーノック・Ｊ・ドレッバー　アメリカ合衆国オハイオ州クリーヴランド』とあります。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国政府・南部社会上流階級の努力に関わらず、数年間盛んなりしも、一八六九年この結社は突如瓦解に至る。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国ではラム酒あるいはウィスキーに糖蜜と醋とを混じた飲料をいうが、船乗りの通語では一般に濃い色をした強い酒をいう。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々合衆国人の渡航によって好奇心を起し、我々の故国を慕うものを、われわれの手によって、断頭台の上へ追い登らせることは、アメリカ合衆国の恥ではないか。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今から十五年まへに出来上つたのですが、最初アメリカ合衆国政府が、パナマ共和国に同意させて、あのほりわりをひらく計画をたてたのは五十年もまへのことで、かねてスヱズの運河を作り上げた、ドゥ・ルッセといふフランス人の技師をやとつて着手させたのでした。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和11・８「サンデー毎日」）歯なしの話　七月四日、アメリカ合衆国の独立記念日、それとは何の関係もなしに、左の上の奥歯二枚が俄かに痛み出した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国にニューヨークという所がある。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国の標語に、“E Pluribus Unum”といふ言葉がある。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "千九百三十七年には、チュカロフがモスクワからアメリカ合衆国まで、北極の上空を通つて飛び、これをスターリン空路と命名してをります。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリー・デーヴィッド・ソーロー Henry David Thoreau は一八一七年七月十二日アメリカ合衆国の東北部、マサチュセッツ州のコンコード（ボストンの西北二十マイル）の町で生まれた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十四日◯アメリカ合衆国日本州の感深し。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音信の方が……人類にとってもっと重要なものであるということが…………　　これがアメリカ独立戦争の導火線となり、アメリカ合衆国の独立によってデモクラシーの思想は新旧両世界を風靡し、遂にフランス革命が起るに至ったからである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七七五年にアメリカ独立戦争が始り、一七七八年にルイ十六世はアメリカ合衆国を承認し、その支援に軍隊と艦隊とを送って、イギリスと交戦状態に入った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのシナの茶とアメリカ人参の往返が太平洋を忌避し、太平洋が帆船にとっても超ゆべからざる地表の大クレヴァスだったわけというのは――　第一にアメリカ合衆国が一八四六年までは太平洋岸を所有していなかったこと。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇年初頭のマルクスの予見どおりに、運命は黄金狂時代のアメリカ合衆国に微笑みかけ、微笑みつづけるもののようだ。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "国会はこの二条約を否決し、アラスカの買収も今後はもう領土買収をしないという条件付で承認したが、このような国会の動きを過大に評価して、当年のアメリカ合衆国の対外政策を「平和的」と規定し去ることは誤っているだろう。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本よりも「文明開化」しているアメリカ合衆国の貨幣は本位貨幣たる金貨、補助貨幣たる銀貨、量目も品位もちゃんと整って、間然するところがない。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクラソウの図ヒマワリ　ヒマワリは一名ヒグルマ、一名ニチリンソウ、一名ヒュウガアオイと呼ばれ、アメリカ合衆国の原産であるが、はやくに広く世界に広まり、諸国で栽培せられている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学名を Helianthus tuberosus L.（この種名は塊茎を有する意）と称し、俗に Girasole または Jerusalem artichoke と呼び、やはりアメリカ合衆国ならびにカナダがその原産地である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミズリイ流域の面積は、約五十三万平方マイルで、アメリカ合衆国全面積の六分の一を占めている。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国の人口総計おおよそ六千一百万にして、寺院大小諸宗を合して九万二千百七棟、僧侶（牧師）七万七千二百三十人なれば、六百六十二人につき寺院一棟、八百人につき僧侶一人の割合なり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後、英国に続きて文化をもって世界に鳴るものは、けだしアメリカ合衆国ならん。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿を一番沢山産する国は、インド、エジプト、ブラジル及び、北アメリカ合衆国とである。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ド・ロマよりは少し前に、北アメリカ合衆国では、フランクリンが雷の本質について、同じやうな研究をした。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしアメリカ合衆国が増加し続けるならば――これは確かに事実であろう、もっともその速度は前と同じではなかろうが――インディアンはますます奥地へとおいやられ、遂にはこの全種族は絶滅され、そして領地はそれ以上拡張し得なくなるであろう（訳註）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国におけるとほとんど同じほどの大いさの人口増加の傾向を想定することなくしては、この事実は私には説明し得ないように思われる２）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "１）　Id. p. 368, 369.　しかし、英蘭の北アメリカ植民地、すなわち今日ではアメリカ合衆国の有力な国民は、その人口増加において、他の一切をはるかに凌駕した。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　一八二〇年の第四囘人口調査によれば、アメリカ合衆国の人口は、七、八六一、七一〇であった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、アメリカ合衆国全体を通じて起ったと知られているものよりも緩慢な増加率である。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人民の境遇は、ヨオロッパの後進国の住民よりはアメリカ合衆国の住民のそれに類似することとなろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
