    "definitions": [
      {
        "index": 1,
        "gloss": "pineapple (Ananas comosus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナナスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナナスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナナスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナナスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナナスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナナスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナナスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナナスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナナスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナナスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナナスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナナスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナナスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナナスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナナスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナナスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナナスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナナスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナナスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナナスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "バナナという木の実、アナナスという果物、見も馴れず、名も知らぬ成りものが、谷と山襞を埋めつくしている、異国人の畑作だとは知らないから、なんとまあ成りものの多い島だなどといっている。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
