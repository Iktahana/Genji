[
  {
    "uuid": "7a9b65ad-ab2d-5ca2-91ae-516ba0bc1000",
    "entry": "アンサンブル",
    "reading": {
      "primary": "アンサンブル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ensemble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アンサンブルについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンサンブルの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンサンブルが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンサンブルについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンサンブルの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンサンブルが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンサンブルという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンサンブルについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンサンブルは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンサンブルが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンサンブルは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンサンブルの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンサンブルは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンサンブルは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "従ってその連鎖のつながり方を規定するものは作者各自の個性のアンサンブルである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金文字のはいった扉を押すと、十球の全波受信機がキャッチしたサンフランシスコの放送音楽が、弦楽器の見事なアンサンブルを繊細な一本の曲線に流して、京吉の足は途端に、リズミカルに動き出した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は厳選したアンサンブルのうえから大きな巻毛の自動車用コウトで埋めつくされていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれの女の子、チェックの｜アンサンブル（赤、緑、黒的）黒いハンドバッグと手袋とをその男がもってやっている。",
              "citation": {
                "source": "情景（秋）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤの生んだ異色ある劇団、蝙蝠座の業績は、われわれに大きな示唆を与へるものであるに拘はらず、詩人、音楽家、舞踊家、美術家の見事なアンサンブルが如何にして可能であるかを、われわれは実のところまだつきつめて考へてみたことはないのである。",
              "citation": {
                "source": "未解決の問題",
                "author": "――新劇の決算――",
                "note": "青空文庫"
              }
            },
            {
              "text": "議論又議論、熟議又熟議、一つのアンサンブルとしての基礎は固くなつて来ました。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、西洋の俳優は、どんな新米でも、どんな端役でも、いっぱし堂々たる声を聞かせ、それが、アンサンブルとして、舞台なりスクリーンなりに、快調ともいうべきセリフの流れをつくるのです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼等の機関誌ができ、サロン風の例会が毎週欠かさず行はれて、まつたく自然の推移のうちに、会員達の有志によつて、候鳥アンサンブルや合唱団が組織された。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアンサンブルとしての演技にとても大人には見られない統一のあった事です。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤマさん、しばらく」　グレーのジャンパー・スカートに、緋裏のついたアンサンブルのコートを、マントのように羽織った、外人向きの、高級バアのマダムという見かけの二十七八の女が、そう言いながら、すらすらと部屋にはいってきた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　初めて仕立が気に入つたといふアンサンブルであつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころパリにいた連中は、忘れられぬ思い出をもっているはずだ」　ほのかな歌声が、管絃楽のアンサンブルの中から音の糸を繰りだすように洩れてきた。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが要点はあくまで、こうした一連のアンサンブルが唯物論の展開として展開されるのでなければ、抵抗線上の進歩性を体系的に齎すことは出来ないという点に懸る。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "『新潮』は新年号に十五枚ぐらいの小説を十五人ぐらいにかかせているが、批評によると、短篇アンサンブルとしての効果なし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェロの良さはやはり大曲における雄大な表現力か、でなければ、アンサンブルの美しさだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種のそれは魔術的なアンサンブルだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブッシュ四重奏団の絃三人にゼルキンのピアノを加えた、アンサンブルの美しさは、恐らく誰でも夢中にさせずには措かないだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイードの鼠と小豆色のグレンチェックのアンサンブル、―――モード・エ・トラヴォーに出ている型を示して、これになさいと二人が云うのでそうする。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは愛する女性セシルとのアンサンブルであるギュスターブのパートだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
