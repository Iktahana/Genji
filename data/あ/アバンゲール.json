        "examples": {
          "standard": [
            {
              "text": "アバンゲールについて考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このアバンゲールは非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールの意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人がアバンゲールについて知っています。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールは日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はアバンゲールの価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールに関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではアバンゲールが重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からアバンゲールを見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールの歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもアバンゲールが取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではアバンゲールが注目されています。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールについて新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもアバンゲールは言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもアバンゲールは使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でアバンゲールは重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にアバンゲールについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "アバンゲールの特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するアバンゲールの側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではアバンゲールの理解が必須です。",
              "source": "幻辞"
            }
          ],
