        "examples": {
          "standard": [
            {
              "text": "法律による保護が市民を守る。",
              "source": "幻辞"
            },
            {
              "text": "政治的な決定は社会に大きな影響を及ぼす。",
              "source": "幻辞"
            },
            {
              "text": "民主的なプロセスが尊重される。",
              "source": "幻辞"
            },
            {
              "text": "法規制により秩序が保たれている。",
              "source": "幻辞"
            },
            {
              "text": "政策立案には多角的な検討が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "議会の議論が活発に行われている。",
              "source": "幻辞"
            },
            {
              "text": "裁判所の判断が先例となる。",
              "source": "幻辞"
            },
            {
              "text": "憲法の遵守は国家の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "法的権利の保護が重要である。",
              "source": "幻辞"
            },
            {
              "text": "政治的合意の形成に時間がかかる。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "へんな書き置きみたいなものを残して行きましたが、それがまた何とも不愉快、あなたはユダヤ人だったのですね、はじめてわかりました、虫にたとえると、赤蟻です、と書いてあるのです。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蟻は彼のモヂヤ／＼した髯の中を草場かと心得て駈け廻るといふ行體。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、何の事はない、虫眼鏡で赤蟻の行列を山へ投懸けて視めるようだ。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何と、其の兩足から、下腹へ掛けて、棕櫚の毛の蚤が、うよ／＼ぞろ／＼……赤蟻の列を造つてる……私は立窘みました。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はもう泣く事にも飽いたのか、五月の冷々とした畳の上にうつぶせになって、小さい赤蟻を一｜匹一匹指で追っては殺していた。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つっ立っている二人の脚から腹へ、腹から胸へと、赤蟻がぞろぞろとはいあがってきた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで赤蟻の大群が引越しをするような有様で、隊伍をととのえて沙漠を横断し、この宇宙艇へ向けて殺到する勢いを示したのである。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のでっかい赤蟻が立ったような恰好の火星人の大群は、見事な隊伍をつくって、刻一刻、沙漠に腹這いになった宇宙艇へ近づいて来る。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『赤蟻』は、既にその時代を約束してゐる。",
              "citation": {
                "source": "中村・阪中二君のこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の足もとのあたりには、小さな赤蟻の群が頻りに何か忙しそうに活動していた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村正常君の「赤蟻」、阪中君の「鳥籠を毀す」、それぞれ文学として、又は戯曲に盛り得る最高のリリシズムとして、当時私は推賞を惜まなかつたものであるが、戯曲の常道を行く技巧と形式の上からは、完成の域に近い意味で、やはり、この「二十六番館」を挙げるべきであらう。",
              "citation": {
                "source": "新劇復興の兆",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蟻がそこらを這い廻っていた。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "化石もすらむ秋の木は骨立ち強に呼吸つまり、天つ御法のおん宣告に、拗ねては、櫨も葉こそ縒れ、孕婦ながら茴香は優婆夷か、悩む色もなし伴にはぐれし赤蟻の飢ゑて足悩ゆむ湿り地に、憐み顔のおとどひは茎も軟らに額づきて、手弱腕にそと乗せつ、弘誓もさこそ、あゝ茴香。",
              "citation": {
                "source": "茴香",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のとりあげた重い玩具の、まだ濡れてゐる眼窩や顳※の疵に、小さな赤蟻がいそがしく見え隠れしてゐる、それは淡い褐色の、不思議に優雅な城のやうであつた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻の二民族のあいだの戦争で、赤蟻はつねに黒蟻と取っ組み、二匹の赤が一匹の黒にかかっているのもちょいちょいあった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい方の赤蟻戦士は相手の胸元に万力のように喰いつき、この戦場における幾まろびのあいだも相手の一方の触角の根元あたりに噛りついて一瞬たりともはなさなかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくするうちに、この谷の斜面をただ一匹の赤蟻が気負いたった態でやってきた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白い顔面はまるで一とすじの布きれのようになって、その新聞紙の上にそそがれたが、間もなく女はそっとその新聞紙をひいたとき、そのしたから胡麻粒のような一面の赤蟻が、殆ど見わけることのできないほどの微かな、いくすじとない行列を畳のへりから障子ぎわの閾までつづけていた。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬なのに蛇トカゲの爬虫類がうようよ這いまわり、毒蛾、サソリ、赤蟻、種類も知れぬ毒虫が群れをなして兵の眠りまで苦しめる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
