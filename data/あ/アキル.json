        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "飽きるは日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "飽きる対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "飽きるに関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では飽きるがテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると飽きるは複雑な現象である。",
              "source": "幻辞"
            },
            {
              "text": "朝起きたとき、飽きるの症状が出ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスモデルは飽きるを核としている。",
              "source": "幻辞"
            },
            {
              "text": "技術革新により飽きるの問題が解決される可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "文学における飽きるの表現方法は時代とともに変わる。",
              "source": "幻辞"
            },
            {
              "text": "飽きるについて学校で教えられることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "彼女は毎日飽きるについて悩んでいる。",
              "source": "幻辞"
            },
            {
              "text": "経済的な観点から飽きるを分析すると興味深い。",
              "source": "幻辞"
            },
            {
              "text": "科学的研究により飽きるの原因が特定された。",
              "source": "幻辞"
            },
            {
              "text": "芸術家たちは飽きるを表現の対象としてきた。",
              "source": "幻辞"
            },
            {
              "text": "大学の研究室で飽きるに関する実験が行われている。",
              "source": "幻辞"
            },
            {
              "text": "飽きるは日常生活で良く見かける現象だ。",
              "source": "幻辞"
            },
            {
              "text": "飽きる対策に多くの企業が投資している。",
              "source": "幻辞"
            },
            {
              "text": "飽きるに関する最新の研究結果が発表された。",
              "source": "幻辞"
            },
            {
              "text": "この作品では飽きるがテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "学問的な観点からすると飽きるは複雑な現象である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "父は維新前いわゆる御鯨方の支配の下に行われた捕鯨の壮観と、大漁後のバッカスの饗宴とを度々目撃し体験していたので、出発前にその話を飽きるほど聞かされていた。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年や二年で見飽きるようなものであったら、自然に関する芸術や科学は数千年前に完結してしまっているはずである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく一生描いて居ても此等の「物」に飽きるやうな事はあるまいと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三児は遊びに飽きると時々自分の書見の室に襲うてくる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく一生かいていてもこれらの「物」に飽きるような事はあるまいと思う。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きのうの我れに飽きる人」の取るべき向上の一路に進まなければならない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も何か充らないやうな、物足りぬ顔で大きな古｜机の前に坐り込むでゐるが、飽きるとゴロリ横になツて、貧乏揺をしながら何時とはなく眠ツて了ふ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはシナリオや小説を飽きる程読んでいる私の耳には、頗るまずい、取って付けたような話としか響かなかったので、強いて想像を逞しくすれば……その美しい第二夫人というのは、私の実の母親の事ではないか。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は子供のときから青年期まで金魚屋に育って、金魚は朝、昼、晩、見飽きるほど見たのだが、蛍の屑ほどにも思わなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭に属するもの塵一つ見飽きるといつては済まないが、沈滞の空気にところを得させぬためにときどき時宜の模様更へは必要である。",
              "citation": {
                "source": "女性と庭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのうちには子供だから摘むのにもぢき飽きるだらうよ」「でも」「まあ、いゝから……」　ひろ子の家は二筋三筋｜距つた町通りに小さい葉茶屋の店を出してゐた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日来｜見飽きるほど見て来た平凡な木乃伊である。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに飽きると今度は姉の夫をすぐバット細工の友達にして仕舞った。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹と一人の男を中に、みにくい争いをするのが嫌さに、美沢は思い切って、妹に与えたつもりでいたのに、子供が玩具に飽きるように、美和子はたちまち美沢を放り出して、新子の生活に侵入して来て、今度は新子を向うに廻して、前川の寵を争うつもりでいるらしい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの養父母や、お磯婆さんから飽きる程繰り返して聞かされているでしょうし、又、村の者の噂や何かも直接間接に耳にしている筈ですから、恐らく誰よりも詳しく知っているでしょう。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三兒は遊びに飽きると時々自分の書見の室に襲うてくる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "物資は別にして、都にゐても森にゐても飽きる時は飽きる。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽きるまでの日を限つて――と勇んで僕は出歩き廻る。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　わたしは宿屋の仮寝に飽きると佗しさに身をもてあまして、その夜中過ぎまでも酒を飲ませる店に渋々ながらも出かけるのが常だつた。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）暫くたつと浜田を始め誰も飽きて了つて、僕の本箱から絵本を引出して見始めたが、僕一人は飽きる処ではなかつた。",
              "citation": {
                "source": "蘭丸の絵",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その要求が成就されるまでは絶対に飽きることがない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の心はただ渾沌と暗く固まった物のまわりを飽きる事もなく幾度も幾度も左から右に、右から左に回っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は幼い時からこれを飽きるほど喰べて來たので、季節の來るごとに自づと思ひ出されてならぬのでした。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方のように、敏感な方なら、直ぐに飽きるでしょうが、彼等のように鈍い感じしか持っていない人達は、何時迄同じことをやっていても飽きないのじゃなくって！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたと十年も廿年も百年も千年も、かうして暮しても飽きるときは、あらじと思はれる！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそれにも飽きると、首を出してとなりの南天の葉に溜る白い雨の雫を見る。",
              "citation": {
                "source": "女の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かう相談するやうに首をかしげて言つてはゐるものゝ、その実さつきからもうちやんと心に決めてゐたので、飽きるほど著古して襟垢のついた単物よりか、たとひ少し位時節は早くても、袷せを著て出ようと密かに楽しんでゐるのであつた。",
              "citation": {
                "source": "散歩",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人のうち九十九人の女は、私がかれらに飽きたら、かれらもまた私に飽きるであろうし、百人のうち七十五人までは、他の男と無遠慮に、盛んにいちゃついて、私に復讐するであろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんべん読みなおしてもあきることがない。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの心の変わりゆきし跡を見たもうてあきれたもうとも笑いたもうとも泣きたもうとも、そは貴嬢が自由なり、されどあきるるも笑うも泣くもみな貴嬢が品性によりてのことなれば、あながち貴嬢が自由ともいい難し。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
