            }
          ],
          "literary": [
            {
              "text": "あたり一面、稲田の中で蛙が雨のように鳴いていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまたあたり一面にわかに薄暗くなりだして、瞬く間に物のあいろも見えなくなり、樺の木立ちも、降り積ッたままでまた日の眼に逢わぬ雪のように、白くおぼろに霞む――と小雨が忍びやかに、怪し気に、私語するようにバラバラと降ッて通ッた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面は明るくて昼のようだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面まっ黒びろうどの夜だ」「まあ、不思議ですわね。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが不思議ですよ、ここまで来ると、このあたり一面に美麗な花が咲いてて、何とも云えない良い匂がするのです、それにそこには※な女がたくさんいて、それが何か唄いながら踊ってたのですが、それが私の方を見て、いっしょに踊らないかと云って招くものですから、ついその気になって、ふらふらと入ったのですよ」",
              "citation": {
                "source": "妖女の舞踏する踏切",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち見たところ、首をかしげて、何考えるか寒の蛙の寒そうな、ちょっぴり温めてくれようか」　そう言ったかと思うと、はや佐助の五体はぱっと消え失せて、一条の煙が立ちのぼった、――と、見るより、煙は忽ち炎と変じて、あれよあれよという間に、あたり一面火の海と化し甲賀流火遁の術であった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一しよに、ほかの二人は、へんな薬の草を口へ一ぱい入れこんで、ふう／＼と、あたり一面へ、薄荷のやうなきついにほひのする烟をはき出します。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり畑へ入って瓜を盗んで食ううちに、あたり一面の水になって、膝まで来て、胴へついて、素裸になって、衣ものを背負って、どうとか……って、話をするのを、小児の時、うとうと寝ながら聞いて、面白くって堪らない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸焼のあたり一面、めらめらとこう掌をあけたように炎になったから、わッというと、うしろ飛びに退っちまったそうですよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色のさびしさは、夢のまま、あたり一面にただよっていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたり一面、軍馬補充部白河支部の牧場に屬す。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に青葉若葉と云はない、あのあたり一面におほい松の林の松の花、蕪村が歌うた若竹やゆふ日の嵯峨となりにけり　の篁つゞきの竹の秋の風情、思ひ起すだに醉ふ樣な心地がする。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに自分の通っている道から両側にかけ三四尺四方の穴を穿って落下した弾の痕が無数に散らばっているのを見ると、あたり一面に草のみ茂って人の影とても無い中のことで、どうしても落ちついて歩いている気になれなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょぴっ、ちょぴっ、ちゃぽん、ちゃぽん、と実に数かぎりないその音が、さながら俄雨でも降り出した様にあたり一面の水の面に起ったのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面の血の海だ。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面、まるで湖水の如く、時には小波さへ立たないで鏡の如く靜かになることさへある。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭に出るとあたり一面の青葉の中に、まだ淡桃色の林檎の花が残っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまたあたり一面にわかに薄暗くなりだして、瞬く間に物のあいろも見えなくなり、樺の木立ちも、降り積ッたままでまだ日の眼に逢わぬ雪のように、白くおぼろに霞む――と小雨が忍びやかに、怪し気に、私語するようにパラパラと降ッて通ッた。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、五秒の後、断末魔の痙攣が起った時には、その右手も共に白布の上で躍って、あたり一面に血の斑点を振りまいた。",
              "citation": {
                "source": "肉腫",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし衰えた、歓声は盛り返す潮の岩に砕けたようにあたり一面に湧き上がる。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩麦の夥しい殼は空の小舟のような軽い粒々をあたり一面に散ってカサコソと鳴るのである。",
              "citation": {
                "source": "鼠と鳩麦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火があたり一面に赤く映えて、橋の上の群衆の顔がパッと明るく照り出された。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、越中島埋立の失敗から、途中に航空研究所と商船学校のある外は人家とてもなく、あたり一面、気味の悪い沼地になっていて、人の背丈ほどもある蒲が生い繁っていた。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面の稲がことごとく倒れているにもかかわらず、その一区画では見事に立ちそろっている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の太陽は光々と輝いて、サナトリウムの全景は、まばゆいばかりの光線に満たされ、鷺太郎がベッドに寝ころんだ儘、ゆうべのことをあれこれと考えていると、ジーッ、ジーッと圧迫されるような油蝉の声が、あたり一面、降るように聴えていた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野草があたり一面に黒々と生ひ繁つて、まるであたりを塞いでしまつてゐるばかりだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは見ている間に猛烈な勢いの黒煙に変って来ると、苦しみ怒るもの狂おしい姿に見え、とめどもない凄じい黒さであたり一面に噴き靡いた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう虫があたり一面なきたてゝいて、秋ふけた感じだつた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "矛盾撞着の葛藤を引きずつたまゝ大きな敗戰の前に、日本といふ樹木はほんたうの神風にあふられてゐるやうに、澤山の哀れな落葉をあたり一面にふりはらつてゐる。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どうしても、良い夢を見るぞ……）　眼をつぶると、物狂わしいジンタが、あたり一面に吹きすさんでいた……。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
