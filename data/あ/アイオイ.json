[
  {
    "uuid": "38894d22-ac08-58ae-9456-165dcef9921a",
    "entry": "相生い",
    "reading": {
      "primary": "あいおい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "developing together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、相生いは私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは相生いが重要です。",
              "source": "幻辞"
            },
            {
              "text": "相生いに関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では相生いが物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で相生いについて学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から相生いについてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では相生いについて明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では相生いが勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では相生いが見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に相生いは重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において相生いは重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に相生いを見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に相生いをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で相生いが議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、相生いの性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は相生いを象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は相生いに関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で相生いについて医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から相生いは重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは相生いを高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "白金大町、あいおい大町どうもいけません。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊二、十一歳、しらかべ町六、九歳、あいおい町重吉、九歳、同町代地又、八歳、としま町梅、八歳、さくま町伝次、七歳、りゅうかん町市、六歳、おしょろさんの裏あつ、四歳、同所　人別書には右のように書いてあり、その住所はおりつがいちおう慥かめたと云った。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
    "meta": {
      "version": "1.0.0",
      "source": "JMdict, Aozora-Crawler, Illusions-Core",
      "updated_at": "2026-03-22T22:30:00Z"
    }
