          "literary": [
            {
              "text": "かういふ当時の歌人と許された人々の、神遊び歌を召されると言つた風が、宮廷詩人の俤を見せて居るのである。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "此信仰の古いものは、縮見細目の家の新室宴にまれびと久米部小楯の為に遊び歌はれた二皇子の伝説の如きものが、其適例を示してゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            }
          ]
        }
