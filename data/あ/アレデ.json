        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あれでについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あれでという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあれでの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあれでが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あれでを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあれでについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あれでの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあれでの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあれでが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あれでという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあれでという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあれでについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あれでを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあれでは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あれでについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあれでが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあれでは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあれでの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれでは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあれでは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな、気の弱さうな人であるけれども、あれで却々野心家だとも思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでもし勝ったら、私は今ほど日本を愛する事が出来なかったかも知れません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしはねえ、あれで小説家になろうと思って勉強したこともあるんですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、兄貴の言葉ではないが、教育界にゐてそんなことをしたからこそ、失敗なので、あれで、當時の政黨にゐて動いてゐたなら、あるひは成功したのかも知れない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、あれで、なかなかむずかしいのですよ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれでゐて、グラムやバットを、隣りに預けて置くやうな芸当が出来るんかなあ……如何いつてお主婦に話をつけたんだらう……いや、耕二が芸当が出来るんぢやないんだ、親達がやかまし過ぎるんだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやお父さん、あれで負けたことはやつぱり口惜しいんですよ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まああたしまだ、仕度なんてしてやあしないわ、それに今晩はあれですもの……夜間（撮映）……ねえ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」が、冗談ぢやない、僕は僕が輝けるやうに生きてゐた。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも二、三百匹はゐるんだらうね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも、まだ、色氣があると見える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあれで、何か色氣があるらしいんだね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると心は叫ぶのだ、あれでもない、これでもない、あれでもないこれでもない！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の登山諸道に、壮麗な神社があるのと対照して、これはこれ、あれはあれでいいと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛や豚の殘骸はあれでも自然の斷片である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文展へ行つて見ろ、島村觀山とか寺岡廣業とか、あゝいふのはみんな大家だぜ、こんなのとはちがわあ」「あれでも何處かへ持つて行きあ、三十圓や五十圓にやあなるんだよ」などといふのも聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、あれで、なかなか女らしいところもあるんだよ」と。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて訊くと「あんな伯母さんのことを気にかけるものではありません」「仔細あって私たちは交際ってはいません」「あれで、なかなか裏に裏のある女でね」「あんな大きな山に住えば誰だって評判はよくなるさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも民さん、あなたをば大変ほめているよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたでいくら心配してもお母さんがあれでは駄目だ」　これが台所会議の決定であったらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚自身にとつてみれば、あれで悲しんでゐるかも知れないのだ。",
              "citation": {
                "source": "橋上",
                "author": "――詩壇の議論家に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って清水のお貸元の身内になるんだ」　「石松、お前ん処の父っつあんあれで中々昔はやくざ仲間で鳴らした男だってね」　「何んだって、父っつあんがやくざ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはどう筆をつづくべきか、どう描き現すべきか、あれでぴつたりしてゐるか、あれでは力が足りないではないか、そんなことが絶えず一杯になつてゐたのであつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、あれで若しどつちかが斷然強くでもなつたとしたら、恐らく進まぬ方は憤然町内を蹴つて去つたかも知れない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも何もしないよりはましであろう。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おじいさんがなくなったのに、お母さんもつれずに、たった一人っきり、お父さんが帰っちゃったでしょう、あれで、もうすっかり、すべてが分るじゃないの。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こないだだって、靴直しに三円持って行って、あれで、一円くらいあまっとる筈だのに自分で取りこんどるんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
