[
  {
    "uuid": "0e9c8f69-a5f2-5455-9094-f2789cac06a3",
    "entry": "荒療治",
    "reading": {
      "primary": "あらりょうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
