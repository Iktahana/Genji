      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rough-and-ready (medical) treatment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒療治について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒療治という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒療治の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒療治が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒療治を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒療治について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒療治の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒療治の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒療治が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒療治という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒療治という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒療治についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒療治を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒療治は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒療治について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒療治が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒療治は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒療治の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒療治は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒療治は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "荒療治　（山本勝治氏）　ある港町の沖仲仕達を組織化しようとしてゐる一人のコンミユニストが、大事な仕事を前にして自分の固い決意の弛緩をふと意識する。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして以前やはりさうした時にとつた荒療治――そのときはカフエーで五人連の暴力團に喧嘩を賣つたのであるが――によつて再び鬪志を強めようと思ふ。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして拳鬪試合に飛び入りをすることが、書いてあるのだが、鬪志といふものがさうした亂暴な荒療治を必要とするものかどうか、それが主人公の稱してゐる如く唯物論的なものであるかどうかはしばらくおくとして、作品の重心がまるで劍劇のやうな立廻りに置かれてゐるといふことは馬鹿々々しい氣を起させる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ、荒療治で、あっさりと無断で失敬して行っちまおうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯科医術のまだ幼稚な明治十年代のことであるからずいぶん乱暴な荒療治であったことと想像される。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田藩には、これほどに思い切った荒療治をなさる知恵者がお出でにならぬものと見限っておりましたのが私の不覚……お蔭で襟半と蔵元屋の御両家、千秋万楽と祈り上げておりました私の楽しみも、茶々苦茶羅になってしまいました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位な荒療治で、寝汗一つ取れる奴か。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "質の悪い肉の癒着は荒療治でも容赦なく截り分けなければならない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この荒療治のおかげで、不幸にも蘇武は半日｜昏絶したのちにまた息を吹返した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、我々が手を下すに至った荒療治の計画の大部分は彼の頭の産み出したものであり、自分はただ局部的に意見を与えたに過ぎないのだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また荒療治をやるかな」　揉あげがそれに応じた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえはだんだんしわがふえる、反対に、かわいい男はますます若返って、いろいろとほかの女どもからちやほやされる、いっそこのままほっておくより――というようなあさはかな考えから、ついつい荒療治をするなんてこたあ、よくある手だからね」「いかにもしかり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "手先に使っておったあの五人の川船頭が、漏らしてならねえ秘密を漏らしそうになったんで、荒療治をやったのよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "久方ぶりに、だんなも荒療治をおやんなさいましたな」「あたりめえだ」　吐き出すようにつぶやくと、毒手にかかった女たちをあわれむように、黙々と目をとじました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒療治でぎゅうとしめあげますぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒療治荒責めはおいらの手じゃねえんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいかわらず荒療治がおすきだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荒療治過ぎたかな？",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、一切の感情は卒業してしまつたから、ロビンの荒療治で退治てしまふ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体お蕗の灸なるものは特に神経系統に効目が露はであるとかで、相当の重患者でもない限りは施療を乞はなかつたが、私は幼時にたつた一度、私の先々代が荒療治を施された光景を印象強く覚えてゐるのだ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度も汽車のなかで心安くなった横浜の糸商人をうまく引っ掛けて、越後の宿屋へくわえ込んだのだが、仕事がどうも思うようにいかなかったと見えて、とうとう荒療治を考えてその男に劇薬をのませて、所持金を引っさらって逃げ出した。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いつも『脳味噌をつめ替えろ』と叱られた狂人が、とうとう狂人らしい率直さから、その教えを実行してしまった、と見せかけて、実は逆に狂人のほうを殺して、自分が死んだような振りをするなんて……成る程、荒療治で脳味噌をとったりすれば、顔なぞ誰の顔だか判らなくなってしまいますからね。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして氣がついて見た時にはもうその矛盾は荒療治をしなくちや解決の出來ないものになつて了つてゐた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必要ならばどうにも仕方がないから荒療治でもなんでもやりませうよ。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随分荒療治ですな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光のなかで荒療治が行なわれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は彼女を紹介する外科のある大家のこともひそかに考えていたが、田舎での不用意な荒療治が、すっかり葉子を懲りさせていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような荒療治をともかく強行し得るということ自体がすでにスターリン政権とソヴェートの統一との鞏固さを示しているといい得る。",
              "citation": {
                "source": "政治の論理と人間の論理",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつの間にやら僕は、君らに荒療治をされていたんだね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ一度はここまで来る筈ですから……チット荒療治ですけど……ホホホ……」「……イ……イケナイ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
