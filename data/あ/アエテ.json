[
  {
    "uuid": "7faae616-dc5a-57ff-8ff8-4dfd20fd3824",
    "entry": "敢えて",
    "reading": {
      "primary": "あえて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "purposely (of something needless, unexpected or seemingly counterproductive, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で、「敢えて」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "季節の変化とともにこの傾向が顕著になる。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からこの風習が形成された。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中でこれは欠かせない材料とされている。",
              "source": "幻辞"
            },
            {
              "text": "観光地を訪れる際にこのポイントを押さえておくべきだ。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で、「敢えて」をよく耳にする。",
              "source": "幻辞"
            },
            {
              "text": "経済ニュースで取り上げられることが増えている。",
              "source": "幻辞"
            },
            {
              "text": "学者たちはこの現象について議論を続けている。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中でも重要なテーマとして扱われている。",
              "source": "幻辞"
            },
            {
              "text": "大学の講義でこの理論が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "医師の指導のもとでこの方法が推奨されている。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題として議論されている。",
              "source": "幻辞"
            },
            {
              "text": "娯楽としてこの活動は人気が高い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "敢えて農作関係ばかりとは限らず、系統的な海洋観測が我邦のような海国にとっては軍事上からも水産事業のためにも非常に必要であるということは、実に分りきったことであるが、この分り切ったことがどういう訳か昔の日本の政府の大官には永い間どうしても分らなかったのである。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点において、プラトンの認識論の倒逆的転換が敢えてなされなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はことし既に三十九歳になるのであるが、私のこれまでの文筆に依って得た収入の全部は、私ひとりの遊びのために浪費して来たと言っても、敢えて過言ではないのである。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その短篇集の著者が、万世一系かどうか、それは彼の言論の自由のしからしむるところであろうから、敢えて不問に附するとしても、それに較べて私が乞食だという彼の断案には承知できないものがあった。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えてここに記して置く。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えて新しいのを買えとはいわぬ。",
              "citation": {
                "source": "白い下地",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか殺そうとまで計画しなかったけれども、そんなに義理人情を弁えない兄夫婦であるならば、その無節操な嫂に対して敢えて不倫を行ったところで、自分の良心に恥ずべきところは些もない筈だと考えて、窃に機会を待つことにした。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、最初からお前達の不義を待ち構えて、ただそれだけの理由で、お前たちをペテンに掛けるために計画的な結婚を敢えてしたのでもあるかのような気持にさえなった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自分は、父がそのお獅子を自分に買って与えたいのだという事に気がつき、父のその意向に迎合して、父の機嫌を直したいばかりに、深夜、客間に忍び込むという冒険を、敢えておかしたのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃になると、自分も、敢えて堀木の案内に頼らずとも、ひとりで電車にも乗れるし、また、歌舞伎座にも行けるし、または、絣の着物を着て、カフエにだってはいれるくらいの、多少の図々しさを装えるようになっていたのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えて責めるべき事で無いかも知れない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、麻川氏の部屋と敢えて書くのは、この頃の麻川氏の部屋は、大川赫子によって殆ど領されて居る形であって最もよく混成された麻川氏と赫子の意志が、麻川氏の部屋の意志と呼んで好いような気さえする。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六、死は敢えて厭うところのものに非ず。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一箇条、敢えて剣聖にゆずらじと思うものの、また考えてみると、死にたくない命をも捨てなければならぬところに尊さがあるので、なんでもかんでも死にたくて、うろうろ死場所を捜し廻っているのは自分勝手のわがままで、ああ、この一箇条もやっぱり駄目なり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄村先生とは、どんな御人物であるか、それに就いては、以前もしばしば御紹介申し上げた筈であるから、いまは繰り返して言わないけれども、私たち後輩に対して常に卓抜の教訓を垂れ給い、ときたま失敗する事があるとはいうものの、とにかく悲痛な理想主義者のひとりであると言っても敢えて過称ではなかろうと思われる。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言っても、それも嘘で、私は私なりに「徒党」の苦しさが予感せられ、むしろ「孤低」を選んだほうが、それだって決して結構なものではないが、むしろそのほうに住んでいたほうが、気楽だと思われるから、敢えて親友交歓を行わないだけのことなのである。",
              "citation": {
                "source": "徒党について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの心裡の説明は、その御当人にさえうまく出来ないものらしいし、まして私のような鈍才無学の者には、他人の気持など、わかりっこないのであるが、しかし、巷説の魯迅の転機は、私にはどうしても少し腑に落ちないところがあるので、敢えて苦手の理窟を大骨折りで述べて見た次第である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリメ、ゴオゴリほどの男でも、その生存中には、それを敢えてしなかったし、後世の人こそ、あの小説の悪魔は、ゴオゴリ自身であるとか、メリメその人の残忍性であるとか評して、それはもう古典になれば、どちらでもかまわないことなのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、人間の名誉というものを重んずる方針なのだから、敢えて、盗んだとは言いません。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、貴下の潔癖が私のこのやりかたを又怒られるのではないかとも一応は考えてみましたが、私の気持ちが純粋である以上、若しこれを怒るならばそれは怒る方が間違いだと考えて敢えてこの御知らせをする次第です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひれ伏す心で願うけれども、誰も教えては呉れない、誰も敢えては呉れない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけを敢えてよ」と穏かに訊きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生百般――と、敢えて大きく出ぬまでも、凡そ人間の成すべきことにして、不正、不義、傲慢のこの三つを除いたありとあらゆる中で、この佐助に能わぬことが、耳かきですくう程もあれば言ってみろ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えてその権謀術策を挙げよというなら、間もなくおれが智慧をしぼって考えだした支店長募集など、そのひとつだろう。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これとても全然はなからの計画ではなく、冷酷といってしまえばそれまでだが、敢えて「あばく」に足るほどのことでもなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとに儲けさせるのはうまいが、自身で儲けるぶんにはからきし駄目で、敢えて悪銭とはいわぬが、身につかなかったわけだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の恋に対する私の確信が私を勇気づけて、そのような戦慄すべき仕事を敢えてさしたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって自ら筆を取り、あえて大胆にこの書をあらわし、著者の見たる「新しき蕪村」を紹介しようと思うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は三人の同窓の死だけから他のものの死の機会を推算するような不合理をあえてしようとは思わない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて蠅に限らず動植鉱物に限らず、人間の社会に存するあらゆる思想風俗習慣についても、やはり同じようなことがいわれはしないか。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
