        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            },
            {
              "text": "スポーツを通じてチームワークを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "エンターテインメント産業は多様な作品を提供する。",
              "source": "幻辞"
            },
            {
              "text": "競技選手たちの努力は称賛に値する。",
              "source": "幻辞"
            },
            {
              "text": "娯楽施設の利用客は増加傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツイベントは地域を活性化させる。",
              "source": "幻辞"
            },
            {
              "text": "選手のトレーニングは厳しく行われている。",
              "source": "幻辞"
            },
            {
              "text": "試合の結果は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "ファンの応援が選手を鼓舞する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツマンシップが重要視される。",
              "source": "幻辞"
            },
            {
              "text": "娯楽は人生のバランスを保つために必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "五平　諦めのいい事もあるまいが、まあ、まあ、そう思って無理に諦めるより外はあるまいよ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めのいい幽霊と言わなければならない。",
              "citation": {
                "source": "妖異むだ言",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　どうもお前の諦めのいいのには驚かされる。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り諦めのいいことはまず誰にも負けないし――といってこれは余り自慢になる性格じゃないが――しょっちゅう早合点をして頭を掻いてばかりいるのだ。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は当然拒絶を承知した諦めのいい集金人のように、その頃私は仏教を勉強する堕落生であったが、さながら魚のように機嫌よく街を泳いで埃を浴びていた。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めのいい家庭の二三は既にそれぞれ他へ住居を契約して、長屋からして泣く泣く移転したくらいである。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は気軽な人物で何事もあきらめのよいたちだから文句はない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三の心持ちでは、荻生さんのようなあきらめのよい運命に従順な人は及びがたいとは思うが、しかしなんとなくあきたらないような気がする。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらめのよい彼は、唯一人広い歌舞伎座の舞台に、輝く金屏風を後にして、改名披露の口上を、自分自ら述べたのである。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
