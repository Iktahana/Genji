          ],
          "literary": [
            {
              "text": "「ちきしょう、あの手この手を出しやがらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "クルベルは、夫人をしつこく口説くのであるが、その、あの手この手は悉く男爵家の陥っている経済的困難を中心とする脅威であり、誘惑である。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手この手と計画をしながら、気ぶりも初めにお見せにならなかったと中の君は恨んでいて、姉の女王と目を見合わせようともしない。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった風な、あの手この手を用いて第一位を獲得したような婦人の憤激を買うようなことがあったら、それこそ大変である！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人自身は、宣伝下手なことを一つの美徳として自ら慰め、その実、ひそかにあの手この手を考へてゐるわけだが、これまた道徳とは関係のないことで、世界の良心と人間の本性とをよく知り、しかも、日本人としての真実にみちた表現を、相手国の活きた言葉で綴り得る人物がその衝に当つてゐないといふだけである。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手この手「痛い、痛い」牛丸少年は宙吊りになった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手この手と、まだやることはたくさんある」「この上、金の奴に一分間でも余計に生きていられては、余の面目にかかわる」「さわぐな。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども日本にナブリ殺しや拷問がなかったわけではなく、特に切支丹の拷問では、あの手この手の変化の数々において世界無比のところがあったかも知れない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "モグリの商事会社もやっているし、あの手この手のイカサマ、きわどいところで法網をくぐっているのがフシギなくらい。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ主人が亡くなったの、やれ気分がどうのって、あの手この手でおいでなさる……支配人がどこぞお出かけですってか。",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はあとからあとから生れて来るもんだで」　そんなふうに彼はごまかして母親の口をつぐませはするが、なにしろ毎日顔をつき合せている間柄なので、あの手この手で攻めたてられるのには、彼も少々業をにやしはじめた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊る宗教唄ふ宗教――、人間の官能を興奮させたり、異常な祈りを神聖視して、人を催眠術的に陶醉させる宗教など、昔も今も、あの手この手に變りはありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱し念佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、司令官はあの手この手を使って、あなたを色々質問責めにするでしょう。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常生活の中でのあの手この手が、一口にナイフと呼ばれるものの中にかくされているのだ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくあの手この手はもうあんな鈍感には効かないの。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、妻子ある男が浮気の相手に、あの手この手で誘ってくるとか。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「寄手の苦計も、いよいよあの手この手と、足掻くだろう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの角は、直後、敵の玉囲イへ迫らんとして、あの手この手、どう、その屋島を、突きくずさんかに、苦心しているところなのだ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
