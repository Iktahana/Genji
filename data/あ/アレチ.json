[
  {
    "uuid": "78728260-5bbc-5d38-b94c-7435f2b3a220",
    "entry": "荒地",
    "reading": {
      "primary": "あれち",
      "alternatives": [
        "こうち"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
