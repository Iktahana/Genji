      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wasteland",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日荒地について考えている。",
              "source": "幻辞"
            },
            {
              "text": "荒地という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は荒地の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には荒地が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "荒地を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは荒地について学習した。",
              "source": "幻辞"
            },
            {
              "text": "荒地の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は荒地の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では荒地が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "荒地という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に荒地という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では荒地についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "荒地を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると荒地は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "荒地について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では荒地が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に荒地は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により荒地の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "荒地は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に荒地は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何か云いたいようでしたが黙って俄かに向うを向き、今まで私の来た方の荒地にとぼとぼ歩き出しました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒地の中で建築の骨組だけ見せられているような気持になることが多い。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の荒地、嶮岨に似ず、坂の表面はきめのこまかい赤土で小石が、いくらか散らばつただけの柔和な傾斜面だつた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、北陸線の通じなかつた時分、舊道は平家物語、太平記、太閤記に至るまで、名だたる荒地山、歸、虎杖坂、中河内、燧ヶ｜嶽。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも段々年をとっては、せめて起臥をわが家でしたいのが人の通情であるから、保胤も六条の荒地の廉いのを購って、吾が住居をこしらえた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この荒地の、まばら垣と向合ったのが、火薬庫の長々とした塀になる。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石州浜田六万四千石……船つきの湊を抱えて、内福の聞こえのあった松平｜某氏が、仔細あって、ここの片原五万四千石、――遠僻の荒地に国がえとなった。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "放題の荒地で、雑草は、やがて人だけに生茂った、上へ伸び、下を這って、芥穴を自然に躍った、怪しき精のごとき南瓜の種が、いつしか一面に生え拡がり、縦横無尽に蔓り乱れて、十三夜が近いというのに、今が黄色な花ざかり。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年目には田地も取返し、畑は以前より殖え、山懷の荒地は美事な桑園と變じ、村内でも屈指の有富な百姓と成り終せたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）荒地菊むせぶいきれを、おのづから催すか、また。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭も広過ぎて、とても掃除や草取りが満足には出来そうもないというので、庭の中程に低い四目垣を結って、その垣の内だけを庭らしくして、垣の外はすべて荒地にして置いたので、夏から秋にかけてはすすきや雑草が一面に生い茂っている。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前共も怖おう御座んしたが、思い切ってその荒地の中へ立ち入りまして、スッカリ見て参じました。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒地を他人のために開墾したのかい？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると向こうから、姫苦蓬や荒地野菊の雑叢の間を、静枝が此方ヘ歩いて来るのだった。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にあの一方は、チャーリントンの荒地で、その一方はチャーリントンの廃院を包む森の間の、一｜哩ばかりの間と云うものは、とても寂しいのでございますの。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ございません」「それではその者は、どっちかの側に、遁げこんだのでしょう、――」「もしそうだとすれば、それは荒地の方なはずはありません。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだどこかしら、調教師が何かわけありで馬を朝の運動に連れ出したと思われていたのだが、母屋そばの小さな丘に上がってみると、そこから付近の荒地が見渡せるものの、いずこにも名馬の影すら見えないばかりか、ただならぬ事に出くわしたのではという何やら不吉な予感がする。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの暗く一帯に暮れて行く荒地の行く道には、そここゝに笹の根や木の株、草や木の枝などを焼く火が、はっきりと見えて、山道とはいうものゝ少しも淋しくない。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒地野菊が地肌を掩い、姫昔蓬が麻畠のように暗い林になって立った。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　斯う、彼等は、屋敷続きの荒地のことも忘れてはいなかった。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行動」の阿部知二作、荒地は、仲々の力作で、わたしはこの作者のものは、これがはじめてゞすが、もつとはやくから読めば好かつたと思はせられました。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒地に水を漑ぐを得、これに樹を植えて植林の実を挙ぐるを得ば、それで事は成るのであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしユトランドの荒地がサハラの沙漠のごときものでありましたならば問題ははるかに容易であったのであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてユトランドの荒地はこの種の荒地であったのであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし難中の難事は荒地に樹を植ゆることでありました、このことについてダルガスは非常の苦心をもって研究しました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物界広しといえどもユトランドの荒地に適しそこに成育してレバノンの栄えを呈わす樹はあるやなしやと彼は研究に研究を重ねました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして彼の心に思い当りましたのはノルウェー産の樅でありました、これはユトランドの荒地に成育すべき樹であることはわかりました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユトランドの荒地は今やこの強梗なる樹木をさえ養うに足るの養分を存しませんでした。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はかすかな旅情らしいものが、濃くあたりに漂っているあれちのぎくの匂いに混じって、自分の心を染めているのを感じた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんだが俺れ旦那に云あれてから、家族の奴等ことも怒んねえはあ、俺れうめえ處見られつちやつたな、いや云あれちや勿體ながす、本當に勿體ねえだよ、お婆さん」爺さんは首を俛て滅切靜かになつていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
