        "examples": {
          "standard": [
            {
              "text": "私は毎日甘粕について考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘粕という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘粕の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘粕が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘粕を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘粕について学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘粕の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘粕の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘粕が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘粕という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘粕という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘粕についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘粕を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘粕は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘粕について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘粕が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘粕は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘粕の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘粕は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘粕は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "只、甘粕近江守は妻女山の北赤坂山に止り、後押として敵を警戒しつつ、十二ヶ瀬を渡って小森附近に止った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘粕隊は遠く南方小森に於て妻女山から来るべき敵に備えた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、最も近い徒渉場たる十二ヶ瀬を渡ろうと急ぐや、越の殿軍甘粕近江守は川辺の葦間から一斉に鉄砲の雨をあびせたので、甲州兵悩まされながら、川の上下、思い思いに雨の宮の渡猫ヶ瀬等から川を渡り北進した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "越の殿軍甘粕近江守景持は部下を集めて最後に退却をおこした。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "高坂は妻女山より自分の持城たる海津城を気づかってこれに向い、それより八幡原に出たので、時すでに敵を犀川方面に追討している時だったので、甘粕隊をみてよき敵にがすなとばかりどっと突撃した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘粕隊は時々逆襲しつつ犀川を渡り、悠々左岸の市村に陣取り大扇の大纏を岸上に高く掲げて敗兵を収容した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この甘粕隊の殿軍ぶりはながく川中島合戦を語るものの感嘆する所である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年九月記　○大正十三年十月補筆　○改造社出版『大正大震火災誌』中所掲「甘粕対大杉事件」参照）追記　大杉が警察のスパイであって主義者の秘密を供給していたので、大杉殺害が警察と陸軍との反目になったという噂が当時或る一部に広がった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘粕石介氏の論文「芸術の写実について」（『学芸』一九三八年第七一号）はこの弱点を指摘して若干の優れた発見を与えている。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今文芸学樹立のために動員すべき専門の会員を挙げて見ると、江口渙、森山啓、窪川鶴次郎、中野重治、新島繁、甘粕石介、高沖陽造、本間唯一、伊豆公夫、徳永泰を始めとして、決して人数と力量に不足はないと思う。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキズムの指導者として、クロポトキンの「革命家の思い出」ロマン・ローランの「民衆芸術論」の翻訳などのあった大杉栄がその妻伊藤野枝と幼い甥の宗一と一緒に、憲兵隊につれてゆかれ甘粕憲兵大尉とその部下によって縊殺された。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十四五日より大杉栄ほか二名が、甘粕大尉に殺された話やかましく新聞に現れた。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　甘粕事件　公判開始　十月二十日　白菊の盛、蠅多き秋○国男折角来たのに「居たって何にもなりゃしない」　翌年　仕事をし始める。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは桜田烈士、中岡｜艮一、甘粕大尉、五・一五や二・二六事件の所謂、志士たち。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは桜田烈士、中岡艮一、甘粕大尉、五・一五や二・二六事件の所謂、志士たち。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、無政府主義者大杉栄は甘粕といふ憲兵大尉に惨殺され、また南葛労働組合の幹部であつた平沢計七、河合義虎等数名の者も亀戸で惨殺され、更に無名の朝鮮人で何の謂はれもなく惨殺された者は無数に上ぼつたが、かうした事件は恐らく難波大助に少からざる刺戟を与へたものであらう。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし此の判決文が新聞紙にでも掲載されようものなら、私はとくの昔し甘粕大尉のやうな人に、何遍殺されてゐるか知れないのだ。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘粕大尉の大杉栄を殺し、中岡｜艮一の原敬を刺せるも皆この時代の風潮に従へるものと言はざるべからず。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくと見た同治療場の監視人で柔道四段の力量を有する甘粕藤太氏は、直ちに急を呼びつつ場内に駆け入ったが、時既に遅く、場内に居った政治狂の某、及、敬神狂の某の二名は、少女シノを救うべく呉一郎に肉迫すると見る間に、前者は横頬を、後者は前額部を呉一郎の鍬の刃先にかけられ、朱に染まって砂の上に昏倒した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に辛うじて意識を回復した甘粕氏は苦痛を忍びつつ起き上り、場の入口を開いて逃げ迷うていた狂人たちを外へ出すと、又も安心のためか気が遠くなって打ち倒れた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇怪な謎　　　　　狂少年の一語右に就て同解放治療場の監視人であった甘粕藤太氏は、負傷した胸部に繃帯を施したまま市内｜鳥飼村自宅に於てかく語った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（次いで正木博士の自殺を告げ死因に就ての心当りを問えば甘粕氏は愕然蒼白となり流涕して唇を震わしつつ）それは本当ですか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった三人ではあったが東京の岡田子爵、越後の甘粕少将、京都の林男爵と、世間知らずの金持華族や、軍人上りの富豪なぞと次から次に結婚して、みんなお前のお得意のコカインの中毒患者にして次から次に自殺みたいな死に方をさせてしまった。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の岡田雪子、新潟の甘粕花子、京都の林百合子という三つの変名も、今のお前の変名と一緒に知っているんだ。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根の打懸纏いを押立てて一手の軍の寄せ来たるは、これぞ越後名代の勇将甘粕備前守と知られたり」　木戸番うつむいて煙草ばかり喫っている。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又わきに一かたまりの中老人、口をきわめて、社会主義を罵倒し、甘粕の行為を賞めたたえて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、甘粕事件の公判開始、世人の痛ましい好奇心をそそること大だ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十六日に、憲兵大尉の甘粕、大杉栄、野枝、甥、宗一を縊り死して、証拠をかくそうとした事件。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大震災直後、かの甘粕大尉によつて大杉栄、伊藤野枝の殺害さるるや、出来星のルパシカ青年は忽ちにして影を秘めてしまつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
