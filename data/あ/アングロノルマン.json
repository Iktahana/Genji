        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アングロノルマンについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアングロノルマンの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアングロノルマンが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアングロノルマンについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアングロノルマンの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアングロノルマンが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアングロノルマンという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアングロノルマンについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアングロノルマンは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアングロノルマンが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアングロノルマンは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアングロノルマンの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アングロノルマンは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアングロノルマンは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
