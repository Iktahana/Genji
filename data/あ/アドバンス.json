    "definitions": [
      {
        "index": 1,
        "gloss": "advance (forward movement)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アドバンスについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアドバンスの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアドバンスが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアドバンスについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアドバンスの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアドバンスが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアドバンスという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアドバンスについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアドバンスは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアドバンスが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアドバンスは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアドバンスの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アドバンスは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアドバンスは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんな錯乱のさなかの一九九一年四月九日、コンパックとマイクロソフト、そしてＵＮＩＸで勝負をかけるサンタクルズオペレーションを始めとする二十一社が、新しい先進的プラットフォームと銘打った、ＡＣＥ（アドバンスト・コンピューティング・エンバイロメント）構想に取り組むと発表してオレの錯乱に拍車をかけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁を突き崩した反逆者の名は、ＡＭＤ（アドバンスト・マイクロ・デバイシズ）である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電機学校にはアドバンス・コピーというものがあり、教師の講義を直接に聴くの必要はなく、通学の時間を毎日一ツ橋図書館に利用し、学校の方は試験だけを受けて進級していた。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内版の発表に合わせて、アドバンスト・パーソナル・コンピュータ（ＡＰＣ）と名付けてアナウンスするこのマシンの売り物として、端末グループはＩＢＭの大型用端末３２７８の機能を備えている点と、ＣＰ／Ｍ―86とＭＳ―ＤＯＳの採用を強調しようとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
