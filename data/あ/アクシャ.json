          ],
          "literary": [
            {
              "text": "山の祖神の翁は、泣いていいか笑っていいか判らない気持にされながら、かがり火越しに幄舎の方を観る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳神の家は幄舎に宛てられていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞観の時は東西南の歩廊及び軒廊に千僧の床を設けたが、天平の時にはまだ歩廊ができていなかったので、それだけ多くの幄舎を設ける必要があったのかも知れない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍軍楽隊は西洋風の音楽をやり、別の幄舎では宮廷楽師達が、その特有の楽器を用いて、日本の音楽を奏していた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこだけは、幄舎形に、屋根や袖部屋の設けもあった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、何か道誉の打合せが来て、二将は、彼の待つ神社の横の幄舎へかくれた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと斜めに小襟を突き上げると、　はあくしゃん！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
